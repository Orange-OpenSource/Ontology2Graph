@prefix ex: <http://example.com/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sc: <http://pygraf.t/> .

ex:entityA a sc:C1 ;
    rdfs:label "Entity A" ;
    rdfs:comment "An instance of C1, acting as a central node." ;
    sc:R3 ex:entityB .

ex:entityB a sc:C3 ;
    rdfs:label "Entity B" ;
    rdfs:comment "An instance of C3, connected to entityA." ;
    sc:R2 ex:entityA .

ex:entityC a sc:C5 ;
    rdfs:label "Entity C" ;
    rdfs:comment "An instance of C5, connected to entityD." ;
    sc:R6 ex:entityD .

ex:entityD a sc:C7 ;
    rdfs:label "Entity D" ;
    rdfs:comment "An instance of C7, connected to entityC and part of the C6 subclass." ;
    a sc:C6 ;
    sc:R8 ex:entityC .

ex:entityE a sc:C2 ;
    rdfs:label "Entity E" ;
    rdfs:comment "An instance of C2, connected to entityF and entityG, acting as a connector node." ;
    sc:R9 ex:entityF, ex:entityG .

ex:entityF a sc:C2 ;
    rdfs:label "Entity F" ;
    rdfs:comment "An instance of C2, connected to entityE." ;
    sc:R9 ex:entityE .

ex:entityG a sc:C2 ;
    rdfs:label "Entity G" ;
    rdfs:comment "An instance of C2, connected to entityE." ;
    sc:R9 ex:entityE .

ex:entityH a sc:C9 ;
    rdfs:label "Entity H" ;
    rdfs:comment "An instance of C9, connected to itself and entityI, acting as a high-degree node." ;
    sc:R4 ex:entityH, ex:entityI .

ex:entityI a sc:C9 ;
    rdfs:label "Entity I" ;
    rdfs:comment "An instance of C9, connected to entityH and itself." ;
    sc:R4 ex:entityH, ex:entityI .

ex:entityJ a sc:C10 ;
    rdfs:label "Entity J" ;
    rdfs:comment "An instance of C10, connected to entityK." ;
    sc:R10 ex:entityK .

ex:entityK a sc:C4 ;
    rdfs:label "Entity K" ;
    rdfs:comment "An instance of C4, connected to entityJ." .

ex:entityL a sc:C8 ;
    rdfs:label "Entity L" ;
    rdfs:comment "An instance of C8, with no connections." .

ex:entityM a sc:C1 ;
    rdfs:label "Entity M" ;
    rdfs:comment "An instance of C1, connected to itself." ;
    sc:R1 ex:entityM .

ex:entityN a sc:C5 ;
    rdfs:label "Entity N" ;
    rdfs:comment "An instance of C5, connected to itself." ;
    sc:R5 ex:entityN .

ex:entityO a sc:C7 ;
    rdfs:label "Entity O" ;
    rdfs:comment "An instance of C7, connected to itself." ;
    sc:R7 ex:entityO .
