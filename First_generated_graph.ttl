 @prefix ex: <http://example.com/> .
 @prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
 @prefix sc: <http://pygraf.t/> .

 ex:entityA a sc:C1 ;
  rdfs:label "Entity A (C1)" ;
  rdfs:comment "An instance of class C1, acting as a connector node." ;
  sc:R3 ex:entityB .

 ex:entityB a sc:C3 ;
  rdfs:label "Entity B (C3)" ;
  rdfs:comment "An instance of class C3, linked to entityA via R3." ;
  sc:R2 ex:entityA .

 ex:entityC a sc:C5 ;
  rdfs:label "Entity C (C5)" ;
  rdfs:comment "An instance of class C5, linked to entityD via R6." ;
  sc:R6 ex:entityD .

 ex:entityD a sc:C7 ;
  rdfs:label "Entity D (C7)" ;
  rdfs:comment "An instance of class C7, linked to entityC via R8." ;
  sc:R8 ex:entityC .

 ex:entityE a sc:C2 ;
  rdfs:label "Entity E (C2)" ;
  rdfs:comment "An instance of class C2, linked to itself via R9." ;
  sc:R9 ex:entityE .

 ex:entityF a sc:C10 ;
  rdfs:label "Entity F (C10)" ;
  rdfs:comment "An instance of class C10, linked to entityG via R10." ;
  sc:R10 ex:entityG .

 ex:entityG a sc:C4 ;
  rdfs:label "Entity G (C4)" ;
  rdfs:comment "An instance of class C4, linked to entityF via R10 (range)." .

 ex:entityH a sc:C9 ;
  rdfs:label "Entity H (C9 - Hub Node)" ;
  rdfs:comment "A hub node of class C9, connected to multiple other C9 instances via R4." ;
  sc:R4 ex:entityI, ex:entityJ .

 ex:entityI a sc:C9 ;
  rdfs:label "Entity I (C9)" ;
  rdfs:comment "An instance of class C9, linked to entityH via R4." ;
  sc:R4 ex:entityH .

 ex:entityJ a sc:C9 ;
  rdfs:label "Entity J (C9)" ;
  rdfs:comment "An instance of class C9, linked to entityH via R4." ;
  sc:R4 ex:entityH .

 ex:entityK a sc:C6 ;
  rdfs:label "Entity K (C6)" ;
  rdfs:comment "An instance of class C6, which is a subclass of C8." .

 ex:entityL a sc:C8 ;
  rdfs:label "Entity L (C8 - High-Degree Node)" ;
  rdfs:comment "A high-degree node of class C8, connected to many other entities." .

 ex:entityM a sc:C1 ;
  rdfs:label "Entity M (C1 - Central Node)" ;
  rdfs:comment "A central node of class C1, connected to multiple C3 instances." ;
  sc:R3 ex:entityN, ex:entityO .

 ex:entityN a sc:C3 ;
  rdfs:label "Entity N (C3)" ;
  rdfs:comment "An instance of class C3, linked to entityM via R2." ;
  sc:R2 ex:entityM .

 ex:entityO a sc:C3 ;
  rdfs:label "Entity O (C3)" ;
  rdfs:comment "Another instance of class C3, linked to entityM via R2." ;
  sc:R2 ex:entityM .

 ex:entityP a sc:C5 ;
  rdfs:label "Entity P (C5 - Intermediary Node)" ;
  rdfs:comment "An intermediary node of class C5, connecting C7 instances." ;
  sc:R6 ex:entityQ .

 ex:entityQ a sc:C7 ;
  rdfs:label "Entity Q (C7)" ;
  rdfs:comment "An instance of class C7, linked to entityP via R8." ;
  sc:R8 ex:entityP .

 ex:entityR a sc:C10 ;
  rdfs:label "Entity R (C10 - Multiplex Node)" ;
  rdfs:comment "A multiplex node of class C10, connected to both C4 and other C10 instances." ;
  sc:R10 ex:entityS .

 ex:entityS a sc:C4 ;
  rdfs:label "Entity S (C4)" ;
  rdfs:comment "An instance of class C4, linked to entityR via R10." .

 ex:entityT a sc:C9 ;
  rdfs:label "Entity T (C9 - Super Node)" ;
  rdfs:comment "A super node of class C9, with multiple connections and properties." ;
  sc:R4 ex:entityU .

 ex:entityU a sc:C9 ;
  rdfs:label "Entity U (C9)" ;
  rdfs:comment "An instance of class C9, linked to entityT via R4." ;
  sc:R4 ex:entityT .
