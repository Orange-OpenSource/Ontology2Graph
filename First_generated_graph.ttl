```turtle
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sc:entityA a sc:C3 ;
    rdfs:label "Entity A"@en ;
    rdfs:comment "An instance of class C3, representing a project."@en ;
    sc:R2 sc:entityB .

sc:entityB a sc:C1 ;
    rdfs:label "Entity B"@en ;
    rdfs:comment "An instance of class C1, representing a task."@en ;
    sc:R3 sc:entityA .

sc:entityC a sc:C5 ;
    rdfs:label "Entity C"@en ;
    rdfs:comment "An instance of class C5, representing a developer."@en ;
    sc:R6 sc:entityD .

sc:entityD a sc:C7 ;
    rdfs:label "Entity D"@en ;
    rdfs:comment "An instance of class C7, representing a feature."@en ;
    sc:R8 sc:entityC .

sc:entityE a sc:C2 ;
    rdfs:label "Entity E"@en ;
    rdfs:comment "An instance of class C2, representing a team."@en ;
    sc:R9 sc:entityF, sc:entityE .

sc:entityF a sc:C2 ;
    rdfs:label "Entity F"@en ;
    rdfs:comment "Another instance of class C2, representing another team."@en ;
    sc:R9 sc:entityE, sc:entityF .

sc:entityG a sc:C9 ;
    rdfs:label "Entity G"@en ;
    rdfs:comment "An instance of class C9, representing a resource."@en ;
    sc:R4 sc:entityH, sc:entityG .

sc:entityH a sc:C9 ;
    rdfs:label "Entity H"@en ;
    rdfs:comment "Another instance of class C9, representing another resource."@en ;
    sc:R4 sc:entityG, sc:entityH .

sc:entityI a sc:C10 ;
    rdfs:label "Entity I"@en ;
    rdfs:comment "An instance of class C10, representing a department."@en ;
    sc:R10 sc:entityB .

sc:entityJ a sc:C6 ;
    rdfs:label "Entity J"@en ;
    rdfs:comment "An instance of class C6, representing a sub feature."@en ;
    sc:R1 sc:entityJ .
```