@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, managing multiple links."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical junction."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node representing a superordinate network component."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A core network resource, such as a server or switch."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:resourceLogisticId "LOG-RES-001"^^xsd:string ;
  noria:resourceHostName "host-resource1"^^xsd:string ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://example.com/resourceType/physical> ] .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual resource, such as a virtual machine."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:resourceLogisticId "LOG-RES-002"^^xsd:string ;
  noria:resourceHostName "vm-resource2"^^xsd:string ;
  noria:locatedAtLocus <https://example.com/locus2> ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://example.com/resourceType/virtual> ] .

<https://example.com/locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Data center rack."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource 1."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:networkInterfaceType [ a skos:Concept ; skos:inScheme <kos/NetworkInterface/type> ; skos:hasTopConcept <https://example.com/networkInterface/type/physical> ] ;
  noria:networkInterfaceOperationalStatus [ a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; skos:hasTopConcept <https://example.com/operationalStatus/up> ] ;
  noria:networkInterfaceRoutingPriorityMetric 100 .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary network interface of Resource 2."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:networkInterfaceType [ a skos:Concept ; skos:inScheme <kos/NetworkInterface/type> ; skos:hasTopConcept <https://example.com/networkInterface/type/virtual> ] ;
  noria:networkInterfaceOperationalStatus [ a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; skos:hasTopConcept <https://example.com/operationalStatus/up> ] ;
  noria:networkInterfaceRoutingPriorityMetric 200 .

<https://example.com/NetworkLink1_extra_node_1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between Resource 1 and Resource 2."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:networkLinkId "NL-001"^^xsd:string ;
  noria:networkLinkType "Optical fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource1> noria:resourceManagedBy <https://example.com/SupportTeam> .

<https://example.com/SupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team responsible for network resources."@en .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating that eth0 interface of Resource 1 is up."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:loggingTime "2023-10-01T12:00:00Z"^^xsd:dateTime ;
  noria:logText "eth0 interface is now operational."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS> .

<https://example.com/NMS> a noria:Application ;
  rdfs:label "Network Management System"@en ;
  rdfs:comment "System monitoring network resources."@en .

<https://example.com/HubNode> noria:structuralElementObservable <https://example.com/Resource1> .

<https://example.com/HighDegreeNode> noria:structuralElementObservable <https://example.com/Resource2> .

<https://example.com/CentralNode> noria:structuralElementObservable <https://example.com/Resource1> .

<https://example.com/ConnectorNode> noria:structuralElementObservable <https://example.com/Resource2> .

<https://example.com/IntermediaryNode> noria:structuralElementObservable <https://example.com/Resource1> .

<https://example.com/MultiplexNode> noria:structuralElementObservable <https://example.com/Resource2> .

<https://example.com/SuperNode> noria:structuralElementObservable <https://example.com/Resource1> .

<https://example.com/Resource1> noria:structuralElementObservable <https://example.com/HubNode> .

<https://example.com/Resource2> noria:structuralElementObservable <https://example.com/HighDegreeNode> .

<https://example.com/Resource1> noria:structuralElementObservable <https://example.com/CentralNode> .

<https://example.com/Resource2> noria:structuralElementObservable <https://example.com/ConnectorNode> .

<https://example.com/Resource1> noria:structuralElementObservable <https://example.com/IntermediaryNode> .

<https://example.com/Resource2> noria:structuralElementObservable <https://example.com/MultiplexNode> .

<https://example.com/Resource1> noria:structuralElementObservable <https://example.com/SuperNode> .

<https://example.com/Resource2> noria:structuralElementObservable <https://example.com/SuperNode> .