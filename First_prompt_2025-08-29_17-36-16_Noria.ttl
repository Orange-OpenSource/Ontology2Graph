  rdfs:comment "Facilitates data flow."@en ;
  noria:structuralElementObservableData "IE-Flow" ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/MuxEntity> a noria:StructuralElement ;
  rdfs:label "Multiplex Entity"@en ;
  rdfs:comment "Handles multiple streams."@en ;
  noria:structuralElementObservableData "ME-Streams" ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/SuperEntity> a noria:StructuralElement ;
  rdfs:label "Super Entity"@en ;
  rdfs:comment "High-level aggregate node."@en ;
  noria:structuralElementObservableData "SE-Overview" ;
  noria:elementManagedBy <https://example.com/ManagementTeam> .