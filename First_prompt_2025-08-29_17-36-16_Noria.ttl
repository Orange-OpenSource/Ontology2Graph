@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData 12345 ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within the network topology."@en ;
  noria:structuralElementObservableData "CentralData" ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservableData "ConnectorData" ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservableData "IntermediaryData" ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservableData "MultiplexData" ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservableData "SuperData" ;
  noria:elementManagedBy <https://example.com/ManagementTeam> .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "A central hub with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData "HDN-001" ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network."@en ;
  noria:structuralElementObservableData "CN-Alpha" ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservableData "CN-Connector" ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node facilitating data transfer between segments."@en ;
  noria:structuralElementObservableData "IN-DataFlow" ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservableData "MN-Streams" ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple sub-nodes for high-level management."@en ;
  noria:structuralElementObservableData "SN-Overview" ;
  noria:elementManagedBy <https://example.com/ManagementTeam> .

<https://example.com/HubNodeEntity> a noria:ManagedElement ;
  rdfs:label "Hub Node Entity"@en ;
  rdfs:comment "A hub node with extensive connections."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/HighDegreeEntity> a noria:StructuralElement ;
  rdfs:label "High-Degree Entity"@en ;
  rdfs:comment "Node with high degree of connectivity."@en ;
  noria:structuralElementObservableData "HDE-002" ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/CentralEntity> a noria:StructuralElement ;
  rdfs:label "Central Entity"@en ;
  rdfs:comment "A central node in the topology."@en ;
  noria:structuralElementObservableData "CE-XYZ" ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/ConnectorEntity> a noria:StructuralElement ;
  rdfs:label "Connector Entity"@en ;
  rdfs:comment "Node connecting different segments."@en ;
  noria:structuralElementObservableData "CNE-Connect" ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/IntermediaryEntity> a noria:StructuralElement ;
