@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity, acting as a central point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/centralNode_extra_node_11> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node serving as a core component in the network topology."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node facilitating data flow between primary nodes."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An aggregated node representing a superordinate network component."@en ;
  noria:structuralElementObservableData <https://example.com/superNodeCapacity> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes."@en .

<https://example.com/latencyMeasurement> a noria:Property ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Average latency in milliseconds for the node."@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Current traffic volume in Mbps."@en .

<https://example.com/connectionStatus> a noria:Property ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection (e.g., active, inactive)."@en .

<https://example.com/dataFlowRate> a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow in Mbps."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of active data streams."@en .

<https://example.com/superNodeCapacity> a noria:Property ;
  rdfs:label "Super Node Capacity"@en ;
  rdfs:comment "Maximum data capacity in Gbps."@en .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "A hub node with high connectivity."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a central point."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Core network node with high traffic."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Facilitates data transfer."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Supports multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregated network node."@en ;
  noria:structuralElementObservableData <https://example.com/superNodeCapacity> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .