@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/OrgSupport> .

<https://example.com/highDegreeNode2> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a core switch."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMetric> .

<https://example.com/centralNode3> a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "A central node managing traffic flow between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> .

<https://example.com/connectorNode4> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a bridge between two subnetworks."@en ;
  noria:structuralElementObservableData <https://example.com/connectionLatency> .

<https://example.com/intermediaryNode5> a noria:StructuralElement ;
  rdfs:label "Intermediate Switch"@en ;
  rdfs:comment "An intermediary node facilitating traffic rerouting."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> .

<https://example.com/multiplexNode6> a noria:StructuralElement ;
  rdfs:label "Multiplexing Node"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode7> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and core nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A virtual machine hosting critical applications."@en ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> ;
  noria:locatedAtLocus <https://example.com/Locus1> .

<https://example.com/ResourceB_extra_node_1> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A physical server in the data center."@en ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> ;
  noria:locatedAtLocus <https://example.com/Locus2> .

<https://example.com/ResourceC> a noria:Resource ;
  rdfs:label "Resource C"@en ;
  rdfs:comment "A network switch connecting multiple devices."@en ;
  noria:resourceManagedBy <https://example.com/NetworkOps> ;
  noria:locatedAtLocus <https://example.com/Locus3> .

<https://example.com/ResourceD> a noria:Resource ;
  rdfs:label "Resource D"@en ;
  rdfs:comment "A virtual firewall appliance."@en ;
  noria:resourceManagedBy <https://example.com/SecurityTeam> ;
  noria:locatedAtLocus <https://example.com/Locus4> .

<https://example.com/ResourceE> a noria:Resource ;
  rdfs:label "Resource E"@en ;
  rdfs:comment "A storage array for backups."@en ;
  noria:resourceManagedBy <https://example.com/StorageAdmin> ;
  noria:locatedAtLocus <https://example.com/Locus5> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link connecting Resource A and Resource B."@en ;
  noria:networkLinkId "NLK-001" .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Ethernet Link 2"@en ;
  rdfs:comment "Ethernet connection between Resource C and Resource D."@en ;
  noria:networkLinkId "NLK-002" .

<https://example.com/NetworkLink3> a noria:NetworkLink ;
  rdfs:label "Virtual Link 3"@en ;
  rdfs:comment "Virtual network connection between Resource E and Resource A."@en ;
  noria:networkLinkId "NLK-003" .

<https://example.com/latencyMetric> a noria:StructuralObservable ;
  rdfs:label "Latency Metric"@en ;
  rdfs:comment "Average latency in milliseconds."@en .

<https://example.com/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load in Mbps."@en .

<https://example.com/connectionLatency> a noria:StructuralObservable ;
  rdfs:label "Connection Latency"@en ;
  rdfs:comment "Latency of the connection in milliseconds."@en .

<https://example.com/streamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/aggregateTraffic> a noria:StructuralObservable ;
  rdfs:label "Aggregate Traffic"@en ;
  rdfs:comment "Total traffic passing through super node."@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Locus in Server Room 314."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Locus in Data Center."@en .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Locus 3"@en ;
  rdfs:comment "Locus in Network Closet."@en .

<https://example.com/Locus4> a noria:Locus ;
  rdfs:label "Locus 4"@en ;
  rdfs:comment "Locus in Security Zone."@en .

<https://example.com/Locus5> a noria:Locus ;
  rdfs:label "Locus 5"@en ;
  rdfs:comment "Locus in Storage Area."@en .

<https://example.com/OrgSupport> a org:OrganizationalUnit ;
  rdfs:label "Support Team"@en ;
  rdfs:comment "Support team responsible for Resource A and B."@en .

<https://example.com/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Network operations team managing Resource C."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Security team managing Resource D."@en .

<https://example.com/StorageAdmin> a org:OrganizationalUnit ;
  rdfs:label "Storage Administration"@en ;
  rdfs:comment "Admin team for Resource E."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Support team managing Resources A and B."@en .

