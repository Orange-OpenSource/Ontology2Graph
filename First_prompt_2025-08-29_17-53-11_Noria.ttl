@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, managing multiple links."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/latency> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionSpeed> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/throughput> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiplexing of multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/muxCapacity> .

<https://example.com/superNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/aggregateLatency> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes."@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "The amount of traffic passing through the node."@en .

<https://example.com/latency> a noria:Property ;
  rdfs:label "Network Latency"@en ;
  rdfs:comment "The latency experienced at the node."@en .

<https://example.com/connectionSpeed> a noria:Property ;
  rdfs:label "Connection Speed"@en ;
  rdfs:comment "The speed of the connection at the node."@en .

<https://example.com/throughput> a noria:Property ;
  rdfs:label "Throughput"@en ;
  rdfs:comment "The data throughput at the node."@en .

<https://example.com/muxCapacity> a noria:Property ;
  rdfs:label "MUX Capacity"@en ;
  rdfs:comment "The multiplexing capacity of the node."@en .

<https://example.com/aggregateLatency> a noria:Property ;
  rdfs:label "Aggregate Latency"@en ;
  rdfs:comment "The overall latency of the super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A network resource representing a physical device."@en ;
  noria:resourceSerialNumber "SN123456"^^xsd:string ;
  noria:locatedAtLocus <https://example.com/LocusA> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "A specific location within the data center."@en ;
  noria:locusLine "Line: L, Column: 6"@en .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual network resource."@en ;
  noria:resourceSerialNumber "SN654321"^^xsd:string ;
  noria:locatedAtLocus <https://example.com/LocusB> .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "A specific location within the server rack."@en ;
  noria:locusRow "Row: 3"@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Optical Fiber Link"@en ;
  rdfs:comment "A high-speed optical fiber connection."@en ;
  noria:networkLinkId "NLK-001"^^xsd:string ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"@en .

<https://example.com/Resource1> noria:resourceManagedBy <https://example.com/NetworkOperations> .
<https://example.com/Resource2> noria:resourceManagedBy <https://example.com/NetworkOperations> .
<https://example.com/NetworkLink1> noria:resourceManagedBy <https://example.com/NetworkOperations> .

<https://example.com/Resource1> noria:resourceType <https://example.com/ResourceType/PhysicalDevice> .
<https://example.com/Resource2> noria:resourceType <https://example.com/ResourceType/VirtualDevice> .

<https://example.com/Resource1> noria:resourceHostName "host1.datacenter.local" .
<https://example.com/Resource2> noria:resourceHostName "vm-01.virtual.local" .

<https://example.com/Resource1> noria:resourceProductModel <https://example.com/ProductModelX> .
<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model X."@en ;
  org:organization <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "ACME Corp"@en .

<https://example.com/Resource2> noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/Resource1> noria:resourceInstallationDate "2021-06-01T09:00:00"^^xsd:dateTime .
<https://example.com/Resource2> noria:resourceInstallationDate "2020-12-15T09:00:00"^^xsd:dateTime .

<https://example.com/Resource1> noria:resourceLogisticId "LOG-RES-001"^^xsd:string .
<https://example.com/Resource2> noria:resourceLogisticId "LOG-RES-002"^^xsd:string .

<https://example.com/Resource1> noria:resourceSerialNumber "SN123456"^^xsd:string .
<https://example.com/Resource2> noria:resourceSerialNumber "SN654321"^^xsd:string .

<https://example.com/Resource1> noria:resourceUsageState <https://example.com/ResourceState/Operational> .
<https://example.com/Resource2> noria:resourceUsageState <https://example.com/ResourceState/Operational> .

<https://example.com/Resource1> noria:locatedAtLocus <https://example.com/LocusA> .
<https://example.com/Resource2> noria:locatedAtLocus <https://example.com/LocusB> .

<https://example.com/Resource1> noria:agentManagesResource <https://example.com/NetworkOpsAgent> .
<https://example.com/Resource2> noria:agentManagesResource <https://example.com/VirtualAgent> .

<https://example.com/NetworkOpsAgent> a foaf:Agent ;
  rdfs:label "Network Operations Agent"@en ;
  rdfs:comment "Agent responsible for managing network resources."@en .

<https://example.com/VirtualAgent> a foaf:Agent ;
  rdfs:label "Virtual Management Agent"@en ;
  rdfs:comment "Agent managing virtual resources."@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Traffic passing through the node."@en .

<https://example.com/latency> a noria:Property ;
  rdfs:label "Network Latency"@en ;
  rdfs:comment "Latency at the node."@en .

<https://example.com/connectionSpeed> a noria:Property ;
  rdfs:label "Connection Speed"@en ;
  rdfs:comment "Speed of the connection."@en .

<https://example.com/throughput> a noria:Property ;
  rdfs:label "Throughput"@en ;
  rdfs:comment "Data throughput."@en .

<https://example.com/muxCapacity> a noria:Property ;
  rdfs:label "MUX Capacity"@en ;
  rdfs:comment "Multiplexing capacity."@en .

<https://example.com/aggregateLatency> a noria:Property ;
  rdfs:label "Aggregate Latency"@en ;
  rdfs:comment "Overall latency of super node."@en .