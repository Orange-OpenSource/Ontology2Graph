@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/highDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a central point."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within the network topology."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node serving as an intermediary in data flow."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource1>
  a noria:Resource ;
  rdfs:label "Resource1"@en ;
  rdfs:comment "A virtual server hosting critical applications."@en ;
  noria:resourceHostName "server1.example.com" ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource2>
  a noria:Resource ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "A network switch connecting multiple segments."@en ;
  noria:resourceHostName "switch1.example.com" ;
  noria:locatedAtLocus <https://example.com/locus2> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/locus1>
  a noria:Locus ;
  rdfs:label "Locus1"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "Line: L1" ;
  noria:locusRow "Row: R1" ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/locus2>
  a noria:Locus ;
  rdfs:label "Locus2"@en ;
  rdfs:comment "Network equipment closet."@en ;
  noria:locusLine "Line: L2" ;
  noria:locusRow "Row: R2" ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/NetworkLink1>
  a noria:NetworkLink ;
  rdfs:label "FiberLink1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLK-001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource1_networkInterface>
  a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet Interface"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource2_networkInterface>
  a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary network interface of Resource2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "Virtual Interface for management"@en ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/HubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/HighDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections acting as a central point."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/CentralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node positioned centrally in the network topology."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ConnectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/IntermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node serving as an intermediary in data flow."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/MultiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/SuperNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple nodes into a super node."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Service1>
  a noria:Service ;
  rdfs:label "Core Network Service"@en ;
  rdfs:comment "A core network service providing routing."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Application1>
  a noria:Application ;
  rdfs:label "Customer Portal"@en ;
  rdfs:comment "Web portal for customer interactions."@en ;
  noria:applicationModelIdentifier "APP-001" ;
  noria:applicationType <https://w3id.org/noria/kos/application/type/customer-facing> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ApplicationModule1>
  a noria:ApplicationModule ;
  rdfs:label "Portal Frontend Module"@en ;
  rdfs:comment "Frontend component of Customer Portal."@en ;
  noria:applicationModuleIdentifier "MOD-001" ;
  noria:applicationModuleName "Frontend"@en ;
  noria:applicationModuleOf <https://example.com/Application1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ChangeRequest1_extra_node_1>
  a noria:ChangeRequest ;
  rdfs:label "CR-2023-001"@en ;
  rdfs:comment "Routine software update."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/TroubleTicket1>
  a noria:TroubleTicket ;
  rdfs:label "TT-2023-045"@en ;
  rdfs:comment "Reported outage in customer internet service."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/EventRecord1>
  a noria:EventRecord ;
  rdfs:label "Event-2023-045"@en ;
  rdfs:comment "Network interface down detected."@en ;
  noria:loggingTime "2023-11-25T14:30:00"^^xsd:dateTime ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource2>
  a noria:Resource ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "A network switch."@en ;
  noria:resourceHostName "switch2.example.com" ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource1>
  a noria:Resource ;
  rdfs:label "Resource1"@en ;
  rdfs:comment "A virtual server."@en ;
  noria:resourceHostName "server1.example.com" ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource1> noria:elementManagedBy <https://example.com/ITTeam> .
<https://example.com/Resource2> noria:elementManagedBy <https://example.com/ITTeam> .

<https://example.com/ITTeam>
  a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "The team responsible for managing network resources."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/NetworkLink1> noria:resourceManagedBy <https://example.com/NetworkSupportTeam> .

<https://example.com/NetworkSupportTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team supporting network links."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/HubNode> noria:elementManagedBy <https://example.com/NetworkSupportTeam> .
<https://example.com/HighDegreeNode> noria:elementManagedBy <https://example.com/NetworkSupportTeam> .
<https://example.com/CentralNode> noria:elementManagedBy <https://example.com/NetworkSupportTeam> .
<https://example.com/ConnectorNode> noria:elementManagedBy <https://example.com/NetworkSupportTeam> .
<https://example.com/IntermediaryNode> noria:elementManagedBy <https://example.com/NetworkSupportTeam> .
<https://example.com/MultiplexNode> noria:elementManagedBy <https://example.com/NetworkSupportTeam> .
<https://example.com/SuperNode> noria:elementManagedBy <https://example.com/NetworkSupportTeam> .

<https://example.com/Application1> noria:applicationType <https://w3id.org/noria/kos/application/type/customer-facing> .
<https://example.com/Application1> noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> .

<https://example.com/ApplicationModule1> noria:applicationModuleRelatedParty <https://example.com/ITTeam> .

<https://example.com/ChangeRequest1> noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/standard> .

<https://example.com/TroubleTicket1> noria:troubleTicketImpacts <https://example.com/Application1> ;
  noria:troubleTicketImpacts <https://example.com/Resource2> .

<https://example.com/EventRecord1> noria:logOriginatingManagedObject <https://example.com/Resource2> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logText "Network interface eth1 down"@en ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Major> .

<https://example.com/NMS1>
  a noria:Application ;
  rdfs:label "Network Management System"@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

