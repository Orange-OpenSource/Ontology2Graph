@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Hub Node: Central Network Hub
<https://example.com/HubNetwork> a noria:ManagedElement ;
  rdfs:label "Main Network Hub"@en ;
  rdfs:comment "The central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

# High-Degree Node: Core Router
<https://example.com/CoreRouter> a noria:StructuralElement, noria:StructuralObservable ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A high-degree node with many connections in the network."@en ;
  noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Traffic Load"@en ] ;
  noria:structuralElementDistinguishedName "Router-CORE-01"@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_1> .

# Central Node: Application Server
<https://example.com/AppServer1> a noria:FunctionalElement, noria:Application ;
  rdfs:label "Application Server 1"@en ;
  rdfs:comment "A critical application server handling user requests."@en ;
  noria:functionalElementDistinguishedName "AppServer1"@en ;
  noria:resourceForApplication <https://example.com/CustomerPortal> .

# Connector Node: Firewall
<https://example.com/Firewall> a noria:StructuralElement ;
  rdfs:label "Firewall"@en ;
  rdfs:comment "Firewall connecting internal network to external internet."@en ;
  noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Firewall Status"@en ] ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

# Intermediary Node: Load Balancer
<https://example.com/LoadBalancer> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Distributes incoming network traffic to multiple servers."@en ;
  noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Load Distribution"@en ] ;
  noria:elementManagedBy <https://example.com/ITSupport> .

# Multiplex Node: Virtual Machine Cluster
<https://example.com/VMCluster> a noria:StructuralElement, noria:Resource ;
  rdfs:label "Virtual Machine Cluster"@en ;
  rdfs:comment "A cluster of virtual machines providing scalable services."@en ;
  noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Cluster Load"@en ] ;
  noria:resourceManagedBy <https://example.com/CloudOps> .

# Super Node: Data Center
<https://example.com/DataCenter> a noria:StructuralElement ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "The primary data center housing critical infrastructure."@en ;
  noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Power Consumption"@en ] ;
  noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Cooling Status"@en ] ;
  noria:elementManagedBy <https://example.com/DataCenterOps> .

# Relationships
<https://example.com/HubNetwork> noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Traffic Flow"@en ] .

<https://example.com/CoreRouter> noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Packet Loss"@en ] .

<https://example.com/AppServer1> noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "CPU Usage"@en ] .

<https://example.com/Firewall> noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Firewall Rules Status"@en ] .

<https://example.com/LoadBalancer> noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Request Distribution"@en ] .

<https://example.com/VMCluster> noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Cluster Utilization"@en ] .

<https://example.com/DataCenter> noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Power Usage"@en ] .

# Additional Nodes linked via relations
<https://example.com/NetworkAdmin> a org:OrganizationalUnit ;
  rdfs:label "Network Administration Team"@en ;
  rdfs:comment "Responsible for managing core network infrastructure."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Handles network routing and core devices."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Manages security devices and policies."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Provides operational support for network devices."@en .

<https://example.com/CloudOps> a org:OrganizationalUnit ;
  rdfs:label "Cloud Operations"@en ;
  rdfs:comment "Manages virtualized resources and clusters."@en .

<https://example.com/DataCenterOps> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en ;
  rdfs:comment "Oversees physical infrastructure."@en .

# Nodes are all connected with at least one relation, no isolated nodes included.