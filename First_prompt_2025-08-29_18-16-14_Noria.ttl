@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, managing multiple links."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical junction."@en ;
  noria:structuralElementDistinguishedName "HighDegreeNode-01" ;
  noria:structuralElementObservableData "Connection count: 150"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable/connectionCount> .

<https://example.com/centralNode> a noria:FunctionalElement ;
  rdfs:label "Central Functional Node"@en ;
  rdfs:comment "A core functional element central to the system's operation."@en ;
  noria:functionalElementDistinguishedName "CentralNode-Alpha" ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different system segments."@en ;
  noria:structuralElementDistinguishedName "Connector-42" ;
  noria:structuralElementObservableData "Bandwidth: 10Gbps"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable/bandwidth> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementDistinguishedName "Intermediary-07" ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/multiplexNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementDistinguishedName "Multiplex-StreamX" ;
  noria:structuralElementObservableData "Streams: 4"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable/streamsCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node integrating multiple subsystems."@en ;
  noria:structuralElementDistinguishedName "SuperNode-Z" ;
  noria:structuralElementObservableData "Subsystems: 8"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable/subsystemsCount> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/ITSupportTeam> a org:Organization ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing technical support."@en .

<https://example.com/NetworkTeam> a org:Organization ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "Team managing network infrastructure."@en .

<https://example.com/observable/connectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/observable/bandwidth> a noria:StructuralObservable ;
  rdfs:label "Bandwidth"@en ;
  rdfs:comment "Bandwidth capacity of a node."@en .

<https://example.com/observable/streamsCount> a noria:StructuralObservable ;
  rdfs:label "Streams Count"@en ;
  rdfs:comment "Number of data streams handled by multiplex nodes."@en .

<https://example.com/observable/subsystemsCount> a noria:StructuralObservable ;
  rdfs:label "Subsystems Count"@en ;
  rdfs:comment "Number of subsystems under a super node."@en .