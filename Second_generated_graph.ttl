@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sc:E1 a sc:C2 ;
    rdfs:label "Entity 1" ;
    rdfs:comment "An instance of class C2." ;
    sc:R9 sc:E2, sc:E3 .

sc:E2 a sc:C2 ;
    rdfs:label "Entity 2" ;
    rdfs:comment "Another instance of class C2, connected to E1 and E3." ;
    sc:R9 sc:E1, sc:E3 .

sc:E3 a sc:C2 ;
    rdfs:label "Entity 3" ;
    rdfs:comment "A central node of class C2, connected to E1 and E2." ;
    sc:R9 sc:E1, sc:E2 .

sc:E4 a sc:C1 ;
    rdfs:label "Entity 4" ;
    rdfs:comment "An instance of class C1, connected to E5." ;
    sc:R3 sc:E5 .

sc:E5 a sc:C3 ;
    rdfs:label "Entity 5" ;
    rdfs:comment "An instance of class C3, connected to E4." ;
    sc:R2 sc:E4 .

sc:E6 a sc:C5 ;
    rdfs:label "Entity 6" ;
    rdfs:comment "An instance of class C5, connected to E7." ;
    sc:R6 sc:E7 .

sc:E7 a sc:C7 ;
    rdfs:label "Entity 7" ;
    rdfs:comment "An instance of class C7, connected to E6." ;
    sc:R8 sc:E6 .

sc:E8 a sc:C9 ;
    rdfs:label "Entity 8" ;
    rdfs:comment "A high-degree node of class C9, connected to E9, E10, and E11." ;
    sc:R4 sc:E9, sc:E10, sc:E11 .

sc:E9 a sc:C9 ;
    rdfs:label "Entity 9" ;
    rdfs:comment "An instance of class C9, connected to E8." ;
    sc:R4 sc:E8 .

sc:E10 a sc:C9 ;
    rdfs:label "Entity 10" ;
    rdfs:comment "An instance of class C9, connected to E8." ;
    sc:R4 sc:E8 .

sc:E11 a sc:C9 ;
    rdfs:label "Entity 11" ;
    rdfs:comment "An instance of class C9, connected to E8." ;
    sc:R4 sc:E8 .

sc:E12 a sc:C4 ;
    rdfs:label "Entity 12" ;
    rdfs:comment "An instance of class C4, connected to E13." ;
    sc:R1 sc:E13 .

sc:E13 a sc:C4 ;
    rdfs:label "Entity 13" ;
    rdfs:comment "An instance of class C4, connected to E12. R1 is transitive, so E12 and E13 are related to themselves." ;
    sc:R1 sc:E12 .

sc:E14 a sc:C10 ;
    rdfs:label "Entity 14" ;
    rdfs:comment "An instance of class C10, connected to E15." ;
    sc:R10 sc:E15 .

sc:E15 a sc:C4 ;
    rdfs:label "Entity 15" ;
    rdfs:comment "An instance of class C4, connected to E14." .

sc:E16 a sc:C8 ;
    rdfs:label "Entity 16" ;
    rdfs:comment "An instance of class C8." .

sc:E17 a sc:C6 ;
    rdfs:label "Entity 17" ;
    rdfs:comment "An instance of class C6, which is a subclass of C8." .

sc:E18 a sc:C10 ;
    rdfs:label "Entity 18" ;
    rdfs:comment "An isolated node of class C10." .

sc:E19 a sc:C10 ;
    rdfs:label "Entity 19" ;
    rdfs:comment "Another isolated node of class C10." .
