@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc:E1 a sc:C2 ;
    rdfs:label "Entity One" ;
    rdfs:comment "A central node of type C2." ;
    sc:R9 sc:E2, sc:E3 .

sc:E2 a sc:C2 ;
    rdfs:label "Entity Two" ;
    rdfs:comment "A connector node of type C2." ;
    sc:R9 sc:E1, sc:E4 .

sc:E3 a sc:C2 ;
    rdfs:label "Entity Three" ;
    rdfs:comment "Another node of type C2." ;
    sc:R9 sc:E1, sc:E5 .

sc:E4 a sc:C2 ;
    rdfs:label "Entity Four" ;
    rdfs:comment "An intermediary node of type C2." ;
    sc:R9 sc:E2 .

sc:E5 a sc:C2 ;
    rdfs:label "Entity Five" ;
    rdfs:comment "A node of type C2." ;
    sc:R9 sc:E3 .

sc:E6 a sc:C3 ;
    rdfs:label "Entity Six" ;
    rdfs:comment "A node of type C3." ;
    sc:R2 sc:E7 .

sc:E7 a sc:C1 ;
    rdfs:label "Entity Seven" ;
    rdfs:comment "A node of type C1." ;
    sc:R3 sc:E6 .

sc:E8 a sc:C5 ;
    rdfs:label "Entity Eight" ;
    rdfs:comment "A hub node of type C5." ;
    sc:R6 sc:E9, sc:E10, sc:E11 .

sc:E9 a sc:C7 ;
    rdfs:label "Entity Nine" ;
    rdfs:comment "A node of type C7." ;
    sc:R8 sc:E8 .

sc:E10 a sc:C7 ;
    rdfs:label "Entity Ten" ;
    rdfs:comment "Another node of type C7." ;
    sc:R8 sc:E8 .

sc:E11 a sc:C7 ;
    rdfs:label "Entity Eleven" ;
    rdfs:comment "Yet another node of type C7." ;
    sc:R8 sc:E8 .

sc:E12 a sc:C9 ;
    rdfs:label "Entity Twelve" ;
    rdfs:comment "A high-degree node of type C9." ;
    sc:R4 sc:E13, sc:E14, sc:E15 .

sc:E13 a sc:C9 ;
    rdfs:label "Entity Thirteen" ;
    rdfs:comment "A node of type C9." ;
    sc:R4 sc:E12 .

sc:E14 a sc:C9 ;
    rdfs:label "Entity Fourteen" ;
    rdfs:comment "Another node of type C9." ;
    sc:R4 sc:E12 .

sc:E15 a sc:C9 ;
    rdfs:label "Entity Fifteen" ;
    rdfs:comment "Yet another node of type C9." ;
    sc:R4 sc:E12 .

sc:E16 a sc:C10 ;
    rdfs:label "Entity Sixteen" ;
    rdfs:comment "A node of type C10." ;
    sc:R10 sc:E17 .

sc:E17 a sc:C4 ;
    rdfs:label "Entity Seventeen" ;
    rdfs:comment "A node of type C4." ;
    sc:R3 sc:E18 .

sc:E18 a sc:C3 ;
    rdfs:label "Entity Eighteen" ;
    rdfs:comment "A node of type C3." ;
    sc:R2 sc:E17 .

sc:E19 a sc:C8 ;
    rdfs:label "Entity Nineteen" ;
    rdfs:comment "A node of type C8." .

sc:E20 a sc:C6 ;
    rdfs:label "Entity Twenty" ;
    rdfs:comment "A node of type C6, subclass of C8." .
