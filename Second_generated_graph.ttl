@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Entities and their relationships

sc:E1 a sc:C10 ;
    rdfs:label "Entity E1"@en ;
    rdfs:comment "A node of type C10."@en ;
    sc:R4 sc:E2, sc:E3 .

sc:E2 a sc:C10 ;
    rdfs:label "Entity E2"@en ;
    rdfs:comment "A node of type C10."@en ;
    sc:R6 sc:E4 .

sc:E3 a sc:C10 ;
    rdfs:label "Entity E3"@en ;
    rdfs:comment "A node of type C10."@en ;
    sc:R1 sc:E1, sc:E5 .

sc:E4 a sc:C10 ;
    rdfs:label "Entity E4"@en ;
    rdfs:comment "A node of type C10."@en ;
    sc:R6 sc:E2 .

sc:E5 a sc:C10 ;
    rdfs:label "Entity E5"@en ;
    rdfs:comment "A node of type C10."@en ;
    sc:R1 sc:E3 ;
    sc:R4 sc:E6 .

sc:E6 a sc:C10 ;
    rdfs:label "Entity E6"@en ;
    rdfs:comment "A node of type C10."@en ;
    sc:R4 sc:E5 ;
    sc:R6 sc:E7 .

sc:E7 a sc:C10 ;
    rdfs:label "Entity E7"@en ;
    rdfs:comment "A node of type C10."@en ;
    sc:R6 sc:E6 .

# Hub Node (E8) connecting different classes
sc:E8 a sc:C10 ;
    rdfs:label "Hub Entity E8"@en ;
    rdfs:comment "A hub node of type C10, connecting to C1, C3, C4, C5, C7, C8, C9."@en ;
    sc:R6 sc:E9, sc:E10, sc:E11, sc:E12, sc:E13, sc:E14, sc:E15 .

sc:E9 a sc:C1 ;
    rdfs:label "Entity E9 (C1)"@en ;
    rdfs:comment "A node of type C1 connected to the hub."@en ;
    sc:R6 sc:E8 .

sc:E10 a sc:C3 ;
    rdfs:label "Entity E10 (C3)"@en ;
    rdfs:comment "A node of type C3 connected to the hub."@en ;
    sc:R6 sc:E8 .

sc:E11 a sc:C4 ;
    rdfs:label "Entity E11 (C4)"@en ;
    rdfs:comment "A node of type C4 connected to the hub."@en ;
    sc:R6 sc:E8 .

sc:E12 a sc:C5 ;
    rdfs:label "Entity E12 (C5)"@en ;
    rdfs:comment "A node of type C5 connected to the hub."@en ;
    sc:R6 sc:E8 .

sc:E13 a sc:C7 ;
    rdfs:label "Entity E13 (C7)"@en ;
    rdfs:comment "A node of type C7 connected to the hub."@en ;
    sc:R6 sc:E8 .

sc:E14 a sc:C8 ;
    rdfs:label "Entity E14 (C8)"@en ;
    rdfs:comment "A node of type C8 connected to the hub."@en ;
    sc:R6 sc:E8 .

sc:E15 a sc:C9 ;
    rdfs:label "Entity E15 (C9)"@en ;
    rdfs:comment "A node of type C9 connected to the hub."@en ;
    sc:R6 sc:E8 .

# High-Degree Node (E16)
sc:E16 a sc:C10 ;
    rdfs:label "High-Degree Entity E16"@en ;
    rdfs:comment "A high-degree node of type C10, connected to many other nodes."@en ;
    sc:R6 sc:E17, sc:E18, sc:E19, sc:E20, sc:E21 .

sc:E17 a sc:C10 ;
    rdfs:label "Entity E17"@en ;
    rdfs:comment "A node of type C10 connected to the high-degree node."@en ;
    sc:R6 sc:E16 .

sc:E18 a sc:C10 ;
    rdfs:label "Entity E18"@en ;
    rdfs:comment "A node of type C10 connected to the high-degree node."@en ;
    sc:R6 sc:E16 .

sc:E19 a sc:C10 ;
    rdfs:label "Entity E19"@en ;
    rdfs:comment "A node of type C10 connected to the high-degree node."@en ;
    sc:R6 sc:E16 .

sc:E20 a sc:C10 ;
    rdfs:label "Entity E20"@en ;
    rdfs:comment "A node of type C10 connected to the high-degree node."@en ;
    sc:R6 sc:E16 .

sc:E21 a sc:C10 ;
    rdfs:label "Entity E21"@en ;
    rdfs:comment "A node of type C10 connected to the high-degree node."@en ;
    sc:R6 sc:E16 .

# Connector Node (E22) connecting two subgraphs
sc:E22 a sc:C10 ;
    rdfs:label "Connector Entity E22"@en ;
    rdfs:comment "A connector node of type C10, connecting two subgraphs."@en ;
    sc:R6 sc:E23, sc:E24 .

sc:E23 a sc:C10 ;
    rdfs:label "Entity E23"@en ;
    rdfs:comment "A node of type C10 in the first subgraph."@en ;
    sc:R6 sc:E22 .

sc:E24 a sc:C10 ;
    rdfs:label "Entity E24"@en ;
    rdfs:comment "A node of type C10 in the second subgraph."@en ;
    sc:R6 sc:E22 .

# Intermediary Node (E25)
sc:E25 a sc:C10 ;
    rdfs:label "Intermediary Entity E25"@en ;
    rdfs:comment "An intermediary node of type C10, connecting two other nodes."@en ;
    sc:R6 sc:E26 .

sc:E26 a sc:C10 ;
    rdfs:label "Entity E26"@en ;
    rdfs:comment "A node of type C10 connected to the intermediary node."@en ;
    sc:R6 sc:E25 .

# Multiplex Node (E27) - connecting to multiple types of relationships
sc:E27 a sc:C10 ;
    rdfs:label "Multiplex Entity E27"@en ;
    rdfs:comment "A multiplex node of type C10, connected by different relationships."@en ;
    sc:R1 sc:E28 ;
    sc:R4 sc:E29 ;
    sc:R6 sc:E30 .

sc:E28 a sc:C10 ;
    rdfs:label "Entity E28"@en ;
    rdfs:comment "A node of type C10 connected to the multiplex node via R1."@en ;
    sc:R1 sc:E27 .

sc:E29 a sc:C10 ;
    rdfs:label "Entity E29"@en ;
    rdfs:comment "A node of type C10 connected to the multiplex node via R4."@en ;
    sc:R4 sc:E27 .

sc:E30 a sc:C10 ;
    rdfs:label "Entity E30"@en ;
    rdfs:comment "A node of type C10 connected to the multiplex node via R6."@en ;
    sc:R6 sc:E27 .

# Super Node (E31) - connected to many nodes of different types and with different relationships
sc:E31 a sc:C10 ;
    rdfs:label "Super Entity E31"@en ;
    rdfs:comment "A super node of type C10, connected to many nodes of different types and with different relationships."@en ;
    sc:R1 sc:E32 ;
    sc:R4 sc:E33 ;
    sc:R6 sc:E34 .

sc:E32 a sc:C1 ;
    rdfs:label "Entity E32 (C1)"@en ;
    rdfs:comment "A node of type C1 connected to the super node via R1."@en ;
    sc:R1 sc:E31 .

sc:E33 a sc:C3 ;
    rdfs:label "Entity E33 (C3)"@en ;
    rdfs:comment "A node of type C3 connected to the super node via R4."@en ;
    sc:R4 sc:E31 .

sc:E34 a sc:C4 ;
    rdfs:label "Entity E34 (C4)"@en ;
    rdfs:comment "A node of type C4 connected to the super node via R6."@en ;
    sc:R6 sc:E31 .

# Isolated Nodes (no connections)
sc:E35 a sc:C10 ;
    rdfs:label "Isolated Entity E35"@en ;
    rdfs:comment "An isolated node of type C10 with no connections."@en .

sc:E36 a sc:C10 ;
    rdfs:label "Isolated Entity E36"@en ;
    rdfs:comment "An isolated node of type C10 with no connections."@en .

# Central Node (E37)
sc:E37 a sc:C10 ;
    rdfs:label "Central Entity E37"@en ;
    rdfs:comment "A central node of type C10, connecting to many other nodes."@en ;
    sc:R6 sc:E38, sc:E39, sc:E40 .

sc:E38 a sc:C10 ;
    rdfs:label "Entity E38"@en ;
    rdfs:comment "A node of type C10 connected to the central node."@en ;
    sc:R6 sc:E37 .

sc:E39 a sc:C10 ;
    rdfs:label "Entity E39"@en ;
    rdfs:comment "A node of type C10 connected to the central node."@en ;
    sc:R6 sc:E37 .

sc:E40 a sc:C10 ;
    rdfs:label "Entity E40"@en ;
    rdfs:comment "A node of type C10 connected to the central node."@en ;
    sc:R6 sc:E37 .
