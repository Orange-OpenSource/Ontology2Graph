@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub Node: E101 (Connects many C2 instances to C9)
sc:E101 a sc:C9 ;
    rdfs:label "Hub Node: E101" ;
    rdfs:comment "Connects multiple C2 instances to C9, acting as a central point." ;
    sc:R2 sc:E187, sc:E252, sc:E75 ;
    sc:R3 sc:E820 ;
    sc:R4 sc:E240 ;
    sc:R9 sc:E607, sc:E858 .

# High-Degree Node: E634 (Many R1 and R6 relationships)
sc:E634 a sc:C10 ;
    rdfs:label "High-Degree Node: E634" ;
    rdfs:comment "Has a high number of relationships (R1 and R6) compared to other nodes." ;
    sc:R1 sc:E25, sc:E646, sc:E829 ;
    sc:R4 sc:E965 ;
    sc:R6 sc:E177 .

# Central Node: E739 (Connects C5 instances to C3 and C10)
sc:E739 a sc:C5 ;
    rdfs:label "Central Node: E739" ;
    rdfs:comment "Connects C5 instances to C3 and C10, playing a key role in information flow." ;
    sc:R1 sc:E920 ;
    sc:R2 sc:E21, sc:E899 ;
    sc:R3 sc:E23, sc:E954 ;
    sc:R6 sc:E804 ;
    sc:R9 sc:E279, sc:E378, sc:E709 .

# Connector Node: E33 (Connects C9 instances through R9)
sc:E33 a sc:C9 ;
    rdfs:label "Connector Node: E33" ;
    rdfs:comment "Connects different C9 instances, facilitating communication between them." ;
    sc:R3 sc:E809 ;
    sc:R6 sc:E410 ;
    sc:R9 sc:E491, sc:E504, sc:E566, sc:E811 .

# Intermediary Node: E431 (Connects C10 instances through R3 and R4)
sc:E431 a sc:C10 ;
    rdfs:label "Intermediary Node: E431" ;
    rdfs:comment "Acts as an intermediary between C10 instances, relaying information." ;
    sc:R3 sc:E163, sc:E184 ;
    sc:R4 sc:E434, sc:E435 ;
    sc:R6 sc:E638 .

# Multiplex Node: E53 (Multiple relationships and classes)
sc:E53 a sc:C8 ;
    rdfs:label "Multiplex Node: E53" ;
    rdfs:comment "Participates in multiple types of relationships (R1, R2, R4, R9) and belongs to class C8." ;
    sc:R1 sc:E130, sc:E626 ;
    sc:R2 sc:E394 ;
    sc:R4 sc:E754 ;
    sc:R9 sc:E170, sc:E923, sc:E953 .

# Super Node: E273 (Connects C2 instances to C6)
sc:E273 a sc:C2 ;
    rdfs:label "Super Node: E273" ;
    rdfs:comment "Connects C2 instances to C6, acting as a central point." ;
    sc:R1 sc:E989 ;
    sc:R10 sc:E111, sc:E117, sc:E504, sc:E862, sc:E947 ;
    sc:R5 sc:E108, sc:E260, sc:E293, sc:E432, sc:E46, sc:E467, sc:E522, sc:E752, sc:E797, sc:E970 ;
    sc:R6 sc:E330 .

