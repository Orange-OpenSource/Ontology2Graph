# =============================================================================
# Locations
# =============================================================================

bot:Site_DC_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "48.867"^^xsd:float ;
    wgs84_pos:long "2.333"^^xsd:float .

bot:Site_Office_Lyon a bot:Site ;
    rdfs:label "Lyon Office Building"@en ;
    rdfs:comment "Main office building in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddressStreet "45 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "45.749"^^xsd:float ;
    wgs84_pos:long "4.849"^^xsd:float .

noria:Room_ServerRoom_A1 a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace bot:Site_DC_Paris .

noria:Room_NetworkCloset_B2 a noria:Room ;
    rdfs:label "Network Closet B2"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace bot:Site_Office_Lyon .

noria:Locus_Rack_R1_A1 a noria:Locus ;
    rdfs:label "Rack R1 in Server Room A1"@en ;
    rdfs:comment "Specific rack location for critical servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoom_A1 .

noria:Locus_Rack_N1_B2 a noria:Locus ;
    rdfs:label "Rack N1 in Network Closet B2"@en ;
    rdfs:comment "Specific rack location for network devices."@en ;
    noria:locusLine "N" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_NetworkCloset_B2 .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
