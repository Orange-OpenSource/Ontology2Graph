    rdfs:comment "Enables employees to securely access corporate resources from remote locations."@en ;
    rdfs:label "Service d'Accès à Distance"@fr ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule7, noria:ApplicationModule5 .

# --- Trouble Tickets (noria:TroubleTicket) ---

noria:TroubleTicket1 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Primary DNS server unreachable, causing widespread name resolution failures."@en ;
    rdfs:label "Incident de Panne du Serveur DNS"@fr ;
    dcterms:created "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application9 ;
    noria:troubleTicketRelatedResource noria:Resource1 ;
    noria:troubleTicketRelatedParty foaf:Agent1 ;
    noria:troubleTicketDetectionDateTime "2024-04-10T08:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketDescription "DNS server dns01.corp.example.com is not responding to queries. Impacting all internal services."@en .

noria:TroubleTicket2 a noria:TroubleTicket ;
    rdfs:label "Core Router 1 Link Down"@en ;
    rdfs:comment "WAN link from Core Router 1 to Edge Router 1 is down, affecting Lyon office connectivity."@en ;
    rdfs:label "Liaison Routeur Cœur 1 Hors Service"@fr ;
