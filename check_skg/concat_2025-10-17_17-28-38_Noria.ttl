# --- Operation Plans, Pre/Post Conditions ---

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Troubleshooting Guide"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving DNS server issues."@en ;
    rdfs:label "Guide de Dépannage Serveur DNS"@fr ;
    noria:operationPlanPreCondition noria:ActionPreCondition1_OP1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1_OP1 .

noria:ActionPreCondition1_OP1 a noria:ActionPreCondition ;
    rdfs:label "DNS Resolution Failure Observed"@en ;
    rdfs:comment "Condition: DNS queries to the corporate DNS server are failing or timing out."@en .

noria:ActionPostCondition1_OP1 a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored"@en ;
    rdfs:comment "Expected outcome: DNS queries to the corporate DNS server are successfully resolved."@en .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Core Router Interface Reset Procedure"@en ;
    rdfs:comment "Procedure for administratively bouncing a network interface on a core router."@en ;
    rdfs:label "Procédure de Réinitialisation Interface Routeur Cœur"@fr ;
    noria:operationPlanPreCondition noria:ActionPreCondition1_OP2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1_OP2 .

noria:ActionPreCondition1_OP2 a noria:ActionPreCondition ;
    rdfs:label "Interface Status is 'Down'"@en ;
    rdfs:comment "Condition: A specific network interface on a core router is showing an operational status of 'down'."@en .

noria:ActionPostCondition1_OP2 a noria:ActionPostCondition ;
    rdfs:label "Interface Status is 'Up'"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is restored to 'up'."@en .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Firewall Policy Review Process"@en ;
    rdfs:comment "Procedure for reviewing and validating firewall policy changes before deployment."@en ;
    rdfs:label "Process de Révision Politique Pare-feu"@fr ;
    noria:operationPlanPreCondition noria:ActionPreCondition1_OP3 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1_OP3 .

noria:ActionPreCondition1_OP3 a noria:ActionPreCondition ;
    rdfs:label "Security Incident Detected Post-Change"@en ;
    rdfs:comment "Condition: A security incident or unexpected traffic blockage is detected shortly after a firewall policy change."@en .

noria:ActionPostCondition1_OP3 a noria:ActionPostCondition ;
    rdfs:label "Policy Compliant, No Further Incidents"@en ;
    rdfs:comment "Expected outcome: Firewall policy is verified to be compliant and no further related security incidents occur."@en .

noria:OperationPlan4 a noria:OperationPlan ;
    rdfs:label "Web Server Log Cleanup Procedure"@en ;
    rdfs:comment "Routine procedure for clearing old log files on web servers to free up disk space."@en ;
    rdfs:label "Procédure de Nettoyage des Logs Serveur Web"@fr ;
    noria:operationPlanPreCondition noria:ActionPreCondition1_OP4 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1_OP4 .

noria:ActionPreCondition1_OP4 a noria:ActionPreCondition ;
    rdfs:label "Web Server Disk Usage High"@en ;
    rdfs:comment "Condition: Disk usage on web server /var/log partition exceeds 90%."@en .

noria:ActionPostCondition1_OP4 a noria:ActionPostCondition ;
    rdfs:label "Web Server Disk Usage Below Threshold"@en ;
    rdfs:comment "Expected outcome: Disk usage on web server /var/log partition is reduced below 80%."@en .

# --- Connecting Trouble Tickets to Event Records and Operation Plans ---

noria:TroubleTicket1 noria:troubleTicketTrigger noria:EventRecord1 .
noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord1 .
noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord2_TT1_Resolved . # Assuming a resolution event record

noria:TroubleTicket2 noria:troubleTicketTrigger noria:EventRecord2 .
noria:TroubleTicket2 noria:documentStatusHistory noria:EventRecord2 .

noria:TroubleTicket3 noria:troubleTicketTrigger noria:EventRecord3 .
noria:TroubleTicket3 noria:documentStatusHistory noria:EventRecord3 .

noria:TroubleTicket4 noria:troubleTicketTrigger noria:EventRecord4 .
noria:TroubleTicket4 noria:documentStatusHistory noria:EventRecord4 .

noria:TroubleTicket5 noria:troubleTicketTrigger noria:EventRecord5 .
noria:TroubleTicket5 noria:documentStatusHistory noria:EventRecord5 .

noria:TroubleTicket6 noria:troubleTicketTrigger noria:EventRecord9 .
noria:TroubleTicket6 noria:documentStatusHistory noria:EventRecord9 .

noria:TroubleTicket7 noria:troubleTicketTrigger noria:EventRecord10 .
noria:TroubleTicket7 noria:documentStatusHistory noria:EventRecord10 .

noria:TroubleTicket8 noria:troubleTicketTrigger noria:EventRecord11 .
noria:TroubleTicket8 noria:documentStatusHistory noria:EventRecord11 .

# Example of a resolution event record for TT1
noria:EventRecord2_TT1_Resolved a noria:EventRecord ;
    rdfs:label "DNS Service Restored Log"@en ;
    rdfs:comment "Log entry indicating the DNS service was successfully restarted and is now operational."@en ;
    dcterms:created "2024-04-10T09:45:00Z"^^xsd:dateTime ;
    noria:loggingTime "2024-04-10T09:45:00Z"^^xsd:dateTime ;
    noria:logText "INFO: DNS service on dns01.corp.example.com is now UP and responding to queries."@en ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmMitigatedBy noria:TroubleTicket1 . # This event record is part of the resolution of TT1

# Example of a resolution event record for TT5
noria:EventRecord2_TT5_Resolved a noria:EventRecord ;
    rdfs:label "Firewall Policy Rollback Success Log"@en ;
    rdfs:comment "Log entry confirming the successful rollback of the firewall policy."@en ;
    dcterms:created "2024-04-14T16:35:00Z"^^xsd:dateTime ;
    noria:loggingTime "2024-04-14T16:35:00Z"^^xsd:dateTime ;
    noria:logText "INFO: Firewall policy on fw01.dmz.example.com rolled back to previous version. Traffic flow restored."@en ;
    noria:logOriginatingManagedObject noria:Resource5 ;
    noria:logOriginatingManagementSystem noria:Application6 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmMitigatedBy noria:TroubleTicket5 .

# Example of a resolution event record for TT8
noria:EventRecord2_TT8_Resolved a noria:EventRecord ;
    rdfs:label "Web Server Log Cleanup Completed Log"@en ;
    rdfs:comment "Log entry confirming the successful cleanup of old log files on the web server."@en ;
    dcterms:created "2024-04-17T09:45:00Z"^^xsd:dateTime ;
    noria:loggingTime "2024-04-17T09:45:00Z"^^xsd:dateTime ;
    noria:logText "INFO: Old log files cleared from /var/log on web01.farm-a.example.com. Disk usage now 40%."@en ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmMitigatedBy noria:TroubleTicket8 .

# --- Connecting Change Requests to Event Records ---
noria:ChangeRequest1 noria:documentStatusHistory noria:EventRecord6 .
noria:ChangeRequest2 noria:documentStatusHistory noria:EventRecord7 .
noria:ChangeRequest5 noria:documentStatusHistory noria:EventRecord8 .

