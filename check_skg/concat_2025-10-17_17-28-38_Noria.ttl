# Example of noria:CorporateUserIdentifier
<https://w3id.org/noria/cuid/jdoe> a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent6 .

<https://w3id.org/noria/cuid/jsmith> a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent7 .

# Example of noria:networkInterfaceRoutingPriorityMetric
noria:NI2_R2 noria:networkInterfaceRoutingPriorityMetric 100 .
noria:NI3_R2 noria:networkInterfaceRoutingPriorityMetric 120 .
noria:NI9_R8 noria:networkInterfaceRoutingPriorityMetric 100 .

# Example of noria:networkInterfaceLaserTxOpticalPower and Rx
noria:NI3_R2 noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 .
noria:NI9_R8 noria:networkInterfaceLaserTxOpticalPower -4 ;
    noria:networkInterfaceLaserRxOpticalPower -6 .

# Example of noria:clusterController
noria:Resource3 noria:clusterController noria:Resource9 . # Web server farm node controlled by load balancer
noria:Resource4 noria:clusterController noria:Resource6 . # Database server (VM) controlled by virtualization host

# Example of noria:virtualServerStatus
noria:Resource15 noria:virtualServerStatus <kos/Resource/OperationalState/Up> . # Assuming it's a VM

# Example of noria:troubleTicketCriticity
noria:TroubleTicket1 noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> .
noria:TroubleTicket3 noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> .

<kos/TroubleTicket/category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the category/criticity of trouble tickets."@en .

<kos/TroubleTicket/category/InterruptedService> a skos:Concept ;
    skos:prefLabel "Interrupted Service"@en ;
    skos:inScheme <kos/TroubleTicket/category> .

<kos/TroubleTicket/category/CorruptedService> a skos:Concept ;
    skos:prefLabel "Corrupted Service"@en ;
    skos:inScheme <kos/TroubleTicket/category> .

# Example of noria:troubleTicketPriority
<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A scheme for classifying the priority of trouble tickets."@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:prefLabel "Priority 1"@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

noria:TroubleTicket1 noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> .
noria:TroubleTicket2 noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> .
noria:TroubleTicket3 noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> .

# Example of noria:troubleTicketUrgency
<kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A scheme for classifying the urgency of trouble tickets."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:prefLabel "Immediate Intervention"@en ;
    skos:inScheme <kos/TroubleTicket/urgency> .

noria:TroubleTicket1 noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> .
noria:TroubleTicket6 noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> .

# Example of noria:problemResponsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying the responsibility for a problem."@en .

<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ;
    skos:prefLabel "Internal IT"@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

noria:TroubleTicket1 noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> .
noria:TroubleTicket5 noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> .

# Example of noria:changeRequestType
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of change requests."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:prefLabel "Standard Change"@en ;
    skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/type/Normal> a skos:Concept ;
    skos:prefLabel "Normal Change"@en ;
    skos:inScheme <kos/ChangeRequest/type> .

noria:ChangeRequest1 noria:changeRequestType <kos/ChangeRequest/type/Normal> .
noria:ChangeRequest3 noria:changeRequestType <kos/ChangeRequest/type/Standard> .

# Example of noria:changeRequestChangeCause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying the cause/reason for change requests."@en .

<kos/ChangeRequest/cause/SecurityPatch> a skos:Concept ;
    skos:prefLabel "Security Patch"@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

<kos/ChangeRequest/cause/NewFeature> a skos:Concept ;
    skos:prefLabel "New Feature"@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

noria:ChangeRequest1 noria:changeRequestChangeCause <kos/ChangeRequest/cause/SecurityPatch> .
noria:ChangeRequest2 noria:changeRequestChangeCause <kos/ChangeRequest/cause/NewFeature> .

# Example of noria:changeRequestSpecification
<kos/ChangeRequest/specification> a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    rdfs:comment "A scheme for classifying the specification of change requests."@en .

<kos/ChangeRequest/specification/StandardProcedure> a skos:Concept ;
    skos:prefLabel "Standard Procedure"@en ;
    skos:inScheme <kos/ChangeRequest/specification> .

noria:ChangeRequest3 noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardProcedure> .

# Example of noria:applicationModuleSlaLevel
<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
    rdfs:label "Application Module SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying the SLA level of application modules."@en .

<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ;
    skos:prefLabel "Gold SLA Level"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

noria:ApplicationModule2 noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime .

# Example of noria:applicationModuleHotlineEnabled
noria:ApplicationModule2 noria:applicationModuleHotlineEnabled "true"^^xsd:boolean .
noria:ApplicationModule3 noria:applicationModuleHotlineEnabled "false"^^xsd:boolean .

# Example of noria:CorporateUserIdentifier
<https://w3id.org/noria/cuid/jdoe> a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent6 .

<https://w3id.org/noria/cuid/jsmith> a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent7 .

# Example of noria:agentPreferredContactMethod
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:prefLabel "Email"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:prefLabel "Phone"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

foaf:Agent1 noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .
foaf:Agent2 noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

