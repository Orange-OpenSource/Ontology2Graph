# --- Services (noria:Service) ---

noria:Service1 a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "Provides end-to-end network connectivity for all corporate locations and users."@en ;
    rdfs:label "Service de Connectivité d'Entreprise"@fr ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule1, noria:ApplicationModule7, noria:ApplicationModule9 .

noria:Service2 a noria:Service ;
    rdfs:label "E-commerce Platform Service"@en ;
    rdfs:comment "The complete service offering for the company's e-commerce operations."@en ;
    rdfs:label "Service Plateforme E-commerce"@fr ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule2, noria:ApplicationModule8, noria:ApplicationModule10 .

noria:Service3 a noria:Service ;
    rdfs:label "Internal Business Application Service"@en ;
    rdfs:comment "Service providing access to internal business applications like CRM."@en ;
    rdfs:label "Service d'Applications Métier Internes"@fr ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:ApplicationModule3, noria:ApplicationModule8 .

noria:Service4 a noria:Service ;
    rdfs:label "Security Monitoring Service"@en ;
    rdfs:comment "Service for continuous monitoring of security events and incidents."@en ;
    rdfs:label "Service de Supervision de Sécurité"@fr ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:ApplicationModule4, noria:ApplicationModule6 .

noria:Service5 a noria:Service ;
