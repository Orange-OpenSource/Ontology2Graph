noria:Resource_DatabaseServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Physical server hosting the main corporate database."@en ;
    noria:resourceLogisticId "RES-DB-001" ;
    noria:resourceHostName "db01.corp.example.com" ;
