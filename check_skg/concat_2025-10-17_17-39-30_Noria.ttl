    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_CorporateDNS, noria:Application_MonitoringPlatform ;
    seas:subSystemOf noria:Resource_CoreRouter01, noria:Resource_Firewall01 .

noria:Service_CRMDataFlow a noria:Service ;
