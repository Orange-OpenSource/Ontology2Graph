	rdfs:isDefinedBy noria: ;
.

noria:changeRequestActorParty
	a owl:ObjectProperty ;
	rdfs:subPropertyOf noria:changeRequestRelatedParty ;
	rdfs:label "changeRequestActorParty" ;
