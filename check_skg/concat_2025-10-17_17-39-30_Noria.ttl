    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:locatedAtLocus noria:Locus_RackB5_U10 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_WebFrontendVM01 a noria:Resource ;
    rdfs:label "Web Frontend VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website frontend."@en ;
    noria:resourceLogisticId "RES-WEB-VM-001" ;
