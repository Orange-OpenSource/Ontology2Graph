    rdfs:comment "Edge router for enterprise and service provider networks."@en ;
    noria:productManufacturedBy org:Manufacturer_Cisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for servers."@en .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the data center."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "23" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5_U10 a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Location for a network device in Server Room A."@en ;
    noria:locusLine "B5" ;
    noria:locusRow "10" ;
    bot:hasSpace noria:Room_ServerRoomA .

bot:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary data center for disaster recovery purposes."@en ;
    noria:siteId "DR01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Road"@en ;
    noria:sitePrincipalAddressCityName "Safetown"@en ;
    noria:sitePrincipalAddressPostalCode "20002"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_DRServerRoom1 a noria:Room ;
    rdfs:label "DR Server Room 1"@en ;
    rdfs:comment "Server room in the disaster recovery site."@en ;
    bot:hasSpace bot:Site_DRSite .

noria:Locus_DRRackC2_U5 a noria:Locus ;
    rdfs:label "DR Rack C2, Unit 5"@en ;
    rdfs:comment "Location for a DR server."@en ;
    noria:locusLine "C2" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room_DRServerRoom1 .

# --- Resources (noria:Resource) ---
noria:Resource_DNSServer01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for the corporate network, hosted in Main DC."@en ;
    noria:resourceLogisticId "RES-DNS-001" ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

