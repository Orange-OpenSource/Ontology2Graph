    rdfs:label "CRM Data Synchronization Service"@en, "Service de Synchronisation des Données CRM"@fr ;
    rdfs:comment "Ensures data consistency between CRM and other business systems."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:ApplicationModuleCRMProd .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecordDNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Outage Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - Network Unreachable"@en ;
    noria:logOriginatingManagedObject noria:ResourceDNS01 ;
    noria:logOriginatingManagementSystem noria:ApplicationMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecordRouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry for a network interface going down on Core Router 01."@en ;
    noria:loggingTime "2024-04-23T10:04:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:ResourceRouterCore01 ;
    noria:logOriginatingManagementSystem noria:ApplicationMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecordAppServerCPUWarning a noria:EventRecord ;
    rdfs:label "App Server CPU Warning"@en ;
    rdfs:comment "Warning log for high CPU utilization on Application Server 01."@en ;
    noria:loggingTime "2024-04-23T09:50:15Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU utilization on appserver01.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:ResourceAppServer01 ;
    noria:logOriginatingManagementSystem noria:ApplicationMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecordConfigChange a noria:EventRecord ;
    rdfs:label "Configuration Change Event"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router 01."@en ;
    noria:loggingTime "2024-04-23T09:30:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jsmith (10.0.0.50)"@en ;
    noria:logOriginatingManagedObject noria:ResourceRouterCore01 ;
    noria:logOriginatingAgent noria:CUidJaneSmith ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> . # Configuration changes can be warnings if not expected.

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TroubleTicketDNSOutage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    dcterms:description "DNS server dns01.corp.example.com is unreachable, causing widespread internet access issues."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketRelatedService noria:ApplicationModuleInternetAccessProd ;
    noria:troubleTicketRelatedParty noria:AgentNOC ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecordDNSOutageLog ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network connectivity loss to DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketImpacts noria:ApplicationModuleInternetAccessProd, noria:ResourceDNS01 ;
    noria:documentExternalId "INC-2024-04-23-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-2024-04-23-001" ;
    noria:documentStatusHistory noria:EventRecordDNSOutageLog .

noria:TroubleTicketCRMPerformance a noria:TroubleTicket ;
    rdfs:label "CRM Performance Degradation"@en, "Dégradation Performance CRM"@fr ;
    dcterms:description "Users report slow response times for the CRM application."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketRelatedService noria:ApplicationModuleCRMProd ;
    noria:troubleTicketRelatedParty noria:AgentAppDev ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T09:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketImpacts noria:ApplicationModuleCRMProd, noria:ResourceAppServer01, noria:ResourceDBServer01 ;
    noria:documentExternalId "INC-2024-04-23-002" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-2024-04-23-002" .

# =============================================================================
# Trouble Ticket Notes
# =============================================================================

noria:TroubleTicketNoteDNSDiag1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Diagnosis Note 1"@en ;
    dcterms:description "Initial diagnosis: Ping to DNS server fails. Checking network path."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicketDNSOutage .

noria:TroubleTicketNoteDNSDiag2 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Diagnosis Note 2"@en ;
    dcterms:description "Traceroute shows connectivity loss at router-core-01. Investigating interface Gi0/0/1."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicketDNSOutage .

# =============================================================================
# Change Requests
# =============================================================================

noria:ChangeRequestRouterUpgrade a noria:ChangeRequest ;
    rdfs:label "Core Router Software Upgrade"@en, "Mise à Jour Logicielle Routeur Cœur"@fr ;
    dcterms:description "Upgrade IOS-XE software on router-core-01 to address security vulnerabilities."@en ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:ResourceRouterCore01, noria:ApplicationModuleInternetAccessProd ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ; # 1 hour 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RoutineMaintenance> ;
    noria:changeRequestInitiatorParty noria:AgentNOC ;
    noria:changeRequestPilotParty noria:AgentInfraOps ;
    noria:changeRequestActorParty noria:AgentInfraOps ;
    noria:changeRequestIsRegulated true ;
    noria:documentExternalId "CR-2024-05-01-001" ;
    noria:documentHRef "https://itsm.example.com/change/CR-2024-05-01-001" .

noria:ChangeRequestDBMigration a noria:ChangeRequest ;
    rdfs:label "CRM Database Migration"@en, "Migration Base de Données CRM"@fr ;
    dcterms:description "Migrate CRM database from on-premise to cloud infrastructure."@en ;
    noria:changeRequestPlannedStartTime "2024-06-15T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-06-16T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ; # Can be considered an upgrade of platform
    noria:changeRequestImpact noria:ResourceDBServer01, noria:ApplicationModuleCRMProd ;
    noria:changeRequestOutageDuration "PT4H"^^xsd:duration ; # 4 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty noria:AgentDBA ;
    noria:changeRequestPilotParty noria:AgentAppDev ;
    noria:changeRequestActorParty noria:AgentDBA ;
    noria:changeRequestIsRegulated false ;
    noria:documentExternalId "CR-2024-06-15-001" ;
    noria:documentHRef "https://itsm.example.com/change/CR-2024-06-15-001" .

# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlanRouterReload a noria:OperationPlan ;
    rdfs:label "Core Router Reload Procedure"@en, "Procédure de Redémarrage Routeur Cœur"@fr ;
    rdfs:comment "Standard operating procedure for reloading a core router."@en ;
    noria:operationPlanPreCondition noria:PreConditionRouterReachability ;
    noria:operationPlanPostCondition noria:PostConditionRouterUp .

noria:OperationPlanDNSCheck a noria:OperationPlan ;
    rdfs:label "DNS Service Health Check"@en, "Vérification Santé Service DNS"@fr ;
    rdfs:comment "Procedure to verify the operational status of DNS services."@en ;
    noria:operationPlanPreCondition noria:PreConditionNetworkConnectivity ;
    noria:operationPlanPostCondition noria:PostConditionDNSResolution .

noria:PreConditionRouterReachability a noria:ActionPreCondition ;
    rdfs:label "Router Reachability Check"@en ;
    rdfs:comment "Verify that the router is reachable via management IP and console."@en .

noria:PreConditionNetworkConnectivity a noria:ActionPreCondition ;
    rdfs:label "Network Connectivity Check"@en ;
    rdfs:comment "Ensure basic network connectivity to the DNS server's subnet."@en .

noria:PostConditionRouterUp a noria:ActionPostCondition ;
    rdfs:label "Router Operational Status Up"@en ;
    rdfs:comment "Confirm that the router has fully booted and all interfaces are up."@en .

noria:PostConditionDNSResolution a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Functional"@en ;
    rdfs:comment "Verify that DNS queries are successfully resolved by the DNS server."@en .

# Linking Operation Plans to Change Requests (example)
noria:ChangeRequestRouterUpgrade
    noria:actionCorrelatedOperationPlan noria:OperationPlanRouterReload .

# Linking Event Records to Operation Plans (example of proposed repair action)
noria:EventRecordRouterInterfaceDown
    noria:alarmProposedRepairAction noria:OperationPlanRouterReload .

# Example of a Corporate User Identifier being the originator of an event
noria:EventRecordConfigChange
    noria:logOriginatingAgent noria:CUidJaneSmith .

# Example of a Trouble Ticket Note being correlated to an execution (implicitly via pep:ProcedureExecutionContainer)
# The vocabulary states that TroubleTicketNote is a subclass of pep:ProcedureExecutionContainer,
# so we can directly link EventRecords to it via pep:member.
noria:TroubleTicketNoteDNSDiag1
    pep:member noria:EventRecordRouterInterfaceDown . # This implies the diagnosis note is part of the execution container that includes this event.

# Example of a Trouble Ticket's status history being recorded by EventRecords
noria:TroubleTicketDNSOutage
    noria:documentStatusHistory noria:EventRecordDNSOutageLog . # This event marks the start of the incident.
# More events could be added here to show status changes.

# Example of a resource being a cluster controller for another resource (e.g., a hypervisor managing VMs)
noria:ResourceHypervisor01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "VMware ESXi host managing virtual machines."@en ;
    noria:resourceManagedBy noria:AgentInfraOps ;
    noria:resourceProductModel noria:ProductModelDellR740 ;
    noria:resourceHostName "hypervisor01.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceManagementIPAddress "10.0.0.20" ;
    noria:locatedAtLocus noria:LocusR1C5 .

noria:ResourceVMApp01 a noria:Resource ;
    rdfs:label "Virtual Machine for App 01"@en ;
    rdfs:comment "Virtual machine hosting a component of Application CRM."@en ;
    noria:resourceManagedBy noria:AgentAppDev ;
    noria:resourceProductModel noria:ProductModelVMwareESXi ; # The VM is 'of' this product model (hypervisor type)
    noria:resourceHostName "vmapp01.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceForApplication noria:ApplicationCRM ;
    noria:clusterController noria:ResourceHypervisor01 . # VM is controlled by the hypervisor.

noria:ResourceHypervisor01
    seas:subSystemOf noria:ApplicationModuleMonitoringProd . # Hypervisor is part of the monitoring application's infrastructure.

# Example of network interface optical power metrics
noria:NetworkInterfaceRouterCore01Gi0_0_0
    noria:networkInterfaceLaserTxOpticalPower -2 ; # -2 dBm
    noria:networkInterfaceLaserRxOpticalPower -5 ; # -5 dBm
    noria:networkInterfaceLaserRxOpticalPowerAverage -4 ; # -4 dBm
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ; # -1 dBm
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 . # -10 dBm

# Example of virtual server status
noria:ResourceVMApp01
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

