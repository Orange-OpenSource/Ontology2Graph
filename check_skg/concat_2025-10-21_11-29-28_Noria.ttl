    noria:networkInterfaceRoutingPriorityMetric 60 ;
    noria:networkInterfaceDescription "Internal DC network link."@en ;
    noria:networkInterfaceType "physical" .

noria:NetworkInterfaceAppServer01Eth0 a noria:NetworkInterface ;
