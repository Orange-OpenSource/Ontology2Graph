# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS (Knowledge Organization System) Concepts
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for application types."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Application providing core infrastructure services."@en .

<kos/application/type/business> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "Application supporting specific business functions."@en .

<kos/application/type/monitoring> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "Application used for system and network monitoring."@en .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for application business importance."@en .

<kos/application/business-importance/high> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application critical for core business operations."@en .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application important but not critical for immediate business operations."@en .

<kos/application/business-importance/low> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Low Business Importance"@en ;
    rdfs:comment "Application with minimal business impact if unavailable."@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Module Status Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for application module operational status."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en, "En Production"@fr ;
    rdfs:comment "The application module is currently active and serving users."@en .

<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Under Maintenance"@en, "En Maintenance"@fr ;
    rdfs:comment "The application module is currently undergoing maintenance."@en .

# Service Types
<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for service types."@en .

<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "Service directly consumed by customers."@en .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "Service supporting other services or internal operations."@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket severity levels."@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical"@en, "Critique"@fr ;
    rdfs:comment "Service completely down or major business impact."@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en, "Majeur"@fr ;
    rdfs:comment "Significant service degradation or partial outage."@en .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor"@en, "Mineur"@fr ;
    rdfs:comment "Small impact, non-critical issue."@en .

# Trouble Ticket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket types."@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en, "Panne"@fr ;
    rdfs:comment "Indicates a system or service failure."@en .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Request for user assistance."@en .

# Trouble Ticket Category
<kos/TroubleTicket/category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket categories."@en .

<kos/TroubleTicket/category/InterruptedService> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "Service is completely unavailable."@en .

<kos/TroubleTicket/category/CorruptedService> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Corrupted Service"@en ;
    rdfs:comment "Service is available but data or functionality is compromised."@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket priority levels."@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate action required."@en .

<kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, urgent action required."@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket origins."@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Ticket initiated by a customer."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System Origin"@en ;
    rdfs:comment "Ticket initiated by an automated monitoring system."@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket urgency levels."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action."@en .

# Trouble Ticket Trouble Category
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the nature of the incident."@en .

<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Complete failure of a system or component."@en .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for problem responsibility."@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility lies with the team managing backbone networks."@en .

# Trouble Ticket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket statuses."@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en, "En Cours"@fr ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en, "Résolu"@fr ;
    rdfs:comment "The issue described in the ticket has been resolved."@en .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket note comment types."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment visible only to internal teams."@en .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket note operation types."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Note related to diagnostic steps taken."@en .

# Change Request Category
<kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for change request categories."@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change performed by internal teams."@en .

# Change Request Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for change request types."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Pre-approved change with low risk."@en .

# Change Request Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for change request causes."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change due to software version upgrade."@en .

# Change Request Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for change request statuses."@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "Change request has been approved."@en .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "Change request has been successfully implemented."@en .

# Change Request Specification
<kos/ChangeRequest/specification> a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for change request specifications."@en .

<kos/ChangeRequest/specification/RoutineMaintenance> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Routine Maintenance"@en ;
    rdfs:comment "Specification for routine maintenance tasks."@en .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for resource operational states."@en .

<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is operational."@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for resource administrative states."@en .

<kos/Resource/AdministrativeState/Enabled> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Enabled"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Disabled> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Disabled"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

# Resource Type
<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for resource types."@en .

<kos/Resource/type/Server> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computing server resource."@en .

<kos/Resource/type/Router> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router resource."@en .

<kos/Resource/type/Switch> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network switch resource."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for resource lifecycle states."@en .

<kos/Resource/LifecycleState/InUse> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Use"@en ;
    rdfs:comment "Resource is actively being used in production."@en .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "Resource has been removed from service."@en .

# Notification Severity Perceived Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for perceived severity of notifications."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Highest severity, immediate attention required."@en .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Indicates a potential issue that needs attention."@en .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

<kos/org/agent-contact-method/phone> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Contact via telephone."@en .

<kos/org/agent-contact-method/email> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Contact via email."@en .

# =============================================================================
# Agents and Organizational Units
# =============================================================================

noria:AgentNOC a foaf:Agent ;
    rdfs:label "Network Operations Center Team"@en, "Équipe du Centre d'Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for 24/7 network monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Contact via dedicated hotline for critical issues."@en ;
    foaf:mbox "noc@example.com" .

noria:AgentAppDev a foaf:Agent ;
    rdfs:label "Application Development Team"@en, "Équipe de Développement Applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit tickets via JIRA for non-critical issues."@en ;
    foaf:mbox "appdev@example.com" .

noria:AgentInfraOps a foaf:Agent ;
    rdfs:label "Infrastructure Operations Team"@en, "Équipe Opérations Infrastructure"@fr ;
    rdfs:comment "Team managing physical and virtual infrastructure."@en ;
    noria:agentWorkingHours "8:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Use internal ticketing system for all requests."@en ;
    foaf:mbox "infraops@example.com" .

noria:AgentSecurity a foaf:Agent ;
    rdfs:label "Security Operations Center"@en, "Centre d'Opérations de Sécurité"@fr ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident handling."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Escalate security incidents immediately."@en ;
    foaf:mbox "soc@example.com" .

noria:AgentDBA a foaf:Agent ;
    rdfs:label "Database Administration Team"@en, "Équipe d'Administration de Bases de Données"@fr ;
    rdfs:comment "Team responsible for database management and support."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Open a ticket for any database-related issue."@en ;
    foaf:mbox "dba@example.com" .

noria:OrgUnitITDept a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en, "Département Informatique"@fr ;
    rdfs:comment "The main IT department of the organization."@en ;
    org:hasMember noria:AgentNOC, noria:AgentAppDev, noria:AgentInfraOps, noria:AgentSecurity, noria:AgentDBA .

noria:CUidJohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe, a member of the AppDev team."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount noria:AgentAppDev .

noria:CUidJaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Jane Smith, a member of the InfraOps team."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount noria:AgentInfraOps .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModelCisco9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-class stackable access switch."@en ;
    noria:productManufacturedBy noria:OrgCisco .

noria:ProductModelDellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server."@en ;
    noria:productManufacturedBy noria:OrgDell .

noria:ProductModelJuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "Modular router for enterprise and service provider applications."@en ;
    noria:productManufacturedBy noria:OrgJuniper .

noria:ProductModelVMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi"@en ;
    rdfs:comment "Type-1 hypervisor for creating and running virtual machines."@en ;
    noria:productManufacturedBy noria:OrgVMware .

noria:OrgCisco a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
