# =============================================================================
# Locations (Sites, Rooms, Loci)
# =============================================================================

noria:SiteParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:SiteLyonOffice a bot:Site ;
    rdfs:label "Lyon Office Building"@en, "Bâtiment de Bureaux de Lyon"@fr ;
    noria:siteId "OFF-LYN-02" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:RoomA101 a noria:Room ;
    rdfs:label "Server Room A101"@en, "Salle Serveurs A101"@fr ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace noria:SiteParisDC .

noria:RoomB202 a noria:Room ;
    rdfs:label "Network Equipment Room B202"@en, "Salle Équipements Réseau B202"@fr ;
    rdfs:comment "Dedicated room for network devices in Paris Data Center."@en ;
    bot:hasSpace noria:SiteParisDC .

noria:LocusR1C5 a noria:Locus ;
    rdfs:label "Rack 1, Column 5"@en ;
    rdfs:comment "Specific location for equipment in Room A101."@en ;
    noria:locusLine "R1" ;
    noria:locusRow "C5" ;
    bot:containsZone noria:RoomA101 .

noria:LocusR2C10 a noria:Locus ;
    rdfs:label "Rack 2, Column 10"@en ;
    rdfs:comment "Specific location for equipment in Room B202."@en ;
    noria:locusLine "R2" ;
    noria:locusRow "C10" ;
    bot:containsZone noria:RoomB202 .

