noria:ServiceCorporateVPN a noria:Service ;
    rdfs:label "Corporate VPN Service"@en, "Service VPN d'Entreprise"@fr ;
    rdfs:comment "Provides secure remote access to corporate resources for employees."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModuleInternetAccessProd . # Linking service to an application module.

