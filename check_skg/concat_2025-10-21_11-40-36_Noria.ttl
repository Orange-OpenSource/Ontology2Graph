# --- Network Interfaces ---
noria:NetInt_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to application VLAN" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects noria:NetLink_WebSrv01_to_CoreSwitch .

noria:NetInt_DBSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBSrv01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to database VLAN" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects noria:NetLink_DBSrv01_to_CoreSwitch .

noria:NetInt_CoreRouter01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router 01 to internal network."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Internal LAN connection" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:NetLink_CoreRouter01_to_Firewall .

noria:NetInt_CoreRouter01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to external network."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "External WAN connection" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceConnects noria:NetLink_CoreRouter01_to_ISP .

noria:NetInt_Firewall01_Eth1 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet 1"@en ;
    rdfs:comment "Internal interface of Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Internal network segment" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects noria:NetLink_CoreRouter01_to_Firewall .

noria:NetInt_Firewall01_Eth2 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet 2"@en ;
    rdfs:comment "External interface of Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "External network segment" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects noria:NetLink_Firewall01_to_ISP .

# --- Network Links ---
noria:NetLink_WebSrv01_to_CoreSwitch a noria:NetworkLink ;
    rdfs:label "WebSrv01 to Core Switch Link"@en ;
    rdfs:comment "Ethernet link between Web Server 01 and the core switch (logical representation)."@en ;
    noria:networkLinkId "NL-WEB01-CS" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-15T10:05:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 . # Assuming CoreRouter01 acts as core switch for simplicity

noria:NetLink_DBSrv01_to_CoreSwitch a noria:NetworkLink ;
    rdfs:label "DBSrv01 to Core Switch Link"@en ;
    rdfs:comment "Ethernet link between Database Server 01 and the core switch (logical representation)."@en ;
    noria:networkLinkId "NL-DB01-CS" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-15T11:05:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DBSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 .

noria:NetLink_CoreRouter01_to_Firewall a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Firewall 01 Link"@en ;
    rdfs:comment "Internal link between core router and firewall."@en ;
    noria:networkLinkId "NL-CR01-FW01-INT" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2022-05-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01 .

noria:NetLink_CoreRouter01_to_ISP a noria:NetworkLink ;
    rdfs:label "Core Router 01 to ISP Link"@en ;
    rdfs:comment "External link from core router to Internet Service Provider."@en ;
    noria:networkLinkId "NL-CR01-ISP" ;
    noria:networkLinkType "MPLS" ;
    noria:networkLinkInstallationDate "2022-05-01T09:45:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01 . # Simplified, ISP is external to Firewall01

noria:NetLink_Firewall01_to_ISP a noria:NetworkLink ;
    rdfs:label "Firewall 01 to ISP Link"@en ;
    rdfs:comment "External link from firewall to Internet Service Provider."@en ;
    noria:networkLinkId "NL-FW01-ISP" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2022-06-01T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Firewall01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 . # Simplified, ISP is external to CoreRouter01

# --- Applications ---
noria:App_Ecommerce a noria:Application ;
    rdfs:label "E-commerce Platform"@en ;
    rdfs:label "Plateforme E-commerce"@fr ;
