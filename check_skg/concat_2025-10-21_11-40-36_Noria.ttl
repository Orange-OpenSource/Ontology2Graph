    noria:loggingTime "2024-03-20T12:00:00Z"^^xsd:dateTime ;
    noria:logText "CRM_PROD: Critical component 'CustomerAuth' failed to initialize."@en ;
    noria:logOriginatingManagedObject noria:AppMod_CRM_Prod ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

# More Trouble Tickets
