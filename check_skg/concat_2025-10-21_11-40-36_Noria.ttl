    noria:logText "Daily backup job for E-commerce database failed with error code 123."@en ;
    noria:logOriginatingManagedObject noria:Resource_BackupServer ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_CRMFailure a noria:EventRecord ;
    rdfs:label "CRM Application Error"@en ;
