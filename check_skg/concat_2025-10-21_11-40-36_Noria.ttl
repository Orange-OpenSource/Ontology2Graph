    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Service Development, Management and Operations" ;
    noria:applicationFunctionalSubDomain "Reporting and Analytics" .

noria:App_MonitoringSystem a noria:Application ;
