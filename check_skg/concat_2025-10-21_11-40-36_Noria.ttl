    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:Event_CRMFailure ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:AppMod_CRM_Prod, noria:Service_CustomerSupport ;
    noria:troubleTicketRelatedParty noria:Agent_CustomerService, noria:Agent_AppSupportL2 ;
    noria:documentExternalId "CUST-INC-2024-005" .

# More Change Requests
noria:CR_RouterFirmwareUpgrade_003 a noria:ChangeRequest ;
    rdfs:label "Core Router Firmware Upgrade"@en ;
    rdfs:comment "Planned firmware upgrade for Core Router 01 to address security vulnerabilities."@en ;
    noria:changeRequestPlannedStartTime "2024-04-05T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-05T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_CoreRouter01 ;
    noria:changeRequestOutageDuration "PT15M"^^xsd:duration ;
