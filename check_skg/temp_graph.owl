  <rdf:Description rdf:about="https://w3id.org/noria/data/instance/resource/virtual_server_01">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/Resource"/>
    <rdfs:label xml:lang="en">Virtual Server 01</rdfs:label>
