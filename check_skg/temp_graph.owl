    <noria:loggingTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-04-23T10:10:00+00:00</noria:loggingTime>
    <noria:logText xml:lang="en">ERROR: Failed to connect to database 'prod_db' from application 'CRM'. Connection timed out.</noria:logText>
    <noria:logOriginatingManagedObject rdf:resource="https://w3id.org/noria/ontology/Resource4"/>
    <noria:logOriginatingManagementSystem rdf:resource="https://w3id.org/noria/ontology/Application6"/>
    <noria:logOriginatingManagementSystem rdf:resource="https://w3id.org/noria/ontology/Application2"/>
    <noria:alarmSeverity rdf:resource="https://w3id.org/noria/Notification/Severity/PerceivedSeverity/Minor"/>
    <noria:alarmSeverity rdf:resource="https://w3id.org/noria/Notification/Severity/PerceivedSeverity/Warning"/>
    <dcterms:references rdf:resource="https://w3id.org/noria/ontology/TroubleTicket4"/>
    <dcterms:identifier>EVT-20240423-004</dcterms:identifier>
    <dcterms:description xml:lang="en">CPU usage exceeded 90% for 15 minutes on db-srv-01.</dcterms:description>
    <dcterms:type rdf:resource="https://w3id.org/noria/kos/Notification/EventType/ThresholdCrossing"/>
    <dcterms:conformsTo rdf:resource="https://w3id.org/noria/kos/Notification/ProbableCause/NetworkCongestion"/>
  </rdf:Description>
