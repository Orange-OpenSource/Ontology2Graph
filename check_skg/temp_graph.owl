  <rdf:Description rdf:about="https://w3id.org/noria/ontology/EventRecordRouterInterfaceDown">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/EventRecord"/>
    <rdfs:label xml:lang="en">Router Interface Down Event</rdfs:label>
    <rdfs:comment xml:lang="en">Log entry for a network interface going down on Core Router 01.</rdfs:comment>
