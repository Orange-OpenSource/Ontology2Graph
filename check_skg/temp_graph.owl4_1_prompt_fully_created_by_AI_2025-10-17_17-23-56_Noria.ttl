  <rdf:Description rdf:about="https://w3id.org/noria/operationPlan/DB_DiskExpansion_Procedure">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/OperationPlan"/>
    <rdfs:label xml:lang="en">Database Disk Expansion Procedure</rdfs:label>
    <rdfs:comment xml:lang="en">Standard operating procedure for expanding disk space on database servers.</rdfs:comment>
    <skos:example xml:lang="en">Steps include: 1. Backup database. 2. Add new disk/expand LVM. 3. Extend filesystem. 4. Verify.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na8c6ffb16052411ba01fbfea5d9bb7ffb92">
    <rdf:first rdf:nodeID="na8c6ffb16052411ba01fbfea5d9bb7ffb90"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/noria/operationPlan/Internet_Failover_Procedure">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/OperationPlan"/>
    <rdfs:label xml:lang="en">Internet Link Failover Procedure</rdfs:label>
    <rdfs:comment xml:lang="en">Procedure to activate backup internet link in case of primary link failure.</rdfs:comment>
    <skos:example xml:lang="en">Steps include: 1. Verify primary link status. 2. Force routing to backup. 3. Verify internet access. 4. Notify stakeholders.</skos:example>
  </rdf:Description>
