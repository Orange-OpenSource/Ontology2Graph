  <rdf:Description rdf:about="https://w3id.org/noria/anomalyPattern/HighCPULowDisk">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/AnomalyPattern"/>
    <rdfs:label xml:lang="en">High CPU and Low Disk Space Pattern</rdfs:label>
    <rdfs:comment xml:lang="en">Anomaly pattern indicating a potential resource exhaustion issue where a server experiences both high CPU usage and critically low disk space, often preceding a crash or service degradation.</rdfs:comment>
    <skos:example xml:lang="en">If (CPU &gt; 90% for 5min) AND (Disk_Usage &gt; 95%), then trigger this pattern.</skos:example>
  </rdf:Description>
