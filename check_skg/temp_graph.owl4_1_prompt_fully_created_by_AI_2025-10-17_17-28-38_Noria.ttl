    <noria:troubleTicketDescription xml:lang="en">DNS server dns01.corp.example.com is not responding to queries. Impacting all internal services.</noria:troubleTicketDescription>
    <noria:troubleTicketTrigger rdf:resource="https://w3id.org/noria/ontology/EventRecord1"/>
    <noria:documentStatusHistory rdf:resource="https://w3id.org/noria/ontology/EventRecord1"/>
    <noria:documentStatusHistory rdf:resource="https://w3id.org/noria/ontology/EventRecord2_TT1_Resolved"/>
    <noria:troubleTicketImpacts rdf:resource="https://w3id.org/noria/ontology/Application9"/>
    <noria:troubleTicketImpacts rdf:resource="https://w3id.org/noria/ontology/Resource1"/>
    <noria:troubleTicketCriticity rdf:resource="https://w3id.org/noria/kos/TroubleTicket/category/InterruptedService"/>
    <noria:troubleTicketPriority rdf:resource="https://w3id.org/noria/kos/TroubleTicket/priority/P1"/>
    <noria:troubleTicketUrgency rdf:resource="https://w3id.org/noria/kos/TroubleTicket/urgency/ImmediateIntervention"/>
    <noria:problemResponsibility rdf:resource="https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/InternalIT"/>
    <noria:troubleTicketSupervisionTool>Nagios</noria:troubleTicketSupervisionTool>
    <noria:troubleTicketCause xml:lang="en">DNS service process crashed due to memory leak.</noria:troubleTicketCause>
