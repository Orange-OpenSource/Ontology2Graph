  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/noria/ontology/logOriginatingAgent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>logOriginatingAgent</rdfs:label>
    <rdfs:comment xml:lang="en">The Agent at the origin of the Log record whenever it represents some action carried out on the ICT system. This includes information about the service user associated with the service request that caused a security alarm.</rdfs:comment>
    <skos:example xml:lang="en">A employee or maintenance bot that carried-out a change or corrective maintenance action. A service user that carried-out SQL Injection.</skos:example>
