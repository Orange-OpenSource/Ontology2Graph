    <rdfs:label xml:lang="fr">Déploiement de Fonctionnalités Portail Client</rdfs:label>
    <rdfs:comment xml:lang="en">Deployment of new features for the customer portal application.</rdfs:comment>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-03-15T11:00:00+00:00</dcterms:created>
