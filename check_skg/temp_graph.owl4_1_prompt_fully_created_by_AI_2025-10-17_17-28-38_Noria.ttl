    <noria:troubleTicketPlannedRestorationDateTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-04-10T09:50:00+00:00</noria:troubleTicketPlannedRestorationDateTime>
    <noria:troubleTicketCommittedRestorationDateTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-04-10T11:00:00+00:00</noria:troubleTicketCommittedRestorationDateTime>
    <noria:troubleTicketIsNotificationEnable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</noria:troubleTicketIsNotificationEnable>
    <noria:documentHRef rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://itsm.example.com/ticket/TT12345</noria:documentHRef>
