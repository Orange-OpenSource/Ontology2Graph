    <noria:troubleTicketOrigin rdf:resource="https://w3id.org/noria/kos/TroubleTicket/origin/Supervision"/>
    <noria:troubleTicketStatusCurrent rdf:resource="https://w3id.org/noria/kos/TroubleTicket/status/InProgress"/>
    <noria:troubleTicketRelatedService rdf:resource="https://w3id.org/noria/ontology/Service1"/>
    <noria:troubleTicketRelatedResource rdf:resource="https://w3id.org/noria/ontology/Resource2"/>
    <noria:troubleTicketRelatedParty rdf:resource="http://xmlns.com/foaf/0.1/Agent2"/>
    <noria:troubleTicketDetectionDateTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-04-11T11:25:00+00:00</noria:troubleTicketDetectionDateTime>
    <noria:troubleTicketDescription xml:lang="en">Interface ge-0/0/1 on cr01.par.example.com is down. Lyon office unreachable.</noria:troubleTicketDescription>
    <noria:troubleTicketTrigger rdf:resource="https://w3id.org/noria/ontology/EventRecord2"/>
    <noria:documentStatusHistory rdf:resource="https://w3id.org/noria/ontology/EventRecord2"/>
    <noria:troubleTicketImpacts rdf:resource="https://w3id.org/noria/ontology/Service1"/>
    <noria:troubleTicketImpacts rdf:resource="https://w3id.org/noria/ontology/Resource2"/>
    <noria:troubleTicketImpacts rdf:resource="https://w3id.org/noria/ontology/NL6"/>
    <noria:troubleTicketPriority rdf:resource="https://w3id.org/noria/kos/TroubleTicket/priority/P1"/>
    <noria:troubleTicketSupervisionTool>Zabbix</noria:troubleTicketSupervisionTool>
    <noria:troubleTicketCause xml:lang="en">Fiber cut on WAN link between Paris and Lyon.</noria:troubleTicketCause>
    <noria:troubleTicketTargetRestorationDateTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-04-11T15:00:00+00:00</noria:troubleTicketTargetRestorationDateTime>
  </rdf:Description>
