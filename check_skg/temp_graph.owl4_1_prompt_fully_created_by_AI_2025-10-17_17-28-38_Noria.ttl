  <rdf:Description rdf:about="https://w3id.org/noria/ontology/TroubleTicket2">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/TroubleTicket"/>
    <rdfs:label xml:lang="en">Core Router 1 Link Down</rdfs:label>
    <rdfs:label xml:lang="fr">Liaison Routeur Cœur 1 Hors Service</rdfs:label>
    <rdfs:comment xml:lang="en">WAN link from Core Router 1 to Edge Router 1 is down, affecting Lyon office connectivity.</rdfs:comment>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-04-11T11:30:00+00:00</dcterms:created>
    <noria:troubleTicketSeverity rdf:resource="https://w3id.org/noria/kos/TroubleTicket/severity/Major"/>
