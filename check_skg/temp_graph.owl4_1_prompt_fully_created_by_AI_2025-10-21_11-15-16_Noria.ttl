  <rdf:Description rdf:about="https://w3id.org/noria/ontology/AnomalyPattern_HighCPUDatabase">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/AnomalyPattern"/>
    <rdfs:label xml:lang="en">High CPU on Database Server Pattern</rdfs:label>
    <rdfs:comment xml:lang="en">Pattern indicating a potential database performance issue due to sustained high CPU usage.</rdfs:comment>
    <skos:example xml:lang="en">Triggered when CPU usage on DB server exceeds 80% for more than 15 minutes, correlated with slow query logs.</skos:example>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/noria/ontology/OrgUnit_NetOpsTeam">
