    <rdfs:label xml:lang="en">Network Operations Team</rdfs:label>
    <rdfs:comment xml:lang="en">Team responsible for managing and maintaining network infrastructure.</rdfs:comment>
    <skos:example xml:lang="en">Handles routing, switching, and firewall configurations.</skos:example>
    <noria:agentWorkingHours rdf:datatype="http://www.w3.org/2001/XMLSchema#string">24/7 (on-call rotation)</noria:agentWorkingHours>
    <noria:agentPreferredContactMethod rdf:resource="https://w3id.org/noria/kos/org/agent-contact-method/email"/>
    <noria:agentInstructions xml:lang="en">For critical issues, call the on-call number after sending an email.</noria:agentInstructions>
