  <rdf:Description rdf:about="https://w3id.org/noria/ontology/alarmSeverity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>alarmSeverity</rdfs:label>
    <rdfs:comment xml:lang="en">Indication of how it is perceived that the capability of the managed object has been affected, or how serious are the service affecting conditions (including for security alarms).</rdfs:comment>
    <skos:example xml:lang="en">Critical, Major, Minor, Warning.</skos:example>
