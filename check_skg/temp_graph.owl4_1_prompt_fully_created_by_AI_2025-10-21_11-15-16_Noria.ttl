  <rdf:Description rdf:about="https://w3id.org/noria/ontology/troubleTicketPriority">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label xml:lang="en">troubleTicketPriority</rdfs:label>
