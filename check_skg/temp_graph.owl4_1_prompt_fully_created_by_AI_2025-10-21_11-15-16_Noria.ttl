  <rdf:Description rdf:about="https://w3id.org/noria/ontology/OrgUnit_SecurityTeam">
    <rdf:type rdf:resource="http://www.w3.org/ns/org#OrganizationalUnit"/>
    <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
    <rdfs:label xml:lang="en">Cybersecurity Operations Center (CSOC)</rdfs:label>
    <rdfs:comment xml:lang="en">Team dedicated to monitoring, detecting, and responding to cybersecurity threats.</rdfs:comment>
    <skos:example xml:lang="en">Monitors SIEM alerts and performs incident response.</skos:example>
    <noria:agentWorkingHours rdf:datatype="http://www.w3.org/2001/XMLSchema#string">24/7 (shift-based)</noria:agentWorkingHours>
    <noria:agentPreferredContactMethod rdf:resource="https://w3id.org/noria/kos/org/agent-contact-method/phone"/>
    <noria:agentInstructions xml:lang="en">Immediate phone call for critical security incidents.</noria:agentInstructions>
    <noria:agentManagesResource rdf:resource="https://w3id.org/noria/ontology/Resource_Firewall001"/>
  </rdf:Description>
