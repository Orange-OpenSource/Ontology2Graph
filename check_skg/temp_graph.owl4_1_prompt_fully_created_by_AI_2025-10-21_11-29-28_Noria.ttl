    <skos:changeNote>Change in v0.2:
- rdfs:domain moved from noria:Employee to foaf:Agent.
- name and label moved from employeePreferredContactMethod to agentPreferredContactMethod.
- adding rdfs:subPropertyOf observable:contactNote.
</skos:changeNote>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/noria/ontology/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/noria/ontology/troubleTicketIsNotificationEnable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>troubleTicketIsNotificationEnable</rdfs:label>
