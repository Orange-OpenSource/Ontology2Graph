    <rdfs:subPropertyOf rdf:resource="https://w3id.org/noria/ontology/elementManagedBy"/>
    <vs:term_status>unstable</vs:term_status>
    <skos:changeNote>Changes in v0.2:
- Adding rdfs:subPropertyOf noria:elementManagedBy.</skos:changeNote>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/noria/ontology/"/>
  </rdf:Description>
