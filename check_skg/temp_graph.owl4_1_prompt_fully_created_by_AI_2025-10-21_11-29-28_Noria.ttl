    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>siteType</rdfs:label>
    <rdfs:comment xml:lang="en">The type of a Site.</rdfs:comment>
    <skos:example>building, data center, rack</skos:example>
    <vs:term_status>unstable</vs:term_status>
