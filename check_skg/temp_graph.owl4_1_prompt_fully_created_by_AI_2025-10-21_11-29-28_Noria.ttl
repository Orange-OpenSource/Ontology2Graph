    <noria:changeRequestPlannedStartTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-05-01T02:00:00+00:00</noria:changeRequestPlannedStartTime>
    <noria:changeRequestPlannedEndTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-05-01T04:00:00+00:00</noria:changeRequestPlannedEndTime>
    <noria:changeRequestCategory rdf:resource="https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention"/>
    <noria:changeRequestType rdf:resource="https://w3id.org/noria/kos/ChangeRequest/type/Standard"/>
    <noria:changeRequestChangeCause rdf:resource="https://w3id.org/noria/kos/ChangeRequest/cause/SoftwareUpgrade"/>
    <noria:changeRequestImpact rdf:resource="https://w3id.org/noria/ontology/ResourceRouterCore01"/>
    <noria:changeRequestImpact rdf:resource="https://w3id.org/noria/ontology/ApplicationModuleInternetAccessProd"/>
    <noria:changeRequestOutageDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#duration">PT1H30M</noria:changeRequestOutageDuration>
    <noria:changeRequestStatusCurrent rdf:resource="https://w3id.org/noria/kos/ChangeRequest/status/Approved"/>
    <noria:changeRequestSpecification rdf:resource="https://w3id.org/noria/kos/ChangeRequest/specification/RoutineMaintenance"/>
    <noria:changeRequestInitiatorParty rdf:resource="https://w3id.org/noria/ontology/AgentNOC"/>
    <noria:changeRequestPilotParty rdf:resource="https://w3id.org/noria/ontology/AgentInfraOps"/>
    <noria:changeRequestActorParty rdf:resource="https://w3id.org/noria/ontology/AgentInfraOps"/>
    <noria:changeRequestIsRegulated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</noria:changeRequestIsRegulated>
    <noria:documentExternalId>CR-2024-05-01-001</noria:documentExternalId>
    <noria:documentHRef>https://itsm.example.com/change/CR-2024-05-01-001</noria:documentHRef>
