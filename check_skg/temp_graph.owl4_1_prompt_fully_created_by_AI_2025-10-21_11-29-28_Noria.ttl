    <rdfs:label xml:lang="en">Network Connectivity Check</rdfs:label>
    <rdfs:comment xml:lang="en">Ensure basic network connectivity to the DNS server's subnet.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/noria/ontology/documentExternalId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>documentExternalId</rdfs:label>
    <rdfs:comment xml:lang="en">ID given by the requestor to facilitate the relationship set up and searches afterwards.</rdfs:comment>
    <skos:example xml:lang="en">Customer reference, Identifier coming from an external system, etc.</skos:example>
