    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>troubleTicketType</rdfs:label>
    <rdfs:comment xml:lang="en">The ticket type.</rdfs:comment>
