  <rdf:Description rdf:about="https://w3id.org/noria/ontology/NetworkInterfaceRouterCore01Gi0_0_0">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/NetworkInterface"/>
    <rdfs:label xml:lang="en">RouterCore01 GigabitEthernet 0/0/0</rdfs:label>
    <rdfs:comment xml:lang="en">Uplink interface from Core Router 01 to ISP.</rdfs:comment>
    <noria:networkInterfaceOf rdf:resource="https://w3id.org/noria/ontology/ResourceRouterCore01"/>
    <noria:networkInterfaceConnects rdf:resource="https://w3id.org/noria/ontology/NetworkLinkISP1"/>
    <noria:networkInterfaceAdministrativeStatus rdf:resource="https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled"/>
    <noria:networkInterfaceOperationalStatus rdf:resource="https://w3id.org/noria/kos/Resource/OperationalState/Up"/>
    <noria:networkInterfaceRoutingPriorityMetric rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">50</noria:networkInterfaceRoutingPriorityMetric>
    <noria:networkInterfaceDescription xml:lang="en">ISP uplink 1.</noria:networkInterfaceDescription>
    <noria:networkInterfaceType>physical</noria:networkInterfaceType>
    <noria:networkInterfaceLaserTxOpticalPower rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-2</noria:networkInterfaceLaserTxOpticalPower>
    <noria:networkInterfaceLaserRxOpticalPower rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-5</noria:networkInterfaceLaserRxOpticalPower>
    <noria:networkInterfaceLaserRxOpticalPowerAverage rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-4</noria:networkInterfaceLaserRxOpticalPowerAverage>
    <noria:networkInterfaceLaserRxHighPowerWarningThreshold rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-1</noria:networkInterfaceLaserRxHighPowerWarningThreshold>
    <noria:networkInterfaceLaserRxLowPowerWarningThreshold rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">-10</noria:networkInterfaceLaserRxLowPowerWarningThreshold>
  </rdf:Description>
