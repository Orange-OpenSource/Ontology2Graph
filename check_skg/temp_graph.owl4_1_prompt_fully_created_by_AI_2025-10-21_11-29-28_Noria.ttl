  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/noria/ontology/ApplicationInternetAccess">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/Application"/>
    <rdfs:label xml:lang="en">Corporate Internet Access</rdfs:label>
    <rdfs:label xml:lang="fr">Accès Internet d'Entreprise</rdfs:label>
    <rdfs:comment xml:lang="en">Provides internet connectivity for all corporate users and services.</rdfs:comment>
    <noria:applicationModelIdentifier>CORP-INET-ACC</noria:applicationModelIdentifier>
    <noria:applicationNumericalIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1001</noria:applicationNumericalIdentifier>
    <noria:applicationShortIdentifier>CIAC</noria:applicationShortIdentifier>
