    <noria:applicationBusinessImportance rdf:resource="https://w3id.org/noria/kos/application/business-importance/high"/>
    <noria:applicationFunctionalDomain xml:lang="en">Network Services</noria:applicationFunctionalDomain>
    <noria:applicationFunctionalSubDomain xml:lang="en">Internet Gateway Management</noria:applicationFunctionalSubDomain>
  </rdf:Description>
