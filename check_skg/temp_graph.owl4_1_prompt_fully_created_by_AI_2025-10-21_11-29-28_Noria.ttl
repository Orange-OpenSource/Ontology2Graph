    <rdfs:comment xml:lang="en">Type-1 hypervisor for creating and running virtual machines.</rdfs:comment>
    <noria:productManufacturedBy rdf:resource="https://w3id.org/noria/ontology/OrgVMware"/>
  </rdf:Description>
