  <rdf:Description rdf:about="https://w3id.org/noria/ontology/alarmSeverity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>alarmSeverity</rdfs:label>
    <rdfs:comment xml:lang="en">Indication of how it is perceived that the capability of the managed object has been affected, or how serious are the service affecting conditions (including for security alarms).</rdfs:comment>
    <skos:example xml:lang="en">Critical, Major, Minor, Warning.</skos:example>
    <rdfs:domain rdf:resource="https://w3id.org/noria/ontology/EventRecord"/>
    <rdfs:range rdf:nodeID="nb1cda3999d7f42d29c47839f37517784b93"/>
    <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/type"/>
    <rdfs:subPropertyOf rdf:resource="http://IBCNServices.github.io/Folio-Ontology/Folio.owl#hasCriticality"/>
    <vs:term_status>stable</vs:term_status>
    <skos:changeNote>Changes in v0.2:
- Changed owl:hasValue restriction to &lt;Notification/Severity/PerceivedSeverity&gt; in place of &lt;Notification/PerceivedSeverity&gt;.
- Adding rdfs:subPropertyOf dcterms:type.
- Adding rdfs:subPropertyOf folio:hasCriticality.
- Merging the noria:securityAlarmSeverity.
</skos:changeNote>
    <rdfs:isDefinedBy rdf:resource="https://www.itu.int/rec/T-REC-X.733-199202-I/"/>
    <rdfs:isDefinedBy rdf:resource="https://www.itu.int/ITU-T/formal-language/itu-t/x/x721/1992/x721.html#-perceivedSeverity"/>
    <rdfs:isDefinedBy rdf:resource="https://www.itu.int/ITU-T/formal-language/itu-t/x/x721/1992/x721.html#-securityAlarmSeverity"/>
