    <skos:example>- Resource("DNS server").resourceManagedBy("DNS admin team")
- NetworkLink("WAN Paris-Papeete").resourceManagedBy("International backbone support team")</skos:example>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/noria/ontology/elementManagedBy"/>
