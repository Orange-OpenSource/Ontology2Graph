    <owl:inverseOf rdf:resource="https://w3id.org/noria/ontology/resourceManagedBy"/>
    <rdfs:label>agentManagesResource</rdfs:label>
    <rdfs:comment xml:lang="en">The Network Element (IT Resource) the Agent is responsible of (supervises).

Alignment:
- *FOAF*: A team may be interested into following the state of some resources, hence this property is semantically akin to `foaf:topic_interest`.
</rdfs:comment>
    <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
    <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/topic_interest"/>
