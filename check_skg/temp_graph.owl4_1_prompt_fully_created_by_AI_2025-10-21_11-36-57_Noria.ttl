    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>troubleTicketOrigin</rdfs:label>
    <rdfs:comment xml:lang="en">The person or group family at the origin of the creation of the Trouble Ticket.</rdfs:comment>
    <skos:example>Customer, Supervision, Internal, Carrier, User, Partners</skos:example>
    <vs:term_status>unstable</vs:term_status>
