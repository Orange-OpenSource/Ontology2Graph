    <rdfs:comment xml:lang="en">Physical inspection of fiber cable between CR01 and ISP link initiated. Engineer dispatched.</rdfs:comment>
    <noria:troubleTicketNoteCommentType rdf:resource="https://w3id.org/noria/kos/TroubleTicket/commentType/Internal"/>
    <noria:troubleTicketNoteOperationType rdf:resource="https://w3id.org/noria/kos/TroubleTicket/operationType/TestsAndMeasurements"/>
    <dcterms:isPartOf rdf:resource="https://w3id.org/noria/ontology/TT_NetworkIssue_003"/>
