  <rdf:Description rdf:about="https://w3id.org/noria/proceduralelement/DDoSResponsePlan">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/ProceduralElement"/>
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/OperationPlan"/>
    <rdfs:label xml:lang="en">DDoS Attack Response Plan</rdfs:label>
    <rdfs:comment xml:lang="en">Standard operating procedure for responding to a Distributed Denial of Service attack.</rdfs:comment>
    <skos:example xml:lang="en">1. Verify attack. 2. Activate scrubbing center. 3. Block malicious IPs. 4. Notify stakeholders.</skos:example>
    <noria:operationPlanPreCondition rdf:resource="https://w3id.org/noria/actionprecondition/DDoSAttackDetected"/>
    <noria:operationPlanPostCondition rdf:resource="https://w3id.org/noria/actionpostcondition/DDoSAttackMitigated"/>
  </rdf:Description>
