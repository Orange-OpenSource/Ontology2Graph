  <rdf:Description rdf:about="https://w3id.org/noria/troubleticketnote/TT_20240421_002_Note1">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/TroubleTicketNote"/>
    <rdfs:label xml:lang="en">Port Scan Analysis</rdfs:label>
    <rdfs:comment xml:lang="en">Analysis shows a common automated port scan. No immediate threat identified. Closed as false positive/informational.</rdfs:comment>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-04-21T10:30:00+00:00</dcterms:created>
    <dcterms:creator rdf:resource="https://w3id.org/noria/agent/Person_Charlie"/>
