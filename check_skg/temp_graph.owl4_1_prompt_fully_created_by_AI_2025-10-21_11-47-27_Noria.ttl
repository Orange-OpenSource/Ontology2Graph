  <rdf:Description rdf:about="https://w3id.org/noria/eventrecord/Log_Core01_InterfaceDown">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/EventRecord"/>
    <rdfs:label xml:lang="en">Core01 Interface Down Alert</rdfs:label>
    <rdfs:comment xml:lang="en">GigabitEthernet 0/0/1 on Core Router 01 went down.</rdfs:comment>
    <noria:loggingTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-04-20T10:15:00+00:00</noria:loggingTime>
    <noria:logOriginatingManagedObject rdf:resource="https://w3id.org/noria/resource/Router_Core01"/>
    <noria:logOriginatingManagementSystem rdf:resource="https://w3id.org/noria/application/MonitoringPlatform"/>
    <noria:logText>CRITICAL: Interface Ge0/0/1 on core01.prod.example.com changed state to down.</noria:logText>
    <noria:alarmSeverity rdf:resource="https://w3id.org/noria/Notification/Severity/PerceivedSeverity/Critical"/>
    <noria:alarmProposedRepairAction rdf:resource="https://w3id.org/noria/operationplan/CheckFiberLink"/>
    <dcterms:conformsTo rdf:resource="https://w3id.org/noria/anomalypattern/NetworkInterfaceDown"/>
    <noria:alarmMitigatedBy rdf:resource="https://w3id.org/noria/troubleticket/TT_20240420_002"/>
  </rdf:Description>
