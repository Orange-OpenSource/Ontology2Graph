  <rdf:Description rdf:about="https://w3id.org/noria/troubleticket/TT_20240422_001">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/TroubleTicket"/>
    <rdfs:label xml:lang="en">Backend Server Unhealthy on Load Balancer</rdfs:label>
    <rdfs:comment xml:lang="en">Load balancer reporting one of the web servers as unhealthy, potentially impacting customer portal performance.</rdfs:comment>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-04-22T09:10:00+00:00</dcterms:created>
    <noria:troubleTicketSeverity rdf:resource="https://w3id.org/noria/kos/TroubleTicket/severity/Major"/>
