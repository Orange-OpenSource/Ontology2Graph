    <noria:troubleTicketPriority rdf:resource="https://w3id.org/noria/kos/TroubleTicket/priority/P2"/>
    <noria:troubleTicketOrigin rdf:resource="https://w3id.org/noria/kos/TroubleTicket/origin/Supervision"/>
    <noria:troubleTicketTrigger rdf:resource="https://w3id.org/noria/eventrecord/Log_LB01_HealthCheckFail"/>
    <noria:troubleTicketUrgency rdf:resource="https://w3id.org/noria/kos/TroubleTicket/urgency/ImmediateIntervention"/>
    <noria:troubleTicketSupervisionTool>Monitoring Platform</noria:troubleTicketSupervisionTool>
    <noria:troubleTicketCategory rdf:resource="https://w3id.org/noria/kos/TroubleTicket/trouble-category/DowngradingEquipment"/>
