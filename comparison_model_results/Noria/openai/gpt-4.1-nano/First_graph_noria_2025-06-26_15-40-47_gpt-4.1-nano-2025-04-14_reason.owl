        <noria:logOriginatingManagementSystem rdf:resource="http://example.com/NMS1"/>
        <noria:logText>Line protocol on Interface GigabitEthernet0/0/1, changed state to up</noria:logText>
        <noria:loggingTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-10-10T14:23:00Z</noria:loggingTime>
    </NamedIndividual>
    


