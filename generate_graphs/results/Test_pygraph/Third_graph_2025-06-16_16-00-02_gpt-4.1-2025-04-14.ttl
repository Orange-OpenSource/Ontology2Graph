@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# --- Super Node ---
sc:E100 a sc:C10 ;
    rdfs:label "Super Node Alpha" ;
    rdfs:comment "A super node with the highest degree, connecting to almost every other node in the graph." ;
    sc:R1 sc:E101, sc:E102, sc:E103, sc:E104, sc:E105, sc:E106, sc:E107, sc:E108 ;
    sc:R4 sc:E109 ;
    sc:R6 sc:E110 .

# --- Hub Node ---
sc:E101 a sc:C9 ;
    rdfs:label "Hub Node Beta" ;
    rdfs:comment "A hub node in the C9 class, central to many C9 and C2 nodes." ;
    sc:R2 sc:E111, sc:E112 ;
    sc:R4 sc:E113 ;
    sc:R9 sc:E114, sc:E115 .

# --- High-degree Node ---
sc:E102 a sc:C3 ;
    rdfs:label "High-degree Node Gamma" ;
    rdfs:comment "A high-degree node in C3, with multiple incoming and outgoing relations." ;
    sc:R1 sc:E116, sc:E117, sc:E118 ;
    sc:R3 sc:E119 ;
    sc:R4 sc:E120 ;
    sc:R6 sc:E121 .

# --- Central Node ---
sc:E103 a sc:C4 ;
    rdfs:label "Central Node Delta" ;
    rdfs:comment "A central node in C4, acting as a bridge between C4 and C10 nodes." ;
    sc:R1 sc:E122 ;
    sc:R3 sc:E123 ;
    sc:R4 sc:E124 ;
    sc:R6 sc:E100 .

# --- Connector Node ---
sc:E104 a sc:C7 ;
    rdfs:label "Connector Node Epsilon" ;
    rdfs:comment "A connector node in C7, linking C7 and C5 nodes." ;
    sc:R6 sc:E125 ;
    sc:R8 sc:E126 .

# --- Intermediary Node ---
sc:E105 a sc:C5 ;
    rdfs:label "Intermediary Node Zeta" ;
    rdfs:comment "An intermediary node in C5, facilitating connections between C9 and C7." ;
    sc:R2 sc:E127 ;
    sc:R6 sc:E104 ;
    sc:R9 sc:E128 .

# --- Multiplex Node ---
sc:E106 a sc:C2 ;
    rdfs:label "Multiplex Node Eta" ;
    rdfs:comment "A multiplex node in C2, participating in multiple types of relations and domains." ;
    sc:R10 sc:E129 ;
    sc:R5 sc:E101 ;
    sc:R9 sc:E130 .

# --- C6 Node (for R7) ---
sc:E107 a sc:C6 ;
    rdfs:label "C6 Node Theta" ;
    rdfs:comment "A node of class C6, used to demonstrate R7 and C6-C2 connections." ;
    sc:R7 sc:E106 .

# --- Multiplex Node (C8) ---
sc:E108 a sc:C8 ;
    rdfs:label "Multiplex Node Iota" ;
    rdfs:comment "A multiplex node in C8, connecting to C9 and C10 nodes." ;
    sc:R3 sc:E131 ;
    sc:R4 sc:E132 ;
    sc:R9 sc:E133 .

# --- C9 Node (for R4, R9) ---
sc:E109 a sc:C9 ;
    rdfs:label "C9 Node Kappa" ;
    rdfs:comment "A C9 node, demonstrating symmetric and reflexive relations within C9." ;
    sc:R4 sc:E101, sc:E109 ;
    sc:R9 sc:E114 .

# --- C10 Node (for R6) ---
sc:E110 a sc:C10 ;
    rdfs:label "C10 Node Lambda" ;
    rdfs:comment "A C10 node, connected via R6 to the super node and other C10 nodes." ;
    sc:R6 sc:E100, sc:E134 .

# --- C2 Node (for R2, R9) ---
sc:E111 a sc:C2 ;
    rdfs:label "C2 Node Mu" ;
    rdfs:comment "A C2 node, linked to hub and intermediary nodes." ;
    sc:R9 sc:E101 ;
    sc:R5 sc:E135 .

# --- C2 Node (for R2) ---
sc:E112 a sc:C2 ;
    rdfs:label "C2 Node Nu" ;
    rdfs:comment "A C2 node, connected to the hub node via R2." ;
    sc:R5 sc:E101 .

# --- C9 Node (for R4) ---
sc:E113 a sc:C9 ;
    rdfs:label "C9 Node Xi" ;
    rdfs:comment "A C9 node, connected to the hub node via R4." ;
    sc:R4 sc:E101 .

# --- C2 Node (for R9) ---
sc:E114 a sc:C2 ;
    rdfs:label "C2 Node Omicron" ;
    rdfs:comment "A C2 node, connected to the hub node via R9." ;
    sc:R9 sc:E101 .

# --- C2 Node (for R9) ---
sc:E115 a sc:C2 ;
    rdfs:label "C2 Node Pi" ;
    rdfs:comment "A C2 node, connected to the hub node via R9." ;
    sc:R9 sc:E101 .

# --- C3 Node (for R1) ---
sc:E116 a sc:C3 ;
    rdfs:label "C3 Node Rho" ;
    rdfs:comment "A C3 node, connected to the high-degree node via R1." ;
    sc:R1 sc:E102 .

# --- C3 Node (for R1) ---
sc:E117 a sc:C3 ;
    rdfs:label "C3 Node Sigma" ;
    rdfs:comment "A C3 node, connected to the high-degree node via R1." ;
    sc:R1 sc:E102 .

# --- C3 Node (for R1) ---
sc:E118 a sc:C3 ;
    rdfs:label "C3 Node Tau" ;
    rdfs:comment "A C3 node, connected to the high-degree node via R1." ;
    sc:R1 sc:E102 .

# --- C1 Node (for R3) ---
sc:E119 a sc:C1 ;
    rdfs:label "C1 Node Upsilon" ;
    rdfs:comment "A C1 node, connected to the high-degree node via R3." ;
    sc:R3 sc:E102 .

# --- C3 Node (for R4) ---
sc:E120 a sc:C3 ;
    rdfs:label "C3 Node Phi" ;
    rdfs:comment "A C3 node, connected to the high-degree node via R4." ;
    sc:R4 sc:E102 .

# --- C10 Node (for R6) ---
sc:E121 a sc:C10 ;
    rdfs:label "C10 Node Chi" ;
    rdfs:comment "A C10 node, connected to the high-degree node via R6." ;
    sc:R6 sc:E102 .

# --- C4 Node (for R1) ---
sc:E122 a sc:C4 ;
    rdfs:label "C4 Node Psi" ;
    rdfs:comment "A C4 node, connected to the central node via R1." ;
    sc:R1 sc:E103 .

# --- C3 Node (for R3) ---
sc:E123 a sc:C3 ;
    rdfs:label "C3 Node Omega" ;
    rdfs:comment "A C3 node, connected to the central node via R3." ;
    sc:R3 sc:E103 .

# --- C4 Node (for R4) ---
sc:E124 a sc:C4 ;
    rdfs:label "C4 Node Alpha-2" ;
    rdfs:comment "A C4 node, connected to the central node via R4." ;
    sc:R4 sc:E103 .

# --- C7 Node (for R6) ---
sc:E125 a sc:C7 ;
    rdfs:label "C7 Node Beta-2" ;
    rdfs:comment "A C7 node, connected to the connector node via R6." ;
    sc:R6 sc:E104 .

# --- C5 Node (for R8) ---
sc:E126 a sc:C5 ;
    rdfs:label "C5 Node Gamma-2" ;
    rdfs:comment "A C5 node, connected to the connector node via R8." ;
    sc:R8 sc:E104 .

# --- C2 Node (for R2) ---
sc:E127 a sc:C2 ;
    rdfs:label "C2 Node Delta-2" ;
    rdfs:comment "A C2 node, connected to the intermediary node via R2." ;
    sc:R5 sc:E105 .

# --- C9 Node (for R9) ---
sc:E128 a sc:C9 ;
    rdfs:label "C9 Node Epsilon-2" ;
    rdfs:comment "A C9 node, connected to the intermediary node via R9." ;
    sc:R9 sc:E105 .

# --- C4 Node (for R10) ---
sc:E129 a sc:C4 ;
    rdfs:label "C4 Node Zeta-2" ;
    rdfs:comment "A C4 node, connected to the multiplex node via R10." ;
    sc:R10 sc:E106 .

# --- C9 Node (for R9) ---
sc:E130 a sc:C9 ;
    rdfs:label "C9 Node Eta-2" ;
    rdfs:comment "A C9 node, connected to the multiplex node via R9." ;
    sc:R9 sc:E106 .

# --- C10 Node (for R3) ---
sc:E131 a sc:C10 ;
    rdfs:label "C10 Node Theta-2" ;
    rdfs:comment "A C10 node, connected to the multiplex node in C8 via R3." ;
    sc:R3 sc:E108 .

# --- C9 Node (for R4) ---
sc:E132 a sc:C9 ;
    rdfs:label "C9 Node Iota-2" ;
    rdfs:comment "A C9 node, connected to the multiplex node in C8 via R4." ;
    sc:R4 sc:E108 .

# --- C2 Node (for R9) ---
sc:E133 a sc:C2 ;
    rdfs:label "C2 Node Kappa-2" ;
    rdfs:comment "A C2 node, connected to the multiplex node in C8 via R9." ;
    sc:R9 sc:E108 .

# --- C10 Node (for R6) ---
sc:E134 a sc:C10 ;
    rdfs:label "C10 Node Lambda-2" ;
    rdfs:comment "A C10 node, connected to another C10 node via R6." ;
    sc:R6 sc:E110 .

# --- C9 Node (for R5) ---
sc:E135 a sc:C9 ;
    rdfs:label "C9 Node Mu-2" ;
    rdfs:comment "A C9 node, connected to a C2 node via R5." ;
    sc:R5 sc:E111 .