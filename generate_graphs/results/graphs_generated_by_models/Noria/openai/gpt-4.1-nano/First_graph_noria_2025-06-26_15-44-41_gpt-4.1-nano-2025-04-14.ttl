@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix resource: <https://example.com/resource/> .

# Hub Node: Central Resource representing a core data center switch
resource:CoreSwitch a noria:Resource ;
  rdfs:label "Core Switch" ;
  rdfs:comment "Main backbone switch connecting multiple network segments." .

# Connector Node: Network Interface of the core switch
resource:CoreSwitchInterface1 a noria:NetworkInterface ;
  rdfs:label "CoreSwitch Interface 1" ;
  rdfs:comment "Primary uplink interface of the core switch." ;
  noria:networkInterfaceOf resource:CoreSwitch .

# High-Degree Node: Application Server connected to multiple resources
resource:AppServer1 a noria:Resource ;
  rdfs:label "Application Server 1" ;
  rdfs:comment "Main application server hosting critical services." .

# Intermediary Node: Network Link between Core Switch and Application Server
resource:Link_Core_App1 a noria:NetworkLink ;
  rdfs:label "Link CoreSwitch to AppServer1" ;
  rdfs:comment "Fiber optic link connecting core switch to application server." .

# Link resource connects the core switch and application server
resource:CoreSwitchToApp1Link a noria:NetworkLink ;
  rdfs:label "CoreSwitch to AppServer1 Link" ;
  rdfs:comment "Physical fiber link between core switch and application server." ;
  noria:networkLinkTerminationResource resource:CoreSwitch ;
  noria:networkLinkTerminationResourceDestination resource:AppServer1 .

# Hub Node: Application Server with multiple network interfaces
resource:AppServer1Interface1 a noria:NetworkInterface ;
  rdfs:label "AppServer1 Interface 1" ;
  rdfs:comment "Primary network interface of Application Server 1." ;
  noria:networkInterfaceOf resource:AppServer1 .

resource:AppServer1Interface2 a noria:NetworkInterface ;
  rdfs:label "AppServer1 Interface 2" ;
  rdfs:comment "Secondary network interface for management." ;
  noria:networkInterfaceOf resource:AppServer1 .

# Super Node: Application System composed of multiple applications
resource:CustomerPortal a noria:Application ;
  rdfs:label "Customer Portal Application" ;
  rdfs:comment "Web portal for customer interactions." .

resource:OrderManagement a noria:Application ;
  rdfs:label "Order Management System" ;
  rdfs:comment "Backend system handling customer orders." .

# Multiplex Node: Application System with multiple modules
resource:CustomerPortalModule1 a noria:ApplicationModule ;
  rdfs:label "Customer Portal Frontend" ;
  rdfs:comment "Frontend module of Customer Portal." ;
  noria:applicationModuleOf resource:CustomerPortal .

resource:CustomerPortalModule2 a noria:ApplicationModule ;
  rdfs:label "Customer Portal Backend" ;
  rdfs:comment "Backend module of Customer Portal." ;
  noria:applicationModuleOf resource:CustomerPortal .

# Connector Node: Link between Application System and Resources
resource:AppSystemToResourceLink a noria:NetworkLink ;
  rdfs:label "Application System to Resource Link" ;
  rdfs:comment "Logical link connecting application system to underlying resources." ;
  noria:networkLinkTerminationResource resource:OrderManagement ;
  noria:networkLinkTerminationResourceDestination resource:CoreSwitch .

# Intermediary Node: Resource connected to multiple applications
resource:Resource1 a noria:Resource ;
  rdfs:label "Database Server" ;
  rdfs:comment "Primary database server for applications." .

# High-Degree Node: Resource with multiple applications
resource:Resource2 a noria:Resource ;
  rdfs:label "Web Server Cluster" ;
  rdfs:comment "Cluster of web servers hosting customer portal." .

# Connector Node: Link between Resource1 and Resource2
resource:ResourceLink1 a noria:NetworkLink ;
  rdfs:label "Link between Database and Web Servers" ;
  rdfs:comment "Network connection between database server and web server cluster." ;
  noria:networkLinkTerminationResource resource:Resource1 ;
  noria:networkLinkTerminationResourceDestination resource:Resource2 .

# Super Node: Organization with multiple teams
org:Organization a owl:Class ;
  rdfs:label "Organization" ;
  rdfs:comment "Main organization managing network and applications." .

resource:ITDepartment a org:OrganizationalUnit ;
  rdfs:label "IT Department" ;
  rdfs:comment "Handles network and application infrastructure." ;
  org:organizationOf org:Organization .

resource:SupportTeam a org:OrganizationalUnit ;
  rdfs:label "Support Team" ;
  rdfs:comment "Provides operational support for network and applications." ;
  org:memberOf org:Organization .

# Connector Node: Link between Organization and Support Team
resource:OrgToSupportLink a org:hasMember ;
  rdfs:label "Organization to Support Team" ;
  rdfs:comment "Support team belonging to the organization." ;
  org:member org:SupportTeam ;
  org:organization org:Organization .

# High-Degree Node: Application with multiple modules and related resources
resource:AnalyticsApp a noria:Application ;
  rdfs:label "Analytics Application" ;
  rdfs:comment "Application for data analytics and reporting." .

resource:AnalyticsModule1 a noria:ApplicationModule ;
  rdfs:label "Analytics Data Collector" ;
  rdfs:comment "Module responsible for data collection." ;
  noria:applicationModuleOf resource:AnalyticsApp .

resource:AnalyticsModule2 a noria:ApplicationModule ;
  rdfs:label "Analytics Dashboard" ;
  rdfs:comment "User interface module for analytics." ;
  noria:applicationModuleOf resource:AnalyticsApp .

# Link between Application and Resources
resource:AppToResourceLink a noria:Application ;
  rdfs:label "Application to Resources" ;
  rdfs:comment "Linking application to its underlying resources." ;
  noria:resourceForApplication resource:Resource2 .

# Dismissed isolated nodes: No nodes are isolated; all have at least one relation.