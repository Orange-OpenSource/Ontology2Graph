@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub node: central connector with multiple relations
sc:E2000 a sc:C10 ;
    rdfs:label "Hub Node E2000" ;
    rdfs:comment "A hub node connecting multiple nodes of various classes." ;
    sc:R1 sc:E2001, sc:E2002, sc:E2003 ;
    sc:R6 sc:E2004 ;
    sc:R4 sc:E2005 .

# High-degree node: many connections, mostly symmetric
sc:E2001 a sc:C4 ;
    rdfs:label "High-degree Node E2001" ;
    rdfs:comment "Node with many symmetric and reflexive relations." ;
    sc:R4 sc:E2000, sc:E2006, sc:E2007 ;
    sc:R1 sc:E2008 ;
    sc:R6 sc:E2009 .

# Central node: key intermediary in the graph
sc:E2002 a sc:C3 ;
    rdfs:label "Central Node E2002" ;
    rdfs:comment "Central node acting as intermediary between hub and connectors." ;
    sc:R3 sc:E2000 ;
    sc:R2 sc:E2010 ;
    sc:R6 sc:E2011 .

# Connector node: links different clusters
sc:E2003 a sc:C1 ;
    rdfs:label "Connector Node E2003" ;
    rdfs:comment "Connector node linking hub to multiplex and super nodes." ;
    sc:R3 sc:E2000 ;
    sc:R6 sc:E2012 ;
    sc:R4 sc:E2013 .

# Intermediary node: mediates between nodes
sc:E2004 a sc:C5 ;
    rdfs:label "Intermediary Node E2004" ;
    rdfs:comment "Intermediary node connecting high-degree and multiplex nodes." ;
    sc:R6 sc:E2001, sc:E2014 ;
    sc:R9 sc:E2015 .

# Multiplex node: multiple types of relations
sc:E2005 a sc:C9 ;
    rdfs:label "Multiplex Node E2005" ;
    rdfs:comment "Node with multiplex relations including symmetric and reflexive." ;
    sc:R4 sc:E2000, sc:E2016 ;
    sc:R9 sc:E2017 ;
    sc:R1 sc:E2018 .

# Super node: super connected and diverse relations
sc:E2006 a sc:C8 ;
    rdfs:label "Super Node E2006" ;
    rdfs:comment "Super node with diverse and numerous relations." ;
    sc:R4 sc:E2001, sc:E2019 ;
    sc:R9 sc:E2020 ;
    sc:R6 sc:E2021 .

# Additional nodes to support relations

sc:E2007 a sc:C4 ;
    rdfs:label "Supporting Node E2007" ;
    rdfs:comment "Supporting node connected to high-degree node." ;
    sc:R4 sc:E2001 .

sc:E2008 a sc:C10 ;
    rdfs:label "Supporting Node E2008" ;
    rdfs:comment "Node connected to high-degree node via reflexive property." ;
    sc:R1 sc:E2001 .

sc:E2009 a sc:C10 ;
    rdfs:label "Supporting Node E2009" ;
    rdfs:comment "Node connected to high-degree node via symmetric and transitive property." ;
    sc:R6 sc:E2001 .

sc:E2010 a sc:C1 ;
    rdfs:label "Supporting Node E2010" ;
    rdfs:comment "Node linked from central node via inverse property." ;
    sc:R3 sc:E2002 .

sc:E2011 a sc:C7 ;
    rdfs:label "Supporting Node E2011" ;
    rdfs:comment "Node linked from central node via inverse property." ;
    sc:R8 sc:E2002 .

sc:E2012 a sc:C4 ;
    rdfs:label "Supporting Node E2012" ;
    rdfs:comment "Node linked from connector node." ;
    sc:R6 sc:E2003 .

sc:E2013 a sc:C4 ;
    rdfs:label "Supporting Node E2013" ;
    rdfs:comment "Node linked from connector node via symmetric property." ;
    sc:R4 sc:E2003 .

sc:E2014 a sc:C7 ;
    rdfs:label "Supporting Node E2014" ;
    rdfs:comment "Node linked from intermediary node." ;
    sc:R8 sc:E2004 .

sc:E2015 a sc:C9 ;
    rdfs:label "Supporting Node E2015" ;
    rdfs:comment "Node linked from intermediary node via symmetric property." ;
    sc:R9 sc:E2004 .

sc:E2016 a sc:C9 ;
    rdfs:label "Supporting Node E2016" ;
    rdfs:comment "Node linked from multiplex node." ;
    sc:R4 sc:E2005 .

sc:E2017 a sc:C9 ;
    rdfs:label "Supporting Node E2017" ;
    rdfs:comment "Node linked from multiplex node via symmetric property." ;
    sc:R9 sc:E2005 .

sc:E2018 a sc:C10 ;
    rdfs:label "Supporting Node E2018" ;
    rdfs:comment "Node linked from multiplex node via reflexive property." ;
    sc:R1 sc:E2005 .

sc:E2019 a sc:C8 ;
    rdfs:label "Supporting Node E2019" ;
    rdfs:comment "Node linked from super node." ;
    sc:R4 sc:E2006 .

sc:E2020 a sc:C9 ;
    rdfs:label "Supporting Node E2020" ;
    rdfs:comment "Node linked from super node via symmetric property." ;
    sc:R9 sc:E2006 .

sc:E2021 a sc:C7 ;
    rdfs:label "Supporting Node E2021" ;
    rdfs:comment "Node linked from super node via inverse property." ;
    sc:R8 sc:E2006 .