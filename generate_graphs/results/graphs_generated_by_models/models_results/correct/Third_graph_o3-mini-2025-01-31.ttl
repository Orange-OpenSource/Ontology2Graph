@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc:     <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

sc:Hub001 a sc:C10 ;
  rdfs:label "Hub Node" ;
  rdfs:comment "An aggregation center that connects disparate sectors of the network." ;
  sc:R1 sc:HighDeg001, sc:Central001, sc:Super001 ;
  sc:R6 sc:Connector001 .

sc:HighDeg001 a sc:C9 ;
  rdfs:label "High-Degree Node" ;
  rdfs:comment "A node recognized for its large number of inbound and outbound links." ;
  sc:R4 sc:Hub001, sc:Multiplex001, sc:Central001 .

sc:Central001 a sc:C1 ;
  rdfs:label "Central Node" ;
  rdfs:comment "A pivotal point that plays a central role in uniting various clusters." ;
  sc:R1 sc:Connector001 ;
  sc:R3 sc:Intermediary001 .

sc:Connector001 a sc:C4 ;
  rdfs:label "Connector Node" ;
  rdfs:comment "Bridges distinct areas and facilitates information flow." ;
  sc:R4 sc:Multiplex001 ;
  sc:R9 sc:Central001 .

sc:Intermediary001 a sc:C3 ;
  rdfs:label "Intermediary Node" ;
  rdfs:comment "Operates between clusters, channeling interactions from one segment to another." ;
  sc:R3 sc:Super001 ;
  sc:R2 sc:Central001 .

sc:Multiplex001 a sc:C5 ;
  rdfs:label "Multiplex Node" ;
  rdfs:comment "Exhibits multiple types of relations and communicates with various nodes." ;
  sc:R1 sc:Intermediary001, sc:HighDeg001 .

sc:Super001 a sc:C6 ;
  rdfs:label "Super Node" ;
  rdfs:comment "A highly influential node with exceptional connectivity throughout the graph." ;
  sc:R7 sc:Hub001 ;
  sc:R10 sc:Multiplex001 .
