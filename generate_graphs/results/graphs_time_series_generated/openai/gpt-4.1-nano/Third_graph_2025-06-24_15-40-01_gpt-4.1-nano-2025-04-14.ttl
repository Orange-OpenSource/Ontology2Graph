@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A node with high connectivity acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of relations, indicating significant influence." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that is central within the network topology." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different parts of the network." .

sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as an intermediary between other nodes." .

sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple relation types or layers." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A super node representing a cluster or a super-entity in the network." .

# Entities
sc:E1001 a sc:HubNode ;
    rdfs:label "Entity E1001" ;
    rdfs:comment "A hub node representing a major server in the network." ;
    sc:sc:R1 sc:E1002 ;
    sc:sc:R10 sc:E1003 .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "Entity E1002" ;
    rdfs:comment "A high-degree node representing a database server." ;
    sc:sc:R2 sc:E1004 ;
    sc:sc:R4 sc:E1005 .

sc:E1003 a sc:CentralNode ;
    rdfs:label "Entity E1003" ;
    rdfs:comment "A central node representing a core switch." ;
    sc:sc:R3 sc:E1006 .

sc:E1004 a sc:ConnectorNode ;
    rdfs:label "Entity E1004" ;
    rdfs:comment "A connector node linking the database to the application servers." ;
    sc:sc:R4 sc:E1007 .

sc:E1005 a sc:IntermediaryNode ;
    rdfs:label "Entity E1005" ;
    rdfs:comment "An intermediary node acting as a firewall." ;
    sc:sc:R5 sc:E1008 .

sc:E1006 a sc:MultiplexNode ;
    rdfs:label "Entity E1006" ;
    rdfs:comment "A multiplex node involved in multiple network layers." ;
    sc:sc:R6 sc:E1009 .

sc:E1007 a sc:SuperNode ;
    rdfs:label "Entity E1007" ;
    rdfs:comment "A super node representing a cluster of application servers." ;
    sc:sc:R7 sc:E1010 .

sc:E1008 a sc:IntermediaryNode ;
    rdfs:label "Entity E1008" ;
    rdfs:comment "A firewall acting as an intermediary between internal and external networks." ;
    sc:sc:R8 sc:E1011 .

sc:E1009 a sc:HighDegreeNode ;
    rdfs:label "Entity E1009" ;
    rdfs:comment "A high-degree node representing a load balancer." ;
    sc:sc:R9 sc:E1012 .

sc:E1010 a sc:SuperNode ;
    rdfs:label "Entity E1010" ;
    rdfs:comment "A super node representing a data center cluster." ;
    sc:sc:R10 sc:E1013 .

sc:E1011 a sc:ConnectorNode ;
    rdfs:label "Entity E1011" ;
    rdfs:comment "A connector node linking the firewall to the application layer." ;
    sc:sc:R4 sc:E1014 .

sc:E1012 a sc:MultiplexNode ;
    rdfs:label "Entity E1012" ;
    rdfs:comment "A multiplex node involved in multiple load balancing layers." ;
    sc:sc:R6 sc:E1015 .

sc:E1013 a sc:SuperNode ;
    rdfs:label "Entity E1013" ;
    rdfs:comment "A super node representing a data center cluster." ;
    sc:sc:R7 sc:E1016 .

sc:E1014 a sc:IntermediaryNode ;
    rdfs:label "Entity E1014" ;
    rdfs:comment "An intermediary node acting as a gateway." ;
    sc:sc:R8 sc:E1017 .

sc:E1015 a sc:HighDegreeNode ;
    rdfs:label "Entity E1015" ;
    rdfs:comment "A high-degree node representing a network switch." ;
    sc:sc:R9 sc:E1018 .

sc:E1016 a sc:SuperNode ;
    rdfs:label "Entity E1016" ;
    rdfs:comment "A super node representing a cluster of storage units." ;
    sc:sc:R10 sc:E1019 .

sc:E1017 a sc:ConnectorNode ;
    rdfs:label "Entity E1017" ;
    rdfs:comment "A connector node linking the gateway to the storage cluster." ;
    sc:sc:R4 sc:E1020 .

sc:E1018 a sc:MultiplexNode ;
    rdfs:label "Entity E1018" ;
    rdfs:comment "A multiplex node involved in multiple storage layers." ;
    sc:sc:R6 sc:E1021 .

sc:E1019 a sc:SuperNode ;
    rdfs:label "Entity E1019" ;
    rdfs:comment "A super node representing a storage cluster." ;
    sc:sc:R7 sc:E1022 .

sc:E1020 a sc:IntermediaryNode ;
    rdfs:label "Entity E1020" ;
    rdfs:comment "An intermediary node acting as a storage gateway." ;
    sc:sc:R8 sc:E1023 .

sc:E1021 a sc:HighDegreeNode ;
    rdfs:label "Entity E1021" ;
    rdfs:comment "A high-degree node representing a storage switch." ;
    sc:sc:R9 sc:E1024 .

sc:E1022 a sc:SuperNode ;
    rdfs:label "Entity E1022" ;
    rdfs:comment "A super node for storage cluster." ;
    sc:sc:R10 sc:E1025 .

sc:E1023 a sc:ConnectorNode ;
    rdfs:label "Entity E1023" ;
    rdfs:comment "A connector node linking storage gateway to storage switch." ;
    sc:sc:R4 sc:E1026 .

sc:E1024 a sc:MultiplexNode ;
    rdfs:label "Entity E1024" ;
    rdfs:comment "A multiplex node involved in multiple storage layers." ;
    sc:sc:R6 sc:E1027 .

sc:E1025 a sc:SuperNode ;
    rdfs:label "Entity E1025" ;
    rdfs:comment "A super node representing a storage cluster." ;
    sc:sc:R7 sc:E1028 .

sc:E1026 a sc:IntermediaryNode ;
    rdfs:label "Entity E1026" ;
    rdfs:comment "A storage gateway acting as an intermediary." ;
    sc:sc:R8 sc:E1029 .

sc:E1027 a sc:HighDegreeNode ;
    rdfs:label "Entity E1027" ;
    rdfs:comment "A high-degree node representing a storage switch." ;
    sc:sc:R9 sc:E1030 .

sc:E1028 a sc:SuperNode ;
    rdfs:label "Entity E1028" ;
    rdfs:comment "A super node for storage cluster." ;
    sc:sc:R10 sc:E1031 .

# Relations (example relations)
sc:R1 a owl:ObjectProperty ;
    rdfs:label "relation R1" ;
    rdfs:comment "Relation R1 between hub and high-degree node." .

sc:R2 a owl:ObjectProperty ;
    rdfs:label "relation R2" ;
    rdfs:comment "Relation R2 between high-degree and central node." .

sc:R3 a owl:ObjectProperty ;
    rdfs:label "relation R3" ;
    rdfs:comment "Relation R3 between central and connector node." .

sc:R4 a owl:ObjectProperty ;
    rdfs:label "relation R4" ;
    rdfs:comment "Relation R4 between connector and intermediary node." .

sc:R5 a owl:ObjectProperty ;
    rdfs:label "relation R5" ;
    rdfs:comment "Relation R5 between intermediary and high-degree node." .

sc:R6 a owl:ObjectProperty ;
    rdfs:label "relation R6" ;
    rdfs:comment "Relation R6 between multiplex and super node." .

sc:R7 a owl:ObjectProperty ;
    rdfs:label "relation R7" ;
    rdfs:comment "Relation R7 between super nodes." .

sc:R8 a owl:ObjectProperty ;
    rdfs:label "relation R8" ;
    rdfs:comment "Relation R8 between intermediary and connector node." .

sc:R9 a owl:ObjectProperty ;
    rdfs:label "relation R9" ;
    rdfs:comment "Relation R9 between high-degree nodes." .

sc:R10 a owl:ObjectProperty ;
    rdfs:label "relation R10" ;
    rdfs:comment "Relation R10 between super nodes." .

# Example relations between entities
sc:E1001 sc:R1 sc:E1002 .
sc:E1002 sc:R2 sc:E1003 .
sc:E1003 sc:R3 sc:E1004 .
sc:E1004 sc:R4 sc:E1005 .
sc:E1005 sc:R5 sc:E1006 .
sc:E1006 sc:R6 sc:E1007 .
sc:E1007 sc:R7 sc:E1008 .
sc:E1008 sc:R8 sc:E1009 .
sc:E1009 sc:R9 sc:E1010 .
sc:E1010 sc:R10 sc:E1011 .

# Additional relations to create a diverse network
sc:E1012 sc:R1 sc:E1013 .
sc:E1014 sc:R4 sc:E1015 .
sc:E1016 sc:R6 sc:E1017 .
sc:E1018 sc:R7 sc:E1019 .
sc:E1020 sc:R8 sc:E1021 .
sc:E1022 sc:R9 sc:E1023 .
sc:E1024 sc:R10 sc:E1025 .
