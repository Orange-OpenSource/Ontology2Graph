@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that acts as a central connector between different parts of the graph." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different classes or groups." .

sc:IntermediaryNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that mediates relations between other nodes." .

sc:MultiplexNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A node with multiple roles and high connectivity." .

# Entities
sc:E1001 a sc:HubNode ;
    rdfs:label "Entity 1001" ;
    rdfs:comment "A hub node representing a central entity." ;
    sc:hasRelation sc:E1002, sc:E1003 .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "Entity 1002" ;
    rdfs:comment "A high-degree node connected to multiple entities." ;
    sc:hasRelation sc:E1004 .

sc:E1003 a sc:ConnectorNode ;
    rdfs:label "Entity 1003" ;
    rdfs:comment "A connector node linking different groups." ;
    sc:hasRelation sc:E1005 .

sc:E1004 a sc:IntermediaryNode ;
    rdfs:label "Entity 1004" ;
    rdfs:comment "An intermediary node mediating relations." ;
    sc:hasRelation sc:E1006 .

sc:E1005 a sc:MultiplexNode ;
    rdfs:label "Entity 1005" ;
    rdfs:comment "A multiplex node involved in multiple relation types." ;
    sc:hasRelation sc:E1007 .

sc:E1006 a sc:SuperNode ;
    rdfs:label "Entity 1006" ;
    rdfs:comment "A super node with multiple roles." ;
    sc:hasRelation sc:E1008 .

sc:E1007 a sc:HighDegreeNode ;
    rdfs:label "Entity 1007" ;
    rdfs:comment "Another high-degree node." ;
    sc:hasRelation sc:E1009 .

