@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Define Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node positioned at the center of a cluster or community." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different communities or clusters." .

sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as a bridge between other nodes or groups." .

sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations or layers." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A node with multiple roles or high importance in the network." .

# Define Entities (Nodes)
sc:E1001 a sc:HubNode ;
    rdfs:label "Node E1001" ;
    rdfs:comment "A central hub node with numerous connections." ;
    sc:hasRelation sc:R1 .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "Node E1002" ;
    rdfs:comment "A high-degree node connected to multiple hubs." ;
    sc:hasRelation sc:R2 .

sc:E1003 a sc:CentralNode ;
    rdfs:label "Node E1003" ;
    rdfs:comment "A node positioned at the core of a cluster." ;
    sc:hasRelation sc:R3 .

sc:E1004 a sc:ConnectorNode ;
    rdfs:label "Node E1004" ;
    rdfs:comment "A connector node linking two communities." ;
    sc:hasRelation sc:R4 .

sc:E1005 a sc:IntermediaryNode ;
    rdfs:label "Node E1005" ;
    rdfs:comment "An intermediary node bridging different groups." ;
    sc:hasRelation sc:R5 .

sc:E1006 a sc:MultiplexNode ;
    rdfs:label "Node E1006" ;
    rdfs:comment "A multiplex node involved in multiple relation types." ;
    sc:hasRelation sc:R6 .

sc:E1007 a sc:SuperNode ;
    rdfs:label "Node E1007" ;
    rdfs:comment "A super node with multiple roles and high influence." ;
    sc:hasRelation sc:R7 .

# Relations between entities
sc:E1001 sc:R1 sc:E1002 ;
    rdfs:label "Relation R1" ;
    rdfs:comment "Relation R between hub node and high-degree node." .

sc:E1002 sc:R2 sc:E1003 ;
    rdfs:label "Relation R2" ;
    rdfs:comment "Relation R indicating connection from high-degree to central node." .

sc:E1003 sc:R3 sc:E1004 ;
    rdfs:label "Relation R3" ;
    rdfs:comment "Relation R linking central node to connector node." .

sc:E1004 sc:R4 sc:E1005 ;
    rdfs:label "Relation R4" ;
    rdfs:comment "Relation R connecting connector node to intermediary node." .

sc:E1005 sc:R5 sc:E1006 ;
    rdfs:label "Relation R5" ;
    rdfs:comment "Relation R bridging intermediary node to multiplex node." .

sc:E1006 sc:R6 sc:E1007 ;
    rdfs:label "Relation R6" ;
    rdfs:comment "Relation R involving multiplex node and super node." .

sc:E1007 sc:R7 sc:E1001 ;
    rdfs:label "Relation R7" ;
    rdfs:comment "Relation R connecting super node back to hub node, forming a cycle." .

# Additional relations to ensure diverse node connectivity
sc:E1002 sc:R8 sc:E1004 ;
    rdfs:label "Relation R8" ;
    rdfs:comment "Symmetric relation between high-degree node and connector node." .

sc:E1003 sc:R9 sc:E1005 ;
    rdfs:label "Relation R9" ;
    rdfs:comment "Symmetric relation between central node and intermediary node." .

sc:E1004 sc:R10 sc:E1006 ;
    rdfs:label "Relation R10" ;
    rdfs:comment "Inverse relation from connector node to multiplex node." .

sc:E1005 sc:R2 sc:E1007 ;
    rdfs:label "Relation R2" ;
    rdfs:comment "Relation R indicating connection from intermediary to super node." .

sc:E1006 sc:R3 sc:E1001 ;
    rdfs:label "Relation R3" ;
    rdfs:comment "Relation R linking multiplex node to hub node." .

sc:E1007 sc:R4 sc:E1002 ;
    rdfs:label "Relation R4" ;
    rdfs:comment "Relation R connecting super node to high-degree node." .

# End of knowledge graph
