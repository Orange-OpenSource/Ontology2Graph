@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A node with high connectivity acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of relations, acting as a key connector." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that is central within a specific subgraph or community." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different classes or communities." .

sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as a bridge between other nodes or classes." .

sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple relation types or classes." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A highly connected node that encompasses multiple roles." .

# Object Properties
sc:relatesTo a owl:ObjectProperty ;
    rdfs:label "relates to" ;
    rdfs:comment "Generic relation between entities." .

sc:connectsTo a owl:ObjectProperty ;
    rdfs:label "connects to" ;
    rdfs:comment "Relation indicating a connection between nodes." .

sc:linksTo a owl:ObjectProperty ;
    rdfs:label "links to" ;
    rdfs:comment "Relation indicating a link or association." .

sc:interactsWith a owl:ObjectProperty ;
    rdfs:label "interacts with" ;
    rdfs:comment "Relation indicating interaction between entities." .

sc:bridges a owl:ObjectProperty ;
    rdfs:label "bridges" ;
    rdfs:comment "Relation indicating bridging role of a node." .

sc:hasRelationType a owl:ObjectProperty ;
    rdfs:label "has relation type" ;
    rdfs:comment "Relation indicating multiplex or multiple relation types." .

# Entities
# Hub Node
sc:NodeA a sc:HubNode ;
    rdfs:label "Node A" ;
    rdfs:comment "A hub node with high connectivity." ;
    sc:connectsTo sc:NodeB, sc:NodeC, sc:NodeD .

# High-Degree Node
sc:NodeB a sc:HighDegreeNode ;
    rdfs:label "Node B" ;
    rdfs:comment "A high-degree node acting as a key connector." ;
    sc:linksTo sc:NodeA, sc:NodeE, sc:NodeF .

# Central Node
sc:NodeC a sc:CentralNode ;
    rdfs:label "Node C" ;
    rdfs:comment "A central node within a community." ;
    sc:interactsWith sc:NodeA, sc:NodeG .

# Connector Node
sc:NodeD a sc:ConnectorNode ;
    rdfs:label "Node D" ;
    rdfs:comment "A connector node linking different classes." ;
    sc:connectsTo sc:NodeA, sc:NodeH .

# Intermediary Node
sc:NodeE a sc:IntermediaryNode ;
    rdfs:label "Node E" ;
    rdfs:comment "An intermediary node bridging classes." ;
    sc:bridges sc:NodeB, sc:NodeF .

# Multiplex Node
sc:NodeF a sc:MultiplexNode ;
    rdfs:label "Node F" ;
    rdfs:comment "A multiplex node involved in multiple relation types." ;
    sc:hasRelationType sc:relatesTo, sc:linksTo .

# Super Node
sc:NodeG a sc:SuperNode ;
    rdfs:label "Node G" ;
    rdfs:comment "A super node with extensive connectivity." ;
    sc:connectsTo sc:NodeA, sc:NodeB, sc:NodeC, sc:NodeD, sc:NodeE, sc:NodeF .

# Additional Nodes for diversity
sc:NodeH a sc:IntermediaryNode ;
    rdfs:label "Node H" ;
    rdfs:comment "An intermediary node connecting to Node D." ;
    sc:linksTo sc:NodeD .

sc:NodeI a sc:HighDegreeNode ;
    rdfs:label "Node I" ;
    rdfs:comment "Another high-degree node." ;
    sc:connectsTo sc:NodeG, sc:NodeJ .

sc:NodeJ a sc:CentralNode ;
    rdfs:label "Node J" ;
    rdfs:comment "A central node in a different subgraph." ;
    sc:interactsWith sc:NodeI .

# Relations among new nodes
sc:NodeI sc:relatesTo sc:NodeJ .
sc:NodeH sc:connectsTo sc:NodeD .

# End of graph
