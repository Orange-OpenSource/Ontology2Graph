    <!-- http://pygraf.t/R6 -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/R6">
        <rdfs:comment>Relation indicating connection between entities.</rdfs:comment>
        <rdfs:label>connects to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
