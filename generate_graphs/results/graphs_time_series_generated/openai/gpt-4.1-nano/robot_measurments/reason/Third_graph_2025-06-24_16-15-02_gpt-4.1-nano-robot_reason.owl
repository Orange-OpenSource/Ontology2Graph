        <R6 rdf:resource="http://pygraf.t/E3"/>
        <R6 rdf:resource="http://pygraf.t/E4"/>
        <rdfs:comment>A central hub node with many connections.</rdfs:comment>
        <rdfs:label>Entity 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E10 -->

