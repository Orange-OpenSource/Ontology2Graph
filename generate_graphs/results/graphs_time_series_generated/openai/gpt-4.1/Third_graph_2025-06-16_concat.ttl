# --- HUB NODE ---
sc:E2000 a sc:C9 ;
    rdfs:label "Central Hub Node" ;
    rdfs:comment "A hub node with high connectivity, acting as a central point for multiple classes." ;
    sc:R2 sc:E2001, sc:E2002, sc:E2003 ;
    sc:R4 sc:E2010, sc:E2020, sc:E2030 ;
    sc:R9 sc:E2100, sc:E2200, sc:E2300 .

# --- HIGH-DEGREE NODE ---
sc:E2001 a sc:C2 ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with many incoming and outgoing relations, representing a highly connected entity." ;
    sc:R10 sc:E2004, sc:E2005 ;
    sc:R5 sc:E2000, sc:E2020, sc:E2100 ;
    sc:R6 sc:E2040 .

# --- CENTRAL NODE ---
sc:E2002 a sc:C2 ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that connects several subgraphs, acting as a bridge between them." ;
    sc:R10 sc:E2006 ;
    sc:R5 sc:E2000, sc:E2030 ;
    sc:R6 sc:E2050 .

# --- CONNECTOR NODE ---
sc:E2003 a sc:C2 ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that links two otherwise separate clusters." ;
    sc:R10 sc:E2007 ;
    sc:R5 sc:E2000, sc:E2010 ;
    sc:R6 sc:E2060 .

# --- MULTIPLEX NODE ---
sc:E2004 a sc:C6 ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node that participates in multiple types of relations and classes." ;
    sc:R7 sc:E2001, sc:E2002, sc:E2003 ;
    sc:R6 sc:E2070 ;
    sc:R9 sc:E2100 .

# --- INTERMEDIARY NODE ---
sc:E2005 a sc:C6 ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that serves as an intermediary in transitive relations." ;
    sc:R7 sc:E2001, sc:E2004 ;
    sc:R6 sc:E2080 .

# --- SUPER NODE ---
sc:E2006 a sc:C6 ;
    rdfs:label "Super Node" ;
    rdfs:comment "A node with the highest degree, connecting to all major clusters and acting as a super-hub." ;
    sc:R7 sc:E2002, sc:E2004, sc:E2005, sc:E2007 ;
    sc:R6 sc:E2090 ;
    sc:R9 sc:E2200, sc:E2300 .

