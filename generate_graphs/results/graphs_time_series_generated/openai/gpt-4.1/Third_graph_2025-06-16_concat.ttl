    sc:R4 sc:E303 ;
    sc:R9 sc:E101, sc:E301 ;
    sc:R6 sc:E202 .

# Intermediary Node
sc:E303 a sc:C10 ;
    rdfs:label "Intermediary Node Pi" ;
    rdfs:comment "An intermediary node between connectors and high-degree nodes." ;
    sc:R1 sc:E301 ;
    sc:R4 sc:E302 ;
    sc:R6 sc:E203 .

# Intermediary Node
sc:E304 a sc:C10 ;
    rdfs:label "Intermediary Node Rho" ;
    rdfs:comment "An intermediary node between intermediary and multiplex nodes." ;
    sc:R1 sc:E305 ;
    sc:R4 sc:E204 ;
    sc:R6 sc:E400 .

# Multiplex Node
sc:E305 a sc:C1, sc:C3 ;
    rdfs:label "Multiplex Node Sigma" ;
    rdfs:comment "A multiplex node, instance of two classes, connecting intermediary and multiplex nodes." ;
    sc:R1 sc:E204 ;
    sc:R3 sc:E304 ;
    sc:R6 sc:E500 .

# Super Node (second, for diversity)
sc:E400 a sc:C10 ;
    rdfs:label "Super Node Tau" ;
    rdfs:comment "A super node, highly connected, linking to the main super node and other hubs." ;
    sc:R1 sc:E100 ;
    sc:R4 sc:E500 ;
    sc:R6 sc:E304, sc:E401 .

# Hub Node
sc:E401 a sc:C9 ;
    rdfs:label "Hub Node Upsilon" ;
    rdfs:comment "A hub node connected to a super node and a connector node." ;
    sc:R2 sc:E402 ;
    sc:R4 sc:E500 ;
    sc:R9 sc:E403 ;
    sc:R6 sc:E400 .

# Connector Node
sc:E402 a sc:C9 ;
    rdfs:label "Connector Node Phi" ;
    rdfs:comment "A connector node linking a hub and an intermediary node." ;
    sc:R2 sc:E401 ;
    sc:R4 sc:E403 ;
    sc:R9 sc:E404 ;
    sc:R6 sc:E405 .

# Intermediary Node
sc:E403 a sc:C10 ;
