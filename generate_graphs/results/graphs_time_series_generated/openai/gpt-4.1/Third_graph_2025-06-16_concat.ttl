sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# --- Hub Node ---
sc:E2001 a sc:C9 ;
    rdfs:label "Central Hub Node" ;
    rdfs:comment "A hub node with high connectivity, acting as a central point for multiple relations." ;
    sc:R2 sc:E2002, sc:E2003, sc:E2004 ;
    sc:R4 sc:E2005, sc:E2006 ;
    sc:R9 sc:E2007, sc:E2008 .

# --- High-degree Node ---
sc:E2002 a sc:C2 ;
    rdfs:label "High-degree Node" ;
    rdfs:comment "A node with a large number of connections, especially to the hub node." ;
    sc:R10 sc:E2001, sc:E2005, sc:E2010 ;
    sc:R5 sc:E2006, sc:E2009 ;
    sc:R6 sc:E2011 .

# --- Central Node ---
sc:E2003 a sc:C5 ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that connects several subgroups and acts as a bridge between them." ;
    sc:R2 sc:E2007, sc:E2012 ;
    sc:R6 sc:E2001 ;
    sc:R9 sc:E2013, sc:E2014 .

# --- Connector Node ---
sc:E2004 a sc:C3 ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that links different classes and serves as a connector in the graph." ;
    sc:R1 sc:E2001, sc:E2015 ;
    sc:R4 sc:E2016 ;
    sc:R6 sc:E2017 .

# --- Intermediary Node ---
sc:E2005 a sc:C10 ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that intermediates between the hub and other nodes, facilitating indirect connections." ;
    sc:R4 sc:E2001, sc:E2018 ;
    sc:R6 sc:E2002 ;
    sc:R3 sc:E2019 .

# --- Multiplex Node ---
sc:E2006 a sc:C9 ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node participating in multiple types of relations and domains." ;
    sc:R2 sc:E2010 ;
    sc:R4 sc:E2001, sc:E2012 ;
    sc:R9 sc:E2002, sc:E2013 .

# --- Super Node ---
sc:E2007 a sc:C9 ;
    rdfs:label "Super Node" ;
    rdfs:comment "A node with both high degree and centrality, connecting to many nodes and acting as a key player." ;
    sc:R2 sc:E2003, sc:E2014 ;
    sc:R4 sc:E2011 ;
    sc:R9 sc:E2001, sc:E2006, sc:E2013 .

# --- Additional Entities for Structure ---

sc:E2008 a sc:C9 ;
    rdfs:label "Peripheral Node A" ;
    rdfs:comment "A peripheral node connected to the hub and super node." ;
    sc:R4 sc:E2001 ;
    sc:R9 sc:E2007 .

sc:E2009 a sc:C9 ;
    rdfs:label "Peripheral Node B" ;
    rdfs:comment "A peripheral node connected to the high-degree and multiplex nodes." ;
    sc:R4 sc:E2006 ;
    sc:R9 sc:E2002 .

sc:E2010 a sc:C2 ;
    rdfs:label "Connector Node C2" ;
    rdfs:comment "A C2 class node connecting high-degree and multiplex nodes." ;
    sc:R10 sc:E2006 ;
    sc:R5 sc:E2002 ;
    sc:R6 sc:E2012 .

sc:E2011 a sc:C10 ;
    rdfs:label "Bridge Node" ;
    rdfs:comment "A node acting as a bridge between the super node and high-degree node." ;
    sc:R6 sc:E2002, sc:E2007 ;
    sc:R4 sc:E2013 .

sc:E2012 a sc:C5 ;
    rdfs:label "Subgroup Node" ;
    rdfs:comment "A node representing a subgroup, connected to central and multiplex nodes." ;
    sc:R2 sc:E2003 ;
    sc:R4 sc:E2006 ;
    sc:R9 sc:E2014 ;
    sc:R6 sc:E2010 .

sc:E2013 a sc:C9 ;
    rdfs:label "Cluster Node" ;
    rdfs:comment "A node forming a cluster with the super, central, and multiplex nodes." ;
    sc:R4 sc:E2011 ;
    sc:R9 sc:E2006, sc:E2007, sc:E2003 .

sc:E2014 a sc:C9 ;
    rdfs:label "Satellite Node" ;
    rdfs:comment "A satellite node orbiting the super and central nodes." ;
    sc:R4 sc:E2012 ;
    sc:R9 sc:E2007, sc:E2003 .

sc:E2015 a sc:C1 ;
    rdfs:label "C1 Connector" ;
    rdfs:comment "A C1 class node connected to the connector node." ;
    sc:R3 sc:E2004 ;
    sc:R6 sc:E2016 .

sc:E2016 a sc:C4 ;
    rdfs:label "C4 Intermediary" ;
    rdfs:comment "A C4 class node acting as an intermediary for the connector node." ;
    sc:R4 sc:E2004 ;
    sc:R6 sc:E2015 .

sc:E2017 a sc:C10 ;
    rdfs:label "Leaf Node" ;
    rdfs:comment "A leaf node connected to the connector node." ;
    sc:R6 sc:E2004 .

sc:E2018 a sc:C10 ;
    rdfs:label "Intermediary Leaf" ;
    rdfs:comment "A leaf node connected to the intermediary node." ;
    sc:R4 sc:E2005 .

sc:E2019 a sc:C3 ;
    rdfs:label "C3 Bridge" ;
    rdfs:comment "A C3 class node connected to the intermediary node." ;
    sc:R1 sc:E2005 .

