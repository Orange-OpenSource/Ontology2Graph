    rdfs:comment "An intermediary node between two connectors." ;
    sc:R1 sc:E403 ;
    sc:R4 sc:E405 ;
    sc:R6 sc:E402 .

# Multiplex Node
sc:E405 a sc:C1, sc:C3 ;
