    sc:R1 sc:E404 ;
    sc:R3 sc:E402 ;
    sc:R6 sc:E500 .

# Super Node (third, for more structure)
sc:E500 a sc:C10 ;
    rdfs:label "Super Node Alpha Prime" ;
    rdfs:comment "A super node, highly connected, linking to other super nodes, hubs, and multiplex nodes." ;
    sc:R1 sc:E100, sc:E400 ;
    sc:R4 sc:E401, sc:E405 ;
    sc:R6 sc:E305 .

# Multiplex Node (with three classes)
sc:E600 a sc:C1, sc:C3, sc:C4 ;
