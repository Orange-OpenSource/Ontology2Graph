# --- Hub Node ---
sc:E2000 a sc:C9 ;
    rdfs:label "Central Hub Node" ;
    rdfs:comment "A hub node with high connectivity, acting as a central point for multiple relations." ;
    sc:R4 sc:E2001, sc:E2002, sc:E2003, sc:E2004, sc:E2005 ;
    sc:R9 sc:E2010, sc:E2011, sc:E2012 .

# --- High-degree Node ---
sc:E2001 a sc:C9 ;
    rdfs:label "High-degree Node" ;
    rdfs:comment "A node with a large number of direct connections, but not necessarily central." ;
    sc:R4 sc:E2000, sc:E2002, sc:E2003, sc:E2006 ;
    sc:R9 sc:E2010, sc:E2013 .

# --- Central Node ---
sc:E2002 a sc:C9 ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that is central in the network, connecting different clusters." ;
    sc:R4 sc:E2000, sc:E2001, sc:E2003, sc:E2007 ;
    sc:R9 sc:E2011, sc:E2014 .

# --- Connector Node ---
sc:E2003 a sc:C9 ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects two or more otherwise separate clusters." ;
    sc:R4 sc:E2000, sc:E2001, sc:E2002, sc:E2008 ;
    sc:R9 sc:E2012, sc:E2015 .

# --- Intermediary Node ---
sc:E2004 a sc:C9 ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as a bridge between the hub and peripheral nodes." ;
    sc:R4 sc:E2000, sc:E2005 ;
    sc:R9 sc:E2013 .

# --- Peripheral Node (for completeness) ---
sc:E2005 a sc:C9 ;
    rdfs:label "Peripheral Node" ;
    rdfs:comment "A node on the edge of the network, connected mainly to the hub and intermediary." ;
    sc:R4 sc:E2000, sc:E2004 ;
    sc:R9 sc:E2014 .

# --- Multiplex Node (multiple types of relations) ---
sc:E2006 a sc:C5 ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node participating in multiple types of relations and classes." ;
    sc:R6 sc:E2007 ;
    sc:R9 sc:E2001, sc:E2015 ;
    sc:R2 sc:E2016 .

# --- Super Node (connects across classes) ---
sc:E2007 a sc:C7 ;
    rdfs:label "Super Node" ;
    rdfs:comment "A super node that connects across different classes and acts as a bridge." ;
    sc:R8 sc:E2008 ;
    sc:R6 sc:E2006 ;
    sc:R4 sc:E2002 .

# --- Connector Node (different class) ---
sc:E2008 a sc:C7 ;
    rdfs:label "Connector Node (Class C7)" ;
    rdfs:comment "A connector node of class C7, linking to the super node and another cluster." ;
    sc:R8 sc:E2007 ;
    sc:R6 sc:E2009 .

# --- Intermediary Node (different class) ---
sc:E2009 a sc:C7 ;
    rdfs:label "Intermediary Node (Class C7)" ;
    rdfs:comment "An intermediary node in class C7, connecting to a connector node." ;
    sc:R8 sc:E2008 .

# --- Cluster 2: C2 nodes (for R9) ---
sc:E2010 a sc:C2 ;
    rdfs:label "Cluster2 Node 1" ;
    rdfs:comment "A node in class C2, part of a cluster connected via R9." ;
    sc:R9 sc:E2000, sc:E2001, sc:E2011 .

sc:E2011 a sc:C2 ;
    rdfs:label "Cluster2 Node 2" ;
    rdfs:comment "Another node in class C2, connected to the hub and central node." ;
    sc:R9 sc:E2000, sc:E2002, sc:E2010, sc:E2012 .

sc:E2012 a sc:C2 ;
    rdfs:label "Cluster2 Node 3" ;
    rdfs:comment "A C2 node connected to the hub, connector, and another C2 node." ;
    sc:R9 sc:E2000, sc:E2003, sc:E2011 .

sc:E2013 a sc:C2 ;
    rdfs:label "Cluster2 Node 4" ;
    rdfs:comment "A C2 node connected to the high-degree and intermediary nodes." ;
    sc:R9 sc:E2001, sc:E2004 .

sc:E2014 a sc:C2 ;
    rdfs:label "Cluster2 Node 5" ;
    rdfs:comment "A C2 node connected to the central and peripheral nodes." ;
    sc:R9 sc:E2002, sc:E2005 .

sc:E2015 a sc:C2 ;
    rdfs:label "Cluster2 Node 6" ;
    rdfs:comment "A C2 node connected to the connector and multiplex nodes." ;
    sc:R9 sc:E2003, sc:E2006 .

# --- Multiplex Node's R2 relation (C5 to C2) ---
sc:E2016 a sc:C2 ;
    rdfs:label "Multiplex Target Node" ;
    rdfs:comment "A C2 node that is the target of a multiplex node's R2 relation." ;
    sc:R9 sc:E2015 .

# --- C4 node with R6 to C10 node ---
sc:E2020 a sc:C4 ;
    rdfs:label "C4 Node" ;
    rdfs:comment "A node of class C4, connected to a C10 node via R6." ;
    sc:R6 sc:E2021 .

sc:E2021 a sc:C10 ;
    rdfs:label "C10 Node" ;
    rdfs:comment "A node of class C10, connected from a C4 node." ;
