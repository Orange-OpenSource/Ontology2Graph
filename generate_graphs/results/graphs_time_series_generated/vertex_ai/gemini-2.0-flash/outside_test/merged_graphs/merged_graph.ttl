    a noria:Locus ;
    rdfs:label "Locus A" ;
    rdfs:comment "Location of Resource 1." .

ex:LocusB
    a noria:Locus ;
    rdfs:label "Locus B" ;
    rdfs:comment "Location of Resource 2." .

ex:LocusC
    a noria:Locus ;
    rdfs:label "Locus C" ;
    rdfs:comment "Location of Resource 3." .

ex:LocusD
