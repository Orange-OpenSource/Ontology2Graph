    rdfs:label "Event Record 2" ;
    noria:logText "Firmware upgrade started on Resource B" ;
    noria:logOriginatingManagedObject ex:ResourceB ;
    noria:loggingTime "2024-11-15T14:05:00Z"^^xsd:dateTime .

