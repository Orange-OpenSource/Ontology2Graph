# Relationships and Node Types
ex:ApplicationX
    seas:subSystemOf ex:ServiceA . # Hub Node: ApplicationX connects to multiple entities

ex:ApplicationY
    seas:subSystemOf ex:ServiceB .

ex:Resource1
    noria:resourceForApplication ex:ApplicationModuleA . # High-Degree Node: Resource1 connects to many applications
ex:Resource2
    noria:resourceForApplication ex:ApplicationModuleB .
ex:Resource3
    noria:resourceForApplication ex:ApplicationX .

ex:NetworkLink1
    noria:networkLinkTerminationResourceOrigin ex:Resource1 ; # Central Node: NetworkLink1 connects Resource1 and Resource2
    noria:networkLinkTerminationResourceDestination ex:Resource2 .

ex:ServiceA
    a noria:Service ;
    rdfs:label "Service A" ;
    rdfs:comment "A critical service." ;
    seas:subSystemOf ex:ServiceSuper . # Connector Node: ServiceA connects ApplicationX and ServiceSuper

ex:ServiceB
    a noria:Service ;
    rdfs:label "Service B" ;
    rdfs:comment "Another important service." ;
    seas:subSystemOf ex:ServiceSuper .

ex:ServiceSuper
    a noria:Service ;
    rdfs:label "Super Service" ;
    rdfs:comment "A super service connecting multiple services." . # Super Node: ServiceSuper connects multiple services

ex:TroubleTicket1
    noria:troubleTicketRelatedService ex:ApplicationModuleA . # Intermediary Node: TroubleTicket1 connects Resource1 and ApplicationModuleA
ex:ChangeRequest1
    noria:changeRequestImpact ex:ApplicationModuleB .

ex:Employee1
    a foaf:Person ;
    rdfs:label "John Doe" ;
    noria:agentManagesResource ex:Resource1 . # Multiplex Node: Employee1 connects to Resource1 and TeamAlpha
ex:TeamAlpha
    a org:OrganizationalUnit ;
    rdfs:label "Team Alpha" ;
