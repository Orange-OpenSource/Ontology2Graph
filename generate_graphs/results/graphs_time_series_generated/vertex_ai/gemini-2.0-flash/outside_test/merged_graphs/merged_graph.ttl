# Relationships and Node Types

# Hub Node: Resource3 (connected to multiple network interfaces and links)
ex:Resource3
    noria:resourceForApplication ex:ApplicationX, ex:ApplicationY ;
    noria:resourceManagedBy ex:TeamAlpha .

# High-Degree Node: NetworkLink1 (connected to multiple network interfaces)
ex:NetworkLink1
    noria:networkLinkTerminationResource ex:Resource1, ex:Resource3 .

# Central Node: ApplicationX (used by multiple resources)
ex:ApplicationX
    noria:resourceForApplication ex:Resource1, ex:Resource2 .

# Connector Node: NetworkInterface3 (connects Resource3 and NetworkLink1)
ex:NetworkInterface3
    noria:networkInterfaceOf ex:Resource3 ;
    noria:networkInterfaceConnects ex:NetworkLink1 .

# Intermediary Node: ApplicationModuleA (connects ApplicationX and ServiceZ)
ex:ApplicationModuleA
    seas:subSystemOf ex:ServiceZ .

# Multiplex Node: Resource1 (part of ApplicationX and connected to NetworkLink1)
ex:Resource1
    noria:resourceForApplication ex:ApplicationX ;
    noria:locatedAtLocus ex:LocusA .

# Super Node: ServiceZ (aggregates ApplicationModuleA and ApplicationModuleB)
ex:ServiceZ
    seas:subSystemOf ex:ApplicationModuleA, ex:ApplicationModuleB .

