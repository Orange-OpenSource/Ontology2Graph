ex:TroubleTicket1
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket 1" ;
    dcterms:description "Network outage on Resource A" ;
    noria:troubleTicketSeverity ex:Severity_Major ;
    noria:troubleTicketType ex:Type_Failure ;
    noria:troubleTicketPriority ex:Priority_P1 ;
    noria:troubleTicketRelatedResource ex:ResourceA ;
    noria:troubleTicketStatusCurrent ex:Status_InProgress ;
    time:inXSDDateTimeStamp "2024-10-27T10:00:00Z"^^xsd:dateTime .

ex:ChangeRequest1
    a noria:ChangeRequest ;
    rdfs:label "Change Request 1" ;
    dcterms:description "Upgrade firmware on Resource B" ;
    noria:changeRequestCategory ex:Category_Internal ;
    noria:changeRequestType ex:Type_Standard ;
    noria:changeRequestImpact ex:ResourceB ;
    noria:changeRequestStatusCurrent ex:Status_Planned ;
    time:inXSDDateTimeStamp "2024-11-15T14:00:00Z"^^xsd:dateTime .

ex:EventRecord1
    a noria:EventRecord ;
    rdfs:label "Event Record 1" ;
    noria:logText "Interface eth0 down on Resource A" ;
    noria:logOriginatingManagedObject ex:ResourceA ;
    noria:loggingTime "2024-10-27T09:55:00Z"^^xsd:dateTime ;
    noria:alarmSeverity ex:Severity_Critical .

ex:EventRecord2
