ex:NetworkLink1
    noria:networkLinkTerminationResource ex:Resource1, ex:Resource2 . # Intermediary node

ex:ServiceA
    seas:subSystemOf ex:ApplicationModuleA . # Central node

ex:ApplicationModuleA
