ex:ApplicationModuleA
    seas:subSystemOf ex:ApplicationX . # Central node (ApplicationModuleA)

ex:ApplicationModuleB
    seas:subSystemOf ex:ApplicationY . # Central node (ApplicationModuleB)

ex:Site1 a bot:Site ;
    rdfs:label "Data Center Site" ;
    noria:siteId "DC001" ;
    bot:hasSpace ex:Room1 . # Super node (Site1)

