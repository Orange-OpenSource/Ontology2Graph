@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity degree, acting as a critical junction."@en ;
  noria:structuralElementObservable <https://example.com/NodeTrafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node coordinating network activities."@en ;
  noria:structuralElementObservable <https://example.com/NodeStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/LinkUtilization> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservable <https://example.com/IntermediaryTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/StreamMultiplexingStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A core network resource responsible for data routing."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:resourceHostName "core-router-1" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual server hosting critical applications."@en ;
  noria:resourceLogisticId "RES-002" ;
  noria:resourceHostName "vm-host-42" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtualServer> ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "Line:L, in Room:Server Room 1"@en ;
  noria:locusRow "Row: R, in Room:Server Room 1"@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Data center rack 7."@en ;
  noria:locusLine "Line:L, in Data Center"@en ;
  noria:locusRow "Row: 7"@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing application and server support."@en .

<https://example.com/NodeTrafficLoad> a noria:StructuralObservable ;
  rdfs:label "Node Traffic Load"@en ;
  rdfs:comment "Current traffic load on the node."@en .

<https://example.com/NodeStatus> a noria:StructuralObservable ;
  rdfs:label "Node Status"@en ;
  rdfs:comment "Operational status of the node."@en .

<https://example.com/LinkUtilization> a noria:StructuralObservable ;
  rdfs:label "Link Utilization"@en ;
  rdfs:comment "Utilization percentage of the network link."@en .

<https://example.com/IntermediaryTraffic> a noria:StructuralObservable ;
  rdfs:label "Intermediary Traffic"@en ;
  rdfs:comment "Traffic passing through the intermediary node."@en .

<https://example.com/StreamMultiplexingStatus> a noria:StructuralObservable ;
  rdfs:label "Stream Multiplexing Status"@en ;
  rdfs:comment "Status of stream multiplexing at the multiplex node."@en .

<https://example.com/SuperNodeTraffic> a noria:StructuralObservable ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Aggregated traffic at the super node."@en .