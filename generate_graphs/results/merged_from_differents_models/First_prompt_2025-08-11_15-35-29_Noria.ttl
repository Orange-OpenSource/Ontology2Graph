@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node coordinating network operations."@en ;
  noria:structuralElementObservable <https://example.com/latencyMonitor> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node serving as a connector between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkSupportTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataThroughput> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamQuality> ;
  noria:elementManagedBy <https://example.com/MediaTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple network elements."@en ;
  noria:structuralElementObservable <https://example.com/superNodeStatus> ;
  noria:elementManagedBy <https://example.com/NetworkSupervisors> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/NetworkAdmin> a org:Organization ;
  rdfs:label "Network Administration"@en ;
  rdfs:comment "Admin team overseeing high-degree nodes."@en .

<https://example.com/NetworkSupportTeam> a org:Organization ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team for connector nodes."@en .

<https://example.com/NetworkTeam> a org:Organization ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "General network management team."@en .

<https://example.com/MediaTeam> a org:Organization ;
  rdfs:label "Media Handling Team"@en ;
  rdfs:comment "Team managing multiplex nodes."@en .

<https://example.com/NetworkSupervisors> a org:Organization ;
  rdfs:label "Network Supervisors"@en ;
  rdfs:comment "Supervisory team for super nodes."@en .

<https://example.com/trafficLoad> a noria:Property ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load on the node."@en .

<https://example.com/latencyMonitor> a noria:Property ;
  rdfs:label "Latency Monitor"@en ;
  rdfs:comment "Monitoring latency metrics."@en .

<https://example.com/connectionStatus> a noria:Property ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the node's connection."@en .

<https://example.com/dataThroughput> a noria:Property ;
  rdfs:label "Data Throughput"@en ;
  rdfs:comment "Data throughput rate."@en .

<https://example.com/streamQuality> a noria:Property ;
  rdfs:label "Stream Quality"@en ;
  rdfs:comment "Quality metrics for multiplex streams."@en .

<https://example.com/superNodeStatus> a noria:Property ;
  rdfs:label "Super Node Status"@en ;
  rdfs:comment "Operational status of the super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Physical resource representing a network device."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "device1.example.com" ;
  noria:resourceType <http://example.com/NetworkDevice> ;
  noria:locatedAtLocus <https://example.com/Room1> ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceUsageState <http://example.com/Operational> ;
  noria:resourceInstallationDate "2020-05-20T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/Room1> a noria:Room ;
  rdfs:label "Server Room 1"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model name."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "Manufacturer A"@en ;
  rdfs:comment "Device manufacturer."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLK001" ;
  noria:networkLinkInstallationDate "2021-01-15T09:00:00Z"^^xsd:dateTime .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Another network device."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "device2.example.com" ;
  noria:resourceType <http://example.com/NetworkDevice> ;
  noria:locatedAtLocus <https://example.com/Room2> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <http://example.com/Operational> ;
  noria:resourceInstallationDate "2019-11-10T11:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagedBy <https://example.com/NetworkSupportTeam> .

<https://example.com/Room2> a noria:Room ;
  rdfs:label "Data Center 2"@en ;
  rdfs:comment "Secondary data center."@en .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Another device model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "Manufacturer B"@en ;
  rdfs:comment "Another device manufacturer."@en .

<https://example.com/Connection1> a noria:NetworkLink ;
  rdfs:label "Connection between Resource1 and Resource2"@en ;
  rdfs:comment "Physical connection."@en ;
  noria:networkLinkId "CONN001" ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub for network traffic."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high connectivity."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node coordinating network functions."@en ;
  noria:structuralElementObservable <https://example.com/latencyMonitor> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkSupportTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Facilitates data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataThroughput> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Handles multiple streams."@en ;
  noria:structuralElementObservable <https://example.com/streamQuality> ;
  noria:elementManagedBy <https://example.com/MediaTeam> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates network elements."@en ;
  noria:structuralElementObservable <https://example.com/superNodeStatus> ;
  noria:elementManagedBy <https://example.com/NetworkSupervisors> .