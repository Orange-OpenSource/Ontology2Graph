@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical network point."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node in the network topology, facilitating data flow."@en ;
  noria:structuralElementObservable <https://example.com/trafficFlow> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/ConnectivitySupport> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating routing between segments."@en ;
  noria:structuralElementObservableData <https://example.com/routingMetrics> ;
  noria:elementManagedBy <https://example.com/RoutingTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/aggregationLevel> ;
  noria:elementManagedBy <https://example.com/NetworkSupervision> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management and maintenance."@en .

<https://example.com/NetworkAdmin> a org:Organization ;
  rdfs:label "Network Administration"@en ;
  rdfs:comment "Admin team overseeing high-degree nodes."@en .

<https://example.com/NetworkTeam> a org:Organization ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "Team managing central nodes."@en .

<https://example.com/ConnectivitySupport> a org:Organization ;
  rdfs:label "Connectivity Support"@en ;
  rdfs:comment "Support team for connector nodes."@en .

<https://example.com/RoutingTeam> a org:Organization ;
  rdfs:label "Routing Team"@en ;
  rdfs:comment "Team responsible for routing and intermediary nodes."@en .

<https://example.com/StreamManagement> a org:Organization ;
  rdfs:label "Stream Management"@en ;
  rdfs:comment "Team managing multiplex nodes."@en .

<https://example.com/NetworkSupervision> a org:Organization ;
  rdfs:label "Network Supervision"@en ;
  rdfs:comment "Team overseeing super nodes."@en .

<https://example.com/degreeMetric> a noria:structuralObservableData ;
  rdfs:label "Degree Metric"@en ;
  rdfs:comment "A metric indicating the number of connections for a node."@en .

<https://example.com/trafficFlow> a noria:structuralObservable ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Measurement of data flow through the node."@en .

<https://example.com/connectionStatus> a noria:structuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Current status of the node's connection."@en .

<https://example.com/routingMetrics> a noria:structuralObservableData ;
  rdfs:label "Routing Metrics"@en ;
  rdfs:comment "Metrics related to routing performance."@en .

<https://example.com/streamCount> a noria:structuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/aggregationLevel> a noria:structuralObservableData ;
  rdfs:label "Aggregation Level"@en ;
  rdfs:comment "Level of data aggregation at super node."@en .
