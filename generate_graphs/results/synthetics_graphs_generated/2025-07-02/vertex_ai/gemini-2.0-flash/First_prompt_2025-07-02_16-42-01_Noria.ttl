ex:TroubleTicket1
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket 1" ;
    dcterms:identifier "TT001" ;
    noria:troubleTicketSeverity ex:Severity_Major ;
    noria:troubleTicketType ex:Type_Failure ;
    noria:troubleTicketPriority ex:Priority_P1 ;
    noria:troubleTicketOrigin ex:Origin_Customer ;
    noria:troubleTicketStatusCurrent ex:Status_InProgress ;
    noria:troubleTicketRelatedService ex:ServiceA ;
    noria:troubleTicketRelatedResource ex:ResourceA .

ex:Severity_Major
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major" .

ex:Type_Failure
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
