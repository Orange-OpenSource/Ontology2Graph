ex:ContactMethod_Email
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email" .

ex:ContactMethod_Phone
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
