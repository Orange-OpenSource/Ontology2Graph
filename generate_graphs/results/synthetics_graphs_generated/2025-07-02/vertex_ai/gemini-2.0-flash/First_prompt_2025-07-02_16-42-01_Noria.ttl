    rdfs:label "Change Request 1" ;
    dcterms:identifier "CR001" ;
    noria:changeRequestCategory ex:Category_Internal ;
    noria:changeRequestType ex:Type_Standard ;
    noria:changeRequestStatusCurrent ex:Status_Approved ;
    noria:changeRequestImpact ex:ResourceB .

