ex:ApplicationModuleA
    a noria:ApplicationModule ;
    rdfs:label "Application Module A" ;
    noria:applicationModuleName "AppModuleA" ;
    noria:applicationModuleIdentifier "AM001" ;
    noria:applicationModuleOf ex:ApplicationX ;
    noria:applicationModuleAdministrationTeam ex:TeamAlpha ;
    noria:applicationModuleSupportTeam ex:TeamBeta ;
    noria:applicationModuleSlaLevel ex:SLA_Gold ;
    noria:applicationModuleStatus ex:Status_Production .

ex:ApplicationModuleB
    a noria:ApplicationModule ;
    rdfs:label "Application Module B" ;
    noria:applicationModuleName "AppModuleB" ;
    noria:applicationModuleIdentifier "AM002" ;
    noria:applicationModuleOf ex:ApplicationY ;
    noria:applicationModuleAdministrationTeam ex:TeamGamma ;
    noria:applicationModuleSupportTeam ex:TeamDelta ;
    noria:applicationModuleSlaLevel ex:SLA_Silver ;
    noria:applicationModuleStatus ex:Status_Testing .

ex:ApplicationX
    a noria:Application ;
    rdfs:label "Application X" ;
    noria:applicationShortIdentifier "APPX" ;
    noria:applicationModelIdentifier "AppXModel" ;
    noria:applicationType ex:Type_Web ;
    noria:applicationBusinessImportance ex:Importance_High .

ex:ApplicationY
    a noria:Application ;
    rdfs:label "Application Y" ;
    noria:applicationShortIdentifier "APPY" ;
    noria:applicationModelIdentifier "AppYModel" ;
    noria:applicationType ex:Type_Database ;
    noria:applicationBusinessImportance ex:Importance_Medium .

ex:ServiceA
    a noria:Service ;
    rdfs:label "Service A" ;
    noria:serviceType ex:ServiceType_Internal ;
    seas:subSystemOf ex:ApplicationModuleA .

ex:ServiceB
    a noria:Service ;
    rdfs:label "Service B" ;
    noria:serviceType ex:ServiceType_External ;
    seas:subSystemOf ex:ApplicationModuleB .

ex:ResourceA
    a noria:Resource ;
    rdfs:label "Resource A" ;
    noria:resourceHostName "resource-a.example.com" ;
    noria:resourceLogisticId "RL001" ;
    noria:resourceType ex:ResourceType_Server ;
    noria:resourceUsageState ex:UsageState_Production ;
    noria:resourceForApplication ex:ApplicationX ;
    noria:locatedAtLocus ex:Locus1 ;
    noria:resourceManagedBy ex:TeamAlpha .

ex:ResourceB
    a noria:Resource ;
    rdfs:label "Resource B" ;
    noria:resourceHostName "resource-b.example.com" ;
    noria:resourceLogisticId "RL002" ;
    noria:resourceType ex:ResourceType_Database ;
    noria:resourceUsageState ex:UsageState_Testing ;
    noria:resourceForApplication ex:ApplicationY ;
    noria:locatedAtLocus ex:Locus2 ;
    noria:resourceManagedBy ex:TeamBeta .

ex:NetworkInterface1
    a noria:NetworkInterface ;
    rdfs:label "eth0" ;
    noria:networkInterfaceDescription "Main Ethernet Interface" ;
    noria:networkInterfaceType ex:InterfaceType_Physical ;
    noria:networkInterfaceOf ex:ResourceA ;
    noria:networkInterfaceConnects ex:NetworkLink1 ;
    noria:networkInterfaceAdministrativeStatus ex:Status_Up ;
    noria:networkInterfaceOperationalStatus ex:Status_Up .

ex:NetworkInterface2
    a noria:NetworkInterface ;
    rdfs:label "eth1" ;
    noria:networkInterfaceDescription "Backup Ethernet Interface" ;
    noria:networkInterfaceType ex:InterfaceType_Virtual ;
    noria:networkInterfaceOf ex:ResourceB ;
    noria:networkInterfaceConnects ex:NetworkLink2 ;
    noria:networkInterfaceAdministrativeStatus ex:Status_Down ;
    noria:networkInterfaceOperationalStatus ex:Status_Down .

ex:NetworkLink1
    a noria:NetworkLink ;
    rdfs:label "Link A-B" ;
    noria:networkLinkId "NL001" ;
    noria:networkLinkTerminationResourceOrigin ex:ResourceA ;
    noria:networkLinkTerminationResourceDestination ex:ResourceB ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy ex:TeamGamma .

ex:NetworkLink2
    a noria:NetworkLink ;
    rdfs:label "Link C-D" ;
    noria:networkLinkId "NL002" ;
    noria:networkLinkTerminationResourceOrigin ex:ResourceC ;
    noria:networkLinkTerminationResourceDestination ex:ResourceD ;
    noria:networkLinkType "Optical Fiber" ;
    noria:resourceManagedBy ex:TeamDelta .

ex:ResourceC
    a noria:Resource ;
    rdfs:label "Resource C" ;
    noria:resourceHostName "resource-c.example.com" ;
    noria:resourceLogisticId "RL003" ;
    noria:resourceType ex:ResourceType_Router ;
    noria:resourceUsageState ex:UsageState_Production ;
    noria:resourceForApplication ex:ApplicationX ;
    noria:locatedAtLocus ex:Locus3 ;
    noria:resourceManagedBy ex:TeamAlpha .

ex:ResourceD
    a noria:Resource ;
    rdfs:label "Resource D" ;
    noria:resourceHostName "resource-d.example.com" ;
    noria:resourceLogisticId "RL004" ;
    noria:resourceType ex:ResourceType_Firewall ;
    noria:resourceUsageState ex:UsageState_Testing ;
    noria:resourceForApplication ex:ApplicationY ;
    noria:locatedAtLocus ex:Locus4 ;
    noria:resourceManagedBy ex:TeamBeta .

ex:Locus1
    a noria:Locus ;
    rdfs:label "Locus 1" ;
    bot:containsZone ex:Room1 ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

ex:Locus2
    a noria:Locus ;
    rdfs:label "Locus 2" ;
    bot:containsZone ex:Room1 ;
    noria:locusLine "B" ;
    noria:locusRow "2" .

ex:Locus3
    a noria:Locus ;
    rdfs:label "Locus 3" ;
    bot:containsZone ex:Room2 ;
    noria:locusLine "C" ;
    noria:locusRow "3" .

ex:Locus4
    a noria:Locus ;
    rdfs:label "Locus 4" ;
    bot:containsZone ex:Room2 ;
    noria:locusLine "D" ;
    noria:locusRow "4" .

ex:Room1
    a noria:Room ;
    rdfs:label "Server Room 1" .

ex:Room2
    a noria:Room ;
    rdfs:label "Server Room 2" .

ex:TeamAlpha
    a org:OrganizationalUnit ;
    rdfs:label "Team Alpha" ;
    noria:agentWorkingHours "9-5 Mon-Fri" ;
    noria:agentPreferredContactMethod ex:ContactMethod_Email ;
    noria:agentInstructions "Contact via ticketing system" .

ex:TeamBeta
    a org:OrganizationalUnit ;
    rdfs:label "Team Beta" ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod ex:ContactMethod_Phone ;
    noria:agentInstructions "Escalate to Team Lead" .

ex:TeamGamma
    a org:OrganizationalUnit ;
