@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix ex: <http://example.com/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix bot: <https://w3id.org/bot#> .

# Entities
ex:ApplicationModuleA
    a noria:ApplicationModule ;
    rdfs:label "Application Module A"@en ;
    rdfs:comment "A critical application module"@en ;
    noria:applicationModuleName "AppModuleA" ;
    noria:applicationModuleIdentifier "AM001" ;
    noria:applicationModuleOf ex:ApplicationX ;
    noria:applicationModuleAdministrationTeam ex:TeamAlpha ;
    noria:applicationModuleSupportTeam ex:TeamBeta ;
    noria:applicationModuleSlaLevel ex:SLA_Gold ;
    noria:applicationModuleStatus ex:Status_Production .

ex:ApplicationX
    a noria:Application ;
    rdfs:label "Application X"@en ;
    rdfs:comment "A central application"@en ;
    noria:applicationShortIdentifier "AppX" ;
    noria:applicationModelIdentifier "AX123" ;
    noria:applicationType ex:Type_BusinessCritical ;
    noria:applicationBusinessImportance ex:Importance_High .

ex:Resource1
    a noria:Resource ;
    rdfs:label "Resource 1"@en ;
    rdfs:comment "A high-degree resource"@en ;
    noria:resourceHostName "resource1.example.com" ;
    noria:resourceLogisticId "RL001" ;
    noria:resourceType ex:Type_Server ;
    noria:resourceForApplication ex:ApplicationX ;
    noria:locatedAtLocus ex:LocusA .

ex:Resource2
    a noria:Resource ;
    rdfs:label "Resource 2"@en ;
    rdfs:comment "An intermediary resource"@en ;
    noria:resourceHostName "resource2.example.com" ;
    noria:resourceLogisticId "RL002" ;
    noria:resourceType ex:Type_Database ;
    noria:resourceForApplication ex:ApplicationModuleA ;
    noria:locatedAtLocus ex:LocusB .

ex:Resource3
    a noria:Resource ;
    rdfs:label "Resource 3"@en ;
    rdfs:comment "A connector resource"@en ;
    noria:resourceHostName "resource3.example.com" ;
    noria:resourceLogisticId "RL003" ;
    noria:resourceType ex:Type_Firewall ;
    noria:resourceForApplication ex:ApplicationModuleA ;
    noria:locatedAtLocus ex:LocusC .

ex:Resource4
    a noria:Resource ;
    rdfs:label "Resource 4"@en ;
    rdfs:comment "A multiplex resource"@en ;
    noria:resourceHostName "resource4.example.com" ;
    noria:resourceLogisticId "RL004" ;
    noria:resourceType ex:Type_LoadBalancer ;
    noria:resourceForApplication ex:ApplicationX ;
    noria:locatedAtLocus ex:LocusD .

ex:Resource5
    a noria:Resource ;
    rdfs:label "Resource 5"@en ;
    rdfs:comment "A hub resource"@en ;
    noria:resourceHostName "resource5.example.com" ;
    noria:resourceLogisticId "RL005" ;
    noria:resourceType ex:Type_Router ;
    noria:resourceForApplication ex:ApplicationX ;
    noria:locatedAtLocus ex:LocusE .

ex:NetworkInterface1
    a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Network interface of Resource 1"@en ;
    noria:networkInterfaceOf ex:Resource1 ;
    noria:networkInterfaceConnects ex:NetworkLink1 .

ex:NetworkInterface2
    a noria:NetworkInterface ;
    rdfs:label "eth1"@en ;
    rdfs:comment "Network interface of Resource 2"@en ;
    noria:networkInterfaceOf ex:Resource2 ;
    noria:networkInterfaceConnects ex:NetworkLink1 .

ex:NetworkLink1
    a noria:NetworkLink ;
    rdfs:label "Link between Resource 1 and Resource 2"@en ;
    rdfs:comment "A critical network link"@en ;
    noria:networkLinkId "NL001" ;
    noria:networkLinkTerminationResourceOrigin ex:Resource1 ;
    noria:networkLinkTerminationResourceDestination ex:Resource2 .

ex:TeamAlpha
    a org:OrganizationalUnit ;
    rdfs:label "Team Alpha"@en ;
    rdfs:comment "Administration team for Application Module A"@en .

ex:TeamBeta
    a org:OrganizationalUnit ;
    rdfs:label "Team Beta"@en ;
    rdfs:comment "Support team for Application Module A"@en .

ex:SLA_Gold
    a skos:Concept ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "Gold service level agreement"@en .

ex:Status_Production
    a skos:Concept ;
    rdfs:label "Production"@en ;
    rdfs:comment "Application module is in production"@en .

ex:Type_BusinessCritical
    a skos:Concept ;
    rdfs:label "Business Critical"@en ;
    rdfs:comment "Business critical application type"@en .

ex:Importance_High
    a skos:Concept ;
    rdfs:label "High Importance"@en ;
    rdfs:comment "High business importance"@en .

ex:Type_Server
    a skos:Concept ;
    rdfs:label "Server"@en ;
    rdfs:comment "Server resource type"@en .

ex:Type_Database
    a skos:Concept ;
    rdfs:label "Database"@en ;
    rdfs:comment "Database resource type"@en .

ex:Type_Firewall
    a skos:Concept ;
    rdfs:label "Firewall"@en ;
    rdfs:comment "Firewall resource type"@en .

ex:Type_LoadBalancer
    a skos:Concept ;
    rdfs:label "Load Balancer"@en ;
    rdfs:comment "Load balancer resource type"@en .

ex:Type_Router
    a skos:Concept ;
    rdfs:label "Router"@en ;
    rdfs:comment "Router resource type"@en .

ex:RoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room"@en .

ex:LocusA
    a noria:Locus ;
    rdfs:label "Locus A"@en ;
    rdfs:comment "Specific location in Server Room A"@en ;
    bot:containedIn ex:RoomA .

ex:LocusB
    a noria:Locus ;
    rdfs:label "Locus B"@en ;
    rdfs:comment "Specific location in Server Room A"@en ;
    bot:containedIn ex:RoomA .

ex:LocusC
    a noria:Locus ;
    rdfs:label "Locus C"@en ;
    rdfs:comment "Specific location in Server Room A"@en ;
    bot:containedIn ex:RoomA .

ex:LocusD
    a noria:Locus ;
    rdfs:label "Locus D"@en ;
    rdfs:comment "Specific location in Server Room A"@en ;
    bot:containedIn ex:RoomA .

ex:LocusE
    a noria:Locus ;
    rdfs:label "Locus E"@en ;
    rdfs:comment "Specific location in Server Room A"@en ;
    bot:containedIn ex:RoomA .

ex:SuperNode
    a noria:Resource ;
    rdfs:label "Super Node"@en ;
    rdfs:comment "A super node connecting multiple applications and resources"@en ;
    noria:resourceHostName "supernode.example.com" ;
    noria:resourceLogisticId "SN001" ;
    noria:resourceType ex:Type_Router ;
    noria:resourceForApplication ex:ApplicationX ;
    noria:resourceForApplication ex:ApplicationModuleA ;
    noria:locatedAtLocus ex:LocusE .

ex:NetworkInterface3
    a noria:NetworkInterface ;
    rdfs:label "eth2"@en ;
    rdfs:comment "Network interface of Super Node"@en ;
    noria:networkInterfaceOf ex:SuperNode ;
    noria:networkInterfaceConnects ex:NetworkLink2 .

ex:NetworkLink2
    a noria:NetworkLink ;
    rdfs:label "Link between Super Node and Resource 3"@en ;
    rdfs:comment "A network link to the super node"@en ;
    noria:networkLinkId "NL002" ;
    noria:networkLinkTerminationResourceOrigin ex:SuperNode ;
    noria:networkLinkTerminationResourceDestination ex:Resource3 .
