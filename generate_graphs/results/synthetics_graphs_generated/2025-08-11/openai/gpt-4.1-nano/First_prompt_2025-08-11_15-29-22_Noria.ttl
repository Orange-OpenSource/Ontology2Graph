@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity, linking multiple nodes."@en ;
  noria:elementManagedBy <https://example.com/opsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with a high number of connections, acting as a critical connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:elementManagedBy <https://example.com/networkOps> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node acting as a connector between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/ConnectivityDept> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node that intermediates data flow between source and destination."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/DataManagement> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiple data streams or services."@en ;
  noria:structuralElementObservable <https://example.com/serviceLoad> ;
  noria:elementManagedBy <https://example.com/ServiceOps> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with super connectivity, acting as a super hub."@en ;
  noria:structuralElementObservable <https://example.com/superTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Core network resource responsible for data routing."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "core-router-1" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagedBy <https://example.com/NetworkOps> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Virtual server hosting critical applications."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "virt-server-42" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualServer> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Provisioned> ;
  noria:resourceInstallationDate "2021-11-20T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagedBy <https://example.com/VirtualizationTeam> .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance router model from Vendor A."@en ;
  noria:productManufacturedBy <https://example.com/VendorA> .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Virtualization platform from Vendor B."@en ;
  noria:productManufacturedBy <https://example.com/VendorB> .

<https://example.com/VendorA> a org:Organization ;
  rdfs:label "Vendor A"@en ;
  rdfs:comment "Leading manufacturer of networking equipment."@en .

<https://example.com/VendorB> a org:Organization ;
  rdfs:label "Vendor B"@en ;
  rdfs:comment "Provider of virtualization solutions."@en .

<https://example.com/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/VirtualizationTeam> a org:OrganizationalUnit ;
  rdfs:label "Virtualization Team"@en ;
  rdfs:comment "Team managing virtual resources."@en .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main data center rack location."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Secondary server room."@en .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2019-03-10T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Virtual Link 1"@en ;
  rdfs:comment "Virtual network link for VM communication."@en ;
  noria:networkLinkId "NL-002" ;
  noria:networkLinkType "VLAN" ;
  noria:networkLinkInstallationDate "2021-07-01T12:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource2> ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource2> .

<https://example.com/trafficVolume> a noria:StructuralObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Measured network traffic in Mbps."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Current status of the connection (e.g., active, inactive)."@en .

<https://example.com/serviceLoad> a noria:StructuralObservable ;
  rdfs:label "Service Load"@en ;
  rdfs:comment "Current load on the service, in percentage."@en .

<https://example.com/superTraffic> a noria:StructuralObservable ;
  rdfs:label "Super Traffic"@en ;
  rdfs:comment "Aggregated traffic across super node."@en .

<https://example.com/connectionCount> a noria:StructuralObservableData ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/dataFlowRate> a noria:StructuralObservableData ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Data transfer rate in Mbps."@en .

<https://example.com/serviceLoad> a noria:StructuralObservable ;
  rdfs:label "Service Load"@en ;
  rdfs:comment "Load on the multiplex node."@en .

<https://example.com/superTraffic> a noria:StructuralObservable ;
  rdfs:label "Super Traffic"@en ;
  rdfs:comment "Traffic aggregated at super node."@en .
