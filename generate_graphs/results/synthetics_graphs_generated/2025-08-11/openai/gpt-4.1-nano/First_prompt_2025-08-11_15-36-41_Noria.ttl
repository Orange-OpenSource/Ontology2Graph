@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with a high betweenness centrality, acting as a key connector."@en ;
  noria:structuralElementObservableData <https://example.com/betweennessScore> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs."@en ;
  noria:structuralElementObservableData <https://example.com/aggregationLevel> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for network management."@en .

<https://example.com/degreeMetric> a noria:Property ;
  rdfs:label "Degree Metric"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/betweennessScore> a noria:Property ;
  rdfs:label "Betweenness Centrality Score"@en ;
  rdfs:comment "A measure of a node's centrality in the network."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of links connected to the node."@en .

<https://example.com/dataFlowRate> a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data passing through the node."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of concurrent data streams supported."@en .

<https://example.com/aggregationLevel> a noria:Property ;
  rdfs:label "Aggregation Level"@en ;
  rdfs:comment "Level of data aggregation in super nodes."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A network resource contributing to the infrastructure."@en ;
  noria:resourceHostName "host1.example.com" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Another network resource."@en ;
  noria:resourceHostName "host2.example.com" .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "Additional resource in the network."@en ;
  noria:resourceHostName "host3.example.com" .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Resource 4"@en ;
  rdfs:comment "Supporting resource node."@en ;
  noria:resourceHostName "host4.example.com" .

<https://example.com/Resource5> a noria:Resource ;
  rdfs:label "Resource 5"@en ;
  rdfs:comment "Another supporting resource."@en ;
  noria:resourceHostName "host5.example.com" .

<https://example.com/Resource6> a noria:Resource ;
  rdfs:label "Resource 6"@en ;
  rdfs:comment "Additional resource node."@en ;
  noria:resourceHostName "host6.example.com" .

<https://example.com/Resource7> a noria:Resource ;
  rdfs:label "Resource 7"@en ;
  rdfs:comment "Supporting resource node."@en ;
  noria:resourceHostName "host7.example.com" .

<https://example.com/Resource8> a noria:Resource ;
  rdfs:label "Resource 8"@en ;
  rdfs:comment "Supporting resource node."@en ;
  noria:resourceHostName "host8.example.com" .

<https://example.com/Resource9> a noria:Resource ;
  rdfs:label "Resource 9"@en ;
  rdfs:comment "Supporting resource node."@en ;
  noria:resourceHostName "host9.example.com" .

<https://example.com/Resource10> a noria:Resource ;
  rdfs:label "Resource 10"@en ;
  rdfs:comment "Supporting resource node."@en ;
  noria:resourceHostName "host10.example.com" .

<https://example.com/HubNode> noria:structuralElementObservable <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeNode> noria:structuralElementObservable <https://example.com/connectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/CentralNode> noria:structuralElementObservable <https://example.com/betweennessScore> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/ConnectorNode> noria:structuralElementObservable <https://example.com/connectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/IntermediaryNode> noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/MultiplexNode> noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/SuperNode> noria:structuralElementObservable <https://example.com/aggregationLevel> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HubNode> noria:elementManagedBy <https://example.com/NetworkOps> .
<https://example.com/HighDegreeNode> noria:elementManagedBy <https://example.com/NetworkOps> .
<https://example.com/CentralNode> noria:elementManagedBy <https://example.com/NetworkOps> .
<https://example.com/ConnectorNode> noria:elementManagedBy <https://example.com/NetworkOps> .
<https://example.com/IntermediaryNode> noria:elementManagedBy <https://example.com/NetworkOps> .
<https://example.com/MultiplexNode> noria:elementManagedBy <https://example.com/NetworkOps> .
<https://example.com/SuperNode> noria:elementManagedBy <https://example.com/NetworkOps> .