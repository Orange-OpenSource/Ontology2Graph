@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing core network infrastructure."@en .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservable <https://example.com/observable/HighDegreeNodeStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within a specific sub-network."@en ;
  noria:structuralElementObservable <https://example.com/observable/CentralNodeLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/ConnectorNodeTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node facilitating data flow between hubs."@en ;
  noria:structuralElementObservable <https://example.com/observable/IntermediaryNodeStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/MultiplexNodeLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node with super connectivity."@en ;
  noria:structuralElementObservable <https://example.com/observable/SuperNodeTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical server resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "server1.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual machine resource."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "vm2.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Provisioned> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceManagedBy <https://example.com/CloudSupportTeam> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Data center rack."@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model X."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ProductModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Manufacturer's model Y."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "Manufacturer A"@en ;
  rdfs:comment "Leading hardware manufacturer."@en .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "Manufacturer B"@en ;
  rdfs:comment "Virtualization platform provider."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for server management."@en .

<https://example.com/CloudSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Cloud Support Team"@en ;
  rdfs:comment "Team managing virtual resources."@en .

<https://example.com/observable/HighDegreeNodeStatus> a noria:StructuralObservable ;
  rdfs:label "High Degree Node Status"@en ;
  rdfs:comment "Status of high-degree node."@en .

<https://example.com/observable/CentralNodeLoad> a noria:StructuralObservable ;
  rdfs:label "Central Node Load"@en ;
  rdfs:comment "Current load on central node."@en .

<https://example.com/observable/ConnectorNodeTraffic> a noria:StructuralObservable ;
  rdfs:label "Connector Node Traffic"@en ;
  rdfs:comment "Traffic volume on connector node."@en .

<https://example.com/observable/IntermediaryNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Intermediary Node Status"@en ;
  rdfs:comment "Operational status of intermediary node."@en .

<https://example.com/observable/MultiplexNodeLoad> a noria:StructuralObservable ;
  rdfs:label "Multiplex Node Load"@en ;
  rdfs:comment "Load metrics for multiplex node."@en .

<https://example.com/observable/SuperNodeTraffic> a noria:StructuralObservable ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Traffic overview of super node."@en .
