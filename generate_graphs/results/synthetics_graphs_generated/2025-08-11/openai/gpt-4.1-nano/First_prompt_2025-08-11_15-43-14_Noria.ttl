@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A highly connected network switch with numerous links."@en ;
  noria:structuralElementObservableData <https://example.com/LinkCount> ;
  noria:structuralElementObservable <https://example.com/LinkCount> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "The core router in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/TrafficLoad> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a bridge between two subnetworks."@en ;
  noria:structuralElementObservable <https://example.com/LinkStatus> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A relay point in the data flow."@en ;
  noria:structuralElementObservable <https://example.com/PacketLoss> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node performing multiplexing of multiple signals."@en ;
  noria:structuralElementObservable <https://example.com/SignalQuality> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An aggregation point with super high connectivity."@en ;
  noria:structuralElementObservable <https://example.com/ConnectionCount> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Server A"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceHostName "serverA.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceForApplication <https://example.com/FinanceApp> ;
  noria:agentManagesResource <https://example.com/ITSupportTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Router B"@en ;
  rdfs:comment "Edge router connecting to external network."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceHostName "routerB.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2021-11-20T09:30:00Z"^^xsd:dateTime ;
  noria:resourceForApplication <https://example.com/ExternalAccess> ;
  noria:agentManagesResource <https://example.com/NetworkTeam> .

<https://example.com/Link1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connecting Server A and Router B."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkInstallationDate "2022-02-01T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Link2> a noria:NetworkLink ;
  rdfs:label "Wireless Link 2"@en ;
  rdfs:comment "Wireless connection between two access points."@en ;
  noria:networkLinkId "NLINK002" ;
  noria:networkLinkInstallationDate "2022-03-15T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Wireless" ;
  noria:networkLinkTerminationResource <https://example.com/Resource2> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource3> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Switch C"@en ;
  rdfs:comment "Aggregation switch in data center."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:locatedAtLocus <https://example.com/Locus3> ;
  noria:resourceHostName "switchC.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
  noria:resourceProductModel <https://example.com/ProductModelZ> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2020-07-10T11:00:00Z"^^xsd:dateTime ;
  noria:resourceForApplication <https://example.com/DataCenterApp> ;
  noria:agentManagesResource <https://example.com/DatacenterOps> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Edge network area."@en .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Locus 3"@en ;
  rdfs:comment "Data center rack."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Responsible for network infrastructure management."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Handles server and resource management."@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "Manages network devices and links."@en .

<https://example.com/DatacenterOps> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en ;
  rdfs:comment "Oversees data center resources."@en .

<https://example.com/FinanceApp> a noria:Application ;
  rdfs:label "Finance Application"@en ;
  rdfs:comment "Application handling financial transactions."@en .

<https://example.com/ExternalAccess> a noria:Application ;
  rdfs:label "External Access Service"@en ;
  rdfs:comment "Service providing external network access."@en .

<https://example.com/DataCenterApp> a noria:Application ;
  rdfs:label "Data Center Management"@en ;
  rdfs:comment "Application for data center resource management."@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model for server."@en .

<https://example.com/ProductModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Manufacturer's model for router."@en .

<https://example.com/ProductModelZ> a noria:ProductModel ;
  rdfs:label "Model Z"@en ;
  rdfs:comment "Manufacturer's model for switch."@en .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "Central hub node in the network."@en .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, e.g., core switch."@en .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Core router in the network."@en .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node bridging subnetworks."@en .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Relay point in data flow."@en .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Performs signal multiplexing."@en .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Highly connected aggregation point."@en .

<https://example.com/LinkCount> a noria:Property ;
  rdfs:label "Link Count"@en ;
  rdfs:comment "Number of links connected to a node."@en .

<https://example.com/TrafficLoad> a noria:Property ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/LinkStatus> a noria:Property ;
  rdfs:label "Link Status"@en ;
  rdfs:comment "Operational status of a link."@en .

<https://example.com/SignalQuality> a noria:Property ;
  rdfs:label "Signal Quality"@en ;
  rdfs:comment "Quality of signal in multiplexing."@en .

<https://example.com/ConnectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .