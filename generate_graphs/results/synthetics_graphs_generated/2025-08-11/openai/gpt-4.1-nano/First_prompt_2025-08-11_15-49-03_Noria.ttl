@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality, connecting multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node linking different network domains."@en ;
  noria:structuralElementObservable <https://example.com/connectionType> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node facilitating data flow between hubs."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/subNodeCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of connections associated with the node."@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "The volume of traffic passing through the node."@en .

<https://example.com/connectionType> a noria:StructuralObservable ;
  rdfs:label "Connection Type"@en ;
  rdfs:comment "Type of connection (e.g., fiber, wireless)."@en .

<https://example.com/dataFlowRate> a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through the node."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/subNodeCount> a noria:Property ;
  rdfs:label "Sub-Node Count"@en ;
  rdfs:comment "Number of sub-nodes under a super node."@en .

<https://example.com/connection> a noria:NetworkLink ;
  rdfs:label "Connection between Hub and High-Degree Node"@en ;
  rdfs:comment "A network connection linking the hub node to a high-degree node."@en ;
  noria:networkLinkId "conn-001" .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Connection between Central and Connector Nodes"@en ;
  rdfs:comment "A network link connecting the central node to a connector node."@en ;
  noria:networkLinkId "conn-002" .

<https://example.com/connection3> a noria:NetworkLink ;
  rdfs:label "Connection between Intermediary and Multiplex Nodes"@en ;
  rdfs:comment "A link facilitating data flow between intermediary and multiplex nodes."@en ;
  noria:networkLinkId "conn-003" .

<https://example.com/connection4> a noria:NetworkLink ;
  rdfs:label "Connection between Multiplex and Super Nodes"@en ;
  rdfs:comment "A high-capacity link connecting multiplex nodes to super nodes."@en ;
  noria:networkLinkId "conn-004" .

<https://example.com/connection5> a noria:NetworkLink ;
  rdfs:label "Connection between Hub and Super Node"@en ;
  rdfs:comment "A backbone connection linking the hub node to the super node."@en ;
  noria:networkLinkId "conn-005" .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity."@en ;
  noria:structuralElementObservable <https://example.com/connectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservable <https://example.com/connectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality in the network."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Links different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionType> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Facilitates data flow between other nodes."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Supports multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/subNodeCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .