@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "Organization responsible for network management."@en .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "High-degree node with many connections."@en ;
  noria:structuralElementObservable <https://example.com/routerStatus1> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/routerStatus1> a noria:StructuralObservable ;
  rdfs:label "Router Operational Status"@en ;
  rdfs:comment "Observable property indicating the status of the core router."@en .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "Central node connecting multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/centralSwitchStatus> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/centralSwitchStatus> a noria:StructuralObservable ;
  rdfs:label "Switch Status"@en ;
  rdfs:comment "Observable property for switch operational state."@en .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Fiber Optic Connector"@en ;
  rdfs:comment "Connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectorStatus> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/connectorStatus> a noria:StructuralObservable ;
  rdfs:label "Connector Status"@en ;
  rdfs:comment "Observable property indicating connector health."@en .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediate Switch"@en ;
  rdfs:comment "Node acting as intermediary in network routing."@en ;
  noria:structuralElementObservable <https://example.com/intermediaryStatus> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/intermediaryStatus> a noria:StructuralObservable ;
  rdfs:label "Intermediary Switch Status"@en ;
  rdfs:comment "Observable for intermediary switch health."@en .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexing Node"@en ;
  rdfs:comment "Node handling multiplexed signals."@en ;
  noria:structuralElementObservable <https://example.com/multiplexStatus> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/multiplexStatus> a noria:StructuralObservable ;
  rdfs:label "Multiplex Node Status"@en ;
  rdfs:comment "Observable property for multiplex node status."@en .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Super node with super high connectivity."@en ;
  noria:structuralElementObservable <https://example.com/superNodeStatus> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/superNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Super Node Status"@en ;
  rdfs:comment "Observable indicating super node health."@en .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "High-speed fiber optic link between HubNode1 and CoreRouter1."@en ;
  noria:networkLinkId "Link-AB-001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Fiber Link B-C"@en ;
  rdfs:comment "Fiber link connecting Core Router to Data Center Switch."@en ;
  noria:networkLinkId "Link-BC-002" ;
  noria:networkLinkInstallationDate "2022-02-20T11:30:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/connection3> a noria:NetworkLink ;
  rdfs:label "Wireless Link C-D"@en ;
  rdfs:comment "Wireless connection from Data Center Switch to Intermediary Node."@en ;
  noria:networkLinkId "Link-CD-003" ;
  noria:networkLinkInstallationDate "2022-03-10T09:45:00"^^xsd:dateTime ;
  noria:networkLinkType "Wireless" .

<https://example.com/routerStatus1> a noria:StructuralObservable ;
  rdfs:label "Router Status"@en ;
  rdfs:comment "Operational status of the core router."@en .

<https://example.com/centralSwitchStatus> a noria:StructuralObservable ;
  rdfs:label "Central Switch Status"@en ;
  rdfs:comment "Operational status of the central switch."@en .

<https://example.com/connectorStatus> a noria:StructuralObservable ;
  rdfs:label "Connector Status"@en ;
  rdfs:comment "Health status of fiber optic connector."@en .

<https://example.com/intermediaryStatus> a noria:StructuralObservable ;
  rdfs:label "Intermediary Switch Status"@en ;
  rdfs:comment "Operational status of intermediary switch."@en .

<https://example.com/multiplexStatus> a noria:StructuralObservable ;
  rdfs:label "Multiplexing Node Status"@en ;
  rdfs:comment "Health status of multiplexing node."@en .

<https://example.com/superNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Super Node Status"@en ;
  rdfs:comment "Operational status of super node."@en .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Network Management Org"@en ;
  rdfs:comment "Organization responsible for network infrastructure."@en .

<https://example.com/HubNode1> a noria:StructuralElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "High-degree node with many connections."@en ;
  noria:structuralElementObservable <https://example.com/routerStatus1> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/CentralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "Central node connecting multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/centralSwitchStatus> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Fiber Optic Connector"@en ;
  rdfs:comment "Connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectorStatus> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/IntermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediate Switch"@en ;
  rdfs:comment "Node acting as intermediary in network routing."@en ;
  noria:structuralElementObservable <https://example.com/intermediaryStatus> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/MuxNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexing Node"@en ;
  rdfs:comment "Node handling multiplexed signals."@en ;
  noria:structuralElementObservable <https://example.com/multiplexStatus> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Super node with super high connectivity."@en ;
  noria:structuralElementObservable <https://example.com/superNodeStatus> ;
  noria:elementManagedBy <https://example.com/organization1> .