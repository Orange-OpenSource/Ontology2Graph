@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical network point."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:structuralElementObservable <https://example.com/degreeObservable> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node in the network topology, facilitating data flow."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionLatency> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating routing between hubs."@en ;
  noria:structuralElementObservable <https://example.com/routingPath> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for load balancing."@en ;
  noria:structuralElementObservable <https://example.com/loadDistribution> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes."@en .

<https://example.com/degreeMetric> a noria:structuralObservableOf ;
  rdfs:label "Degree Metric"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/degreeObservable> a noria:StructuralObservable ;
  rdfs:label "Degree Observable"@en ;
  rdfs:comment "Observable representing node degree."@en .

<https://example.com/trafficLoad> a noria:structuralObservableOf ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load at the node."@en .

<https://example.com/connectionLatency> a noria:structuralObservableData ;
  rdfs:label "Connection Latency"@en ;
  rdfs:comment "Latency in milliseconds for connections."@en .

<https://example.com/routingPath> a noria:structuralObservable ;
  rdfs:label "Routing Path"@en ;
  rdfs:comment "The routing path data for the node."@en .

<https://example.com/streamCount> a noria:structuralObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/loadDistribution> a noria:structuralObservable ;
  rdfs:label "Load Distribution"@en ;
  rdfs:comment "Distribution of load across multiple nodes."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical network resource."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceHostName "server1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/physical> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceManagementIPAddress "192.168.1.10" ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceForApplication <https://example.com/NetworkManagementApp> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room location."@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model name."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "ACME Corp"@en ;
  rdfs:comment "Manufacturer of Product Model X."@en .

<https://example.com/NetworkManagementApp> a noria:Application ;
  rdfs:label "Network Management System"@en ;
  rdfs:comment "Application managing network resources."@en ;
  noria:applicationModelIdentifier "NMS-Model-2023" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Backup server."@en ;
  noria:resourceLogisticId "RES-002" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceHostName "backup1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtual> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/standby> ;
  noria:resourceManagementIPAddress "192.168.1.11" .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Secondary data center."@en .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "Edge router."@en ;
  noria:resourceLogisticId "RES-003" ;
  noria:locatedAtLocus <https://example.com/Locus3> ;
  noria:resourceHostName "edge-router.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/physical> ;
  noria:resourceSerialNumber "SN789012" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceManagementIPAddress "192.168.1.12" .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Locus 3"@en ;
  rdfs:comment "Network edge location."@en .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, critical for network resilience."@en ;
  noria:structuralElementObservable <https://example.com/degreeMetric> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node acting as a central routing point."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionLatency> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Routing intermediary for data flow."@en ;
  noria:structuralElementObservable <https://example.com/routingPath> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Supports multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple nodes for load balancing."@en ;
  noria:structuralElementObservable <https://example.com/loadDistribution> .