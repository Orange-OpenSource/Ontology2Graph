@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality in the network."@en ;
  noria:structuralElementObservable <https://example.com/centralityScore> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/segmentConnections> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregationScore> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource1"@en ;
  rdfs:comment "A critical server hosting core applications."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceHostName "server1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceSerialNumber "SN987654321" ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagementIPAddress "192.168.1.10" ;
  noria:agentManagesResource <https://example.com/ITAdminTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "A virtual machine supporting analytics."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceHostName "vm-analytics.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Provisioned> ;
  noria:resourceSerialNumber "SN123456789" ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:agentManagesResource <https://example.com/ITSupportTeam> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "FiberLink1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource3"@en ;
  rdfs:comment "A network switch connecting multiple segments."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:locatedAtLocus <https://example.com/LocusC> ;
  noria:resourceHostName "switch1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceSerialNumber "SN654321987" ;
  noria:resourceProductModel <https://example.com/ProductModelZ> ;
  noria:agentManagesResource <https://example.com/NetworkTeam> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "LocusA"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "LocusB"@en ;
  rdfs:comment "Data center floor 2."@en .

<https://example.com/LocusC> a noria:Locus ;
  rdfs:label "LocusC"@en ;
  rdfs:comment "Network equipment rack."@en .

<https://example.com/ITAdminTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Administration Team"@en ;
  rdfs:comment "Team responsible for server management."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Support team for virtual infrastructure."@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team managing network devices."@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance server model."@en ;
  org:organizationName "TechCorp Inc." .

<https://example.com/ProductModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Virtual machine configuration."@en ;
  org:organizationName "TechCorp Inc." .

<https://example.com/ProductModelZ> a noria:ProductModel ;
  rdfs:label "Model Z"@en ;
  rdfs:comment "Network switch model."@en ;
  org:organizationName "NetGear Ltd." .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/centralityScore> a noria:Property ;
  rdfs:label "Centrality Score"@en ;
  rdfs:comment "Network centrality metric."@en .

<https://example.com/aggregationScore> a noria:Property ;
  rdfs:label "Aggregation Score"@en ;
  rdfs:comment "Score indicating node aggregation level."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/connectionPoint> a noria:StructuralObservable ;
  rdfs:label "Connection Point"@en ;
  rdfs:comment "A point where connections occur."@en .

<https://example.com/dataFlowRate> a noria:StructuralObservable ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data transfer."@en .

<https://example.com/centralityScore> a noria:StructuralObservable ;
  rdfs:label "Centrality Score"@en ;
  rdfs:comment "A measure of node importance."@en .

<https://example.com/connectionCount> a noria:StructuralObservableData ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/streamCount> a noria:StructuralObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of multiplexed streams."@en .

<https://example.com/aggregationScore> a noria:StructuralObservable ;
  rdfs:label "Aggregation Score"@en ;
  rdfs:comment "Level of node aggregation."@en .

<https://example.com/Resource1> a noria:ManagedElement ;
  rdfs:label "Resource1"@en ;
  rdfs:comment "Main application server."@en .

<https://example.com/Resource2> a noria:ManagedElement ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "Supporting virtual machine."@en .

<https://example.com/Resource3> a noria:ManagedElement ;
  rdfs:label "Resource3"@en ;
  rdfs:comment "Network switch for segmenting traffic."@en .

<https://example.com/NetworkLink1> a noria:StructuralElement ;
  rdfs:label "Fiber Link"@en ;
  rdfs:comment "Optical fiber connection between Resource1 and Resource2."@en .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Resource4"@en ;
  rdfs:comment "Backup server for redundancy."@en ;
  noria:resourceLogisticId "LOG99999" ;
  noria:locatedAtLocus <https://example.com/LocusD> ;
  noria:resourceHostName "backup-server.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceSerialNumber "SN000000" ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:agentManagesResource <https://example.com/ITAdminTeam> .

<https://example.com/LocusD> a noria:Locus ;
  rdfs:label "LocusD"@en ;
  rdfs:comment "Secondary data center."@en .

<https://example.com/ITAdminTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Admin Team"@en ;
  rdfs:comment "Responsible for core server management."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Support team for virtual infrastructure."@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Manages network devices and links."@en .