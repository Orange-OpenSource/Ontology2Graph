@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a critical junction."@en ;
  noria:structuralElementObservable <https://example.com/observable/connectionCount> ;
  noria:structuralElementObservableData "150"^^xsd:integer .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within the network topology."@en ;
  noria:structuralElementObservable <https://example.com/observable/centralityScore> ;
  noria:structuralElementObservableData "0.85"^^xsd:float .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node serving as a connector between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/segmentConnections> ;
  noria:structuralElementObservableData "3"^^xsd:integer .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/observable/dataFlowRate> ;
  noria:structuralElementObservableData "200 Mbps"^^xsd:string .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/streamCount> ;
  noria:structuralElementObservableData "4"^^xsd:integer .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/observable/aggregationLevel> ;
  noria:structuralElementObservableData "Super"@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A core network resource."@en ;
  noria:resourceLogisticId "RES-001"^^xsd:string ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceHostName "host1.example.com"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <kos/Resource/type/Physical> ] ;
  noria:resourceSerialNumber "SN123456"^^xsd:string ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <kos/Resource/LifecycleState/Active> ] ;
  noria:resourceManagementIPAddress "192.168.1.10"^^xsd:string ;
  noria:resourceProductModel <https://example.com/ModelX> .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "A specific product model from manufacturer."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "Manufacturer A"@en ;
  rdfs:comment "A network equipment manufacturer."@en .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/Network1> a noria:NetworkLink ;
  rdfs:label "Network Link 1"@en ;
  rdfs:comment "Optical fiber connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001"^^xsd:string ;
  noria:networkLinkInstallationDate "2020-01-15T00:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Backup server."@en ;
  noria:resourceLogisticId "RES-002"^^xsd:string ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceHostName "host2.example.com"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <kos/Resource/type/Virtual> ] ;
  noria:resourceSerialNumber "SN654321"^^xsd:string ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <kos/Resource/LifecycleState/Active> ] ;
  noria:resourceManagementIPAddress "192.168.1.11"^^xsd:string .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Data center rack B."@en .

