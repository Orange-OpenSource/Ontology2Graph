@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix ex: <http://example.com/> .

ex:ApplicationModuleA
    a noria:ApplicationModule ;
    rdfs:label "Application Module A"@en ;
    rdfs:comment "A critical application module for customer service."@en ;
    noria:applicationModuleName "AppModule-A"@en ;
    noria:applicationModuleIdentifier "AM001"@en ;
    noria:applicationModuleOf ex:ApplicationA ;
    noria:applicationModuleAdministrationTeam ex:TeamAlpha ;
    noria:applicationModuleSupportTeam ex:TeamBeta ;
    noria:applicationModuleSlaLevel ex:SLA_Gold ;
    noria:applicationModuleStatus ex:Status_Production .

ex:ApplicationModuleB
    a noria:ApplicationModule ;
    rdfs:label "Application Module B"@en ;
    rdfs:comment "A secondary application module for internal use."@en ;
    noria:applicationModuleName "AppModule-B"@en ;
    noria:applicationModuleIdentifier "AM002"@en ;
    noria:applicationModuleOf ex:ApplicationB ;
    noria:applicationModuleAdministrationTeam ex:TeamGamma ;
    noria:applicationModuleSupportTeam ex:TeamDelta ;
    noria:applicationModuleSlaLevel ex:SLA_Silver ;
    noria:applicationModuleStatus ex:Status_Testing .

ex:ApplicationA
    a noria:Application ;
    rdfs:label "Application A"@en ;
    rdfs:comment "A customer-facing application."@en ;
    noria:applicationShortIdentifier "App-A"@en ;
    noria:applicationModelIdentifier "AppModel-A"@en ;
    noria:applicationType ex:Type_CustomerFacing ;
    noria:applicationBusinessImportance ex:Importance_High .

ex:ApplicationB
    a noria:Application ;
    rdfs:label "Application B"@en ;
    rdfs:comment "An internal application for data processing."@en ;
    noria:applicationShortIdentifier "App-B"@en ;
    noria:applicationModelIdentifier "AppModel-B"@en ;
    noria:applicationType ex:Type_Internal ;
    noria:applicationBusinessImportance ex:Importance_Medium .

ex:ResourceServer1
    a noria:Resource ;
    rdfs:label "Server 1"@en ;
    rdfs:comment "A high-degree node, serving multiple applications."@en ;
    noria:resourceHostName "server1.example.com"@en ;
    noria:resourceLogisticId "RL001"@en ;
    noria:resourceType ex:Type_Server ;
    noria:resourceForApplication ex:ApplicationA, ex:ApplicationB ;
    noria:locatedAtLocus ex:LocusA .

ex:ResourceRouter1
    a noria:Resource ;
    rdfs:label "Router 1"@en ;
    rdfs:comment "A central node, routing traffic between networks."@en ;
    noria:resourceHostName "router1.example.com"@en ;
    noria:resourceLogisticId "RR001"@en ;
    noria:resourceType ex:Type_Router ;
    noria:resourceManagedBy ex:TeamAlpha ;
    noria:locatedAtLocus ex:LocusB .

ex:ResourceFirewall1
    a noria:Resource ;
    rdfs:label "Firewall 1"@en ;
    rdfs:comment "A connector node, connecting different networks."@en ;
    noria:resourceHostName "firewall1.example.com"@en ;
    noria:resourceLogisticId "RF001"@en ;
    noria:resourceType ex:Type_Firewall ;
    noria:resourceManagedBy ex:TeamBeta ;
    noria:locatedAtLocus ex:LocusC .

ex:ResourceLoadBalancer1
    a noria:Resource ;
    rdfs:label "Load Balancer 1"@en ;
    rdfs:comment "A multiplex node, distributing traffic across servers."@en ;
    noria:resourceHostName "loadbalancer1.example.com"@en ;
    noria:resourceLogisticId "RLB001"@en ;
    noria:resourceType ex:Type_LoadBalancer ;
    noria:resourceForApplication ex:ApplicationA ;
    noria:locatedAtLocus ex:LocusD .

ex:NetworkInterfaceEth0
    a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "The primary network interface of Server 1."@en ;
    noria:networkInterfaceOf ex:ResourceServer1 ;
    noria:networkInterfaceConnects ex:NetworkLink1 .

ex:NetworkInterfaceEth1
    a noria:NetworkInterface ;
    rdfs:label "eth1"@en ;
    rdfs:comment "The secondary network interface of Server 1."@en ;
    noria:networkInterfaceOf ex:ResourceServer1 ;
    noria:networkInterfaceConnects ex:NetworkLink2 .

ex:NetworkLink1
    a noria:NetworkLink ;
    rdfs:label "Network Link 1"@en ;
    rdfs:comment "A high-bandwidth network link."@en ;
    noria:networkLinkId "NL001"@en ;
    noria:networkLinkTerminationResource ex:ResourceRouter1 .

ex:NetworkLink2
    a noria:NetworkLink ;
    rdfs:label "Network Link 2"@en ;
    rdfs:comment "A low-latency network link."@en ;
    noria:networkLinkId "NL002"@en ;
    noria:networkLinkTerminationResource ex:ResourceFirewall1 .

ex:TeamAlpha
    a org:OrganizationalUnit ;
    rdfs:label "Team Alpha"@en ;
    rdfs:comment "The primary administration team."@en .

ex:TeamBeta
    a org:OrganizationalUnit ;
    rdfs:label "Team Beta"@en ;
    rdfs:comment "The secondary support team."@en .

ex:TeamGamma
    a org:OrganizationalUnit ;
    rdfs:label "Team Gamma"@en ;
    rdfs:comment "The gamma administration team."@en .

ex:TeamDelta
    a org:OrganizationalUnit ;
    rdfs:label "Team Delta"@en ;
    rdfs:comment "The delta support team."@en .

ex:LocusA
    a noria:Locus ;
    rdfs:label "Locus A"@en ;
    rdfs:comment "Location of Server 1."@en ;
    bot:containsZone ex:RoomA .

ex:LocusB
    a noria:Locus ;
    rdfs:label "Locus B"@en ;
    rdfs:comment "Location of Router 1."@en ;
    bot:containsZone ex:RoomB .

ex:LocusC
    a noria:Locus ;
    rdfs:label "Locus C"@en ;
    rdfs:comment "Location of Firewall 1."@en ;
    bot:containsZone ex:RoomC .

ex:LocusD
    a noria:Locus ;
    rdfs:label "Locus D"@en ;
    rdfs:comment "Location of Load Balancer 1."@en ;
    bot:containsZone ex:RoomD .

ex:RoomA
    a noria:Room ;
    rdfs:label "Room A"@en ;
    rdfs:comment "Server Room A."@en .

ex:RoomB
    a noria:Room ;
    rdfs:label "Room B"@en ;
    rdfs:comment "Router Room B."@en .

ex:RoomC
    a noria:Room ;
    rdfs:label "Room C"@en ;
    rdfs:comment "Firewall Room C."@en .

ex:RoomD
    a noria:Room ;
    rdfs:label "Room D"@en ;
    rdfs:comment "Load Balancer Room D."@en .

ex:SLA_Gold
    a skos:Concept ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "Gold Service Level Agreement."@en .

ex:SLA_Silver
    a skos:Concept ;
    rdfs:label "Silver SLA"@en ;
    rdfs:comment "Silver Service Level Agreement."@en .

ex:Status_Production
    a skos:Concept ;
    rdfs:label "Production"@en ;
    rdfs:comment "In Production."@en .

ex:Status_Testing
    a skos:Concept ;
    rdfs:label "Testing"@en ;
    rdfs:comment "In Testing."@en .

ex:Type_CustomerFacing
    a skos:Concept ;
    rdfs:label "Customer Facing"@en ;
    rdfs:comment "Customer Facing Application."@en .

ex:Type_Internal
    a skos:Concept ;
    rdfs:label "Internal"@en ;
    rdfs:comment "Internal Application."@en .

ex:Type_Server
    a skos:Concept ;
    rdfs:label "Server"@en ;
    rdfs:comment "Server Resource."@en .

ex:Type_Router
    a skos:Concept ;
    rdfs:label "Router"@en ;
    rdfs:comment "Router Resource."@en .

ex:Type_Firewall
    a skos:Concept ;
    rdfs:label "Firewall"@en ;
    rdfs:comment "Firewall Resource."@en .

ex:Type_LoadBalancer
    a skos:Concept ;
    rdfs:label "Load Balancer"@en ;
    rdfs:comment "Load Balancer Resource."@en .

ex:Importance_High
    a skos:Concept ;
    rdfs:label "High"@en ;
    rdfs:comment "High Business Importance."@en .

ex:Importance_Medium
    a skos:Concept ;
    rdfs:label "Medium"@en ;
    rdfs:comment "Medium Business Importance."@en .
