@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a connector in the network."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf noria:structuralElementObservableData ;
  noria:structuralElementDistinguishedName "Node-HD-01" .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable noria:structuralElementObservable ;
  noria:structuralObservableOf noria:structuralObservableOf ;
  noria:structuralElementDistinguishedName "Node-Central-01" .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node serving as a connector between different network segments."@en ;
  noria:structuralElementObservable noria:structuralElementObservable ;
  noria:structuralObservableOf noria:structuralObservableOf ;
  noria:structuralElementDistinguishedName "Node-Connector-01" .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow between hubs."@en ;
  noria:structuralElementObservable noria:structuralElementObservable ;
  noria:structuralObservableOf noria:structuralObservableOf ;
  noria:structuralElementDistinguishedName "Node-Intermediary-01" .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node connecting multiple network paths."@en ;
  noria:structuralElementObservable noria:structuralElementObservable ;
  noria:structuralObservableOf noria:structuralObservableOf ;
  noria:structuralElementDistinguishedName "Node-Multiplex-01" .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level analysis."@en ;
  noria:structuralElementObservable noria:structuralElementObservable ;
  noria:structuralObservableOf noria:structuralObservableOf ;
  noria:structuralElementDistinguishedName "Node-Super-01" .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A physical server hosting critical applications."@en ;
  noria:resourceLogisticId "LOG-RES-001" ;
  noria:resourceHostName "server1.example.com" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual machine running critical services."@en ;
  noria:resourceLogisticId "LOG-RES-002" ;
  noria:resourceHostName "vm-application.example.com" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2023-03-10T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceManagedBy <https://example.com/CloudOpsTeam> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource 1."@en ;
  noria:networkInterfaceDescription "Gigabit Ethernet interface 0"@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 ;

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary virtual network interface of Resource 2."@en ;
  noria:networkInterfaceDescription "Virtual NIC for VM"@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink2> ;
  noria:networkInterfaceRoutingPriorityMetric 200 ;
  noria:networkInterfaceLaserTxOpticalPower -1 ;
  noria:networkInterfaceLaserRxOpticalPower -2 .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between Resource 1 and Resource 2."@en ;
  noria:networkLinkId "NLINK-001" ;
  noria:networkLinkType "fiber" ;
  noria:networkLinkInstallationDate "2021-06-01T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Link2"@en ;
  rdfs:comment "Virtual link for VM network."@en ;
  noria:networkLinkId "NLINK-002" ;
  noria:networkLinkType "virtual" ;
  noria:networkLinkInstallationDate "2023-04-15T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource2> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus1"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "Line:L, in Room:Server room 314"@en ;
  noria:locusRow "Row:1"@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus2"@en ;
  rdfs:comment "Data center rack."@en ;
  noria:locusLine "Line:L, in Data Center"@en ;
  noria:locusRow "Row:2"@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for managing physical resources."@en .

<https://example.com/CloudOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Cloud Operations Team"@en ;
  rdfs:comment "Team managing virtualized resources and cloud infrastructure."@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance server model X."@en ;
  noria:productManufacturedBy <https://example.com/TechManufacturer> .

<https://example.com/ProductModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Virtual machine template Y."@en ;
  noria:productManufacturedBy <https://example.com/VMManufacturer> .

<https://example.com/TechManufacturer> a org:Organization ;
  rdfs:label "Tech Manufacturer Inc."@en ;
  rdfs:comment "Manufacturer of hardware resources."@en .

<https://example.com/VMManufacturer> a org:Organization ;
  rdfs:label "VM Software Inc."@en ;
  rdfs:comment "Manufacturer of VM templates."@en .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/CloudOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Cloud Operations Team"@en ;
  rdfs:comment "Team managing cloud and virtual resources."@en .