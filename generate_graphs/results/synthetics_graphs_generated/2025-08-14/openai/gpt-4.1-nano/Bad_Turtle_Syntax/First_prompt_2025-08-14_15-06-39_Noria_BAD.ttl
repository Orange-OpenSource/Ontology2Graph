@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Graph1> a owl:NamedIndividual ;
    rdfs:label "Sample Network and System Graph"@en ;
    rdfs:comment "A created knowledge graph demonstrating various node types and relations based on the NORIA schema."@en .

# Hub Node: Central Router
<https://example.com/Router1> a noria:StructuralElement ;
    rdfs:label "Router1"@en ;
    rdfs:comment "Main backbone router serving multiple subnets."@en ;
    noria:structuralElementDistinguishedName "Router1-DN" ;
    noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

# High-Degree Node: Core Switch
<https://example.com/SwitchCore> a noria:StructuralElement ;
    rdfs:label "CoreSwitch"@en ;
    rdfs:comment "Core switch with high connectivity in the network."@en ;
    noria:structuralElementDistinguishedName "CoreSwitch-DN" ;
    noria:structuralElementObservableData "High traffic capacity"^^xsd:string ;
    noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

# Central Node: Data Center
<https://example.com/DataCenter> a noria:StructuralElement ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center hosting critical infrastructure."@en ;
    noria:structuralElementDistinguishedName "DataCenter-DN" ;
    noria:structuralElementObservableData "Contains multiple servers and network devices"^^xsd:string ;
    noria:elementManagedBy <https://example.com/ITDepartment> .

# Connector Node: Firewall
<https://example.com/Firewall1> a noria:StructuralElement ;
    rdfs:label "Firewall1"@en ;
    rdfs:comment "Firewall connecting internal network to external internet."@en ;
    noria:structuralElementDistinguishedName "Firewall1-DN" ;
    noria:structuralElementObservableData "State: Active"^^xsd:string ;
    noria:elementManagedBy <https://example.com/SecurityTeam> .

# Intermediary Node: Virtual Machine
<https://example.com/VM1> a noria:FunctionalElement ;
    rdfs:label "VM1"@en ;
    rdfs:comment "Virtual machine hosting application services."@en ;
    noria:functionalElementDistinguishedName "VM1-DN" ;
    noria:elementManagedBy <https://example.com/ITSupport> .

# Multiplex Node: Load Balancer
<https://example.com/LoadBalancer> a noria:StructuralElement ;
    rdfs:label "LoadBalancer"@en ;
    rdfs:comment "Distributes traffic among multiple servers."@en ;
    noria:structuralElementDistinguishedName "LoadBalancer-DN" ;
    noria:elementManagedBy <https://example.com/NetworkTeam> .

# Super Node: Network Backbone
<https://example.com/Backbone> a noria:StructuralElement ;
    rdfs:label "NetworkBackbone"@en ;
    rdfs:comment "Core network infrastructure connecting all major nodes."@en ;
    noria:structuralElementDistinguishedName "Backbone-DN" ;
    noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

# Relations: Link nodes together

# Router1 connected to SwitchCore
<https://example.com/Router1> noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/SwitchCore> .

# SwitchCore connected to DataCenter
<https://example.com/SwitchCore> noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/DataCenter> .

# Firewall connected to Router1
<https://example.com/Firewall1> noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/Router1> .

# VM1 connected to DataCenter
<https://example.com/VM1> noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/DataCenter> .

# LoadBalancer connects to VM1 and DataCenter
<https://example.com/LoadBalancer> noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/VM1> ;
    noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/DataCenter> .

# Backbone links to Router1, SwitchCore, Firewall, DataCenter, VM1, LoadBalancer
<https://example.com/Backbone> noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/Router1> ;
    noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/SwitchCore> ;
    noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/Firewall1> ;
    noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/DataCenter> ;
    noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/VM1> ;
    noria:structuralElementObservable noria:structuralElementObservableOf <https://example.com/LoadBalancer> .

# Additional Nodes: Application and Service
<https://example.com/NetworkMonitoringApp> a noria:Application ;
    rdfs:label "Network Monitoring Application"@en ;
    rdfs:comment "Application monitoring network health and performance."@en ;
    noria:applicationModelIdentifier "NMA-001" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/Monitoring> ;
    noria:resourceForApplication <https://example.com/DataCenter> .

<https://example.com/NetworkService> a noria:Service ;
    rdfs:label "Network Service"@en ;
    rdfs:comment "End-to-end network connectivity service."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    rdfs:subClassOf noria:Application ;
    noria:applicationShortIdentifier "NetSvc01" .

# Link Application to Nodes
<https://example.com/NetworkMonitoringApp> noria:resourceForApplication <https://example.com/Backbone> .

# Additional Relations: Link nodes with roles
<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
    rdfs:label "Security Team"@en .

<https://example.com/ITDepartment> a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en .

<https://example.com/ITSupport> a foaf:Agent ;
    rdfs:label "IT Support Agent"@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
    rdfs:label "Network Support Team"@en .

# End of graph.