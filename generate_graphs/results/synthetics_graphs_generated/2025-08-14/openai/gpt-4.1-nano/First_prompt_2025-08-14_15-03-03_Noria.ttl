<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node in the network, connecting multiple segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch."@en ;
  noria:structuralElementObservableData <https://example.com/observable/portStatus> ;
  noria:structuralObservableOf <https://example.com/HubNode1> .

<https://example.com/CentralNode1> a noria:FunctionalElement ;
  rdfs:label "Authentication Server"@en ;
  rdfs:comment "A central node responsible for user authentication services."@en ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking internal and external networks."@en ;
  noria:structuralElementObservableData <https://example.com/observable/connectionStatus> ;
  noria:structuralElementObservable <https://example.com/structuralObservableOf/Firewall1> .

<https://example.com/IntermediaryNode1> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/MultiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/observable/streamLoad> ;
  noria:structuralObservableOf <https://example.com/HubNode1> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A super node with extensive connections, forming a backbone."@en ;
  noria:structuralElementObservableData <https://example.com/observable/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/HighDegreeNode1> .

<https://example.com/HubNode1> a noria:ManagedElement ;
  rdfs:label "Network Hub"@en ;
  rdfs:comment "A hub node with high connectivity, central to network topology."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/HighDegreeNode2> a noria:StructuralElement ;
  rdfs:label "Distribution Switch"@en ;
  rdfs:comment "A high-degree node distributing traffic to various subnets."@en ;
  noria:structuralElementObservableData <https://example.com/observable/portUtilization> ;
  noria:structuralObservableOf <https://example.com/HubNode1> .

<https://example.com/CentralNode2> a noria:FunctionalElement ;
