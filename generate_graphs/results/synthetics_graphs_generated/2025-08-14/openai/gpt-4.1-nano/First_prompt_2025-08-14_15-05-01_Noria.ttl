@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

<https://example.com/hubRouter> a noria:StructuralElement ;
  rdfs:label "Main Hub Router"@en ;
  rdfs:comment "Central node connecting multiple network segments."@en ;
  noria:structuralElementDistinguishedName "Router-Hub-001" ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/HighDegreeSwitch> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A switch with high connectivity degree, acting as a connector."@en ;
  noria:structuralElementDistinguishedName "Switch-HD-002" ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/CentralServer> a noria:StructuralElement, noria:Resource ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A critical server acting as a central node in the data center."@en ;
  noria:structuralElementDistinguishedName "Server-001" ;
  noria:resourceHostName "central-server-01" ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam_extra_node_0> ;
  noria:locatedAtLocus <https://example.com/Locus1> .

<https://example.com/ConnectorNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments, acting as an intermediary."@en ;
  noria:structuralElementDistinguishedName "Connector-003" ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/IntermediaryNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating complex routing."@en ;
  noria:structuralElementDistinguishedName "Intermediary-004" ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementDistinguishedName "Multiplex-005" ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/SuperNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementDistinguishedName "SuperNode_extra_node_0-006" ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/ITSupportTeam_extra_node_0> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing support for servers and infrastructure."@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus in Server Room 314"@en ;
  rdfs:comment "Specific location within the server room."@en ;
  noria:locusLine "Line:L, Column:6"@en ;
  noria:locusRow "Row:3"@en .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Network Interface Down Event"@en ;
  rdfs:comment "Event indicating network interface failure."@en ;
  noria:loggingTime "2024-03-15T10:15:00Z"^^xsd:dateTime ;
  noria:logText "Interface ge-0/0/1 on Router1 is down."@en ;
  noria:logOriginatingManagedObject <https://example.com/Router1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:alarmSeverity <skos:ConceptScheme> ; # placeholder for severity concept
  noria:alarmSeverity <https://example.com/Severity/Critical> ;
  noria:alarmProposedRepairAction <https://example.com/Action/RestartInterface> ;
  noria:alarmMitigatedBy <https://example.com/Procedure/RestartInterfaceProcedure> .

<https://example.com/Router1> a noria:Resource ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Main router in data center."@en ;
  noria:resourceHostName "router1.dc" ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en ;
  rdfs:comment "System monitoring network devices."@en .

<https://example.com/Severity/Critical> a skos:Concept ;
  rdfs:label "Critical"@en ;
  skos:inScheme <https://example.com/Notification/Severity> .

<https://example.com/Action/RestartInterface> a noria:OperationPlan ;
  rdfs:label "Restart Interface Procedure"@en ;
  rdfs:comment "Procedure to restart network interface."@en .

<https://example.com/Procedure/RestartInterfaceProcedure> a noria:ProceduralElement ;
  rdfs:label "Restart Interface Procedure"@en ;
  rdfs:comment "Procedure to restart network interface."@en .

<https://example.com/ChangeRequest1> a noria:ChangeRequest ;
  rdfs:label "Software Upgrade on Router1"@en ;
  rdfs:comment "Upgrade firmware to fix bugs."@en ;
  noria:changeRequestCreationDateTime "2024-03-14T09:00:00Z"^^xsd:dateTime ;
  noria:changeRequestChangeCause <https://example.com/Cause/SoftwareUpgrade> ;
  noria:changeRequestImpact <https://example.com/Router1> ;
  noria:changeRequestStatusCurrent <skos:Concept> ; # placeholder
  noria:changeRequestStatusCurrent <https://example.com/Status/Planned> .

<https://example.com/Cause/SoftwareUpgrade> a skos:Concept ;
  rdfs:label "Software Upgrade"@en ;
  skos:inScheme <https://example.com/ChangeRequest/Cause> .

<https://example.com/Status/Planned> a skos:Concept ;
  rdfs:label "Planned"@en ;
  skos:inScheme <https://example.com/ChangeRequest/Status> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Backup Server"@en ;
  rdfs:comment "Secondary server for redundancy."@en ;
  noria:resourceHostName "backup-server-01" ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam_extra_node_0> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Firewall Appliance"@en ;
  rdfs:comment "Firewall for perimeter security."@en ;
  noria:resourceHostName "firewall-01" ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Virtual Machine VM-01"@en ;
  rdfs:comment "Virtual machine hosting critical application."@en ;
  noria:resourceHostName "vm-01" ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam_extra_node_0> .

<https://example.com/Resource5> a noria:Resource ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Distributes traffic among servers."@en ;
  noria:resourceHostName "loadbalancer-01" ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Resource6> a noria:Resource ;
  rdfs:label "Database Cluster"@en ;
  rdfs:comment "Cluster of database servers."@en ;
  noria:resourceHostName "db-cluster-01" ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam_extra_node_0> .

<https://example.com/Resource7> a noria:Resource ;
  rdfs:label "Edge Router"@en ;
  rdfs:comment "Router at network edge."@en ;
  noria:resourceHostName "edge-router-01" ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Resource8> a noria:Resource ;
  rdfs:label "Core Switch"@en ;
  rdfs:comment "Core network switch."@en ;
  noria:resourceHostName "core-switch-01" ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Resource9> a noria:Resource ;
  rdfs:label "Wireless Access Point"@en ;
  rdfs:comment "Wi-Fi access point."@en ;
  noria:resourceHostName "wpa-01" ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam_extra_node_0> .

<https://example.com/Resource10> a noria:Resource ;
  rdfs:label "Storage Array"@en ;
  rdfs:comment "Network storage device."@en ;
  noria:resourceHostName "storage-01" ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam_extra_node_0> .