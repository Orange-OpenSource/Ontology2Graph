@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode_extra_node_0> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node in the network, connecting multiple segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_0> .

<https://example.com/highDegreeNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central switch."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservable1> ;
  noria:structuralObservableOf <https://example.com/structuralObservable2> ;
  noria:elementManagedBy <https://example.com/NetworkOps_extra_node_0Team> .

<https://example.com/centralNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center, connecting servers and storage."@en ;
  noria:structuralElementObservableOf <https://example.com/observable1> ;
  noria:elementManagedBy <https://example.com/DataCenterTeam> .

<https://example.com/connectorNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node acting as a firewall boundary between segments."@en ;
  noria:structuralElementObservableOf <https://example.com/observableFirewall> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservableOf <https://example.com/observableLoad> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/multiplexNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/observableMux> ;
  noria:elementManagedBy <https://example.com/NetworkTeam_extra_node_0> .

<https://example.com/superNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "An advanced super node with high capacity and multiple roles."@en ;
  noria:structuralElementObservableOf <https://example.com/observableSuper> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/HubNode_extra_node_0> a noria:ManagedElement ;
  rdfs:label "Network Hub"@en ;
  rdfs:comment "A hub node with high connectivity, central to network topology."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps_extra_node_0> .

<https://example.com/HighDegreeNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Aggregation Switch"@en ;
  rdfs:comment "A node with many connections, acting as a high-degree node."@en ;
  noria:structuralElementObservableOf <https://example.com/observableHighDeg> ;
  noria:elementManagedBy <https://example.com/NetworkTeam_extra_node_0> .

<https://example.com/CentralNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Main Data Center Switch"@en ;
  rdfs:comment "A central node with high degree, connecting core systems."@en ;
  noria:structuralElementObservableOf <https://example.com/observableCentral> ;
  noria:elementManagedBy <https://example.com/DataCenterOps> .

<https://example.com/ConnectorNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Edge Firewall"@en ;
  rdfs:comment "A connector node acting as a security boundary."@en ;
  noria:structuralElementObservableOf <https://example.com/observableFirewallEdge> ;
  noria:elementManagedBy <https://example.com/SecurityOps> .

<https://example.com/IntermediaryNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Traffic Distributor"@en ;
  rdfs:comment "An intermediary node for traffic distribution."@en ;
  noria:structuralElementObservableOf <https://example.com/observableTraffic> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam_extra_node_0> .

<https://example.com/MultiplexNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Data Stream Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/observableMuxStream> ;
  noria:elementManagedBy <https://example.com/NetworkOps_extra_node_0> .

<https://example.com/SuperNode_extra_node_0> a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "A super node with high capacity and multiple functions."@en ;
  noria:structuralElementObservableOf <https://example.com/observableSuperSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/HubNode_extra_node_0Entity> a noria:ManagedElement ;
  rdfs:label "Core Hub"@en ;
  rdfs:comment "A high-degree hub node in the core network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps_extra_node_0> .

<https://example.com/HighDegreeEntity> a noria:StructuralElement ;
  rdfs:label "Distribution Switch"@en ;
  rdfs:comment "A high-degree node connecting multiple segments."@en ;
  noria:structuralElementObservableOf <https://example.com/observableDistSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkOps_extra_node_0Team> .

<https://example.com/CentralEntity> a noria:StructuralElement ;
  rdfs:label "Core Data Switch"@en ;
  rdfs:comment "A central node within the core infrastructure."@en ;
  noria:structuralElementObservableOf <https://example.com/observableCoreData> ;
  noria:elementManagedBy <https://example.com/DataCenterTeam> .

<https://example.com/ConnectorEntity> a noria:StructuralElement ;
  rdfs:label "Firewall Boundary"@en ;
  rdfs:comment "A connector node acting as a security boundary."@en ;
  noria:structuralElementObservableOf <https://example.com/observableFirewallBoundary> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryEntity> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node for load distribution."@en ;
  noria:structuralElementObservableOf <https://example.com/observableLoadBalancer> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/MultiplexEntity> a noria:StructuralElement ;
  rdfs:label "Stream Multiplexer"@en ;
  rdfs:comment "A multiplex node for data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/observableStreamMux> ;
  noria:elementManagedBy <https://example.com/NetworkTeam_extra_node_0> .

<https://example.com/SuperEntity> a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "A high-capacity super node."@en ;
  noria:structuralElementObservableOf <https://example.com/observableSuperSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .
