@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode_extra_node_3> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_3> .

<https://example.com/highDegreeNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralElementObservable <https://example.com/connectionCountObservable> .

<https://example.com/centralNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/centralityScore> ;
  noria:structuralElementObservableData <https://example.com/centralityScoreData> .

<https://example.com/connectorNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/segmentConnections> ;
  noria:structuralElementObservableData <https://example.com/segmentConnectionsData> .

<https://example.com/intermediaryNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:structuralElementObservableData <https://example.com/dataFlowRateData> .

<https://example.com/multiplexNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that handles multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/multiplexCapacity> ;
  noria:structuralElementObservableData <https://example.com/multiplexCapacityData> .

<https://example.com/superNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/superNode_extra_node_1Load> ;
  noria:structuralElementObservableData <https://example.com/superNode_extra_node_1LoadData> .

<https://example.com/NetworkOperations_extra_node_3> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network infrastructure."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections for a node."@en .

<https://example.com/connectionCountObservable> a noria:StructuralObservable ;
  rdfs:label "Connection Count Observable"@en ;
  rdfs:comment "Observable property for connection count."@en .

<https://example.com/centralityScore> a noria:Property ;
  rdfs:label "Centrality Score"@en ;
  rdfs:comment "A score indicating the centrality of a node in the network."@en .

<https://example.com/centralityScoreData> a noria:structuralElementObservableData ;
  rdfs:label "Centrality Score Data"@en ;
  rdfs:comment "Data associated with the centrality score."@en .

<https://example.com/segmentConnections> a noria:Property ;
  rdfs:label "Segment Connections"@en ;
  rdfs:comment "Number of segment connections for a node."@en .

<https://example.com/segmentConnectionsData> a noria:structuralElementObservableData ;
  rdfs:label "Segment Connections Data"@en ;
  rdfs:comment "Data related to segment connections."@en .

<https://example.com/dataFlowRate> a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through the node."@en .

<https://example.com/dataFlowRateData> a noria:structuralElementObservableData ;
  rdfs:label "Data Flow Rate Data"@en ;
  rdfs:comment "Data associated with data flow rate."@en .

<https://example.com/multiplexCapacity> a noria:Property ;
  rdfs:label "Multiplex Capacity"@en ;
  rdfs:comment "Capacity of multiplexing at the node."@en .

<https://example.com/multiplexCapacityData> a noria:structuralElementObservableData ;
  rdfs:label "Multiplex Capacity Data"@en ;
  rdfs:comment "Data related to multiplex capacity."@en .

<https://example.com/superNode_extra_node_1Load> a noria:Property ;
  rdfs:label "Super Node Load"@en ;
  rdfs:comment "Current load on the super node."@en .

<https://example.com/superNode_extra_node_1LoadData> a noria:structuralElementObservableData ;
  rdfs:label "Super Node Load Data"@en ;
  rdfs:comment "Data related to super node load."@en .

# Relationships linking nodes
<https://example.com/hubNode_extra_node_3> noria:structuralElementObservable <https://example.com/connectionCountObservable> ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/highDegreeNode_extra_node_1> noria:structuralElementObservable <https://example.com/connectionCountObservable> ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/centralNode_extra_node_1> noria:structuralElementObservable <https://example.com/centralityScore> ;
  noria:structuralElementObservableData <https://example.com/centralityScoreData> .

<https://example.com/connectorNode_extra_node_1> noria:structuralElementObservable <https://example.com/segmentConnections> ;
  noria:structuralElementObservableData <https://example.com/segmentConnectionsData> .

<https://example.com/intermediaryNode_extra_node_1> noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:structuralElementObservableData <https://example.com/dataFlowRateData> .

<https://example.com/multiplexNode_extra_node_1> noria:structuralElementObservable <https://example.com/multiplexCapacity> ;
  noria:structuralElementObservableData <https://example.com/multiplexCapacityData> .

<https://example.com/superNode_extra_node_1> noria:structuralElementObservable <https://example.com/superNode_extra_node_1Load> ;
  noria:structuralElementObservableData <https://example.com/superNode_extra_node_1LoadData> .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "A fiber optic link connecting hubNode_extra_node_3 to highDegreeNode_extra_node_1."@en ;
  noria:networkLinkId "NLK-001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkTerminationResource <https://example.com/hubNode_extra_node_3> ;
  noria:networkLinkTerminationResource <https://example.com/highDegreeNode_extra_node_1> .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Virtual Link A"@en ;
  rdfs:comment "A virtual connection between centralNode_extra_node_1 and connectorNode_extra_node_1."@en ;
  noria:networkLinkId "NLV-002" ;
  noria:networkLinkInstallationDate "2023-03-10T09:30:00"^^xsd:dateTime ;
  noria:networkLinkType "Virtual Link"@en ;
  noria:networkLinkTerminationResource <https://example.com/centralNode_extra_node_1> ;
  noria:networkLinkTerminationResource <https://example.com/connectorNode_extra_node_1> .

<https://example.com/connection3> a noria:NetworkLink ;
  rdfs:label "Intermediary to Multiplex"@en ;
  rdfs:comment "A link from intermediaryNode_extra_node_1 to multiplexNode_extra_node_1."@en ;
  noria:networkLinkId "NL-003" ;
  noria:networkLinkInstallationDate "2022-11-20T14:45:00"^^xsd:dateTime ;
  noria:networkLinkType "Logical Link"@en ;
  noria:networkLinkTerminationResource <https://example.com/intermediaryNode_extra_node_1> ;
  noria:networkLinkTerminationResource <https://example.com/multiplexNode_extra_node_1> .

<https://example.com/connection4> a noria:NetworkLink ;
  rdfs:label "Super Node Cluster Link"@en ;
  rdfs:comment "A high-capacity link from superNode_extra_node_1 to hubNode_extra_node_3."@en ;
  noria:networkLinkId "NL-004" ;
  noria:networkLinkInstallationDate "2024-02-01T08:00:00"^^xsd:dateTime ;
  noria:networkLinkType "High Capacity Link"@en ;
  noria:networkLinkTerminationResource <https://example.com/superNode_extra_node_1> ;
  noria:networkLinkTerminationResource <https://example.com/hubNode_extra_node_3> .

# End of graph