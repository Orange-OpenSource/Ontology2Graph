  noria:changeRequestId "CR-20231001-001" ;
  noria:changeRequestCreationDateTime "2023-10-01T10:00:00"^^xsd:dateTime ;
  noria:changeRequestActualStartTime "2023-10-02T22:00:00"^^xsd:dateTime ;
  noria:changeRequestActualEndTime "2023-10-02T23:30:00"^^xsd:dateTime ;
