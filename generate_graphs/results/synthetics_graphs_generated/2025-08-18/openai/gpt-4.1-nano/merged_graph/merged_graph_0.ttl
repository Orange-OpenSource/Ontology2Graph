@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node in the network, connecting multiple segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central switch."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservable1> ;
  noria:structuralObservableOf <https://example.com/structuralObservable2> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center, connecting servers and storage."@en ;
  noria:structuralElementObservableOf <https://example.com/observable1> ;
  noria:elementManagedBy <https://example.com/DataCenterTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node acting as a firewall boundary between segments."@en ;
  noria:structuralElementObservableOf <https://example.com/observableFirewall> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservableOf <https://example.com/observableLoad> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/observableMux> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "An advanced super node with high capacity and multiple roles."@en ;
  noria:structuralElementObservableOf <https://example.com/observableSuper> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Network Hub"@en ;
  rdfs:comment "A hub node with high connectivity, central to network topology."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Aggregation Switch"@en ;
  rdfs:comment "A node with many connections, acting as a high-degree node."@en ;
  noria:structuralElementObservableOf <https://example.com/observableHighDeg> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Main Data Center Switch"@en ;
  rdfs:comment "A central node with high degree, connecting core systems."@en ;
  noria:structuralElementObservableOf <https://example.com/observableCentral> ;
  noria:elementManagedBy <https://example.com/DataCenterOps> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Edge Firewall"@en ;
  rdfs:comment "A connector node acting as a security boundary."@en ;
  noria:structuralElementObservableOf <https://example.com/observableFirewallEdge> ;
  noria:elementManagedBy <https://example.com/SecurityOps> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Traffic Distributor"@en ;
  rdfs:comment "An intermediary node for traffic distribution."@en ;
  noria:structuralElementObservableOf <https://example.com/observableTraffic> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Data Stream Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/observableMuxStream> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "A super node with high capacity and multiple functions."@en ;
  noria:structuralElementObservableOf <https://example.com/observableSuperSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/HubNodeEntity> a noria:ManagedElement ;
  rdfs:label "Core Hub"@en ;
  rdfs:comment "A high-degree hub node in the core network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeEntity> a noria:StructuralElement ;
  rdfs:label "Distribution Switch"@en ;
  rdfs:comment "A high-degree node connecting multiple segments."@en ;
  noria:structuralElementObservableOf <https://example.com/observableDistSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/CentralEntity> a noria:StructuralElement ;
  rdfs:label "Core Data Switch"@en ;
  rdfs:comment "A central node within the core infrastructure."@en ;
  noria:structuralElementObservableOf <https://example.com/observableCoreData> ;
  noria:elementManagedBy <https://example.com/DataCenterTeam> .

<https://example.com/ConnectorEntity> a noria:StructuralElement ;
  rdfs:label "Firewall Boundary"@en ;
  rdfs:comment "A connector node acting as a security boundary."@en ;
  noria:structuralElementObservableOf <https://example.com/observableFirewallBoundary> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryEntity> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node for load distribution."@en ;
  noria:structuralElementObservableOf <https://example.com/observableLoadBalancer> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/MultiplexEntity> a noria:StructuralElement ;
  rdfs:label "Stream Multiplexer"@en ;
  rdfs:comment "A multiplex node for data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/observableStreamMux> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/SuperEntity> a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "A high-capacity super node."@en ;
  noria:structuralElementObservableOf <https://example.com/observableSuperSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .


<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode2> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch in the core network."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableSwitchStatus> ;
  noria:structuralObservableOf <https://example.com/structuralObservableTrafficLoad> .

<https://example.com/CentralNode3> a noria:FunctionalElement ;
  rdfs:label "Central Application Server"@en ;
  rdfs:comment "A central node hosting core applications, connecting to multiple resources."@en ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/ConnectorNode4> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking internal and external network segments."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableFirewallStatus> .

<https://example.com/IntermediaryNode5> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/MultiplexNode6> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableStreamLoad> .

<https://example.com/SuperNode7> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes for high-level management."@en ;
  noria:elementManagedBy <https://example.com/ManagementCenter> .

<https://example.com/Network1> a noria:Resource ;
  rdfs:label "Main Data Center Network"@en ;
  rdfs:comment "The primary network infrastructure connecting core nodes."@en ;
  noria:resourceLogisticId "DCN-001" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Edge Router"@en ;
  rdfs:comment "An edge router connecting local network to the core."@en ;
  noria:resourceLogisticId "ER-002" .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Application Server"@en ;
  rdfs:comment "A server hosting critical applications."@en ;
  noria:resourceLogisticId "AS-003" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A"@en ;
  rdfs:comment "Optical fiber link connecting HubNode1 to Main Data Center Network."@en ;
  noria:networkLinkId "FL-1001" ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Ethernet Link B"@en ;
  rdfs:comment "Ethernet connection between Main Switch and Application Server."@en ;
  noria:networkLinkId "EL-2002" ;
  noria:networkLinkType "Ethernet" .

<https://example.com/structuralObservableSwitchStatus> a noria:StructuralObservable ;
  rdfs:label "Switch Status"@en ;
  rdfs:comment "Operational status of the main switch."@en .

<https://example.com/structuralObservableTrafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load on the switch."@en .

<https://example.com/structuralObservableFirewallStatus> a noria:StructuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Operational status of the firewall connector."@en .

<https://example.com/structuralObservableStreamLoad> a noria:StructuralObservable ;
  rdfs:label "Stream Load"@en ;
  rdfs:comment "Data stream load on the multiplex node."@en .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team managing application and server infrastructure."@en .

<https://example.com/ManagementCenter> a org:OrganizationalUnit ;
  rdfs:label "Management Center"@en ;
  rdfs:comment "High-level management node overseeing super nodes."@en .

<https://example.com/Resource> a noria:Resource ;
  rdfs:label "Generic Resource"@en ;
  rdfs:comment "A generic network resource."@en .

<https://example.com/HubNode1> noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .
<https://example.com/HighDegreeNode2> noria:structuralElementObservableOf <https://example.com/structuralObservableSwitchStatus> , <https://example.com/structuralObservableTrafficLoad> .
<https://example.com/CentralNode3> noria:elementManagedBy <https://example.com/ITSupportTeam> .
<https://example.com/ConnectorNode4> noria:structuralElementObservableOf <https://example.com/structuralObservableFirewallStatus> .
<https://example.com/IntermediaryNode5> noria:elementManagedBy <https://example.com/NetworkTeam> .
<https://example.com/MultiplexNode6> noria:structuralElementObservableOf <https://example.com/structuralObservableStreamLoad> .
<https://example.com/SuperNode7> noria:elementManagedBy <https://example.com/ManagementCenter> .

<https://example.com/HubNode1> noria:connected_to <https://example.com/Network1> .
<https://example.com/HighDegreeNode2> noria:connected_to <https://example.com/Network1> .
<https://example.com/CentralNode3> noria:connected_to <https://example.com/Resource3> .
<https://example.com/ConnectorNode4> noria:connected_to <https://example.com/Network1> .
<https://example.com/IntermediaryNode5> noria:connected_to <https://example.com/Resource3> .
<https://example.com/MultiplexNode6> noria:connected_to <https://example.com/Resource2> .
<https://example.com/SuperNode7> noria:connected_to <https://example.com/Network1> .

# End of graph.

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central switch."@en ;
  noria:structuralElementObservableOf <https://example.com/HubNode1> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center connecting servers and other network devices."@en ;
  noria:structuralElementObservableOf <https://example.com/HighDegreeNode> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking external network to internal resources."@en ;
  noria:structuralElementObservableOf <https://example.com/CentralNode> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservableOf <https://example.com/ConnectorNode> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/IntermediaryNode> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "A super node aggregating multiple central nodes for high-level management."@en ;
  noria:structuralElementObservableOf <https://example.com/CentralNode> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Server A"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Router R1"@en ;
  rdfs:comment "Edge router connecting to external network."@en ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/NetworkOps> .

<https://example.com/Resource3> a noria:Resource ;
