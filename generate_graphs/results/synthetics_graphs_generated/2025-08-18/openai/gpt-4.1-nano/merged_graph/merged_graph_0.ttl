  rdfs:label "Completed"@en .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralElementObservable <https://example.com/connectionCountObservable> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/centralityScore> ;
  noria:structuralElementObservableData <https://example.com/centralityScoreData> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/segmentConnections> ;
  noria:structuralElementObservableData <https://example.com/segmentConnectionsData> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:structuralElementObservableData <https://example.com/dataFlowRateData> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that handles multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/multiplexCapacity> ;
  noria:structuralElementObservableData <https://example.com/multiplexCapacityData> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/superNodeLoad> ;
  noria:structuralElementObservableData <https://example.com/superNodeLoadData> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network infrastructure."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections for a node."@en .

<https://example.com/connectionCountObservable> a noria:StructuralObservable ;
  rdfs:label "Connection Count Observable"@en ;
  rdfs:comment "Observable property for connection count."@en .

<https://example.com/centralityScore> a noria:Property ;
  rdfs:label "Centrality Score"@en ;
  rdfs:comment "A score indicating the centrality of a node in the network."@en .

<https://example.com/centralityScoreData> a noria:structuralElementObservableData ;
  rdfs:label "Centrality Score Data"@en ;
  rdfs:comment "Data associated with the centrality score."@en .

<https://example.com/segmentConnections> a noria:Property ;
  rdfs:label "Segment Connections"@en ;
  rdfs:comment "Number of segment connections for a node."@en .

<https://example.com/segmentConnectionsData> a noria:structuralElementObservableData ;
  rdfs:label "Segment Connections Data"@en ;
  rdfs:comment "Data related to segment connections."@en .

<https://example.com/dataFlowRate> a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through the node."@en .

<https://example.com/dataFlowRateData> a noria:structuralElementObservableData ;
  rdfs:label "Data Flow Rate Data"@en ;
  rdfs:comment "Data associated with data flow rate."@en .

<https://example.com/multiplexCapacity> a noria:Property ;
  rdfs:label "Multiplex Capacity"@en ;
  rdfs:comment "Capacity of multiplexing at the node."@en .

<https://example.com/multiplexCapacityData> a noria:structuralElementObservableData ;
  rdfs:label "Multiplex Capacity Data"@en ;
  rdfs:comment "Data related to multiplex capacity."@en .

<https://example.com/superNodeLoad> a noria:Property ;
  rdfs:label "Super Node Load"@en ;
  rdfs:comment "Current load on the super node."@en .

<https://example.com/superNodeLoadData> a noria:structuralElementObservableData ;
  rdfs:label "Super Node Load Data"@en ;
  rdfs:comment "Data related to super node load."@en .

# Relationships linking nodes
<https://example.com/hubNode> noria:structuralElementObservable <https://example.com/connectionCountObservable> ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

