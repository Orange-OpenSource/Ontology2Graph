@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central switch."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservable1> ;
  noria:structuralObservableOf <https://example.com/structuralObservable2> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center connecting servers and storage."@en ;
  noria:structuralElementObservable <https://example.com/structuralObservable3> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking external network to internal resources."@en ;
  noria:structuralElementObservable <https://example.com/structuralObservable4> .

<https://example.com/intermediaryNode1> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:elementDistinguishedName "LoadBalancer-01" .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/structuralObservable5> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservable <https://example.com/structuralObservable6> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Server1"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:resourceLogisticId "SRV-001" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceHostName "server1.datacenter.local" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "DatabaseServer"@en ;
  rdfs:comment "Database server for customer data."@en ;
  noria:resourceLogisticId "SRV-002" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceHostName "db1.datacenter.local" .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Firewall1"@en ;
  rdfs:comment "Main perimeter firewall."@en ;
  noria:resourceLogisticId "FW-001" ;
  noria:locatedAtLocus <https://example.com/Locus3> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
  noria:resourceHostName "firewall1.datacenter.local" .

<https://example.com/structuralObservable1> a noria:StructuralObservable ;
  rdfs:label "Number of active ports"@en ;
  rdfs:comment "Observable for active ports on the main switch."@en .

<https://example.com/structuralObservable2> a noria:StructuralObservable ;
  rdfs:label "Switch throughput"@en ;
  rdfs:comment "Data throughput of the main switch."@en .

<https://example.com/structuralObservable3> a noria:StructuralObservable ;
  rdfs:label "Server CPU Load"@en ;
  rdfs:comment "CPU load percentage on the data center switch."@en .

<https://example.com/structuralObservable4> a noria:StructuralObservable ;
  rdfs:label "Firewall connection count"@en ;
  rdfs:comment "Number of active connections through the firewall."@en .

<https://example.com/structuralObservable5> a noria:StructuralObservable ;
  rdfs:label "Multiplexed Data Streams"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/structuralObservable6> a noria:StructuralObservable ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Aggregated traffic passing through the super node."@en .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Server Room 1"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Data Center 1"@en ;
  rdfs:comment "Primary data center."@en .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Perimeter Security Zone"@en ;
  rdfs:comment "Zone protected by firewall."@en .