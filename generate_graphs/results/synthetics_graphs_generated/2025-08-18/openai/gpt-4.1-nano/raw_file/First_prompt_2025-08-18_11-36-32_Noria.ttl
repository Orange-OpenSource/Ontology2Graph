@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/HubSwitch> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality, connecting multiple subnets."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/RouterA> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node linking different network segments."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/LoadBalancer1> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node multiplexing multiple data streams."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Multiplexer1> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/SuperSwitch> .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/HubSwitch> a noria:Resource ;
  rdfs:label "Main Hub Switch"@en ;
  rdfs:comment "A core switch acting as a network hub."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "hub-switch-01" .

<https://example.com/RouterA> a noria:Resource ;
  rdfs:label "Router A"@en ;
  rdfs:comment "A central router connecting multiple subnets."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:resourceHostName "router-a" .

<https://example.com/Firewall1> a noria:Resource ;
  rdfs:label "Firewall 1"@en ;
  rdfs:comment "Firewall acting as a connector node."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "firewall-01" .

<https://example.com/LoadBalancer1> a noria:Resource ;
  rdfs:label "Load Balancer 1"@en ;
  rdfs:comment "Intermediary node balancing traffic."@en ;
  noria:resourceLogisticId "LOG11223" ;
  noria:resourceHostName "loadbalancer-01" .

<https://example.com/Multiplexer1> a noria:Resource ;
  rdfs:label "Multiplexer 1"@en ;
  rdfs:comment "Multiplexing node for data streams."@en ;
  noria:resourceLogisticId "LOG44556" ;
  noria:resourceHostName "multiplexer-01" .

<https://example.com/SuperSwitch> a noria:Resource ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "Aggregating super node for multiple hubs."@en ;
  noria:resourceLogisticId "LOG99887" ;
  noria:resourceHostName "super-switch" .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "An example resource connected to the network."@en ;
  noria:resourceLogisticId "LOG00001" ;
  noria:resourceHostName "resource1" .

<https://example.com/connectedTo> a noria:elementProperty ;
  rdfs:label "connected to"@en ;
  rdfs:comment "Relation indicating a direct connection between nodes."@en .

<https://example.com/linksTo> a noria:elementProperty ;
  rdfs:label "links to"@en ;
  rdfs:comment "Relation indicating a link between network nodes."@en .

<https://example.com/hasConnection> a noria:elementProperty ;
  rdfs:label "has connection"@en ;
  rdfs:comment "Relation indicating a node's connection to another node."@en .

<https://example.com/connectedNode1> a noria:StructuralElement ;
  rdfs:label "Connected Node 1"@en ;
  rdfs:comment "A node connected to the hub node."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Resource1> .

<https://example.com/connectedNode2> a noria:StructuralElement ;
  rdfs:label "Connected Node 2"@en ;
  rdfs:comment "Another node connected to the hub node."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Resource1> .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Connection 1"@en ;
  rdfs:comment "A link between HubSwitch and RouterA."@en ;
  noria:networkLinkId "LINK001" ;
  noria:networkLinkInstallationDate "2023-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Connection 2"@en ;
  rdfs:comment "A link between RouterA and Firewall1."@en ;
  noria:networkLinkId "LINK002" ;
  noria:networkLinkInstallationDate "2023-02-20T12:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Ethernet" .

<https://example.com/connection3> a noria:NetworkLink ;
  rdfs:label "Connection 3"@en ;
  rdfs:comment "A link between Firewall1 and LoadBalancer1."@en ;
  noria:networkLinkId "LINK003" ;
  noria:networkLinkInstallationDate "2023-03-10T09:30:00"^^xsd:dateTime ;
  noria:networkLinkType "Virtual Link" .

<https://example.com/connection4> a noria:NetworkLink ;
  rdfs:label "Connection 4"@en ;
  rdfs:comment "A link between LoadBalancer1 and Multiplexer1."@en ;
  noria:networkLinkId "LINK004" ;
  noria:networkLinkInstallationDate "2023-04-05T11:15:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/connection5> a noria:NetworkLink ;
  rdfs:label "Connection 5"@en ;
  rdfs:comment "A link between Multiplexer1 and SuperSwitch."@en ;
  noria:networkLinkId "LINK005" ;
  noria:networkLinkInstallationDate "2023-05-01T14:45:00"^^xsd:dateTime ;
  noria:networkLinkType "Fiber Optic" .

<https://example.com/connection6> a noria:NetworkLink ;
  rdfs:label "Connection 6"@en ;
  rdfs:comment "A link connecting SuperSwitch to HubNode."@en ;
  noria:networkLinkId "LINK006" ;
  noria:networkLinkInstallationDate "2023-06-10T16:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Fiber" .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/HubSwitch> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections acting as a connector."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Resource1> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node with high centrality connecting multiple subnets."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/RouterA> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node linking different network segments."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/LoadBalancer1> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Multiplexer1> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple hubs and high-degree nodes."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/SuperSwitch> .

<https://example.com/connectedTo> a noria:elementProperty ;
  rdfs:label "connected to"@en ;
  rdfs:comment "Relation indicating direct connection between nodes."@en .

<https://example.com/linksTo> a noria:elementProperty ;
  rdfs:label "links to"@en ;
  rdfs:comment "Relation indicating link between network nodes."@en .

<https://example.com/hasConnection> a noria:elementProperty ;
  rdfs:label "has connection"@en ;
  rdfs:comment "Relation indicating a node's connection to another node."@en .

# Connecting nodes with relations
<https://example.com/HubNode> noria:connectedTo <https://example.com/HubSwitch> .
<https://example.com/HubSwitch> noria:linksTo <https://example.com/connection1> .

<https://example.com/Resource1> noria:connectedTo <https://example.com/Firewall1> .
<https://example.com/Firewall1> noria:linksTo <https://example.com/connection2> .

<https://example.com/RouterA> noria:connectedTo <https://example.com/LoadBalancer1> .
<https://example.com/LoadBalancer1> noria:linksTo <https://example.com/connection4> .

<https://example.com/Multiplexer1> noria:connectedTo <https://example.com/SuperSwitch> .
<https://example.com/SuperSwitch> noria:linksTo <https://example.com/connection5> .

<https://example.com/HubNode> noria:connectedTo <https://example.com/HighDegreeNode> .
<https://example.com/HighDegreeNode> noria:linksTo <https://example.com/connection3> .

<https://example.com/HighDegreeNode> noria:connectedTo <https://example.com/CentralNode> .
<https://example.com/CentralNode> noria:linksTo <https://example.com/connection6> .

# End of graph