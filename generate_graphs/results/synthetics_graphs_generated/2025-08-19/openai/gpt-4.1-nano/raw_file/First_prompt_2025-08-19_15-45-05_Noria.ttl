@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/OrgDept> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with a high number of connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node that is central in the network topology, connecting multiple subnets."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node serving as a bridge between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionQuality> ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow, facilitating routing."@en ;
  noria:structuralElementObservableData <https://example.com/routingPath> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node that multiplexes multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamThroughput> ;
  noria:elementManagedBy <https://example.com/PerformanceTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/aggregateLatency> ;
  noria:elementManagedBy <https://example.com/ManagementBoard> .

<https://example.com/Entity1> a noria:ManagedElement ;
  rdfs:label "Entity1"@en ;
  rdfs:comment "An example resource entity from example.com."@en ;
  noria:elementManagedBy <https://example.com/EntityOwner> .

<https://example.com/Entity2> a noria:ManagedElement ;
  rdfs:label "Entity2"@en ;
  rdfs:comment "Another resource entity from example.com."@en ;
  noria:elementManagedBy <https://example.com/EntityOwner> .

<https://example.com/Entity3> a noria:ManagedElement ;
  rdfs:label "Entity3"@en ;
  rdfs:comment "Third resource entity from example.com."@en ;
  noria:elementManagedBy <https://example.com/EntityOwner> .

<https://example.com/Entity4> a noria:ManagedElement ;
  rdfs:label "Entity4"@en ;
  rdfs:comment "Fourth resource entity from example.com."@en ;
  noria:elementManagedBy <https://example.com/EntityOwner> .

<https://example.com/EntityOwner> a org:OrganizationalUnit ;
  rdfs:label "Entity Owner"@en ;
  rdfs:comment "Organization responsible for managing entities."@en .

<https://example.com/degreeMetric> a noria:structuralElementObservableData ;
  rdfs:label "Degree Metric"@en ;
  rdfs:comment "Number of connections for high-degree node."@en .

<https://example.com/latencyObservable> a noria:structuralElementObservable ;
  rdfs:label "Latency Observable"@en ;
  rdfs:comment "Network latency measurement for central node."@en .

<https://example.com/connectionQuality> a noria:structuralElementObservable ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Quality indicator of the connection at connector node."@en .

<https://example.com/routingPath> a noria:structuralElementObservableData ;
  rdfs:label "Routing Path"@en ;
  rdfs:comment "Data representing routing path through intermediary node."@en .

<https://example.com/streamThroughput> a noria:structuralElementObservable ;
  rdfs:label "Stream Throughput"@en ;
  rdfs:comment "Data stream throughput at multiplex node."@en .

<https://example.com/aggregateLatency> a noria:structuralElementObservable ;
  rdfs:label "Aggregate Latency"@en ;
  rdfs:comment "Overall latency at super node."@en .

<https://example.com/Entity1> noria:elementManagedBy <https://example.com/EntityOwner> .
<https://example.com/Entity2> noria:elementManagedBy <https://example.com/EntityOwner> .
<https://example.com/Entity3> noria:elementManagedBy <https://example.com/EntityOwner> .
<https://example.com/Entity4> noria:elementManagedBy <https://example.com/EntityOwner> .