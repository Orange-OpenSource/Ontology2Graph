@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:structuralObservableOf <https://example.com/Router1> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:structuralObservableOf <https://example.com/ServerA> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node serving as a connector between different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that intermediates data flow between other nodes."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:structuralObservableOf <https://example.com/LoadBalancer1> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that multiplexes multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/Multiplexer1> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservableData <https://example.com/subNodeCount> ;
  noria:structuralObservableOf <https://example.com/SuperSwitch> .

<https://example.com/Router1> a noria:StructuralElement ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/ServerA> a noria:StructuralElement ;
  rdfs:label "ServerA"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Firewall1> a noria:StructuralElement ;
  rdfs:label "Firewall1"@en ;
  rdfs:comment "Network firewall for security."@en ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/LoadBalancer1> a noria:StructuralElement ;
  rdfs:label "LoadBalancer1"@en ;
  rdfs:comment "Distributes network traffic."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Multiplexer1> a noria:StructuralElement ;
  rdfs:label "Multiplexer1"@en ;
  rdfs:comment "Aggregates multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/DataCenterTeam> .

<https://example.com/SuperSwitch> a noria:StructuralElement ;
  rdfs:label "SuperSwitch"@en ;
  rdfs:comment "Main network switch aggregating sub-nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team managing application servers."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for network security."@en .

<https://example.com/NetworkManagement> a foaf:Agent ;
  rdfs:label "Network Management System"@en ;
  rdfs:comment "System monitoring network devices."@en .

<https://example.com/LatencyMonitor> a foaf:Agent ;
  rdfs:label "Latency Monitoring System"@en ;
  rdfs:comment "System monitoring latency metrics."@en .

<https://example.com/TrafficAnalyzer> a foaf:Agent ;
  rdfs:label "Traffic Analysis System"@en ;
  rdfs:comment "System analyzing network traffic."@en .

<https://example.com/ConnectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Current status of network connection."@en .

<https://example.com/LatencyMeasurement> a noria:StructuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Latency metrics between nodes."@en .

<https://example.com/TrafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/StreamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/SubNodeCount> a noria:StructuralObservable ;
  rdfs:label "Sub-Node Count"@en ;
  rdfs:comment "Number of sub-nodes under a super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource1"@en ;
  rdfs:comment "Physical resource in data center."@en ;
  noria:resourceLogisticId "RES-001" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "Virtual resource in cloud environment."@en ;
  noria:resourceLogisticId "RES-002" .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource3"@en ;
  rdfs:comment "Backup resource."@en ;
  noria:resourceLogisticId "RES-003" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Link2"@en ;
  rdfs:comment "Ethernet link between Resource2 and Resource3."@en ;
  noria:networkLinkId "NL-002" .

<https://example.com/Resource1> noria:locatedAtLocus <https://example.com/Locus1> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus in Server Room 314"@en ;
  rdfs:comment "Location within server room."@en .

<https://example.com/latencyMeasurement> a noria:structuralElementObservableData ;
  rdfs:label "Latency Data"@en ;
  rdfs:comment "Latency data between Resource1 and Resource2."@en .

<https://example.com/connectionStatus> a noria:structuralElementObservableData ;
  rdfs:label "Connection Status Data"@en ;
  rdfs:comment "Current status of the connection."@en .

<https://example.com/trafficLoad> a noria:structuralElementObservableData ;
  rdfs:label "Traffic Load Data"@en ;
  rdfs:comment "Traffic load metrics."@en .

<https://example.com/streamCount> a noria:structuralElementObservableData ;
  rdfs:label "Stream Count Data"@en ;
  rdfs:comment "Number of multiplexed streams."@en .

<https://example.com/subNodeCount> a noria:structuralElementObservableData ;
  rdfs:label "Sub-Node Count Data"@en ;
  rdfs:comment "Number of sub-nodes under super node."@en .