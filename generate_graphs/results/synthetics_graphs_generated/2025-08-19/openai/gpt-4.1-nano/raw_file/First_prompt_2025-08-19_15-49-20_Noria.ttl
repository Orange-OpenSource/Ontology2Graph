@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within a subnetwork, connecting multiple segments."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments, acting as a bridge."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow, often involved in routing."@en ;
  noria:structuralElementObservableData <https://example.com/routingMetrics> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that handles multiple data streams or protocols."@en ;
  noria:structuralElementObservable <https://example.com/protocolHandling> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkManagementTeam> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network nodes and infrastructure."@en .

<https://example.com/NetworkManagementTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Management Team"@en ;
  rdfs:comment "Team overseeing high-level network infrastructure and super nodes."@en .

<https://example.com/latencyMeasurement> a noria:StructuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Measurement of latency between nodes."@en .

<https://example.com/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load on the node."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection (up/down)."@en .

<https://example.com/routingMetrics> a noria:StructuralObservable ;
  rdfs:label "Routing Metrics"@en ;
  rdfs:comment "Metrics related to routing performance."@en .

<https://example.com/protocolHandling> a noria:StructuralObservable ;
  rdfs:label "Protocol Handling"@en ;
  rdfs:comment "Protocols supported and handled by the node."@en .

<https://example.com/aggregateTraffic> a noria:StructuralObservable ;
  rdfs:label "Aggregate Traffic"@en ;
  rdfs:comment "Total traffic aggregated at super node."@en .

<https://example.com/NodeConnector> a noria:StructuralElement ;
  rdfs:label "Node Connector"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NodeIntermediary> a noria:StructuralElement ;
  rdfs:label "Node Intermediary"@en ;
  rdfs:comment "An intermediary node involved in routing decisions."@en ;
  noria:structuralElementObservableData <https://example.com/routingMetrics> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NodeMultiplex> a noria:StructuralElement ;
  rdfs:label "Node Multiplex"@en ;
  rdfs:comment "A multiplex node handling multiple protocols."@en ;
  noria:structuralElementObservable <https://example.com/protocolHandling> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NodeSuper> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkManagementTeam> .