@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Define Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:Node ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that is central within a specific subgraph." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:Node ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different parts of the graph, acting as a bridge." .

sc:IntermediaryNode a owl:Class ;
    rdfs:subClassOf sc:Node ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that mediates interactions between other nodes." .

sc:MultiplexNode a owl:Class ;
    rdfs:subClassOf sc:Node ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations or layers." .

sc:SuperNode a owl:Class ;
    rdfs:subClassOf sc:Node ;
    rdfs:label "Super Node" ;
    rdfs:comment "An overarching node that encompasses multiple nodes or functions." .

# Define Object Properties
sc:connectsTo a owl:ObjectProperty ;
    rdfs:domain sc:Node ;
    rdfs:range sc:Node ;
    rdfs:label "connects to" ;
    rdfs:comment "Indicates a connection between two nodes." .

sc:hasRelationType a owl:ObjectProperty ;
    rdfs:domain sc:Node ;
    rdfs:range sc:RelationType ;
    rdfs:label "has relation type" ;
    rdfs:comment "Specifies the type of relation a node has with another." .

sc:linksLayer a owl:ObjectProperty ;
    rdfs:domain sc:Node ;
    rdfs:range sc:Layer ;
    rdfs:label "links layer" ;
    rdfs:comment "Indicates the layer or dimension in multiplex networks." .

# Define some relation types
sc:RelationType a owl:Class ;
    rdfs:label "Relation Type" ;
    rdfs:comment "A class representing different types of relations." .

sc:Association a sc:RelationType ;
    rdfs:label "Association" ;
    rdfs:comment "A relation indicating an association or link." .

sc:Dependency a sc:RelationType ;
    rdfs:label "Dependency" ;
    rdfs:comment "A relation indicating a dependency between nodes." .

sc:Layer a owl:Class ;
    rdfs:label "Layer" ;
    rdfs:comment "Represents different layers or dimensions in multiplex networks." .

# Define some layers
sc:LayerA a sc:Layer ;
    rdfs:label "Layer A" ;
    rdfs:comment "First layer representing social interactions." .

sc:LayerB a sc:Layer ;
    rdfs:label "Layer B" ;
    rdfs:comment "Second layer representing organizational hierarchy." .

sc:LayerC a sc:Layer ;
    rdfs:label "Layer C" ;
    rdfs:comment "Third layer representing technological dependencies." .

# Entities (Nodes)
sc:Entity1 a sc:HubNode ;
    rdfs:label "Entity 1" ;
    rdfs:comment "A central hub node with many connections." ;
    sc:connectsTo sc:Entity2, sc:Entity3, sc:Entity4 ;
    sc:hasRelationType sc:Association .

sc:Entity2 a sc:HighDegreeNode ;
    rdfs:label "Entity 2" ;
    rdfs:comment "A high-degree node connected to multiple entities." ;
    sc:connectsTo sc:Entity1, sc:Entity3 ;
    sc:hasRelationType sc:Dependency .

sc:Entity3 a sc:ConnectorNode ;
    rdfs:label "Entity 3" ;
    rdfs:comment "A connector node bridging different subgraphs." ;
    sc:connectsTo sc:Entity1, sc:Entity2, sc:Entity5 ;
    sc:linksLayer sc:LayerA ;
    sc:hasRelationType sc:Association .

sc:Entity4 a sc:IntermediaryNode ;
    rdfs:label "Entity 4" ;
    rdfs:comment "An intermediary node mediating between entities." ;
    sc:connectsTo sc:Entity1, sc:Entity6 ;
    sc:hasRelationType sc:Dependency .

sc:Entity5 a sc:MultiplexNode ;
    rdfs:label "Entity 5" ;
    rdfs:comment "A multiplex node involved in multiple layers." ;
    sc:connectsTo sc:Entity3, sc:Entity7 ;
    sc:linksLayer sc:LayerA ;
    sc:linksLayer sc:LayerB ;
    sc:hasRelationType sc:Association .

sc:Entity6 a sc:SuperNode ;
    rdfs:label "Entity 6" ;
    rdfs:comment "A super node encompassing multiple sub-entities." ;
    sc:connectsTo sc:Entity4, sc:Entity8, sc:Entity9 ;
    sc:hasRelationType sc:Dependency .

sc:Entity7 a sc:HighDegreeNode ;
    rdfs:label "Entity 7" ;
    rdfs:comment "Another high-degree node with multiple connections." ;
    sc:connectsTo sc:Entity5, sc:Entity10 ;
    sc:hasRelationType sc:Association .

sc:Entity8 a sc:IntermediaryNode ;
    rdfs:label "Entity 8" ;
    rdfs:comment "An intermediary node in the network." ;
    sc:connectsTo sc:Entity6, sc:Entity11 ;
    sc:hasRelationType sc:Dependency .

sc:Entity9 a sc:ConnectorNode ;
    rdfs:label "Entity 9" ;
    rdfs:comment "A connector node linking different layers." ;
    sc:connectsTo sc:Entity6, sc:Entity12 ;
    sc:linksLayer sc:LayerB ;
    sc:hasRelationType sc:Association .

sc:Entity10 a sc:HubNode ;
    rdfs:label "Entity 10" ;
    rdfs:comment "A hub node with multiple high-degree connections." ;
    sc:connectsTo sc:Entity7, sc:Entity13, sc:Entity14 ;
    sc:hasRelationType sc:Association .

sc:Entity11 a sc:SuperNode ;
    rdfs:label "Entity 11" ;
    rdfs:comment "A super node representing a cluster." ;
    sc:connectsTo sc:Entity8, sc:Entity15 ;
    sc:hasRelationType sc:Dependency .

sc:Entity12 a sc:HighDegreeNode ;
    rdfs:label "Entity 12" ;
    rdfs:comment "High-degree node in a different layer." ;
    sc:connectsTo sc:Entity9, sc:Entity16 ;
    sc:linksLayer sc:LayerC ;
    sc:hasRelationType sc:Association .

sc:Entity13 a sc:ConnectorNode ;
    rdfs:label "Entity 13" ;
    rdfs:comment "Connector node bridging layers." ;
    sc:connectsTo sc:Entity10, sc:Entity17 ;
    sc:linksLayer sc:LayerA ;
    sc:linksLayer sc:LayerC ;
    sc:hasRelationType sc:Association .

