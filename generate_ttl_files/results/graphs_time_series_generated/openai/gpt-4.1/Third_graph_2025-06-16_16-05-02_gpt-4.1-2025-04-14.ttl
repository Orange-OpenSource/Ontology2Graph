@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# --- Super Node ---
sc:E_Super a sc:C9 ;
    rdfs:label "Super Node" ;
    rdfs:comment "A super node with the highest degree, connecting to almost all other nodes in the graph." ;
    sc:R4 sc:E_Hub, sc:E_Central, sc:E_Connector, sc:E_Intermediary, sc:E_Multiplex, sc:E_HighDegree ;
    sc:R9 sc:E_Hub, sc:E_Central, sc:E_Connector, sc:E_Intermediary, sc:E_Multiplex, sc:E_HighDegree .

# --- Hub Node ---
sc:E_Hub a sc:C5 ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A hub node with many direct connections, acting as a local center." ;
    sc:R4 sc:E_Central, sc:E_Connector, sc:E_Intermediary, sc:E_Multiplex, sc:E_HighDegree, sc:E_Super ;
    sc:R9 sc:E_Central, sc:E_Connector, sc:E_Intermediary, sc:E_Multiplex, sc:E_HighDegree, sc:E_Super .

# --- High-Degree Node ---
sc:E_HighDegree a sc:C9 ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of connections, but not as central as the super node." ;
    sc:R4 sc:E_Hub, sc:E_Central, sc:E_Connector, sc:E_Intermediary, sc:E_Multiplex, sc:E_Super ;
    sc:R9 sc:E_Hub, sc:E_Central, sc:E_Connector, sc:E_Intermediary, sc:E_Multiplex, sc:E_Super .

# --- Central Node ---
sc:E_Central a sc:C9 ;
    rdfs:label "Central Node" ;
    rdfs:comment "A central node that connects different communities and acts as a bridge." ;
    sc:R4 sc:E_Hub, sc:E_Connector, sc:E_Intermediary, sc:E_Multiplex, sc:E_HighDegree, sc:E_Super ;
    sc:R9 sc:E_Hub, sc:E_Connector, sc:E_Intermediary, sc:E_Multiplex, sc:E_HighDegree, sc:E_Super .

# --- Connector Node ---
sc:E_Connector a sc:C9 ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A connector node that links otherwise distant parts of the graph." ;
    sc:R4 sc:E_Hub, sc:E_Central, sc:E_Intermediary, sc:E_Multiplex, sc:E_HighDegree, sc:E_Super ;
    sc:R9 sc:E_Hub, sc:E_Central, sc:E_Intermediary, sc:E_Multiplex, sc:E_HighDegree, sc:E_Super .

# --- Intermediary Node ---
sc:E_Intermediary a sc:C9 ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "An intermediary node that sits between major nodes, facilitating indirect connections." ;
    sc:R4 sc:E_Hub, sc:E_Central, sc:E_Connector, sc:E_Multiplex, sc:E_HighDegree, sc:E_Super ;
    sc:R9 sc:E_Hub, sc:E_Central, sc:E_Connector, sc:E_Multiplex, sc:E_HighDegree, sc:E_Super .

# --- Multiplex Node ---
sc:E_Multiplex a sc:C9 ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A multiplex node that participates in multiple types of relations and communities." ;
    sc:R4 sc:E_Hub, sc:E_Central, sc:E_Connector, sc:E_Intermediary, sc:E_HighDegree, sc:E_Super ;
    sc:R9 sc:E_Hub, sc:E_Central, sc:E_Connector, sc:E_Intermediary, sc:E_HighDegree, sc:E_Super .

# --- Example of a node from another class (C3) to show diversity ---
sc:E_Specialist a sc:C3 ;
    rdfs:label "Specialist Node" ;
    rdfs:comment "A node of a different class, connected to the central node and the hub node." ;
    sc:R2 sc:E_Central ;
    sc:R6 sc:E_Hub .

# --- Example of a node from another class (C1) ---
sc:E_Leaf a sc:C1 ;
    rdfs:label "Leaf Node" ;
    rdfs:comment "A peripheral node with a single connection to the connector node." ;
    sc:R3 sc:E_Connector .

# --- Example of a node from another class (C10) ---
sc:E_Isolate a sc:C10 ;
    rdfs:label "Isolate Node" ;
    rdfs:comment "A node with a single connection to the multiplex node, representing a weakly connected entity." ;
    sc:R6 sc:E_Multiplex .

# --- Example of a node from another class (C4) ---
sc:E_Cluster a sc:C4 ;
    rdfs:label "Cluster Node" ;
    rdfs:comment "A node representing a cluster, connected to the high-degree node and the specialist node." ;
    sc:R4 sc:E_HighDegree ;
    sc:R6 sc:E_Specialist .
