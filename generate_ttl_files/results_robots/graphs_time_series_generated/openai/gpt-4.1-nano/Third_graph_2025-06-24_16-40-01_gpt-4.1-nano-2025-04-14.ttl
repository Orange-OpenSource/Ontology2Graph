@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub." .

sc:CentralNode a owl:Class ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that is central within a specific subgraph or community." .

sc:ConnectorNode a owl:Class ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different communities or subgraphs." .

sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as a bridge between two nodes or groups." .

sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations or layers." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "An overarching node representing a large community or superstructure." .

# Entities
sc:E1001 a sc:HubNode ;
    rdfs:label "Entity 1001" ;
    rdfs:comment "A hub node with extensive connections." ;
    sc:hasRelation sc:R1, sc:R2, sc:R3 .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "Entity 1002" ;
    rdfs:comment "A high-degree node connected to multiple entities." ;
    sc:hasRelation sc:R2, sc:R4 .

sc:E1003 a sc:CentralNode ;
    rdfs:label "Entity 1003" ;
    rdfs:comment "A central node within a specific community." ;
    sc:hasRelation sc:R3, sc:R5 .

sc:E1004 a sc:ConnectorNode ;
    rdfs:label "Entity 1004" ;
    rdfs:comment "A connector node linking different groups." ;
    sc:hasRelation sc:R6 .

sc:E1005 a sc:IntermediaryNode ;
    rdfs:label "Entity 1005" ;
    rdfs:comment "An intermediary node bridging two entities." ;
    sc:hasRelation sc:R7 .

sc:E1006 a sc:MultiplexNode ;
    rdfs:label "Entity 1006" ;
    rdfs:comment "A multiplex node involved in multiple relation types." ;
    sc:hasRelation sc:R8, sc:R9 .

sc:E1007 a sc:SuperNode ;
    rdfs:label "Entity 1007" ;
    rdfs:comment "A super node representing a large community." ;
    sc:hasRelation sc:R10 .

# Relations
sc:R1 a owl:ObjectProperty ;
    rdfs:label "relation R1" ;
    rdfs:comment "A primary relation connecting hub nodes to other entities." .

sc:R2 a owl:ObjectProperty ;
    rdfs:label "relation R2" ;
    rdfs:comment "A relation indicating a high-degree connection." .

sc:R3 a owl:ObjectProperty ;
    rdfs:label "relation R3" ;
    rdfs:comment "A relation denoting centrality within a subgraph." .

sc:R4 a owl:ObjectProperty ;
    rdfs:label "relation R4" ;
    rdfs:comment "A relation linking high-degree nodes to other entities." .

sc:R5 a owl:ObjectProperty ;
    rdfs:label "relation R5" ;
    rdfs:comment "A relation indicating a central position." .

sc:R6 a owl:ObjectProperty ;
    rdfs:label "relation R6" ;
    rdfs:comment "A connector relation between nodes." .

sc:R7 a owl:ObjectProperty ;
    rdfs:label "relation R7" ;
    rdfs:comment "An intermediary relation bridging two nodes." .

sc:R8 a owl:ObjectProperty ;
    rdfs:label "relation R8" ;
    rdfs:comment "A multiplex relation involving multiple layers." .

sc:R9 a owl:ObjectProperty ;
    rdfs:label "relation R9" ;
    rdfs:comment "A relation indicating multiplex involvement." .

sc:R10 a owl:ObjectProperty ;
    rdfs:label "relation R10" ;
    rdfs:comment "A super relation representing large community structures." .

# Example of relations between entities
sc:E1001 sc:R1 sc:E1002 .
sc:E1002 sc:R2 sc:E1003 .
sc:E1003 sc:R3 sc:E1004 .
sc:E1004 sc:R4 sc:E1005 .
sc:E1005 sc:R5 sc:E1006 .
sc:E1006 sc:R6 sc:E1007 .
sc:E1007 sc:R10 sc:E1001 .

# Additional nodes with diverse roles
sc:E1010 a sc:HubNode ;
    rdfs:label "Entity 1010" ;
    rdfs:comment "Another hub node with multiple relations." ;
    sc:hasRelation sc:R1, sc:R2 .

sc:E1011 a sc:HighDegreeNode ;
    rdfs:label "Entity 1011" ;
    rdfs:comment "High-degree node connected to several entities." ;
    sc:hasRelation sc:R2, sc:R4 .

sc:E1012 a sc:ConnectorNode ;
    rdfs:label "Entity 1012" ;
    rdfs:comment "Connector node linking different communities." ;
    sc:hasRelation sc:R6 .

sc:E1013 a sc:IntermediaryNode ;
    rdfs:label "Entity 1013" ;
    rdfs:comment "Intermediary node bridging two groups." ;
    sc:hasRelation sc:R7 .

sc:E1014 a sc:MultiplexNode ;
    rdfs:label "Entity 1014" ;
    rdfs:comment "Involved in multiple relation types." ;
    sc:hasRelation sc:R8, sc:R9 .

sc:E1015 a sc:SuperNode ;
    rdfs:label "Entity 1015" ;
    rdfs:comment "Represents a large community or superstructure." ;
    sc:hasRelation sc:R10 .

# End of example graph
