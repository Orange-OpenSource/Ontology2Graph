    <!-- http://pygraf.t/connectsTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/connectsTo">
        <rdfs:comment>Indicates a connection between two nodes.</rdfs:comment>
        <rdfs:label>connects to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/interactsWith -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/interactsWith">
        <rdfs:comment>Indicates an interaction between entities.</rdfs:comment>
        <rdfs:label>interacts with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/linksTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/linksTo">
        <rdfs:comment>A linking relation between nodes.</rdfs:comment>
        <rdfs:label>links to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/relatesTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/relatesTo">
