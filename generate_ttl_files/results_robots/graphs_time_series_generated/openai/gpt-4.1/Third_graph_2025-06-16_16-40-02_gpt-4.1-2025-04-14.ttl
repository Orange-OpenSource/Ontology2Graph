@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Super Node: Highly connected, central to the graph
sc:E100 a sc:C10 ;
    rdfs:label "Super Node Alpha" ;
    rdfs:comment "A super node with the highest degree, connecting to almost all other nodes." ;
    sc:R6 sc:E200, sc:E300, sc:E400, sc:E500, sc:E600, sc:E700, sc:E800 ;
    sc:R1 sc:E200, sc:E300 ;
    sc:R4 sc:E900 .

# Hub Node: Connects to many nodes, but not as central as the super node
sc:E200 a sc:C9 ;
    rdfs:label "Hub Node Beta" ;
    rdfs:comment "A hub node in the network, connecting to several clusters." ;
    sc:R9 sc:E300, sc:E400, sc:E500, sc:E600 ;
    sc:R2 sc:E710 ;
    sc:R4 sc:E800 .

# High-degree Node: Many connections, but not a hub
sc:E300 a sc:C5 ;
    rdfs:label "High-degree Node Gamma" ;
    rdfs:comment "A high-degree node with multiple connections, but not a central hub." ;
    sc:R9 sc:E400, sc:E500, sc:E600 ;
    sc:R2 sc:E720 ;
    sc:R6 sc:E700 .

# Central Node: Bridges major clusters
sc:E400 a sc:C6 ;
    rdfs:label "Central Node Delta" ;
    rdfs:comment "A central node acting as a bridge between major clusters." ;
    sc:R7 sc:E500, sc:E600 ;
    sc:R9 sc:E700 ;
    sc:R4 sc:E100 .

# Connector Node: Connects two otherwise separate clusters
sc:E500 a sc:C2 ;
    rdfs:label "Connector Node Epsilon" ;
    rdfs:comment "A connector node linking two otherwise separate clusters." ;
    sc:R10 sc:E600 ;
    sc:R5 sc:E700 ;
    sc:R6 sc:E800 .

# Intermediary Node: Lies on many shortest paths
sc:E600 a sc:C3 ;
    rdfs:label "Intermediary Node Zeta" ;
    rdfs:comment "An intermediary node that lies on many shortest paths between other nodes." ;
    sc:R3 sc:E700 ;
    sc:R1 sc:E800 ;
    sc:R4 sc:E900 .

# Multiplex Node: Participates in multiple types of relations
sc:E700 a sc:C4 ;
    rdfs:label "Multiplex Node Eta" ;
    rdfs:comment "A multiplex node involved in multiple types of relations." ;
    sc:R6 sc:E800 ;
    sc:R3 sc:E900 ;
    sc:R4 sc:E100 .

# Connector Node (second): Connects two clusters, different class
sc:E800 a sc:C1 ;
    rdfs:label "Connector Node Theta" ;
    rdfs:comment "A connector node of a different class, linking clusters through different relations." ;
    sc:R3 sc:E900 ;
    sc:R6 sc:E100 ;
    sc:R1 sc:E500 .

# Peripheral Node: Only a few connections, but part of the structure
sc:E900 a sc:C7 ;
    rdfs:label "Peripheral Node Iota" ;
    rdfs:comment "A peripheral node with few connections, but still part of the network structure." ;
    sc:R8 sc:E1000 ;
    sc:R4 sc:E100 ;
    sc:R6 sc:E600 .

# Multiplex Node (second): Multiple relations, different class
sc:E1000 a sc:C8 ;
    rdfs:label "Multiplex Node Kappa" ;
    rdfs:comment "A multiplex node of a different class, participating in several relation types." ;
    sc:R9 sc:E200 ;
    sc:R8 sc:E900 ;
    sc:R1 sc:E300 .

# Additional intermediary node to increase complexity
sc:E710 a sc:C2 ;
    rdfs:label "Intermediary Node Lambda" ;
    rdfs:comment "An intermediary node connecting the hub to the high-degree node." ;
    sc:R5 sc:E200 ;
    sc:R10 sc:E300 .

# Additional intermediary node to increase complexity
sc:E720 a sc:C2 ;
    rdfs:label "Intermediary Node Mu" ;
    rdfs:comment "An intermediary node connecting the high-degree node to the connector node." ;
    sc:R5 sc:E300 ;
    sc:R10 sc:E500 .

# Additional multiplex node
sc:E730 a sc:C9 ;
    rdfs:label "Multiplex Node Nu" ;
    rdfs:comment "A multiplex node connecting to the super node and the peripheral node." ;
    sc:R9 sc:E100, sc:E900 ;
    sc:R2 sc:E710 .

# Additional central node
sc:E740 a sc:C6 ;
    rdfs:label "Central Node Xi" ;
    rdfs:comment "A central node connecting the super node, hub, and high-degree node." ;
    sc:R7 sc:E100, sc:E200, sc:E300 .

# Additional hub node
sc:E750 a sc:C5 ;
    rdfs:label "Hub Node Omicron" ;
    rdfs:comment "A secondary hub node connecting to the central and multiplex nodes." ;
    sc:R9 sc:E740, sc:E730 ;
    sc:R2 sc:E720 .

# Additional connector node
sc:E760 a sc:C4 ;
    rdfs:label "Connector Node Pi" ;
    rdfs:comment "A connector node linking the peripheral node and the intermediary node." ;
    sc:R4 sc:E900 ;
    sc:R3 sc:E710 .

# Additional super node
sc:E770 a sc:C10 ;
    rdfs:label "Super Node Rho" ;
    rdfs:comment "A secondary super node, highly connected to other nodes." ;
    sc:R6 sc:E100, sc:E200, sc:E300, sc:E400, sc:E500, sc:E600, sc:E700, sc:E800, sc:E900, sc:E1000 .

# End of graph.