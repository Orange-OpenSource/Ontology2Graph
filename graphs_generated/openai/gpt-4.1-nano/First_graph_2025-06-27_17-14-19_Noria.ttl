@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/entityHub>
  a noria:ManagedElement, noria:StructuralElement, noria:FunctionalElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, linking multiple entities."@en ;
  noria:elementManagedBy <https://example.com/organization/opsTeam> .

<https://example.com/entityHighDegree>
  a noria:ManagedElement, noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/observable/connectionCount> .

<https://example.com/entityCentral>
  a noria:ManagedElement, noria:FunctionalElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node coordinating multiple services and resources."@en ;
  noria:elementManagedBy <https://example.com/organization/centralOps> .

<https://example.com/entityConnector>
  a noria:ManagedElement, noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/connectionStatus> .

<https://example.com/entityIntermediary>
  a noria:ManagedElement, noria:ProceduralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow between primary nodes."@en ;
  noria:elementManagedBy <https://example.com/organization/intermediateTeam> .

<https://example.com/entityMultiplex>
  a noria:ManagedElement, noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node supporting multiple communication channels."@en ;
  noria:structuralElementObservable <https://example.com/observable/channelUtilization> .

<https://example.com/entitySuper>
  a noria:ManagedElement, noria:StructuralElement, noria:FunctionalElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple sub-nodes for high-level management."@en ;
  noria:elementManagedBy <https://example.com/organization/superOps> .

<https://example.com/organization/opsTeam>
  a org:Organization ;
  rdfs:label "Operations Team"@en ;
  rdfs:comment "The team responsible for managing core network entities."@en .

<https://example.com/organization/centralOps>
  a org:Organization ;
  rdfs:label "Central Operations"@en ;
  rdfs:comment "The central management entity overseeing key nodes."@en .

<https://example.com/organization/intermediateTeam>
  a org:Organization ;
  rdfs:label "Intermediary Management"@en ;
  rdfs:comment "Team managing intermediary nodes."@en .

<https://example.com/organization/superOps>
  a org:Organization ;
  rdfs:label "Super Node Management"@en ;
  rdfs:comment "High-level management of super nodes."@en .

<https://example.com/observable/connectionCount>
  a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of connections associated with a node."@en .

<https://example.com/observable/connectionStatus>
  a noria:Property ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Operational status of the connection."@en .

<https://example.com/observable/channelUtilization>
  a noria:Property ;
  rdfs:label "Channel Utilization"@en ;
  rdfs:comment "Utilization percentage of communication channels."@en .

<https://example.com/observable/connectionUtilization>
  a noria:Property ;
  rdfs:label "Connection Utilization"@en ;
  rdfs:comment "Utilization metrics for network connections."@en .

<https://example.com/Resource1>
  a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A core network resource."@en ;
  noria:locatedAtLocus <https://example.com/locus1> .

<https://example.com/Resource2>
  a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A secondary network resource."@en ;
  noria:locatedAtLocus <https://example.com/locus2> .

<https://example.com/locus1>
  a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Location within Server Room 314."@en .

<https://example.com/locus2>
  a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Location within Data Center A."@en .

<https://example.com/connection1>
  a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber connection between Resource 1 and Resource 2."@en .

<https://example.com/connection2>
  a noria:NetworkLink ;
  rdfs:label "Wireless Link C-D"@en ;
  rdfs:comment "Wireless connection between Resource 3 and Resource 4."@en .

<https://example.com/Resource3>
  a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A virtual server."@en ;
  noria:locatedAtLocus <https://example.com/locus3> .

<https://example.com/Resource4>
  a noria:Resource ;
  rdfs:label "Resource 4"@en ;
  rdfs:comment "A network switch."@en ;
  noria:locatedAtLocus <https://example.com/locus4> .

<https://example.com/locus3>
  a noria:Locus ;
  rdfs:label "Locus 3"@en ;
  rdfs:comment "Data Center B, Rack 5."@en .

<https://example.com/locus4>
  a noria:Locus ;
  rdfs:label "Locus 4"@en ;
  rdfs:comment "Main Switch Room."@en .

<https://example.com/Resource5>
  a noria:Resource ;
  rdfs:label "Resource 5"@en ;
  rdfs:comment "A multiplex node supporting multiple channels."@en ;
  noria:locatedAtLocus <https://example.com/locus5> .

<https://example.com/locus5>
  a noria:Locus ;
  rdfs:label "Locus 5"@en ;
  rdfs:comment "Main Data Center."@en .

<https://example.com/Resource6>
  a noria:Resource ;
  rdfs:label "Resource 6"@en ;
  rdfs:comment "A super node aggregating multiple sub-nodes."@en ;
  noria:locatedAtLocus <https://example.com/locus6> .

<https://example.com/locus6>
  a noria:Locus ;
  rdfs:label "Locus 6"@en ;
  rdfs:comment "High-level aggregation point."@en .

<https://example.com/Resource7>
  a noria:Resource ;
  rdfs:label "Resource 7"@en ;
  rdfs:comment "A connector node linking segments."@en ;
  noria:locatedAtLocus <https://example.com/locus7> .

<https://example.com/locus7>
  a noria:Locus ;
  rdfs:label "Locus 7"@en ;
  rdfs:comment "Intermediate connection point."@en .

<https://example.com/Resource8>
  a noria:Resource ;
  rdfs:label "Resource 8"@en ;
  rdfs:comment "A high-degree node with many links."@en ;
  noria:locatedAtLocus <https://example.com/locus8> .

<https://example.com/locus8>
  a noria:Locus ;
  rdfs:label "Locus 8"@en ;
  rdfs:comment "Critical hub in the core network."@en .

<https://example.com/Resource9>
  a noria:Resource ;
  rdfs:label "Resource 9"@en ;
  rdfs:comment "A super node managing multiple sub-nodes."@en ;
  noria:locatedAtLocus <https://example.com/locus9> .

<https://example.com/locus9>
  a noria:Locus ;
  rdfs:label "Locus 9"@en ;
  rdfs:comment "Top-level aggregation point."@en .

<https://example.com/Resource10>
  a noria:Resource ;
  rdfs:label "Resource 10"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:locatedAtLocus <https://example.com/locus10> .

<https://example.com/locus10>
  a noria:Locus ;
  rdfs:label "Locus 10"@en ;
  rdfs:comment "Intermediate data relay point."@en .

<https://example.com/organization/opsTeam>
  a org:Organization ;
  rdfs:label "Operations Team"@en ;
  rdfs:comment "Core network management team."@en .

<https://example.com/organization/centralOps>
  a org:Organization ;
  rdfs:label "Central Operations"@en ;
  rdfs:comment "Oversees key network nodes."@en .

<https://example.com/organization/intermediateTeam>
  a org:Organization ;
  rdfs:label "Intermediary Management"@en ;
  rdfs:comment "Manages intermediary nodes."@en .

<https://example.com/organization/superOps>
  a org:Organization ;
  rdfs:label "Super Node Management"@en ;
  rdfs:comment "High-level node oversight."@en .