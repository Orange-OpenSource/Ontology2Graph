@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Define Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Hub Node"@en ;
    rdfs:comment "A highly connected node acting as a central hub in the network."@en .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "High-Degree Node"@en ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub."@en .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Central Node"@en ;
    rdfs:comment "A node positioned at the center of a specific cluster or community."@en .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Connector Node"@en ;
    rdfs:comment "A node that connects different clusters or communities."@en .

sc:IntermediaryNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Intermediary Node"@en ;
    rdfs:comment "A node that acts as a bridge in a chain of nodes."@en .

sc:MultiplexNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Multiplex Node"@en ;
    rdfs:comment "A node involved in multiple types of relations."@en .

sc:SuperNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Super Node"@en ;
    rdfs:comment "A node that encompasses multiple nodes or communities."@en .

# Define Entities (Nodes)
sc:E1001 a sc:HubNode ;
    rdfs:label "Hub Node E1001"@en ;
    rdfs:comment "A central hub node with many connections."@en ;
    sc:sc:R1 sc:E1002, sc:E1003, sc:E1004 .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node E1002"@en ;
    rdfs:comment "A node with a high number of relations."@en ;
    sc:sc:R1 sc:E1001, sc:E1005 .

sc:E1003 a sc:CentralNode ;
    rdfs:label "Central Node E1003"@en ;
    rdfs:comment "A node positioned at the center of a cluster."@en ;
    sc:sc:R1 sc:E1001, sc:E1006 .

sc:E1004 a sc:ConnectorNode ;
    rdfs:label "Connector Node E1004"@en ;
    rdfs:comment "Connects different communities."@en ;
    sc:sc:R1 sc:E1001, sc:E1007 .

sc:E1005 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node E1005"@en ;
    rdfs:comment "Bridges a chain of nodes."@en ;
    sc:sc:R1 sc:E1002, sc:E1008 .

sc:E1006 a sc:MultiplexNode ;
    rdfs:label "Multiplex Node E1006"@en ;
    rdfs:comment "Participates in multiple relation types."@en ;
    sc:sc:R1 sc:E1003, sc:E1009 .

sc:E1007 a sc:SuperNode ;
    rdfs:label "Super Node E1007"@en ;
    sc:sc:R1 sc:E1004, sc:E1010 .

sc:E1008 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node E1008"@en ;
    sc:sc:R1 sc:E1005 .

sc:E1009 a sc:CentralNode ;
    rdfs:label "Central Node E1009"@en ;
    sc:sc:R1 sc:E1006 .

sc:E1010 a sc:HubNode ;
    rdfs:label "Hub Node E1010"@en ;
    sc:sc:R1 sc:E1007 .

# Relations (example of different relation types)
sc:R1 a owl:ObjectProperty ;
    rdfs:label "relates to"@en ;
    rdfs:comment "Generic relation between nodes."@en .

