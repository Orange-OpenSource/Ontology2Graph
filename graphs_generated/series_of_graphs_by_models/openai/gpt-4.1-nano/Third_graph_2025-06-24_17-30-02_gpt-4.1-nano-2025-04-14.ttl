@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub Node: Entity with many relations, central in the network
sc:HubNode1 a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Global Hub Node"@en ;
    rdfs:comment "A central node connecting multiple classes and relations."@en ;
    sc:R1 sc:EntityA ;
    sc:R6 sc:EntityB .

# High-Degree Node: Entity with numerous relations
sc:HighDegreeNode a owl:NamedIndividual, sc:C10 ;
    rdfs:label "High Degree Node"@en ;
    rdfs:comment "Node with a high number of relations, acting as a connector."@en ;
    sc:R1 sc:EntityC ;
    sc:R4 sc:EntityD ;
    sc:R6 sc:EntityE ;
    sc:R9 sc:EntityF .

# Central Node: Entity acting as a core within a subgraph
sc:CentralNode a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Central Node"@en ;
    rdfs:comment "A node that acts as a core within a specific class cluster."@en ;
    sc:R1 sc:EntityG ;
    sc:R3 sc:EntityH ;
    sc:R6 sc:EntityI .

# Connector Node: Entity linking two different classes
sc:ConnectorNode a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Connector Node"@en ;
    rdfs:comment "Connects entities across different classes."@en ;
    sc:R2 sc:EntityJ ;
    sc:R4 sc:EntityK .

# Intermediary Node: Entity mediating relations between other nodes
sc:IntermediaryNode a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Intermediary Node"@en ;
    rdfs:comment "Acts as an intermediary in complex relation chains."@en ;
    sc:R3 sc:EntityL ;
    sc:R6 sc:EntityM .

# Multiplex Node: Entity involved in multiple relation types
sc:MultiplexNode a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Multiplex Node"@en ;
    rdfs:comment "Participates in multiple relation types across classes."@en ;
    sc:R1 sc:EntityN ;
    sc:R4 sc:EntityO ;
    sc:R6 sc:EntityP ;
    sc:R9 sc:EntityQ .

# Super Node: Entity representing a superordinate concept
sc:SuperNode a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Super Node"@en ;
    rdfs:comment "A superordinate node encompassing multiple sub-entities."@en ;
    sc:R1 sc:EntityR ;
    sc:R6 sc:EntityS .

# Additional Entities with relations to ensure diversity
sc:EntityA a owl:NamedIndividual, sc:C1 ;
    rdfs:label "Entity A"@en ;
    rdfs:comment "An entity related to the Hub Node."@en ;
    sc:R2 sc:EntityT .

sc:EntityB a owl:NamedIndividual, sc:C2 ;
    rdfs:label "Entity B"@en ;
    rdfs:comment "A high-degree node connected to multiple entities."@en ;
    sc:R3 sc:EntityU .

sc:EntityC a owl:NamedIndividual, sc:C3 ;
    rdfs:label "Entity C"@en ;
    rdfs:comment "A node with relations to the high-degree node."@en ;
    sc:R4 sc:EntityV .

sc:EntityD a owl:NamedIndividual, sc:C4 ;
    rdfs:label "Entity D"@en ;
    sc:R5 sc:EntityW .

sc:EntityE a owl:NamedIndividual, sc:C5 ;
    rdfs:label "Entity E"@en ;
    sc:R7 sc:EntityX .

sc:EntityF a owl:NamedIndividual, sc:C6 ;
    rdfs:label "Entity F"@en ;
    sc:R8 sc:EntityY .

sc:EntityG a owl:NamedIndividual, sc:C7 ;
    rdfs:label "Entity G"@en ;
    sc:R9 sc:EntityZ .

sc:EntityH a owl:NamedIndividual, sc:C8 ;
    rdfs:label "Entity H"@en ;
    sc:R10 sc:EntityAA .

sc:EntityI a owl:NamedIndividual, sc:C9 ;
    rdfs:label "Entity I"@en ;
    sc:R1 sc:EntityAB .

sc:EntityJ a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Entity J"@en ;
    sc:R2 sc:EntityAC .

sc:EntityK a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Entity K"@en ;
    sc:R3 sc:EntityAD .

sc:EntityL a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Entity L"@en ;
    sc:R4 sc:EntityAE .

sc:EntityM a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Entity M"@en ;
    sc:R5 sc:EntityAF .

sc:EntityN a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Entity N"@en ;
    sc:R6 sc:EntityAG .

sc:EntityO a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Entity O"@en ;
    sc:R7 sc:EntityAH .

sc:EntityP a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Entity P"@en ;
    sc:R8 sc:EntityAI .

sc:EntityQ a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Entity Q"@en ;
    sc:R9 sc:EntityAJ .

sc:EntityR a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Entity R"@en ;
    sc:R10 sc:EntityAK .

# Relations (example)
sc:EntityA sc:R2 sc:EntityB .
sc:EntityC sc:R3 sc:EntityD .
sc:EntityE sc:R4 sc:EntityF .
sc:EntityG sc:R5 sc:EntityH .
sc:EntityI sc:R6 sc:EntityJ .
sc:EntityK sc:R7 sc:EntityL .
sc:EntityM sc:R8 sc:EntityN .
sc:EntityO sc:R9 sc:EntityP .
sc:EntityQ sc:R10 sc:EntityR .

# End of graph
