@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@Prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@Prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Entities
sc:E1 a sc:HubNode ;
    rdfs:label "Entity 1" ;
    rdfs:comment "A central hub node with numerous connections." ;
    sc:sc:R1 sc:E2, sc:E3, sc:E4 .

sc:E2 a sc:HighDegreeNode ;
    rdfs:label "Entity 2" ;
    rdfs:comment "A high-degree node connecting to multiple entities." ;
    sc:sc:R1 sc:E1, sc:E5 .

sc:E3 a sc:CentralNode ;
    rdfs:label "Entity 3" ;
    rdfs:comment "A central node with balanced connections." ;
    sc:sc:R1 sc:E1, sc:E6 .

sc:E4 a sc:ConnectorNode ;
    rdfs:label "Entity 4" ;
    rdfs:comment "A connector node bridging different network parts." ;
    sc:sc:R1 sc:E1, sc:E7 .

sc:E5 a sc:IntermediaryNode ;
    rdfs:label "Entity 5" ;
    rdfs:comment "An intermediary node mediating between high-degree nodes." ;
    sc:sc:R1 sc:E2, sc:E8 .

sc:E6 a sc:MultiplexNode ;
    rdfs:label "Entity 6" ;
    rdfs:comment "A multiplex node involved in multiple relation types." ;
    sc:sc:R1 sc:E3, sc:E9 .

sc:E7 a sc:SuperNode ;
    rdfs:label "Entity 7" ;
    rdfs:comment "A super node with extensive influence." ;
    sc:sc:R1 sc:E4, sc:E10 .

sc:E8 a sc:HighDegreeNode ;
    rdfs:label "Entity 8" ;
    rdfs:comment "A high-degree node connected to multiple intermediary nodes." ;
    sc:sc:R1 sc:E5, sc:E11 .

sc:E9 a sc:CentralNode ;
    rdfs:label "Entity 9" ;
    sc:comment "A central node with multiple relations." ;
    sc:sc:R1 sc:E6, sc:E12 .

sc:E10 a sc:ConnectorNode ;
    rdfs:label "Entity 10" ;
    sc:comment "A connector bridging different network segments." ;
    sc:sc:R1 sc:E7, sc:E13 .

sc:E11 a sc:IntermediaryNode ;
    rdfs:label "Entity 11" ;
    sc:comment "An intermediary node facilitating connections." ;
    sc:sc:R1 sc:E8, sc:E14 .

sc:E12 a sc:MultiplexNode ;
    rdfs:label "Entity 12" ;
    sc:comment "A multiplex node involved in multiple relation types." ;
    sc:sc:R1 sc:E9, sc:E15 .

sc:E13 a sc:SuperNode ;
    rdfs:label "Entity 13" ;
    sc:comment "A super node with extensive influence." ;
    sc:sc:R1 sc:E10, sc:E16 .

sc:E14 a sc:HighDegreeNode ;
    rdfs:label "Entity 14" ;
    sc:comment "A high-degree node with multiple connections." ;
    sc:sc:R1 sc:E11, sc:E17 .

sc:E15 a sc:CentralNode ;
    rdfs:label "Entity 15" ;
    sc:comment "A central node with balanced relations." ;
    sc:sc:R1 sc:E12, sc:E18 .

sc:E16 a sc:ConnectorNode ;
    rdfs:label "Entity 16" ;
    sc:comment "A connector node linking different parts." ;
    sc:sc:R1 sc:E13, sc:E19 .

sc:E17 a sc:IntermediaryNode ;
    rdfs:label "Entity 17" ;
    sc:comment "An intermediary node mediating relations." ;
    sc:sc:R1 sc:E14, sc:E20 .

sc:E18 a sc:MultiplexNode ;
    rdfs:label "Entity 18" ;
    sc:comment "A multiplex node involved in multiple relation types." ;
    sc:sc:R1 sc:E15, sc:E21 .

sc:E19 a sc:SuperNode ;
    rdfs:label "Entity 19" ;
    sc:comment "A super node with extensive influence." ;
    sc:sc:R1 sc:E16, sc:E22 .

sc:E20 a sc:HighDegreeNode ;
    rdfs:label "Entity 20" ;
    sc:comment "A high-degree node with multiple connections." ;
    sc:sc:R1 sc:E17, sc:E23 .

sc:E21 a sc:CentralNode ;
    rdfs:label "Entity 21" ;
    sc:comment "A central node with balanced relations." ;
    sc:sc:R1 sc:E18, sc:E24 .

sc:E22 a sc:ConnectorNode ;
    rdfs:label "Entity 22" ;
    sc:comment "A connector bridging different network segments." ;
    sc:sc:R1 sc:E19, sc:E25 .

sc:E23 a sc:IntermediaryNode ;
    rdfs:label "Entity 23" ;
    sc:comment "An intermediary node mediating relations." ;
    sc:sc:R1 sc:E20, sc:E26 .

sc:E24 a sc:MultiplexNode ;
    rdfs:label "Entity 24" ;
    sc:comment "A multiplex node involved in multiple relation types." ;
    sc:sc:R1 sc:E21, sc:E27 .

sc:E25 a sc:SuperNode ;
    rdfs:label "Entity 25" ;
    sc:comment "A super node with extensive influence." ;
    sc:sc:R1 sc:E22, sc:E28 .

# Relations (example)
sc:R1 a owl:ObjectProperty ;
    rdfs:label "relates to" ;
    rdfs:comment "Generic relation connecting entities." .

# Additional relations to create network complexity
sc:E1 sc:R1 sc:E2 .
sc:E2 sc:R1 sc:E3 .
sc:E3 sc:R1 sc:E4 .
sc:E4 sc:R1 sc:E5 .
sc:E5 sc:R1 sc:E6 .
sc:E6 sc:R1 sc:E7 .
sc:E7 sc:R1 sc:E8 .
sc:E8 sc:R1 sc:E9 .
sc:E9 sc:R1 sc:E10 .
sc:E10 sc:R1 sc:E11 .
sc:E11 sc:R1 sc:E12 .
sc:E12 sc:R1 sc:E13 .
sc:E13 sc:R1 sc:E14 .
sc:E14 sc:R1 sc:E15 .
sc:E15 sc:R1 sc:E16 .
sc:E16 sc:R1 sc:E17 .
sc:E17 sc:R1 sc:E18 .
sc:E18 sc:R1 sc:E19 .
sc:E19 sc:R1 sc:E20 .
sc:E20 sc:R1 sc:E21 .
sc:E21 sc:R1 sc:E22 .
sc:E22 sc:R1 sc:E23 .
sc:E23 sc:R1 sc:E24 .
sc:E24 sc:R1 sc:E25 .

# Reflexive and symmetric relations
sc:R1 a owl:ObjectProperty ;
    owl:ReflexiveProperty ;
    owl:SymmetricProperty .

sc:R4 a owl:ObjectProperty ;
    owl:SymmetricProperty .

# Transitive relation example
sc:R6 a owl:ObjectProperty ;
    owl:TransitiveProperty .

# End of graph
