    <!-- http://pygraf.t/CentralNode -->

    <owl:Class rdf:about="http://pygraf.t/CentralNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/C10"/>
        <rdfs:comment xml:lang="en">A node positioned at the center of a specific cluster or community.</rdfs:comment>
        <rdfs:label xml:lang="en">Central Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/ConnectorNode -->

    <owl:Class rdf:about="http://pygraf.t/ConnectorNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/C10"/>
        <rdfs:comment xml:lang="en">A node that connects different clusters or communities.</rdfs:comment>
        <rdfs:label xml:lang="en">Connector Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HighDegreeNode -->

    <owl:Class rdf:about="http://pygraf.t/HighDegreeNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/C10"/>
        <rdfs:comment xml:lang="en">A node with a high number of connections, but not necessarily a hub.</rdfs:comment>
        <rdfs:label xml:lang="en">High-Degree Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HubNode -->

    <owl:Class rdf:about="http://pygraf.t/HubNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/C10"/>
        <rdfs:comment xml:lang="en">A highly connected node acting as a central hub in the network.</rdfs:comment>
        <rdfs:label xml:lang="en">Hub Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/IntermediaryNode -->

    <owl:Class rdf:about="http://pygraf.t/IntermediaryNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/C10"/>
        <rdfs:comment xml:lang="en">A node that acts as a bridge in a chain of nodes.</rdfs:comment>
        <rdfs:label xml:lang="en">Intermediary Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/MultiplexNode -->

    <owl:Class rdf:about="http://pygraf.t/MultiplexNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/C10"/>
        <rdfs:comment xml:lang="en">A node involved in multiple types of relations.</rdfs:comment>
        <rdfs:label xml:lang="en">Multiplex Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/SuperNode -->

    <owl:Class rdf:about="http://pygraf.t/SuperNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/C10"/>
        <rdfs:comment xml:lang="en">A node that encompasses multiple nodes or communities.</rdfs:comment>
        <rdfs:label xml:lang="en">Super Node</rdfs:label>
    </owl:Class>
    


