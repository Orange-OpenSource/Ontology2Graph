        <R9 rdf:resource="http://pygraf.t/E2003"/>
        <R9 rdf:resource="http://pygraf.t/E2007"/>
        <rdfs:comment>A satellite node orbiting the super and central nodes.</rdfs:comment>
        <rdfs:label>Satellite Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2015 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2015">
