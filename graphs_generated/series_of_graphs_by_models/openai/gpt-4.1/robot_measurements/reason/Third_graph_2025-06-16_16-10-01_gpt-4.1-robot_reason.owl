        <R9 rdf:resource="http://pygraf.t/E2013"/>
        <rdfs:comment>A node with both high degree and centrality, connecting to many nodes and acting as a key player.</rdfs:comment>
        <rdfs:label>Super Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2008 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2008">
