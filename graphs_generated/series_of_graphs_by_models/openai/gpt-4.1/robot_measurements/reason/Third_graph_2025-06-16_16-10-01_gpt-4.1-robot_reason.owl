        <R6 rdf:resource="http://pygraf.t/E2010"/>
        <R9 rdf:resource="http://pygraf.t/E2014"/>
        <rdfs:comment>A node representing a subgroup, connected to central and multiplex nodes.</rdfs:comment>
        <rdfs:label>Subgroup Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2013 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2013">
