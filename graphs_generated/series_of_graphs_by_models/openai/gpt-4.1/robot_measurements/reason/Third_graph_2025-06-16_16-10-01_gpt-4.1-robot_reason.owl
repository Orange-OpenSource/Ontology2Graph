        <R6 rdf:resource="http://pygraf.t/E2002"/>
        <rdfs:comment>A node that intermediates between the hub and other nodes, facilitating indirect connections.</rdfs:comment>
        <rdfs:label>Intermediary Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2006 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2006">
