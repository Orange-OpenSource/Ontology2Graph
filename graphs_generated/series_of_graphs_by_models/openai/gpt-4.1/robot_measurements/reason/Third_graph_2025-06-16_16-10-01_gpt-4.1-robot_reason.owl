        <R9 rdf:resource="http://pygraf.t/E2014"/>
        <rdfs:comment>A node that connects several subgroups and acts as a bridge between them.</rdfs:comment>
        <rdfs:label>Central Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2004 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2004">
