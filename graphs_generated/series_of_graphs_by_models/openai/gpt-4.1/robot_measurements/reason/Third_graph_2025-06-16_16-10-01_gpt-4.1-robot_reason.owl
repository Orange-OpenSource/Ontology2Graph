        <R9 rdf:resource="http://pygraf.t/E2013"/>
        <rdfs:comment>A node participating in multiple types of relations and domains.</rdfs:comment>
        <rdfs:label>Multiplex Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2007 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2007">
