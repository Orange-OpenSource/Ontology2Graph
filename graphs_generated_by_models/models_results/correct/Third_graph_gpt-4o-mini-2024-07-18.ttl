@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub Node
sc:E1001 a sc:C10 ;
    rdfs:label "Hub Node E1001" ;
    rdfs:comment "This is a hub node connecting multiple entities." ;
    sc:R1 sc:E1002, sc:E1003, sc:E1004 .

# High-Degree Node
sc:E1002 a sc:C10 ;
    rdfs:label "High-Degree Node E1002" ;
    rdfs:comment "This node has a high number of connections." ;
    sc:R1 sc:E1001, sc:E1005, sc:E1006, sc:E1007 .

# Central Node
sc:E1003 a sc:C10 ;
    rdfs:label "Central Node E1003" ;
    rdfs:comment "This node serves as a central point in the graph." ;
    sc:R1 sc:E1001, sc:E1002, sc:E1008 .

# Connector Node
sc:E1004 a sc:C10 ;
    rdfs:label "Connector Node E1004" ;
    rdfs:comment "This node connects different parts of the graph." ;
    sc:R1 sc:E1001, sc:E1009 .

# Intermediary Node
sc:E1005 a sc:C10 ;
    rdfs:label "Intermediary Node E1005" ;
    rdfs:comment "This node acts as an intermediary between two nodes." ;
    sc:R1 sc:E1002, sc:E1010 .

# Multiplex Node
sc:E1006 a sc:C10 ;
    rdfs:label "Multiplex Node E1006" ;
    rdfs:comment "This node has multiple types of connections." ;
    sc:R1 sc:E1002, sc:E1011 ;
    sc:R4 sc:E1012 .

# Super Node
sc:E1007 a sc:C10 ;
    rdfs:label "Super Node E1007" ;
    rdfs:comment "This node has a super role in the graph." ;
    sc:R1 sc:E1002, sc:E1013, sc:E1014 .

# Additional Nodes
sc:E1008 a sc:C10 ;
    rdfs:label "Node E1008" ;
    rdfs:comment "An additional node connected to the central node." ;
    sc:R1 sc:E1003 .

sc:E1009 a sc:C10 ;
    rdfs:label "Node E1009" ;
    rdfs:comment "An additional node connected to the connector node." ;
    sc:R1 sc:E1004 .

sc:E1010 a sc:C10 ;
    rdfs:label "Node E1010" ;
    rdfs:comment "An additional node connected to the intermediary node." ;
    sc:R1 sc:E1005 .

sc:E1011 a sc:C10 ;
    rdfs:label "Node E1011" ;
    rdfs:comment "An additional node connected to the multiplex node." ;
    sc:R1 sc:E1006 .

sc:E1012 a sc:C10 ;
    rdfs:label "Node E1012" ;
    rdfs:comment "An additional node connected to the multiplex node." ;
    sc:R1 sc:E1006 .

sc:E1013 a sc:C10 ;
    rdfs:label "Node E1013" ;
    rdfs:comment "An additional node connected to the super node." ;
    sc:R1 sc:E1007 .

sc:E1014 a sc:C10 ;
    rdfs:label "Node E1014" ;
    rdfs:comment "An additional node connected to the super node." ;
    sc:R1 sc:E1007 .
