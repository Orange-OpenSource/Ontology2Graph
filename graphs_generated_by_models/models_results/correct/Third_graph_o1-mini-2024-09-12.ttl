@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub Node: Central point connecting multiple entities
sc:HubNode a sc:C10 ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A central hub connecting multiple entities in the knowledge graph." ;
    sc:R1 sc:EntityA, sc:EntityB, sc:EntityC .

# Entity A: Connected directly to the Hub Node
sc:EntityA a sc:C4 ;
    rdfs:label "Entity A" ;
    rdfs:comment "An entity directly connected to the Hub Node." ;
    sc:R4 sc:HubNode .

# Entity B: Connected directly to the Hub Node
sc:EntityB a sc:C4 ;
    rdfs:label "Entity B" ;
    rdfs:comment "Another entity directly connected to the Hub Node." ;
    sc:R6 sc:HubNode .

# Entity C: Connected directly to the Hub Node and acting as a connector
sc:EntityC a sc:C3 ;
    rdfs:label "Entity C" ;
    rdfs:comment "An entity connected to the Hub Node, acting as a connector to other nodes." ;
    sc:R4 sc:ConnectorNode .

# Connector Node: Bridges Hub Node with other clusters
sc:ConnectorNode a sc:C1 ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that bridges the Hub Node with other clusters within the knowledge graph." ;
    sc:R2 sc:Cluster1, sc:Cluster2 .

# Cluster 1: Represents a group of related entities
sc:Cluster1 a sc:C2 ;
    rdfs:label "Cluster 1" ;
    rdfs:comment "A cluster of entities related through various relationships." ;
    sc:R5 sc:EntityD, sc:EntityE .

# Cluster 2: Another group of related entities
sc:Cluster2 a sc:C2 ;
    rdfs:label "Cluster 2" ;
    rdfs:comment "Another cluster of entities interconnected through multiple relationships." ;
    sc:R5 sc:EntityF, sc:EntityG .

# Entity D: Part of Cluster 1, connected to multiple nodes
sc:EntityD a sc:C10 ;
    rdfs:label "Entity D" ;
    rdfs:comment "A high-degree node within Cluster 1, connected to multiple entities." ;
    sc:R6 sc:HubNode, sc:EntityE .

# Entity E: Part of Cluster 1, connected to Entity D and Entity F
sc:EntityE a sc:C10 ;
    rdfs:label "Entity E" ;
    rdfs:comment "A central node in Cluster 1, linking to Entity D and Cluster 2." ;
    sc:R6 sc:EntityD, sc:EntityF .

# Entity F: Part of Cluster 2, connected to Entity E and Entity G
sc:EntityF a sc:C10 ;
    rdfs:label "Entity F" ;
    rdfs:comment "An intermediary node in Cluster 2, connecting Cluster 1 and Cluster 2." ;
    sc:R6 sc:EntityE, sc:EntityG .

# Entity G: Part of Cluster 2, connected to Entity F and Hub Node
sc:EntityG a sc:C10 ;
    rdfs:label "Entity G" ;
    rdfs:comment "A super node in Cluster 2 with extensive connections." ;
    sc:R6 sc:EntityF, sc:HubNode .

# Multiplex Node: Handles multiple types of relationships
sc:MultiplexNode a sc:C7 ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node that manages multiple types of relationships, acting as a central connector." ;
    sc:R3 sc:ConnectorNode, sc:Cluster1, sc:Cluster2 .

# Super Node: Highly connected node with extensive relationships
sc:SuperNode a sc:C8 ;
    rdfs:label "Super Node" ;
    rdfs:comment "A super node with a high degree of connectivity, acting as a pivotal point in the knowledge graph." ;
    sc:R9 sc:HubNode, sc:MultiplexNode .
