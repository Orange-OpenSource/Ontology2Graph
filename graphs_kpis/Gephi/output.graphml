  <rdf:Description rdf:about="http://example.com/TeamZeta">
    <rdf:type rdf:resource="http://www.w3.org/ns/org#OrganizationalUnit"/>
    <rdfs:label>Team Zeta</rdfs:label>
    <rdfs:comment>Support team for Reporting Application - Production.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.com/ApplicationA">
    <rdf:type rdf:resource="https://w3id.org/noria/ontology/Application"/>
    <rdfs:label>Central Application</rdfs:label>
    <rdfs:comment>A core application providing essential services.</rdfs:comment>
    <noria:applicationModelIdentifier>APP-001</noria:applicationModelIdentifier>
    <noria:applicationShortIdentifier>CentralApp</noria:applicationShortIdentifier>
    <noria:applicationType rdf:resource="https://w3id.org/noria/kos/application/type/core"/>
    <noria:applicationBusinessImportance rdf:resource="https://w3id.org/noria/kos/application/business-importance/high"/>
    <noria:applicationFunctionalDomain>Core Services</noria:applicationFunctionalDomain>
    <noria:applicationFunctionalSubDomain>Centralized Data Processing</noria:applicationFunctionalSubDomain>
    <seas:subSystemOf rdf:resource="http://example.com/ServiceX"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.com/TeamBeta">
    <rdf:type rdf:resource="http://www.w3.org/ns/org#OrganizationalUnit"/>
