@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

sc:HubNode a sc:C10 ;
    rdfs:label "Central Hub" ;
    rdfs:comment "A highly connected node central to the graph";
    sc:R1 sc:HighDegreeNode, sc:ConnectorNode ;
    sc:R6 sc:IntermediaryNode.

sc:HighDegreeNode a sc:C9 ;
    rdfs:label "High-Degree Node";
    rdfs:comment "Node with many connections";
    sc:R1 sc:HubNode, sc:CentralNode ;
    sc:R4 sc:ConnectorNode ;
    sc:R9 sc:MultiplexNode.

sc:CentralNode a sc:C4 ;
    rdfs:label "Central Node";
    rdfs:comment "Important node, highly central in the graph";
    sc:R1 sc:HighDegreeNode, sc:SuperNode ;
    sc:R4 sc:HubNode ;
    sc:R6 sc:MultiplexNode.

sc:ConnectorNode a sc:C3 ;
    rdfs:label "Connector Node";
    rdfs:comment "Connects different clusters in the graph";
    sc:R1 sc:HubNode, sc:IntermediaryNode ;
    sc:R4 sc:HighDegreeNode ;
    sc:R2 sc:SuperNode.

sc:IntermediaryNode a sc:C1 ;
    rdfs:label "Intermediary Node";
    rdfs:comment "Node bridging two other nodes";
    sc:R1 sc:ConnectorNode ;
    sc:R3 sc:HubNode ;
    sc:R6 sc:HubNode.

sc:MultiplexNode a sc:C2 ;
    rdfs:label "Multiplex Node";
    rdfs:comment "Node involved in multiple types of relationships";
    sc:R1 sc:HighDegreeNode ;
    sc:R9 sc:HighDegreeNode ;
    sc:R10 sc:SuperNode.

sc:SuperNode a sc:C8 ;
    rdfs:label "Super Node";
    rdfs:comment "A node with high centrality and influence";
    sc:R1 sc:CentralNode ;
    sc:R3 sc:ConnectorNode ;
    sc:R7 sc:MultiplexNode.

sc:AnotherNode a sc:C7;
    rdfs:label "Another Node";
    rdfs:comment "Example of a node in class C7";
    sc:R8 sc:SuperNode.

sc:YetAnotherNode a sc:C5;
    rdfs:label "Yet Another Node";
    rdfs:comment "Example of a node in class C5";
    sc:R6 sc:SuperNode.

sc:LastNode a sc:C6;
    rdfs:label "Last Node";
    rdfs:comment "Example of a node in class C6";
    sc:R10 sc:MultiplexNode.

