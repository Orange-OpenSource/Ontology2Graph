@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Define Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub." .

sc:CentralNode a owl:Class ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that is central within a specific subgraph or community." .

sc:ConnectorNode a owl:Class ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different communities or subgraphs." .

sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as a bridge between two other nodes or groups." .

sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations or layers." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "An overarching node that encompasses multiple nodes or communities." .

# Define Object Properties
sc:connects a owl:ObjectProperty ;
    rdfs:label "connects" ;
    rdfs:comment "Relation indicating a connection between two nodes." .

sc:relatesTo a owl:ObjectProperty ;
    rdfs:label "relates to" ;
    rdfs:comment "Generic relation indicating a relation between entities." .

sc:bridges a owl:ObjectProperty ;
    rdfs:domain sc:ConnectorNode ;
    rdfs:range sc:IntermediaryNode ;
    rdfs:label "bridges" ;
    rdfs:comment "Relation indicating a bridging role of a connector node." .

sc:partOf a owl:ObjectProperty ;
    rdfs:label "part of" ;
    rdfs:comment "Indicates membership of a node within a community or group." .

sc:hasRelation a owl:ObjectProperty ;
    rdfs:label "has relation" ;
    rdfs:comment "Relation indicating a multiplex or layered relation." .

# Define Entities (Nodes)
sc:EntityHub a sc:HubNode ;
    rdfs:label "Entity Hub" ;
    rdfs:comment "A hub node with multiple connections to various entities." ;
    sc:connects sc:EntityA, sc:EntityB, sc:EntityC, sc:EntityD .

sc:EntityA a sc:HighDegreeNode ;
    rdfs:label "Entity A" ;
    rdfs:comment "A high-degree node connected to multiple entities." ;
    sc:connects sc:EntityHub, sc:EntityB, sc:EntityC .

sc:EntityB a sc:CentralNode ;
    rdfs:label "Entity B" ;
    rdfs:comment "A central node within a subgraph." ;
    sc:connects sc:EntityA, sc:EntityC, sc:EntityD .

sc:EntityC a sc:ConnectorNode ;
    rdfs:label "Entity C" ;
    rdfs:comment "A connector node linking different parts of the graph." ;
    sc:connects sc:EntityA, sc:EntityB, sc:EntityE ;
    sc:bridges sc:EntityC .

sc:EntityD a sc:IntermediaryNode ;
    rdfs:label "Entity D" ;
    rdfs:comment "An intermediary node bridging EntityA and EntityB." ;
    sc:connects sc:EntityA, sc:EntityB .

sc:EntityE a sc:MultiplexNode ;
    rdfs:label "Entity E" ;
    rdfs:comment "A multiplex node involved in multiple relation types." ;
    sc:connects sc:EntityC, sc:EntityF, sc:EntityG ;
    sc:hasRelation sc:Relation1, sc:Relation2 .

sc:EntityF a sc:SuperNode ;
    rdfs:label "Entity F" ;
    rdfs:comment "A super node representing a large community or layer." ;
    sc:connects sc:EntityE .

sc:EntityG a sc:HighDegreeNode ;
    rdfs:label "Entity G" ;
    rdfs:comment "Another high-degree node connected to EntityE." ;
    sc:connects sc:EntityE, sc:EntityH .

sc:EntityH a sc:CentralNode ;
    rdfs:label "Entity H" ;
    rdfs:comment "A central node within a subgraph." ;
    sc:connects sc:EntityG .

# Additional relations to create diversity
sc:EntityI a sc:IntermediaryNode ;
    rdfs:label "Entity I" ;
    rdfs:comment "An intermediary node connecting EntityF and EntityG." ;
    sc:connects sc:EntityF, sc:EntityG .

sc:EntityJ a sc:ConnectorNode ;
    rdfs:label "Entity J" ;
    rdfs:comment "A connector node linking EntityH and EntityI." ;
    sc:connects sc:EntityH, sc:EntityI ;
    sc:bridges sc:EntityJ .

# Multiplex relations
sc:Relation1 a owl:ObjectProperty ;
    rdfs:label "Relation 1" ;
    rdfs:comment "A multiplex relation involving multiple nodes." .

sc:Relation2 a owl:ObjectProperty ;
    rdfs:label "Relation 2" ;
    rdfs:comment "Another multiplex relation." .

# Nodes with multiple relations (multiplex)
sc:EntityK a sc:MultiplexNode ;
    rdfs:label "Entity K" ;
    rdfs:comment "A multiplex node with relations to EntityJ and EntityE." ;
    sc:connects sc:EntityJ, sc:EntityE ;
    sc:hasRelation sc:Relation1, sc:Relation2 .

# Nodes with high degree but not hubs
sc:EntityL a sc:HighDegreeNode ;
    rdfs:label "Entity L" ;
    rdfs:comment "A high-degree node with several connections." ;
    sc:connects sc:EntityH, sc:EntityG, sc:EntityJ .

# Nodes acting as super connectors
sc:EntityM a sc:SuperNode ;
    rdfs:label "Entity M" ;
    rdfs:comment "A super node connecting multiple communities." ;
    sc:connects sc:EntityF, sc:EntityK, sc:EntityL .

# End of graph
