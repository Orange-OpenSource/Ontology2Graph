@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub Node: Entity that connects to many others
sc:HubNode a owl:Class ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A central entity with multiple relations to various nodes." .

sc:E1001 a sc:HubNode ;
    rdfs:label "Global Network Hub" ;
    rdfs:comment "A super connector linking multiple classes and entities." .

# High-degree Node: Entity with many relations
sc:HighDegreeNode a owl:Class ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "An entity with a high number of relations." .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "Major Actor" ;
    rdfs:comment "A prominent actor involved in numerous relations." .

# Central Node: Entity that acts as a core within a subgroup
sc:CentralNode a owl:Class ;
    rdfs:label "Central Node" ;
    rdfs:comment "A key entity within a specific subgroup." .

sc:E1003 a sc:CentralNode ;
    rdfs:label "Core Module" ;
    rdfs:comment "A central module connecting related components." .

# Connector Node: Entity that links two different classes
sc:ConnectorNode a owl:Class ;
    rdfs:label "Connector Node" ;
    rdfs:comment "An entity that connects two distinct classes." .

sc:E1004 a sc:ConnectorNode ;
    rdfs:label "Bridge Entity" ;
    rdfs:comment "Acts as a bridge between class A and class B." .

# Intermediary Node: Entity that mediates relations
sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "Mediates relations between other entities." .

sc:E1005 a sc:IntermediaryNode ;
    rdfs:label "Mediator Entity" ;
    rdfs:comment "Facilitates interactions between different nodes." .

# Multiplex Node: Entity involved in multiple relation types
sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "Participates in multiple relation types." .

sc:E1006 a sc:MultiplexNode ;
    rdfs:label "Multi-role Entity" ;
    rdfs:comment "Engages in various relation types across classes." .

# Super Node: Entity that encompasses multiple classes
sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A high-level entity integrating multiple classes." .

sc:E1007 a sc:SuperNode ;
    rdfs:label "Composite Entity" ;
    rdfs:comment "Represents an aggregate of several classes." .

# Entities based on schema classes
sc:E2001 a sc:C1 ;
    rdfs:label "Entity of Class C1" ;
    rdfs:comment "A specific instance of class C1." .

sc:E2002 a sc:C4 ;
    rdfs:label "Entity of Class C4" ;
    rdfs:comment "A specific instance of class C4." .

sc:E2003 a sc:C10 ;
    rdfs:label "Entity of Class C10" ;
    rdfs:comment "A specific instance of class C10." .

# Relations between entities
sc:E1001 sc:R6 sc:E2003 ; # Hub node connected to a C10 entity
    rdfs:label "connects to" ;
    rdfs:comment "Relation indicating connection to a C10 entity." .

sc:E1002 sc:R4 sc:E2002 ; # High-degree node linking to C4
    rdfs:label "links with" ;
    rdfs:comment "Relation indicating a link with a C4 entity." .

sc:E1003 sc:R3 sc:E2001 ; # Central node linking to C1
    rdfs:label "relates to" ;
    rdfs:comment "Relation indicating relation to a C1 entity." .

sc:E1004 sc:R7 sc:E2002 ; # Connector node bridging C4 and C10
    rdfs:label "bridges" ;
    rdfs:comment "Relation indicating bridging between C4 and C10 entities." .

sc:E1005 sc:R5 sc:E2003 ; # Intermediary node mediating between C10 entities
    rdfs:label "mediates" ;
    rdfs:comment "Relation indicating mediation role." .

sc:E1006 sc:R10 sc:E2002 ; # Multiplex node connected to C4
    rdfs:label "participates in" ;
    rdfs:comment "Relation indicating participation in multiple relation types." .

sc:E1007 sc:R6 sc:E2001 ; # Super node encompassing C1
    rdfs:label "encompasses" ;
    rdfs:comment "Relation indicating inclusion of a C1 entity." .

# Additional relations to create a diverse graph
sc:E2002 sc:R9 sc:E2003 ; # Symmetric relation within C10 entities
    rdfs:label "interacts with" ;
    rdfs:comment "Symmetric relation indicating mutual interaction." .

sc:E2004 a sc:C2 ;
    rdfs:label "Entity of Class C2" ;
    rdfs:comment "A specific instance of class C2." .

sc:E2005 a sc:C3 ;
    rdfs:label "Entity of Class C3" ;
    rdfs:comment "A specific instance of class C3." .

sc:E2004 sc:R2 sc:E2005 ; # Relation between C2 and C3
    rdfs:label "relates to" ;
    rdfs:comment "Relation indicating a connection between C2 and C3 entities." .

sc:E2005 sc:R4 sc:E2004 ; # Inverse relation
    rdfs:label "related by" ;
    rdfs:comment "Inverse relation to 'relates to'." .

# Creating a small subgraph with different node types
sc:E2010 a sc:HubNode ;
    rdfs:label "Subgraph Hub" ;
    rdfs:comment "A hub node within a subgraph." .

sc:E2011 a sc:HighDegreeNode ;
    rdfs:label "Subgraph High-Degree" ;
    rdfs:comment "A high-degree node within a subgraph." .

sc:E2012 a sc:ConnectorNode ;
    rdfs:label "Subgraph Connector" ;
    rdfs:comment "Connector node linking subgraph entities." .

sc:E2010 sc:R6 sc:E2011 ;
    rdfs:label "connects to" ;
    rdfs:comment "Relation indicating connection within subgraph." .

sc:E2011 sc:R4 sc:E2012 ;
    rdfs:label "links" ;
    rdfs:comment "Relation linking connector to high-degree node." .

sc:E2012 sc:R3 sc:E2005 ;
    rdfs:label "relates to" ;
    rdfs:comment "Relation linking connector to a class C3 entity." .

# End of generated knowledge graph in Turtle format respecting the schema and node types.