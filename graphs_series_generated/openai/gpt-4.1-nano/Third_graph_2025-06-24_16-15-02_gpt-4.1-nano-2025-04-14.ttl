@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that acts as a key connector within the network." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different parts of the network." .

sc:IntermediaryNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that mediates connections between other nodes." .

sc:MultiplexNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations or layers." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A super node with extensive connections across the network." .

# Entities
sc:E1 a sc:HubNode ;
    rdfs:label "Entity 1" ;
    rdfs:comment "A central hub node with many connections." ;
    sc:R6 sc:E2 ;
    sc:R6 sc:E3 .

sc:E2 a sc:HighDegreeNode ;
    rdfs:label "Entity 2" ;
    rdfs:comment "A high-degree node connected to multiple entities." ;
    sc:R6 sc:E4 ;
    sc:R6 sc:E5 .

sc:E3 a sc:CentralNode ;
    rdfs:label "Entity 3" ;
    rdfs:comment "A key connector node linking different parts of the network." ;
    sc:R6 sc:E6 .

sc:E4 a sc:ConnectorNode ;
    rdfs:label "Entity 4" ;
    rdfs:comment "A connector node bridging sub-networks." ;
    sc:R6 sc:E7 .

sc:E5 a sc:IntermediaryNode ;
    rdfs:label "Entity 5" ;
    rdfs:comment "An intermediary node mediating relations." ;
    sc:R6 sc:E8 .

sc:E6 a sc:MultiplexNode ;
    rdfs:label "Entity 6" ;
    rdfs:comment "A multiplex node involved in multiple relation types." ;
    sc:R6 sc:E9 .

sc:E7 a sc:SuperNode ;
    rdfs:label "Entity 7" ;
    rdfs:comment "A super node with extensive network reach." ;
    sc:R6 sc:E10 .

sc:E8 a sc:HighDegreeNode ;
    rdfs:label "Entity 8" ;
    rdfs:comment "A high-degree node with multiple connections." ;
    sc:R6 sc:E11 .

sc:E9 a sc:CentralNode ;
    rdfs:label "Entity 9" ;
    rdfs:comment "A central node connecting various sub-networks." ;
    sc:R6 sc:E12 .

sc:E10 a sc:IntermediaryNode ;
    rdfs:label "Entity 10" ;
    sc:R6 sc:E13 .

sc:E11 a sc:MultiplexNode ;
    rdfs:label "Entity 11" ;
    rdfs:comment "A multiplex node involved in layered relations." ;
    sc:R6 sc:E14 .

sc:E12 a sc:SuperNode ;
    rdfs:label "Entity 12" ;
    rdfs:comment "A super node with broad network influence." ;
    sc:R6 sc:E15 .

# Relations (examples)
sc:R6 a owl:ObjectProperty ;
    rdfs:label "connects to" ;
    rdfs:comment "Relation indicating connection between entities." .

# Additional relations to create a diverse graph
sc:E1 sc:R6 sc:E4 .
sc:E2 sc:R6 sc:E5 .
sc:E3 sc:R6 sc:E6 .
sc:E4 sc:R6 sc:E7 .
sc:E5 sc:R6 sc:E8 .
sc:E6 sc:R6 sc:E9 .
sc:E7 sc:R6 sc:E10 .
sc:E8 sc:R6 sc:E11 .
sc:E9 sc:R6 sc:E12 .
sc:E10 sc:R6 sc:E13 .
sc:E11 sc:R6 sc:E14 .
sc:E12 sc:R6 sc:E15 .

# End of graph
