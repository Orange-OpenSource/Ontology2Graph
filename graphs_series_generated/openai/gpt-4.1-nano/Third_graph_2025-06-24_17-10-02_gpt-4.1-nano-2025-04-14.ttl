@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Define Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Hub Node"@en ;
    rdfs:comment "A node with high connectivity acting as a central hub in the network."@en .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "High-Degree Node"@en ;
    rdfs:comment "A node with a high number of relations, indicating significant influence."@en .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Central Node"@en ;
    rdfs:comment "A node positioned at the center of the network topology."@en .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Connector Node"@en ;
    rdfs:comment "A node that connects different parts of the network."@en .

sc:IntermediaryNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Intermediary Node"@en ;
    rdfs:comment "A node that acts as a bridge between other nodes."@en .

sc:MultiplexNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Multiplex Node"@en ;
    rdfs:comment "A node involved in multiple types of relations."@en .

sc:SuperNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Super Node"@en ;
    rdfs:comment "An overarching node that encompasses multiple nodes or classes."@en .

# Define Entities
sc:E1001 a sc:HubNode ;
    rdfs:label "Hub Entity 1"@en ;
    rdfs:comment "A hub node with extensive relations."@en ;
    sc:sc:R1 sc:E1002, sc:E1003 ;
    sc:sc:R2 sc:E1004 .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "High Degree Entity 2"@en ;
    rdfs:comment "A high-degree node connected to multiple entities."@en ;
    sc:sc:R3 sc:E1005 .

sc:E1003 a sc:CentralNode ;
    rdfs:label "Central Entity 3"@en ;
    rdfs:comment "A central node in the network."@en ;
    sc:sc:R4 sc:E1006 .

sc:E1004 a sc:ConnectorNode ;
    rdfs:label "Connector Entity 4"@en ;
    rdfs:comment "Connects different network segments."@en ;
    sc:sc:R5 sc:E1007 .

sc:E1005 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Entity 5"@en ;
    rdfs:comment "Acts as a bridge between nodes."@en ;
    sc:sc:R6 sc:E1008 .

sc:E1006 a sc:MultiplexNode ;
    rdfs:label "Multiplex Entity 6"@en ;
    rdfs:comment "Participates in multiple relation types."@en ;
    sc:sc:R7 sc:E1009 .

sc:E1007 a sc:SuperNode ;
    rdfs:label "Super Entity 7"@en ;
    rdfs:comment "Encompasses multiple nodes."@en ;
    sc:sc:R8 sc:E1010 .

# Relations between entities
sc:E1001 sc:sc:R1 sc:E1002 ;
    sc:sc:R2 sc:E1003 .

sc:E1002 sc:sc:R3 sc:E1004 .

sc:E1003 sc:sc:R4 sc:E1005 .

sc:E1004 sc:sc:R5 sc:E1006 .

sc:E1005 sc:sc:R6 sc:E1007 .

sc:E1006 sc:sc:R7 sc:E1008 .

sc:E1007 sc:sc:R8 sc:E1009 .

sc:E1008 sc:sc:R9 sc:E1010 .

# Additional nodes to ensure diversity
sc:E1011 a sc:HighDegreeNode ;
    rdfs:label "High Degree Entity 11"@en ;
    rdfs:comment "Another high-degree node."@en ;
    sc:sc:R1 sc:E1012 .

sc:E1012 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Entity 12"@en ;
    rdfs:comment "Acts as a bridge in a different network segment."@en ;
    sc:sc:R2 sc:E1013 .

sc:E1013 a sc:ConnectorNode ;
    rdfs:label "Connector Entity 13"@en ;
    rdfs:comment "Connects to multiple multiplex nodes."@en ;
    sc:sc:R3 sc:E1014 .

sc:E1014 a sc:MultiplexNode ;
    rdfs:label "Multiplex Entity 14"@en ;
    rdfs:comment "Participates in various relation types."@en ;
    sc:sc:R4 sc:E1015 .

sc:E1015 a sc:SuperNode ;
    rdfs:label "Super Entity 15"@en ;
    rdfs:comment "A super node representing a large network component."@en .

