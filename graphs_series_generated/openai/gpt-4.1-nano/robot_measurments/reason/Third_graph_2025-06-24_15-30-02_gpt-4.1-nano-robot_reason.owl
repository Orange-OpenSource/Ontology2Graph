    <owl:Class rdf:about="http://pygraf.t/MultiplexNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/C10"/>
        <rdfs:comment>A node participating in various relation types, representing complex interactions.</rdfs:comment>
