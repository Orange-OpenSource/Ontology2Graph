@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# --- HUB NODE ---
sc:E2000 a sc:C9 ;
    rdfs:label "Central Hub Node" ;
    rdfs:comment "A hub node with high connectivity, acting as a central point for multiple classes." ;
    sc:R2 sc:E2001, sc:E2002, sc:E2003 ;
    sc:R4 sc:E2010, sc:E2020, sc:E2030 ;
    sc:R9 sc:E2100, sc:E2200, sc:E2300 .

# --- HIGH-DEGREE NODE ---
sc:E2001 a sc:C2 ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with many incoming and outgoing relations, representing a highly connected entity." ;
    sc:R10 sc:E2004, sc:E2005 ;
    sc:R5 sc:E2000, sc:E2020, sc:E2100 ;
    sc:R6 sc:E2040 .

# --- CENTRAL NODE ---
sc:E2002 a sc:C2 ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that connects several subgraphs, acting as a bridge between them." ;
    sc:R10 sc:E2006 ;
    sc:R5 sc:E2000, sc:E2030 ;
    sc:R6 sc:E2050 .

# --- CONNECTOR NODE ---
sc:E2003 a sc:C2 ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that links two otherwise separate clusters." ;
    sc:R10 sc:E2007 ;
    sc:R5 sc:E2000, sc:E2010 ;
    sc:R6 sc:E2060 .

# --- MULTIPLEX NODE ---
sc:E2004 a sc:C6 ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node that participates in multiple types of relations and classes." ;
    sc:R7 sc:E2001, sc:E2002, sc:E2003 ;
    sc:R6 sc:E2070 ;
    sc:R9 sc:E2100 .

# --- INTERMEDIARY NODE ---
sc:E2005 a sc:C6 ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that serves as an intermediary in transitive relations." ;
    sc:R7 sc:E2001, sc:E2004 ;
    sc:R6 sc:E2080 .

# --- SUPER NODE ---
sc:E2006 a sc:C6 ;
    rdfs:label "Super Node" ;
    rdfs:comment "A node with the highest degree, connecting to all major clusters and acting as a super-hub." ;
    sc:R7 sc:E2002, sc:E2004, sc:E2005, sc:E2007 ;
    sc:R6 sc:E2090 ;
    sc:R9 sc:E2200, sc:E2300 .

# --- CONNECTOR NODE 2 ---
sc:E2007 a sc:C6 ;
    rdfs:label "Connector Node 2" ;
    rdfs:comment "A secondary connector node linking the super node and other clusters." ;
    sc:R7 sc:E2003, sc:E2006 ;
    sc:R6 sc:E2100 .

# --- CLASS C4 NODE ---
sc:E2010 a sc:C4 ;
    rdfs:label "C4 Node" ;
    rdfs:comment "A node of class C4, connected to the hub and other C4 nodes." ;
    sc:R4 sc:E2000, sc:E2020 ;
    sc:R6 sc:E2110 .

sc:E2020 a sc:C4 ;
    rdfs:label "C4 Node 2" ;
    rdfs:comment "Another node of class C4, forming a symmetric relation with E2010." ;
    sc:R4 sc:E2010, sc:E2000 ;
    sc:R6 sc:E2120 .

sc:E2030 a sc:C4 ;
    rdfs:label "C4 Node 3" ;
    rdfs:comment "A third C4 node, connected to the hub and central node." ;
    sc:R4 sc:E2000 ;
    sc:R6 sc:E2130 .

# --- CLASS C10 NODES ---
sc:E2040 a sc:C10 ;
    rdfs:label "C10 Node A" ;
    rdfs:comment "A C10 node connected to the high-degree node." ;
    sc:R6 sc:E2001, sc:E2050 .

sc:E2050 a sc:C10 ;
    rdfs:label "C10 Node B" ;
    rdfs:comment "A C10 node connected to the central node and C10 Node A." ;
    sc:R6 sc:E2002, sc:E2040 .

sc:E2060 a sc:C10 ;
    rdfs:label "C10 Node C" ;
    rdfs:comment "A C10 node connected to the connector node." ;
    sc:R6 sc:E2003 .

sc:E2070 a sc:C10 ;
    rdfs:label "C10 Node D" ;
    rdfs:comment "A C10 node connected to the multiplex node." ;
    sc:R6 sc:E2004 .

sc:E2080 a sc:C10 ;
    rdfs:label "C10 Node E" ;
    rdfs:comment "A C10 node connected to the intermediary node." ;
    sc:R6 sc:E2005 .

sc:E2090 a sc:C10 ;
    rdfs:label "C10 Node F" ;
    rdfs:comment "A C10 node connected to the super node." ;
    sc:R6 sc:E2006 .

# --- CLASS C9 NODES (for R9) ---
sc:E2100 a sc:C9 ;
    rdfs:label "C9 Node Alpha" ;
    rdfs:comment "A C9 node connected to the hub and multiplex node via R9." ;
    sc:R9 sc:E2000, sc:E2004 .

sc:E2200 a sc:C9 ;
    rdfs:label "C9 Node Beta" ;
    rdfs:comment "A C9 node connected to the hub and super node via R9." ;
    sc:R9 sc:E2000, sc:E2006 .

sc:E2300 a sc:C9 ;
    rdfs:label "C9 Node Gamma" ;
    rdfs:comment "A C9 node connected to the hub and super node via R9." ;
    sc:R9 sc:E2000, sc:E2006 .

# --- CLASS C10 NODES (for R6) ---
sc:E2110 a sc:C10 ;
    rdfs:label "C10 Node G" ;
    rdfs:comment "A C10 node connected to C4 Node E2010." ;
    sc:R6 sc:E2010 .

sc:E2120 a sc:C10 ;
    rdfs:label "C10 Node H" ;
    rdfs:comment "A C10 node connected to C4 Node E2020." ;
    sc:R6 sc:E2020 .

sc:E2130 a sc:C10 ;
    rdfs:label "C10 Node I" ;
    rdfs:comment "A C10 node connected to C4 Node E2030." ;
    sc:R6 sc:E2030 .

# --- CLASS C1 NODE ---
sc:E2140 a sc:C1 ;
    rdfs:label "C1 Node" ;
    rdfs:comment "A C1 node connected to the high-degree node and a C10 node." ;
    sc:R3 sc:E2001 ;
    sc:R6 sc:E2040 .

# --- CLASS C3 NODE ---
sc:E2150 a sc:C3 ;
    rdfs:label "C3 Node" ;
    rdfs:comment "A C3 node connected to the central node and a C10 node." ;
    sc:R3 sc:E2002 ;
    sc:R6 sc:E2050 .

# --- CLASS C5 NODE ---
sc:E2160 a sc:C5 ;
    rdfs:label "C5 Node" ;
    rdfs:comment "A C5 node connected to the hub and a C9 node." ;
    sc:R2 sc:E2000 ;
    sc:R9 sc:E2100 .

# --- CLASS C7 NODE ---
sc:E2170 a sc:C7 ;
    rdfs:label "C7 Node" ;
    rdfs:comment "A C7 node connected to a C5 node and a C10 node." ;
    sc:R8 sc:E2160 ;
    sc:R6 sc:E2040 .

# --- CLASS C8 NODE ---
sc:E2180 a sc:C8 ;
    rdfs:label "C8 Node" ;
    rdfs:comment "A C8 node connected to a C9 node and a C10 node." ;
    sc:R4 sc:E2100 ;
    sc:R6 sc:E2050 .

# --- CLASS C6 NODE ---
sc:E2190 a sc:C6 ;
    rdfs:label "C6 Node" ;
    rdfs:comment "A C6 node connected to a C2 node and a C10 node." ;
    sc:R7 sc:E2001 ;
    sc:R6 sc:E2090 .

# --- CLASS C1 NODE 2 ---
sc:E2201 a sc:C1 ;
    rdfs:label "C1 Node 2" ;
    rdfs:comment "A C1 node connected to the connector node and a C10 node." ;
    sc:R3 sc:E2003 ;
    sc:R6 sc:E2060 .

# --- CLASS C3 NODE 2 ---
sc:E2202 a sc:C3 ;
    rdfs:label "C3 Node 2" ;
    rdfs:comment "A C3 node connected to the multiplex node and a C10 node." ;
    sc:R3 sc:E2004 ;
    sc:R6 sc:E2070 .

# --- CLASS C5 NODE 2 ---
sc:E2203 a sc:C5 ;
    rdfs:label "C5 Node 2" ;
    rdfs:comment "A C5 node connected to the intermediary node and a C9 node." ;
    sc:R2 sc:E2005 ;
    sc:R9 sc:E2200 .

# --- CLASS C7 NODE 2 ---
sc:E2204 a sc:C7 ;
    rdfs:label "C7 Node 2" ;
    rdfs:comment "A C7 node connected to the super node and a C5 node." ;
    sc:R8 sc:E2203 ;
    sc:R6 sc:E2090 .

# --- CLASS C8 NODE 2 ---
sc:E2205 a sc:C8 ;
    rdfs:label "C8 Node 2" ;
    rdfs:comment "A C8 node connected to a C9 node and a C10 node." ;
    sc:R4 sc:E2200 ;
    sc:R6 sc:E2080 .

# --- CLASS C6 NODE 2 ---
sc:E2206 a sc:C6 ;
    rdfs:label "C6 Node 2" ;
    rdfs:comment "A C6 node connected to a C2 node and a C10 node." ;
    sc:R7 sc:E2002 ;
    sc:R6 sc:E2090 .

# --- CLASS C9 NODE 4 ---
sc:E2301 a sc:C9 ;
    rdfs:label "C9 Node Delta" ;
    rdfs:comment "A C9 node connected to the hub and connector node 2 via R9." ;
    sc:R9 sc:E2000, sc:E2007 .

# --- CLASS C10 NODE J ---
sc:E2400 a sc:C10 ;
    rdfs:label "C10 Node J" ;
    rdfs:comment "A C10 node connected to the connector node 2." ;
    sc:R6 sc:E2007 .

# --- CLASS C10 NODE K ---
sc:E2401 a sc:C10 ;
    rdfs:label "C10 Node K" ;
    rdfs:comment "A C10 node connected to the super node." ;
    sc:R6 sc:E2006 .

# --- CLASS C10 NODE L ---
sc:E2402 a sc:C10 ;
    rdfs:label "C10 Node L" ;
    rdfs:comment "A C10 node connected to the multiplex node." ;
    sc:R6 sc:E2004 .

# --- CLASS C10 NODE M ---
sc:E2403 a sc:C10 ;
    rdfs:label "C10 Node M" ;
    rdfs:comment "A C10 node connected to the intermediary node." ;
    sc:R6 sc:E2005 .

# --- CLASS C10 NODE N ---
sc:E2404 a sc:C10 ;
    rdfs:label "C10 Node N" ;
    rdfs:comment "A C10 node connected to the connector node." ;
    sc:R6 sc:E2003 .