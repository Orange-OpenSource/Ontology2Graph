 @prefix dcterms: <http://purl.org/dc/terms/> .
 @prefix owl: <http://www.w3.org/2002/07/owl#> .
 @prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
 @prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
 @prefix sc: <http://pygraf.t/> .

 sc: a owl:Ontology ;
  dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

 # Entities

 sc:EntityA a sc:C10 ;
  rdfs:label "Entity A"@en ;
  rdfs:comment "A central node with high degree."@en ;
  sc:R6 sc:EntityB,
   sc:EntityC,
   sc:EntityD,
   sc:EntityE,
   sc:EntityF .

 sc:EntityB a sc:C1 ;
  rdfs:label "Entity B"@en ;
  rdfs:comment "A connector node linking to EntityA and EntityG."@en ;
  sc:R6 sc:EntityA ;
  sc:R3 sc:EntityG .

 sc:EntityC a sc:C3 ;
  rdfs:label "Entity C"@en ;
  rdfs:comment "An intermediary node between EntityA and EntityH."@en ;
  sc:R6 sc:EntityA ;
  sc:R2 sc:EntityH .

 sc:EntityD a sc:C4 ;
  rdfs:label "Entity D"@en ;
  rdfs:comment "A high-degree node connected to EntityA and EntityI."@en ;
  sc:R6 sc:EntityA ;
  sc:R4 sc:EntityI .

 sc:EntityE a sc:C5 ;
  rdfs:label "Entity E"@en ;
  rdfs:comment "A hub node connecting EntityA and EntityJ."@en ;
  sc:R6 sc:EntityA ;
  sc:R9 sc:EntityJ .

 sc:EntityF a sc:C7 ;
  rdfs:label "Entity F"@en ;
  rdfs:comment "A multiplex node connected to EntityA and EntityK."@en ;
  sc:R6 sc:EntityA ;
  sc:R8 sc:EntityK .

 sc:EntityG a sc:C2 ;
  rdfs:label "Entity G"@en ;
  rdfs:comment "A simple node connected to EntityB."@en ;
  sc:R3 sc:EntityB .

 sc:EntityH a sc:C1 ;
  rdfs:label "Entity H"@en ;
  rdfs:comment "A simple node connected to EntityC."@en ;
  sc:R3 sc:EntityC .

 sc:EntityI a sc:C9 ;
  rdfs:label "Entity I"@en ;
  rdfs:comment "A simple node connected to EntityD."@en ;
  sc:R4 sc:EntityD .

 sc:EntityJ a sc:C10 ;
  rdfs:label "Entity J"@en ;
  rdfs:comment "A simple node connected to EntityE."@en ;
  sc:R9 sc:EntityE .

 sc:EntityK a sc:C8 ;
  rdfs:label "Entity K"@en ;
  rdfs:comment "A simple node connected to EntityF."@en ;
  sc:R8 sc:EntityF .

 sc:EntityL a sc:C6 ;
  rdfs:label "Entity L"@en ;
  rdfs:comment "A super node connected to EntityM and EntityN."@en ;
  sc:R7 sc:EntityM ;
  sc:R7 sc:EntityN .

 sc:EntityM a sc:C2 ;
  rdfs:label "Entity M"@en ;
  rdfs:comment "A simple node connected to EntityL."@en ;
  sc:R7 sc:EntityL .

 sc:EntityN a sc:C2 ;
  rdfs:label "Entity N"@en ;
  rdfs:comment "A simple node connected to EntityL."@en ;
  sc:R7 sc:EntityL .
