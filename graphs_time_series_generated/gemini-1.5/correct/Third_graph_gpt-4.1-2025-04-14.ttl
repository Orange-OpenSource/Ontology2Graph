@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# --- Super Node ---
sc:E100 a sc:C10 ;
    rdfs:label "Super Node Alpha" ;
    rdfs:comment "A super node with the highest degree, connecting to almost every other node in the graph." ;
    sc:R1 sc:E101, sc:E102, sc:E103, sc:E104, sc:E105, sc:E106, sc:E107, sc:E108 ;
    sc:R6 sc:E109, sc:E110 ;
    sc:R4 sc:E111 .

# --- Hub Node ---
sc:E101 a sc:C9 ;
    rdfs:label "Hub Node Beta" ;
    rdfs:comment "A hub node in the C9 class, central to many C9 and C10 nodes." ;
    sc:R9 sc:E102, sc:E112, sc:E113 ;
    sc:R4 sc:E114 ;
    sc:R2 sc:E115 ;
    sc:R1 sc:E100 .

# --- High-degree Node ---
sc:E102 a sc:C9 ;
    rdfs:label "High-degree Node Gamma" ;
    rdfs:comment "A high-degree node with multiple symmetric and transitive relations." ;
    sc:R9 sc:E101, sc:E113, sc:E116 ;
    sc:R4 sc:E117 ;
    sc:R2 sc:E118 ;
    sc:R1 sc:E100 .

# --- Central Node ---
sc:E103 a sc:C4 ;
    rdfs:label "Central Node Delta" ;
    rdfs:comment "A central node in the C4 class, bridging C10 and C9 nodes." ;
    sc:R4 sc:E119 ;
    sc:R6 sc:E100, sc:E120 ;
    sc:R1 sc:E121 .

# --- Connector Node ---
sc:E104 a sc:C10 ;
    rdfs:label "Connector Node Epsilon" ;
    rdfs:comment "A connector node linking different classes and acting as a bridge." ;
    sc:R6 sc:E122, sc:E123 ;
    sc:R4 sc:E124 ;
    sc:R1 sc:E100 .

# --- Intermediary Node ---
sc:E105 a sc:C10 ;
    rdfs:label "Intermediary Node Zeta" ;
    rdfs:comment "An intermediary node facilitating indirect connections between hubs and peripherals." ;
    sc:R6 sc:E125 ;
    sc:R4 sc:E126 ;
    sc:R1 sc:E100 .

# --- Multiplex Node ---
sc:E106 a sc:C5 ;
    rdfs:label "Multiplex Node Eta" ;
    rdfs:comment "A multiplex node in C5, participating in multiple types of relations and domains." ;
    sc:R9 sc:E127, sc:E128 ;
    sc:R2 sc:E129 ;
    sc:R6 sc:E100 ;
    sc:R4 sc:E130 .

# --- Peripheral Node (for contrast) ---
sc:E107 a sc:C1 ;
    rdfs:label "Peripheral Node Theta" ;
    rdfs:comment "A peripheral node with minimal connections, representing the edge of the network." ;
    sc:R3 sc:E131 ;
    sc:R1 sc:E100 .

# --- Multiplex Node (C7) ---
sc:E108 a sc:C7 ;
    rdfs:label "Multiplex Node Iota" ;
    rdfs:comment "A multiplex node in C7, connecting to both C5 and C10 nodes." ;
    sc:R8 sc:E132 ;
    sc:R6 sc:E100 ;
    sc:R4 sc:E133 .

# --- Intermediary Node (C3) ---
sc:E109 a sc:C3 ;
    rdfs:label "Intermediary Node Kappa" ;
    rdfs:comment "An intermediary node in C3, linking C10 and C1 nodes." ;
    sc:R3 sc:E134 ;
    sc:R6 sc:E100 ;
    sc:R1 sc:E135 .

# --- Connector Node (C4) ---
sc:E110 a sc:C4 ;
    rdfs:label "Connector Node Lambda" ;
    rdfs:comment "A connector node in C4, bridging C10 and C9 nodes." ;
    sc:R4 sc:E136 ;
    sc:R6 sc:E100 ;
    sc:R1 sc:E137 .

# --- Central Node (C2) ---
sc:E111 a sc:C2 ;
