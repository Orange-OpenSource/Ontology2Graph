@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub Node: Entity with many relations, central in the network
sc:HubNode a owl:Class ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the graph." ;
    rdfs:subClassOf sc:C10 .

# High-degree Node: Entity with many relations, but not necessarily a hub
sc:HighDegreeNode a owl:Class ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of relations, influential but not a central hub." ;
    rdfs:subClassOf sc:C10 .

# Central Node: Entity positioned at the core of the network
sc:CentralNode a owl:Class ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that connects multiple classes, serving as a core connector." ;
    rdfs:subClassOf sc:C10 .

# Connector Node: Entity that links different classes or groups
sc:ConnectorNode a owl:Class ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects disparate parts of the graph, facilitating communication." ;
    rdfs:subClassOf sc:C10 .

# Intermediary Node: Entity acting as a bridge between other nodes
sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that mediates relations between other entities." ;
    rdfs:subClassOf sc:C10 .

# Multiplex Node: Entity involved in multiple relation types
sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node participating in various relation types, representing complex interactions." ;
    rdfs:subClassOf sc:C10 .

# Super Node: Entity that encompasses multiple classes or functions
sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "An entity that aggregates multiple nodes or functions, acting as a super-entity." ;
    rdfs:subClassOf sc:C10 .

# Example entities with relations based on the schema

# Hub node with multiple relations
sc:E1001 a sc:HubNode ;
    rdfs:label "Entity E1001" ;
    rdfs:comment "A hub node connected to several high-degree nodes." ;
    sc:R1 sc:E1002 ;
    sc:R1 sc:E1003 ;
    sc:R1 sc:E1004 .

# High-degree node connected to various entities
sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "Entity E1002" ;
    rdfs:comment "A high-degree node linking to multiple central and connector nodes." ;
    sc:R1 sc:E1005 ;
    sc:R1 sc:E1006 ;
    sc:R1 sc:E1007 .

# Central node connecting different classes
sc:E1003 a sc:CentralNode ;
    rdfs:label "Entity E1003" ;
    rdfs:comment "A central node bridging classes C1 and C4." ;
    sc:R2 sc:E1008 ;
    sc:R3 sc:E1009 .

# Connector node linking classes C2 and C3
sc:E1004 a sc:ConnectorNode ;
    rdfs:label "Entity E1004" ;
    rdfs:comment "A connector node linking class C2 and C3." ;
    sc:R10 sc:E1010 ;
    sc:R4 sc:E1011 .

# Intermediary node mediating between entities
sc:E1005 a sc:IntermediaryNode ;
    rdfs:label "Entity E1005" ;
    rdfs:comment "An intermediary node facilitating relations between E1002 and E1006." ;
    sc:R3 sc:E1012 .

# Multiplex node involved in multiple relation types
sc:E1006 a sc:MultiplexNode ;
    rdfs:label "Entity E1006" ;
    rdfs:comment "A multiplex node involved in various relation types." ;
    sc:R4 sc:E1013 ;
    sc:R6 sc:E1014 .

# Super node aggregating multiple entities
sc:E1007 a sc:SuperNode ;
    rdfs:label "Entity E1007" ;
    rdfs:comment "A super node representing an aggregated entity." ;
    sc:R1 sc:E1015 ;
    sc:R1 sc:E1016 .

