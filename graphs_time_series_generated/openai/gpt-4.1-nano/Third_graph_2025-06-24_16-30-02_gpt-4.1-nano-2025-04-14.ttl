@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Define Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A node with high connectivity acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of relations, acting as a key connector." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that acts as a central point in the network, connecting multiple nodes." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different parts of the graph, facilitating communication." .

sc:IntermediaryNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as an intermediary between hubs and peripheral nodes." .

sc:MultiplexNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations, acting as a multiplex hub." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A super node with extensive relations, often acting as a super hub." .

# Define Object Properties
sc:relatesTo a owl:ObjectProperty ;
    rdfs:label "relates to" ;
    rdfs:comment "A generic relation between entities." .

sc:connectsTo a owl:ObjectProperty ;
    rdfs:label "connects to" ;
    rdfs:comment "Indicates a connection between two nodes." .

sc:linksTo a owl:ObjectProperty ;
    rdfs:label "links to" ;
    rdfs:comment "A linking relation between nodes." .

sc:interactsWith a owl:ObjectProperty ;
    rdfs:label "interacts with" ;
    rdfs:comment "Indicates an interaction between entities." .

# Define Entities (Nodes)
# Hub Node
sc:Hub1 a sc:HubNode ;
    rdfs:label "Main Hub" ;
    rdfs:comment "The central hub connecting multiple high-degree nodes." ;
    sc:connectsTo sc:HighNode1, sc:HighNode2, sc:SuperNode1 .

# High Degree Nodes
sc:HighNode1 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node 1" ;
    rdfs:comment "A key connector with many relations." ;
    sc:connectsTo sc:Hub1, sc:Connector1, sc:Multiplex1 .

sc:HighNode2 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node 2" ;
    rdfs:comment "Another key connector with multiple relations." ;
    sc:connectsTo sc:Hub1, sc:Connector2 .

# Central Node
sc:Central1 a sc:CentralNode ;
    rdfs:label "Central Node 1" ;
    sc:interactsWith sc:Intermediary1, sc:HighNode1 .

# Connector Nodes
sc:Connector1 a sc:ConnectorNode ;
    rdfs:label "Connector Node 1" ;
    sc:linksTo sc:HighNode1, sc:Intermediary1 .

sc:Connector2 a sc:ConnectorNode ;
    rdfs:label "Connector Node 2" ;
    sc:linksTo sc:HighNode2, sc:Intermediary2 .

# Intermediary Nodes
sc:Intermediary1 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node 1" ;
    sc:interactsWith sc:Central1, sc:Connector1 .

sc:Intermediary2 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node 2" ;
    sc:interactsWith sc:HighNode2, sc:SuperNode1 .

# Multiplex Node
sc:Multiplex1 a sc:MultiplexNode ;
    rdfs:label "Multiplex Node 1" ;
    sc:connectsTo sc:HighNode1, sc:SuperNode1, sc:Intermediary2 .

# Super Node
sc:SuperNode1 a sc:SuperNode ;
    rdfs:label "Super Node 1" ;
    rdfs:comment "A super node with extensive relations acting as a super hub." ;
    sc:connectsTo sc:Hub1, sc:HighNode2, sc:Multiplex1 .

# Relations between nodes
sc:Hub1 sc:connectsTo sc:HighNode1, sc:HighNode2, sc:SuperNode1 .
sc:HighNode1 sc:connectsTo sc:Hub1, sc:Connector1, sc:Multiplex1 .
sc:HighNode2 sc:connectsTo sc:Hub1, sc:Connector2 .
sc:Connector1 sc:linksTo sc:HighNode1, sc:Intermediary1 .
sc:Connector2 sc:linksTo sc:HighNode2, sc:Intermediary2 .
sc:Intermediary1 sc:interactsWith sc:Central1, sc:Connector1 .
sc:Intermediary2 sc:interactsWith sc:HighNode2, sc:SuperNode1 .
sc:Multiplex1 sc:connectsTo sc:HighNode1, sc:SuperNode1, sc:Intermediary2 .
sc:SuperNode1 sc:connectsTo sc:Hub1, sc:HighNode2, sc:Multiplex1 .

