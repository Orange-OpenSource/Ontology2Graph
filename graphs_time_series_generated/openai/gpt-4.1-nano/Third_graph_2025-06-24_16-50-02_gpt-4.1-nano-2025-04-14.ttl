@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Class definitions
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node positioned at the center of a cluster or community." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different clusters or communities." .

sc:IntermediaryNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as a bridge between two other nodes." .

sc:MultiplexNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations." .

sc:SuperNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Super Node" ;
    rdfs:comment "A node that aggregates multiple nodes or communities." .

# Entities
sc:E1001 a sc:HubNode ;
    rdfs:label "Main Hub" ;
    rdfs:comment "A central hub node connecting multiple high-degree nodes." ;
    sc:R1 sc:E1022, sc:E1033 .

sc:E1022 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node A" ;
    rdfs:comment "A node with many connections to other nodes." ;
    sc:R2 sc:E1044, sc:E1055 .

sc:E1033 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node B" ;
    rdfs:comment "Another high-degree node connected to the hub." ;
    sc:R2 sc:E1066 .

sc:E1044 a sc:ConnectorNode ;
    rdfs:label "Connector Node 1" ;
    rdfs:comment "Connects different high-degree nodes to the hub." ;
    sc:R3 sc:E1077 .

sc:E1055 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "Bridges between high-degree nodes." ;
    sc:R4 sc:E1088 .

sc:E1066 a sc:MultiplexNode ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "Participates in multiple relation types." ;
    sc:R5 sc:E1099 .

sc:E1077 a sc:SuperNode ;
    rdfs:label "Super Node" ;
    rdfs:comment "Aggregates multiple communities." ;
    sc:R6 sc:E1100 .

sc:E1088 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node C" ;
    rdfs:comment "Connected to multiple connector nodes." ;
    sc:R2 sc:E1022 .

sc:E1099 a sc:ConnectorNode ;
    rdfs:label "Connector Node 2" ;
    rdfs:comment "Links different clusters." ;
    sc:R3 sc:E1110 .

sc:E1100 a sc:SuperNode ;
    rdfs:label "Super Node 2" ;
    rdfs:comment "A super node connecting multiple communities." ;
    sc:R6 sc:E1121 .

# Relations among entities
sc:E1022 sc:R7 sc:E1033 .
sc:E1044 sc:R8 sc:E1055 .
sc:E1055 sc:R9 sc:E1066 .
sc:E1066 sc:R10 sc:E1077 .
sc:E1077 sc:R7 sc:E1088 .
sc:E1088 sc:R8 sc:E1099 .
sc:E1099 sc:R9 sc:E1100 .
sc:E1100 sc:R10 sc:E1022 .

# Additional nodes to diversify the graph
sc:E1111 a sc:CentralNode ;
    rdfs:label "Central Node Alpha" ;
    rdfs:comment "A central node within a specific community." ;
    sc:R1 sc:E1122 .

sc:E1122 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node Alpha" ;
    rdfs:comment "A high-degree node within the community." ;
    sc:R2 sc:E1133 .

sc:E1133 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node Beta" ;
    rdfs:comment "Acts as a bridge within the community." ;
    sc:R3 sc:E1144 .

sc:E1144 a sc:MultiplexNode ;
    rdfs:label "Multiplex Node Beta" ;
    rdfs:comment "Participates in multiple relation types." ;
    sc:R4 sc:E1155 .

sc:E1155 a sc:SuperNode ;
    rdfs:label "Super Node Beta" ;
    rdfs:comment "A super node representing a larger community." ;
    sc:R6 sc:E1166 .

