@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub Node: Entity with many relations, central in the network
sc:HubNode a owl:Class ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the graph." ;
    rdfs:subClassOf sc:C10 .

# High-degree Node: Entity with many relations, but not necessarily a hub
sc:HighDegreeNode a owl:Class ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of relations, influential but not a central hub." ;
    rdfs:subClassOf sc:C10 .

# Central Node: Entity positioned at the core of the network
sc:CentralNode a owl:Class ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node located at the center of the network, connecting multiple classes." ;
    rdfs:subClassOf sc:C10 .

# Connector Node: Entity that connects different classes or groups
sc:ConnectorNode a owl:Class ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that links different parts of the graph, facilitating cross-group relations." ;
    rdfs:subClassOf sc:C10 .

# Intermediary Node: Entity acting as a bridge between two nodes or classes
sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that mediates relations between other entities, often serving as a bridge." ;
    rdfs:subClassOf sc:C10 .

# Multiplex Node: Entity involved in multiple relation types
sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node participating in multiple relation types, representing complex interactions." ;
    rdfs:subClassOf sc:C10 .

# Super Node: Entity that encompasses multiple classes or functions
sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A highly influential node that integrates multiple classes or functions." ;
    rdfs:subClassOf sc:C10 .

# Entities with relations
sc:E1001 a sc:HubNode ;
    rdfs:label "Entity E1001" ;
    rdfs:comment "A hub node connected to multiple high-degree nodes and central nodes." ;
    sc:sc:R6 sc:E1002, sc:E1003, sc:E1004 .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "Entity E1002" ;
    rdfs:comment "A high-degree node linking various classes, acting as a key connector." ;
    sc:sc:R6 sc:E1001, sc:E1005 .

sc:E1003 a sc:CentralNode ;
    rdfs:label "Entity E1003" ;
    rdfs:comment "A central node connecting different classes and acting as a core entity." ;
    sc:sc:R6 sc:E1001, sc:E1006 .

sc:E1004 a sc:ConnectorNode ;
    rdfs:label "Entity E1004" ;
    rdfs:comment "A connector node linking peripheral nodes to the core network." ;
    sc:sc:R6 sc:E1001, sc:E1007 .

sc:E1005 a sc:IntermediaryNode ;
    rdfs:label "Entity E1005" ;
    rdfs:comment "An intermediary node bridging high-degree nodes and other classes." ;
    sc:sc:R6 sc:E1002, sc:E1008 .

sc:E1006 a sc:MultiplexNode ;
    rdfs:label "Entity E1006" ;
    rdfs:comment "A multiplex node involved in multiple relation types across classes." ;
    sc:sc:R6 sc:E1003, sc:E1009 .

sc:E1007 a sc:SuperNode ;
    rdfs:label "Entity E1007" ;
    rdfs:comment "A super node representing an overarching entity with multiple relations." ;
    sc:sc:R6 sc:E1004, sc:E1010 .

# Additional relations to create a diverse network
sc:E1008 a sc:HighDegreeNode ;
    rdfs:label "Entity E1008" ;
    rdfs:comment "A high-degree node connected to various intermediary nodes." ;
    sc:sc:R6 sc:E1005 .

sc:E1009 a sc:CentralNode ;
    rdfs:label "Entity E1009" ;
    rdfs:comment "A central node linking multiplex and super nodes." ;
    sc:sc:R6 sc:E1006 .

sc:E1010 a sc:ConnectorNode ;
    rdfs:label "Entity E1010" ;
    rdfs:comment "A connector node facilitating relations between super and hub nodes." ;
    sc:sc:R6 sc:E1007 .

# Relations among entities
sc:E1001 sc:sc:R6 sc:E1002 .
sc:E1002 sc:sc:R6 sc:E1003 .
sc:E1003 sc:sc:R6 sc:E1004 .
sc:E1004 sc:sc:R6 sc:E1005 .
sc:E1005 sc:sc:R6 sc:E1006 .
sc:E1006 sc:sc:R6 sc:E1007 .
sc:E1007 sc:sc:R6 sc:E1008 .
sc:E1008 sc:sc:R6 sc:E1009 .
sc:E1009 sc:sc:R6 sc:E1010 .

# Additional diverse relations
sc:E1010 sc:sc:R6 sc:E1001 .

# End of graph
