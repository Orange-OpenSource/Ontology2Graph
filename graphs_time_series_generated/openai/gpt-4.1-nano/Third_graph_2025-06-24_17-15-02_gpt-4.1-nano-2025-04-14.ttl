@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Hub Node"@en ;
    rdfs:comment "A highly connected node acting as a central hub in the network."@en .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "High-Degree Node"@en ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub."@en .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Central Node"@en ;
    rdfs:comment "A node positioned at the center of a cluster or community."@en .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Connector Node"@en ;
    rdfs:comment "A node that connects different communities or clusters."@en .

sc:IntermediaryNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Intermediary Node"@en ;
    rdfs:comment "A node that acts as a bridge between two other nodes."@en .

sc:MultiplexNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Multiplex Node"@en ;
    rdfs:comment "A node involved in multiple types of relations."@en .

sc:SuperNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Super Node"@en ;
    rdfs:comment "A node that aggregates multiple nodes or functions as a super hub."@en .

# Entities
sc:E1001 a sc:HubNode ;
    rdfs:label "Hub Node Alpha"@en ;
    rdfs:comment "A central hub connecting multiple communities."@en ;
    sc:sc:R1 sc:E1002 ;
    sc:sc:R10 sc:E1003 .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "High-Degree Node Beta"@en ;
    rdfs:comment "A node with many connections, acting as a key connector."@en ;
    sc:sc:R1 sc:E1004 .

sc:E1003 a sc:ConnectorNode ;
    rdfs:label "Connector Node Gamma"@en ;
    rdfs:comment "Connects two distinct clusters."@en ;
    sc:sc:R4 sc:E1005 .

sc:E1004 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node Delta"@en ;
    rdfs:comment "Bridges between high-degree nodes."@en ;
    sc:sc:R6 sc:E1006 .

sc:E1005 a sc:MultiplexNode ;
    rdfs:label "Multiplex Node Epsilon"@en ;
    rdfs:comment "Participates in multiple relation types."@en ;
    sc:sc:R4 sc:E1007 .

sc:E1006 a sc:SuperNode ;
    rdfs:label "Super Node Zeta"@en ;
    rdfs:comment "A super hub aggregating multiple nodes."@en ;
    sc:sc:R1 sc:E1008 .

sc:E1007 a sc:HighDegreeNode ;
    rdfs:label "High-Degree Node Eta"@en ;
    rdfs:comment "A high-degree node involved in multiplex relations."@en ;
    sc:sc:R10 sc:E1009 .

sc:E1008 a sc:HubNode ;
    rdfs:label "Hub Node Theta"@en ;
    sc:comment "A central hub in the network."@en ;
    sc:sc:R1 sc:E1010 .

sc:E1009 a sc:ConnectorNode ;
    rdfs:label "Connector Node Iota"@en ;
    sc:comment "Connects super nodes to other hubs."@en ;
    sc:sc:R4 sc:E1011 .

sc:E1010 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node Kappa"@en ;
    sc:comment "Acts as a bridge between hubs and high-degree nodes."@en ;
    sc:sc:R6 sc:E1012 .

sc:E1011 a sc:MultiplexNode ;
    rdfs:label "Multiplex Node Lambda"@en ;
    sc:comment "Involved in multiple relation types across the network."@en ;
    sc:sc:R4 sc:E1013 .

sc:E1012 a sc:SuperNode ;
    rdfs:label "Super Node Mu"@en ;
    sc:comment "A super node aggregating multiple multiplex nodes."@en ;
    sc:sc:R1 sc:E1014 .

sc:E1013 a sc:HighDegreeNode ;
    rdfs:label "High-Degree Node Nu"@en ;
    sc:comment "A multiplex node with high connectivity."@en ;
    sc:sc:R10 sc:E1015 .

sc:E1014 a sc:HubNode ;
    rdfs:label "Hub Node Xi"@en ;
    sc:comment "A major hub in the network."@en ;
    sc:sc:R1 sc:E1016 .

sc:E1015 a sc:ConnectorNode ;
    rdfs:label "Connector Node Omicron"@en ;
    sc:comment "Connects super nodes to other hubs."@en ;
    sc:sc:R4 sc:E1017 .

sc:E1016 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node Pi"@en ;
    sc:comment "Bridges between super nodes and high-degree nodes."@en ;
    sc:sc:R6 sc:E1018 .

sc:E1017 a sc:MultiplexNode ;
    rdfs:label "Multiplex Node Rho"@en ;
    sc:comment "Participates in multiple relation types."@en ;
    sc:sc:R4 sc:E1019 .

sc:E1018 a sc:SuperNode ;
    rdfs:label "Super Node Sigma"@en ;
    sc:comment "A super hub connecting multiplex nodes."@en ;
    sc:sc:R1 sc:E1020 .

sc:E1019 a sc:HighDegreeNode ;
    rdfs:label "High-Degree Node Tau"@en ;
    sc:comment "A multiplex node with extensive connections."@en ;
    sc:sc:R10 sc:E1021 .

sc:E1020 a sc:HubNode ;
    rdfs:label "Hub Node Upsilon"@en ;
    sc:comment "A central hub in the network."@en ;
    sc:sc:R1 sc:E1022 .

sc:E1021 a sc:ConnectorNode ;
    rdfs:label "Connector Node Phi"@en ;
    sc:comment "Connects super nodes to other hubs."@en ;
    sc:sc:R4 sc:E1023 .

sc:E1022 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node Chi"@en ;
    sc:comment "Bridges between hubs and multiplex nodes."@en ;
    sc:sc:R6 sc:E1024 .

sc:E1023 a sc:MultiplexNode ;
    rdfs:label "Multiplex Node Psi"@en ;
    sc:comment "Involved in multiple relation types."@en ;
    sc:sc:R4 sc:E1025 .

sc:E1024 a sc:SuperNode ;
    rdfs:label "Super Node Omega"@en ;
    sc:comment "A super hub connecting multiplex nodes."@en ;
    sc:sc:R1 sc:E1026 .

