    <!-- http://pygraf.t/Central1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Central1">
        <rdf:type rdf:resource="http://pygraf.t/CentralNode"/>
        <connects rdf:resource="http://pygraf.t/Intermediary1"/>
        <connects rdf:resource="http://pygraf.t/NodeB"/>
        <connects rdf:resource="http://pygraf.t/NodeC"/>
        <rdfs:comment>A key node within a specific community.</rdfs:comment>
        <rdfs:label>Central Node Alpha</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Connector1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Connector1">
        <rdf:type rdf:resource="http://pygraf.t/ConnectorNode"/>
        <bridges rdf:resource="http://pygraf.t/HighDeg1"/>
        <bridges rdf:resource="http://pygraf.t/Hub1"/>
        <bridges rdf:resource="http://pygraf.t/NodeD"/>
        <rdfs:comment>Connects different communities or subgraphs.</rdfs:comment>
        <rdfs:label>Connector Node X</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/HighDeg1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/HighDeg1">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
        <connects rdf:resource="http://pygraf.t/Hub1"/>
        <connects rdf:resource="http://pygraf.t/Intermediary1"/>
        <connects rdf:resource="http://pygraf.t/NodeA"/>
        <rdfs:comment>A node with many connections, acting as a local hub.</rdfs:comment>
        <rdfs:label>High Degree Node 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Hub1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Hub1">
        <rdf:type rdf:resource="http://pygraf.t/HubNode"/>
        <connects rdf:resource="http://pygraf.t/Connector1"/>
        <connects rdf:resource="http://pygraf.t/HighDeg1"/>
        <connects rdf:resource="http://pygraf.t/Super1"/>
        <rdfs:comment>A central hub node with numerous connections.</rdfs:comment>
        <rdfs:label>Main Hub</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Intermediary1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Intermediary1">
        <rdf:type rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <relatesTo rdf:resource="http://pygraf.t/NodeA"/>
        <relatesTo rdf:resource="http://pygraf.t/NodeB"/>
        <relatesTo rdf:resource="http://pygraf.t/NodeC"/>
        <rdfs:comment>Mediates interactions between multiple nodes.</rdfs:comment>
        <rdfs:label>Mediator Node Y</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Layer1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Layer1">
        <rdf:type rdf:resource="http://pygraf.t/RelationLayer"/>
        <rdfs:comment>First relation layer.</rdfs:comment>
        <rdfs:label>Layer 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Layer2 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Layer2">
        <rdf:type rdf:resource="http://pygraf.t/RelationLayer"/>
        <rdfs:comment>Second relation layer.</rdfs:comment>
        <rdfs:label>Layer 2</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/MultiNode1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/MultiNode1">
        <rdf:type rdf:resource="http://pygraf.t/MultiplexNode"/>
        <participatesIn rdf:resource="http://pygraf.t/Layer1"/>
        <participatesIn rdf:resource="http://pygraf.t/Layer2"/>
        <rdfs:comment>Participates in multiple relation layers.</rdfs:comment>
        <rdfs:label>Multiplex Node Z</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeA -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeA">
        <rdf:type rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>An ordinary node connected to high-degree nodes.</rdfs:comment>
        <rdfs:label>Node A</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeB -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeB">
        <rdf:type rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>A node within the central community.</rdfs:comment>
        <rdfs:label>Node B</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeC -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeC">
        <rdf:type rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>Another node within the central community.</rdfs:comment>
        <rdfs:label>Node C</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeD -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeD">
        <rdf:type rdf:resource="http://pygraf.t/Node"/>
        <connects rdf:resource="http://pygraf.t/Hub1"/>
        <rdfs:comment>A peripheral node connected via a connector.</rdfs:comment>
        <rdfs:label>Node D</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Super1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Super1">
        <rdf:type rdf:resource="http://pygraf.t/SuperNode"/>
        <encompasses rdf:resource="http://pygraf.t/Central1"/>
        <encompasses rdf:resource="http://pygraf.t/HighDeg1"/>
        <encompasses rdf:resource="http://pygraf.t/Hub1"/>
        <rdfs:comment>Encompasses multiple nodes or communities.</rdfs:comment>
        <rdfs:label>Super Node Omega</rdfs:label>
    </owl:NamedIndividual>
