        <rdfs:range rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>Connects different parts of the graph, acting as a bridge.</rdfs:comment>
        <rdfs:label>bridges</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/connects -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/connects">
        <rdfs:domain rdf:resource="http://pygraf.t/Node"/>
        <rdfs:range rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>Indicates a connection between two nodes.</rdfs:comment>
        <rdfs:label>connects to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/encompasses -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/encompasses">
        <rdfs:domain rdf:resource="http://pygraf.t/SuperNode"/>
        <rdfs:range rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>Represents a super node that encompasses multiple nodes.</rdfs:comment>
        <rdfs:label>encompasses</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/mediates -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/mediates">
        <rdfs:domain rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <rdfs:range rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>Mediates interactions between other nodes.</rdfs:comment>
        <rdfs:label>mediates</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/participatesIn -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/participatesIn">
        <rdfs:domain rdf:resource="http://pygraf.t/MultiplexNode"/>
        <rdfs:range rdf:resource="http://pygraf.t/RelationLayer"/>
        <rdfs:comment>Indicates involvement of multiplex nodes in multiple relation layers.</rdfs:comment>
        <rdfs:label>participates in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/relatesTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/relatesTo">
        <rdfs:domain rdf:resource="http://pygraf.t/Node"/>
        <rdfs:range rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>Indicates a relation or association between two nodes.</rdfs:comment>
        <rdfs:label>relates to</rdfs:label>
    </owl:ObjectProperty>
    


