        <connectsTo rdf:resource="http://pygraf.t/Entity7"/>
        <hasRelationType rdf:resource="http://pygraf.t/Association"/>
        <rdfs:comment>A hub node with multiple high-degree connections.</rdfs:comment>
        <rdfs:label>Entity 10</rdfs:label>
