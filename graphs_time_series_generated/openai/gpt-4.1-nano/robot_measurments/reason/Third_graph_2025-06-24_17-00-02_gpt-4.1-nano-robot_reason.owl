<?xml version="1.0"?>
<rdf:RDF xmlns="http://pygraf.t/"
     xml:base="http://pygraf.t/"
     xmlns:sc="http://pygraf.t/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://pygraf.t/">
        <dcterms:license rdf:resource="https://creativecommons.org/publicdomain/zero/1.0/"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pygraf.t/connectsTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/connectsTo">
        <rdfs:domain rdf:resource="http://pygraf.t/Node"/>
        <rdfs:range rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>Indicates a connection between two nodes.</rdfs:comment>
        <rdfs:label>connects to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/hasRelationType -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/hasRelationType">
        <rdfs:domain rdf:resource="http://pygraf.t/Node"/>
        <rdfs:range rdf:resource="http://pygraf.t/RelationType"/>
        <rdfs:comment>Specifies the type of relation a node has with another.</rdfs:comment>
        <rdfs:label>has relation type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/linksLayer -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/linksLayer">
        <rdfs:domain rdf:resource="http://pygraf.t/Node"/>
        <rdfs:range rdf:resource="http://pygraf.t/Layer"/>
        <rdfs:comment>Indicates the layer or dimension in multiplex networks.</rdfs:comment>
        <rdfs:label>links layer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pygraf.t/CentralNode -->

    <owl:Class rdf:about="http://pygraf.t/CentralNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>A node that is central within a specific subgraph.</rdfs:comment>
        <rdfs:label>Central Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/ConnectorNode -->

    <owl:Class rdf:about="http://pygraf.t/ConnectorNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>A node that connects different parts of the graph, acting as a bridge.</rdfs:comment>
        <rdfs:label>Connector Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HighDegreeNode -->

    <owl:Class rdf:about="http://pygraf.t/HighDegreeNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/CentralNode"/>
        <rdfs:comment>A node with a high number of connections, but not necessarily a hub.</rdfs:comment>
        <rdfs:label>High-Degree Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HubNode -->

    <owl:Class rdf:about="http://pygraf.t/HubNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/SuperNode"/>
        <rdfs:comment>A highly connected node acting as a central hub in the network.</rdfs:comment>
        <rdfs:label>Hub Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/IntermediaryNode -->

    <owl:Class rdf:about="http://pygraf.t/IntermediaryNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>A node that mediates interactions between other nodes.</rdfs:comment>
        <rdfs:label>Intermediary Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/Layer -->

    <owl:Class rdf:about="http://pygraf.t/Layer">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>Represents different layers or dimensions in multiplex networks.</rdfs:comment>
        <rdfs:label>Layer</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/MultiplexNode -->

    <owl:Class rdf:about="http://pygraf.t/MultiplexNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>A node involved in multiple types of relations or layers.</rdfs:comment>
        <rdfs:label>Multiplex Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/Node -->

    <owl:Class rdf:about="http://pygraf.t/Node">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    


    <!-- http://pygraf.t/RelationType -->

    <owl:Class rdf:about="http://pygraf.t/RelationType">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A class representing different types of relations.</rdfs:comment>
        <rdfs:label>Relation Type</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/SuperNode -->

    <owl:Class rdf:about="http://pygraf.t/SuperNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>An overarching node that encompasses multiple nodes or functions.</rdfs:comment>
        <rdfs:label>Super Node</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pygraf.t/Association -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Association">
        <rdf:type rdf:resource="http://pygraf.t/RelationType"/>
        <rdfs:comment>A relation indicating an association or link.</rdfs:comment>
        <rdfs:label>Association</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Dependency -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Dependency">
        <rdf:type rdf:resource="http://pygraf.t/RelationType"/>
        <rdfs:comment>A relation indicating a dependency between nodes.</rdfs:comment>
        <rdfs:label>Dependency</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Entity1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Entity1">
        <rdf:type rdf:resource="http://pygraf.t/HubNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Entity2"/>
        <connectsTo rdf:resource="http://pygraf.t/Entity3"/>
        <connectsTo rdf:resource="http://pygraf.t/Entity4"/>
        <connectsTo rdf:resource="http://pygraf.t/Entity5"/>
        <hasRelationType rdf:resource="http://pygraf.t/Association"/>
        <rdfs:comment>A central hub node with many connections.</rdfs:comment>
        <rdfs:label>Entity 1</rdfs:label>
    </owl:NamedIndividual>
    


