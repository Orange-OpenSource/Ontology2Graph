     -->

    


    <!-- http://pygraf.t/E1001 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1001">
        <rdf:type rdf:resource="http://pygraf.t/HubNode"/>
        <R1 rdf:resource="http://pygraf.t/E1002"/>
        <hasRelation rdf:resource="http://pygraf.t/R1"/>
        <rdfs:comment>A central hub node with numerous connections.</rdfs:comment>
        <rdfs:comment>Relation R between hub node and high-degree node.</rdfs:comment>
        <rdfs:label>Node E1001</rdfs:label>
        <rdfs:label>Relation R1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1002 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1002">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
        <R2 rdf:resource="http://pygraf.t/E1003"/>
        <R8 rdf:resource="http://pygraf.t/E1004"/>
        <hasRelation rdf:resource="http://pygraf.t/R2"/>
        <rdfs:comment>A high-degree node connected to multiple hubs.</rdfs:comment>
        <rdfs:comment>Relation R indicating connection from high-degree to central node.</rdfs:comment>
        <rdfs:comment>Symmetric relation between high-degree node and connector node.</rdfs:comment>
        <rdfs:label>Node E1002</rdfs:label>
        <rdfs:label>Relation R2</rdfs:label>
        <rdfs:label>Relation R8</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1003 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1003">
        <rdf:type rdf:resource="http://pygraf.t/CentralNode"/>
        <R3 rdf:resource="http://pygraf.t/E1004"/>
        <R9 rdf:resource="http://pygraf.t/E1005"/>
        <hasRelation rdf:resource="http://pygraf.t/R3"/>
        <rdfs:comment>A node positioned at the core of a cluster.</rdfs:comment>
        <rdfs:comment>Relation R linking central node to connector node.</rdfs:comment>
        <rdfs:comment>Symmetric relation between central node and intermediary node.</rdfs:comment>
        <rdfs:label>Node E1003</rdfs:label>
        <rdfs:label>Relation R3</rdfs:label>
        <rdfs:label>Relation R9</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1004 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1004">
        <rdf:type rdf:resource="http://pygraf.t/ConnectorNode"/>
        <R10 rdf:resource="http://pygraf.t/E1006"/>
        <R4 rdf:resource="http://pygraf.t/E1005"/>
        <hasRelation rdf:resource="http://pygraf.t/R4"/>
        <rdfs:comment>A connector node linking two communities.</rdfs:comment>
        <rdfs:comment>Inverse relation from connector node to multiplex node.</rdfs:comment>
        <rdfs:comment>Relation R connecting connector node to intermediary node.</rdfs:comment>
        <rdfs:label>Node E1004</rdfs:label>
        <rdfs:label>Relation R10</rdfs:label>
        <rdfs:label>Relation R4</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1005 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1005">
        <rdf:type rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <R2 rdf:resource="http://pygraf.t/E1007"/>
        <R5 rdf:resource="http://pygraf.t/E1006"/>
        <hasRelation rdf:resource="http://pygraf.t/R5"/>
        <rdfs:comment>An intermediary node bridging different groups.</rdfs:comment>
        <rdfs:comment>Relation R bridging intermediary node to multiplex node.</rdfs:comment>
        <rdfs:comment>Relation R indicating connection from intermediary to super node.</rdfs:comment>
        <rdfs:label>Node E1005</rdfs:label>
        <rdfs:label>Relation R2</rdfs:label>
        <rdfs:label>Relation R5</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1006 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1006">
        <rdf:type rdf:resource="http://pygraf.t/MultiplexNode"/>
        <R3 rdf:resource="http://pygraf.t/E1001"/>
        <R6 rdf:resource="http://pygraf.t/E1007"/>
        <hasRelation rdf:resource="http://pygraf.t/R6"/>
        <rdfs:comment>A multiplex node involved in multiple relation types.</rdfs:comment>
        <rdfs:comment>Relation R involving multiplex node and super node.</rdfs:comment>
        <rdfs:comment>Relation R linking multiplex node to hub node.</rdfs:comment>
        <rdfs:label>Node E1006</rdfs:label>
        <rdfs:label>Relation R3</rdfs:label>
        <rdfs:label>Relation R6</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1007 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1007">
        <rdf:type rdf:resource="http://pygraf.t/SuperNode"/>
        <R4 rdf:resource="http://pygraf.t/E1002"/>
        <R7 rdf:resource="http://pygraf.t/E1001"/>
        <hasRelation rdf:resource="http://pygraf.t/R7"/>
        <rdfs:comment>A super node with multiple roles and high influence.</rdfs:comment>
        <rdfs:comment>Relation R connecting super node back to hub node, forming a cycle.</rdfs:comment>
        <rdfs:comment>Relation R connecting super node to high-degree node.</rdfs:comment>
        <rdfs:label>Node E1007</rdfs:label>
        <rdfs:label>Relation R4</rdfs:label>
        <rdfs:label>Relation R7</rdfs:label>
    </owl:NamedIndividual>
</rdf:RDF>



