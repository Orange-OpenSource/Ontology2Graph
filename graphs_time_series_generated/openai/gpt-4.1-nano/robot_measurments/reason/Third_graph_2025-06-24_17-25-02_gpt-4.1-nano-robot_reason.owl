    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pygraf.t/bridges -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/bridges">
        <rdfs:comment>Relation indicating bridging role of a node.</rdfs:comment>
        <rdfs:label>bridges</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/connectsTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/connectsTo">
        <rdfs:comment>Relation indicating a connection between nodes.</rdfs:comment>
        <rdfs:label>connects to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/hasRelationType -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/hasRelationType">
        <rdfs:comment>Relation indicating multiplex or multiple relation types.</rdfs:comment>
        <rdfs:label>has relation type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/interactsWith -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/interactsWith">
        <rdfs:comment>Relation indicating interaction between entities.</rdfs:comment>
        <rdfs:label>interacts with</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/linksTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/linksTo"/>
    


    <!-- http://pygraf.t/relatesTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/relatesTo"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pygraf.t/CentralNode -->

    <owl:Class rdf:about="http://pygraf.t/CentralNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/SuperNode"/>
        <rdfs:comment>A node that is central within a specific subgraph or community.</rdfs:comment>
        <rdfs:label>Central Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/ConnectorNode -->

    <owl:Class rdf:about="http://pygraf.t/ConnectorNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <rdfs:comment>A node that connects different classes or communities.</rdfs:comment>
        <rdfs:label>Connector Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HighDegreeNode -->

    <owl:Class rdf:about="http://pygraf.t/HighDegreeNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/CentralNode"/>
        <rdfs:comment>A node with a high number of relations, acting as a key connector.</rdfs:comment>
        <rdfs:label>High-Degree Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HubNode -->

    <owl:Class rdf:about="http://pygraf.t/HubNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/SuperNode"/>
        <rdfs:comment>A node with high connectivity acting as a central hub in the network.</rdfs:comment>
        <rdfs:label>Hub Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/IntermediaryNode -->

    <owl:Class rdf:about="http://pygraf.t/IntermediaryNode">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A node that acts as a bridge between other nodes or classes.</rdfs:comment>
        <rdfs:label>Intermediary Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/MultiplexNode -->

    <owl:Class rdf:about="http://pygraf.t/MultiplexNode">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A node involved in multiple relation types or classes.</rdfs:comment>
        <rdfs:label>Multiplex Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/SuperNode -->

    <owl:Class rdf:about="http://pygraf.t/SuperNode">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A highly connected node that encompasses multiple roles.</rdfs:comment>
        <rdfs:label>Super Node</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pygraf.t/NodeA -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeA">
        <rdf:type rdf:resource="http://pygraf.t/HubNode"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeB"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeC"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeD"/>
        <rdfs:comment>A hub node with high connectivity.</rdfs:comment>
        <rdfs:label>Node A</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeB -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeB">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
        <linksTo rdf:resource="http://pygraf.t/NodeA"/>
        <linksTo rdf:resource="http://pygraf.t/NodeE"/>
        <linksTo rdf:resource="http://pygraf.t/NodeF"/>
        <rdfs:comment>A high-degree node acting as a key connector.</rdfs:comment>
        <rdfs:label>Node B</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeC -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeC">
        <rdf:type rdf:resource="http://pygraf.t/CentralNode"/>
        <interactsWith rdf:resource="http://pygraf.t/NodeA"/>
        <interactsWith rdf:resource="http://pygraf.t/NodeG"/>
        <rdfs:comment>A central node within a community.</rdfs:comment>
        <rdfs:label>Node C</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeD -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeD">
        <rdf:type rdf:resource="http://pygraf.t/ConnectorNode"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeA"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeH"/>
        <rdfs:comment>A connector node linking different classes.</rdfs:comment>
        <rdfs:label>Node D</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeE -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeE">
        <rdf:type rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <bridges rdf:resource="http://pygraf.t/NodeB"/>
        <bridges rdf:resource="http://pygraf.t/NodeF"/>
        <rdfs:comment>An intermediary node bridging classes.</rdfs:comment>
        <rdfs:label>Node E</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeF -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeF">
        <rdf:type rdf:resource="http://pygraf.t/MultiplexNode"/>
        <hasRelationType rdf:resource="http://pygraf.t/linksTo"/>
        <hasRelationType rdf:resource="http://pygraf.t/relatesTo"/>
        <rdfs:comment>A multiplex node involved in multiple relation types.</rdfs:comment>
        <rdfs:label>Node F</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeG -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeG">
        <rdf:type rdf:resource="http://pygraf.t/SuperNode"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeA"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeB"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeC"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeD"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeE"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeF"/>
        <rdfs:comment>A super node with extensive connectivity.</rdfs:comment>
        <rdfs:label>Node G</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeH -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeH">
        <rdf:type rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeD"/>
        <linksTo rdf:resource="http://pygraf.t/NodeD"/>
        <rdfs:comment>An intermediary node connecting to Node D.</rdfs:comment>
        <rdfs:label>Node H</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeI -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeI">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeG"/>
        <connectsTo rdf:resource="http://pygraf.t/NodeJ"/>
        <relatesTo rdf:resource="http://pygraf.t/NodeJ"/>
        <rdfs:comment>Another high-degree node.</rdfs:comment>
        <rdfs:label>Node I</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/NodeJ -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/NodeJ">
        <rdf:type rdf:resource="http://pygraf.t/CentralNode"/>
        <interactsWith rdf:resource="http://pygraf.t/NodeI"/>
        <rdfs:comment>A central node in a different subgraph.</rdfs:comment>
        <rdfs:label>Node J</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/linksTo -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/linksTo"/>
    


    <!-- http://pygraf.t/relatesTo -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/relatesTo"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <rdf:Description rdf:about="http://pygraf.t/linksTo">
        <rdfs:comment>Relation indicating a link or association.</rdfs:comment>
        <rdfs:label>links to</rdfs:label>
    </rdf:Description>
    <rdf:Description rdf:about="http://pygraf.t/relatesTo">
        <rdfs:comment>Generic relation between entities.</rdfs:comment>
        <rdfs:label>relates to</rdfs:label>
    </rdf:Description>
</rdf:RDF>



