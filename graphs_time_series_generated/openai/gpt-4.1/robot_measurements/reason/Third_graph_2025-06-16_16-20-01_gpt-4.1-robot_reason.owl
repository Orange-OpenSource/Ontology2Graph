        <R9 rdf:resource="http://pygraf.t/EntityHighDegree"/>
        <rdfs:comment>A hub node connecting to many other nodes, facilitating communication across the graph.</rdfs:comment>
        <rdfs:label>EntityHub</rdfs:label>
