        <R6 rdf:resource="http://pygraf.t/EntitySuper"/>
        <rdfs:comment>A connector node that links different communities or clusters in the graph.</rdfs:comment>
        <rdfs:label>EntityConnector</rdfs:label>
    </owl:NamedIndividual>
    


