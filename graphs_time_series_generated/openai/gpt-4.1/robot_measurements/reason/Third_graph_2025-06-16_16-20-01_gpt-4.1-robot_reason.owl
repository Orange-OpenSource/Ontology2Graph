        <R9 rdf:resource="http://pygraf.t/EntityCentral"/>
        <R9 rdf:resource="http://pygraf.t/EntityHub"/>
        <rdfs:comment>A high-degree node with multiple direct connections, but not as central as the super node.</rdfs:comment>
        <rdfs:label>EntityHighDegree</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/EntityHub -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/EntityHub">
