    <!-- http://pygraf.t/E2000 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2000">
        <rdf:type rdf:resource="http://pygraf.t/C9"/>
        <R2 rdf:resource="http://pygraf.t/E2001"/>
        <R2 rdf:resource="http://pygraf.t/E2002"/>
        <R2 rdf:resource="http://pygraf.t/E2003"/>
        <R4 rdf:resource="http://pygraf.t/E2010"/>
        <R4 rdf:resource="http://pygraf.t/E2020"/>
        <R4 rdf:resource="http://pygraf.t/E2030"/>
        <R9 rdf:resource="http://pygraf.t/E2100"/>
        <R9 rdf:resource="http://pygraf.t/E2200"/>
        <R9 rdf:resource="http://pygraf.t/E2300"/>
        <rdfs:comment>A hub node with high connectivity, acting as a central point for multiple classes.</rdfs:comment>
        <rdfs:label>Central Hub Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2001 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2001">
        <rdf:type rdf:resource="http://pygraf.t/C2"/>
        <R10 rdf:resource="http://pygraf.t/E2004"/>
        <R10 rdf:resource="http://pygraf.t/E2005"/>
        <R5 rdf:resource="http://pygraf.t/E2000"/>
        <R5 rdf:resource="http://pygraf.t/E2020"/>
        <R5 rdf:resource="http://pygraf.t/E2100"/>
        <R6 rdf:resource="http://pygraf.t/E2040"/>
        <rdfs:comment>A node with many incoming and outgoing relations, representing a highly connected entity.</rdfs:comment>
        <rdfs:label>High-Degree Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2002 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2002">
        <rdf:type rdf:resource="http://pygraf.t/C2"/>
        <R10 rdf:resource="http://pygraf.t/E2006"/>
        <R5 rdf:resource="http://pygraf.t/E2000"/>
        <R5 rdf:resource="http://pygraf.t/E2030"/>
        <R6 rdf:resource="http://pygraf.t/E2050"/>
        <rdfs:comment>A node that connects several subgraphs, acting as a bridge between them.</rdfs:comment>
        <rdfs:label>Central Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2003 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2003">
