        <R7 rdf:resource="http://pygraf.t/E2003"/>
        <R9 rdf:resource="http://pygraf.t/E2100"/>
        <rdfs:comment>A node that participates in multiple types of relations and classes.</rdfs:comment>
        <rdfs:label>Multiplex Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2005 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2005">
