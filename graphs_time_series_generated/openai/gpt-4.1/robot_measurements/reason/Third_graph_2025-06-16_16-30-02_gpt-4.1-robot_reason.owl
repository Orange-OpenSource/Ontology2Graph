        <R5 rdf:resource="http://pygraf.t/E2010"/>
        <R6 rdf:resource="http://pygraf.t/E2060"/>
        <rdfs:comment>A node that links two otherwise separate clusters.</rdfs:comment>
        <rdfs:label>Connector Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2004 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2004">
