@prefix ex: <http://example.com/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

ex:entity1 a sc:C1 ;
    rdfs:label "Entity 1" ;
    rdfs:comment "An instance of C1, related to C3." ;
    sc:R3 ex:entity3 .

ex:entity2 a sc:C2 ;
    rdfs:label "Entity 2" ;
    rdfs:comment "An instance of C2, part of a symmetric relation." ;
    sc:R9 ex:entity4, ex:entity5 .

ex:entity3 a sc:C3 ;
    rdfs:label "Entity 3" ;
    rdfs:comment "An instance of C3, related to C1." ;
    sc:R2 ex:entity1 .

ex:entity4 a sc:C2 ;
    rdfs:label "Entity 4" ;
    rdfs:comment "Another instance of C2, part of a symmetric relation." ;
    sc:R9 ex:entity2, ex:entity5 .

ex:entity5 a sc:C2 ;
    rdfs:label "Entity 5" ;
    rdfs:comment "Yet another instance of C2, part of a symmetric relation." ;
    sc:R9 ex:entity2, ex:entity4 .

ex:entity6 a sc:C4 ;
    rdfs:label "Entity 6" ;
    rdfs:comment "An instance of C4, related to C10." .

ex:entity7 a sc:C5 ;
    rdfs:label "Entity 7" ;
    rdfs:comment "An instance of C5, related to C7." ;
    sc:R6 ex:entity8 .

ex:entity8 a sc:C7 ;
    rdfs:label "Entity 8" ;
    rdfs:comment "An instance of C7, related to C5." ;
    sc:R8 ex:entity7 .

ex:entity9 a sc:C6 ;
    rdfs:label "Entity 9" ;
    rdfs:comment "An instance of C6, a subclass of C8." .

ex:entity10 a sc:C8 ;
    rdfs:label "Entity 10" ;
    rdfs:comment "An instance of C8." .

ex:entity11 a sc:C9 ;
    rdfs:label "Entity 11" ;
    rdfs:comment "An instance of C9, part of a symmetric relation." ;
    sc:R4 ex:entity12 .

ex:entity12 a sc:C9 ;
    rdfs:label "Entity 12" ;
    rdfs:comment "Another instance of C9, part of a symmetric relation." ;
    sc:R4 ex:entity11 .

ex:entity13 a sc:C10 ;
    rdfs:label "Entity 13" ;
    rdfs:comment "An instance of C10, related to C4." ;
    sc:R10 ex:entity6 .

ex:entity14 a sc:C10 ;
    rdfs:label "Entity 14" ;
    rdfs:comment "An isolated instance of C10." .

ex:entity15 a sc:C10 ;
    rdfs:label "Entity 15" ;
    rdfs:comment "Another isolated instance of C10." .

ex:entity16 a sc:C9 ;
    rdfs:label "Entity 16" ;
    rdfs:comment "High-degree node of C9, connected to many other C9 nodes." ;
    sc:R4 ex:entity17, ex:entity18, ex:entity19 .

ex:entity17 a sc:C9 ;
    rdfs:label "Entity 17" ;
    rdfs:comment "C9 node connected to the high-degree node." ;
    sc:R4 ex:entity16 .

ex:entity18 a sc:C9 ;
    rdfs:label "Entity 18" ;
    rdfs:comment "Another C9 node connected to the high-degree node." ;
    sc:R4 ex:entity16 .

ex:entity19 a sc:C9 ;
    rdfs:label "Entity 19" ;
    rdfs:comment "Yet another C9 node connected to the high-degree node." ;
    sc:R4 ex:entity16 .
