@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix example: <http://example.com/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .

# Knowledge Graph describing Applications and Application Modules

example:ApplicationA
    a noria:Application ;
    rdfs:label "Central Application" ;
    rdfs:comment "A core application providing essential services." ;
    noria:applicationModelIdentifier "APP-001" ;
    noria:applicationShortIdentifier "CentralApp" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/core> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Core Services" ;
    noria:applicationFunctionalSubDomain "Centralized Data Processing" .

example:ApplicationB
    a noria:Application ;
    rdfs:label "Reporting Application" ;
    rdfs:comment "An application for generating reports." ;
    noria:applicationModelIdentifier "APP-002" ;
    noria:applicationShortIdentifier "ReportApp" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/reporting> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Analytics" ;
    noria:applicationFunctionalSubDomain "Data Visualization" .

example:ApplicationC
    a noria:Application ;
    rdfs:label "Authentication Service" ;
    rdfs:comment "A service for authenticating users." ;
    noria:applicationModelIdentifier "APP-003" ;
    noria:applicationShortIdentifier "AuthService" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/service> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Security" ;
    noria:applicationFunctionalSubDomain "Identity Management" .

example:ApplicationD
    a noria:Application ;
    rdfs:label "Data Ingestion Application" ;
    rdfs:comment "An application for ingesting data from various sources." ;
    noria:applicationModelIdentifier "APP-004" ;
    noria:applicationShortIdentifier "DataIngest" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/data-processing> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Data Management" ;
    noria:applicationFunctionalSubDomain "ETL Processes" .

example:ApplicationE
    a noria:Application ;
    rdfs:label "Monitoring Application" ;
    rdfs:comment "An application for monitoring system performance." ;
    noria:applicationModelIdentifier "APP-005" ;
    noria:applicationShortIdentifier "MonitorApp" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Operations" ;
    noria:applicationFunctionalSubDomain "System Health Checks" .

example:ModuleA1
    a noria:ApplicationModule ;
    rdfs:label "Central Application - Production" ;
    rdfs:comment "Production instance of the Central Application." ;
    noria:applicationModuleOf example:ApplicationA ;
    noria:applicationModuleName "CentralApp_Prod" ;
    noria:applicationModuleIdentifier "MOD-001" ;
    noria:applicationModuleAdministrationTeam example:TeamAlpha ;
    noria:applicationModuleSupportTeam example:TeamBeta ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/gold> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/in-production> .

