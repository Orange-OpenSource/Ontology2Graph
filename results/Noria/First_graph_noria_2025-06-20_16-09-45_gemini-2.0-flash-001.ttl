example:ApplicationA seas:subSystemOf example:ServiceX .
example:ApplicationB seas:subSystemOf example:ServiceX .
example:ApplicationC seas:subSystemOf example:ServiceY .
example:ApplicationD seas:subSystemOf example:ServiceY .
example:ApplicationE seas:subSystemOf example:ServiceZ .

example:ServiceX
    a noria:Service ;
    rdfs:label "Core Service X" ;
    rdfs:comment "A core service composed of Central and Reporting Applications." ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/internal> .

example:ServiceY
    a noria:Service ;
    rdfs:label "Security Service Y" ;
    rdfs:comment "A security service composed of Authentication and Data Ingestion Applications." ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/customer-facing> .

example:ServiceZ
    a noria:Service ;
    rdfs:label "Monitoring Service Z" ;
    rdfs:comment "A monitoring service composed of Monitoring Application." ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/internal> .
