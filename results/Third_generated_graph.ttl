 @prefix dcterms: <http://purl.org/dc/terms/> .
 @prefix owl: <http://www.w3.org/2002/07/owl#> .
 @prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
 @prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
 @prefix sc: <http://pygraf.t/> .

 sc: a owl:Ontology ;
  dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

 # Entities and their relationships

 sc:EntityA a sc:C1 ;
  rdfs:label "Entity A" ;
  rdfs:comment "A central node of type C1." ;
  sc:R1 sc:EntityA , sc:EntityB , sc:EntityC , sc:EntityD , sc:EntityE , sc:EntityF , sc:EntityG , sc:EntityH , sc:EntityI , sc:EntityJ , sc:EntityK , sc:EntityL , sc:EntityM , sc:EntityN , sc:EntityO , sc:EntityP , sc:EntityQ , sc:EntityR , sc:EntityS , sc:EntityT .

 sc:EntityB a sc:C2 ;
  rdfs:label "Entity B" ;
  rdfs:comment "A connector node of type C2." ;
  sc:R9 sc:EntityC , sc:EntityD .

 sc:EntityC a sc:C3 ;
  rdfs:label "Entity C" ;
  rdfs:comment "An intermediary node of type C3." ;
  sc:R2 sc:EntityA .

 sc:EntityD a sc:C4 ;
  rdfs:label "Entity D" ;
  rdfs:comment "A high-degree node of type C4." ;
  sc:R1 sc:EntityE , sc:EntityF .

 sc:EntityE a sc:C5 ;
  rdfs:label "Entity E" ;
  rdfs:comment "A multiplex node of type C5." ;
  sc:R6 sc:EntityG .

 sc:EntityF a sc:C6 ;
  rdfs:label "Entity F" ;
  rdfs:comment "A hub node of type C6." ;
  sc:R7 sc:EntityB .

 sc:EntityG a sc:C7 ;
  rdfs:label "Entity G" ;
  rdfs:comment "A connector node of type C7." ;
  sc:R8 sc:EntityH .

 sc:EntityH a sc:C8 ;
  rdfs:label "Entity H" ;
  rdfs:comment "An intermediary node of type C8." ;
  sc:R1 sc:EntityI .

 sc:EntityI a sc:C9 ;
  rdfs:label "Entity I" ;
  rdfs:comment "A high-degree node of type C9." ;
  sc:R4 sc:EntityJ .

 sc:EntityJ a sc:C10 ;
  rdfs:label "Entity J" ;
  rdfs:comment "A hub node of type C10." ;
  sc:R6 sc:EntityK .

 sc:EntityK a sc:C1 ;
  rdfs:label "Entity K" ;
  rdfs:comment "A connector node of type C1." ;
  sc:R1 sc:EntityL .

 sc:EntityL a sc:C2 ;
  rdfs:label "Entity L" ;
  rdfs:comment "An intermediary node of type C2." ;
  sc:R9 sc:EntityM .

 sc:EntityM a sc:C3 ;
  rdfs:label "Entity M" ;
  rdfs:comment "A high-degree node of type C3." ;
  sc:R2 sc:EntityN .

 sc:EntityN a sc:C4 ;
  rdfs:label "Entity N" ;
  rdfs:comment "A hub node of type C4." ;
  sc:R1 sc:EntityO .

 sc:EntityO a sc:C5 ;
  rdfs:label "Entity O" ;
  rdfs:comment "A connector node of type C5." ;
  sc:R6 sc:EntityP .

 sc:EntityP a sc:C6 ;
  rdfs:label "Entity P" ;
  rdfs:comment "An intermediary node of type C6." ;
  sc:R7 sc:EntityQ .

 sc:EntityQ a sc:C7 ;
  rdfs:label "Entity Q" ;
  rdfs:comment "A high-degree node of type C7." ;
  sc:R8 sc:EntityR .

 sc:EntityR a sc:C8 ;
  rdfs:label "Entity R" ;
  rdfs:comment "A hub node of type C8." ;
  sc:R1 sc:EntityS .

 sc:EntityS a sc:C9 ;
  rdfs:label "Entity S" ;
  rdfs:comment "A connector node of type C9." ;
  sc:R4 sc:EntityT .

 sc:EntityT a sc:C10 ;
  rdfs:label "Entity T" ;
  rdfs:comment "An intermediary node of type C10." ;
  sc:R6 sc:EntityA .

 sc:IsolatedEntity1 a sc:C10 ;
  rdfs:label "Isolated Entity 1" ;
  rdfs:comment "An isolated node of type C10." .

 sc:IsolatedEntity2 a sc:C3 ;
  rdfs:label "Isolated Entity 2" ;
  rdfs:comment "An isolated node of type C3." .

 sc:SuperNode a sc:C9 ;
  rdfs:label "Super Node" ;
  rdfs:comment "A super node of type C9, connected to many other nodes." ;
  sc:R4 sc:EntityA , sc:EntityB , sc:EntityC , sc:EntityD , sc:EntityE , sc:EntityF , sc:EntityG , sc:EntityH , sc:EntityI , sc:EntityJ .

 sc:EntityU a sc:C10 ;
  rdfs:label "Entity U" ;
  rdfs:comment "A node of type C10 connected to the super node." ;
  sc:R6 sc:SuperNode .

 sc:EntityV a sc:C3 ;
  rdfs:label "Entity V" ;
  rdfs:comment "A node of type C3 connected to the super node." ;
  sc:R2 sc:SuperNode .

 sc:EntityW a sc:C4 ;
  rdfs:label "Entity W" ;
  rdfs:comment "A node of type C4 connected to the super node." ;
  sc:R1 sc:SuperNode .

 sc:EntityX a sc:C5 ;
  rdfs:label "Entity X" ;
  rdfs:comment "A node of type C5 connected to the super node." ;
  sc:R6 sc:SuperNode .

 sc:EntityY a sc:C6 ;
  rdfs:label "Entity Y" ;
  rdfs:comment "A node of type C6 connected to the super node." ;
  sc:R7 sc:SuperNode .

 sc:EntityZ a sc:C7 ;
  rdfs:label "Entity Z" ;
  rdfs:comment "A node of type C7 connected to the super node." ;
  sc:R8 sc:SuperNode .
