@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Central Hub Node
sc:E2000 a sc:C10 ;
    rdfs:label "Central Hub" ;
    rdfs:comment "A central hub node with multiple connections across different categories." ;
    sc:R6 sc:E2001, sc:E2002, sc:E2003 .

# Connector Node
sc:E2001 a sc:C5 ;
    rdfs:label "Connector Node Alpha" ;
    rdfs:comment "Connector node facilitating relationships between C5 class entities." ;
    sc:R2 sc:E2004 .

# Multiplex Node
sc:E2002 a sc:C9 ;
    rdfs:label "Multiplex Node Beta" ;
    rdfs:comment "Multiplex node participating in multiple relationships within C9 class." ;
    sc:R9 sc:E2005, sc:E2006 ;
    sc:R1 sc:E2007 .

# Super Node
sc:E2003 a sc:C10 ;
    rdfs:label "Super Node Gamma" ;
    rdfs:comment "Super node with extensive connections and influence across the graph." ;
    sc:R6 sc:E2008 .

# Hub Node
sc:E2004 a sc:C7 ;
    rdfs:label "Hub Node Delta" ;
    rdfs:comment "Hub node connecting various high-degree nodes." ;
    sc:R4 sc:E2000 .

# High-Degree Node
sc:E2005 a sc:C3 ;
    rdfs:label "High-Degree Node Epsilon" ;
    rdfs:comment "High-degree node with numerous outgoing and incoming relationships." ;
    sc:R3 sc:E2001, sc:E2002 ;
    sc:R4 sc:E2006 .

# Central Node
sc:E2006 a sc:C4 ;
    rdfs:label "Central Node Zeta" ;
    rdfs:comment "Central node acting as a key point for information flow." ;
    sc:R5 sc:E2003 ;
    sc:R1 sc:E2007 .

# Connector Node
sc:E2007 a sc:C1 ;
    rdfs:label "Connector Node Eta" ;
    rdfs:comment "Connector node bridging two distinct clusters within the graph." ;
    sc:R2 sc:E2008 ;
    sc:R4 sc:E2004 .

# Intermediary Node
sc:E2008 a sc:C2 ;
    rdfs:label "Intermediary Node Theta" ;
    rdfs:comment "Intermediary node facilitating indirect relationships between other nodes." ;
    sc:R3 sc:E2000 ;
    sc:R5 sc:E2005 .

# Multiplex Node
sc:E2009 a sc:C9 ;
    rdfs:label "Multiplex Node Iota" ;
    rdfs:comment "Multiplex node engaging in various types of relationships simultaneously." ;
    sc:R1 sc:E2010, sc:E2011 ;
    sc:R6 sc:E2012 .

# Super Node
sc:E2010 a sc:C10 ;
    rdfs:label "Super Node Kappa" ;
    rdfs:comment "Super node with significant influence and connectivity across multiple classes." ;
    sc:R6 sc:E2000, sc:E2003 .

# Connector Node with Few Isolated Nodes
sc:E2011 a sc:C5 ;
    rdfs:label "Connector Node Lambda" ;
    rdfs:comment "Connector node with limited but crucial connections." ;
    sc:R2 sc:E2013 .

sc:E2012 a sc:C10 ;
    rdfs:label "Isolated Node Sigma" ;
    rdfs:comment "A rarely connected isolated node within the knowledge graph." .

# Intermediary Node
sc:E2013 a sc:C3 ;
    rdfs:label "Intermediary Node Mu" ;
    rdfs:comment "Intermediary node serving as a bridge between different network segments." ;
    sc:R3 sc:E2005 ;
    sc:R4 sc:E2006 .

# High-Degree Node
sc:E2014 a sc:C9 ;
    rdfs:label "High-Degree Node Nu" ;
    rdfs:comment "High-degree node with numerous connections enhancing network density." ;
    sc:R9 sc:E2002, sc:E2009 ;
    sc:R1 sc:E2015 .

# Hub Node
sc:E2015 a sc:C7 ;
    rdfs:label "Hub Node Xi" ;
    rdfs:comment "Hub node acting as a central point for dynamic interactions." ;
    sc:R4 sc:E2014 ;
    sc:R2 sc:E2001 .

# Central Node
sc:E2016 a sc:C4 ;
    rdfs:label "Central Node Omicron" ;
    rdfs:comment "Central node pivotal for maintaining the structural integrity of the graph." ;
    sc:R5 sc:E2007 ;
    sc:R1 sc:E2017 .

# Final Node Definitions
sc:E2017 a sc:C1 ;
    rdfs:label "Connector Node Pi" ;
    rdfs:comment "Final connector node ensuring seamless communication across clusters." ;
    sc:R2 sc:E2016 ;
    sc:R4 sc:E2010 .
