@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Entities of Class C1
sc:E1 a sc:C1 ;
    rdfs:label "Entity 1"@en ;
    rdfs:comment "A basic entity of type C1."@en ;
    sc:R3 sc:E3 .

sc:E2 a sc:C1 ;
    rdfs:label "Entity 2"@en ;
    rdfs:comment "Another entity of type C1."@en ;
    sc:R6 sc:E4 .

# Entities of Class C2
sc:E3 a sc:C2 ;
    rdfs:label "Entity 3"@en ;
    rdfs:comment "A basic entity of type C2."@en ;
    sc:R5 sc:E5 .

sc:E4 a sc:C2 ;
    rdfs:label "Entity 4"@en ;
    rdfs:comment "Another entity of type C2."@en ;
    sc:R9 sc:E6 .

# Entities of Class C3
sc:E5 a sc:C3 ;
    rdfs:label "Entity 5"@en ;
    rdfs:comment "A basic entity of type C3."@en ;
    sc:R2 sc:E1 .

sc:E6 a sc:C3 ;
    rdfs:label "Entity 6"@en ;
    rdfs:comment "Another entity of type C3."@en ;
    sc:R1 sc:E7 .

# Entities of Class C4
sc:E7 a sc:C4 ;
    rdfs:label "Entity 7"@en ;
    rdfs:comment "A basic entity of type C4."@en ;
    sc:R1 sc:E8 .

sc:E8 a sc:C4 ;
    rdfs:label "Entity 8"@en ;
    rdfs:comment "Another entity of type C4."@en ;
    sc:R6 sc:E9 .

# Entities of Class C5
sc:E9 a sc:C5 ;
    rdfs:label "Entity 9"@en ;
    rdfs:comment "A basic entity of type C5."@en ;
    sc:R6 sc:E10 .

sc:E10 a sc:C5 ;
    rdfs:label "Entity 10"@en ;
    rdfs:comment "Another entity of type C5."@en ;
    sc:R9 sc:E11 .

# Entities of Class C6
sc:E11 a sc:C6 ;
    rdfs:label "Entity 11"@en ;
    rdfs:comment "A basic entity of type C6."@en ;
    sc:R7 sc:E3 .

sc:E12 a sc:C6 ;
    rdfs:label "Entity 12"@en ;
    rdfs:comment "Another entity of type C6."@en ;
    sc:R7 sc:E4 .

# Entities of Class C7
sc:E13 a sc:C7 ;
    rdfs:label "Entity 13"@en ;
    rdfs:comment "A basic entity of type C7."@en ;
    sc:R8 sc:E9 .

sc:E14 a sc:C7 ;
    rdfs:label "Entity 14"@en ;
    rdfs:comment "Another entity of type C7."@en ;
    sc:R8 sc:E10 .

# Entities of Class C8
sc:E15 a sc:C8 ;
    rdfs:label "Entity 15"@en ;
    rdfs:comment "A basic entity of type C8."@en ;
    sc:R9 sc:E16 .

sc:E16 a sc:C8 ;
    rdfs:label "Entity 16"@en ;
    rdfs:comment "Another entity of type C8."@en ;
    sc:R9 sc:E17 .

# Entities of Class C9
sc:E17 a sc:C9 ;
    rdfs:label "Entity 17"@en ;
    rdfs:comment "A basic entity of type C9."@en ;
    sc:R4 sc:E18 .

sc:E18 a sc:C9 ;
    rdfs:label "Entity 18"@en ;
    rdfs:comment "Another entity of type C9."@en ;
    sc:R4 sc:E19 .

# Entities of Class C10
sc:E19 a sc:C10 ;
    rdfs:label "Entity 19"@en ;
    rdfs:comment "A basic entity of type C10."@en ;
    sc:R10 sc:E7 .

sc:E20 a sc:C10 ;
    rdfs:label "Entity 20"@en ;
    rdfs:comment "Another entity of type C10."@en ;
    sc:R10 sc:E8 .

# Hub Node (C9) - Connects to many other nodes
sc:E21 a sc:C9 ;
    rdfs:label "Hub Node"@en ;
    rdfs:comment "A hub node connecting multiple entities."@en ;
    sc:R4 sc:E1, sc:E2, sc:E3, sc:E4, sc:E5, sc:E6, sc:E7, sc:E8, sc:E9, sc:E10 .

# High-Degree Node (C10) - Many incoming/outgoing relations
sc:E22 a sc:C10 ;
    rdfs:label "High-Degree Node"@en ;
    rdfs:comment "A node with many relationships."@en ;
    sc:R1 sc:E1, sc:E2 ;
    sc:R6 sc:E3, sc:E4 .

# Central Node (C4) - Connects to many other nodes
sc:E23 a sc:C4 ;
    rdfs:label "Central Node"@en ;
    rdfs:comment "A central node connecting multiple entities."@en ;
    sc:R1 sc:E1, sc:E2, sc:E3, sc:E4, sc:E5, sc:E6, sc:E7, sc:E8, sc:E9, sc:E10 .

# Connector Node (C3) - Connects different parts of the graph
sc:E24 a sc:C3 ;
    rdfs:label "Connector Node"@en ;
    rdfs:comment "A connector node linking different entities."@en ;
    sc:R2 sc:E1, sc:E2 ;
    sc:R1 sc:E3, sc:E4 .

# Intermediary Node (C2) - Lies on paths between other nodes
sc:E25 a sc:C2 ;
    rdfs:label "Intermediary Node"@en ;
    rdfs:comment "An intermediary node between other entities."@en ;
    sc:R5 sc:E5 ;
    sc:R9 sc:E6 .

# Multiplex Node (C1) - Participates in multiple types of relations
sc:E26 a sc:C1 ;
    rdfs:label "Multiplex Node"@en ;
    rdfs:comment "A node participating in multiple relation types."@en ;
    sc:R3 sc:E3 ;
    sc:R6 sc:E4 .

# Super Node (C10) - Connects to many nodes of different types
sc:E27 a sc:C10 ;
    rdfs:label "Super Node"@en ;
    rdfs:comment "A super node connecting to various entity types."@en ;
    sc:R10 sc:E11 ;
    sc:R6 sc:E1, sc:E2, sc:E3, sc:E4, sc:E5, sc:E6, sc:E7, sc:E8, sc:E9, sc:E10 .

# Additional connections to demonstrate relations
sc:E1 sc:R1 sc:E1 . # Reflexive relation
sc:E2 sc:R4 sc:E2 . # Symmetric relation
sc:E3 sc:R3 sc:E3 . # Reflexive relation
sc:E4 sc:R9 sc:E4 . # Symmetric relation
sc:E5 sc:R1 sc:E5 . # Reflexive relation
sc:E6 sc:R4 sc:E6 . # Symmetric relation
sc:E7 sc:R1 sc:E7 . # Reflexive relation
sc:E8 sc:R4 sc:E8 . # Symmetric relation
sc:E9 sc:R1 sc:E9 . # Reflexive relation
sc:E10 sc:R4 sc:E10 . # Symmetric relation
