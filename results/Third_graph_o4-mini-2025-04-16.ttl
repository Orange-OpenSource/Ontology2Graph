@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc:     <http://pygraf.t/> .

sc:   a owl:Ontology ;
     dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

sc:Hub1 
    a sc:C9 ;
    rdfs:label   "Hub Node" ;
    rdfs:comment "A hub connecting multiple key nodes" ;
    sc:R4 sc:Central1, sc:Multiplex1 ;
    sc:R9 sc:Super1 .

sc:Central1
    a sc:C10 ;
    rdfs:label   "Central Node" ;
    rdfs:comment "Core of the network" ;
    sc:R4 sc:Hub1 ;
    sc:R10 sc:High1 ;
    sc:R6 sc:Super1 .

sc:High1
    a sc:C4 ;
    rdfs:label   "High-degree Node" ;
    rdfs:comment "Node with many connections" ;
    sc:R3 sc:Connector1 ;
    sc:R6 sc:Central1 ;
    sc:R4 sc:Hub1 .

sc:Connector1
    a sc:C3 ;
    rdfs:label   "Connector Node" ;
    rdfs:comment "Bridges between nodes" ;
    sc:R2 sc:High1 ;
    sc:R5 sc:Multiplex1 .

sc:Inter1
    a sc:C5 ;
    rdfs:label   "Intermediary Node" ;
    rdfs:comment "Mediates connections" ;
    sc:R6 sc:InterTarget .

sc:InterTarget
    a sc:C7 ;
    rdfs:label   "Intermediary Target" ;
    rdfs:comment "Endpoint for intermediary node" ;
    sc:R8 sc:Inter1 .

sc:Multiplex1
    a sc:C2 ;
    rdfs:label   "Multiplex Node" ;
    rdfs:comment "Multiplexing data streams" ;
    sc:R9 sc:Hub1 ;
    sc:R2 sc:Super1 .

sc:Super1
    a sc:C6 ;
    rdfs:label   "Super Node" ;
    rdfs:comment "Highest-level node" ;
    sc:R7 sc:Multiplex1 ;
    sc:R4 sc:Hub1 .