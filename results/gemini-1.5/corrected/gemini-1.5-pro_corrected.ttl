@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .


sc:Entity1 a sc:C1 ;
    rdfs:label "Entity 1 - Connector" ;
    rdfs:comment "Connects C1 and C3 clusters." ;
    sc:R3 sc:Entity3 .


sc:Entity2 a sc:C2 ;
    rdfs:label "Entity 2 - Multiplex" ;
    rdfs:comment "Multiple relations with various classes." ;
    sc:R5 sc:Entity4 ;
    sc:R9 sc:Entity5 ;
    sc:R10 sc:Entity6 .


sc:Entity3 a sc:C3 ;
    rdfs:label "Entity 3 - Hub" ;
    rdfs:comment "Central node in C3, connected to many C1 instances." ;
    sc:R2 sc:Entity7 , sc:Entity8 , sc:Entity9 .


sc:Entity4 a sc:C9 ;
    rdfs:label "Entity 4 - Supernode" ;
    rdfs:comment "Aggregates information from multiple C8 subclasses." ;
    sc:R4 sc:Entity10 ;
    sc:R9 sc:Entity11 , sc:Entity12 .


sc:Entity5 a sc:C2 ;
    rdfs:label "Entity 5 - High-Degree" ;
    rdfs:comment "Many connections within C2." ;
    sc:R9 sc:Entity13 , sc:Entity14 , sc:Entity15 .


sc:Entity6 a sc:C6 ;
    rdfs:label "Entity 6 - Intermediary" ;
    rdfs:comment "Bridges between C2 and C8 through R10/R7." ;
    sc:R7 sc:Entity16 .


sc:Entity7 a sc:C1 ;
    rdfs:label "Entity 7" ;
    rdfs:comment "Example of a C1 instance." .


sc:Entity8 a sc:C1 ;
    rdfs:label "Entity 8" ;
    rdfs:comment "Another C1 instance." .


sc:Entity9 a sc:C1 ;
    rdfs:label "Entity 9" ;
    rdfs:comment "Yet another C1 instance." .


sc:Entity10 a sc:C8 ;
    rdfs:label "Entity 10 - Central Node" ;
    rdfs:comment "Key node within the C8 hierarchy." ;
    sc:R9 sc:Entity12 .


sc:Entity11 a sc:C8 ;
    rdfs:label "Entity 11" ;
    rdfs:comment "Example of a C8 subclass instance." .


sc:Entity12 a sc:C5 ;
    rdfs:label "Entity 12" ;
    rdfs:comment "Example of a C5 instance (subclass of C9)." ;
    sc:R6 sc:Entity17 .


sc:Entity13 a sc:C2 ;
    rdfs:label "Entity 13" ;
    rdfs:comment "Another C2 instance." .


sc:Entity14 a sc:C2 ;
    rdfs:label "Entity 14" ;
    rdfs:comment "Yet another C2 instance." .


sc:Entity15 a sc:C2 ;
    rdfs:label "Entity 15" ;
    rdfs:comment "And another C2 instance." .


sc:Entity16 a sc:C2 ;
    rdfs:label "Entity 16" ;
    rdfs:comment "One more C2 instance." .


sc:Entity17 a sc:C7 ;
    rdfs:label "Entity 17" ;
    rdfs:comment "Example of a C7 instance (subclass of C8)." ;
    sc:R8 sc:Entity18 .


sc:Entity18 a sc:C7 ;
    rdfs:label "Entity 18" ;
    rdfs:comment "Another C7 instance." .

