@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# --- Hub Node ---
sc:E2000 a sc:C9 ;
    rdfs:label "Central Hub Node" ;
    rdfs:comment "A hub node with high connectivity, linking multiple classes and acting as a central point in the graph." ;
    sc:R2 sc:E2001, sc:E2002, sc:E2003 ;
    sc:R4 sc:E2010, sc:E2020 ;
    sc:R9 sc:E2021, sc:E2022, sc:E2023 .

# --- High-degree Node ---
sc:E2001 a sc:C2 ;
    rdfs:label "High-degree Node Alpha" ;
    rdfs:comment "A high-degree node with many connections, representing a key entity in the network." ;
    sc:R10 sc:E2004, sc:E2005 ;
    sc:R5 sc:E2000, sc:E2020 ;
    sc:R9 sc:E2022 .

# --- Central Node ---
sc:E2002 a sc:C2 ;
    rdfs:label "Central Node Beta" ;
    rdfs:comment "A central node that connects to both the hub and other intermediary nodes." ;
    sc:R10 sc:E2006 ;
    sc:R5 sc:E2000 ;
    sc:R9 sc:E2021 .

# --- Connector Node ---
sc:E2003 a sc:C2 ;
    rdfs:label "Connector Node Gamma" ;
    rdfs:comment "A connector node bridging the hub and a multiplex node." ;
    sc:R10 sc:E2007 ;
    sc:R5 sc:E2000 ;
    sc:R9 sc:E2023 .

# --- Intermediary Node ---
sc:E2004 a sc:C6 ;
    rdfs:label "Intermediary Node Delta" ;
    rdfs:comment "An intermediary node facilitating connections between high-degree and multiplex nodes." ;
    sc:R7 sc:E2001, sc:E2008 ;
    sc:R9 sc:E2022 .

# --- Intermediary Node ---
sc:E2005 a sc:C6 ;
    rdfs:label "Intermediary Node Epsilon" ;
    rdfs:comment "Another intermediary node, linking high-degree and super nodes." ;
    sc:R7 sc:E2001, sc:E2009 ;
    sc:R9 sc:E2023 .

# --- Intermediary Node ---
sc:E2006 a sc:C6 ;
    rdfs:label "Intermediary Node Zeta" ;
    rdfs:comment "Intermediary node between central and multiplex nodes." ;
    sc:R7 sc:E2002, sc:E2008 ;
    sc:R9 sc:E2021 .

# --- Intermediary Node ---
sc:E2007 a sc:C6 ;
    rdfs:label "Intermediary Node Eta" ;
    rdfs:comment "Intermediary node between connector and multiplex nodes." ;
    sc:R7 sc:E2003, sc:E2008 ;
    sc:R9 sc:E2023 .

# --- Multiplex Node ---
sc:E2008 a sc:C8 ;
    rdfs:label "Multiplex Node Theta" ;
    rdfs:comment "A multiplex node connecting to several intermediary nodes and a super node." ;
    sc:R3 sc:E2004, sc:E2006, sc:E2007 ;
    sc:R4 sc:E2011 ;
    sc:R9 sc:E2021, sc:E2022 .

# --- Super Node ---
sc:E2009 a sc:C6 ;
    rdfs:label "Super Node Lambda" ;
    rdfs:comment "A super node with connections to intermediary, multiplex, and hub nodes." ;
    sc:R7 sc:E2005, sc:E2010, sc:E2008 ;
    sc:R9 sc:E2023 .

# --- Hub's Peer Node ---
sc:E2010 a sc:C9 ;
    rdfs:label "Hub Peer Node" ;
    rdfs:comment "A peer node to the hub, forming a symmetric relationship." ;
    sc:R4 sc:E2000 ;
    sc:R9 sc:E2022 .

# --- Multiplex's Peer Node ---
sc:E2011 a sc:C8 ;
    rdfs:label "Multiplex Peer Node" ;
    rdfs:comment "A peer node to the multiplex node, forming a symmetric relationship." ;
    sc:R4 sc:E2008 ;
    sc:R9 sc:E2021 .

# --- Class C5 Node ---
sc:E2020 a sc:C5 ;
    rdfs:label "C5 Node Sigma" ;
    rdfs:comment "A node of class C5, connected to the hub and a C7 node." ;
    sc:R2 sc:E2001 ;
    sc:R6 sc:E2024 ;
    sc:R9 sc:E2000 .

# --- Class C7 Node ---
sc:E2024 a sc:C7 ;
    rdfs:label "C7 Node Omega" ;
    rdfs:comment "A node of class C7, connected to a C5 node and another C7 node." ;
    sc:R8 sc:E2025 ;
    sc:R6 sc:E2020 .

# --- C7 Peer Node ---
sc:E2025 a sc:C7 ;
    rdfs:label "C7 Peer Node" ;
    rdfs:comment "A peer node to the C7 node, forming a symmetric relationship." ;
    sc:R8 sc:E2024 .

# --- C9 Node for R9 relations ---
sc:E2021 a sc:C9 ;
    rdfs:label "C9 Node Pi" ;
    rdfs:comment "A C9 node involved in R9 symmetric relations with hub, central, and multiplex nodes." ;
    sc:R9 sc:E2000, sc:E2002, sc:E2008, sc:E2011 .

sc:E2022 a sc:C9 ;
    rdfs:label "C9 Node Rho" ;
    rdfs:comment "A C9 node involved in R9 symmetric relations with hub, high-degree, and multiplex nodes." ;
    sc:R9 sc:E2000, sc:E2001, sc:E2004, sc:E2008 .

sc:E2023 a sc:C9 ;
    rdfs:label "C9 Node Tau" ;
    rdfs:comment "A C9 node involved in R9 symmetric relations with hub, connector, and super nodes." ;
    sc:R9 sc:E2000, sc:E2003, sc:E2005, sc:E2007, sc:E2009 .

# --- C4 Node (for R10 domain/range) ---
sc:E2030 a sc:C4 ;
    rdfs:label "C4 Node Upsilon" ;
    rdfs:comment "A node of class C4, target of R10 from a C10 node." ;
    sc:R4 sc:E2031 .

# --- C10 Node (for R10 domain/range) ---
sc:E2031 a sc:C10 ;
    rdfs:label "C10 Node Phi" ;
    rdfs:comment "A node of class C10, source of R10 to a C4 node." ;
    sc:R10 sc:E2030 .

# --- C1 Node (subclass of C4) ---
sc:E2040 a sc:C1 ;
    rdfs:label "C1 Node Chi" ;
    rdfs:comment "A node of class C1, subclass of C4, connected to a C3 node." ;
    sc:R3 sc:E2041 ;
    sc:R4 sc:E2042 .

# --- C3 Node (subclass of C10) ---
sc:E2041 a sc:C3 ;
    rdfs:label "C3 Node Psi" ;
    rdfs:comment "A node of class C3, subclass of C10, connected to a C1 node and a C9 node." ;
    sc:R2 sc:E2040 ;
    sc:R4 sc:E2042 .

# --- C9 Node (for C1/C3/C9 triangle) ---
sc:E2042 a sc:C9 ;
    rdfs:label "C9 Node Omega" ;
    rdfs:comment "A C9 node connecting C1 and C3 nodes via R4." ;
    sc:R4 sc:E2040, sc:E2041 .

# --- C8 Node (subclass of C9) ---
sc:E2050 a sc:C8 ;
    rdfs:label "C8 Node AlphaPrime" ;
    rdfs:comment "A node of class C8, subclass of C9, connected to a C9 node and a C6 node." ;
    sc:R4 sc:E2021 ;
    sc:R3 sc:E2051 .

# --- C6 Node (subclass of C8) ---
sc:E2051 a sc:C6 ;
    rdfs:label "C6 Node BetaPrime" ;
    rdfs:comment "A node of class C6, subclass of C8, connected to a C8 node and a C2 node." ;
    sc:R7 sc:E2050 ;
    sc:R10 sc:E2002 .

# --- C10 Node (super node, connects to many) ---
sc:E2060 a sc:C10 ;
    rdfs:label "C10 Super Node" ;
    rdfs:comment "A super node of class C10, connecting to C4, C1, C3, and C9 nodes." ;
    sc:R6 sc:E2030, sc:E2040, sc:E2041, sc:E2021 .

# --- C4 Node (connected to super node) ---
sc:E2061 a sc:C4 ;
    rdfs:label "C4 Node SigmaPrime" ;
    rdfs:comment "A C4 node connected to the C10 super node." ;
    sc:R6 sc:E2060 .

# --- C1 Node (connected to super node) ---
sc:E2062 a sc:C1 ;
    rdfs:label "C1 Node DeltaPrime" ;
    rdfs:comment "A C1 node connected to the C10 super node." ;
    sc:R6 sc:E2060 .

# --- C3 Node (connected to super node) ---
sc:E2063 a sc:C3 ;
    rdfs:label "C3 Node EpsilonPrime" ;
    rdfs:comment "A C3 node connected to the C10 super node." ;
    sc:R6 sc:E2060 .

# --- C9 Node (connected to super node) ---
sc:E2064 a sc:C9 ;
    rdfs:label "C9 Node ZetaPrime" ;
    rdfs:comment "A C9 node connected to the C10 super node." ;
    sc:R6 sc:E2060 .
