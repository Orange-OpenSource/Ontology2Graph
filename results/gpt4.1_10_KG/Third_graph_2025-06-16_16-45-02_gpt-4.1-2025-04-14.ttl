@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Super Node: Highly connected, central to the graph
sc:E100 a sc:C10 ;
    rdfs:label "Super Node Alpha" ;
    rdfs:comment "A super node with the highest degree, connecting to many other nodes and acting as a central hub." ;
    sc:R1 sc:E101, sc:E102, sc:E103, sc:E104, sc:E105 ;
    sc:R4 sc:E200, sc:E300 ;
    sc:R6 sc:E400, sc:E500 .

# Hub Node: Connects to many, but not as central as the super node
sc:E101 a sc:C9 ;
    rdfs:label "Hub Node Beta" ;
    rdfs:comment "A hub node in the network, connecting to several intermediary and connector nodes." ;
    sc:R2 sc:E201, sc:E202 ;
    sc:R4 sc:E102, sc:E103 ;
    sc:R9 sc:E301, sc:E302 .

# High-degree Node: Many direct connections, not necessarily central
sc:E102 a sc:C3 ;
    rdfs:label "High-degree Node Gamma" ;
    rdfs:comment "A high-degree node with multiple direct relationships to other nodes." ;
    sc:R1 sc:E104, sc:E105, sc:E106 ;
    sc:R4 sc:E101 ;
    sc:R6 sc:E201 .

# Central Node: Bridges different communities
sc:E103 a sc:C4 ;
    rdfs:label "Central Node Delta" ;
    rdfs:comment "A central node that bridges the hub and super node, as well as several connectors." ;
    sc:R1 sc:E100, sc:E101 ;
    sc:R4 sc:E201 ;
    sc:R6 sc:E202 .

# Connector Node: Connects two or more clusters
sc:E104 a sc:C10 ;
    rdfs:label "Connector Node Epsilon" ;
    rdfs:comment "A connector node linking the super node, high-degree node, and an intermediary node." ;
    sc:R1 sc:E100, sc:E102 ;
    sc:R4 sc:E202 ;
    sc:R6 sc:E203 .

# Intermediary Node: Lies on many shortest paths
sc:E105 a sc:C10 ;
    rdfs:label "Intermediary Node Zeta" ;
    rdfs:comment "An intermediary node that is frequently traversed in paths between other nodes." ;
    sc:R1 sc:E100, sc:E102 ;
    sc:R4 sc:E203 ;
    sc:R6 sc:E204 .

# Multiplex Node: Belongs to multiple classes
sc:E106 a sc:C1, sc:C4 ;
    rdfs:label "Multiplex Node Eta" ;
    rdfs:comment "A multiplex node, instance of multiple classes, connecting different types of nodes." ;
    sc:R1 sc:E102 ;
    sc:R3 sc:E205 ;
    sc:R6 sc:E300 .

# Intermediary Node
sc:E201 a sc:C10 ;
    rdfs:label "Intermediary Node Theta" ;
    rdfs:comment "An intermediary node connecting the hub, high-degree, and central nodes." ;
    sc:R1 sc:E101, sc:E102 ;
    sc:R4 sc:E103 ;
    sc:R6 sc:E301 .

# Connector Node
sc:E202 a sc:C9 ;
    rdfs:label "Connector Node Iota" ;
    rdfs:comment "A connector node linking the hub, central, and another connector node." ;
    sc:R2 sc:E101 ;
    sc:R4 sc:E104 ;
    sc:R9 sc:E302 ;
    sc:R6 sc:E103 .

# Intermediary Node
sc:E203 a sc:C10 ;
    rdfs:label "Intermediary Node Kappa" ;
    rdfs:comment "An intermediary node between connector and high-degree nodes." ;
    sc:R1 sc:E104 ;
    sc:R4 sc:E105 ;
    sc:R6 sc:E303 .

# Intermediary Node
sc:E204 a sc:C10 ;
    rdfs:label "Intermediary Node Lambda" ;
    rdfs:comment "An intermediary node between the intermediary and multiplex nodes." ;
    sc:R1 sc:E105 ;
    sc:R4 sc:E205 ;
    sc:R6 sc:E304 .

# Multiplex Node
sc:E205 a sc:C3, sc:C1 ;
    rdfs:label "Multiplex Node Mu" ;
    rdfs:comment "A multiplex node, instance of two classes, connecting intermediary and multiplex nodes." ;
    sc:R1 sc:E106 ;
    sc:R3 sc:E204 ;
    sc:R6 sc:E305 .

# Hub Node
sc:E300 a sc:C9 ;
    rdfs:label "Hub Node Nu" ;
    rdfs:comment "A hub node connected to the super node, multiplex, and other hubs." ;
    sc:R2 sc:E301 ;
    sc:R4 sc:E100 ;
    sc:R9 sc:E101, sc:E302 ;
    sc:R6 sc:E106 .

# High-degree Node
sc:E301 a sc:C5 ;
    rdfs:label "High-degree Node Xi" ;
    rdfs:comment "A high-degree node with many connections to hubs and connectors." ;
    sc:R2 sc:E101 ;
    sc:R6 sc:E201, sc:E302 ;
    sc:R9 sc:E300, sc:E303 .

# Connector Node
sc:E302 a sc:C9 ;
    rdfs:label "Connector Node Omicron" ;
    rdfs:comment "A connector node linking hubs and high-degree nodes." ;
    sc:R2 sc:E101 ;
    sc:R4 sc:E303 ;
    sc:R9 sc:E101, sc:E301 ;
    sc:R6 sc:E202 .

# Intermediary Node
sc:E303 a sc:C10 ;
    rdfs:label "Intermediary Node Pi" ;
    rdfs:comment "An intermediary node between connectors and high-degree nodes." ;
    sc:R1 sc:E301 ;
    sc:R4 sc:E302 ;
    sc:R6 sc:E203 .

# Intermediary Node
sc:E304 a sc:C10 ;
    rdfs:label "Intermediary Node Rho" ;
    rdfs:comment "An intermediary node between intermediary and multiplex nodes." ;
    sc:R1 sc:E305 ;
    sc:R4 sc:E204 ;
    sc:R6 sc:E400 .

# Multiplex Node
sc:E305 a sc:C1, sc:C3 ;
    rdfs:label "Multiplex Node Sigma" ;
    rdfs:comment "A multiplex node, instance of two classes, connecting intermediary and multiplex nodes." ;
    sc:R1 sc:E204 ;
    sc:R3 sc:E304 ;
    sc:R6 sc:E500 .

# Super Node (second, for diversity)
sc:E400 a sc:C10 ;
    rdfs:label "Super Node Tau" ;
    rdfs:comment "A super node, highly connected, linking to the main super node and other hubs." ;
    sc:R1 sc:E100 ;
    sc:R4 sc:E500 ;
    sc:R6 sc:E304, sc:E401 .

# Hub Node
sc:E401 a sc:C9 ;
    rdfs:label "Hub Node Upsilon" ;
    rdfs:comment "A hub node connected to a super node and a connector node." ;
    sc:R2 sc:E402 ;
    sc:R4 sc:E500 ;
    sc:R9 sc:E403 ;
    sc:R6 sc:E400 .

# Connector Node
sc:E402 a sc:C9 ;
    rdfs:label "Connector Node Phi" ;
    rdfs:comment "A connector node linking a hub and an intermediary node." ;
    sc:R2 sc:E401 ;
    sc:R4 sc:E403 ;
    sc:R9 sc:E404 ;
    sc:R6 sc:E405 .

# Intermediary Node
sc:E403 a sc:C10 ;
    rdfs:label "Intermediary Node Chi" ;
    rdfs:comment "An intermediary node between connector and hub nodes." ;
    sc:R1 sc:E404 ;
    sc:R4 sc:E402 ;
    sc:R6 sc:E401 .

# Intermediary Node
sc:E404 a sc:C10 ;
    rdfs:label "Intermediary Node Psi" ;
    rdfs:comment "An intermediary node between two connectors." ;
    sc:R1 sc:E403 ;
    sc:R4 sc:E405 ;
    sc:R6 sc:E402 .

# Multiplex Node
sc:E405 a sc:C1, sc:C3 ;
    rdfs:label "Multiplex Node Omega" ;
    rdfs:comment "A multiplex node, instance of two classes, connecting connectors and intermediaries." ;
    sc:R1 sc:E404 ;
    sc:R3 sc:E402 ;
    sc:R6 sc:E500 .

# Super Node (third, for more structure)
sc:E500 a sc:C10 ;
    rdfs:label "Super Node Alpha Prime" ;
    rdfs:comment "A super node, highly connected, linking to other super nodes, hubs, and multiplex nodes." ;
    sc:R1 sc:E100, sc:E400 ;
    sc:R4 sc:E401, sc:E405 ;
    sc:R6 sc:E305 .

# Multiplex Node (with three classes)
sc:E600 a sc:C1, sc:C3, sc:C4 ;
    rdfs:label "Multiplex Node Poly" ;
    rdfs:comment "A multiplex node, instance of three classes, connecting to various node types and acting as a bridge." ;
    sc:R1 sc:E305 ;
    sc:R3 sc:E106 ;
    sc:R4 sc:E103 ;
    sc:R6 sc:E203 .

# Central Node (bridging two super nodes)
sc:E200 a sc:C4 ;
    rdfs:label "Central Node Bridge" ;
    rdfs:comment "A central node bridging the two main super nodes." ;
    sc:R1 sc:E100 ;
    sc:R4 sc:E500 ;
    sc:R6 sc:E101 .

# Central Node (bridging two hubs)
sc:E5001 a sc:C4 ;
    rdfs:label "Central Node Bridge 2" ;
    rdfs:comment "A central node bridging two hub nodes." ;
    sc:R1 sc:E300 ;
    sc:R4 sc:E401 ;
    sc:R6 sc:E301 .

# Multiplex Node (with two classes, connecting central and super nodes)
sc:E700 a sc:C1, sc:C4 ;
    rdfs:label "Multiplex Node Bridge" ;
    rdfs:comment "A multiplex node, instance of two classes, connecting central and super nodes." ;
    sc:R1 sc:E200 ;
    sc:R3 sc:E100 ;
    sc:R4 sc:E500 ;
    sc:R6 sc:E305 .