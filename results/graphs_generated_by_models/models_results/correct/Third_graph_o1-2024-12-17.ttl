@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
   dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

sc:EHub a sc:C9 ;
   rdfs:label "Hub Node" ;
   rdfs:comment "Represents a hub connecting multiple nodes" ;
   sc:R4 sc:EHighDegree .

sc:EHighDegree a sc:C9 ;
   rdfs:label "High-Degree Node" ;
   rdfs:comment "Has multiple relationships to other nodes" ;
   sc:R4 sc:EHub .

sc:ECentral a sc:C2 ;
   rdfs:label "Central Node" ;
   rdfs:comment "A central node emphasizing core position in the graph" ;
   sc:R9 sc:ESuper .

sc:ESuper a sc:C2 ;
   rdfs:label "Super Node" ;
   rdfs:comment "A super node with prominent structural importance" ;
   sc:R9 sc:ECentral .

sc:EConnector a sc:C10 ;
   rdfs:label "Connector Node" ;
   rdfs:comment "Bridges sc:C10 with a sc:C4 node" ;
   sc:R10 sc:ECnxTarget .

sc:ECnxTarget a sc:C4 ;
   rdfs:label "Connector Target Node" ;
   rdfs:comment "A sc:C4 node reached by the connector" .

sc:EIntermediary a sc:C3 ;
   rdfs:label "Intermediary Node" ;
   rdfs:comment "Facilitates interaction from sc:C3 to sc:C1" ;
   sc:R2 sc:EMultiplex .

sc:EMultiplex a sc:C1 ;
   rdfs:label "Multiplex Node" ;
   rdfs:comment "A sc:C1 node that can be reached through an intermediary" .