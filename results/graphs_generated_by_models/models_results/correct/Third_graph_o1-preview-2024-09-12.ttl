@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub Node
sc:E1001 a sc:C9 ;
    rdfs:label "Hub Node" ;
    rdfs:comment "An entity of class C9 acting as a hub node" ;
    sc:R1 sc:E1002, sc:E1003, sc:E1004 ;
    sc:R4 sc:E1005, sc:E1006 ;
    sc:R5 sc:E1007, sc:E1008 .

sc:E1002 a sc:C4 ;
    rdfs:label "Node E1002" ;
    rdfs:comment "An entity connected to the hub node via R1" ;
    sc:R1 sc:E1001 .

sc:E1003 a sc:C3 ;
    rdfs:label "Node E1003" ;
    rdfs:comment "An entity connected to the hub node via R1" ;
    sc:R1 sc:E1001 .

sc:E1004 a sc:C5 ;
    rdfs:label "Node E1004" ;
    rdfs:comment "An entity connected to the hub node via R1" ;
    sc:R1 sc:E1001 .

sc:E1005 a sc:C9 ;
    rdfs:label "Node E1005" ;
    rdfs:comment "An entity of class C9 connected via R4" ;
    sc:R4 sc:E1001 .

sc:E1006 a sc:C9 ;
    rdfs:label "Node E1006" ;
    rdfs:comment "An entity of class C9 connected via R4" ;
    sc:R4 sc:E1001 .

sc:E1007 a sc:C10 ;
    rdfs:label "Node E1007" ;
    rdfs:comment "An entity connected via R5" ;
    sc:R5 sc:E1001 .

sc:E1008 a sc:C2 ;
    rdfs:label "Node E1008" ;
    rdfs:comment "An entity connected via R5" ;
    sc:R5 sc:E1001 .

# High-Degree Node
sc:E1010 a sc:C3 ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "An entity of class C3 with many connections" ;
    sc:R2 sc:E1011, sc:E1012 ;
    sc:R1 sc:E1015, sc:E1016 ;
    sc:R7 sc:E1017 .

sc:E1011 a sc:C1 ;
    rdfs:label "Node E1011" ;
    rdfs:comment "An entity connected via R2" ;
    sc:R3 sc:E1010 .

sc:E1012 a sc:C1 ;
    rdfs:label "Node E1012" ;
    rdfs:comment "An entity connected via R2" ;
    sc:R3 sc:E1010 .

sc:E1015 a sc:C10 ;
    rdfs:label "Node E1015" ;
    rdfs:comment "An entity connected via R1" ;
    sc:R1 sc:E1010 .

sc:E1016 a sc:C10 ;
    rdfs:label "Node E1016" ;
    rdfs:comment "An entity connected via R1" ;
    sc:R1 sc:E1010 .

sc:E1017 a sc:C10 ;
    rdfs:label "Node E1017" ;
    rdfs:comment "An entity connected via R7" ;
    sc:R7 sc:E1010 .

# Central Node
sc:E1020 a sc:C10 ;
    rdfs:label "Central Node" ;
    rdfs:comment "An entity of class C10 acting as a central node" ;
    sc:R10 sc:E1024 ;
    sc:R1 sc:E1025, sc:E1026 ;
    sc:R7 sc:E1027 .

sc:E1024 a sc:C4 ;
    rdfs:label "Node E1024" ;
    rdfs:comment "An entity of class C4 connected via R10" ;
    sc:R10 sc:E1020 .

sc:E1025 a sc:C3 ;
    rdfs:label "Node E1025" ;
    rdfs:comment "An entity connected via R1" ;
    sc:R1 sc:E1020 .

sc:E1026 a sc:C5 ;
    rdfs:label "Node E1026" ;
    rdfs:comment "An entity connected via R1" ;
    sc:R1 sc:E1020 .

sc:E1027 a sc:C10 ;
    rdfs:label "Node E1027" ;
    rdfs:comment "An entity connected via R7" ;
    sc:R7 sc:E1020 .

# Connector Node
sc:E1030 a sc:C5 ;
    rdfs:label "Connector Node" ;
    rdfs:comment "An entity of class C5 acting as a connector node" ;
    sc:R6 sc:E1031, sc:E1032 .

sc:E1031 a sc:C7 ;
    rdfs:label "Node E1031" ;
    rdfs:comment "An entity of class C7 connected via R6" ;
    sc:R8 sc:E1030 .

sc:E1032 a sc:C7 ;
    rdfs:label "Node E1032" ;
    rdfs:comment "An entity of class C7 connected via R6" ;
    sc:R8 sc:E1030 .

# Intermediary Node
sc:E1040 a sc:C3 ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "An entity of class C3 acting as an intermediary node" ;
    sc:R2 sc:E1041 ;
    sc:R3 sc:E1042 .

sc:E1041 a sc:C1 ;
    rdfs:label "Node E1041" ;
    rdfs:comment "An entity connected via R2" ;
    sc:R3 sc:E1040 .

sc:E1042 a sc:C1 ;
    rdfs:label "Node E1042" ;
    rdfs:comment "An entity connected via R3" ;
    sc:R2 sc:E1040 .

# Multiplex Node
sc:E1050 a sc:C2 ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "An entity of class C2 with multiple types of relationships" ;
    sc:R9 sc:E1051 ;
    sc:R1 sc:E1052 ;
    sc:R5 sc:E1053 .

sc:E1051 a sc:C2 ;
    rdfs:label "Node E1051" ;
    rdfs:comment "An entity of class C2 connected via R9" ;
    sc:R9 sc:E1050 .

sc:E1052 a sc:C10 ;
    rdfs:label "Node E1052" ;
    rdfs:comment "An entity connected via R1" ;
    sc:R1 sc:E1050 .

sc:E1053 a sc:C4 ;
    rdfs:label "Node E1053" ;
    rdfs:comment "An entity connected via R5" ;
    sc:R5 sc:E1050 .

# Super Node
sc:E1060 a sc:C6 ;
    rdfs:label "Super Node" ;
    rdfs:comment "An entity of class C6 acting as a super node" ;
    sc:R2 sc:E1061 ;
    sc:R6 sc:E1062 ;
    sc:R1 sc:E1063 ;
    sc:R4 sc:E1064 .

sc:E1061 a sc:C1 ;
    rdfs:label "Node E1061" ;
    rdfs:comment "An entity connected via R2" ;
    sc:R3 sc:E1060 .

sc:E1062 a sc:C7 ;
    rdfs:label "Node E1062" ;
    rdfs:comment "An entity connected via R6" ;
    sc:R8 sc:E1060 .

sc:E1063 a sc:C10 ;
    rdfs:label "Node E1063" ;
    rdfs:comment "An entity connected via R1" ;
    sc:R1 sc:E1060 .

sc:E1064 a sc:C9 ;
    rdfs:label "Node E1064" ;
    rdfs:comment "An entity connected via R4" ;
    sc:R4 sc:E1060 .
