@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <http://example.com/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .

# Entities
ex:ApplicationModuleA
    a noria:ApplicationModule ;
    rdfs:label "Application Module A" ;
    rdfs:comment "A critical application module." ;
    noria:applicationModuleName "AppModuleA" ;
    noria:applicationModuleIdentifier "AM001" ;
    noria:applicationModuleOf ex:ApplicationX ;
    noria:applicationModuleAdministrationTeam ex:TeamAlpha .

ex:ApplicationModuleB
    a noria:ApplicationModule ;
    rdfs:label "Application Module B" ;
    rdfs:comment "Another application module." ;
    noria:applicationModuleName "AppModuleB" ;
    noria:applicationModuleIdentifier "AM002" ;
    noria:applicationModuleOf ex:ApplicationY ;
    noria:applicationModuleSupportTeam ex:TeamBeta .

ex:ApplicationX
    a noria:Application ;
    rdfs:label "Application X" ;
    rdfs:comment "A core application." ;
    noria:applicationShortIdentifier "AppX" ;
    noria:applicationModelIdentifier "AppModelX" .

ex:ApplicationY
    a noria:Application ;
    rdfs:label "Application Y" ;
    rdfs:comment "An important application." ;
    noria:applicationShortIdentifier "AppY" ;
    noria:applicationModelIdentifier "AppModelY" .

ex:Resource1
    a noria:Resource ;
    rdfs:label "Resource 1" ;
    rdfs:comment "A server in the data center." ;
    noria:resourceHostName "server1.example.com" ;
    noria:resourceLogisticId "RL001" ;
    noria:locatedAtLocus ex:Locus1 .

ex:Resource2
    a noria:Resource ;
    rdfs:label "Resource 2" ;
    rdfs:comment "Another server in the data center." ;
    noria:resourceHostName "server2.example.com" ;
    noria:resourceLogisticId "RL002" ;
    noria:locatedAtLocus ex:Locus2 .

ex:Resource3
    a noria:Resource ;
    rdfs:label "Resource 3" ;
    rdfs:comment "A network device." ;
    noria:resourceHostName "router1.example.com" ;
    noria:resourceLogisticId "RL003" ;
    noria:locatedAtLocus ex:Locus3 .

ex:NetworkInterface1
    a noria:NetworkInterface ;
    rdfs:label "eth0" ;
    rdfs:comment "Ethernet interface." ;
    noria:networkInterfaceOf ex:Resource1 ;
    noria:networkInterfaceConnects ex:NetworkLink1 .

ex:NetworkInterface2
    a noria:NetworkInterface ;
    rdfs:label "eth1" ;
    rdfs:comment "Another ethernet interface." ;
    noria:networkInterfaceOf ex:Resource2 ;
    noria:networkInterfaceConnects ex:NetworkLink1 .

ex:NetworkLink1
    a noria:NetworkLink ;
    rdfs:label "Link 1" ;
    rdfs:comment "A network link connecting two servers." ;
    noria:networkLinkId "NL001" ;
    noria:networkLinkTerminationResourceOrigin ex:Resource1 ;
    noria:networkLinkTerminationResourceDestination ex:Resource2 .

ex:TroubleTicket1
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket 1" ;
    rdfs:comment "A ticket related to a server issue." ;
    dcterms:identifier "TT001" ;
    noria:troubleTicketRelatedResource ex:Resource1 .

ex:ChangeRequest1
    a noria:ChangeRequest ;
    rdfs:label "Change Request 1" ;
    rdfs:comment "A change request for a network configuration." ;
    dcterms:identifier "CR001" ;
    noria:changeRequestImpact ex:Resource3 .

ex:TeamAlpha
    a org:OrganizationalUnit ;
    rdfs:label "Team Alpha" ;
    rdfs:comment "Administration team." .

ex:TeamBeta
    a org:OrganizationalUnit ;
    rdfs:label "Team Beta" ;
    rdfs:comment "Support team." .

ex:Locus1
    a noria:Locus ;
    rdfs:label "Locus 1" ;
    rdfs:comment "Location of Resource 1." ;
    bot:containsZone ex:Room1 .

ex:Locus2
    a noria:Locus ;
    rdfs:label "Locus 2" ;
    rdfs:comment "Location of Resource 2." ;
    bot:containsZone ex:Room1 .

ex:Locus3
    a noria:Locus ;
    rdfs:label "Locus 3" ;
    rdfs:comment "Location of Resource 3." ;
    bot:containsZone ex:Room1 .

ex:Room1
    a noria:Room ;
    rdfs:label "Server Room 1" ;
    rdfs:comment "A server room." .

# Relationships and Node Types
ex:ApplicationX
    seas:subSystemOf ex:ServiceA . # Hub Node: ApplicationX connects to multiple entities

ex:ApplicationY
    seas:subSystemOf ex:ServiceB .

ex:Resource1
    noria:resourceForApplication ex:ApplicationModuleA . # High-Degree Node: Resource1 connects to many applications
ex:Resource2
    noria:resourceForApplication ex:ApplicationModuleB .
ex:Resource3
    noria:resourceForApplication ex:ApplicationX .

ex:NetworkLink1
    noria:networkLinkTerminationResourceOrigin ex:Resource1 ; # Central Node: NetworkLink1 connects to multiple resources
    noria:networkLinkTerminationResourceDestination ex:Resource2 .

ex:TroubleTicket1
    noria:troubleTicketRelatedService ex:ApplicationModuleA . # Connector Node: TroubleTicket1 connects documentation to resources

ex:ChangeRequest1
    noria:changeRequestImpact ex:Resource3 . # Intermediary Node: ChangeRequest1 connects documentation to resources

ex:ServiceA
    a noria:Service ;
    rdfs:label "Service A" ;
    rdfs:comment "A critical service." ;
    seas:subSystemOf ex:ApplicationModuleA . # Multiplex Node: ServiceA connects to multiple applications and modules

ex:ServiceB
    a noria:Service ;
    rdfs:label "Service B" ;
    rdfs:comment "Another important service." ;
    seas:subSystemOf ex:ApplicationModuleB .

ex:OrganizationA
    a org:Organization ;
    rdfs:label "Organization A" ;
    rdfs:comment "The organization managing the resources." ;
    org:hasMember ex:TeamAlpha ;
    org:hasMember ex:TeamBeta . # Super Node: OrganizationA connects to multiple teams and resources

ex:Resource1
    noria:resourceManagedBy ex:TeamAlpha .
ex:Resource2
    noria:resourceManagedBy ex:TeamBeta .
ex:Resource3
    noria:resourceManagedBy ex:TeamAlpha .
