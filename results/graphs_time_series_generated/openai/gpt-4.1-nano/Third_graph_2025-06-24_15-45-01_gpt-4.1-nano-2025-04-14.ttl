@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A node with high connectivity acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of relations, indicating significant influence." .

sc:CentralNode a owl:Class ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that is central within a specific subgraph or community." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different parts of the graph, facilitating communication." .

sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as an intermediary between other nodes or groups." .

sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations or belonging to multiple classes." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "An overarching node that encompasses multiple nodes or classes." .

# Entities
sc:E1001 a sc:HubNode ;
    rdfs:label "Entity E1001" ;
    rdfs:comment "A hub node representing a major transportation hub." ;
    sc:hasRelation sc:E1002, sc:E1003 .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "Entity E1002" ;
    rdfs:comment "A high-degree node representing a central business district." ;
    sc:relatesTo sc:E1004 .

sc:E1003 a sc:ConnectorNode ;
    rdfs:label "Entity E1003" ;
    rdfs:comment "A connector node linking different transportation modes." ;
    sc:connectsTo sc:E1005 .

sc:E1004 a sc:IntermediaryNode ;
    rdfs:label "Entity E1004" ;
    rdfs:comment "An intermediary node representing a transit station." ;
    sc:mediates sc:E1006 .

sc:E1005 a sc:MultiplexNode ;
    rdfs:label "Entity E1005" ;
    rdfs:comment "A multiplex node involved in multiple transportation networks." ;
    sc:participatesIn sc:E1007, sc:E1008 .

sc:E1006 a sc:SuperNode ;
    rdfs:label "Entity E1006" ;
    rdfs:comment "A super node representing a large metropolitan area." ;
    sc:includes sc:E1002, sc:E1004 .

sc:E1007 a sc:HighDegreeNode ;
    rdfs:label "Entity E1007" ;
    rdfs:comment "A high-degree node representing a major train station." ;
    sc:connectedTo sc:E1003 .

sc:E1008 a sc:ConnectorNode ;
    rdfs:label "Entity E1008" ;
    rdfs:comment "A connector node linking regional and local networks." ;
    sc:linksTo sc:E1005 .

# Relations
sc:hasRelation a owl:ObjectProperty ;
    rdfs:label "has relation" ;
    rdfs:comment "Indicates a relation between entities." .

sc:relatesTo a owl:ObjectProperty ;
    rdfs:label "relates to" ;
    rdfs:comment "Indicates a relation between entities." .

sc:connectsTo a owl:ObjectProperty ;
    rdfs:label "connects to" ;
    rdfs:comment "Indicates a direct connection between nodes." .

sc:mediates a owl:ObjectProperty ;
    rdfs:label "mediates" ;
    rdfs:comment "Indicates an intermediary role in relations." .

sc:participatesIn a owl:ObjectProperty ;
    rdfs:label "participates in" ;
    rdfs:comment "Indicates participation of multiplex nodes in multiple networks." .

sc:includes a owl:ObjectProperty ;
    rdfs:label "includes" ;
    rdfs:comment "Indicates that a super node encompasses other nodes." .

sc:linksTo a owl:ObjectProperty ;
    rdfs:label "links to" ;
    rdfs:comment "Indicates a linking relation between nodes." .

# Additional creative nodes and relations
sc:E1010 a sc:SuperNode ;
    rdfs:label "Entity E1010" ;
    rdfs:comment "A super node representing a national transportation network." ;
    sc:includes sc:E1001, sc:E1006 .

sc:E1011 a sc:CentralNode ;
    rdfs:label "Entity E1011" ;
    rdfs:comment "A central node representing a major airport." ;
    sc:connectedTo sc:E1003 .

sc:E1012 a sc:MultiplexNode ;
    rdfs:label "Entity E1012" ;
    rdfs:comment "A multiplex node involved in both air and rail networks." ;
    sc:participatesIn sc:E1010, sc:E1011 .

sc:E1013 a sc:HighDegreeNode ;
    rdfs:label "Entity E1013" ;
    rdfs:comment "A high-degree node representing a central train station." ;
    sc:relatesTo sc:E1007 .

sc:E1014 a sc:ConnectorNode ;
    rdfs:label "Entity E1014" ;
    rdfs:comment "A connector node linking different transportation modes." ;
    sc:connectsTo sc:E1012 .

# End of example graph in turtle format
