@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Define Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that acts as a central connector between different parts of the graph." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different classes or groups." .

sc:IntermediaryNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that mediates relations between other nodes." .

sc:MultiplexNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A super node with multiple roles and high connectivity." .

# Define Properties
sc:connectsTo a owl:ObjectProperty ;
    rdfs:domain sc:SuperNode ;
    rdfs:range sc:SuperNode ;
    rdfs:label "connects to" ;
    rdfs:comment "Indicates a connection between two nodes." .

sc:relatesTo a owl:ObjectProperty ;
    rdfs:domain sc:IntermediaryNode ;
    rdfs:range sc:IntermediaryNode ;
    rdfs:label "relates to" ;
    rdfs:comment "Indicates a relation between intermediary nodes." .

sc:linksTo a owl:ObjectProperty ;
    rdfs:domain sc:ConnectorNode ;
    rdfs:range sc:HighDegreeNode ;
    rdfs:label "links to" ;
    rdfs:comment "Links a connector node to a high-degree node." .

sc:mediates a owl:ObjectProperty ;
    rdfs:domain sc:IntermediaryNode ;
    rdfs:range sc:ConnectorNode ;
    rdfs:label "mediates" ;
    rdfs:comment "Indicates mediation role of an intermediary node." .

sc:participatesIn a owl:ObjectProperty ;
    rdfs:domain sc:MultiplexNode ;
    rdfs:range sc:SuperNode ;
    rdfs:label "participates in" ;
    rdfs:comment "Indicates participation of multiplex nodes in multiple relations." .

# Entities with labels and comments
# Hub Node
sc:Hub1 a sc:HubNode ;
    rdfs:label "Main Hub" ;
    rdfs:comment "The central hub connecting multiple high-degree nodes." .

# High Degree Nodes
sc:High1 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node 1" ;
    rdfs:comment "A node with many connections to other nodes." .

sc:High2 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node 2" ;
    rdfs:comment "Another high-degree node with extensive relations." .

# Central Nodes
sc:Central1 a sc:CentralNode ;
    rdfs:label "Central Node A" ;
    rdfs:comment "A key node acting as a bridge between different groups." .

sc:Central2 a sc:CentralNode ;
    rdfs:label "Central Node B" ;
    rdfs:comment "Supports multiple relations across the network." .

# Connector Nodes
sc:Connector1 a sc:ConnectorNode ;
    rdfs:label "Connector Node X" ;
    rdfs:comment "Connects different classes of nodes." .

sc:Connector2 a sc:ConnectorNode ;
    rdfs:label "Connector Node Y" ;
    rdfs:comment "Facilitates relations between intermediary nodes." .

# Intermediary Nodes
sc:Intermediary1 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node 1" ;
    rdfs:comment "Mediates relations between high-degree and connector nodes." .

sc:Intermediary2 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node 2" ;
    rdfs:comment "Acts as a mediator in multiplex relations." .

# Multiplex Nodes
sc:Multiplex1 a sc:MultiplexNode ;
    rdfs:label "Multiplex Node Alpha" ;
    rdfs:comment "Participates in multiple relation types." .

sc:Multiplex2 a sc:MultiplexNode ;
    rdfs:label "Multiplex Node Beta" ;
    rdfs:comment "Engages in diverse relations across the graph." .

# Super Nodes
sc:Super1 a sc:SuperNode ;
    rdfs:label "Super Node 1" ;
    rdfs:comment "A highly connected super node with multiple roles." .

sc:Super2 a sc:SuperNode ;
    rdfs:label "Super Node 2" ;
    rdfs:comment "A super node involved in multiplex relations." .

# Relations among entities
sc:MainHub a sc:HubNode ;
    rdfs:label "Main Hub" ;
    rdfs:comment "The central hub connecting multiple high-degree nodes." .

# Establishing relations
sc:MainHub sc:connectsTo sc:High1 ;
    rdfs:label "Main Hub connects to High Degree Node 1" .

sc:MainHub sc:connectsTo sc:High2 ;
    rdfs:label "Main Hub connects to High Degree Node 2" .

sc:High1 sc:linksTo sc:Central1 ;
    rdfs:label "High Degree Node 1 links to Central Node A" .

sc:High2 sc:linksTo sc:Central2 ;
    rdfs:label "High Degree Node 2 links to Central Node B" .

sc:Central1 sc:relatesTo sc:Intermediary1 ;
    rdfs:label "Central Node A relates to Intermediary 1" .

sc:Central2 sc:relatesTo sc:Intermediary2 ;
    rdfs:label "Central Node B relates to Intermediary 2" .

sc:Intermediary1 sc:mediates sc:Connector1 ;
    rdfs:label "Intermediary 1 mediates Connector 1" .

sc:Intermediary2 sc:mediates sc:Connector2 ;
    rdfs:label "Intermediary 2 mediates Connector 2" .

sc:Super1 sc:connectsTo sc:Super2 ;
    rdfs:label "Super Node 1 connects to Super Node 2" .

sc:Super2 sc:connectsTo sc:MainHub ;
    rdfs:label "Super Node 2 connects to Main Hub" .

# Additional relations to ensure nodes have at least one relation
sc:High1 sc:connectsTo sc:High2 ;
    rdfs:label "High Degree Nodes connect to each other" .

sc:Connector1 sc:linksTo sc:Intermediary1 ;
    rdfs:label "Connector 1 links to Intermediary 1" .

sc:Intermediary2 sc:relatesTo sc:Intermediary1 ;
    rdfs:label "Intermediary 2 relates to Intermediary 1" .

sc:Multiplex1 sc:connectsTo sc:High1 ;
    rdfs:label "Multiplex 1 connects to High 1" .

sc:Super1 sc:relatesTo sc:Super2 ;
    rdfs:label "Super Nodes relate to each other" .
