@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub Node: Entity with many relations, central in the network
sc:HubNode a owl:Class ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the graph." ;
    a sc:C10 .

sc:EHub1 a sc:HubNode ;
    rdfs:label "Main Hub" ;
    rdfs:comment "The central hub connecting multiple classes." ;
    sc:R1 sc:E122, sc:E124, sc:E131, sc:E174, sc:E176 .

# High-degree Node: Entity with many relations but not as central as hub
sc:HighDegreeNode a owl:Class ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with numerous connections, influential but not a main hub." ;
    a sc:C9 .

sc:EHD1 a sc:HighDegreeNode ;
    rdfs:label "Influential Node 1" ;
    rdfs:comment "Connected to several classes, influencing the network." ;
    sc:R1 sc:E103, sc:E105, sc:E110, sc:E113, sc:E115 .

# Central Node: Entity that acts as a key connector
sc:CentralNode a owl:Class ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that links different parts of the graph." ;
    a sc:C8 .

sc:ECentral1 a sc:CentralNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "Connects classes C4, C5, and C10." ;
    sc:R1 sc:E124, sc:E146, sc:E174 .

# Connector Node: Entity linking multiple classes
sc:ConnectorNode a owl:Class ;
    rdfs:label "Connector Node" ;
    rdfs:comment "Links various classes to facilitate information flow." ;
    a sc:C7 .

sc:EConn1 a sc:ConnectorNode ;
    rdfs:label "Connector Entity 1" ;
    rdfs:comment "Connects class C2 with C6 and C9." ;
    sc:R10 sc:E105, sc:E108, sc:E111 .

# Intermediary Node: Entity acting as a bridge
sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "Serves as a bridge between different classes." ;
    a sc:C4 .

sc:EInter1 a sc:IntermediaryNode ;
    rdfs:label "Bridge Entity" ;
    sc:R4 sc:E112, sc:E113, sc:E115 .

# Multiplex Node: Entity involved in multiple relation types
sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "Participates in multiple relation types across classes." ;
    a sc:C10 .

sc:EMulti1 a sc:MultiplexNode ;
    rdfs:label "Multi-Relation Entity" ;
    sc:R1 sc:E124, sc:E131, sc:E146 ;
    sc:R4 sc:E174, sc:E176, sc:E189 .

# Super Node: Entity that encompasses multiple classes
sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A node representing a superordinate entity covering multiple classes." ;
    a sc:C10 .

sc:ESuper1 a sc:SuperNode ;
    rdfs:label "Super Entity" ;
    sc:R1 sc:E122, sc:E124, sc:E131, sc:E174, sc:E176, sc:E189 .

# Additional Entities with diverse relations
sc:EHigh1 a owl:NamedIndividual, sc:C9 ;
    rdfs:label "High Degree Entity" ;
    rdfs:comment "Entity with multiple symmetric and reflexive relations." ;
    sc:R4 sc:E122, sc:E124 ;
    sc:R5 sc:E131 .

sc:ECentral2 a owl:NamedIndividual, sc:C8 ;
    rdfs:label "Key Connector" ;
    rdfs:comment "Links classes C4, C5, and C10 with multiple relations." ;
    sc:R1 sc:E146 ;
    sc:R6 sc:E174 .

sc:EMult1 a owl:NamedIndividual, sc:C10 ;
    rdfs:label "Multi-Relation Entity" ;
    rdfs:comment "Participates in various relation types across classes." ;
    sc:R1 sc:E131, sc:E174 ;
    sc:R4 sc:E176, sc:E189 .

# Relations between entities (examples)
sc:E122 sc:R6 sc:E124 .
sc:E131 sc:R4 sc:E146 .
sc:E174 sc:R1 sc:E176 .
sc:E189 sc:R4 sc:E122 .

# End of graph
