@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Class definitions
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Hub Node"@en ;
    rdfs:comment "A node with high connectivity acting as a central hub in the network."@en .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "High-Degree Node"@en ;
    rdfs:comment "A node with a high number of relations, acting as a connector."@en .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Central Node"@en ;
    rdfs:comment "A node that is central within a specific subgraph."@en .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Connector Node"@en ;
    rdfs:comment "A node that connects different classes or groups."@en .

sc:IntermediaryNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Intermediary Node"@en ;
    rdfs:comment "A node that acts as a bridge between two other nodes."@en .

sc:MultiplexNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Multiplex Node"@en ;
    rdfs:comment "A node involved in multiple relation types."@en .

sc:SuperNode a owl:Class ;
    rdfs:subClassOf sc:C10 ;
    rdfs:label "Super Node"@en ;
    rdfs:comment "A node that aggregates multiple nodes or classes."@en .

# Entities with relations
sc:E1001 a sc:HubNode ;
    rdfs:label "Main Hub"@en ;
    rdfs:comment "A central hub node connecting multiple high-degree nodes."@en ;
    sc:sc:R1 sc:E1002, sc:E1003 ;
    sc:sc:R6 sc:E1004 .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "Connector A"@en ;
    rdfs:comment "A high-degree node acting as a connector between hubs and other nodes."@en ;
    sc:sc:R1 sc:E1001 ;
    sc:sc:R4 sc:E1005 .

sc:E1003 a sc:HighDegreeNode ;
    rdfs:label "Connector B"@en ;
    rdfs:comment "Another high-degree node with multiple relations."@en ;
    sc:sc:R1 sc:E1001 ;
    sc:sc:R4 sc:E1006 .

sc:E1004 a sc:CentralNode ;
    rdfs:label "Central Node 1"@en ;
    rdfs:comment "A central node within a subgraph."@en ;
    sc:sc:R1 sc:E1001 ;
    sc:sc:R6 sc:E1007 .

sc:E1005 a sc:IntermediaryNode ;
    rdfs:label "Bridge Node 1"@en ;
    sc:sc:R3 sc:E1002 ;
    sc:sc:R4 sc:E1008 .

sc:E1006 a sc:IntermediaryNode ;
    rdfs:label "Bridge Node 2"@en ;
    sc:sc:R3 sc:E1003 ;
    sc:sc:R4 sc:E1009 .

sc:E1007 a sc:SuperNode ;
    rdfs:label "Super Node Alpha"@en ;
    rdfs:comment "A super node aggregating multiple entities."@en ;
    sc:sc:R1 sc:E1004 ;
    sc:sc:R6 sc:E1010 .

sc:E1008 a sc:MultiplexNode ;
    rdfs:label "Multi-Relation Node 1"@en ;
    rdfs:comment "A node involved in multiple relation types."@en ;
    sc:sc:R1 sc:E1005 ;
    sc:sc:R4 sc:E1011 .

sc:E1009 a sc:MultiplexNode ;
    rdfs:label "Multi-Relation Node 2"@en ;
    rdfs:comment "Another multiplex node with diverse relations."@en ;
    sc:sc:R1 sc:E1006 ;
    sc:sc:R4 sc:E1012 .

sc:E1010 a sc:SuperNode ;
    rdfs:label "Super Node Beta"@en ;
    rdfs:comment "An overarching node representing a large group."@en ;
    sc:sc:R1 sc:E1007 ;
    sc:sc:R6 sc:E1013 .

sc:E1011 a sc:ConnectorNode ;
    rdfs:label "Connector Node 3"@en ;
    rdfs:comment "Connects different subgroups."@en ;
    sc:sc:R1 sc:E1008 ;
    sc:sc:R4 sc:E1014 .

sc:E1012 a sc:IntermediaryNode ;
    rdfs:label "Bridge Node 3"@en ;
    rdfs:comment "Acts as a bridge between multiplex nodes."@en ;
    sc:sc:R3 sc:E1009 ;
    sc:sc:R4 sc:E1015 .

sc:E1013 a sc:HubNode ;
    rdfs:label "Main Hub Beta"@en ;
    rdfs:comment "A secondary hub connecting to super nodes."@en ;
    sc:sc:R1 sc:E1010 ;
    sc:sc:R6 sc:E1016 .

sc:E1014 a sc:HighDegreeNode ;
    rdfs:label "Connector D"@en ;
    rdfs:comment "High-degree connector node."@en ;
    sc:sc:R1 sc:E1011 ;
    sc:sc:R4 sc:E1017 .

sc:E1015 a sc:MultiplexNode ;
    rdfs:label "Multi-Relation Node 3"@en ;
    rdfs:comment "Involved in multiple relation types."@en ;
    sc:sc:R1 sc:E1012 ;
    sc:sc:R4 sc:E1018 .

sc:E1016 a sc:SuperNode ;
    rdfs:label "Super Node Gamma"@en ;
    rdfs:comment "A large super node representing a major group."@en ;
    sc:sc:R1 sc:E1013 ;
    sc:sc:R6 sc:E1019 .

sc:E1017 a sc:ConnectorNode ;
    rdfs:label "Connector D"@en ;
    rdfs:comment "Connects super nodes to other entities."@en ;
    sc:sc:R1 sc:E1014 ;
    sc:sc:R4 sc:E1020 .

sc:E1018 a sc:IntermediaryNode ;
    rdfs:label "Bridge Node 4"@en ;
    rdfs:comment "Bridge between multiplex and connector nodes."@en ;
    sc:sc:R3 sc:E1015 ;
    sc:sc:R4 sc:E1021 .

sc:E1019 a sc:HubNode ;
    rdfs:label "Main Hub Gamma"@en ;
    rdfs:comment "A hub node connecting major groups."@en ;
    sc:sc:R1 sc:E1016 ;
    sc:sc:R6 sc:E1022 .

sc:E1020 a sc:HighDegreeNode ;
    rdfs:label "Connector E"@en ;
    rdfs:comment "High-degree connector for large groups."@en ;
    sc:sc:R1 sc:E1017 ;
    sc:sc:R4 sc:E1023 .

sc:E1021 a sc:MultiplexNode ;
    rdfs:label "Multi-Relation Node 4"@en ;
    rdfs:comment "Node involved in multiple relation types."@en ;
    sc:sc:R1 sc:E1018 ;
    sc:sc:R4 sc:E1024 .

sc:E1022 a sc:SuperNode ;
    rdfs:label "Super Node Delta"@en ;
    rdfs:comment "A super node representing a major cluster."@en ;
    sc:sc:R1 sc:E1019 ;
    sc:sc:R6 sc:E1025 .

sc:E1023 a sc:ConnectorNode ;
    rdfs:label "Connector F"@en ;
    rdfs:comment "Connector node linking super nodes."@en ;
    sc:sc:R1 sc:E1020 ;
    sc:sc:R4 sc:E1026 .

sc:E1024 a sc:IntermediaryNode ;
    rdfs:label "Bridge Node 5"@en ;
    sc:sc:R3 sc:E1021 ;
    sc:sc:R4 sc:E1027 .

sc:E1025 a sc:HubNode ;
    rdfs:label "Main Hub Delta"@en ;
    rdfs:comment "A hub node for large network segments."@en ;
    sc:sc:R1 sc:E1022 ;
    sc:sc:R6 sc:E1028 .

sc:E1026 a sc:HighDegreeNode ;
    rdfs:label "Connector G"@en ;
    rdfs:comment "High-degree connector for super nodes."@en ;
    sc:sc:R1 sc:E1023 ;
    sc:sc:R4 sc:E1029 .

sc:E1027 a sc:MultiplexNode ;
    rdfs:label "Multi-Relation Node 5"@en ;
    rdfs:comment "Node involved in multiple relation types."@en ;
    sc:sc:R1 sc:E1024 ;
    sc:sc:R4 sc:E1030 .

sc:E1028 a sc:SuperNode ;
    rdfs:label "Super Node Epsilon"@en ;
    rdfs:comment "A super node representing a major cluster."@en ;
    sc:sc:R1 sc:E1025 ;
    sc:sc:R6 sc:E1031 .

sc:E1029 a sc:ConnectorNode ;
    rdfs:label "Connector H"@en ;
    rdfs:comment "Connector linking super nodes."@en ;
    sc:sc:R1 sc:E1026 ;
    sc:sc:R4 sc:E1032 .

sc:E1030 a sc:IntermediaryNode ;
    rdfs:label "Bridge Node 6"@en ;
    sc:sc:R3 sc:E1027 ;
    sc:sc:R4 sc:E1033 .

sc:E1031 a sc:HubNode ;
    rdfs:label "Main Hub Epsilon"@en ;
    rdfs:comment "A hub node for major network segments."@en ;
    sc:sc:R1 sc:E1028 ;
    sc:sc:R6 sc:E1034 .

sc:E1032 a sc:HighDegreeNode ;
    rdfs:label "Connector I"@en ;
    rdfs:comment "High-degree connector for super nodes."@en ;
    sc:sc:R1 sc:E1029 ;
    sc:sc:R4 sc:E1035 .

sc:E1033 a sc:MultiplexNode ;
    rdfs:label "Multi-Relation Node 6"@en ;
    rdfs:comment "Node involved in multiple relation types."@en ;
    sc:sc:R1 sc:E1030 ;
    sc:sc:R4 sc:E1036 .

sc:E1034 a sc:SuperNode ;
    rdfs:label "Super Node Zeta"@en ;
    rdfs:comment "A super node representing a major cluster."@en ;
    sc:sc:R1 sc:E1031 ;
    sc:sc:R6 sc:E1037 .

