    <!-- http://pygraf.t/connectsTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/connectsTo">
        <rdfs:domain rdf:resource="http://pygraf.t/Node"/>
        <rdfs:range rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>Indicates a connection between two nodes.</rdfs:comment>
        <rdfs:label>connects to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/hasRelation -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/hasRelation">
        <rdfs:domain rdf:resource="http://pygraf.t/Node"/>
        <rdfs:range rdf:resource="http://pygraf.t/Relation"/>
        <rdfs:comment>Associates a node with a specific relation type.</rdfs:comment>
        <rdfs:label>has relation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/linksTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/linksTo">
        <rdfs:domain rdf:resource="http://pygraf.t/Node"/>
        <rdfs:range rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>Represents a link from one node to another.</rdfs:comment>
        <rdfs:label>links to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
