     -->

    


    <!-- http://pygraf.t/CentralNode -->

    <owl:Class rdf:about="http://pygraf.t/CentralNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>A node that is central within a specific subgraph.</rdfs:comment>
        <rdfs:label>Central Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/ConnectorNode -->

    <owl:Class rdf:about="http://pygraf.t/ConnectorNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>A node that connects different parts of the graph, acting as a bridge.</rdfs:comment>
        <rdfs:label>Connector Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HighDegreeNode -->

    <owl:Class rdf:about="http://pygraf.t/HighDegreeNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/CentralNode"/>
        <rdfs:comment>A node with a high number of connections, but not necessarily a hub.</rdfs:comment>
        <rdfs:label>High-Degree Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HubNode -->

    <owl:Class rdf:about="http://pygraf.t/HubNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/SuperNode"/>
        <rdfs:comment>A highly connected node acting as a central hub in the network.</rdfs:comment>
        <rdfs:label>Hub Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/IntermediaryNode -->

    <owl:Class rdf:about="http://pygraf.t/IntermediaryNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>A node that mediates interactions between other nodes.</rdfs:comment>
        <rdfs:label>Intermediary Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/MultiplexNode -->

    <owl:Class rdf:about="http://pygraf.t/MultiplexNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>A node involved in multiple types of relations or layers.</rdfs:comment>
        <rdfs:label>Multiplex Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/Node -->

    <owl:Class rdf:about="http://pygraf.t/Node">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    


    <!-- http://pygraf.t/Relation -->

    <owl:Class rdf:about="http://pygraf.t/Relation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>
    


    <!-- http://pygraf.t/SuperNode -->

    <owl:Class rdf:about="http://pygraf.t/SuperNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/Node"/>
        <rdfs:comment>An overarching node that encompasses multiple nodes or functions.</rdfs:comment>
        <rdfs:label>Super Node</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pygraf.t/Central1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Central1">
        <rdf:type rdf:resource="http://pygraf.t/CentralNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Intermediary1"/>
        <connectsTo rdf:resource="http://pygraf.t/Intermediary2"/>
        <rdfs:comment>A node central within a specific community.</rdfs:comment>
        <rdfs:label>Central Node 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Connector1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Connector1">
        <rdf:type rdf:resource="http://pygraf.t/ConnectorNode"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode1"/>
        <connectsTo rdf:resource="http://pygraf.t/Intermediary3"/>
        <rdfs:comment>Connects the hub to other subgraphs.</rdfs:comment>
        <rdfs:label>Connector Node 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Connector2 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Connector2">
        <rdf:type rdf:resource="http://pygraf.t/ConnectorNode"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode2"/>
        <connectsTo rdf:resource="http://pygraf.t/Intermediary3"/>
        <rdfs:label>Connector Node 2</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/HighNode1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/HighNode1">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Hub1"/>
        <connectsTo rdf:resource="http://pygraf.t/Intermediary1"/>
        <connectsTo rdf:resource="http://pygraf.t/SuperNode1"/>
        <hasRelation rdf:resource="http://pygraf.t/RelationType1"/>
        <rdfs:comment>A node with many connections, acting as a key influencer.</rdfs:comment>
        <rdfs:label>High-Degree Node 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/HighNode2 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/HighNode2">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Hub1"/>
        <connectsTo rdf:resource="http://pygraf.t/Intermediary2"/>
        <hasRelation rdf:resource="http://pygraf.t/RelationType2"/>
        <rdfs:label>High-Degree Node 2</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Hub1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Hub1">
        <rdf:type rdf:resource="http://pygraf.t/HubNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Connector1"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode1"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode2"/>
        <rdfs:comment>A central hub connecting multiple high-degree nodes.</rdfs:comment>
        <rdfs:label>Hub Node 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Intermediary1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Intermediary1">
        <rdf:type rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Central1"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode1"/>
        <linksTo rdf:resource="http://pygraf.t/Intermediary2"/>
        <rdfs:label>Intermediary Node 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Intermediary2 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Intermediary2">
        <rdf:type rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Central1"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode2"/>
        <rdfs:label>Intermediary Node 2</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Intermediary3 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Intermediary3">
        <rdf:type rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Connector1"/>
        <connectsTo rdf:resource="http://pygraf.t/Connector2"/>
        <linksTo rdf:resource="http://pygraf.t/Central1"/>
        <rdfs:label>Intermediary Node 3</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Multiplex1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Multiplex1">
        <rdf:type rdf:resource="http://pygraf.t/MultiplexNode"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode1"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode2"/>
        <connectsTo rdf:resource="http://pygraf.t/SuperNode1"/>
        <rdfs:comment>Participates in multiple relation types and layers.</rdfs:comment>
        <rdfs:label>Multiplex Node 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/RelationType1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/RelationType1">
        <rdf:type rdf:resource="http://pygraf.t/Relation"/>
        <rdfs:comment>A specific relation type for multiplex nodes.</rdfs:comment>
        <rdfs:label>Relation Type 1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/RelationType2 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/RelationType2">
        <rdf:type rdf:resource="http://pygraf.t/Relation"/>
        <rdfs:comment>Another relation type for high-degree nodes.</rdfs:comment>
        <rdfs:label>Relation Type 2</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/SuperNode1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/SuperNode1">
        <rdf:type rdf:resource="http://pygraf.t/SuperNode"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode1"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode2"/>
        <connectsTo rdf:resource="http://pygraf.t/Hub1"/>
        <connectsTo rdf:resource="http://pygraf.t/Multiplex1"/>
        <rdfs:comment>An overarching node representing a superstructure.</rdfs:comment>
        <rdfs:label>Super Node 1</rdfs:label>
    </owl:NamedIndividual>
</rdf:RDF>



