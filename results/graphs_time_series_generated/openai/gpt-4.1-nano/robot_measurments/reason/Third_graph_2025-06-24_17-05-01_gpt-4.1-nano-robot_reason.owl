        <rdfs:comment>A node participating in multiple relation types, representing complex interactions.</rdfs:comment>
        <rdfs:label>Multiplex Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/SuperNode -->

    <owl:Class rdf:about="http://pygraf.t/SuperNode">
