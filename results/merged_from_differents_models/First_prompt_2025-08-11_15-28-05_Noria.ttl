@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix fo: <http://example.com/> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree core router node acting as a central hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree switch connecting multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/PortStatus> ;
  noria:structuralObservableOf <https://example.com/ResourceSwitch1> .

<https://example.com/CentralNode1> a noria:FunctionalElement ;
  rdfs:label "Authentication Server"@en ;
  rdfs:comment "A central node responsible for user authentication."@en ;
  noria:elementManagedBy <https://example.com/ITSecurityTeam> .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node acting as a firewall boundary."@en ;
  noria:structuralElementObservable <https://example.com/observable/FirewallStatus> ;
  noria:structuralObservableOf <https://example.com/ResourceFirewall1> .

<https://example.com/IntermediaryNode1> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/MultiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/StreamStatus> ;
  noria:structuralObservableOf <https://example.com/ResourceStream1> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Main Switch"@en ;
  rdfs:comment "A super node representing a data center backbone switch."@en ;
  noria:structuralElementObservable <https://example.com/observable/PowerStatus> ;
  noria:structuralObservableOf <https://example.com/ResourceDataCenterSwitch> .

<https://example.com/ResourceSwitch1> a noria:Resource ;
  rdfs:label "Edge Switch 1"@en ;
  rdfs:comment "An edge switch connecting to access points."@en ;
  noria:resourceLogisticId "RSW1-XYZ" ;
  noria:resourceHostName "edge-switch-1" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagedBy <https://example.com/NetworkTeam> .

<https://example.com/ResourceFirewall1> a noria:Resource ;
  rdfs:label "Firewall Appliance 1"@en ;
  rdfs:comment "A firewall device controlling network access."@en ;
  noria:resourceLogisticId "FW-001" ;
  noria:resourceHostName "firewall-1" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/NetworkSecurityTeam> .

<https://example.com/ResourceDataCenterSwitch> a noria:Resource ;
  rdfs:label "Data Center Core Switch"@en ;
  rdfs:comment "Main switch in the data center backbone."@en ;
  noria:resourceLogisticId "DCS-CORE" ;
  noria:resourceHostName "dc-core-switch" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
  noria:locatedAtLocus <https://example.com/Locus3> ;
  noria:resourceManagedBy <https://example.com/DataCenterOps> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Main server room in building A."@en ;
  noria:locusLine "L" ;
  noria:locusRow "6" .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Firewall Zone"@en ;
  rdfs:comment "Dedicated zone for firewall appliances."@en ;
  noria:locusLine "F" ;
  noria:locusRow "1" .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Data Center Main"@en ;
  rdfs:comment "Main data center location."@en ;
  noria:locusLine "D" ;
  noria:locusRow "1" .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Security Team"@en ;
  rdfs:comment "Team managing security devices."@en .

<https://example.com/OperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Operations Team"@en ;
  rdfs:comment "Team handling operational tasks."@en .

<https://example.com/DataCenterOps> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en ;
  rdfs:comment "Team managing data center resources."@en .

<https://example.com/observable/PortStatus> a noria:StructuralObservable ;
  rdfs:label "Port Status"@en ;
  rdfs:comment "Observable for port operational status."@en .

<https://example.com/observable/FirewallStatus> a noria:StructuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Observable for firewall device status."@en .

<https://example.com/observable/StreamStatus> a noria:StructuralObservable ;
  rdfs:label "Stream Status"@en ;
  rdfs:comment "Observable for data stream health."@en .

<https://example.com/observable/PowerStatus> a noria:StructuralObservable ;
  rdfs:label "Power Status"@en ;
  rdfs:comment "Observable for power supply status."@en .