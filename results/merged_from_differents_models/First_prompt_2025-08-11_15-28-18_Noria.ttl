@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:ManagedElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high connectivity degree, acting as a key connector."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:ManagedElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:ManagedElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node that connects different network segments or systems."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/intermediaryNode> a noria:ManagedElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode> a noria:ManagedElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node that multiplexes multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with superordinate control or aggregation role."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "A physical or logical hub node in the network."@en ;
  noria:structuralElementObservable <https://example.com/HubNodeObservable> .

<https://example.com/HubNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Hub Node Observable"@en ;
  rdfs:comment "Observable properties of the Hub Node."@en .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a key connector."@en ;
  noria:structuralElementObservable <https://example.com/HighDegreeNodeObservable> .

<https://example.com/HighDegreeNodeObservable> a noria:StructuralObservable ;
  rdfs:label "High-Degree Node Observable"@en ;
  rdfs:comment "Observable properties of the High-Degree Node."@en .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/CentralNodeObservable> .

<https://example.com/CentralNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Central Node Observable"@en ;
  rdfs:comment "Observable properties of the Central Node."@en .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservable <https://example.com/ConnectorNodeObservable> .

<https://example.com/ConnectorNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Connector Node Observable"@en ;
  rdfs:comment "Observable properties of the Connector Node."@en .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/IntermediaryNodeObservable> .

<https://example.com/IntermediaryNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Intermediary Node Observable"@en ;
  rdfs:comment "Observable properties of the Intermediary Node."@en .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node that multiplexes multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/MultiplexNodeObservable> .

<https://example.com/MultiplexNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Multiplex Node Observable"@en ;
  rdfs:comment "Observable properties of the Multiplex Node."@en .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with superordinate control or aggregation role."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeObservable> .

<https://example.com/SuperNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Super Node Observable"@en ;
  rdfs:comment "Observable properties of the Super Node."@en .

<https://example.com/Network> a noria:Application ;
  rdfs:label "Network Application"@en ;
  rdfs:comment "A network application representing a specific network service."@en ;
  noria:applicationType <https://example.com/NetworkType> .

<https://example.com/NetworkType> a skos:Concept ;
  rdfs:label "Network Type"@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A network resource representing a server."@en ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceHostName "server1.example.com" ;
  noria:locatedAtLocus <https://example.com/Locus1> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Location within Server Room 314."@en ;
  noria:locusLine "L" ;
  noria:locusRow "6" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLK-001" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A network switch."@en ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceHostName "switch1.example.com" ;
  noria:locatedAtLocus <https://example.com/Locus2> .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Location within Server Room 314."@en ;
  noria:locusLine "L" ;
  noria:locusRow "7" .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Lead network administrator responsible for managing network nodes."@en .

<https://example.com/HubNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/HighDegreeNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/CentralNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/ConnectorNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/IntermediaryNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/MultiplexNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/SuperNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/HubNode> noria:structuralElementObservable <https://example.com/HubNodeObservable> .
<https://example.com/HighDegreeNode> noria:structuralElementObservable <https://example.com/HighDegreeNodeObservable> .
<https://example.com/CentralNode> noria:structuralElementObservable <https://example.com/CentralNodeObservable> .
<https://example.com/ConnectorNode> noria:structuralElementObservable <https://example.com/ConnectorNodeObservable> .
<https://example.com/IntermediaryNode> noria:structuralElementObservable <https://example.com/IntermediaryNodeObservable> .
<https://example.com/MultiplexNode> noria:structuralElementObservable <https://example.com/MultiplexNodeObservable> .
<https://example.com/SuperNode> noria:structuralElementObservable <https://example.com/SuperNodeObservable> .

<https://example.com/HubNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Hub Node Observable"@en ;
  rdfs:comment "Observable properties of the Hub Node."@en .

<https://example.com/HighDegreeNodeObservable> a noria:StructuralObservable ;
  rdfs:label "High-Degree Node Observable"@en ;
  rdfs:comment "Observable properties of the High-Degree Node."@en .

<https://example.com/CentralNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Central Node Observable"@en ;
  rdfs:comment "Observable properties of the Central Node."@en .

<https://example.com/ConnectorNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Connector Node Observable"@en ;
  rdfs:comment "Observable properties of the Connector Node."@en .

<https://example.com/IntermediaryNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Intermediary Node Observable"@en ;
  rdfs:comment "Observable properties of the Intermediary Node."@en .

<https://example.com/MultiplexNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Multiplex Node Observable"@en ;
  rdfs:comment "Observable properties of the Multiplex Node."@en .

<https://example.com/SuperNodeObservable> a noria:StructuralObservable ;
  rdfs:label "Super Node Observable"@en ;
  rdfs:comment "Observable properties of the Super Node."@en .