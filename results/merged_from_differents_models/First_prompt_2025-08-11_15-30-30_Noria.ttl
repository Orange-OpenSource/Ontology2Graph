@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Data Center Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central switch in the data center."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/connectionCount> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Firewall"@en ;
  rdfs:comment "A node with high centrality, managing security policies across the network."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/securityStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "VPN Gateway"@en ;
  rdfs:comment "A connector node linking remote sites via VPN."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/vpnStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/trafficDistribution> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node integrating multiple subsystems."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/systemHealth> ;
  noria:elementManagedBy <https://example.com/ITManagement> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing technical support for network devices."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team managing network security policies."@en .

<https://example.com/NetworkOps> a foaf:Agent ;
  rdfs:label "Network Operations Agent"@en ;
  rdfs:comment "Agent responsible for network operations."@en .

<https://example.com/ITManagement> a foaf:Agent ;
  rdfs:label "IT Management Agent"@en ;
  rdfs:comment "Agent overseeing overall IT system health."@en .

<https://example.com/observable/connectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at the node."@en .

<https://example.com/observable/securityStatus> a noria:StructuralObservable ;
  rdfs:label "Security Status"@en ;
  rdfs:comment "Current security status of the node."@en .

<https://example.com/observable/vpnStatus> a noria:StructuralObservable ;
  rdfs:label "VPN Status"@en ;
  rdfs:comment "Operational status of the VPN connection."@en .

<https://example.com/observable/trafficDistribution> a noria:StructuralObservable ;
  rdfs:label "Traffic Distribution"@en ;
  rdfs:comment "Distribution of network traffic across servers."@en .

<https://example.com/observable/streamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/observable/systemHealth> a noria:StructuralObservable ;
  rdfs:label "System Health"@en ;
  rdfs:comment "Overall health status of the system."@en .