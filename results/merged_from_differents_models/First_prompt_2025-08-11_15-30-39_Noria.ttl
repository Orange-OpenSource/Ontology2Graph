@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within a subnetwork."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/segmentConnections> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservableData <https://example.com/subNodeCount> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes."@en .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "A fiber optic link connecting HubNode and CentralNode."@en ;
  noria:networkLinkId "Link-001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Wireless Link B-C"@en ;
  rdfs:comment "Wireless connection between HighDegreeNode and ConnectorNode."@en ;
  noria:networkLinkId "Link-002" ;
  noria:networkLinkInstallationDate "2022-03-10T09:30:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Wireless" .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Main Hub"@en ;
  rdfs:comment "The central hub node with high connectivity."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralElementObservable <https://example.com/connection1> ;
  noria:structuralElementObservable <https://example.com/connection2> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Switch 42"@en ;
  rdfs:comment "A high-degree switch connecting multiple segments."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:structuralElementObservable <https://example.com/connection1> ;
  noria:structuralElementObservable <https://example.com/connection2> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Data Center Core"@en ;
  rdfs:comment "A central node within the data center."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Edge Router"@en ;
  rdfs:comment "Router connecting edge segments."@en ;
  noria:structuralElementObservableData <https://example.com/segmentConnections> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Data Aggregator"@en ;
  rdfs:comment "Node aggregating data streams."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Stream Multiplexer"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Network Super Node"@en ;
  rdfs:comment "Aggregated super node for entire network segment."@en ;
  noria:structuralElementObservableData <https://example.com/subNodeCount> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .