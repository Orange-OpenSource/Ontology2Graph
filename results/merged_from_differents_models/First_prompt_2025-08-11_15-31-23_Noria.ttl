@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservable <https://example.com/observable/connectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality, crucial for network integrity."@en ;
  noria:structuralElementObservable <https://example.com/observable/centralityScore> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/segmentConnections> ;
  noria:elementManagedBy <https://example.com/SegmentSupport> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/observable/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/DataFlowTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable/aggregationLevel> ;
  noria:elementManagedBy <https://example.com/SuperNodeOps> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical network resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "host-resource1" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelA> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual network resource."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "host-resource2" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Provisioned> ;
  noria:resourceInstallationDate "2023-03-10T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelB> ;
  noria:resourceManagedBy <https://example.com/VirtualizationTeam> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Optical Fiber Link"@en ;
  rdfs:comment "A high-speed optical fiber connection."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2021-06-20T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet port 0"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary virtual interface."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "VLAN interface"@en ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceRoutingPriorityMetric 200 ;
  noria:networkInterfaceLaserTxOpticalPower -1 ;
  noria:networkInterfaceLaserRxOpticalPower -4 .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "L" ;
  noria:locusRow "6" .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Secondary data center."@en ;
  noria:locusLine "R" ;
  noria:locusRow "12" .

<https://example.com/ProductModelA> a noria:ProductModel ;
  rdfs:label "Model A"@en ;
  rdfs:comment "Manufacturer's model A."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerX> .

<https://example.com/ProductModelB> a noria:ProductModel ;
  rdfs:label "Model B"@en ;
  rdfs:comment "Manufacturer's model B."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerY> .

<https://example.com/ManufacturerX> a org:Organization ;
  rdfs:label "Manufacturer X"@en ;
  rdfs:comment "Leading hardware manufacturer."@en .

<https://example.com/ManufacturerY> a org:Organization ;
  rdfs:label "Manufacturer Y"@en ;
  rdfs:comment "Virtualization platform provider."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for physical resources."@en .

<https://example.com/VirtualizationTeam> a org:OrganizationalUnit ;
  rdfs:label "Virtualization Team"@en ;
  rdfs:comment "Team managing virtual resources."@en .

<https://example.com/SegmentSupport> a org:OrganizationalUnit ;
  rdfs:label "Segment Support"@en ;
  rdfs:comment "Support team for network segments."@en .

<https://example.com/DataFlowTeam> a org:OrganizationalUnit ;
  rdfs:label "Data Flow Team"@en ;
  rdfs:comment "Team overseeing data streams."@en .

<https://example.com/StreamManagement> a org:OrganizationalUnit ;
  rdfs:label "Stream Management"@en ;
  rdfs:comment "Team managing multiplexed streams."@en .

<https://example.com/SuperNodeOps> a org:OrganizationalUnit ;
  rdfs:label "Super Node Operations"@en ;
  rdfs:comment "Operations team for super nodes."@en .