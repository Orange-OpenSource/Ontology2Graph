@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A highly connected network switch with numerous links."@en ;
  noria:structuralElementObservableData <https://example.com/LinkCount> ;
  noria:elementManagedBy <https://example.com/NetworkAdminTeam> .

<https://example.com/centralNode> a noria:FunctionalElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A core server providing essential services."@en ;
  noria:elementDistinguishedName "Server-01" ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A router connecting different network zones."@en ;
  noria:structuralElementObservableData <https://example.com/ConnectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A switch facilitating traffic between segments."@en ;
  noria:structuralElementObservableData <https://example.com/TrafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A device aggregating multiple links."@en ;
  noria:structuralElementObservableData <https://example.com/LinkAggregationCount> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An advanced node with multiple roles and high capacity."@en ;
  noria:structuralElementObservableData <https://example.com/Capacity> ;
  noria:elementManagedBy <https://example.com/InfrastructureDept> .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "A central node with high connectivity."@en ;
  noria:elementDistinguishedName "Hub-01" ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A switch with many links."@en ;
  noria:structuralElementObservableData <https://example.com/LinkCount> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/CentralNode> a noria:FunctionalElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "Core server providing main services."@en ;
  noria:elementDistinguishedName "Server-Alpha" ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Router"@en ;
  rdfs:comment "Router connecting network zones."@en ;
  noria:structuralElementObservableData <https://example.com/ConnectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Switch"@en ;
  rdfs:comment "Switch facilitating traffic flow."@en ;
  noria:structuralElementObservableData <https://example.com/TrafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Device"@en ;
  rdfs:comment "Device aggregating multiple links."@en ;
  noria:structuralElementObservableData <https://example.com/LinkCount> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/SuperNode> a noria:StructuralElement ;
