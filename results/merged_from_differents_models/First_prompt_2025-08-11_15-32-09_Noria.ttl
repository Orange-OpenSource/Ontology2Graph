@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Data Center Switch"@en ;
  rdfs:comment "High-degree node with many connections in the data center."@en ;
  noria:structuralElementObservableData <https://example.com/PowerUsage> ;
  noria:structuralElementObservable <https://example.com/PowerUsage> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Firewall"@en ;
  rdfs:comment "A node acting as a central security control point."@en ;
  noria:structuralElementObservable <https://example.com/FirewallStatus> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Link Aggregation Switch"@en ;
  rdfs:comment "Connector node aggregating multiple links."@en ;
  noria:structuralElementObservable <https://example.com/LinkTraffic> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediate Router"@en ;
  rdfs:comment "Intermediary node routing traffic between segments."@en ;
  noria:structuralElementObservable <https://example.com/TrafficLoad> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "Device multiplexing multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/StreamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Super node managing multiple sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/NodeHealth> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Server A"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:resourceLogisticId "SRV-A-001" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceHostName "serverA.datacenter.local" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Router B"@en ;
  rdfs:comment "Edge router connecting to external network."@en ;
  noria:resourceLogisticId "RTR-B-002" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:resourceHostName "routerB.datacenter.local" .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Rack 12, Slot 3"@en ;
  rdfs:comment "Locus within server rack 12."@en ;
  noria:locusLine "Line:12" ;
  noria:locusRow "Row:3" .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Rack 5, Slot 1"@en ;
  rdfs:comment "Locus within network equipment rack 5."@en ;
  noria:locusLine "Line:5" ;
  noria:locusRow "Row:1" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Server A."@en ;
  noria:networkInterfaceType "physical"^^xsd:string ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/0"@en ;
  rdfs:comment "WAN interface of Router B."@en ;
  noria:networkInterfaceType "physical"^^xsd:string ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating fiber link is operational."@en ;
  noria:loggingTime "2024-03-15T12:00:00Z"^^xsd:dateTime ;
  noria:logText "Fiber link NL-001 is now active." ;
  noria:logOriginatingManagedObject <https://example.com/NetworkLink1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:alarmSeverity <https://www.w3.org/ns/seas#Normal> .

<https://example.com/Event2> a noria:EventRecord ;
  rdfs:label "Server CPU Overload"@en ;
  rdfs:comment "High CPU usage detected on Server A."@en ;
  noria:loggingTime "2024-03-15T12:30:00Z"^^xsd:dateTime ;
  noria:logText "CPU usage exceeded 90%." ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/MonitoringSystem> ;
  noria:alarmSeverity <https://www.w3.org/ns/seas#Critical> .

<https://example.com/TroubleTicket1> a noria:TroubleTicket ;
  rdfs:label "TT-2024-0001"@en ;
  rdfs:comment "Network link fiber failure."@en ;
  <http://purl.org/dc/terms/identifier> "TT-2024-0001" ;
  noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major> ;
  noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
  noria:troubleTicketOrigin <https://example.com/Resource2> ;
  noria:troubleTicketImpacts <https://example.com/Resource2> ;
  noria:troubleTicketImpacts <https://example.com/Resource1> ;
  noria:troubleTicketDetectionDateTime "2024-03-15T12:05:00Z"^^xsd:dateTime ;
  noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status/InProgress> ;
  noria:troubleTicketRelatedResource <https://example.com/Resource2> ;
  noria:troubleTicketRelatedService <https://example.com/Service1> .

<https://example.com/Service1> a noria:Service ;
  rdfs:label "Core Network Service"@en ;
  rdfs:comment "Main core network connectivity service."@en ;
  noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> .

<https://example.com/ChangeRequest1> a noria:ChangeRequest ;
  rdfs:label "CR-2024-001"@en ;
  rdfs:comment "Upgrade fiber link NL-001."@en ;
  <http://purl.org/dc/terms/identifier> "CR-2024-001" ;
  noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/Configuration> ;
  noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/Configuration> ;
  noria:changeRequestImpact <https://example.com/Resource2> ;
  noria:changeRequestImpact <https://example.com/Resource1> ;
  noria:changeRequestPlannedStartTime "2024-03-20T08:00:00Z"^^xsd:dateTime ;
  noria:changeRequestPlannedEndTime "2024-03-20T12:00:00Z"^^xsd:dateTime .

<https://example.com/Document1> a noria:DocumentAttachment ;
  rdfs:label "Fiber Link Repair Plan"@en ;
  rdfs:comment "Detailed plan for fiber link NL-001 repair."@en ;
  noria:documentExternalId "DOC-2024-0001" ;
  noria:documentHRef "http://docs.example.com/CR-2024-001" .

<https://example.com/TicketNote1> a noria:TroubleTicketNote ;
  rdfs:label "Note on fiber repair"@en ;
  rdfs:comment "Repair scheduled for fiber link NL-001."@en ;
  noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Customer> ;
  noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Repair> ;
  noria:troubleTicketNoteCorrelatedExecution <https://example.com/Operation1> .

<https://example.com/Operation1> a noria:OperationPlan ;
  rdfs:label "Fiber Link Repair Operation"@en ;
  rdfs:comment "Operational plan to repair fiber link NL-001."@en .

<https://example.com/Agent1> a foaf:Agent ;
  rdfs:label "Network Engineer Alice"@en ;
  rdfs:comment "Lead engineer responsible for network repairs."@en .

<https://example.com/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System"@en ;
  rdfs:comment "System monitoring network events."@en .

<https://example.com/MonitoringSystem> a noria:Application ;
  rdfs:label "Monitoring System"@en ;
  rdfs:comment "System detecting anomalies and thresholds."@en .

<https://w3id.org/noria/kos/TroubleTicket/severity/Major> a skos:Concept ;
  rdfs:label "Major"@en .

<https://w3id.org/noria/kos/TroubleTicket/type/Failure> a skos:Concept ;
  rdfs:label "Failure"@en .

<https://w3id.org/noria/kos/TroubleTicket/status/InProgress> a skos:Concept ;
  rdfs:label "InProgress"@en .

<https://w3id.org/noria/kos/service/type/CustomerFacingService> a skos:Concept ;
  rdfs:label "Customer Facing Service"@en .

<https://w3id.org/noria/kos/Resource/type/Server> a skos:Concept ;
  rdfs:label "Server"@en .

<https://w3id.org/noria/kos/Resource/type/Router> a skos:Concept ;
  rdfs:label "Router"@en .

<https://w3id.org/noria/kos/ChangeRequest/category/Configuration> a skos:Concept ;
  rdfs:label "Configuration"@en .

<https://w3id.org/noria/kos/ChangeRequest/type/Configuration> a skos:Concept ;
  rdfs:label "Configuration"@en .

<https://w3id.org/noria/kos/TroubleTicket/commentType/Customer> a skos:Concept ;
  rdfs:label "Customer"@en .

<https://w3id.org/noria/kos/TroubleTicket/operationType/Repair> a skos:Concept ;
  rdfs:label "Repair"@en .

