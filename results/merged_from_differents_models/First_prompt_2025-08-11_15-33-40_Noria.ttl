@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/NodeDegree> ;
  noria:structuralElementObservable <https://example.com/NodeDegreeObservable> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central to multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/TrafficFlow> ;
  noria:structuralElementObservableData <https://example.com/TrafficVolume> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network domains."@en ;
  noria:structuralElementObservable <https://example.com/ConnectionStatus> ;
  noria:structuralElementObservableData <https://example.com/ConnectionQuality> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/DataLatency> ;
  noria:structuralElementObservableData <https://example.com/LatencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/StreamCount> ;
  noria:structuralElementObservableData <https://example.com/StreamNumber> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeTraffic> ;
  noria:structuralElementObservableData <https://example.com/TotalTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes."@en .

<https://example.com/NodeDegree> a noria:Property ;
  rdfs:label "Node Degree"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/NodeDegreeObservable> a noria:StructuralObservable ;
  rdfs:label "Node Degree Observable"@en ;
  rdfs:comment "Observable property for node degree."@en .

<https://example.com/TrafficFlow> a noria:Property ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Flow of traffic through a node."@en .

<https://example.com/TrafficVolume> a noria:StructuralObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Measured volume of traffic."@en .

<https://example.com/ConnectionStatus> a noria:Property ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection (up/down)."@en .

<https://example.com/ConnectionQuality> a noria:StructuralObservable ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Quality metrics of the connection."@en .

<https://example.com/DataLatency> a noria:Property ;
  rdfs:label "Data Latency"@en ;
  rdfs:comment "Latency in data transmission."@en .

<https://example.com/LatencyMeasurement> a noria:StructuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Observable for latency."@en .

<https://example.com/StreamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams handled."@en .

<https://example.com/StreamNumber> a noria:StructuralObservable ;
  rdfs:label "Stream Number"@en ;
  rdfs:comment "Observable for stream count."@en .

<https://example.com/SuperNodeTraffic> a noria:Property ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Total traffic handled by super node."@en .

<https://example.com/TotalTraffic> a noria:StructuralObservable ;
  rdfs:label "Total Traffic"@en ;
  rdfs:comment "Observable for total traffic."@en .