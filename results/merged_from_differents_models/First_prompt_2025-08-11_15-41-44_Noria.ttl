@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A switch with high connectivity degree, acting as a network backbone."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "A core router serving as a central point in the network."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A relay node facilitating data transfer."@en ;
  noria:structuralElementObservableData <https://example.com/transferRate> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node multiplexing multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network nodes and links."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical network resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "host-resource1" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://example.com/ResourceType/Server> ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceUsageState <https://example.com/ResourceState/Active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagedBy <https://example.com/NetworkOperations> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Location within Server Room 314."@en ;
  noria:locusLine "Line:L, in Room:Server room 314" .

<https://example.com/ResourceType/Server> a skos:Concept ;
  rdfs:label "Server"@en .

<https://example.com/ResourceState/Active> a skos:Concept ;
  rdfs:label "Active"@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model name for Resource1."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "Manufacturer A"@en ;
  rdfs:comment "Manufacturer of ProductModelX."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLK-001" ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkInstallationDate "2021-12-01T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Backup server."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:resourceHostName "host-resource2" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceType <https://example.com/ResourceType/Server> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://example.com/ResourceState/Active> ;
  noria:resourceInstallationDate "2022-02-20T11:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceManagedBy <https://example.com/NetworkOperations> .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Location in Data Center."@en .

<https://example.com/ProductModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Manufacturer's model name for Resource2."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "Manufacturer B"@en ;
  rdfs:comment "Manufacturer of ProductModelY."@en .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "Network switch."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "switch-01" ;
  noria:locatedAtLocus <https://example.com/LocusC> ;
  noria:resourceType <https://example.com/ResourceType/Switch> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceUsageState <https://example.com/ResourceState/Active> ;
  noria:resourceInstallationDate "2020-11-10T08:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelZ> ;
  noria:resourceManagedBy <https://example.com/NetworkOperations> .

<https://example.com/LocusC> a noria:Locus ;
  rdfs:label "Locus C"@en ;
  rdfs:comment "Location in Main Switch Room."@en .

<https://example.com/ProductModelZ> a noria:ProductModel ;
  rdfs:label "Model Z"@en ;
  rdfs:comment "Manufacturer's model name for Resource3."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerC> .

<https://example.com/ManufacturerC> a org:Organization ;
  rdfs:label "Manufacturer C"@en ;
  rdfs:comment "Manufacturer of ProductModelZ."@en .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Main Hub Switch"@en ;
  rdfs:comment "Central switch connecting multiple segments."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/HighDegreeSwitch> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A switch with high connectivity, backbone node."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/CentralRouter> a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "Main router in the core network."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Relays data between nodes."@en ;
  noria:structuralElementObservableData <https://example.com/transferRate> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node multiplexing multiple streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple nodes for high-level control."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .