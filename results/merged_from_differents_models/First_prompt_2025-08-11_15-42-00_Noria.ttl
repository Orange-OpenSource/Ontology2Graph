@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, serving as a critical connector."@en ;
  noria:structuralElementObservable <https://example.com/observable/NodeLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/observable/TrafficFlow> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/LinkStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that facilitates data transfer between other nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable/PacketLoss> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/StreamThroughput> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node with extensive connectivity, acting as a super hub."@en ;
  noria:structuralElementObservable <https://example.com/observable/NetworkCapacity> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes."@en .

<https://example.com/observable/NodeLoad> a noria:StructuralObservable ;
  rdfs:label "Node Load"@en ;
  rdfs:comment "Current load on a network node."@en .

<https://example.com/observable/TrafficFlow> a noria:StructuralObservable ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Flow of traffic through a node."@en .

<https://example.com/observable/LinkStatus> a noria:StructuralObservable ;
  rdfs:label "Link Status"@en ;
  rdfs:comment "Operational status of a network link."@en .

<https://example.com/observable/PacketLoss> a noria:StructuralObservable ;
  rdfs:label "Packet Loss"@en ;
  rdfs:comment "Packet loss rate on a node or link."@en .

<https://example.com/observable/StreamThroughput> a noria:StructuralObservable ;
  rdfs:label "Stream Throughput"@en ;
  rdfs:comment "Data throughput of a multiplex node."@en .

<https://example.com/observable/NetworkCapacity> a noria:StructuralObservable ;
  rdfs:label "Network Capacity"@en ;
  rdfs:comment "Total capacity of the super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical network resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceHostName "host-resource1" ;
  noria:resourceType <https://example.com/kos/Resource/type/Physical> ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceUsageState <https://example.com/kos/Resource/LifecycleState/Active> ;
  noria:resourceManagementIPAddress "192.168.1.10" ;
  noria:resourceProductModel <https://example.com/ResourceModelX> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "L" ;
  noria:locusRow "6" .

<https://example.com/ResourceModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model X."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerY> .

<https://example.com/ManufacturerY> a org:Organization ;
  rdfs:label "Manufacturer Y"@en ;
  rdfs:comment "Leading hardware manufacturer."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link 1"@en ;
  rdfs:comment "Optical fiber link between core nodes."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource2> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource3> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Secondary resource endpoint."@en .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "Destination resource endpoint."@en .

<https://example.com/observable/NetworkCapacity> a noria:StructuralObservable ;
  rdfs:label "Network Capacity"@en ;
  rdfs:comment "Capacity of the super node."@en .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub with extensive connections."@en ;
  noria:structuralElementObservable <https://example.com/observable/NetworkCapacity> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, critical for network resilience."@en ;
  noria:structuralElementObservable <https://example.com/observable/NodeLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node acting as a central point in the topology."@en ;
  noria:structuralElementObservable <https://example.com/observable/TrafficFlow> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/LinkStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Facilitates data transfer between nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable/PacketLoss> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Handles multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/StreamThroughput> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Extensive connectivity node acting as a super hub."@en ;
  noria:structuralElementObservable <https://example.com/observable/NetworkCapacity> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .