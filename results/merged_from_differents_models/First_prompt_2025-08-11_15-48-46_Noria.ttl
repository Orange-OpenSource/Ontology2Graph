@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A highly connected network switch with numerous links."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:structuralObservableOf <https://example.com/NetworkSwitch1> .

<https://example.com/centralNode> a noria:FunctionalElement ;
  rdfs:label "Central Application Server"@en ;
  rdfs:comment "Core server hosting critical applications."@en ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a bridge between two network segments."@en ;
  noria:structuralElementObservableData <https://example.com/throughput> ;
  noria:structuralElementDistinguishedName "Connector-XYZ" .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Intermediate node facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/packetLossRate> ;
  noria:structuralObservableOf <https://example.com/Router2> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiple virtual connections."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/VirtualSwitch> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating several sub-nodes for load balancing."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/DataCenterSwitch> .

<https://example.com/Router1> a noria:StructuralElement ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Edge router connecting local network to backbone."@en ;
  noria:structuralElementDistinguishedName "Router1" .

<https://example.com/Router2> a noria:StructuralElement ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Intermediate router managing internal traffic."@en ;
  noria:structuralElementDistinguishedName "Router2" .

<https://example.com/NetworkSwitch1> a noria:StructuralElement ;
  rdfs:label "Network Switch 1"@en ;
  rdfs:comment "Core network switch with high port density."@en ;
  noria:structuralElementDistinguishedName "Switch1" .

<https://example.com/VirtualSwitch> a noria:StructuralElement ;
  rdfs:label "Virtual Switch"@en ;
  rdfs:comment "A virtual switch supporting VLANs."@en ;
  noria:structuralElementDistinguishedName "VSwitch1" .

<https://example.com/DataCenterSwitch> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "Switch within data center for server connections."@en ;
  noria:structuralElementDistinguishedName "DCSwitch" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between Router1 and Switch1."@en ;
  noria:networkLinkId "Link-AB" .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Ethernet Link B-C"@en ;
  rdfs:comment "Ethernet connection between Switch1 and Router2."@en ;
  noria:networkLinkId "Link-BC" .

<https://example.com/NetworkLink3> a noria:NetworkLink ;
  rdfs:label "Virtual Link V1"@en ;
  rdfs:comment "Virtual link within the data center."@en ;
  noria:networkLinkId "Link-V1" .

<https://example.com/latencyMeasurement> a noria:structuralObservableData ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Average latency in milliseconds."@en ;
  noria:structuralElementObservableData "10ms"^^xsd:string .

<https://example.com/throughput> a noria:structuralObservableData ;
  rdfs:label "Throughput"@en ;
  rdfs:comment "Maximum throughput in Gbps."@en ;
  noria:structuralElementObservableData "40Gbps"^^xsd:string .

<https://example.com/connectionCount> a noria:structuralObservableData ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en ;
  noria:structuralElementObservableData "256"^^xsd:string .

<https://example.com/packetLossRate> a noria:structuralObservableData ;
  rdfs:label "Packet Loss Rate"@en ;
  rdfs:comment "Packet loss percentage."@en ;
  noria:structuralElementObservableData "0.1%"^^xsd:string .

<https://example.com/trafficVolume> a noria:structuralObservableData ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Total traffic in TB."@en ;
  noria:structuralElementObservableData "120TB"^^xsd:string .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing technical support."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Primary network administrator responsible for maintenance."@en ;
  foaf:accountName "netadmin" .

<https://example.com/SupportEngineer> a foaf:Agent ;
  rdfs:label "Support Engineer"@en ;
  rdfs:comment "Engineer handling network issues."@en ;
  foaf:accountName "supportEng" .

<https://example.com/HubNode> a noria:hubNode ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node connecting core network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/HighDegreeSwitch> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A switch with high connectivity."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/NetworkSwitch1> .

<https://example.com/CentralAppServer> a noria:FunctionalElement ;
  rdfs:label "Central App Server"@en ;
  rdfs:comment "Server hosting core applications."@en ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Acts as a bridge between segments."@en ;
  noria:structuralElementObservableData <https://example.com/throughput> ;
  noria:structuralElementDistinguishedName "Connector-XYZ" .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Facilitates internal routing."@en ;
  noria:structuralElementObservableData <https://example.com/packetLossRate> ;
  noria:structuralObservableOf <https://example.com/Router2> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Supports multiple virtual connections."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/VirtualSwitch> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple nodes for load balancing."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/DataCenterSwitch> .