@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high connectivity, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/latency> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node that connects different network domains."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/throughput> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Core router in data center."@en ;
  noria:resourceLogisticId "LR-DC-001" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <http://purl.org/ontology/bibo/NetworkDevice> ;
  noria:resourceHostName "core-router-1" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Edge switch connecting access points."@en ;
  noria:resourceLogisticId "LR-ED-045" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceType <http://purl.org/ontology/bibo/NetworkDevice> ;
  noria:resourceHostName "edge-switch-3" .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "Virtual machine hosting critical application."@en ;
  noria:resourceLogisticId "VM-APP-789" ;
  noria:locatedAtLocus <https://example.com/LocusC> ;
  noria:resourceType <http://purl.org/ontology/bibo/ComputingDevice> ;
  noria:resourceHostName "vm-application" .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main Data Center Rack"@en ;
  noria:locusLine "Line: L, in Rack 12" .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Edge Switch Location"@en ;
  noria:locusLine "Line: L, in Rack 5" .

<https://example.com/LocusC> a noria:Locus ;
  rdfs:label "Locus C"@en ;
  rdfs:comment "Virtual Machine Host"@en ;
  noria:locusLine "Virtual Host Cluster 3" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link DC to Edge"@en ;
  rdfs:comment "Optical fiber connecting Data Center to Edge Switch."@en ;
  noria:networkLinkId "NL-DC-ED-01" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2021-06-15T09:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Virtual Link VM to App Server"@en ;
  rdfs:comment "Virtual network link between VM and application server."@en ;
  noria:networkLinkId "NL-VIRT-01" ;
  noria:networkLinkType "Virtual Network" ;
  noria:networkLinkInstallationDate "2022-01-10T10:30:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource3> ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource3> .

<https://example.com/Service1> a noria:Service ;
  rdfs:label "Core Network Service"@en ;
  rdfs:comment "Main core network data path."@en ;
  noria:serviceType <http://purl.org/ontology/bibo/Service> ;
  rdfs:seeAlso <https://github.com/tmforum-apis/TMF638_ServiceInventory> .

<https://example.com/Application1> a noria:Application ;
  rdfs:label "Customer Portal App"@en ;
  rdfs:comment "Web portal for customer interactions."@en ;
  noria:applicationModelIdentifier "CPA-Model-2023" ;
  noria:applicationNumericalIdentifier 101 ;
  noria:applicationShortIdentifier "CustPortal" ;
  noria:applicationType <http://purl.org/ontology/bibo/SoftwareApplication> ;
  noria:applicationBusinessImportance <skos:Concept> .

<https://example.com/ApplicationModule1> a noria:ApplicationModule ;
  rdfs:label "Customer Portal Module"@en ;
  rdfs:comment "Module handling customer login and account management."@en ;
  noria:applicationModuleIdentifier "CPAM-01" ;
  noria:applicationModuleName "Login and Account Management" ;
  noria:applicationModuleOf <https://example.com/Application1> ;
  noria:applicationModuleStatus <skos:Concept> .

<https://example.com/Agent1> a foaf:Agent ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en ;
  org:organization <https://example.com/OrgNetworkOps> .

<https://example.com/OrgNetworkOps> a org:Organization ;
  rdfs:label "Network Operations Organization"@en ;
  rdfs:comment "Organization managing network infrastructure."@en .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating network link is operational."@en ;
  noria:loggingTime "2023-10-01T14:22:00"^^xsd:dateTime ;
  noria:logText "Fiber link NL-DC-ED-01 is now active."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System"@en ;
  rdfs:comment "System monitoring network links."@en .

<https://example.com/Event2> a noria:EventRecord ;
  rdfs:label "VM Connection Established"@en ;
  rdfs:comment "Event indicating VM is connected to application server."@en ;
  noria:loggingTime "2023-10-02T09:45:00"^^xsd:dateTime ;
  noria:logText "Virtual machine VM-APP-789 connected to application server."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource3> ;
  noria:logOriginatingManagementSystem <https://example.com/VMMonitor> .

<https://example.com/VMMonitor> a noria:Application ;
  rdfs:label "VM Monitoring System"@en ;
  rdfs:comment "System monitoring virtual machines."@en .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting core resources."@en .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high connectivity, critical for network resilience."@en .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in topology."@en .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node aggregating multiple sub-nodes."@en .