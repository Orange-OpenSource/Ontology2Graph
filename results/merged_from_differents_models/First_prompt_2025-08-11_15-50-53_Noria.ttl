@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:ManagedElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high connectivity, acting as a major switch."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:ManagedElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:ManagedElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network domains."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryNode> a noria:ManagedElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode> a noria:ManagedElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Super node aggregating multiple nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "A physical or logical hub node in the network."@en ;
  noria:structuralElementObservable <https://example.com/HubNodeStatus> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high degree of connectivity."@en ;
  noria:structuralElementObservable <https://example.com/HighDegreeNodeStatus> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/CentralNodeStatus> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/ConnectorNodeStatus> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/IntermediaryNodeStatus> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Handles multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/MultiplexNodeStatus> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeStatus> .

<https://example.com/HubNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Hub Node Status"@en ;
  rdfs:comment "Operational status of the Hub Node."@en .

<https://example.com/HighDegreeNodeStatus> a noria:StructuralObservable ;
  rdfs:label "High-Degree Node Status"@en ;
  rdfs:comment "Operational status of the High-Degree Node."@en .

<https://example.com/CentralNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Central Node Status"@en ;
  rdfs:comment "Operational status of the Central Node."@en .

<https://example.com/ConnectorNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Connector Node Status"@en ;
  rdfs:comment "Operational status of the Connector Node."@en .

<https://example.com/IntermediaryNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Intermediary Node Status"@en ;
  rdfs:comment "Operational status of the Intermediary Node."@en .

<https://example.com/MultiplexNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Multiplex Node Status"@en ;
  rdfs:comment "Operational status of the Multiplex Node."@en .

<https://example.com/SuperNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Super Node Status"@en ;
  rdfs:comment "Operational status of the Super Node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A core network resource."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:resourceHostName "res1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/physical> ;
  noria:locatedAtLocus <https://example.com/Locus1> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual network resource."@en ;
  noria:resourceLogisticId "RES-002" ;
  noria:resourceHostName "res2.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtual> ;
  noria:locatedAtLocus <https://example.com/Locus2> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource 1 and Resource 2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical fiber" ;
  noria:networkLinkInstallationDate "2020-01-15T00:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A network switch."@en ;
  noria:resourceLogisticId "RES-003" ;
  noria:resourceHostName "switch1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/physical> ;
  noria:locatedAtLocus <https://example.com/Locus3> .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Link 2"@en ;
  rdfs:comment "Ethernet connection between Resource 3 and Resource 2."@en ;
  noria:networkLinkId "NL-002" ;
  noria:networkLinkType "Ethernet" ;
  noria:networkLinkInstallationDate "2021-06-10T00:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource3> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Data center rack."@en .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Locus 3"@en ;
  rdfs:comment "Network equipment room."@en .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Main Hub"@en ;
  rdfs:comment "Central hub node in the core network."@en ;
  noria:structuralElementObservable <https://example.com/HubNodeStatus> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Core Switch"@en ;
  rdfs:comment "High connectivity switch in the core."@en ;
  noria:structuralElementObservable <https://example.com/HighDegreeNodeStatus> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "Router serving as a central point."@en ;
  noria:structuralElementObservable <https://example.com/CentralNodeStatus> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Edge Connector"@en ;
  rdfs:comment "Connects edge network to core."@en ;
  noria:structuralElementObservable <https://example.com/ConnectorNodeStatus> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Switch"@en ;
  rdfs:comment "Intermediate switch in the network."@en ;
  noria:structuralElementObservable <https://example.com/IntermediaryNodeStatus> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/MultiplexNodeStatus> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeStatus> .

<https://example.com/HubNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Hub Node Status"@en ;
  rdfs:comment "Operational status of the Hub Node."@en .

<https://example.com/HighDegreeNodeStatus> a noria:StructuralObservable ;
  rdfs:label "High-Degree Node Status"@en ;
  rdfs:comment "Operational status of the High-Degree Node."@en .

<https://example.com/CentralNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Central Node Status"@en ;
  rdfs:comment "Operational status of the Central Node."@en .

<https://example.com/ConnectorNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Connector Node Status"@en ;
  rdfs:comment "Operational status of the Connector Node."@en .

<https://example.com/IntermediaryNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Intermediary Node Status"@en ;
  rdfs:comment "Operational status of the Intermediary Node."@en .

<https://example.com/MultiplexNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Multiplex Node Status"@en ;
  rdfs:comment "Operational status of the Multiplex Node."@en .

<https://example.com/SuperNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Super Node Status"@en ;
  rdfs:comment "Operational status of the Super Node."@en .