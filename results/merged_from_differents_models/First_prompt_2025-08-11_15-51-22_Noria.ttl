@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:structuralObservableOf <https://example.com/Router1> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central to multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/throughputObservable> ;
  noria:structuralObservableOf <https://example.com/SwitchA> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network domains."@en ;
  noria:structuralElementObservable <https://example.com/connectionQuality> ;
  noria:structuralObservableOf <https://example.com/FirewallX> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node serving as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:structuralObservableOf <https://example.com/Router2> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/throughputObservable> ;
  noria:structuralObservableOf <https://example.com/LoadBalancer1> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node representing a superordinate network segment."@en ;
  noria:structuralElementObservable <https://example.com/overallPerformance> ;
  noria:structuralObservableOf <https://example.com/DataCenterSwitch> .

<https://example.com/Router1> a noria:StructuralElement ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Main router in the core network."@en ;
  noria:elementDistinguishedName "Router1-Core" .

<https://example.com/Router2> a noria:StructuralElement ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Secondary router connecting branch networks."@en ;
  noria:elementDistinguishedName "Router2-Branch" .

<https://example.com/SwitchA> a noria:StructuralElement ;
  rdfs:label "SwitchA"@en ;
  rdfs:comment "Distribution switch in the data center."@en ;
  noria:elementDistinguishedName "SwitchA-DataCenter" .

<https://example.com/FirewallX> a noria:StructuralElement ;
  rdfs:label "FirewallX"@en ;
  rdfs:comment "Firewall device controlling access."@en ;
  noria:elementDistinguishedName "FirewallX-Perimeter" .

<https://example.com/LoadBalancer1> a noria:StructuralElement ;
  rdfs:label "LoadBalancer1"@en ;
  rdfs:comment "Load balancer for web services."@en ;
  noria:elementDistinguishedName "LoadBalancer-Web" .

<https://example.com/DataCenterSwitch> a noria:StructuralElement ;
  rdfs:label "DataCenterSwitch"@en ;
  rdfs:comment "Switch at the data center core."@en ;
  noria:elementDistinguishedName "DataCenterSwitch-Core" .

<https://example.com/overallPerformance> a noria:Property ;
  rdfs:label "Overall Network Performance"@en ;
  rdfs:comment "Aggregate performance metric of the network segment."@en .

<https://example.com/latencyObservable> a noria:StructuralObservable ;
  rdfs:label "Latency Observable"@en ;
  rdfs:comment "Observable measuring network latency."@en .

<https://example.com/throughputObservable> a noria:StructuralObservable ;
  rdfs:label "Throughput Observable"@en ;
  rdfs:comment "Observable measuring data throughput."@en .

<https://example.com/connectionQuality> a noria:StructuralObservable ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Observable indicating connection quality metrics."@en .

<https://example.com/overallPerformance> a noria:StructuralObservable ;
  rdfs:label "Overall Performance"@en ;
  rdfs:comment "Observable indicating overall network performance."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Primary network administrator responsible for core nodes."@en .

<https://example.com/NetworkEngineer> a foaf:Agent ;
  rdfs:label "Network Engineer"@en ;
  rdfs:comment "Engineer responsible for branch network nodes."@en .

<https://example.com/SupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Support Team"@en ;
  rdfs:comment "Support team managing network devices."@en .

