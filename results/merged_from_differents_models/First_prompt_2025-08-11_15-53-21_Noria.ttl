@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity, linking multiple nodes."@en ;
  noria:elementManagedBy <https://example.com/ITTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with a high number of connections, acting as a critical connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralElementObservable <https://example.com/connectionCountObs> .

<https://example.com/connectionCountObs> a noria:StructuralObservable ;
  rdfs:label "Connection Count Observable"@en ;
  rdfs:comment "Observable property indicating the number of connections for a node."@en .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservableData <https://example.com/centralityScore> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node that connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiplexing of multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/muxStatus> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level analysis."@en ;
  noria:structuralElementObservableData <https://example.com/aggregationLevel> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Physical resource representing a network switch."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "switch01.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkSwitch> ;
  noria:resourceSerialNumber "SN987654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model of the network switch."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "Network Equipment Inc."@en ;
  rdfs:comment "Manufacturer of Model X."@en .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Specific location within Server Room 314."@en .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Virtual machine hosting critical application."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "vm-application.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:resourceSerialNumber "VM123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2021-11-20T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Virtualization platform model."@en ;
  noria:productManufacturedBy <https://example.com/VirtualizationCorp> .

<https://example.com/VirtualizationCorp> a org:Organization ;
  rdfs:label "Virtualization Corp."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Location within Data Center 2."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for IT resource management."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Admin responsible for network resources."@en .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLK-001" ;
  noria:networkLinkInstallationDate "2019-03-10T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Virtual Link"@en ;
  rdfs:comment "Virtual network link between VM and external network."@en ;
  noria:networkLinkId "NLK-002" ;
  noria:networkLinkInstallationDate "2022-01-15T12:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "VLAN"@en ;
  noria:networkLinkTerminationResource <https://example.com/Resource2> .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Core Switch"@en ;
  rdfs:comment "High-capacity core switch acting as network hub."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/connectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections on the hub node."@en .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Distribution Switch"@en ;
  rdfs:comment "Switch with many connected devices, acting as a high-degree node."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCountObs> .

<https://example.com/connectionCountObs> a noria:StructuralObservable ;
  rdfs:label "Connection Count Observable"@en ;
  rdfs:comment "Observable for number of connections on high-degree node."@en .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "Router acting as a central point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/centralityScore> .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Observable indicating if the node is connected or disconnected."@en .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node that connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node that facilitates data flow between segments."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> .

<https://example.com/DataFlowRate> a noria:StructuralObservable ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data transfer through the node."@en .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiplexing."@en ;
  noria:structuralElementObservable <https://example.com/muxStatus> .

<https://example.com/muxStatus> a noria:StructuralObservable ;
  rdfs:label "MUX Status"@en ;
  rdfs:comment "Status of multiplexing capability."@en .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregated node for high-level analysis."@en ;
  noria:structuralElementObservableData <https://example.com/aggregationLevel> .

<https://example.com/aggregationLevel> a noria:StructuralObservable ;
  rdfs:label "Aggregation Level"@en ;
  rdfs:comment "Level of aggregation for super node."@en .
