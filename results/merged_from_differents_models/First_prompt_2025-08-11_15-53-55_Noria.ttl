@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:ManagedElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high connectivity degree, acting as a major switch."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central resource in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/centralNodeLoad> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/intermediaryLoad> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Handles multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/multiplexTraffic> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/superNodeLoad> .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "Physical server hosting critical applications."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceHostName "serverA.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceSerialNumber "SN-987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "Virtual machine for testing."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceHostName "vm-test.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Provisioned> ;
  noria:resourceInstallationDate "2023-03-01T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance server model."@en ;
  noria:productManufacturedBy <https://example.com/Manufacturer1> .

<https://example.com/ProductModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Virtualization platform."@en ;
  noria:productManufacturedBy <https://example.com/Manufacturer2> .

<https://example.com/Manufacturer1> a org:Organization ;
  rdfs:label "TechCorp Inc."@en ;
  rdfs:comment "Manufacturer of high-performance servers."@en .

<https://example.com/Manufacturer2> a org:Organization ;
  rdfs:label "VirtualSoft Ltd."@en ;
  rdfs:comment "Manufacturer of virtualization platforms."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Responsible for network infrastructure management."@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Testing environment."@en .

<https://example.com/centralNodeLoad> a noria:StructuralObservable ;
  rdfs:label "Central Node Load"@en ;
  rdfs:comment "Current load on the central node."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection between nodes."@en .

<https://example.com/intermediaryLoad> a noria:StructuralObservable ;
  rdfs:label "Intermediary Load"@en ;
  rdfs:comment "Load on the intermediary node."@en .

<https://example.com/multiplexTraffic> a noria:StructuralObservable ;
  rdfs:label "Multiplex Traffic"@en ;
  rdfs:comment "Traffic handled by multiplex node."@en .

<https://example.com/superNodeLoad> a noria:StructuralObservable ;
  rdfs:label "Super Node Load"@en ;
  rdfs:comment "Aggregate load on super node."@en .

<https://example.com/ResourceA> noria:structuralElementObservable <https://example.com/centralNodeLoad> .
<https://example.com/ResourceB> noria:structuralElementObservable <https://example.com/intermediaryLoad> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between ResourceA and ResourceB."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2021-06-10T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Notification that Fiber Link 1 is operational."@en ;
  noria:loggingTime "2023-10-01T12:00:00Z"^^xsd:dateTime ;
  noria:logText "Fiber Link 1 is now active."@en ;
  noria:logOriginatingManagedObject <https://example.com/ResourceA> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/NetworkAdmin> ;
  noria:alarmSeverity <https://skos.org/Notification/Severity/Major> .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Admin"@en ;
  rdfs:comment "Responsible for network configuration."@en .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en ;
  rdfs:comment "System monitoring network links."@en .

<https://example.com/ResourceA> noria:eventRelatedElement <https://example.com/Event1> .
<https://example.com/ResourceB> noria:eventRelatedElement <https://example.com/Event1> .

<https://example.com/ResourceA> noria:troubleTicketRelatedResource <https://example.com/TroubleTicket1> .

<https://example.com/TroubleTicket1> a noria:TroubleTicket ;
  rdfs:label "Network Link Failure"@en ;
  rdfs:comment "Failure detected on Fiber Link 1."@en ;
  noria:troubleTicketSeverity <https://skos.org/Notification/Severity/Critical> ;
  noria:troubleTicketType <https://skos.org/kos/TroubleTicket/type/Failure> ;
  noria:troubleTicketStatusCurrent <https://skos.org/kos/TroubleTicket/status/InProgress> ;
  noria:troubleTicketDetectionDateTime "2023-10-01T12:05:00Z"^^xsd:dateTime ;
  noria:troubleTicketImpacts <https://example.com/ResourceA> , <https://example.com/ResourceB> ;
  noria:troubleTicketRelatedParty <https://example.com/NetworkAdmin> .

<https://example.com/TroubleTicket1> noria:troubleTicketNoteCommentType <https://skos.org/Notification/CommentType/System> .

<https://example.com/ChangeRequest1> a noria:ChangeRequest ;
  rdfs:label "Upgrade Fiber Link 1"@en ;
  rdfs:comment "Planned upgrade to fiber link."@en ;
  noria:changeRequestId "CR-20231001" ;
  noria:changeRequestCreationDateTime "2023-10-01T12:10:00Z"^^xsd:dateTime ;
  noria:changeRequestChangeCause "Upgrade to higher capacity fiber."@en ;
  noria:changeRequestImpact <https://example.com/ResourceA> ;
  noria:changeRequestImpact <https://example.com/ResourceB> ;
  noria:changeRequestStatusCurrent <https://skos.org/kos/ChangeRequest/status/Planned> ;
  noria:changeRequestActorParty <https://example.com/NetworkAdmin> .

<https://example.com/Document1> a noria:DocumentAttachment ;
  rdfs:label "Upgrade Plan Document"@en ;
  rdfs:comment "Document detailing the fiber upgrade plan."@en ;
  noria:documentExternalId "DOC-20231001" ;
  noria:documentHRef "https://docs.example.com/upgrade_plan.pdf"^^xsd:anyURI ;
  noria:documentStatusHistory <https://example.com/Event1> .

<https://example.com/ResourceA> noria:changeRequestImpact <https://example.com/ChangeRequest1> .
<https://example.com/ResourceB> noria:changeRequestImpact <https://example.com/ChangeRequest1> .