@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Define Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that acts as a key connector within the network." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different parts of the network." .

sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as a bridge between other nodes." .

sc:MultiplexNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node participating in multiple types of relations." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A node with extensive connections across the network." .

# Define Object Properties
sc:connectsTo a owl:ObjectProperty ;
    rdfs:label "connects to" ;
    rdfs:comment "Indicates a connection between two nodes." .

sc:relatesTo a owl:ObjectProperty ;
    rdfs:label "relates to" ;
    rdfs:comment "Indicates a relation of any kind between two nodes." .

sc:linksTo a owl:ObjectProperty ;
    rdfs:label "links to" ;
    rdfs:comment "A directional link from one node to another." .

# Define specific relations (examples)
sc:hasRelation a owl:ObjectProperty ;
    rdfs:label "has relation" ;
    rdfs:comment "A generic relation between entities." .

# Entities with various node types
# Hub Node
sc:Hub1 a sc:HubNode ;
    rdfs:label "Main Hub" ;
    rdfs:comment "The central hub connecting multiple high-degree nodes." ;
    sc:connectsTo sc:HighNode1, sc:HighNode2, sc:Connector1 .

# High Degree Nodes
sc:HighNode1 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node 1" ;
    rdfs:comment "A node with many connections to other nodes." ;
    sc:connectsTo sc:Hub1, sc:InterNode1, sc:Multiplex1 .

sc:HighNode2 a sc:HighDegreeNode ;
    rdfs:label "High Degree Node 2" ;
    rdfs:comment "Another high-degree node connected to the main hub." ;
    sc:connectsTo sc:Hub1, sc:InterNode2 .

# Central Node
sc:Central1 a sc:CentralNode ;
    rdfs:label "Central Node 1" ;
    rdfs:comment "A key connector bridging different network parts." ;
    sc:connectsTo sc:InterNode1, sc:InterNode2, sc:Connector2 .

# Connector Nodes
sc:Connector1 a sc:ConnectorNode ;
    rdfs:label "Connector Node 1" ;
    rdfs:comment "Connects high-degree nodes to intermediary nodes." ;
    sc:connectsTo sc:HighNode1, sc:InterNode3 .

sc:Connector2 a sc:ConnectorNode ;
    rdfs:label "Connector Node 2" ;
    sc:connectsTo sc:Central1, sc:InterNode4 .

# Intermediary Nodes
sc:InterNode1 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node 1" ;
    rdfs:comment "Bridges high-degree node to other parts." ;
    sc:connectsTo sc:HighNode1, sc:InterNode3 .

sc:InterNode2 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node 2" ;
    sc:connectsTo sc:HighNode2, sc:InterNode4 .

sc:InterNode3 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node 3" ;
    sc:connectsTo sc:Connector1, sc:InterNode1 .

sc:InterNode4 a sc:IntermediaryNode ;
    rdfs:label "Intermediary Node 4" ;
    sc:connectsTo sc:Connector2, sc:InterNode2 .

# Multiplex Node
sc:Multiplex1 a sc:MultiplexNode ;
    rdfs:label "Multiplex Node 1" ;
    rdfs:comment "Participates in multiple relation types." ;
    sc:connectsTo sc:HighNode1, sc:Central1, sc:InterNode4 .

# Super Node
sc:Super1 a sc:SuperNode ;
    rdfs:label "Super Node" ;
    rdfs:comment "Extensively connected node acting as a super hub." ;
    sc:connectsTo sc:Hub1, sc:HighNode1, sc:HighNode2, sc:Central1, sc:Multiplex1, sc:InterNode1, sc:InterNode2, sc:InterNode3, sc:InterNode4 .

# Additional relations to create a rich network
sc:HighNode1 sc:relatesTo sc:InterNode2 .
sc:InterNode4 sc:linksTo sc:Super1 .
sc:Connector2 sc:connectsTo sc:HighNode2 .
sc:Multiplex1 sc:relatesTo sc:Central1 .
sc:Super1 sc:connectsTo sc:Hub1 .

# End of graph definition