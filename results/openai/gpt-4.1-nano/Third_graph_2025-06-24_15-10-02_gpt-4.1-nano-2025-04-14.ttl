@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A highly connected node acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of connections, but not necessarily a hub." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that is central within a specific module or community." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different modules or communities." .

sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as a bridge between other nodes or groups." .

sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations or layers." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A super node representing a cluster or a super-entity." .

# Entities
sc:E1 a sc:HubNode ;
    rdfs:label "Entity 1" ;
    rdfs:comment "A hub node with multiple connections." ;
    sc:hasRelation sc:R1 .

sc:E2 a sc:HighDegreeNode ;
    rdfs:label "Entity 2" ;
    rdfs:comment "A high-degree node connected to several central nodes." ;
    sc:hasRelation sc:R2 .

sc:E3 a sc:CentralNode ;
    rdfs:label "Entity 3" ;
    rdfs:comment "A central node within a module." ;
    sc:hasRelation sc:R3 .

sc:E4 a sc:ConnectorNode ;
    rdfs:label "Entity 4" ;
    rdfs:comment "A connector node linking different modules." ;
    sc:hasRelation sc:R4 .

sc:E5 a sc:IntermediaryNode ;
    rdfs:label "Entity 5" ;
    rdfs:comment "An intermediary node bridging two communities." ;
    sc:hasRelation sc:R5 .

sc:E6 a sc:MultiplexNode ;
    rdfs:label "Entity 6" ;
    rdfs:comment "A multiplex node involved in multiple relation types." ;
    sc:hasRelation sc:R6 .

sc:E7 a sc:SuperNode ;
    rdfs:label "Entity 7" ;
    rdfs:comment "A super node representing a cluster of entities." ;
    sc:hasRelation sc:R7 .

# Relations
sc:R1 a owl:ObjectProperty ;
    rdfs:label "relation R1" ;
    rdfs:comment "Relation R1 between entities." .

sc:R2 a owl:ObjectProperty ;
    rdfs:label "relation R2" ;
    rdfs:comment "Relation R2 between entities." .

sc:R3 a owl:ObjectProperty ;
    rdfs:label "relation R3" ;
    rdfs:comment "Relation R3 between entities." .

sc:R4 a owl:ObjectProperty ;
    rdfs:label "relation R4" ;
    rdfs:comment "Relation R4 between entities." .

sc:R5 a owl:ObjectProperty ;
    rdfs:label "relation R5" ;
    rdfs:comment "Relation R5 between entities." .

sc:R6 a owl:ObjectProperty ;
    rdfs:label "relation R6" ;
    rdfs:comment "Relation R6 between entities." .

sc:R7 a owl:ObjectProperty ;
    rdfs:label "relation R7" ;
    rdfs:comment "Relation R7 between entities." .

# Additional Nodes with relations
sc:E8 a sc:HighDegreeNode ;
    rdfs:label "Entity 8" ;
    rdfs:comment "Another high-degree node." ;
    sc:hasRelation sc:R2 .

sc:E9 a sc:IntermediaryNode ;
    rdfs:label "Entity 9" ;
    rdfs:comment "An intermediary node bridging modules." ;
    sc:hasRelation sc:R5 .

sc:E10 a sc:MultiplexNode ;
    rdfs:label "Entity 10" ;
    rdfs:comment "A multiplex node involved in multiple relations." ;
    sc:hasRelation sc:R6 .

sc:E11 a sc:SuperNode ;
    rdfs:label "Entity 11" ;
    rdfs:comment "A super node representing a community." ;
    sc:hasRelation sc:R7 .

# Relations between entities
sc:R1 rdfs:domain sc:HubNode ;
    rdfs:range sc:CentralNode .

sc:R2 rdfs:domain sc:HighDegreeNode ;
    rdfs:range sc:HubNode .

sc:R3 rdfs:domain sc:CentralNode ;
    rdfs:range sc:IntermediaryNode .

sc:R4 rdfs:domain sc:ConnectorNode ;
    rdfs:range sc:SuperNode .

sc:R5 rdfs:domain sc:IntermediaryNode ;
    rdfs:range sc:MultiplexNode .

sc:R6 rdfs:domain sc:MultiplexNode ;
    rdfs:range sc:SuperNode .

sc:R7 rdfs:domain sc:SuperNode ;
    rdfs:range sc:HubNode .

# Example relations between entities
sc:E1 sc:R1 sc:E3 .
sc:E2 sc:R2 sc:E1 .
sc:E3 sc:R3 sc:E4 .
sc:E4 sc:R4 sc:E7 .
sc:E5 sc:R5 sc:E6 .
sc:E6 sc:R6 sc:E11 .
sc:E7 sc:R7 sc:E1 .

# Additional relations to ensure nodes are connected
sc:E8 sc:R2 sc:E2 .
sc:E9 sc:R5 sc:E5 .
sc:E10 sc:R6 sc:E8 .
sc:E11 sc:R7 sc:E9 .

