@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Define Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A node with high connectivity acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of relations, acting as a key connector." .

sc:CentralNode a owl:Class ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that is central within a specific subgraph or community." .

sc:ConnectorNode a owl:Class ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different classes or communities." .

sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as a bridge between two other nodes or classes." .

sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple types of relations or relations across different classes." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A highly connected node that spans multiple classes or communities." .

# Define Object Properties
sc:relatesTo a owl:ObjectProperty ;
    rdfs:label "relates to" ;
    rdfs:comment "Generic relation indicating a connection between entities." .

sc:connectsTo a owl:ObjectProperty ;
    rdfs:label "connects to" ;
    rdfs:comment "Relation indicating a direct connection between nodes." .

sc:bridges a owl:ObjectProperty ;
    rdfs:label "bridges" ;
    rdfs:comment "Relation indicating bridging role between nodes or classes." .

sc:intermediates a owl:ObjectProperty ;
    rdfs:label "intermediates" ;
    rdfs:comment "Relation indicating an intermediary role." .

sc:multiplexRelation a owl:ObjectProperty ;
    rdfs:label "multiplex relation" ;
    rdfs:comment "Relation involving multiple types of relations or classes." .

# Define Entities (Nodes)
sc:EntityHub a sc:HubNode ;
    rdfs:label "Entity Hub" ;
    rdfs:comment "A hub node with multiple relations to various entities." ;
    sc:connectsTo sc:EntityA, sc:EntityB, sc:EntityC .

sc:EntityA a sc:HighDegreeNode ;
    rdfs:label "Entity A" ;
    rdfs:comment "A high-degree node acting as a key connector." ;
    sc:connectsTo sc:EntityB, sc:EntityD .

sc:EntityB a sc:CentralNode ;
    rdfs:label "Entity B" ;
    rdfs:comment "A central node within a community." ;
    sc:connectsTo sc:EntityA, sc:EntityC, sc:EntityE .

sc:EntityC a sc:ConnectorNode ;
    rdfs:label "Entity C" ;
    rdfs:comment "A connector node linking different classes." ;
    sc:connectsTo sc:EntityA, sc:EntityF .

sc:EntityD a sc:IntermediaryNode ;
    rdfs:label "Entity D" ;
    rdfs:comment "An intermediary node bridging Entity A and Entity E." ;
    sc:bridges sc:EntityA, sc:EntityE .

sc:EntityE a sc:MultiplexNode ;
    rdfs:label "Entity E" ;
    rdfs:comment "A multiplex node involved in multiple relations." ;
    sc:multiplexRelation sc:EntityB, sc:EntityF .

sc:EntityF a sc:SuperNode ;
    rdfs:label "Entity F" ;
    rdfs:comment "A super node spanning multiple classes." ;
    sc:connectsTo sc:EntityC, sc:EntityE, sc:EntityG .

sc:EntityG a sc:HighDegreeNode ;
    rdfs:label "Entity G" ;
    rdfs:comment "Another high-degree node with multiple relations." ;
    sc:connectsTo sc:EntityF, sc:EntityH .

sc:EntityH a sc:CentralNode ;
    rdfs:label "Entity H" ;
    rdfs:comment "A central node in a different subgraph." ;
    sc:connectsTo sc:EntityG, sc:EntityI .

sc:EntityI a sc:ConnectorNode ;
    rdfs:label "Entity I" ;
    rdfs:comment "A connector node linking Entity H to other entities." ;
    sc:connectsTo sc:EntityH, sc:EntityJ .

sc:EntityJ a sc:IntermediaryNode ;
    rdfs:label "Entity J" ;
    rdfs:comment "An intermediary node connecting Entity I to Entity F." ;
    sc:bridges sc:EntityI, sc:EntityF .

# Additional relations to ensure diverse node types
sc:EntityK a sc:SuperNode ;
    rdfs:label "Entity K" ;
    rdfs:comment "A super node with multiple relations." ;
    sc:connectsTo sc:EntityG, sc:EntityL .

sc:EntityL a sc:HighDegreeNode ;
    rdfs:label "Entity L" ;
    rdfs:comment "High-degree node connected to Entity K." ;
    sc:connectsTo sc:EntityK, sc:EntityM .

sc:EntityM a sc:CentralNode ;
    rdfs:label "Entity M" ;
    rdfs:comment "Central node in a different community." ;
    sc:connectsTo sc:EntityL, sc:EntityN .

sc:EntityN a sc:ConnectorNode ;
    rdfs:label "Entity N" ;
    rdfs:comment "Connector node linking Entity M to other nodes." ;
    sc:connectsTo sc:EntityM, sc:EntityO .

sc:EntityO a sc:IntermediaryNode ;
    rdfs:label "Entity O" ;
    rdfs:comment "Intermediary node bridging Entity N and Entity K." ;
    sc:bridges sc:EntityO, sc:EntityK .

# End of graph
