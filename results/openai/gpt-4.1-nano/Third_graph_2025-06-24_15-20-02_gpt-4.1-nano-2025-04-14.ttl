@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub Node: Entity with many relations, central in the network
sc:HubNode1 a sc:C10 ;
    rdfs:label "Global Hub Node" ;
    rdfs:comment "A central node connecting multiple classes and relations" ;
    sc:R1 sc:EntityA ;
    sc:R6 sc:EntityB ;
    sc:R8 sc:EntityC .

# High-degree Node: Entity with numerous relations
sc:HighDegreeNode a sc:C10 ;
    rdfs:label "High Degree Node" ;
    rdfs:comment "Node with many connections indicating high importance" ;
    sc:R1 sc:EntityD ;
    sc:R2 sc:EntityE ;
    sc:R3 sc:EntityF ;
    sc:R4 sc:EntityG ;
    sc:R6 sc:EntityH .

# Central Node: Acts as a core connecting different parts
sc:CentralNode a sc:C10 ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that links various subgraphs" ;
    sc:R1 sc:EntityI ;
    sc:R4 sc:EntityJ ;
    sc:R6 sc:EntityK .

# Connector Node: Connects two otherwise disconnected subgraphs
sc:ConnectorNode a sc:C10 ;
    rdfs:label "Connector Node" ;
    rdfs:comment "Bridges different classes or subgraphs" ;
    sc:R1 sc:EntityL ;
    sc:R5 sc:EntityM .

# Intermediary Node: Facilitates relations between two entities
sc:IntermediaryNode a sc:C10 ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "Acts as a mediator in relation chains" ;
    sc:R1 sc:EntityN ;
    sc:R3 sc:EntityO .

# Multiplex Node: Entity involved in multiple relation types
sc:MultiplexNode a sc:C10 ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "Participates in various relation types" ;
    sc:R1 sc:EntityP ;
    sc:R4 sc:EntityQ ;
    sc:R6 sc:EntityR ;
    sc:R8 sc:EntityS .

# Super Node: Encompasses multiple classes or functions
sc:SuperNode a sc:C10 ;
    rdfs:label "Super Node" ;
    rdfs:comment "Aggregates multiple entities and relations" ;
    sc:R1 sc:EntityT ;
    sc:R2 sc:EntityU ;
    sc:R3 sc:EntityV ;
    sc:R4 sc:EntityW ;
    sc:R6 sc:EntityX .

# Additional Entities with relations
sc:EntityA a sc:C1 ;
    rdfs:label "Entity A" ;
    rdfs:comment "A specific entity connected to the hub node" ;
    sc:R2 sc:EntityY .

sc:EntityB a sc:C2 ;
    rdfs:label "Entity B" ;
    rdfs:comment "A high-degree node entity" ;
    sc:R3 sc:EntityZ .

sc:EntityC a sc:C3 ;
    rdfs:label "Entity C" ;
    rdfs:comment "Connector node related entity" ;
    sc:R4 sc:EntityAA .

sc:EntityD a sc:C4 ;
    rdfs:label "Entity D" ;
    rdfs:comment "Entity with multiple relations" ;
    sc:R6 sc:EntityAB .

sc:EntityE a sc:C5 ;
    rdfs:label "Entity E" ;
    rdfs:comment "Entity involved in relation R2" ;
    sc:R2 sc:EntityAC .

sc:EntityF a sc:C6 ;
    rdfs:label "Entity F" ;
    rdfs:comment "Entity with symmetric relation" ;
    sc:R4 sc:EntityAD .

sc:EntityG a sc:C7 ;
    rdfs:label "Entity G" ;
    rdfs:comment "Entity with relation R8" ;
    sc:R8 sc:EntityAE .

sc:EntityH a sc:C8 ;
    rdfs:label "Entity H" ;
    rdfs:comment "Disjoint class entity" ;
    sc:R9 sc:EntityAF .

sc:EntityI a sc:C9 ;
    rdfs:label "Entity I" ;
    rdfs:comment "Entity acting as a high-degree node" ;
    sc:R10 sc:EntityAG .

sc:EntityJ a sc:C10 ;
    rdfs:label "Entity J" ;
    rdfs:comment "Entity connected to multiple classes" ;
    sc:R1 sc:EntityAH .

sc:EntityK a sc:C10 ;
    rdfs:label "Entity K" ;
    rdfs:comment "Another core entity" ;
    sc:R6 sc:EntityAI .

sc:EntityL a sc:C10 ;
    rdfs:label "Entity L" ;
    rdfs:comment "Connector node example" ;
    sc:R1 sc:EntityAJ .

sc:EntityM a sc:C10 ;
    rdfs:label "Entity M" ;
    rdfs:comment "Relation facilitator" ;
    sc:R3 sc:EntityAK .

sc:EntityN a sc:C10 ;
    rdfs:label "Entity N" ;
    rdfs:comment "Intermediary node example" ;
    sc:R1 sc:EntityAL .

sc:EntityO a sc:C10 ;
    rdfs:label "Entity O" ;
    rdfs:comment "Another intermediary node" ;
    sc:R3 sc:EntityAM .

sc:EntityP a sc:C10 ;
    rdfs:label "Entity P" ;
    rdfs:comment "Multiplex participation" ;
    sc:R1 sc:EntityAN .

sc:EntityQ a sc:C10 ;
    rdfs:label "Entity Q" ;
    rdfs:comment "Participates in multiple relations" ;
    sc:R4 sc:EntityAO .

sc:EntityR a sc:C10 ;
    rdfs:label "Entity R" ;
    rdfs:comment "Super node example" ;
    sc:R6 sc:EntityAP .

sc:EntityS a sc:C10 ;
    rdfs:label "Entity S" ;
    rdfs:comment "Node with symmetric relation" ;
    sc:R8 sc:EntityAQ .

sc:EntityT a sc:C10 ;
    rdfs:label "Entity T" ;
    rdfs:comment "Encompassing super node" ;
    sc:R1 sc:EntityAR .

sc:EntityU a sc:C10 ;
    rdfs:label "Entity U" ;
    rdfs:comment "High connectivity node" ;
    sc:R2 sc:EntityAS .

sc:EntityV a sc:C10 ;
    rdfs:label "Entity V" ;
    rdfs:comment "Core entity in the network" ;
    sc:R3 sc:EntityAT .

sc:EntityW a sc:C10 ;
    rdfs:label "Entity W" ;
    rdfs:comment "Node with multiple relations" ;
    sc:R4 sc:EntityAU .

sc:EntityX a sc:C10 ;
    rdfs:label "Entity X" ;
    rdfs:comment "Super node with many relations" ;
    sc:R6 sc:EntityAV .

sc:EntityY a sc:C1 ;
    rdfs:label "Entity Y" ;
    rdfs:comment "Entity connected to EntityA" ;
    sc:R2 sc:EntityA .

sc:EntityZ a sc:C2 ;
    rdfs:label "Entity Z" ;
    rdfs:comment "High-degree node related to EntityB" ;
    sc:R3 sc:EntityB .

# Relations (examples)
sc:EntityA sc:R2 sc:EntityY .
sc:EntityB sc:R3 sc:EntityZ .
sc:EntityC sc:R4 sc:EntityAA .
sc:EntityD sc:R6 sc:EntityAB .
sc:EntityE sc:R2 sc:EntityAC .
sc:EntityF sc:R4 sc:EntityAD .
sc:EntityG sc:R8 sc:EntityAE .
sc:EntityH sc:R9 sc:EntityAF .
sc:EntityI sc:R10 sc:EntityAG .
sc:EntityJ sc:R1 sc:EntityAH .

# End of graph example