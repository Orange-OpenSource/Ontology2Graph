@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Hub Node: Entity with many relations, central position
sc:HubNode1 a sc:C10 ;
    rdfs:label "Global Hub Node"@en ;
    rdfs:comment "A central node connecting multiple classes and relations"@en ;
    sc:R1 sc:E1000 ;
    sc:R6 sc:E880 .

# High-Degree Node: Entity with numerous relations, high connectivity
sc:HighDegreeNode a sc:C10 ;
    rdfs:label "High Degree Node"@en ;
    rdfs:comment "Node with many relations indicating high connectivity"@en ;
    sc:R1 sc:E103 ;
    sc:R4 sc:E864 ;
    sc:R6 sc:E420 ;
    sc:R9 sc:E915 .

# Central Node: Entity acting as a core within the network
sc:CentralNode a sc:C10 ;
    rdfs:label "Central Node"@en ;
    rdfs:comment "A node serving as a core within the graph structure"@en ;
    sc:R1 sc:E104 ;
    sc:R4 sc:E666 ;
    sc:R6 sc:E789 .

# Connector Node: Entity linking different parts of the graph
sc:ConnectorNode a sc:C10 ;
    rdfs:label "Connector Node"@en ;
    rdfs:comment "Connects multiple classes and relations across the graph"@en ;
    sc:R1 sc:E122 ;
    sc:R4 sc:E620 ;
    sc:R6 sc:E580 .

# Intermediary Node: Entity acting as an intermediary in relations
sc:IntermediaryNode a sc:C10 ;
    rdfs:label "Intermediary Node"@en ;
    rdfs:comment "Facilitates relations between other nodes"@en ;
    sc:R1 sc:E131 ;
    sc:R4 sc:E207 ;
    sc:R6 sc:E78 .

# Multiplex Node: Entity involved in multiple relation types
sc:MultiplexNode a sc:C10 ;
    rdfs:label "Multiplex Node"@en ;
    rdfs:comment "Participates in multiple relation types and classes"@en ;
    sc:R1 sc:E139 ;
    sc:R4 sc:E580 ;
    sc:R6 sc:E251 .

# Super Node: Entity representing a superordinate class
sc:SuperNode a sc:C10 ;
    rdfs:label "Super Node"@en ;
    rdfs:comment "A superordinate node encompassing multiple sub-classes"@en ;
    sc:R1 sc:E146 ;
    sc:R4 sc:E218 ;
    sc:R6 sc:E251 .

# Additional Entities with relations to demonstrate diversity

# Entity with symmetric and reflexive relations
sc:EntityA a sc:C9 ;
    rdfs:label "Entity A"@en ;
    rdfs:comment "An entity with symmetric and reflexive relations"@en ;
    sc:R4 sc:E124 ;
    sc:R5 sc:E5 .

# Entity with inverse relations
sc:EntityB a sc:C8 ;
    rdfs:label "Entity B"@en ;
    rdfs:comment "Entity involved in inverse relations"@en ;
    sc:R2 sc:E105 ;
    sc:R5 sc:E105 .

# Entity with multiple class memberships
sc:EntityC a sc:C10, sc:C4 ;
    rdfs:label "Entity C"@en ;
    rdfs:comment "Entity belonging to multiple classes"@en ;
    sc:R1 sc:E174 ;
    sc:R4 sc:E207 .

# Entity with disjoint class relations
sc:EntityD a sc:C8 ;
    rdfs:label "Entity D"@en ;
    rdfs:comment "Disjoint class entity"@en ;
    sc:R2 sc:E185 .

# Entity with relation to a super class
sc:EntityE a sc:C10 ;
    rdfs:label "Entity E"@en ;
    rdfs:comment "Entity related to a super class"@en ;
    sc:R1 sc:E1000 .

# Entity with multiple relation types (multiplex)
sc:EntityF a sc:C10 ;
    rdfs:label "Entity F"@en ;
    rdfs:comment "Entity involved in multiple relation types"@en ;
    sc:R1 sc:E122 ;
    sc:R4 sc:E620 ;
    sc:R6 sc:E251 .

# Entity with a symmetric property relation
sc:EntityG a sc:C7 ;
    rdfs:label "Entity G"@en ;
    rdfs:comment "Entity with symmetric relation"@en ;
    sc:R8 sc:E8 .

# Entity with a reflexive property relation
sc:EntityH a sc:C9 ;
    rdfs:label "Entity H"@en ;
    rdfs:comment "Entity with reflexive relation"@en ;
    sc:R1 sc:E103 .

# Entity with a relation to a disjoint class
sc:EntityI a sc:C8 ;
    rdfs:label "Entity I"@en ;
    rdfs:comment "Entity disjoint with class C2"@en ;
    sc:R2 sc:E105 .

# Entity with inverse relation
sc:EntityJ a sc:C9 ;
    rdfs:label "Entity J"@en ;
    rdfs:comment "Entity with inverse relation"@en ;
    sc:R2 sc:E105 .

# End of graph
