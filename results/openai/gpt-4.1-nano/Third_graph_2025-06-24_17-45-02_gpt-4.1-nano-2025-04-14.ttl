# Relations (example)
sc:R1 a owl:ObjectProperty ;
    rdfs:label "Relation R1" ;
    rdfs:comment "A primary relation connecting entities." .

sc:R6 a owl:ObjectProperty ;
    rdfs:label "Relation R6" ;
    rdfs:comment "A high-level relation indicating influence or connectivity." .

# Note: Additional relations can be added as needed following the schema and creating more interconnected nodes.