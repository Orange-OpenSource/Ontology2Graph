@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# Classes
sc:HubNode a owl:Class ;
    rdfs:subClassOf sc:CentralNode ;
    rdfs:label "Hub Node" ;
    rdfs:comment "A node with high connectivity acting as a central hub in the network." .

sc:HighDegreeNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "High-Degree Node" ;
    rdfs:comment "A node with a high number of relations, acting as a key connector." .

sc:CentralNode a owl:Class ;
    rdfs:subClassOf sc:SuperNode ;
    rdfs:label "Central Node" ;
    rdfs:comment "A node that is central within the network, connecting multiple classes." .

sc:ConnectorNode a owl:Class ;
    rdfs:subClassOf sc:IntermediaryNode ;
    rdfs:label "Connector Node" ;
    rdfs:comment "A node that connects different classes or groups, facilitating interaction." .

sc:IntermediaryNode a owl:Class ;
    rdfs:label "Intermediary Node" ;
    rdfs:comment "A node that acts as an intermediary between other nodes or classes." .

sc:MultiplexNode a owl:Class ;
    rdfs:label "Multiplex Node" ;
    rdfs:comment "A node involved in multiple relation types, acting across different relation layers." .

sc:SuperNode a owl:Class ;
    rdfs:label "Super Node" ;
    rdfs:comment "A highly influential node with extensive relations across the network." .

# Entities
sc:E1001 a sc:HubNode ;
    rdfs:label "Entity 1001" ;
    rdfs:comment "A central hub node connecting multiple high-degree nodes." ;
    sc:sc:R1 sc:E1002, sc:E1003 ;
    sc:sc:R6 sc:E1004 .

sc:E1002 a sc:HighDegreeNode ;
    rdfs:label "Entity 1002" ;
    rdfs:comment "A high-degree node acting as a key connector between classes." ;
    sc:sc:R1 sc:E1005 ;
    sc:sc:R4 sc:E1006 .

sc:E1003 a sc:HighDegreeNode ;
    rdfs:label "Entity 1003" ;
    rdfs:comment "Another high-degree node with multiplex relations." ;
    sc:sc:R1 sc:E1007 ;
    sc:sc:R6 sc:E1008 .

sc:E1004 a sc:SuperNode ;
    rdfs:label "Entity 1004" ;
    rdfs:comment "A super node with extensive relations, influencing multiple classes." ;
    sc:sc:R6 sc:E1009 .

