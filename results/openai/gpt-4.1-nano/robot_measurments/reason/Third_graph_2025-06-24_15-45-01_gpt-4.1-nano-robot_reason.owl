        <includes rdf:resource="http://pygraf.t/E1004"/>
        <rdfs:comment>A super node representing a large metropolitan area.</rdfs:comment>
        <rdfs:label>Entity E1006</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1007 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1007">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
