        <rdfs:comment>A high-degree node representing a major train station.</rdfs:comment>
        <rdfs:label>Entity E1007</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1008 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1008">
        <rdf:type rdf:resource="http://pygraf.t/ConnectorNode"/>
        <linksTo rdf:resource="http://pygraf.t/E1005"/>
        <rdfs:comment>A connector node linking regional and local networks.</rdfs:comment>
        <rdfs:label>Entity E1008</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1010 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1010">
        <rdf:type rdf:resource="http://pygraf.t/SuperNode"/>
        <includes rdf:resource="http://pygraf.t/E1001"/>
        <includes rdf:resource="http://pygraf.t/E1006"/>
        <rdfs:comment>A super node representing a national transportation network.</rdfs:comment>
        <rdfs:label>Entity E1010</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1011 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1011">
        <rdf:type rdf:resource="http://pygraf.t/CentralNode"/>
        <connectedTo rdf:resource="http://pygraf.t/E1003"/>
        <rdfs:comment>A central node representing a major airport.</rdfs:comment>
        <rdfs:label>Entity E1011</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1012 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1012">
        <rdf:type rdf:resource="http://pygraf.t/MultiplexNode"/>
        <participatesIn rdf:resource="http://pygraf.t/E1010"/>
