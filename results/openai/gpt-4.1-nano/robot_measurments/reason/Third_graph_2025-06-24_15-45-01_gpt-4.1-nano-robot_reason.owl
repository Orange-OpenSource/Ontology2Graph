    <!-- http://pygraf.t/E1001 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1001">
        <rdf:type rdf:resource="http://pygraf.t/HubNode"/>
        <hasRelation rdf:resource="http://pygraf.t/E1002"/>
        <hasRelation rdf:resource="http://pygraf.t/E1003"/>
        <rdfs:comment>A hub node representing a major transportation hub.</rdfs:comment>
        <rdfs:label>Entity E1001</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1002 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1002">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
        <relatesTo rdf:resource="http://pygraf.t/E1004"/>
        <rdfs:comment>A high-degree node representing a central business district.</rdfs:comment>
        <rdfs:label>Entity E1002</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1003 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1003">
        <rdf:type rdf:resource="http://pygraf.t/ConnectorNode"/>
