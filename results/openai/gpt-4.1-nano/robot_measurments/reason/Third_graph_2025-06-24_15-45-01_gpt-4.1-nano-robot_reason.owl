        <rdfs:comment>A connector node linking different transportation modes.</rdfs:comment>
        <rdfs:label>Entity E1003</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1004 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1004">
        <rdf:type rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <mediates rdf:resource="http://pygraf.t/E1006"/>
        <rdfs:comment>An intermediary node representing a transit station.</rdfs:comment>
        <rdfs:label>Entity E1004</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1005 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1005">
        <rdf:type rdf:resource="http://pygraf.t/MultiplexNode"/>
        <participatesIn rdf:resource="http://pygraf.t/E1007"/>
        <participatesIn rdf:resource="http://pygraf.t/E1008"/>
        <rdfs:comment>A multiplex node involved in multiple transportation networks.</rdfs:comment>
        <rdfs:label>Entity E1005</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1006 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1006">
        <rdf:type rdf:resource="http://pygraf.t/SuperNode"/>
