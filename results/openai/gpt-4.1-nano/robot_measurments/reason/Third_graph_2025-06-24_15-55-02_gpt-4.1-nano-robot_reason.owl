    <!-- http://pygraf.t/connectsTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/connectsTo">
        <rdfs:comment>Relation indicating a direct connection between nodes.</rdfs:comment>
        <rdfs:label>connects to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/linksTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/linksTo">
        <rdfs:comment>Relation indicating a link or association between entities.</rdfs:comment>
        <rdfs:label>links to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/relatesTo -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/relatesTo">
        <rdfs:comment>Generic relation indicating a connection between entities.</rdfs:comment>
        <rdfs:label>relates to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pygraf.t/CentralNode -->

    <owl:Class rdf:about="http://pygraf.t/CentralNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/SuperNode"/>
        <rdfs:comment>A node positioned at the center of the network, connecting multiple classes.</rdfs:comment>
        <rdfs:label>Central Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/ConnectorNode -->

    <owl:Class rdf:about="http://pygraf.t/ConnectorNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <rdfs:comment>A node that connects different classes or groups, acting as a bridge.</rdfs:comment>
        <rdfs:label>Connector Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HighDegreeNode -->

    <owl:Class rdf:about="http://pygraf.t/HighDegreeNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/SuperNode"/>
        <rdfs:comment>A node with a high number of relations, indicating significant influence.</rdfs:comment>
        <rdfs:label>High-Degree Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HubNode -->

    <owl:Class rdf:about="http://pygraf.t/HubNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/SuperNode"/>
        <rdfs:comment>A node with high connectivity acting as a central hub in the network.</rdfs:comment>
        <rdfs:label>Hub Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/IntermediaryNode -->

    <owl:Class rdf:about="http://pygraf.t/IntermediaryNode">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A node that mediates relations between other nodes or classes.</rdfs:comment>
        <rdfs:label>Intermediary Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/MultiplexNode -->

    <owl:Class rdf:about="http://pygraf.t/MultiplexNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/SuperNode"/>
        <rdfs:comment>A node involved in multiple relation types or classes, representing multiplex relationships.</rdfs:comment>
        <rdfs:label>Multiplex Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/SuperNode -->

    <owl:Class rdf:about="http://pygraf.t/SuperNode">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A highly connected node with multiple relations across classes.</rdfs:comment>
        <rdfs:label>Super Node</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pygraf.t/Central1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Central1">
        <rdf:type rdf:resource="http://pygraf.t/CentralNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Hub1"/>
        <connectsTo rdf:resource="http://pygraf.t/Intermediary1"/>
        <connectsTo rdf:resource="http://pygraf.t/Multiplex1"/>
        <rdfs:comment>A node positioned at the network&apos;s center.</rdfs:comment>
        <rdfs:label>Central Entity</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Connector1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Connector1">
        <rdf:type rdf:resource="http://pygraf.t/ConnectorNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Intermediary1"/>
        <connectsTo rdf:resource="http://pygraf.t/Multiplex1"/>
        <rdfs:comment>Connects different classes, acting as a bridge.</rdfs:comment>
        <rdfs:label>Bridge Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/HighNode1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/HighNode1">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Hub1"/>
        <connectsTo rdf:resource="http://pygraf.t/Multiplex1"/>
        <connectsTo rdf:resource="http://pygraf.t/Super1"/>
        <relatesTo rdf:resource="http://pygraf.t/Super2"/>
        <rdfs:comment>A high-degree node with many relations.</rdfs:comment>
        <rdfs:label>Influencer A</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/HighNode2 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/HighNode2">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Hub1"/>
        <connectsTo rdf:resource="http://pygraf.t/Super2"/>
        <linksTo rdf:resource="http://pygraf.t/Super1"/>
        <rdfs:comment>Another high-degree node with multiple relations.</rdfs:comment>
        <rdfs:label>Influencer B</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Hub1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Hub1">
        <rdf:type rdf:resource="http://pygraf.t/HubNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Central1"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode1"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode2"/>
        <rdfs:comment>A central hub node connecting multiple high-degree nodes.</rdfs:comment>
        <rdfs:label>Main Hub</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Intermediary1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Intermediary1">
        <rdf:type rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Connector1"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode1"/>
        <relatesTo rdf:resource="http://pygraf.t/HighNode2"/>
        <rdfs:comment>Mediates relations between other nodes.</rdfs:comment>
        <rdfs:label>Mediator Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Multiplex1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Multiplex1">
        <rdf:type rdf:resource="http://pygraf.t/MultiplexNode"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode2"/>
        <connectsTo rdf:resource="http://pygraf.t/SuperNode1"/>
        <linksTo rdf:resource="http://pygraf.t/Super2"/>
        <rdfs:comment>Participates in multiple relation types.</rdfs:comment>
        <rdfs:label>Multi-Relation Node</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Super1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Super1">
        <rdf:type rdf:resource="http://pygraf.t/SuperNode"/>
        <connectsTo rdf:resource="http://pygraf.t/Central1"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode1"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode2"/>
        <rdfs:comment>A super node with extensive relations.</rdfs:comment>
        <rdfs:label>Super Connector</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/Super2 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/Super2">
        <rdf:type rdf:resource="http://pygraf.t/SuperNode"/>
        <connectsTo rdf:resource="http://pygraf.t/HighNode2"/>
        <connectsTo rdf:resource="http://pygraf.t/Hub1"/>
        <rdfs:comment>A super node with high influence.</rdfs:comment>
        <rdfs:label>Super Influencer</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/SuperNode1 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/SuperNode1"/>
</rdf:RDF>



