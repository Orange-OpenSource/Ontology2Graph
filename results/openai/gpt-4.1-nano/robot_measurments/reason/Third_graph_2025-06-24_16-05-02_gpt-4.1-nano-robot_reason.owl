        <rdfs:label>Entity of Class C10</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2004 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2004">
        <rdf:type rdf:resource="http://pygraf.t/C2"/>
        <R2 rdf:resource="http://pygraf.t/E2005"/>
        <rdfs:comment>A specific instance of class C2.</rdfs:comment>
        <rdfs:comment>Relation indicating a connection between C2 and C3 entities.</rdfs:comment>
        <rdfs:label>Entity of Class C2</rdfs:label>
        <rdfs:label>relates to</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2005 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2005">
        <rdf:type rdf:resource="http://pygraf.t/C3"/>
        <R4 rdf:resource="http://pygraf.t/E2004"/>
        <rdfs:comment>A specific instance of class C3.</rdfs:comment>
        <rdfs:comment>Inverse relation to &apos;relates to&apos;.</rdfs:comment>
        <rdfs:label>Entity of Class C3</rdfs:label>
        <rdfs:label>related by</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2010 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2010">
        <rdf:type rdf:resource="http://pygraf.t/HubNode"/>
        <R6 rdf:resource="http://pygraf.t/E2011"/>
        <rdfs:comment>A hub node within a subgraph.</rdfs:comment>
        <rdfs:comment>Relation indicating connection within subgraph.</rdfs:comment>
        <rdfs:label>Subgraph Hub</rdfs:label>
        <rdfs:label>connects to</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2011 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2011">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
        <R4 rdf:resource="http://pygraf.t/E2012"/>
        <rdfs:comment>A high-degree node within a subgraph.</rdfs:comment>
        <rdfs:comment>Relation linking connector to high-degree node.</rdfs:comment>
        <rdfs:label>Subgraph High-Degree</rdfs:label>
        <rdfs:label>links</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2012 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2012">
        <rdf:type rdf:resource="http://pygraf.t/ConnectorNode"/>
        <R3 rdf:resource="http://pygraf.t/E2005"/>
        <rdfs:comment>Connector node linking subgraph entities.</rdfs:comment>
        <rdfs:comment>Relation linking connector to a class C3 entity.</rdfs:comment>
        <rdfs:label>Subgraph Connector</rdfs:label>
        <rdfs:label>relates to</rdfs:label>
    </owl:NamedIndividual>
