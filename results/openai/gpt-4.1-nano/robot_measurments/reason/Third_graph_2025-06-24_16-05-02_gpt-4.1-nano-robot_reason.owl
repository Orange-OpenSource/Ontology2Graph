    <!-- http://pygraf.t/E1001 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1001">
        <rdf:type rdf:resource="http://pygraf.t/HubNode"/>
        <R6 rdf:resource="http://pygraf.t/E2003"/>
        <rdfs:comment>A super connector linking multiple classes and entities.</rdfs:comment>
        <rdfs:comment>Relation indicating connection to a C10 entity.</rdfs:comment>
        <rdfs:label>Global Network Hub</rdfs:label>
        <rdfs:label>connects to</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1002 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1002">
        <rdf:type rdf:resource="http://pygraf.t/HighDegreeNode"/>
        <R4 rdf:resource="http://pygraf.t/E2002"/>
        <rdfs:comment>A prominent actor involved in numerous relations.</rdfs:comment>
        <rdfs:comment>Relation indicating a link with a C4 entity.</rdfs:comment>
        <rdfs:label>Major Actor</rdfs:label>
        <rdfs:label>links with</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1003 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1003">
        <rdf:type rdf:resource="http://pygraf.t/CentralNode"/>
        <R3 rdf:resource="http://pygraf.t/E2001"/>
        <rdfs:comment>A central module connecting related components.</rdfs:comment>
        <rdfs:comment>Relation indicating relation to a C1 entity.</rdfs:comment>
        <rdfs:label>Core Module</rdfs:label>
        <rdfs:label>relates to</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1004 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1004">
        <rdf:type rdf:resource="http://pygraf.t/ConnectorNode"/>
        <R7 rdf:resource="http://pygraf.t/E2002"/>
        <rdfs:comment>Acts as a bridge between class A and class B.</rdfs:comment>
        <rdfs:comment>Relation indicating bridging between C4 and C10 entities.</rdfs:comment>
        <rdfs:label>Bridge Entity</rdfs:label>
        <rdfs:label>bridges</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1005 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1005">
        <rdf:type rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <R5 rdf:resource="http://pygraf.t/E2003"/>
        <rdfs:comment>Facilitates interactions between different nodes.</rdfs:comment>
        <rdfs:comment>Relation indicating mediation role.</rdfs:comment>
        <rdfs:label>Mediator Entity</rdfs:label>
        <rdfs:label>mediates</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1006 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1006">
        <rdf:type rdf:resource="http://pygraf.t/MultiplexNode"/>
        <R10 rdf:resource="http://pygraf.t/E2002"/>
        <rdfs:comment>Engages in various relation types across classes.</rdfs:comment>
        <rdfs:comment>Relation indicating participation in multiple relation types.</rdfs:comment>
        <rdfs:label>Multi-role Entity</rdfs:label>
        <rdfs:label>participates in</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E1007 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E1007">
        <rdf:type rdf:resource="http://pygraf.t/SuperNode"/>
        <R6 rdf:resource="http://pygraf.t/E2001"/>
        <rdfs:comment>Relation indicating inclusion of a C1 entity.</rdfs:comment>
        <rdfs:comment>Represents an aggregate of several classes.</rdfs:comment>
        <rdfs:label>Composite Entity</rdfs:label>
        <rdfs:label>encompasses</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2001 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2001">
        <rdf:type rdf:resource="http://pygraf.t/C1"/>
        <rdfs:comment>A specific instance of class C1.</rdfs:comment>
        <rdfs:label>Entity of Class C1</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2002 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2002">
        <rdf:type rdf:resource="http://pygraf.t/C4"/>
        <R9 rdf:resource="http://pygraf.t/E2003"/>
        <rdfs:comment>A specific instance of class C4.</rdfs:comment>
        <rdfs:comment>Symmetric relation indicating mutual interaction.</rdfs:comment>
        <rdfs:label>Entity of Class C4</rdfs:label>
        <rdfs:label>interacts with</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://pygraf.t/E2003 -->

    <owl:NamedIndividual rdf:about="http://pygraf.t/E2003">
