    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://pygraf.t/comment -->

    <owl:AnnotationProperty rdf:about="http://pygraf.t/comment"/>
    


    <!-- http://pygraf.t/sc:R1 -->

    <owl:AnnotationProperty rdf:about="http://pygraf.t/sc:R1"/>
    


    <!-- http://pygraf.t/sc:R4 -->

    <owl:AnnotationProperty rdf:about="http://pygraf.t/sc:R4"/>
    


    <!-- http://pygraf.t/sc:R6 -->

    <owl:AnnotationProperty rdf:about="http://pygraf.t/sc:R6"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pygraf.t/R1 -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/R1">
        <rdfs:comment>A primary relation connecting entities.</rdfs:comment>
        <rdfs:label>Relation R1</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://pygraf.t/R6 -->

    <owl:ObjectProperty rdf:about="http://pygraf.t/R6">
        <rdfs:comment>A high-level relation indicating influence or connectivity.</rdfs:comment>
        <rdfs:label>Relation R6</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pygraf.t/CentralNode -->

    <owl:Class rdf:about="http://pygraf.t/CentralNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/SuperNode"/>
        <rdfs:comment>A node that is central within the network, connecting multiple classes.</rdfs:comment>
        <rdfs:label>Central Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/ConnectorNode -->

    <owl:Class rdf:about="http://pygraf.t/ConnectorNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/IntermediaryNode"/>
        <rdfs:comment>A node that connects different classes or groups, facilitating interaction.</rdfs:comment>
        <rdfs:label>Connector Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HighDegreeNode -->

    <owl:Class rdf:about="http://pygraf.t/HighDegreeNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/SuperNode"/>
        <rdfs:comment>A node with a high number of relations, acting as a key connector.</rdfs:comment>
        <rdfs:label>High-Degree Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/HubNode -->

    <owl:Class rdf:about="http://pygraf.t/HubNode">
        <rdfs:subClassOf rdf:resource="http://pygraf.t/CentralNode"/>
        <rdfs:comment>A node with high connectivity acting as a central hub in the network.</rdfs:comment>
        <rdfs:label>Hub Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/IntermediaryNode -->

    <owl:Class rdf:about="http://pygraf.t/IntermediaryNode">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A node that acts as an intermediary between other nodes or classes.</rdfs:comment>
        <rdfs:label>Intermediary Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/MultiplexNode -->

    <owl:Class rdf:about="http://pygraf.t/MultiplexNode">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A node involved in multiple relation types, acting across different relation layers.</rdfs:comment>
        <rdfs:label>Multiplex Node</rdfs:label>
    </owl:Class>
    


    <!-- http://pygraf.t/SuperNode -->

    <owl:Class rdf:about="http://pygraf.t/SuperNode">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A highly influential node with extensive relations across the network.</rdfs:comment>
        <rdfs:label>Super Node</rdfs:label>
    </owl:Class>
    


