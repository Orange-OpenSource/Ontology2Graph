@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sc: <http://pygraf.t/> .

sc: a owl:Ontology ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> .

# --- Hub Node ---
sc:E2000 a sc:C9 ;
    rdfs:label "Hub Node Alpha" ;
    rdfs:comment "A central hub node in the network, connecting to many other nodes of various classes." ;
    sc:R4 sc:E2001, sc:E2002, sc:E2003, sc:E2004, sc:E2005 ;
    sc:R9 sc:E2010, sc:E2011, sc:E2012 .

# --- High-degree Node ---
sc:E2001 a sc:C5 ;
    rdfs:label "High-degree Node Beta" ;
    rdfs:comment "A node with a high number of direct connections, acting as a local authority." ;
    sc:R4 sc:E2000, sc:E2002, sc:E2003 ;
    sc:R9 sc:E2010, sc:E2013 .

# --- Central Node ---
sc:E2002 a sc:C10 ;
    rdfs:label "Central Node Gamma" ;
    rdfs:comment "A node positioned at the center of the graph, bridging several clusters." ;
    sc:R4 sc:E2000, sc:E2001, sc:E2003, sc:E2004 ;
    sc:R6 sc:E2014 .

# --- Connector Node ---
sc:E2003 a sc:C4 ;
    rdfs:label "Connector Node Delta" ;
    rdfs:comment "A node that connects two otherwise separate clusters, acting as a bridge." ;
    sc:R4 sc:E2000, sc:E2001, sc:E2002, sc:E2005 ;
    sc:R6 sc:E2015 .

# --- Intermediary Node ---
sc:E2004 a sc:C3 ;
    rdfs:label "Intermediary Node Epsilon" ;
    rdfs:comment "A node that intermediates between the hub and peripheral nodes." ;
    sc:R4 sc:E2000, sc:E2002, sc:E2005 ;
    sc:R6 sc:E2016 .

# --- Multiplex Node ---
sc:E2005 a sc:C1 ;
    rdfs:label "Multiplex Node Zeta" ;
    rdfs:comment "A node with multiple types of relations, linking to various classes." ;
    sc:R4 sc:E2000, sc:E2003, sc:E2004 ;
    sc:R3 sc:E2017 ;
    sc:R6 sc:E2018 .

# --- Super Node ---
sc:E2010 a sc:C9 ;
    rdfs:label "Super Node Omega" ;
    rdfs:comment "A super node with both high degree and high betweenness, influencing the entire graph." ;
    sc:R4 sc:E2000, sc:E2001 ;
    sc:R9 sc:E2011, sc:E2012, sc:E2013, sc:E2019 .

# --- Peripheral Node 1 ---
sc:E2011 a sc:C5 ;
    rdfs:label "Peripheral Node Sigma" ;
    rdfs:comment "A peripheral node connected to the super node and hub." ;
    sc:R4 sc:E2010, sc:E2000 ;
    sc:R9 sc:E2012 .

# --- Peripheral Node 2 ---
sc:E2012 a sc:C9 ;
    rdfs:label "Peripheral Node Tau" ;
    rdfs:comment "Another peripheral node, part of the super node's cluster." ;
    sc:R4 sc:E2010, sc:E2000 ;
    sc:R9 sc:E2011 .

# --- High-degree Node 2 ---
sc:E2013 a sc:C5 ;
    rdfs:label "High-degree Node Lambda" ;
    rdfs:comment "A high-degree node in the super node's cluster." ;
    sc:R4 sc:E2010 ;
    sc:R9 sc:E2001 .

# --- Central Node 2 ---
sc:E2014 a sc:C10 ;
    rdfs:label "Central Node Theta" ;
    rdfs:comment "A central node in a different cluster, connected to the main central node." ;
    sc:R6 sc:E2002 ;
    sc:R4 sc:E2015 .

# --- Connector Node 2 ---
sc:E2015 a sc:C4 ;
    rdfs:label "Connector Node Iota" ;
    rdfs:comment "A connector node linking two central nodes." ;
    sc:R6 sc:E2003 ;
    sc:R4 sc:E2014 .

# --- Intermediary Node 2 ---
sc:E2016 a sc:C3 ;
    rdfs:label "Intermediary Node Kappa" ;
    rdfs:comment "An intermediary node in a secondary cluster." ;
    sc:R6 sc:E2004 ;
    sc:R4 sc:E2017 .

# --- Multiplex Node 2 ---
sc:E2017 a sc:C1 ;
    rdfs:label "Multiplex Node Mu" ;
    rdfs:comment "A multiplex node with diverse relations in a secondary cluster." ;
    sc:R3 sc:E2005 ;
    sc:R4 sc:E2016 ;
    sc:R6 sc:E2018 .

# --- Peripheral Node 3 ---
sc:E2018 a sc:C10 ;
    rdfs:label "Peripheral Node Nu" ;
    rdfs:comment "A peripheral node connected to multiplex nodes." ;
    sc:R6 sc:E2005, sc:E2017 .

# --- Super Node 2 ---
sc:E2019 a sc:C9 ;
    rdfs:label "Super Node Psi" ;
    rdfs:comment "A super node in a secondary cluster, connected to the main super node." ;
    sc:R9 sc:E2010 .

# --- Example of a C6 node (for R7/R10) ---
sc:E2020 a sc:C6 ;
    rdfs:label "Special Node Chi" ;
    rdfs:comment "A node of class C6, demonstrating R7 and R10 relations." ;
    sc:R7 sc:E2010 ;
    sc:R10 sc:E2021 .

sc:E2021 a sc:C4 ;
    rdfs:label "Target Node Upsilon" ;
    rdfs:comment "A node of class C4, target of R10 from a C6 node." ;
    sc:R6 sc:E2020 .

# --- Example of a C2 node (for R2/R5) ---
sc:E2022 a sc:C2 ;
    rdfs:label "C2 Node Phi" ;
    rdfs:comment "A node of class C2, demonstrating R2 and R5 relations." ;
    sc:R2 sc:E2000 ;
    sc:R5 sc:E2010 .

# --- Example of a C7 node (for R6/R8) ---
sc:E2023 a sc:C7 ;
    rdfs:label "C7 Node Rho" ;
    rdfs:comment "A node of class C7, demonstrating R6 and R8 relations." ;
    sc:R6 sc:E2018 ;
    sc:R8 sc:E2024 .

sc:E2024 a sc:C7 ;
    rdfs:label "C7 Node Sigma" ;
    rdfs:comment "Another node of class C7, symmetric to Rho via R8." ;
    sc:R8 sc:E2023 .

# --- Example of a C8 node (for C6/C7/C8 hierarchy) ---
sc:E2025 a sc:C8 ;
    rdfs:label "C8 Node Pi" ;
    rdfs:comment "A node of class C8, showing subclass relations in the schema." ;
    sc:R4 sc:E2000 ;
    sc:R9 sc:E2010 .

# --- Example of a C3 node (for R2/R3) ---
sc:E2026 a sc:C3 ;
    rdfs:label "C3 Node Omicron" ;
    rdfs:comment "A node of class C3, demonstrating R2 and R3 relations." ;
    sc:R2 sc:E2022 ;
    sc:R3 sc:E2004 .

# --- Example of a C1 node (for R3) ---
sc:E2027 a sc:C1 ;
    rdfs:label "C1 Node Xi" ;
    rdfs:comment "A node of class C1, demonstrating R3 relation." ;
    sc:R3 sc:E2026 .

# --- Example of a C10 node (for R6) ---
sc:E2028 a sc:C10 ;
    rdfs:label "C10 Node Omega" ;
    rdfs:comment "A node of class C10, demonstrating R6 relation." ;
    sc:R6 sc:E2018 .