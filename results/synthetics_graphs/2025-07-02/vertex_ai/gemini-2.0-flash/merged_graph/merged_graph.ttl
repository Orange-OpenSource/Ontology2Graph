# Relationships and Node Types

# Hub Node: Resource3_extra_node_23 (connected to multiple network interfaces and links)
ex:Resource3_extra_node_23
    noria:resourceForApplication ex:ApplicationX_extra_node_41, ex:ApplicationY_extra_node_34 ;
    noria:resourceManagedBy ex:TeamAlpha_extra_node_41 .

# High-Degree Node: NetworkLink1_extra_node_41 (connected to multiple network interfaces)
ex:NetworkLink1_extra_node_41
    noria:networkLinkTerminationResource ex:Resource1_extra_node_29, ex:Resource3_extra_node_23 .

# Central Node: ApplicationX_extra_node_41 (used by multiple resources)
ex:ApplicationX_extra_node_41
    noria:resourceForApplication ex:Resource1_extra_node_29, ex:Resource2_extra_node_29 .

# Connector Node: NetworkInterface3_extra_node_16 (connects Resource3_extra_node_23 and NetworkLink1_extra_node_41)
ex:NetworkInterface3_extra_node_16
    noria:networkInterfaceOf ex:Resource3_extra_node_23 ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra_node_41 .

# Intermediary Node: ApplicationModuleA_extra_node_41 (connects ApplicationX_extra_node_41 and ServiceZ_extra_node_16)
ex:ApplicationModuleA_extra_node_41
    seas:subSystemOf ex:ServiceZ_extra_node_16 .

# Multiplex Node: Resource1_extra_node_29 (part of ApplicationX_extra_node_41 and connected to NetworkLink1_extra_node_41)
ex:Resource1_extra_node_29
    noria:resourceForApplication ex:ApplicationX_extra_node_41 ;
    noria:locatedAtLocus ex:LocusA_extra_node_29 .

# Super Node: ServiceZ_extra_node_16 (aggregates ApplicationModuleA_extra_node_41 and ApplicationModuleB_extra_node_34)
ex:ServiceZ_extra_node_16
    seas:subSystemOf ex:ApplicationModuleA_extra_node_41, ex:ApplicationModuleB_extra_node_34 .


