# Relationships and Node Types

# Hub Node: Resource3_extra_node_12 (connected to multiple network interfaces and links)
ex:Resource3_extra_node_12
    noria:resourceForApplication ex:ApplicationX_extra_node_25, ex:ApplicationY_extra_node_21 ;
    noria:resourceManagedBy ex:TeamAlpha_extra_node_25 .

# High-Degree Node: NetworkLink1_extra_node_25 (connected to multiple network interfaces)
ex:NetworkLink1_extra_node_25
    noria:networkLinkTerminationResource ex:Resource1_extra_node_17, ex:Resource3_extra_node_12 .

# Central Node: ApplicationX_extra_node_25 (connected to multiple application modules and resources)
ex:ApplicationX_extra_node_25
    seas:subSystemOf ex:Resource1_extra_node_17, ex:Resource3_extra_node_12 .

# Connector Node: NetworkInterface3_extra_node_9 (connects Resource3_extra_node_12 and NetworkLink1_extra_node_25)
ex:NetworkInterface3_extra_node_9
    noria:networkInterfaceOf ex:Resource3_extra_node_12 ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra_node_25 .

# Intermediary Node: ApplicationModuleA_extra_node_25 (connects ApplicationX_extra_node_25 and ServiceZ_extra_node_9)
ex:ApplicationModuleA_extra_node_25
    seas:subSystemOf ex:ServiceZ_extra_node_9 .

# Multiplex Node: Resource1_extra_node_17 (part of ApplicationX_extra_node_25 and connected to NetworkLink1_extra_node_25)
ex:Resource1_extra_node_17
    noria:resourceForApplication ex:ApplicationX_extra_node_25 ;
    noria:resourceManagedBy ex:TeamBeta_extra_node_25 .

# Super Node: ServiceZ_extra_node_9 (aggregates multiple application modules)
ex:ServiceZ_extra_node_9
    seas:subSystemOf ex:ApplicationModuleA_extra_node_25, ex:ApplicationModuleB_extra_node_21 .


