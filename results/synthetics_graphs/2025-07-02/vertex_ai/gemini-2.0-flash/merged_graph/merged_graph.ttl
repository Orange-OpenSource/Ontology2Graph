# Relationships and Node Types

# Hub Node: Resource3_extra_node_29 (connected to multiple network interfaces and links)
ex:Resource3_extra_node_29
    noria:resourceForApplication ex:ApplicationX_extra_node_57, ex:ApplicationY_extra_node_45 ;
    noria:resourceManagedBy ex:TeamAlpha_extra_node_57 .

# High-Degree Node: NetworkLink1_extra_node_57 (connected to multiple network interfaces)
ex:NetworkLink1_extra_node_57
    noria:networkLinkTerminationResource ex:Resource1_extra_node_40, ex:Resource3_extra_node_29 .

# Central Node: ApplicationX_extra_node_57 (connected to multiple application modules and resources)
ex:ApplicationX_extra_node_57
    seas:subSystemOf ex:Resource1_extra_node_40, ex:Resource3_extra_node_29 .

# Connector Node: NetworkInterface3_extra_node_20 (connects Resource3_extra_node_29 and NetworkLink1_extra_node_57)
ex:NetworkInterface3_extra_node_20
    noria:networkInterfaceOf ex:Resource3_extra_node_29 ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra_node_57 .

# Intermediary Node: ApplicationModuleA_extra_node_57 (connects ApplicationX_extra_node_57 and ServiceZ_extra_node_20)
ex:ApplicationModuleA_extra_node_57
    seas:subSystemOf ex:ServiceZ_extra_node_20 .

# Multiplex Node: Resource1_extra_node_40 (part of ApplicationX_extra_node_57 and connected to NetworkLink1_extra_node_57)
ex:Resource1_extra_node_40
    noria:resourceForApplication ex:ApplicationX_extra_node_57 ;
    noria:resourceManagedBy ex:TeamBeta_extra_node_57 .

# Super Node: ServiceZ_extra_node_20 (aggregates multiple application modules)
ex:ServiceZ_extra_node_20
    seas:subSystemOf ex:ApplicationModuleA_extra_node_57, ex:ApplicationModuleB_extra_node_45 .


