    noria:resourceManagedBy ex:TeamAlpha_extra_node_5 .

# High-Degree Node: NetworkLink1_extra_node_5 (connected to multiple network interfaces)
ex:NetworkLink1_extra_node_5
    noria:networkLinkTerminationResource ex:Resource1_extra_node_2, ex:Resource3_extra_node_1 .

# Central Node: ApplicationX_extra_node_5 (connected to multiple application modules and resources)
ex:ApplicationX_extra_node_5
    seas:subSystemOf ex:Resource1_extra_node_2, ex:Resource3_extra_node_1 .

# Connector Node: NetworkInterface3_extra_node_1 (connects Resource3_extra_node_1 and NetworkLink1_extra_node_5)
ex:NetworkInterface3_extra_node_1
    noria:networkInterfaceOf ex:Resource3_extra_node_1 ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra_node_5 .

# Intermediary Node: ApplicationModuleA_extra_node_5 (connects ApplicationX_extra_node_5 and ServiceZ_extra_node_1)
ex:ApplicationModuleA_extra_node_5
    seas:subSystemOf ex:ServiceZ_extra_node_1 .

# Multiplex Node: Resource1_extra_node_2 (part of ApplicationX_extra_node_5 and connected to NetworkLink1_extra_node_5)
ex:Resource1_extra_node_2
    noria:resourceForApplication ex:ApplicationX_extra_node_5 ;
    noria:resourceManagedBy ex:TeamBeta_extra_node_5 .

# Super Node: ServiceZ_extra_node_1 (aggregates multiple application modules)
ex:ServiceZ_extra_node_1
    seas:subSystemOf ex:ApplicationModuleA_extra_node_5, ex:ApplicationModuleB_extra_node_5 .


