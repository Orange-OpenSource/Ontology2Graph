    rdfs:comment "A backup network link." ;
    noria:networkLinkId "NL002" ;
    noria:networkLinkTerminationResourceOrigin ex:Resource2 ;
    noria:networkLinkTerminationResourceDestination ex:Resource3 .

ex:TeamAlpha
    a org:OrganizationalUnit ;
    rdfs:label "Team Alpha" ;
    rdfs:comment "Administration team." .

ex:TeamBeta
    a org:OrganizationalUnit ;
    rdfs:label "Team Beta" ;
    rdfs:comment "Support team." .

ex:LocusA
    a noria:Locus ;
    rdfs:label "Locus A" ;
    rdfs:comment "Location of Resource 1." .

ex:LocusB
    a noria:Locus ;
    rdfs:label "Locus B" ;
    rdfs:comment "Location of Resource 2." .

ex:LocusC
    a noria:Locus ;
    rdfs:label "Locus C" ;
    rdfs:comment "Location of Resource 3." .

ex:LocusD
    a noria:Locus ;
    rdfs:label "Locus D" ;
    rdfs:comment "Location of Resource 4." .

ex:ServiceZ
    a noria:Service ;
    rdfs:label "Service Z" ;
    rdfs:comment "A critical service." ;
    seas:subSystemOf ex:ApplicationModuleA, ex:ApplicationModuleB .

ex:TroubleTicket1
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket 1" ;
    rdfs:comment "A ticket related to Resource 1." ;
    noria:troubleTicketRelatedResource ex:Resource1 ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major> .

ex:ChangeRequest1
    a noria:ChangeRequest ;
    rdfs:label "Change Request 1" ;
    rdfs:comment "A change request impacting Application X." ;
    noria:changeRequestImpact ex:ApplicationX ;
    noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention> .

# Relationships and Node Types

# Hub Node: Resource3 (connected to multiple network interfaces and links)
ex:Resource3
    noria:resourceForApplication ex:ApplicationX, ex:ApplicationY ;
    noria:resourceManagedBy ex:TeamAlpha .

# High-Degree Node: NetworkLink1 (connected to multiple network interfaces)
ex:NetworkLink1
    noria:networkLinkTerminationResource ex:Resource1, ex:Resource3 .

# Central Node: ApplicationX (used by multiple resources)
ex:ApplicationX
    noria:resourceForApplication ex:Resource1, ex:Resource2 .

# Connector Node: NetworkInterface3 (connects Resource3 and NetworkLink1)
ex:NetworkInterface3
    noria:networkInterfaceOf ex:Resource3 ;
    noria:networkInterfaceConnects ex:NetworkLink1 .

# Intermediary Node: ApplicationModuleA (connects ApplicationX and ServiceZ)
ex:ApplicationModuleA
    seas:subSystemOf ex:ServiceZ .

# Multiplex Node: Resource1 (part of ApplicationX and connected to NetworkLink1)
ex:Resource1
    noria:resourceForApplication ex:ApplicationX ;
    noria:locatedAtLocus ex:LocusA .

# Super Node: ServiceZ (aggregates ApplicationModuleA and ApplicationModuleB)
ex:ServiceZ
    seas:subSystemOf ex:ApplicationModuleA, ex:ApplicationModuleB .

