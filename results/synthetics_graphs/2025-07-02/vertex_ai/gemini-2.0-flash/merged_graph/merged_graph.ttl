# Relationships and Node Types

# Hub Node: Resource3_extra_node_0 (connected to multiple network interfaces and links)
ex:Resource3_extra_node_0
    noria:resourceForApplication ex:ApplicationX_extra_node_3, ex:ApplicationY_extra_node_3 ;
    noria:resourceManagedBy ex:TeamAlpha_extra_node_3 .

# High-Degree Node: NetworkLink1_extra_node_3 (connected to multiple network interfaces)
ex:NetworkLink1_extra_node_3
    noria:networkLinkTerminationResource ex:Resource1_extra_node_1, ex:Resource3_extra_node_0 .

# Central Node: ApplicationX_extra_node_3 (used by multiple resources)
ex:ApplicationX_extra_node_3
    noria:resourceForApplication ex:Resource1_extra_node_1, ex:Resource2_extra_node_1 .

# Connector Node: NetworkInterface3_extra_node_0 (connects Resource3_extra_node_0 and NetworkLink1_extra_node_3)
ex:NetworkInterface3_extra_node_0
    noria:networkInterfaceOf ex:Resource3_extra_node_0 ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra_node_3 .

# Intermediary Node: ApplicationModuleA_extra_node_3 (connects ApplicationX_extra_node_3 and ServiceZ_extra_node_0)
ex:ApplicationModuleA_extra_node_3
    seas:subSystemOf ex:ServiceZ_extra_node_0 .

# Multiplex Node: Resource1_extra_node_1 (part of ApplicationX_extra_node_3 and connected to NetworkLink1_extra_node_3)
ex:Resource1_extra_node_1
    noria:resourceForApplication ex:ApplicationX_extra_node_3 ;
    noria:locatedAtLocus ex:LocusA_extra_node_1 .

# Super Node: ServiceZ_extra_node_0 (aggregates ApplicationModuleA_extra_node_3 and ApplicationModuleB_extra_node_3)
ex:ServiceZ_extra_node_0
    seas:subSystemOf ex:ApplicationModuleA_extra_node_3, ex:ApplicationModuleB_extra_node_3 .


