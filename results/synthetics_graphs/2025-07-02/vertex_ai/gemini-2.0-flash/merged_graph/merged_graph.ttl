# Relationships and Node Types

# Hub Node: Resource3_extra_node_18 (connected to multiple network interfaces and links)
ex:Resource3_extra_node_18
    noria:resourceForApplication ex:ApplicationX_extra_node_34, ex:ApplicationY_extra_node_27 ;
    noria:resourceManagedBy ex:TeamAlpha_extra_node_34 .

# High-Degree Node: NetworkLink1_extra_node_34 (connected to multiple network interfaces)
ex:NetworkLink1_extra_node_34
    noria:networkLinkTerminationResource ex:Resource1_extra_node_23, ex:Resource3_extra_node_18 .

# Central Node: ApplicationX_extra_node_34 (used by multiple resources)
ex:ApplicationX_extra_node_34
    noria:resourceForApplication ex:Resource1_extra_node_23, ex:Resource2_extra_node_23 .

# Connector Node: NetworkInterface3_extra_node_13 (connects Resource3_extra_node_18 and NetworkLink1_extra_node_34)
ex:NetworkInterface3_extra_node_13
    noria:networkInterfaceOf ex:Resource3_extra_node_18 ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra_node_34 .

# Intermediary Node: ApplicationModuleA_extra_node_34 (connects ApplicationX_extra_node_34 and ServiceZ_extra_node_13)
ex:ApplicationModuleA_extra_node_34
    seas:subSystemOf ex:ServiceZ_extra_node_13 .

# Multiplex Node: Resource1_extra_node_23 (part of ApplicationX_extra_node_34 and connected to NetworkLink1_extra_node_34)
ex:Resource1_extra_node_23
    noria:resourceForApplication ex:ApplicationX_extra_node_34 ;
    noria:locatedAtLocus ex:LocusA_extra_node_25 .

# Super Node: ServiceZ_extra_node_13 (aggregates ApplicationModuleA_extra_node_34 and ApplicationModuleB_extra_node_27)
ex:ServiceZ_extra_node_13
    seas:subSystemOf ex:ApplicationModuleA_extra_node_34, ex:ApplicationModuleB_extra_node_27 .


