# Relationships and Node Types

# Hub Node: Resource3_extra_node_3 (connected to multiple network interfaces and links)
ex:Resource3_extra_node_3
    noria:resourceForApplication ex:ApplicationX_extra_node_8, ex:ApplicationY_extra_node_7 ;
    noria:resourceManagedBy ex:TeamAlpha_extra_node_8 .

# High-Degree Node: NetworkLink1_extra_node_8 (connected to multiple network interfaces)
ex:NetworkLink1_extra_node_8
    noria:networkLinkTerminationResource ex:Resource1_extra_node_4, ex:Resource3_extra_node_3 .

# Central Node: ApplicationX_extra_node_8 (connected to multiple application modules and resources)
ex:ApplicationX_extra_node_8
    seas:subSystemOf ex:Resource1_extra_node_4, ex:Resource3_extra_node_3 .

# Connector Node: NetworkInterface3_extra_node_3 (connects Resource3_extra_node_3 and NetworkLink1_extra_node_8)
ex:NetworkInterface3_extra_node_3
    noria:networkInterfaceOf ex:Resource3_extra_node_3 ;
    noria:networkInterfaceConnects ex:NetworkLink1_extra_node_8 .

# Intermediary Node: ApplicationModuleA_extra_node_8 (connects ApplicationX_extra_node_8 and ServiceZ_extra_node_3)
ex:ApplicationModuleA_extra_node_8
    seas:subSystemOf ex:ServiceZ_extra_node_3 .

# Multiplex Node: Resource1_extra_node_4 (part of ApplicationX_extra_node_8 and connected to NetworkLink1_extra_node_8)
ex:Resource1_extra_node_4
    noria:resourceForApplication ex:ApplicationX_extra_node_8 ;
    noria:resourceManagedBy ex:TeamBeta_extra_node_8 .

# Super Node: ServiceZ_extra_node_3 (aggregates multiple application modules)
ex:ServiceZ_extra_node_3
    seas:subSystemOf ex:ApplicationModuleA_extra_node_8, ex:ApplicationModuleB_extra_node_7 .


