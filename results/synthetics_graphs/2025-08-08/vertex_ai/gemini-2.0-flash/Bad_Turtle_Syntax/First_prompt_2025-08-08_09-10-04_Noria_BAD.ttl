@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix ex: <http://example.com/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# Entities Declaration and Relationships

ex:ApplicationModuleA
    a noria:ApplicationModule ;
    rdfs:label "Application Module A"@en ;
    rdfs:comment "A critical application module serving as a central node."@en ;
    noria:applicationModuleName "AppModuleA" ;
    noria:applicationModuleIdentifier "AM001" ;
    noria:applicationModuleOf ex:ApplicationA ;
    noria:applicationModuleAdministrationTeam ex:TeamAlpha ;
    noria:applicationModuleSupportTeam ex:TeamBeta ;
    noria:applicationModuleSlaLevel ex:SLA_Gold ;
    noria:applicationModuleStatus ex:Status_Production .

ex:ApplicationA
    a noria:Application ;
    rdfs:label "Application A"@en ;
    rdfs:comment "A core application with high business importance."@en ;
    noria:applicationShortIdentifier "AppA" ;
    noria:applicationModelIdentifier "APP_001" ;
    noria:applicationType ex:Type_BusinessCritical ;
    noria:applicationBusinessImportance ex:Importance_High .

ex:ResourceRouter1
    a noria:Resource ;
    rdfs:label "Router 1"@en ;
    rdfs:comment "A high-degree node, connected to many network interfaces."@en ;
    noria:resourceHostName "router1.example.com" ;
    noria:resourceType ex:Type_Router ;
    noria:resourceManagedBy ex:TeamGamma ;
    noria:locatedAtLocus ex:Locus1 .

ex:NetworkInterface1
    a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "A network interface of Router 1."@en ;
    noria:networkInterfaceOf ex:ResourceRouter1 ;
    noria:networkInterfaceType ex:Type_Physical ;
    noria:networkInterfaceConnects ex:NetworkLink1 .

ex:NetworkInterface2
    a noria:NetworkInterface ;
    rdfs:label "eth1"@en ;
    rdfs:comment "Another network interface of Router 1."@en ;
    noria:networkInterfaceOf ex:ResourceRouter1 ;
    noria:networkInterfaceType ex:Type_Physical ;
    noria:networkInterfaceConnects ex:NetworkLink2 .

ex:NetworkLink1
    a noria:NetworkLink ;
    rdfs:label "Link A-B"@en ;
    rdfs:comment "A network link connecting Router 1 and Server 1."@en ;
    noria:networkLinkId "LINK_001" ;
    noria:networkLinkTerminationResourceOrigin ex:ResourceRouter1 ;
    noria:networkLinkTerminationResourceDestination ex:ResourceServer1 .

ex:NetworkLink2
    a noria:NetworkLink ;
    rdfs:label "Link A-C"@en ;
    rdfs:comment "A network link connecting Router 1 and Server 2."@en ;
    noria:networkLinkId "LINK_002" ;
    noria:networkLinkTerminationResourceOrigin ex:ResourceRouter1 ;
    noria:networkLinkTerminationResourceDestination ex:ResourceServer2 .

ex:ResourceServer1
    a noria:Resource ;
    rdfs:label "Server 1"@en ;
    rdfs:comment "A server connected to Router 1."@en ;
    noria:resourceHostName "server1.example.com" ;
    noria:resourceType ex:Type_Server ;
    noria:resourceManagedBy ex:TeamDelta ;
    noria:resourceForApplication ex:ApplicationModuleA .

ex:ResourceServer2
    a noria:Resource ;
    rdfs:label "Server 2"@en ;
    rdfs:comment "Another server connected to Router 1."@en ;
    noria:resourceHostName "server2.example.com" ;
    noria:resourceType ex:Type_Server ;
    noria:resourceManagedBy ex:TeamEpsilon ;
    noria:resourceForApplication ex:ApplicationModuleA .

ex:TeamAlpha
    a org:OrganizationalUnit ;
    rdfs:label "Team Alpha"@en ;
    rdfs:comment "The administration team for Application Module A."@en .

ex:TeamBeta
    a org:OrganizationalUnit ;
    rdfs:label "Team Beta"@en ;
    rdfs:comment "The support team for Application Module A."@en .

ex:TeamGamma
    a org:OrganizationalUnit ;
    rdfs:label "Team Gamma"@en ;
    rdfs:comment "The network team managing Router 1."@en .

ex:TeamDelta
    a org:OrganizationalUnit ;
    rdfs:label "Team Delta"@en ;
    rdfs:comment "The server team managing Server 1."@en .

ex:TeamEpsilon
    a org:OrganizationalUnit ;
    rdfs:label "Team Epsilon"@en ;
    rdfs:comment "The server team managing Server 2."@en .

ex:SLA_Gold
    a skos:Concept ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "Gold service level agreement."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

ex:Status_Production
    a skos:Concept ;
    rdfs:label "Production"@en ;
    rdfs:comment "The application module is in production."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

ex:Type_BusinessCritical
    a skos:Concept ;
    rdfs:label "Business Critical"@en ;
    rdfs:comment "A business critical application type."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

ex:Importance_High
    a skos:Concept ;
    rdfs:label "High Importance"@en ;
    rdfs:comment "High business importance."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

ex:Type_Router
    a skos:Concept ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router."@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

ex:Type_Server
    a skos:Concept ;
    rdfs:label "Server"@en ;
    rdfs:comment "A server resource."@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

ex:Type_Physical
    a skos:Concept ;
    rdfs:label "Physical"@en ;
    rdfs:comment "A physical network interface."@en ;
    skos:inScheme <https://w3id.org/noria/kos/NetworkInterface/type> .

ex:Locus1
    a noria:Locus ;
    rdfs:label "Locus 1"@en ;
    rdfs:comment "Location of Router 1 in the server room."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .
