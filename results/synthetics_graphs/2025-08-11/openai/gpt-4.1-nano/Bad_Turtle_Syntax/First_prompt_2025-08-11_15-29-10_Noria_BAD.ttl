@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central node acting as a core router hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, serving as a central switch."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:structuralElementDistinguishedName "Switch-01" .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node connecting multiple application servers."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking external network to internal resources."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservable <https://example.com/loadDistribution> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamQuality> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/segmentTraffic> .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Server A"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Router B"@en ;
  rdfs:comment "Edge router connecting to external network."@en ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/ResourceC> a noria:Resource ;
  rdfs:label "Firewall C"@en ;
  rdfs:comment "Firewall protecting internal network."@en ;
  noria:locatedAtLocus <https://example.com/Locus3> ;
  noria:resourceManagedBy <https://example.com/SecurityTeam> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between ResourceA and ResourceB."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Ethernet Link 2"@en ;
  rdfs:comment "Ethernet connection between ResourceB and ResourceC."@en ;
  noria:networkLinkId "NL-002" ;
  noria:networkLinkInstallationDate "2022-02-20T12:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Ethernet" .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of ResourceA."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceOperationalStatus <https://example.com/status/up> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 ;

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/1"@en ;
  rdfs:comment "External interface of ResourceB."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOperationalStatus <https://example.com/status/down> ;
  noria:networkInterfaceRoutingPriorityMetric 200 ;
  noria:networkInterfaceLaserTxOpticalPower -1 ;
  noria:networkInterfaceLaserRxOpticalPower -4 .

<https://example.com/Resource> a noria:Resource ;
  rdfs:label "Generic Resource"@en ;
  rdfs:comment "A generic network resource."@en ;
  noria:locatedAtLocus <https://example.com/Locus4> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security management."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing general IT support."@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Server Room 1"@en ;
  rdfs:comment "Main server room in Building A."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Main Entrance"@en ;
  rdfs:comment "Entrance hall of the data center."@en .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Firewall Zone"@en ;
  rdfs:comment "Zone where Firewall C is located."@en .

<https://example.com/Locus4> a noria:Locus ;
  rdfs:label "Remote Site"@en ;
  rdfs:comment "Remote resource location."@en .

<https://example.com/status/up> a skos:Concept ;
  rdfs:label "Up"@en .

<https://example.com/status/down> a skos:Concept ;
  rdfs:label "Down"@en .

