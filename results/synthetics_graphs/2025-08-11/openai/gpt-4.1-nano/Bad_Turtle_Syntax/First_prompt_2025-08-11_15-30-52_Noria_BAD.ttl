@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a critical junction in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node coordinating network traffic."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/throughput> ;
  noria:elementManagedBy <https://example.com/Operations> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node aggregating multiple sub-nodes."@en ;
  noria:structuralObservableOf <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/SupervisionTeam> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical network resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "server1.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model of Resource 1."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "ACME Corp."@en ;
  rdfs:comment "Manufacturer of Model X."@en .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Location within Server Room 314."@en ;
  noria:locusLine "L" ;
  noria:locusRow "6" .

<https://example.com/Network1> a noria:NetworkLink ;
  rdfs:label "Fiber Optic Link"@en ;
  rdfs:comment "A high-speed fiber optic connection."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2021-06-01T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Another network resource."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:resourceHostName "switch2.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-02-20T11:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagedBy <https://example.com/NetworkTeam> .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Manufacturer's model of Resource 2."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "BetaTech"@en ;
  rdfs:comment "Manufacturer of Model Y."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Location within Data Center 2."@en ;
  noria:locusLine "A" ;
  noria:locusRow "12" .

<https://example.com/AlarmEvent1> a noria:EventRecord ;
  rdfs:label "Alarm Event Critical"@en ;
  rdfs:comment "Critical alarm indicating resource failure."@en ;
  noria:logRecordId "ER-0001" ;
  noria:logText "Resource 1 has failed." ;
  noria:loggingTime "2023-10-01T14:22:00Z"^^xsd:dateTime ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:alarmSeverity <https://skos.org/Notification/Severity/Critical> ;
  noria:alarmProposedRepairAction <https://example.com/RepairAction1> .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en ;
  rdfs:comment "System monitoring network resources."@en .

<https://example.com/RepairAction1> a pep:Procedure ;
  rdfs:label "Resource Restart"@en ;
  rdfs:comment "Procedure to restart the failed resource."@en .

<https://example.com/TrafficEvent> a noria:EventRecord ;
  rdfs:label "Traffic Load Event"@en ;
  rdfs:comment "High traffic detected on Resource 2."@en ;
  noria:logRecordId "ER-0002" ;
  noria:logText "Traffic exceeds threshold." ;
  noria:loggingTime "2023-10-01T15:00:00Z"^^xsd:dateTime ;
  noria:logOriginatingManagedObject <https://example.com/Resource2> ;
  noria:structuralElementObservable <https://example.com/throughput> .

<https://example.com/throughput> a noria:Property ;
  rdfs:label "Throughput"@en ;
  rdfs:comment "Data throughput in Mbps."@en .

<https://example.com/aggregateTraffic> a noria:StructuralObservable ;
  rdfs:label "Aggregate Traffic"@en ;
  rdfs:comment "Total network traffic across multiple nodes."@en .

<https://example.com/SupervisionTeam> a org:OrganizationalUnit ;
  rdfs:label "Supervision Team"@en ;
  rdfs:comment "Team responsible for overseeing network operations."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Operational team managing network infrastructure."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Support team responsible for resource management."@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team handling network resources."@en .

<https://example.com/StreamManagement> a org:OrganizationalUnit ;
  rdfs:label "Stream Management"@en ;
  rdfs:comment "Team managing data streams."@en .

<https://example.com/Operations> a org:OrganizationalUnit ;
  rdfs:label "Operations"@en ;
  rdfs:comment "General operations team."@en .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "mux1.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusC> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Mux> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-05-10T08:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelZ> ;
  noria:resourceManagedBy <https://example.com/StreamOps> .

<https://example.com/ModelZ> a noria:ProductModel ;
  rdfs:label "Model Z"@en ;
  rdfs:comment "Manufacturer's model of Resource 3."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerC> .

<https://example.com/ManufacturerC> a org:Organization ;
  rdfs:label "GammaManufacture"@en ;
  rdfs:comment "Manufacturer of Model Z."@en .

<https://example.com/LocusC> a noria:Locus ;
  rdfs:label "Locus C"@en ;
  rdfs:comment "Location within Data Center 3."@en ;
  noria:locusLine "B" ;
  noria:locusRow "7" .