@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity degree, acting as a critical junction."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node coordinating network traffic."@en ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:elementManagedBy <https://example.com/InterconnectTeam> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:elementManagedBy <https://example.com/SupervisionTeam> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical server resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceHostName "server1.example.com" ;
  noria:resourceType <http://purl.org/ontology/bibo/Hardware> ;
  noria:resourceSerialNumber "SN-987654" ;
  noria:resourceUsageState <http://purl.org/ontology/bibo/Operational> ;
  noria:resourceInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual machine resource."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceHostName "vm2.example.com" ;
  noria:resourceType <http://purl.org/ontology/bibo/VirtualMachine> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceUsageState <http://purl.org/ontology/bibo/Operational> ;
  noria:resourceInstallationDate "2021-03-20T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceManagedBy <https://example.com/VirtualizationTeam> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource 1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet Interface"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 ;

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary virtual network interface of Resource 2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "Virtual Ethernet Interface"@en ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink2> ;
  noria:networkInterfaceRoutingPriorityMetric 200 ;
  noria:networkInterfaceLaserTxOpticalPower -1 ;
  noria:networkInterfaceLaserRxOpticalPower -4 .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between Resource 1 and Resource 2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "fiber" ;
  noria:networkLinkInstallationDate "2019-11-10T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Link2"@en ;
  rdfs:comment "Virtual link for resource virtualization."@en ;
  noria:networkLinkId "NL-002" ;
  noria:networkLinkType "virtual" ;
  noria:networkLinkInstallationDate "2020-01-15T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource2> ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource1> .

<https://example.com/Resource> a noria:Resource ;
  rdfs:label "Generic Resource"@en ;
  rdfs:comment "A generic network resource."@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance server model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ProductModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Virtualization platform."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "TechCorp Inc."@en ;
  rdfs:comment "Leading hardware manufacturer."@en .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "VirtuTech Ltd."@en ;
  rdfs:comment "Virtualization hardware provider."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for physical resources."@en .

<https://example.com/VirtualizationTeam> a org:OrganizationalUnit ;
  rdfs:label "Virtualization Team"@en ;
  rdfs:comment "Team managing virtual resources."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Network operations support team."@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team handling network infrastructure."@en .

<https://example.com/ConnectivityTeam> a org:OrganizationalUnit ;
  rdfs:label "Connectivity Team"@en ;
  rdfs:comment "Team managing network connectivity."@en .

<https://example.com/InterconnectTeam> a org:OrganizationalUnit ;
  rdfs:label "Interconnect Team"@en ;
  rdfs:comment "Team responsible for inter-node links."@en .

<https://example.com/StreamManagement> a org:OrganizationalUnit ;
  rdfs:label "Stream Management"@en ;
  rdfs:comment "Team managing data streams."@en .

<https://example.com/SupervisionTeam> a org:OrganizationalUnit ;
  rdfs:label "Supervision Team"@en ;
  rdfs:comment "Team overseeing super nodes."@en .