@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservable <https://example.com/NodeLoadObservable> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within a specific subnetwork."@en ;
  noria:structuralElementObservable <https://example.com/TrafficFlowObservable> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservable <https://example.com/LinkStatusObservable> ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/LatencyObservable> ;
  noria:elementManagedBy <https://example.com/PerformanceTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/StreamCountObservable> ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeLoad> ;
  noria:elementManagedBy <https://example.com/SuperNodeOps> .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Operations team managing network nodes."@en .

<https://example.com/NetworkAdmin> a org:OrganizationalUnit ;
  rdfs:label "Network Administration"@en ;
  rdfs:comment "Admin team for central nodes."@en .

<https://example.com/ConnectivityTeam> a org:OrganizationalUnit ;
  rdfs:label "Connectivity Team"@en ;
  rdfs:comment "Team handling link and connection issues."@en .

<https://example.com/PerformanceTeam> a org:OrganizationalUnit ;
  rdfs:label "Performance Team"@en ;
  rdfs:comment "Team monitoring latency and throughput."@en .

<https://example.com/StreamManagement> a org:OrganizationalUnit ;
  rdfs:label "Stream Management"@en ;
  rdfs:comment "Team managing multiplex data streams."@en .

<https://example.com/SuperNodeOps> a org:OrganizationalUnit ;
  rdfs:label "Super Node Operations"@en ;
  rdfs:comment "Team overseeing super node functions."@en .

<https://example.com/NodeLoadObservable> a noria:structuralObservableOf ;
  rdfs:label "Node Load Observable"@en ;
  rdfs:comment "Observable for node load metrics."@en .

<https://example.com/TrafficFlowObservable> a noria:structuralObservableOf ;
  rdfs:label "Traffic Flow Observable"@en ;
  rdfs:comment "Observable for traffic flow metrics."@en .

<https://example.com/LinkStatusObservable> a noria:structuralObservableOf ;
  rdfs:label "Link Status Observable"@en ;
  rdfs:comment "Observable for link status."@en .

<https://example.com/LatencyObservable> a noria:structuralObservableOf ;
  rdfs:label "Latency Observable"@en ;
  rdfs:comment "Observable for latency measurements."@en .

<https://example.com/StreamCountObservable> a noria:structuralObservableOf ;
  rdfs:label "Stream Count Observable"@en ;
  rdfs:comment "Observable for multiplex stream counts."@en .

<https://example.com/SuperNodeLoad> a noria:structuralObservableOf ;
  rdfs:label "Super Node Load"@en ;
  rdfs:comment "Observable for super node load metrics."@en .