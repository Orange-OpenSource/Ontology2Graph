<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within a specific sub-network."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/DataManagement> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that multiplexes multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamControl> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkSupervision> .

