@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity, managing multiple links."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with numerous connections, acting as a critical junction."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/throughputObservable> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionQuality> ;
  noria:elementManagedBy <https://example.com/ConnectivitySupport> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/throughputObservable> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/systemHealth> ;
  noria:elementManagedBy <https://example.com/ITManagement> .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "Core network resource responsible for routing."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:resourceSerialNumber "SN-987654" ;
  noria:resourceHostName "routerA.example.com" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagedBy <https://example.com/NetworkTeam> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "Virtual server hosting critical applications."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualServer> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceHostName "vs-application.example.com" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagedBy <https://example.com/ApplicationSupport> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between ResourceA and ResourceB."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkInstallationDate "2021-06-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/latencyObservable> a noria:StructuralObservable ;
  rdfs:label "Latency Observable"@en ;
  rdfs:comment "Monitoring latency between nodes."@en .

<https://example.com/throughputObservable> a noria:StructuralObservable ;
  rdfs:label "Throughput Observable"@en ;
  rdfs:comment "Monitoring throughput capacity."@en .

<https://example.com/systemHealth> a noria:StructuralObservable ;
  rdfs:label "System Health"@en ;
  rdfs:comment "Overall health status of the network system."@en .

<https://example.com/connectionQuality> a noria:StructuralObservable ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Quality metrics of network connections."@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Secondary data center."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/NetworkAdmin> a org:OrganizationalUnit ;
  rdfs:label "Network Administration"@en ;
  rdfs:comment "Team managing high-degree nodes."@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "Team overseeing network resources."@en .

<https://example.com/ApplicationSupport> a org:OrganizationalUnit ;
  rdfs:label "Application Support"@en ;
  rdfs:comment "Team supporting virtual resources."@en .

<https://example.com/ITManagement> a org:OrganizationalUnit ;
  rdfs:label "IT Management"@en ;
  rdfs:comment "High-level management of IT infrastructure."@en .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Router model X from Manufacturer A."@en ;
  noria:productManufacturedBy <https://orgs/ManufacturerA> .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Virtual server platform Y from Manufacturer B."@en ;
  noria:productManufacturedBy <https://orgs/ManufacturerB> .

<https://orgs/ManufacturerA> a org:Organization ;
  rdfs:label "Manufacturer A"@en .

<https://orgs/ManufacturerB> a org:Organization ;
  rdfs:label "Manufacturer B"@en .