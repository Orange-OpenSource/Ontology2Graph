@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMetric> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central to multiple applications and resources."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/intermediateLatency> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregationLevel> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical resource in the network."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceSerialNumber "SN-987654" ;
  noria:resourceHostName "server1.example.com" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagementIPAddress "192.168.1.10" ;
  noria:agentManagesResource <https://example.com/NetworkAdmin> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A backup resource in the network."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceHostName "router2.example.com" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Standby> ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagementIPAddress "192.168.1.20" ;
  noria:agentManagesResource <https://example.com/NetworkSupport> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "Line: L, in Room:Server room 314" .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Secondary network area."@en ;
  noria:locusRow "Row: 5" .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Lead network administrator responsible for Resource 1."@en .

<https://example.com/NetworkSupport> a foaf:Agent ;
  rdfs:label "Network Support"@en ;
  rdfs:comment "Support agent for Resource 2."@en .

<https://example.com/latencyMetric> a noria:structuralObservableOf ;
  rdfs:label "Latency Metric"@en ;
  rdfs:comment "Average latency in milliseconds."@en .

<https://example.com/trafficLoad> a noria:structuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/connectionStatus> a noria:structuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the network connection."@en .

<https://example.com/intermediateLatency> a noria:structuralObservable ;
  rdfs:label "Intermediate Latency"@en ;
  rdfs:comment "Latency at intermediate nodes."@en .

<https://example.com/streamCount> a noria:structuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/aggregationLevel> a noria:structuralObservable ;
  rdfs:label "Aggregation Level"@en ;
  rdfs:comment "Level of data aggregation in super nodes."@en .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance server model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Enterprise router model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "TechCorp Inc."@en ;
  rdfs:comment "Manufacturer of Model X."@en .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "NetMakers Ltd."@en ;
  rdfs:comment "Manufacturer of Model Y."@en .