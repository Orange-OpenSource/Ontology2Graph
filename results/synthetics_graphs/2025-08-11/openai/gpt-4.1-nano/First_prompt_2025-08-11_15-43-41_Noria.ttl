@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMetric> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central to multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/throughputObservable> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network domains."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/DataTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkSupervision> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "The organization responsible for network management."@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team managing network infrastructure."@en ;
  org:organizes <https://example.com/NetworkOperations> .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Lead network administrator responsible for central nodes."@en .

<https://example.com/ConnectivityTeam> a foaf:Agent ;
  rdfs:label "Connectivity Support Team"@en ;
  rdfs:comment "Team handling connector nodes and links."@en .

<https://example.com/DataTeam> a foaf:Agent ;
  rdfs:label "Data Flow Management Team"@en ;
  rdfs:comment "Team overseeing data flow and intermediary nodes."@en .

<https://example.com/StreamManagement> a foaf:Agent ;
  rdfs:label "Stream Management Group"@en ;
  rdfs:comment "Group managing multiplex nodes and data streams."@en .

<https://example.com/NetworkSupervision> a foaf:Agent ;
  rdfs:label "Network Supervision Unit"@en ;
  rdfs:comment "Unit supervising super nodes and overall traffic."@en .

<https://example.com/latencyMetric> a noria:structuralObservableOf ;
  rdfs:label "Latency Metric"@en ;
  rdfs:comment "Measurement of network latency at high-degree nodes."@en .

<https://example.com/throughputObservable> a noria:structuralObservable ;
  rdfs:label "Throughput Observable"@en ;
  rdfs:comment "Monitoring throughput at central nodes."@en .

<https://example.com/connectionStatus> a noria:structuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of connections at connector nodes."@en .

<https://example.com/dataFlowRate> a noria:structuralObservableData ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through intermediary nodes."@en .

<https://example.com/streamCount> a noria:structuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed at multiplex nodes."@en .

<https://example.com/aggregateTraffic> a noria:structuralObservable ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Total traffic handled by super nodes."@en .
