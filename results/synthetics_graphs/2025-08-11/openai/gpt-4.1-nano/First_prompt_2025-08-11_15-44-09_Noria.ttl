  noria:resourceSerialNumber "SN654321" ;
  noria:resourceHostName "host-resource2" .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Locus in Server Room 314."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Locus in Data Center 1."@en .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary Ethernet interface."@en ;
  noria:networkInterfaceType "physical"^^xsd:string ;
  noria:networkInterfaceDescription "GigabitEthernet0/0/1"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "veth0"@en ;
  rdfs:comment "Virtual Ethernet interface."@en ;
  noria:networkInterfaceType "virtual"^^xsd:string ;
  noria:networkInterfaceDescription "veth interface for container."@en ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink2> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
