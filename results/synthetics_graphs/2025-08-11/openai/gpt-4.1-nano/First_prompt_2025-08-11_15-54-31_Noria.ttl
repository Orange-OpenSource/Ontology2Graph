@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a critical junction in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node coordinating network traffic."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/throughput> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkSupervisors> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "The organization responsible for network management."@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team managing high-degree nodes."@en ;
  org:organizes <https://example.com/NetworkOperations> .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Central node administrator."@en .

<https://example.com/ConnectivityTeam> a foaf:Agent ;
  rdfs:label "Connectivity Support Team"@en ;
  rdfs:comment "Handles connector nodes."@en .

<https://example.com/NetworkSupport> a foaf:Agent ;
  rdfs:label "Network Support"@en ;
  rdfs:comment "Supports intermediary nodes."@en .

<https://example.com/StreamManagement> a foaf:Agent ;
  rdfs:label "Stream Management"@en ;
  rdfs:comment "Manages multiplex nodes."@en .

<https://example.com/NetworkSupervisors> a foaf:Agent ;
  rdfs:label "Network Supervisors"@en ;
  rdfs:comment "Oversees super nodes."@en .

<https://example.com/latencyMeasurement> a noria:StructuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Average latency between nodes."@en .

<https://example.com/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection (up/down)."@en .

<https://example.com/throughput> a noria:StructuralObservableData ;
  rdfs:label "Throughput"@en ;
  rdfs:comment "Data throughput rate."@en .

<https://example.com/streamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/aggregateTraffic> a noria:StructuralObservable ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Total traffic passing through super node."@en .