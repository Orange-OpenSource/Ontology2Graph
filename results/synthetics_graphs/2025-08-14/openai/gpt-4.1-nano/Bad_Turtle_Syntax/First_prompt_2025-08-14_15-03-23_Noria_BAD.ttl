@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Graph1> a owl:Ontology ;
    rdfs:label "Sample Noria-based Knowledge Graph"@en .

# Hub Node: Central Application
<https://example.com/Application1> a noria:Application ;
    rdfs:label "Core Network Management System"@en ;
    rdfs:comment "Main application managing network devices and events."@en ;
    noria:applicationShortIdentifier "NetMgmtSys" ;
    noria:applicationType <kos/application/type/ManagementSystem> ;
    noria:applicationBusinessImportance <skos:Concept> ;
    noria:applicationFunctionalDomain "Network Operations" ;
    noria:applicationFunctionalSubDomain "Network Monitoring" .

# High-Degree Node: Network Link connecting multiple resources
<https://example.com/NetworkLink1> a noria:NetworkLink ;
    rdfs:label "Fiber Optic Link A-B"@en ;
    rdfs:comment "High capacity fiber link connecting Router A and Router B."@en ;
    noria:networkLinkId "Link-AB-001" ;
    noria:networkLinkType "Optical Fiber" ;
    noria:networkLinkInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime .

# Resources connected via the high-degree node
<https://example.com/ResourceRouterA> a noria:Resource ;
    rdfs:label "Router A"@en ;
    rdfs:comment "Core router in data center."@en ;
    noria:resourceLogisticId "R-A-DC" ;
    noria:resourceHostName "routerA.dc.example.com" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:locatedAtLocus <https://example.com/Locus1> .

<https://example.com/ResourceRouterB> a noria:Resource ;
    rdfs:label "Router B"@en ;
    rdfs:comment "Edge router connecting to branch office."@en ;
    noria:resourceLogisticId "R-B-BO" ;
    noria:resourceHostName "routerB.bo.example.com" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:locatedAtLocus <https://example.com/Locus2> .

# Connect resources to the network link
<https://example.com/ResourceRouterA> noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
<https://example.com/ResourceRouterB> noria:networkInterfaceConnects <https://example.com/NetworkLink1> .

# Connector Node: Network Interface on Router A
<https://example.com/NetworkInterfaceA> a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Primary interface on Router A."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "GigabitEthernet0/0/0"@en ;
    noria:networkInterfaceOf <https://example.com/ResourceRouterA> .

# Connector Node: Network Interface on Router B
<https://example.com/NetworkInterfaceB> a noria:NetworkInterface ;
    rdfs:label "eth1"@en ;
    rdfs:comment "Primary interface on Router B."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "GigabitEthernet0/0/1"@en ;
    noria:networkInterfaceOf <https://example.com/ResourceRouterB> .

# Intermediary Node: Event Record for link status change
<https://example.com/EventRecord1> a noria:EventRecord ;
    rdfs:label "Link Up Event"@en ;
    rdfs:comment "Event indicating fiber link is operational."@en ;
    noria:loggingTime "2024-03-15T12:30:00Z"^^xsd:dateTime ;
    noria:logText "Fiber link between Router A and Router B is now active."@en ;
    noria:logOriginatingManagedObject <https://example.com/NetworkLink1> ;
    noria:logOriginatingManagementSystem <https://example.com/ManagementSystem1> ;
    noria:alarmSeverity <skos:Concept> ; # e.g., normal
    noria:alarmSeverity <skos:Concept> ; # placeholder for severity concept
    noria:alarmProposedRepairAction <https://example.com/Procedure1> .

# Super Node: Entire Network System
<https://example.com/NetworkSystem> a seas:System ;
    rdfs:label "Corporate Network System"@en ;
    rdfs:comment "Complete corporate network infrastructure including routers, links, and management applications."@en ;
    seas:subSystemOf <https://example.com/Application1> ;
    seas:hasPart <https://example.com/ResourceRouterA> , <https://example.com/ResourceRouterB> , <https://example.com/NetworkLink1> , <https://example.com/NetworkInterfaceA> , <https://example.com/NetworkInterfaceB> , <https://example.com/EventRecord1> .

# Additional Nodes for clarity
<https://example.com/ManagementSystem1> a noria:Application ;
    rdfs:label "Network Management System"@en ;
    rdfs:comment "System responsible for managing network devices and events."@en .

<https://example.com/Procedure1> a noria:OperationPlan ;
    rdfs:label "Link Activation Procedure"@en ;
    rdfs:comment "Procedure to activate or verify fiber link."@en .

<https://example.com/Locus1> a noria:Locus ;
    rdfs:label "Data Center Rack 1"@en ;
    rdfs:comment "Location of Router A in data center."@en .

<https://example.com/Locus2> a noria:Locus ;
    rdfs:label "Branch Office"@en ;
    rdfs:comment "Location of Router B in branch office."@en .