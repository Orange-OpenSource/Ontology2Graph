@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A network switch with high connectivity degree, acting as a key connector."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMetric> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:FunctionalElement ;
  rdfs:label "Central Application Server"@en ;
  rdfs:comment "A core server hosting critical applications, acting as a central node."@en ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A firewall acting as a connector between internal and external networks."@en ;
  noria:structuralElementObservable <https://example.com/trafficObservable> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "A device multiplexing multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamQuality> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node aggregating multiple sub-nodes for high-level management."@en ;
  noria:structuralElementObservableData <https://example.com/systemHealth> ;
  noria:elementManagedBy <https://example.com/ManagementTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Support team for core IT infrastructure."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team managing security devices and policies."@en .

<https://example.com/OperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Operations Team"@en ;
  rdfs:comment "Team overseeing operational aspects of the network."@en .

<https://example.com/ManagementTeam> a org:OrganizationalUnit ;
  rdfs:label "Management Team"@en ;
  rdfs:comment "High-level management overseeing network and system health."@en .

<https://example.com/latencyMetric> a noria:StructuralObservable ;
  rdfs:label "Latency Metric"@en ;
  rdfs:comment "Measurement of network latency in milliseconds."@en .

<https://example.com/trafficObservable> a noria:StructuralObservable ;
  rdfs:label "Traffic Observable"@en ;
  rdfs:comment "Real-time traffic flow measurement."@en .

<https://example.com/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current load on load balancer in Mbps."@en .

<https://example.com/systemHealth> a noria:StructuralObservable ;
  rdfs:label "System Health"@en ;
  rdfs:comment "Overall health status of the super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Physical server hosting application."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceHostName "server1.example.com" .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "L" ;
  noria:locusRow "Row 1" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Virtual machine for testing."@en ;
  noria:resourceLogisticId "RES-002" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceHostName "vm-test.example.com" .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Virtual lab environment."@en ;
  noria:locusLine "L" ;
  noria:locusRow "Row 2" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber connecting Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceOf <https://example.com/Resource1> .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary interface of Resource2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOf <https://example.com/Resource2> .

<https://example.com/TrafficFlow> a noria:EventRecord ;
  rdfs:label "Traffic Flow Event"@en ;
  rdfs:comment "An event indicating high traffic detected."@en ;
  noria:loggingTime "2023-10-01T14:30:00"^^xsd:dateTime ;
  noria:logText "Traffic spike detected on eth0."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> .

<https://example.com/AlarmCritical> a noria:EventRecord ;
  rdfs:label "Critical Alarm"@en ;
  rdfs:comment "Critical security breach detected."@en ;
  noria:loggingTime "2023-10-02T09:15:00"^^xsd:dateTime ;
  noria:logText "Firewall breach detected."@en ;
  noria:alarmSeverity <skos:Concept> ;
  noria:alarmSeverity <https://example.com/CriticalSeverity> ;
  noria:alarmProposedRepairAction <https://example.com/RepairAction1> ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> .

<https://example.com/CriticalSeverity> a skos:Concept ;
  rdfs:label "Critical"@en ;
  skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .

<https://example.com/RepairAction1> a pep:Procedure ;
  rdfs:label "Restart Firewall"@en ;
  rdfs:comment "Procedure to restart the firewall device."@en .

<https://example.com/TrafficLoadEvent> a noria:EventRecord ;
  rdfs:label "Traffic Load Event"@en ;
  rdfs:comment "High load detected on load balancer."@en ;
  noria:loggingTime "2023-10-01T16:00:00"^^xsd:dateTime ;
  noria:logText "Traffic load exceeded threshold."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource2> .

<https://example.com/SystemHealthStatus> a noria:EventRecord ;
  rdfs:label "System Health Status"@en ;
  rdfs:comment "Overall health status of the super node."@en ;
  noria:loggingTime "2023-10-01T12:00:00"^^xsd:dateTime ;
  noria:logText "System operating within normal parameters."@en ;
  noria:logOriginatingManagedObject <https://example.com/SuperNode> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "High-level aggregation node for system monitoring."@en ;
  noria:structuralElementObservableData <https://example.com/systemHealth> ;
  noria:elementManagedBy <https://example.com/ManagementTeam> .

<https://example.com/ManagementTeam> a org:OrganizationalUnit ;
  rdfs:label "Management Team"@en ;
  rdfs:comment "Oversees system health and high-level management."@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Manages network infrastructure."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en .

<https://example.com/TrafficFlow> a noria:EventRecord ;
  rdfs:label "Traffic Flow Event"@en .

<https://example.com/AlarmCritical> a noria:EventRecord ;
  rdfs:label "Critical Alarm"@en .

<https://example.com/TrafficLoadEvent> a noria:EventRecord ;
  rdfs:label "Traffic Load Event"@en .

<https://example.com/SystemHealthStatus> a noria:EventRecord ;
  rdfs:label "System Health Status"@en .