@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode_extra_node_11> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity, managing multiple links."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "Organization responsible for network management."@en .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "High-degree node with many connections in the network."@en ;
  noria:structuralElementObservableData "Routing table size: 1024 entries"^^xsd:string ;
  noria:structuralElementDistinguishedName "CoreRouter-01" .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Switch"@en ;
  rdfs:comment "Node acting as a central point in the network topology."@en ;
  noria:structuralElementObservableData "Switch port count: 48"^^xsd:string ;
  noria:structuralElementDistinguishedName "CentralSwitch-01" .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Fiber Connector"@en ;
  rdfs:comment "Connector node linking different network segments."@en ;
  noria:structuralElementObservableData "Fiber type: Single-mode"^^xsd:string ;
  noria:structuralElementDistinguishedName "FiberConnector-01" .

<https://example.com/intermediaryNode1> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Intermediary node distributing traffic among servers."@en ;
  noria:functionalElementDistinguishedName "LoadBalancer-Alpha" .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en ;
  noria:structuralElementObservableData "Streams multiplexed: 8"^^xsd:string ;
  noria:structuralElementDistinguishedName "Multiplexer-01" .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Super node aggregating multiple high-degree nodes."@en ;
  noria:structuralElementObservableData "Connected to 10 high-degree nodes"^^xsd:string ;
  noria:structuralElementDistinguishedName "SuperNode_extra_node_1-01" .

<https://example.com/nodeA> a noria:StructuralElement ;
  rdfs:label "Node A"@en ;
  rdfs:comment "Hub node with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/nodeB> a noria:StructuralElement ;
  rdfs:label "Node B"@en ;
  rdfs:comment "High-degree node in the network."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/nodeC> a noria:StructuralElement ;
  rdfs:label "Node C"@en ;
  rdfs:comment "Connector node linking segments."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/nodeD> a noria:FunctionalElement ;
  rdfs:label "Node D"@en ;
  rdfs:comment "Intermediary node for traffic routing."@en ;
  noria:functionalElementDistinguishedName "NodeD-Functional" ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/nodeE> a noria:StructuralElement ;
  rdfs:label "Node E"@en ;
  rdfs:comment "Multiplex node handling multiple streams."@en ;
  noria:structuralElementObservableData "Streams: 4"^^xsd:string ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/nodeF> a noria:StructuralElement ;
  rdfs:label "Node F"@en ;
  rdfs:comment "Super node aggregating high-degree nodes."@en ;
  noria:structuralElementObservableData "Connected to 8 high-degree nodes"^^xsd:string ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/link1> a noria:NetworkLink ;
  rdfs:label "Link 1"@en ;
  rdfs:comment "Optical fiber link connecting Node A and Node B."@en ;
  noria:networkLinkId "Link-AB-001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/nodeA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/nodeB> ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/link2> a noria:NetworkLink ;
  rdfs:label "Link 2"@en ;
  rdfs:comment "Ethernet link between Node C and Node D."@en ;
  noria:networkLinkId "Link-CD-002" ;
  noria:networkLinkInstallationDate "2022-02-20T12:30:00"^^xsd:dateTime ;
  noria:networkLinkType "Ethernet"^^xsd:string ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/nodeC> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/nodeD> ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/link3> a noria:NetworkLink ;
  rdfs:label "Link 3"@en ;
  rdfs:comment "WDM link connecting Node E and Node F."@en ;
  noria:networkLinkId "Link-EF-003" ;
  noria:networkLinkInstallationDate "2022-03-10T09:45:00"^^xsd:dateTime ;
  noria:networkLinkType "WDM"^^xsd:string ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/nodeE> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/nodeF> ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/structuralObservable1> a noria:structuralObservableOf ;
  rdfs:label "Router Observable"@en ;
  rdfs:comment "Observable property for Router status."@en ;
  noria:structuralObservableOf <https://example.com/nodeA> ;
  noria:structuralElementObservableData "Uptime: 99.99%"^^xsd:string .

<https://example.com/structuralObservable2> a noria:structuralObservableOf ;
  rdfs:label "Switch Observable"@en ;
  rdfs:comment "Observable property for Switch status."@en ;
  noria:structuralObservableOf <https://example.com/nodeB> ;
  noria:structuralElementObservableData "Packet Loss: 0.1%"^^xsd:string .

<https://example.com/connectorObservable1> a noria:structuralObservableOf ;
  rdfs:label "Fiber Connector Power"@en ;
  rdfs:comment "Optical power measurement for Fiber Connector."@en ;
  noria:structuralObservableOf <https://example.com/fiberConnector1> ;
  noria:structuralElementObservableData "Tx Power: -2 dBm"^^xsd:string .

<https://example.com/intermediaryObservable1> a noria:structuralObservableOf ;
  rdfs:label "Load Balancer Traffic"@en ;
  rdfs:comment "Traffic load on Load Balancer."@en ;
  noria:structuralObservableOf <https://example.com/loadBalancer1> ;
  noria:structuralElementObservableData "Current Load: 75%"^^xsd:string .

<https://example.com/multiplexObservable1> a noria:structuralObservableOf ;
  rdfs:label "Multiplexer Streams"@en ;
  rdfs:comment "Number of streams multiplexed."@en ;
  noria:structuralObservableOf <https://example.com/multiplexer1> ;
  noria:structuralElementObservableData "Streams: 8"^^xsd:string .

<https://example.com/superNodeObservable1> a noria:structuralObservableOf ;
  rdfs:label "Super Node Connectivity"@en ;
  rdfs:comment "Number of high-degree nodes connected."@en ;
  noria:structuralObservableOf <https://example.com/superNode1> ;
  noria:structuralElementObservableData "Connected to 10 nodes"^^xsd:string .