@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode_extra_node_0>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "High-degree node with many connections in the network."@en ;
  noria:structuralElementObservableData <https://example.com/routerTrafficVolume> .

<https://example.com/centralNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "Central node facilitating data flow within the data center."@en ;
  noria:structuralElementObservable <https://example.com/portStatus> .

<https://example.com/connectorNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "Connector node linking external and internal networks."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> .

<https://example.com/intermediaryNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservable <https://example.com/loadDistribution> .

<https://example.com/multiplexNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> .

<https://example.com/superNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Super node aggregating multiple hubs."@en ;
  noria:structuralElementObservable <https://example.com/aggregationLevel> .

<https://example.com/ResourceA>
  a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "Physical server hosting applications."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/Locus1_extra_node_0> ;
  noria:resourceHostName "serverA01" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/physical_extra_node_0> ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelX> .

<https://example.com/ResourceB>
  a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "Virtual machine instance."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceHostName "vmB02" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtual> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceInstallationDate "2023-03-10T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelY> .

<https://example.com/NetworkLink1_extra_node_0>
  a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Resource A and Resource B."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkInstallationDate "2022-02-20T12:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkTerminationResource <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/NetworkInterfaceA1>
  a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource A."@en ;
  noria:networkInterfaceType "physical_extra_node_0"@en ;
  noria:networkInterfaceDescription "Gigabit Ethernet port 0"@en ;
  noria:networkInterfaceOf <https://example.com/ResourceA> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1_extra_node_0> .

<https://example.com/NetworkInterfaceB1>
  a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary network interface of Resource B."@en ;
  noria:networkInterfaceType "virtual"@en ;
  noria:networkInterfaceDescription "VLAN interface 100"@en ;
  noria:networkInterfaceOf <https://example.com/ResourceB> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1_extra_node_0> .

<https://example.com/Event1>
  a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating the link has come up."@en ;
  noria:loggingTime "2024-03-15T14:22:00Z"^^xsd:dateTime ;
  noria:logText "NetworkLink1_extra_node_0 is now operational."@en ;
  noria:logOriginatingManagedObject <https://example.com/NetworkLink1_extra_node_0> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/NetworkAdmin_extra_node_0> ;
  noria:alarmSeverity <https://www.w3.org/ns/seas#Normal> .

<https://example.com/Event2>
  a noria:EventRecord ;
  rdfs:label "Resource A CPU High"@en ;
  rdfs:comment "High CPU utilization detected."@en ;
  noria:loggingTime "2024-03-15T15:00:00Z"^^xsd:dateTime ;
  noria:logText "CPU usage exceeded 90%."@en ;
  noria:logOriginatingManagedObject <https://example.com/ResourceA> ;
  noria:logOriginatingManagementSystem <https://example.com/MonitoringSystem> ;
  noria:logOriginatingAgent <https://example.com/MonitoringAgent> ;
  noria:alarmSeverity <https://www.w3.org/ns/seas#Critical> .

<https://example.com/AlarmEvent1>
  a noria:EventRecord ;
  rdfs:label "Security Breach Detected"@en ;
  rdfs:comment "Security alarm indicating potential breach."@en ;
  noria:loggingTime "2024-03-15T16:45:00Z"^^xsd:dateTime ;
  noria:logText "Multiple failed login attempts detected."@en ;
  noria:logOriginatingManagedObject <https://example.com/SecuritySystem> ;
  noria:logOriginatingManagementSystem <https://example.com/SecurityMonitoring> ;
  noria:logOriginatingAgent <https://example.com/SecurityAdmin> ;
  noria:alarmSeverity <https://www.w3.org/ns/seas#Critical> .

<https://example.com/ChangeRequest1>
  a noria:ChangeRequest ;
  rdfs:label "Update Firewall Rules"@en ;
  rdfs:comment "Change request to update firewall policies."@en ;
  noria:changeRequestId "CR-2024-001" ;
  noria:changeRequestCreationDateTime "2024-03-10T09:00:00Z"^^xsd:dateTime ;
  noria:changeRequestDescription "Implement new firewall rules to block malicious IPs."@en ;
  noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/Operational_extra_node_0> ;
  noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/Standard> ;
  noria:changeRequestImpact <https://example.com/ResourceA> ;
  noria:changeRequestOutageDuration "PT1H"^^xsd:duration ;
  noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Planned> ;
  noria:changeRequestInitiatorParty <https://example.com/NetworkEngineer> ;
  noria:changeRequestActorParty <https://example.com/FirewallTeam> .

<https://example.com/Document1>
  a noria:DocumentAttachment ;
  rdfs:label "Firewall Rules Config"@en ;
  rdfs:comment "Configuration file for firewall rules."@en ;
  noria:documentExternalId "DOC-2024-03-15-01" ;
  noria:documentHRef "http://docs.example.com/firewall_rules.conf"^^xsd:anyURI ;
  noria:documentStatusHistory <https://example.com/Event1> .

<https://example.com/ResourceImpact>
  a noria:Resource ;
  rdfs:label "Resource Impacted"@en ;
  rdfs:comment "Resource affected by the change."@en ;
  noria:resourceLogisticId "LOG12345" .

<https://example.com/ResourceImpact2>
  a noria:Resource ;
  rdfs:label "Secondary Resource"@en ;
  rdfs:comment "Another resource impacted."@en ;
  noria:resourceLogisticId "LOG67890" .

<https://example.com/Agent1>
  a foaf:Agent ;
  rdfs:label "Network Engineer"@en ;
  rdfs:comment "Engineer responsible for network changes."@en .

<https://example.com/Team1>
  a org:OrganizationalUnit ;
  rdfs:label "Firewall Support Team"@en ;
  rdfs:comment "Team responsible for firewall management."@en .

<https://example.com/NMS1>
  a noria:Application ;
  rdfs:label "Network Management System"@en ;
  rdfs:comment "System monitoring network events."@en .

<https://example.com/MonitoringSystem>
  a noria:Application ;
  rdfs:label "Monitoring System"@en ;
  rdfs:comment "System monitoring resource health."@en .

<https://example.com/SecuritySystem>
  a noria:Resource ;
  rdfs:label "Security System"@en ;
  rdfs:comment "System detecting security breaches."@en .

<https://example.com/SecurityMonitoring>
  a noria:Application ;
  rdfs:label "Security Monitoring"@en ;
  rdfs:comment "Application for security alerts."@en .

<https://example.com/SecurityAdmin>
  a foaf:Agent ;
  rdfs:label "Security Admin"@en ;
  rdfs:comment "Admin responsible for security."@en .

<https://example.com/FirewallTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Firewall Management Team"@en ;
  rdfs:comment "Team managing firewall policies."@en .

<https://example.com/NetworkAdmin_extra_node_0>
  a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Admin managing network infrastructure."@en .
