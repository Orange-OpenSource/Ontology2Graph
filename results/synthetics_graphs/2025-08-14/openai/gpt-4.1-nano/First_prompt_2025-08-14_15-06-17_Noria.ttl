@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity degree, acting as a critical network point."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:FunctionalElement ;
  rdfs:label "Central Application Server"@en ;
  rdfs:comment "A key application server acting as a central processing node."@en ;
  noria:functionalElementDistinguishedName "AppServer-Central-01" ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments or systems."@en ;
  noria:structuralElementObservableData <https://example.com/connectionLatency> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node serving as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that multiplexes multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/TelecomDept> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservableData <https://example.com/subNodeCount> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/ITSupportTeam> a org:Organization ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing application and system support."@en .

<https://example.com/NetworkSupport> a org:Organization ;
  rdfs:label "Network Support"@en ;
  rdfs:comment "Support team for network connectivity issues."@en .

<https://example.com/TelecomDept> a org:Organization ;
  rdfs:label "Telecom Department"@en ;
  rdfs:comment "Department managing telecom multiplexing nodes."@en .

<https://example.com/ResourceNode1> a noria:Resource ;
  rdfs:label "Resource Node 1"@en ;
  rdfs:comment "A physical resource node in the data center."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:resourceHostName "resnode1.datacenter.example.com" ;
  noria:resourceType <http://purl.org/ontology/bibo/Hardware> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ; skos:hasTopConcept <https://w3id.org/noria/kos/Resource/Operational> ] ;
  noria:locatedAtLocus <https://example.com/Room314> ;
  noria:resourceManagedBy <https://example.com/NetworkOperations> .

<https://example.com/Room314> a noria:Room ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Main server room on floor 3."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Optical Fiber Link A-B"@en ;
  rdfs:comment "High-speed optical fiber connection between Data Center A and B."@en ;
  noria:networkLinkId "NLINK-AB" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2021-06-01T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceNode1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceNode2> .

<https://example.com/ResourceNode2> a noria:Resource ;
  rdfs:label "Resource Node 2"@en ;
  rdfs:comment "Secondary resource node in the data center."@en ;
  noria:resourceLogisticId "RES-002" ;
  noria:resourceHostName "resnode2.datacenter.example.com" ;
  noria:resourceType <http://purl.org/ontology/bibo/Hardware> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceInstallationDate "2022-02-20T11:00:00Z"^^xsd:dateTime ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ; skos:hasTopConcept <https://w3id.org/noria/kos/Resource/Operational> ] ;
  noria:locatedAtLocus <https://example.com/Room315> ;
  noria:resourceManagedBy <https://example.com/NetworkOperations> .

<https://example.com/degreeMetric> a noria:Property ;
  rdfs:label "Network Degree"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/connectionLatency> a noria:Property ;
  rdfs:label "Connection Latency"@en ;
  rdfs:comment "Latency measurement between nodes."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/subNodeCount> a noria:Property ;
  rdfs:label "Sub-Node Count"@en ;
  rdfs:comment "Number of sub-nodes under a super node."@en .

<https://example.com/Resource> a rdfs:Class ;
  rdfs:label "Resource"@en ;
  rdfs:comment "A physical or virtual resource in the network."@en .

<https://example.com/NetworkLink> a rdfs:Class ;
  rdfs:label "Network Link"@en ;
  rdfs:comment "A link between network resources."@en .

<https://example.com/Room314> a noria:Room ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Main server room on floor 3."@en .

<https://example.com/NetworkManagement> a org:Organization ;
  rdfs:label "Network Management"@en .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations Team"@en .

<https://example.com/ITSupportTeam> a org:Organization ;
  rdfs:label "IT Support Team"@en .

<https://example.com/NetworkSupport> a org:Organization ;
  rdfs:label "Network Support"@en .

<https://example.com/TelecomDept> a org:Organization ;
  rdfs:label "Telecom Department"@en .

<https://example.com/ResourceNode1> a noria:Resource ;
  rdfs:label "Resource Node 1"@en .

<https://example.com/ResourceNode2> a noria:Resource ;
  rdfs:label "Resource Node 2"@en .

<https://example.com/ResourceNode2> a noria:Resource ;
  rdfs:label "Resource Node 2"@en .

<https://example.com/ResourceNode1> noria:elementManagedBy <https://example.com/NetworkOperations> .
<https://example.com/ResourceNode2> noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NetworkLink1> noria:resourceManagedBy <https://example.com/NetworkOperations> .

<https://example.com/ResourceNode1> noria:locatedAtLocus <https://example.com/Room314> .
<https://example.com/ResourceNode2> noria:locatedAtLocus <https://example.com/Room315> .

<https://example.com/ResourceNode1> noria:structuralElementObservableData <https://example.com/degreeMetric> .
<https://example.com/ResourceNode2> noria:structuralElementObservableData <https://example.com/connectionLatency> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity, acting as a critical point."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/CentralNode> a noria:FunctionalElement ;
  rdfs:label "Central Application Server"@en ;
  rdfs:comment "A key application server acting as a central processing node."@en ;
  noria:functionalElementDistinguishedName "AppServer-Central-01" ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionLatency> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Serves as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Multiplexes multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/TelecomDept> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple sub-nodes."@en ;
  noria:structuralElementObservableData <https://example.com/subNodeCount> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .