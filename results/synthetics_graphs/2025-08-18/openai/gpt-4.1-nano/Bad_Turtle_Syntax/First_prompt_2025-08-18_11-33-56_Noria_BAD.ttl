@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData "Degree: 15"^^xsd:integer ;
  noria:structuralElementDistinguishedName "Node-HD-01" .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the topology."@en ;
  noria:structuralElementObservableData "Centrality Score: 0.85"^^xsd:float ;
  noria:structuralElementDistinguishedName "Node-Center-01" .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservableData "Segment Connections: 3"^^xsd:integer ;
  noria:structuralElementDistinguishedName "Node-Connect-01" .

<https://example.com/intermediaryNode> a noria:FunctionalElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:functionalElementDistinguishedName "Intermediary-Node-01" .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservableData "Streams Managed: 4"^^xsd:integer ;
  noria:structuralElementDistinguishedName "Node-Mux-01" .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with super connectivity and role."@en ;
  noria:structuralElementObservableData "Connections: 20"^^xsd:integer ;
  noria:structuralElementDistinguishedName "Node-Super-01" .

<https://example.com/NetworkAdmin> a org:OrganizationalUnit ;
  rdfs:label "Network Administration Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Core router in data center."@en ;
  noria:resourceLogisticId "LOG-RES-001" ;
  noria:resourceHostName "router-core-01" ;
  noria:locatedAtLocus <https://example.com/Room314> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/operational> ;
  noria:resourceInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:agentManagesResource <https://example.com/NetworkAdmin> .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance router model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "TechManufacture Inc."@en ;
  rdfs:comment "Manufacturer of network devices."@en .

<https://example.com/Room314> a noria:Room ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Main server room in building."@en .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Interface Up Event"@en ;
  rdfs:comment "Event indicating interface went up."@en ;
  noria:loggingTime "2023-10-20T14:30:00Z"^^xsd:dateTime ;
  noria:logText "Interface ge-0/0/1 on Resource1 is now up."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Major> ;
  noria:alarmProposedRepairAction <https://example.com/Action1> .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en ;
  rdfs:comment "System monitoring network resources."@en .

<https://example.com/Action1> a pep:Procedure ;
  rdfs:label "Reset Interface"@en ;
  rdfs:comment "Procedure to reset network interface."@en .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub"@en ;
  rdfs:comment "Central hub node connecting multiple segments."@en .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "Switch with many connections."@en ;
  noria:structuralElementObservableData "Connections: 12"^^xsd:integer ;
  noria:structuralElementDistinguishedName "Switch-HD-01" .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "Main router in core network."@en ;
  noria:structuralElementObservableData "Traffic Load: 75%"^^xsd:string ;
  noria:structuralElementDistinguishedName "Router-Center-01" .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Switch"@en ;
  rdfs:comment "Switch connecting different network segments."@en ;
  noria:structuralElementObservableData "Segments Connected: 3"^^xsd:integer ;
  noria:structuralElementDistinguishedName "Switch-Connect-01" .

<https://example.com/IntermediaryNode> a noria:FunctionalElement ;
  rdfs:label "Intermediary Firewall"@en ;
  rdfs:comment "Firewall acting as intermediary in data flow."@en ;
  noria:functionalElementDistinguishedName "Firewall-Intermediary-01" .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservableData "Streams: 4"^^xsd:integer ;
  noria:structuralElementDistinguishedName "Mux-Node-01" .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with high connectivity and role."@en ;
  noria:structuralElementObservableData "Connections: 20"^^xsd:integer ;
  noria:structuralElementDistinguishedName "Super-Node-01" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Backup server in data center."@en ;
  noria:resourceLogisticId "LOG-RES-002" ;
  noria:resourceHostName "backup-server-01" ;
  noria:locatedAtLocus <https://example.com/Room314> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/server> ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/standby> ;
  noria:resourceInstallationDate "2021-03-10T09:00:00Z"^^xsd:dateTime ;
  noria:agentManagesResource <https://example.com/NetworkAdmin> .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Enterprise server model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "Edge router in branch office."@en ;
  noria:resourceLogisticId "LOG-RES-003" ;
  noria:resourceHostName "edge-router-01" ;
  noria:locatedAtLocus <https://example.com/Room314> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceSerialNumber "SN789012" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/operational> ;
  noria:resourceInstallationDate "2019-11-05T11:00:00Z"^^xsd:dateTime ;
  noria:agentManagesResource <https://example.com/NetworkAdmin> .

<https://example.com/IntermediaryNode2> a noria:FunctionalElement ;
  rdfs:label "Intermediary Load Balancer"@en ;
  rdfs:comment "Load balancer acting as intermediary."@en ;
  noria:functionalElementDistinguishedName "LoadBalancer-Intermediary-02" .

<https://example.com/MuxNode2> a noria:StructuralElement ;
  rdfs:label "Multiplexing Node 2"@en ;
  rdfs:comment "Node managing multiple data streams."@en ;
  noria:structuralElementObservableData "Streams: 6"^^xsd:integer ;
  noria:structuralElementDistinguishedName "Mux-Node-02" .

<https://example.com/SuperNode2> a noria:StructuralElement ;
  rdfs:label "Super Node 2"@en ;
  rdfs:comment "High connectivity node."@en ;
  noria:structuralElementObservableData "Connections: 25"^^xsd:integer ;
  noria:structuralElementDistinguishedName "Super-Node-02" .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Resource 4"@en ;
