@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralElementObservable <https://example.com/connectionCountObs> .

<https://example.com/connectionCountObs> a noria:StructuralObservable ;
  rdfs:label "Connection Count Observable"@en ;
  rdfs:comment "Observable property indicating the number of connections for a node."@en .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> .

<https://example.com/trafficVolume> a noria:StructuralObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Observable property representing the volume of traffic passing through a node."@en .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments, facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/latency> .

<https://example.com/latency> a noria:StructuralObservable ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Observable property indicating network latency at the connector node."@en .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data routing."@en ;
  noria:structuralElementObservable <https://example.com/errorRate> .

<https://example.com/errorRate> a noria:StructuralObservable ;
  rdfs:label "Error Rate"@en ;
  rdfs:comment "Observable property representing the error rate of data transmission."@en .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams or services."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/streamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of active data streams at the multiplex node."@en .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> .

<https://example.com/aggregateTraffic> a noria:StructuralObservable ;
  rdfs:label "Aggregate Traffic"@en ;
  rdfs:comment "Observable property indicating total traffic passing through the super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical network resource, such as a core router."@en ;
  noria:resourceLogisticId "LR-001" ;
  noria:resourceHostName "core-router-1" ;
  noria:locatedAtLocus <https://example.com/Room314> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual server hosting critical applications."@en ;
  noria:resourceLogisticId "LR-002" ;
  noria:resourceHostName "virtual-server-42" ;
  noria:locatedAtLocus <https://example.com/Room314> .

<https://example.com/Room314> a noria:Room ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Main server room housing core network equipment."@en .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating a network link has come up."@en ;
  noria:loggingTime "2024-03-15T10:15:00Z"^^xsd:dateTime ;
  noria:logText "Optical fiber link between Resource1 and Resource2 is now active."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS> ;
  noria:logOriginatingAgent <https://example.com/NetworkEngineer> ;
  noria:alarmSeverity <https://example.com/SeverityMajor> ;
  noria:alarmProposedRepairAction <https://example.com/RepairAction1> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A network switch connecting multiple segments."@en ;
  noria:resourceLogisticId "LR-003" ;
  noria:resourceHostName "switch-5" ;
  noria:locatedAtLocus <https://example.com/Room314> .

<https://example.com/NetworkEngineer> a foaf:Agent ;
  rdfs:label "Network Engineer"@en ;
  rdfs:comment "Responsible network engineer."@en .

<https://example.com/NMS> a noria:Application ;
  rdfs:label "Network Management System"@en ;
  rdfs:comment "System monitoring network health."@en .

<https://example.com/SeverityMajor> a skos:Concept ;
  rdfs:label "Major Severity"@en .

<https://example.com/RepairAction1> a pep:Procedure ;
  rdfs:label "Fiber Link Repair"@en ;
  rdfs:comment "Procedure to repair fiber link."@en .

<https://example.com/connectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at a node."@en .

<https://example.com/trafficVolume> a noria:StructuralObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of network traffic passing through a node."@en .

<https://example.com/latency> a noria:StructuralObservable ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency measurement."@en .

<https://example.com/errorRate> a noria:StructuralObservable ;
  rdfs:label "Error Rate"@en ;
  rdfs:comment "Packet error rate."@en .

<https://example.com/streamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams."@en .

<https://example.com/aggregateTraffic> a noria:StructuralObservable ;
  rdfs:label "Aggregate Traffic"@en ;
  rdfs:comment "Total traffic passing through super node."@en .