@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode_extra_node_4>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_4> .

<https://example.com/highDegreeNode_extra_node_21>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A high-degree network switch acting as a central connector."@en ;
  noria:structuralElementObservable <https://example.com/observable/trafficLoad> ;
  noria:structuralObservableOf <https://example.com/hubNode_extra_node_4> ;
  noria:elementManagedBy <https://example.com/NetworkOps_extra_node_2Team> .

<https://example.com/highDegreeNode_extra_node_22>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Router 2"@en ;
  rdfs:comment "A router with high connectivity serving as a central node."@en ;
  noria:structuralElementObservable <https://example.com/observable/latency> ;
  noria:structuralObservableOf <https://example.com/hubNode_extra_node_4> ;
  noria:elementManagedBy <https://example.com/NetworkOps_extra_node_2Team> .

<https://example.com/centralNode_extra_node_2>
  a noria:StructuralElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A critical server acting as a central node in the network."@en ;
  noria:structuralElementObservable <https://example.com/observable/serverLoad> ;
  noria:structuralObservableOf <https://example.com/hubNode_extra_node_4> ;
  noria:elementManagedBy <https://example.com/ITDept> .

<https://example.com/connectorNode_extra_node_2>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/connectionStatus> ;
  noria:structuralObservableOf <https://example.com/centralNode_extra_node_2> ;
  noria:elementManagedBy <https://example.com/NetworkOps_extra_node_2Team> .

<https://example.com/intermediaryNode_extra_node_2>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservable <https://example.com/observable/dataFlow> ;
  noria:structuralObservableOf <https://example.com/connectorNode_extra_node_2> ;
  noria:elementManagedBy <https://example.com/ITDept> .

<https://example.com/multiplexNode_extra_node_2>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/streamQuality> ;
  noria:structuralObservableOf <https://example.com/intermediaryNode_extra_node_2> ;
  noria:elementManagedBy <https://example.com/NetworkOps_extra_node_2Team> .

<https://example.com/superNode_extra_node_2>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level analysis."@en ;
  noria:structuralElementObservable <https://example.com/observable/overallHealth> ;
  noria:structuralObservableOf <https://example.com/multiplexNode_extra_node_2> ;
  noria:elementManagedBy <https://example.com/ManagementTeam> .

<https://example.com/NetworkOperations_extra_node_4>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "The organization responsible for network management."@en .

<https://example.com/NetworkOps_extra_node_2Team>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team managing high-degree nodes and network infrastructure."@en ;
  org:member <https://example.com/NetworkOperations_extra_node_4> .

<https://example.com/ITDept>
  a org:OrganizationalUnit ;
  rdfs:label "IT Department"@en ;
  rdfs:comment "Department responsible for central server and intermediary nodes."@en .

<https://example.com/ManagementTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Management Team"@en ;
  rdfs:comment "Team overseeing super nodes and overall network health."@en .

<https://example.com/observable/trafficLoad>
  a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Measurement of network traffic load."@en .

<https://example.com/observable/latency>
  a noria:StructuralObservable ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Measurement of network latency."@en .

<https://example.com/observable/serverLoad>
  a noria:StructuralObservable ;
  rdfs:label "Server Load"@en ;
  rdfs:comment "Current load on the central server."@en .

<https://example.com/observable/connectionStatus>
  a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection between nodes."@en .

<https://example.com/observable/dataFlow>
  a noria:StructuralObservable ;
  rdfs:label "Data Flow"@en ;
  rdfs:comment "Flow of data through intermediary nodes."@en .

<https://example.com/observable/streamQuality>
  a noria:StructuralObservable ;
  rdfs:label "Stream Quality"@en ;
  rdfs:comment "Quality metrics of multiplexed data streams."@en .

<https://example.com/observable/overallHealth>
  a noria:StructuralObservable ;
  rdfs:label "Overall Network Health"@en ;
  rdfs:comment "High-level health status of the entire network."@en .