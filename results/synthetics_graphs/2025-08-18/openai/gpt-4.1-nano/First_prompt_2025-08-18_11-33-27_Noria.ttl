<https://example.com/hubNode_extra_node_71> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps_extra_node_3Team> .

<https://example.com/HighDegreeNode_extra_node_4> a noria:StructuralElement ;
  rdfs:label "Main Data Center Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central switch in the data center."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Resource1_extra_node_3> .

<https://example.com/CentralNode_extra_node_4> a noria:StructuralElement ;
  rdfs:label "Central Firewall"@en ;
  rdfs:comment "A node with high centrality, managing security policies across the network."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Resource2_extra_node_3> .

<https://example.com/ConnectorNode_extra_node_4> a noria:StructuralElement ;
  rdfs:label "Connector Switch"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Resource3_extra_node_3> .

<https://example.com/IntermediaryNode_extra_node_4> a noria:StructuralElement ;
  rdfs:label "Intermediary Router"@en ;
  rdfs:comment "An intermediary node facilitating traffic between hubs."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Resource4> .

<https://example.com/MultiplexNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Resource5> .

<https://example.com/SuperNode_extra_node_4> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Resource6> .

<https://example.com/Resource1_extra_node_3> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A server in the main data center."@en ;
  noria:resourceLogisticId "RES-DC1-001" ;
  noria:locatedAtLocus <https://example.com/Locus1_extra_node_2> .

<https://example.com/Resource2_extra_node_3> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A security appliance managing network security."@en ;
  noria:resourceLogisticId "RES-SEC-002" ;
  noria:locatedAtLocus <https://example.com/Locus2_extra_node_2> .

<https://example.com/Resource3_extra_node_3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A core switch connecting multiple segments."@en ;
  noria:resourceLogisticId "RES-SW3" ;
  noria:locatedAtLocus <https://example.com/Locus3_extra_node_2> .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Resource 4"@en ;
  rdfs:comment "An intermediary router for traffic forwarding."@en ;
  noria:resourceLogisticId "RES-INT4" ;
  noria:locatedAtLocus <https://example.com/Locus4> .

<https://example.com/Resource5> a noria:Resource ;
  rdfs:label "Resource 5"@en ;
  rdfs:comment "A multiplexing switch handling multiple data streams."@en ;
  noria:resourceLogisticId "RES-MUX5" ;
  noria:locatedAtLocus <https://example.com/Locus5> .

<https://example.com/Resource6> a noria:Resource ;
  rdfs:label "Resource 6"@en ;
  rdfs:comment "A super node aggregating multiple network resources."@en ;
  noria:resourceLogisticId "RES-SUP6" ;
  noria:locatedAtLocus <https://example.com/Locus6> .

