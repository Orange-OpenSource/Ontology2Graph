@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode_extra_node_11> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_1Team> .

<https://example.com/HighDegreeNode_extra_node_12> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch in the core network."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableSwitchStatus> ;
  noria:structuralObservableOf <https://example.com/structuralObservableTrafficLoad> .

<https://example.com/CentralNode_extra_node_13> a noria:FunctionalElement ;
  rdfs:label "Central Application Server"@en ;
  rdfs:comment "A central node hosting core applications, connecting to multiple resources."@en ;
  noria:elementManagedBy <https://example.com/ITSupportTeam_extra_node_1> .

<https://example.com/ConnectorNode_extra_node_14> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking internal and external network segments."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableFirewallStatus> .

<https://example.com/IntermediaryNode_extra_node_15> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam_extra_node_1> .

<https://example.com/MultiplexNode_extra_node_16> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableStreamLoad> .

<https://example.com/SuperNode_extra_node_17> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes for high-level management."@en ;
  noria:elementManagedBy <https://example.com/ManagementCenter> .

<https://example.com/Network1> a noria:Resource ;
  rdfs:label "Main Data Center Network"@en ;
  rdfs:comment "The primary network infrastructure connecting core nodes."@en ;
  noria:resourceLogisticId "DCN-001" .

<https://example.com/Resource2_extra_node_0> a noria:Resource ;
  rdfs:label "Edge Router"@en ;
  rdfs:comment "An edge router connecting local network to the core."@en ;
  noria:resourceLogisticId "ER-002" .

<https://example.com/Resource3_extra_node_0> a noria:Resource ;
  rdfs:label "Application Server"@en ;
  rdfs:comment "A server hosting critical applications."@en ;
  noria:resourceLogisticId "AS-003" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A"@en ;
  rdfs:comment "Optical fiber link connecting HubNode_extra_node_11 to Main Data Center Network."@en ;
  noria:networkLinkId "FL-1001" ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Ethernet Link B"@en ;
  rdfs:comment "Ethernet connection between Main Switch and Application Server."@en ;
  noria:networkLinkId "EL-2002" ;
  noria:networkLinkType "Ethernet" .

<https://example.com/structuralObservableSwitchStatus> a noria:StructuralObservable ;
  rdfs:label "Switch Status"@en ;
  rdfs:comment "Operational status of the main switch."@en .

<https://example.com/structuralObservableTrafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load on the switch."@en .

<https://example.com/structuralObservableFirewallStatus> a noria:StructuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Operational status of the firewall connector."@en .

<https://example.com/structuralObservableStreamLoad> a noria:StructuralObservable ;
  rdfs:label "Stream Load"@en ;
  rdfs:comment "Data stream load on the multiplex node."@en .

<https://example.com/NetworkOperations_extra_node_1Team> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSupportTeam_extra_node_1> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team managing application and server infrastructure."@en .

<https://example.com/ManagementCenter> a org:OrganizationalUnit ;
  rdfs:label "Management Center"@en ;
  rdfs:comment "High-level management node overseeing super nodes."@en .

<https://example.com/Resource> a noria:Resource ;
  rdfs:label "Generic Resource"@en ;
  rdfs:comment "A generic network resource."@en .

<https://example.com/HubNode_extra_node_11> noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_1Team> .
<https://example.com/HighDegreeNode_extra_node_12> noria:structuralElementObservableOf <https://example.com/structuralObservableSwitchStatus> , <https://example.com/structuralObservableTrafficLoad> .
<https://example.com/CentralNode_extra_node_13> noria:elementManagedBy <https://example.com/ITSupportTeam_extra_node_1> .
<https://example.com/ConnectorNode_extra_node_14> noria:structuralElementObservableOf <https://example.com/structuralObservableFirewallStatus> .
<https://example.com/IntermediaryNode_extra_node_15> noria:elementManagedBy <https://example.com/NetworkTeam_extra_node_1> .
<https://example.com/MultiplexNode_extra_node_16> noria:structuralElementObservableOf <https://example.com/structuralObservableStreamLoad> .
<https://example.com/SuperNode_extra_node_17> noria:elementManagedBy <https://example.com/ManagementCenter> .

<https://example.com/HubNode_extra_node_11> noria:connected_to <https://example.com/Network1> .
<https://example.com/HighDegreeNode_extra_node_12> noria:connected_to <https://example.com/Network1> .
<https://example.com/CentralNode_extra_node_13> noria:connected_to <https://example.com/Resource3_extra_node_0> .
<https://example.com/ConnectorNode_extra_node_14> noria:connected_to <https://example.com/Network1> .
<https://example.com/IntermediaryNode_extra_node_15> noria:connected_to <https://example.com/Resource3_extra_node_0> .
<https://example.com/MultiplexNode_extra_node_16> noria:connected_to <https://example.com/Resource2_extra_node_0> .
<https://example.com/SuperNode_extra_node_17> noria:connected_to <https://example.com/Network1> .

