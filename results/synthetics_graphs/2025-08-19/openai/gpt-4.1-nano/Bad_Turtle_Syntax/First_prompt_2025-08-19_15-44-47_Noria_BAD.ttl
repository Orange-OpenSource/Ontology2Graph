@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/HubNode> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within a subnetwork."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/HighDegreeNode> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/segmentCount> ;
  noria:structuralObservableOf <https://example.com/centralNode> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:structuralObservableOf <https://example.com/connectorNode> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/intermediaryNode> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservableData <https://example.com/aggregateTraffic> ;
  noria:structuralObservableOf <https://example.com/MultiplexNode> .

<https://example.com/NetworkAdmin> a org:OrganizationalUnit ;
  rdfs:label "Network Administration Team"@en ;
  rdfs:comment "The team responsible for network management."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of connections for the node."@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of traffic passing through the node."@en .

<https://example.com/segmentCount> a noria:Property ;
  rdfs:label "Segment Count"@en ;
  rdfs:comment "Number of network segments connected."@en .

<https://example.com/dataFlowRate> a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through the node."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/aggregateTraffic> a noria:Property ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Total traffic aggregated at super node."@en .

# Relations linking nodes
<https://example.com/HubNode> noria:connectedTo <https://example.com/HighDegreeNode> ;
<https://example.com/HighDegreeNode> noria:connectedTo <https://example.com/CentralNode> ;
<https://example.com/CentralNode> noria:connectedTo <https://example.com/ConnectorNode> ;
<https://example.com/ConnectorNode> noria:connectedTo <https://example.com/IntermediaryNode> ;
<https://example.com/IntermediaryNode> noria:connectedTo <https://example.com/MultiplexNode> ;
<https://example.com/MultiplexNode> noria:connectedTo <https://example.com/SuperNode> .

# Link nodes to the network admin
<https://example.com/HubNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/HighDegreeNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/CentralNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/ConnectorNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/IntermediaryNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/MultiplexNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/SuperNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .