@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/highDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a connector in the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node that is central in the network topology, connecting multiple subnets."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node that connects different network segments or systems."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow between other nodes."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiple types of connections or functions."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node that aggregates multiple nodes, acting as a super hub."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA>
  a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A virtual server hosting critical applications."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceB>
  a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A physical network switch."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceC>
  a noria:Resource ;
  rdfs:label "Resource C"@en ;
  rdfs:comment "A virtual machine connected to Resource A."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Locus1>
  a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "Line: L, in Room:Server room 314" ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Locus2>
  a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Secondary network closet."@en ;
  noria:locusLine "Line: R, in Room:Data Center 2" ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/NetworkLink1>
  a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Resource B and Resource C."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/NetworkLink2>
  a noria:NetworkLink ;
  rdfs:label "Ethernet Link 2"@en ;
  rdfs:comment "Ethernet connection between Resource A and Resource B."@en ;
  noria:networkLinkId "NLINK002" ;
  noria:networkLinkType "Ethernet" ;
  noria:networkLinkInstallationDate "2021-06-10T09:30:00"^^xsd:dateTime ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_NetworkInterface1>
  a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource A."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "VLAN 10" ;
  noria:networkInterfaceOf <https://example.com/ResourceA> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceB_NetworkInterface1>
  a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Management interface of Resource B."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "GigabitEthernet0/1" ;
  noria:networkInterfaceOf <https://example.com/ResourceB> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceC_NetworkInterface1>
  a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Virtual network interface of Resource C."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "VLAN 20" ;
  noria:networkInterfaceOf <https://example.com/ResourceC> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_NetworkLinkConnects>
  a noria:NetworkLink ;
  rdfs:label "Link between Resource A and B"@en ;
  rdfs:comment "Connection via Ethernet between Resource A and Resource B."@en ;
  rdfs:seeAlso <https://w3id.org/noria/NetworkLink2> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceB_NetworkLinkConnects>
  a noria:NetworkLink ;
  rdfs:label "Link between Resource B and C"@en ;
  rdfs:comment "Optical fiber connection between Resource B and Resource C."@en ;
  rdfs:seeAlso <https://w3id.org/noria/NetworkLink1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_ConnectedTo>
  a noria:Resource ;
  rdfs:label "Resource A connected to Resource B"@en ;
  rdfs:comment "Resource A is connected to Resource B via Ethernet."@en ;
  rdfs:seeAlso <https://example.com/ResourceA_NetworkLink1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceB_ConnectedTo>
  a noria:Resource ;
  rdfs:label "Resource B connected to Resource C"@en ;
  rdfs:comment "Resource B is connected to Resource C via fiber."@en ;
  rdfs:seeAlso <https://example.com/ResourceB_NetworkLinkConnects> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_ConnectedTo2>
  a noria:Resource ;
  rdfs:label "Resource A to Resource C"@en ;
  rdfs:comment "Indirect connection between Resource A and Resource C."@en ;
  rdfs:seeAlso <https://example.com/ResourceA_NetworkLink1> ;
  rdfs:seeAlso <https://example.com/ResourceC_NetworkInterface1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceB_ConnectedTo2>
  a noria:Resource ;
  rdfs:label "Resource B to Resource C"@en ;
  rdfs:comment "Resource B connected to Resource C via fiber."@en ;
  rdfs:seeAlso <https://example.com/ResourceB_NetworkLinkConnects> ;
  rdfs:seeAlso <https://example.com/ResourceC_NetworkInterface1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_ConnectedTo3>
  a noria:Resource ;
  rdfs:label "Resource A to Resource C (via virtual interface)"@en ;
  rdfs:comment "Virtual connection between Resource A and Resource C."@en ;
  rdfs:seeAlso <https://example.com/ResourceA_NetworkInterface1> ;
  rdfs:seeAlso <https://example.com/ResourceC_NetworkInterface1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_ConnectedTo4>
  a noria:Resource ;
  rdfs:label "Resource A to Resource B (via virtual interface)"@en ;
  rdfs:comment "Virtual connection between Resource A and Resource B."@en ;
  rdfs:seeAlso <https://example.com/ResourceA_NetworkInterface1> ;
  rdfs:seeAlso <https://example.com/ResourceB_NetworkInterface1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_ConnectedTo5>
  a noria:Resource ;
  rdfs:label "Resource A to Resource C (via virtual interface)"@en ;
  rdfs:comment "Another virtual link between Resource A and Resource C."@en ;
