@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode1>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node 1"@en ;
  rdfs:comment "A node with high connectivity, acting as a central connector."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:structuralObservableOf <https://example.com/HubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode2>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node 2"@en ;
  rdfs:comment "Another high-degree node serving as a connector."@en ;
  noria:structuralElementObservable <https://example.com/throughputObservable> ;
  noria:structuralObservableOf <https://example.com/HubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high betweenness centrality, acting as a core connector."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:structuralObservableOf <https://example.com/HubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a bridge between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatusObservable> ;
  noria:structuralObservableOf <https://example.com/centralNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservable <https://example.com/trafficObservable> ;
  noria:structuralObservableOf <https://example.com/connectorNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamQualityObservable> ;
  noria:structuralObservableOf <https://example.com/intermediaryNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level analysis."@en ;
  noria:structuralElementObservable <https://example.com/overallPerformanceObservable> ;
  noria:structuralObservableOf <https://example.com/multiplexNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NetworkOperations>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network nodes and links."@en .

<https://example.com/latencyObservable>
  a noria:StructuralObservable ;
  rdfs:label "Latency Observable"@en ;
  rdfs:comment "Observable measuring network latency."@en .

<https://example.com/throughputObservable>
  a noria:StructuralObservable ;
  rdfs:label "Throughput Observable"@en ;
  rdfs:comment "Observable measuring network throughput."@en .

<https://example.com/connectionStatusObservable>
  a noria:StructuralObservable ;
  rdfs:label "Connection Status Observable"@en ;
  rdfs:comment "Observable indicating connection status."@en .

<https://example.com/trafficObservable>
  a noria:StructuralObservable ;
  rdfs:label "Traffic Observable"@en ;
  rdfs:comment "Observable monitoring traffic flow."@en .

<https://example.com/streamQualityObservable>
  a noria:StructuralObservable ;
  rdfs:label "Stream Quality Observable"@en ;
  rdfs:comment "Observable assessing quality of data streams."@en .

<https://example.com/overallPerformanceObservable>
  a noria:StructuralObservable ;
  rdfs:label "Overall Performance Observable"@en ;
  rdfs:comment "High-level observable aggregating overall network performance."@en .
