@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A switch with high connectivity degree, acting as a network backbone."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:FunctionalElement ;
  rdfs:label "Central Application Server"@en ;
  rdfs:comment "A core server hosting critical applications."@en ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A firewall node acting as a connector between internal and external networks."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplexing node combining multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/dataThroughput> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An advanced super node aggregating multiple network functions."@en ;
  noria:structuralElementObservable <https://example.com/systemHealth> ;
  noria:elementManagedBy <https://example.com/ITManagement> .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Network Hub"@en ;
  rdfs:comment "A central hub connecting various network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Core Switch"@en ;
  rdfs:comment "A switch with high connectivity, forming the network backbone."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/CentralNode> a noria:FunctionalElement ;
  rdfs:label "Main Application Server"@en ;
  rdfs:comment "The primary server hosting critical applications."@en ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Gateway"@en ;
  rdfs:comment "Firewall node acting as a connector between internal and external networks."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Distributes incoming traffic to backend servers."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Data Multiplexer"@en ;
  rdfs:comment "Combines multiple data streams into one."@en ;
  noria:structuralElementObservable <https://example.com/dataThroughput> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An advanced node aggregating multiple network functions."@en ;
  noria:structuralElementObservable <https://example.com/systemHealth> ;
  noria:elementManagedBy <https://example.com/ITManagement> .

<https://example.com/HubNodeEntity> a noria:ManagedElement ;
  rdfs:label "Network Hub Entity"@en ;
  rdfs:comment "A hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeEntity> a noria:StructuralElement ;
  rdfs:label "Core Switch Entity"@en ;
  rdfs:comment "A high-degree switch forming the backbone."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/CentralEntity> a noria:FunctionalElement ;
  rdfs:label "Main Application Server Entity"@en ;
  rdfs:comment "Core server hosting critical apps."@en ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/ConnectorEntity> a noria:StructuralElement ;
  rdfs:label "Firewall Gateway Entity"@en ;
  rdfs:comment "Firewall node connecting internal and external networks."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryEntity> a noria:StructuralElement ;
  rdfs:label "Load Balancer Entity"@en ;
  rdfs:comment "Distributes traffic among servers."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/MuxEntity> a noria:StructuralElement ;
  rdfs:label "Data Multiplexer Entity"@en ;
  rdfs:comment "Combines multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/dataThroughput> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/SuperEntity> a noria:StructuralElement ;
  rdfs:label "Super Node Entity"@en ;
  rdfs:comment "Aggregates multiple network functions."@en ;
  noria:structuralElementObservable <https://example.com/systemHealth> ;
  noria:elementManagedBy <https://example.com/ITManagement> .

<https://example.com/HubNodeConnector> a noria:ManagedElement ;
  rdfs:label "Network Hub Connector"@en ;
  rdfs:comment "Connects network segments at the hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeConnector> a noria:StructuralElement ;
  rdfs:label "Core Switch Connector"@en ;
  rdfs:comment "High-degree switch acting as backbone connector."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/CentralConnector> a noria:FunctionalElement ;
  rdfs:label "Main Application Connector"@en ;
  rdfs:comment "Connector for core application server."@en ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/IntermediaryConnector> a noria:StructuralElement ;
  rdfs:label "Load Balancer Connector"@en ;
  rdfs:comment "Distributes traffic to backend servers."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/MuxConnector> a noria:StructuralElement ;
  rdfs:label "Data Multiplexer Connector"@en ;
  rdfs:comment "Combines data streams at the network level."@en ;
  noria:structuralElementObservable <https://example.com/dataThroughput> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/SuperConnector> a noria:StructuralElement ;
  rdfs:label "Super Node Connector"@en ;
  rdfs:comment "Aggregates multiple network functions."@en ;
  noria:structuralElementObservable <https://example.com/systemHealth> ;
  noria:elementManagedBy <https://example.com/ITManagement> .