<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management and operations."@en .

<https://example.com/NetworkAdminTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Administration Team"@en ;
  rdfs:comment "Team handling network configuration and maintenance."@en .

<https://example.com/NetworkSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team providing support for network issues."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for IT support and troubleshooting."@en .

<https://example.com/degreeMetric> a noria:Property ;
  rdfs:label "Degree Metric"@en ;
  rdfs:comment "A measure of the number of connections for a node."@en .

<https://example.com/latencyObservable> a noria:StructuralObservable ;
  rdfs:label "Latency Observable"@en ;
  rdfs:comment "Measurement of network latency at the node."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Current status of the node's connection."@en .

<https://example.com/dataFlowRate> a noria:StructuralObservable ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through the node."@en .

<https://example.com/streamQuality> a noria:StructuralObservable ;
  rdfs:label "Stream Quality"@en ;
  rdfs:comment "Quality metrics of multiplexed streams."@en .

<https://example.com/aggregateTraffic> a noria:StructuralObservable ;
  rdfs:label "Aggregate Traffic"@en ;
  rdfs:comment "Total traffic passing through the super node."@en .

<https://example.com/NetworkLeadership> a org:OrganizationalUnit ;
  rdfs:label "Network Leadership"@en ;
  rdfs:comment "Leadership team overseeing network architecture."@en .

<https://example.com/NetworkEngineering> a org:OrganizationalUnit ;
  rdfs:label "Network Engineering"@en ;
  rdfs:comment "Team responsible for network design and engineering."@en .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node connecting multiple high-degree nodes in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode1>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A switch with high connectivity serving as a connector in the network."@en ;
  noria:structuralElementObservable <https://example.com/observable/HighDegreeNode1Status> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode2>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Router 2"@en ;
  rdfs:comment "A router with high connectivity acting as a central node."@en ;
  noria:structuralElementObservable <https://example.com/observable/HighDegreeNode2Status> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A server acting as a central node with high degree of connections."@en ;
  noria:structuralElementObservable <https://example.com/observable/CentralServerStatus> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Switch"@en ;
  rdfs:comment "A switch connecting different network segments, acting as a connector node."@en ;
  noria:structuralElementObservable <https://example.com/observable/ConnectorSwitchStatus> ;
  noria:elementManagedBy <https://example.com/NetworkSupportTeam> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediate Router"@en ;
  rdfs:comment "An intermediary router facilitating traffic between high-degree nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable/IntermediaryRouterStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "A device multiplexing multiple data streams, acting as a multiplex node."@en ;
  noria:structuralElementObservable <https://example.com/observable/MultiplexDeviceStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level analysis."@en ;
  noria:structuralElementObservable <https://example.com/observable/SuperNodeStatus> ;
  noria:elementManagedBy <https://example.com/NetworkManagementTeam> .

<https://example.com/NetworkOperationsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/ITSupportTeam>
  a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing support for central servers."@en .

<https://example.com/NetworkSupportTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team supporting network devices and switches."@en .

<https://example.com/observable/HighDegreeNode1Status>
  a noria:StructuralObservable ;
  rdfs:label "High Degree Node 1 Status"@en ;
  rdfs:comment "Operational status of High-Degree Switch 1."@en .

<https://example.com/observable/HighDegreeNode2Status>
  a noria:StructuralObservable ;
  rdfs:label "High Degree Node 2 Status"@en ;
  rdfs:comment "Operational status of High-Degree Router 2."@en .

<https://example.com/observable/CentralServerStatus>
  a noria:StructuralObservable ;
  rdfs:label "Central Server Status"@en ;
  rdfs:comment "Operational status of the Central Server."@en .

<https://example.com/observable/ConnectorSwitchStatus>
  a noria:StructuralObservable ;
  rdfs:label "Connector Switch Status"@en ;
  rdfs:comment "Operational status of the Connector Switch."@en .

<https://example.com/observable/IntermediaryRouterStatus>
  a noria:StructuralObservable ;
  rdfs:label "Intermediary Router Status"@en ;
  rdfs:comment "Operational status of the Intermediary Router."@en .

<https://example.com/observable/MultiplexDeviceStatus>
  a noria:StructuralObservable ;
  rdfs:label "Multiplex Device Status"@en ;
  rdfs:comment "Operational status of the Multiplexing Device."@en .

<https://example.com/observable/SuperNodeStatus>
  a noria:StructuralObservable ;
  rdfs:label "Super Node Status"@en ;
  rdfs:comment "Operational status of the Super Node."@en .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with a high number of connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:structuralElementObservable <https://example.com/degreeObservable> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/centralObservable> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectorData> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node serving as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/intermediaryObservable> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/multiplexData> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node that aggregates multiple nodes or functions as a super hub."@en ;
  noria:structuralElementObservable <https://example.com/superObservable> .

<https://example.com/NetworkAdmin> a org:Organization ;
  rdfs:label "Network Administration Team"@en ;
  rdfs:comment "Team responsible for managing network elements."@en .

<https://example.com/degreeMetric> a noria:structuralElementObservableData ;
  rdfs:label "Degree Metric"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/degreeObservable> a noria:StructuralObservable ;
  rdfs:label "Degree Observable"@en ;
  rdfs:comment "Observable representing node degree."@en .

<https://example.com/centralObservable> a noria:StructuralObservable ;
  rdfs:label "Centrality Observable"@en ;
  rdfs:comment "Observable indicating centrality measure."@en .

<https://example.com/connectorData> a noria:structuralElementObservableData ;
  rdfs:label "Connector Data"@en ;
  rdfs:comment "Data related to connector nodes."@en .

<https://example.com/intermediaryObservable> a noria:StructuralObservable ;
  rdfs:label "Intermediary Observable"@en ;
  rdfs:comment "Observable for intermediary nodes."@en .

<https://example.com/multiplexData> a noria:structuralElementObservableData ;
  rdfs:label "Multiplex Data"@en ;
  rdfs:comment "Data for multiplex nodes."@en .

<https://example.com/superObservable> a noria:StructuralObservable ;
  rdfs:label "Super Node Observable"@en ;
  rdfs:comment "Observable for super nodes."@en .

