# Additional relations linking nodes
<https://example.com/hubNode> noria:structuralElementObservable <https://example.com/ResourceA> .
<https://example.com/hubNode> noria:structuralElementObservable <https://example.com/ResourceB> .
<https://example.com/hubNode> noria:structuralElementObservable <https://example.com/ResourceC> .

<https://example.com/highDegreeNode> noria:structuralElementObservable <https://example.com/ResourceA> .
<https://example.com/highDegreeNode> noria:structuralElementObservable <https://example.com/ResourceB> .

<https://example.com/centralNode> noria:structuralElementObservable <https://example.com/ResourceA> .
<https://example.com/centralNode> noria:structuralElementObservable <https://example.com/ResourceC> .

<https://example.com/connectorNode> noria:structuralElementObservable <https://example.com/ResourceB> .

<https://example.com/intermediaryNode> noria:structuralElementObservable <https://example.com/ResourceA> .

<https://example.com/multiplexNode> noria:structuralElementObservable <https://example.com/ResourceA> .
<https://example.com/multiplexNode> noria:structuralElementObservable <https://example.com/ResourceB> .

<https://example.com/superNode> noria:structuralElementObservable <https://example.com/ResourceA> .
<https://example.com/superNode> noria:structuralElementObservable <https://example.com/ResourceB> .
<https://example.com/superNode> noria:structuralElementObservable <https://example.com/ResourceC> .

# Link nodes to the hub node
<https://example.com/hubNode> noria:structuralElementObservable <https://example.com/ResourceA> .
<https://example.com/hubNode> noria:structuralElementObservable <https://example.com/ResourceB> .
<https://example.com/hubNode> noria:structuralElementObservable <https://example.com/ResourceC> .

# Link nodes to high-degree node
<https://example.com/highDegreeNode> noria:structuralElementObservable <https://example.com/ResourceA> .
<https://example.com/highDegreeNode> noria:structuralElementObservable <https://example.com/ResourceB> .

# Link nodes to central node
<https://example.com/centralNode> noria:structuralElementObservable <https://example.com/ResourceA> .
<https://example.com/centralNode> noria:structuralElementObservable <https://example.com/ResourceC> .

# Link nodes to connector node
<https://example.com/connectorNode> noria:structuralElementObservable <https://example.com/ResourceB> .

# Link nodes to intermediary node
<https://example.com/intermediaryNode> noria:structuralElementObservable <https://example.com/ResourceA> .

# Link nodes to multiplex node
<https://example.com/multiplexNode> noria:structuralElementObservable <https://example.com/ResourceA> .
<https://example.com/multiplexNode> noria:structuralElementObservable <https://example.com/ResourceB> .

# Link nodes to super node
<https://example.com/superNode> noria:structuralElementObservable <https://example.com/ResourceA> .
<https://example.com/superNode> noria:structuralElementObservable <https://example.com/ResourceB> .
<https://example.com/superNode> noria:structuralElementObservable <https://example.com/ResourceC> .

# Link nodes to each other to ensure no isolated nodes
<https://example.com/ResourceA> noria:elementProperty <https://example.com/ResourceB> .
<https://example.com/ResourceA> noria:elementProperty <https://example.com/ResourceC> .
<https://example.com/ResourceB> noria:elementProperty <https://example.com/ResourceC> .

# End of graph

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:structuralObservableOf <https://example.com/Router1> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:structuralObservableOf <https://example.com/ServerA> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node serving as a connector between different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that intermediates data flow between other nodes."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:structuralObservableOf <https://example.com/LoadBalancer1> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that multiplexes multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/Multiplexer1> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservableData <https://example.com/subNodeCount> ;
  noria:structuralObservableOf <https://example.com/SuperSwitch> .

