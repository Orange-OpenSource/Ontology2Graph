@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode_extra_node_0>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode_extra_node_01>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node 1"@en ;
  rdfs:comment "A node with high connectivity, acting as a central connector."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:structuralObservableOf <https://example.com/HubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode_extra_node_02>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node 2"@en ;
  rdfs:comment "Another high-degree node serving as a connector."@en ;
  noria:structuralElementObservable <https://example.com/throughputObservable> ;
  noria:structuralObservableOf <https://example.com/HubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high betweenness centrality, acting as a core connector."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:structuralObservableOf <https://example.com/HubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a bridge between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatusObservable> ;
  noria:structuralObservableOf <https://example.com/centralNode_extra_node_0> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/intermediaryNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservable <https://example.com/trafficObservable> ;
  noria:structuralObservableOf <https://example.com/connectorNode_extra_node_0> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamQualityObservable> ;
  noria:structuralObservableOf <https://example.com/intermediaryNode_extra_node_0> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level analysis."@en ;
  noria:structuralElementObservable <https://example.com/overallPerformanceObservable> ;
  noria:structuralObservableOf <https://example.com/multiplexNode_extra_node_0> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NetworkOperations>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network nodes and links."@en .

<https://example.com/latencyObservable>
  a noria:StructuralObservable ;
  rdfs:label "Latency Observable"@en ;
  rdfs:comment "Observable measuring network latency."@en .

<https://example.com/throughputObservable>
  a noria:StructuralObservable ;
  rdfs:label "Throughput Observable"@en ;
  rdfs:comment "Observable measuring network throughput."@en .

<https://example.com/connectionStatusObservable>
  a noria:StructuralObservable ;
  rdfs:label "Connection Status Observable"@en ;
  rdfs:comment "Observable indicating connection status."@en .

<https://example.com/trafficObservable>
  a noria:StructuralObservable ;
  rdfs:label "Traffic Observable"@en ;
  rdfs:comment "Observable monitoring traffic flow."@en .

<https://example.com/streamQualityObservable>
  a noria:StructuralObservable ;
  rdfs:label "Stream Quality Observable"@en ;
  rdfs:comment "Observable assessing quality of data streams."@en .

<https://example.com/overallPerformanceObservable>
  a noria:StructuralObservable ;
  rdfs:label "Overall Performance Observable"@en ;
  rdfs:comment "High-level observable aggregating overall network performance."@en .


<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within a subnetwork, connecting multiple segments."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments, acting as a bridge."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow, often involved in routing."@en ;
  noria:structuralElementObservableData <https://example.com/routingMetrics> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that handles multiple data streams or protocols."@en ;
  noria:structuralElementObservable <https://example.com/protocolHandling> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkManagementTeam> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network nodes and infrastructure."@en .

<https://example.com/NetworkManagementTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Management Team"@en ;
  rdfs:comment "Team overseeing high-level network infrastructure and super nodes."@en .

<https://example.com/latencyMeasurement> a noria:StructuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Measurement of latency between nodes."@en .

<https://example.com/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load on the node."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection (up/down)."@en .

<https://example.com/routingMetrics> a noria:StructuralObservable ;
  rdfs:label "Routing Metrics"@en ;
  rdfs:comment "Metrics related to routing performance."@en .

<https://example.com/protocolHandling> a noria:StructuralObservable ;
  rdfs:label "Protocol Handling"@en ;
  rdfs:comment "Protocols supported and handled by the node."@en .

<https://example.com/aggregateTraffic> a noria:StructuralObservable ;
  rdfs:label "Aggregate Traffic"@en ;
  rdfs:comment "Total traffic aggregated at super node."@en .

<https://example.com/NodeConnector> a noria:StructuralElement ;
  rdfs:label "Node Connector"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NodeIntermediary> a noria:StructuralElement ;
  rdfs:label "Node Intermediary"@en ;
  rdfs:comment "An intermediary node involved in routing decisions."@en ;
  noria:structuralElementObservableData <https://example.com/routingMetrics> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NodeMultiplex> a noria:StructuralElement ;
  rdfs:label "Node Multiplex"@en ;
  rdfs:comment "A multiplex node handling multiple protocols."@en ;
  noria:structuralElementObservable <https://example.com/protocolHandling> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NodeSuper> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkManagementTeam> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/OrgDept> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with a high number of connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node that is central in the network topology, connecting multiple subnets."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node serving as a bridge between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionQuality> ;
  noria:elementManagedBy <https://example.com/ConnectivityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow, facilitating routing."@en ;
  noria:structuralElementObservableData <https://example.com/routingPath> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node that multiplexes multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamThroughput> ;
  noria:elementManagedBy <https://example.com/PerformanceTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/aggregateLatency> ;
  noria:elementManagedBy <https://example.com/ManagementBoard> .

<https://example.com/Entity1> a noria:ManagedElement ;
  rdfs:label "Entity1"@en ;
  rdfs:comment "An example resource entity from example.com."@en ;
  noria:elementManagedBy <https://example.com/EntityOwner> .

<https://example.com/Entity2> a noria:ManagedElement ;
  rdfs:label "Entity2"@en ;
  rdfs:comment "Another resource entity from example.com."@en ;
  noria:elementManagedBy <https://example.com/EntityOwner> .

<https://example.com/Entity3> a noria:ManagedElement ;
  rdfs:label "Entity3"@en ;
  rdfs:comment "Third resource entity from example.com."@en ;
  noria:elementManagedBy <https://example.com/EntityOwner> .

<https://example.com/Entity4> a noria:ManagedElement ;
  rdfs:label "Entity4"@en ;
  rdfs:comment "Fourth resource entity from example.com."@en ;
  noria:elementManagedBy <https://example.com/EntityOwner> .

<https://example.com/EntityOwner> a org:OrganizationalUnit ;
  rdfs:label "Entity Owner"@en ;
  rdfs:comment "Organization responsible for managing entities."@en .

<https://example.com/degreeMetric> a noria:structuralElementObservableData ;
  rdfs:label "Degree Metric"@en ;
  rdfs:comment "Number of connections for high-degree node."@en .

<https://example.com/latencyObservable> a noria:structuralElementObservable ;
  rdfs:label "Latency Observable"@en ;
  rdfs:comment "Network latency measurement for central node."@en .

<https://example.com/connectionQuality> a noria:structuralElementObservable ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Quality indicator of the connection at connector node."@en .

<https://example.com/routingPath> a noria:structuralElementObservableData ;
  rdfs:label "Routing Path"@en ;
  rdfs:comment "Data representing routing path through intermediary node."@en .

<https://example.com/streamThroughput> a noria:structuralElementObservable ;
  rdfs:label "Stream Throughput"@en ;
  rdfs:comment "Data stream throughput at multiplex node."@en .

<https://example.com/aggregateLatency> a noria:structuralElementObservable ;
  rdfs:label "Aggregate Latency"@en ;
  rdfs:comment "Overall latency at super node."@en .

<https://example.com/Entity1> noria:elementManagedBy <https://example.com/EntityOwner> .
<https://example.com/Entity2> noria:elementManagedBy <https://example.com/EntityOwner> .
<https://example.com/Entity3> noria:elementManagedBy <https://example.com/EntityOwner> .
<https://example.com/Entity4> noria:elementManagedBy <https://example.com/EntityOwner> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/highDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a connector in the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node that is central in the network topology, connecting multiple subnets."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node that connects different network segments or systems."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow between other nodes."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiple types of connections or functions."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node that aggregates multiple nodes, acting as a super hub."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA>
  a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A virtual server hosting critical applications."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceB>
  a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A physical network switch."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceC>
  a noria:Resource ;
  rdfs:label "Resource C"@en ;
  rdfs:comment "A virtual machine connected to Resource A."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Locus1>
  a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "Line: L, in Room:Server room 314" ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Locus2>
  a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Secondary network closet."@en ;
  noria:locusLine "Line: R, in Room:Data Center 2" ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/NetworkLink1>
  a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Resource B and Resource C."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/NetworkLink2>
  a noria:NetworkLink ;
  rdfs:label "Ethernet Link 2"@en ;
  rdfs:comment "Ethernet connection between Resource A and Resource B."@en ;
  noria:networkLinkId "NLINK002" ;
  noria:networkLinkType "Ethernet" ;
  noria:networkLinkInstallationDate "2021-06-10T09:30:00"^^xsd:dateTime ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_NetworkInterface1>
  a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource A."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "VLAN 10" ;
  noria:networkInterfaceOf <https://example.com/ResourceA> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceB_NetworkInterface1>
  a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Management interface of Resource B."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "GigabitEthernet0/1" ;
  noria:networkInterfaceOf <https://example.com/ResourceB> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceC_NetworkInterface1>
  a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Virtual network interface of Resource C."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "VLAN 20" ;
  noria:networkInterfaceOf <https://example.com/ResourceC> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_NetworkLinkConnects>
  a noria:NetworkLink ;
  rdfs:label "Link between Resource A and B"@en ;
  rdfs:comment "Connection via Ethernet between Resource A and Resource B."@en ;
  rdfs:seeAlso <https://w3id.org/noria/NetworkLink2> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceB_NetworkLinkConnects>
  a noria:NetworkLink ;
  rdfs:label "Link between Resource B and C"@en ;
  rdfs:comment "Optical fiber connection between Resource B and Resource C."@en ;
  rdfs:seeAlso <https://w3id.org/noria/NetworkLink1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_ConnectedTo>
  a noria:Resource ;
  rdfs:label "Resource A connected to Resource B"@en ;
  rdfs:comment "Resource A is connected to Resource B via Ethernet."@en ;
  rdfs:seeAlso <https://example.com/ResourceA_NetworkLink1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceB_ConnectedTo>
  a noria:Resource ;
  rdfs:label "Resource B connected to Resource C"@en ;
  rdfs:comment "Resource B is connected to Resource C via fiber."@en ;
  rdfs:seeAlso <https://example.com/ResourceB_NetworkLinkConnects> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_ConnectedTo2>
  a noria:Resource ;
  rdfs:label "Resource A to Resource C"@en ;
  rdfs:comment "Indirect connection between Resource A and Resource C."@en ;
  rdfs:seeAlso <https://example.com/ResourceA_NetworkLink1> ;
  rdfs:seeAlso <https://example.com/ResourceC_NetworkInterface1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceB_ConnectedTo2>
  a noria:Resource ;
  rdfs:label "Resource B to Resource C"@en ;
  rdfs:comment "Resource B connected to Resource C via fiber."@en ;
  rdfs:seeAlso <https://example.com/ResourceB_NetworkLinkConnects> ;
  rdfs:seeAlso <https://example.com/ResourceC_NetworkInterface1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ResourceA_ConnectedTo3>
  a noria:Resource ;
