  rdfs:comment "Virtual connection between Resource A and Resource B."@en ;
  rdfs:seeAlso <https://example.com/ResourceA_NetworkInterface1> ;
  rdfs:seeAlso <https://example.com/ResourceB_NetworkInterface1> ;
