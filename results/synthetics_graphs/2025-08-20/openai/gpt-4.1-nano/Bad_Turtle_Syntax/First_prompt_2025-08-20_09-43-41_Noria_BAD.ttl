@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "Central node with high connectivity, acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:ManagedElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with a high number of connections, acting as a critical point in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:ManagedElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node that serves as a central point for data aggregation."@en ;
  noria:elementManagedBy <https://example.com/DataCenterTeam> .

<https://example.com/connectorNode> a noria:ManagedElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node that connects different network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkSupportTeam> .

<https://example.com/intermediaryNode> a noria:ManagedElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/multiplexNode> a noria:ManagedElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node that multiplexes multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with superordinate control over multiple nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource1"@en ;
  rdfs:comment "Core router in the main data center."@en ;
  noria:resourceLogisticId "LR-DC-001" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceHostName "router-main-01" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://example.com/ResourceType/Router> ] ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <https://example.com/ResourceState/Operational> ] ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceManagementIPAddress "192.168.0.1" .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Main Server Room Locus"@en ;
  rdfs:comment "Locus within the main server room."@en ;
  noria:locusLine "Line:L, in Room:Server Room 1"@en ;
  noria:locusRow "Row:3"@en .

<https://example.com/ResourceType/Router> a skos:Concept ;
  rdfs:label "Router"@en ;
  skos:inScheme <kos/Resource/type> .

<https://example.com/ResourceState/Operational> a skos:Concept ;
  rdfs:label "Operational"@en ;
  skos:inScheme <kos/Resource/LifecycleState> .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance enterprise router model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "TechManufacture Inc."@en ;
  rdfs:comment "Leading manufacturer of network equipment."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/DataCenterTeam> a org:OrganizationalUnit ;
  rdfs:label "Data Center Team"@en ;
  rdfs:comment "Team managing data center resources."@en .

<https://example.com/NetworkSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team for network segments."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "IT support team for troubleshooting."@en .

<https://example.com/NetworkManagement> a org:OrganizationalUnit ;
  rdfs:label "Network Management"@en ;
  rdfs:comment "Team overseeing network management."@en .

<https://example.com/AlarmEvent1> a noria:EventRecord ;
  rdfs:label "Alarm Event 1"@en ;
  rdfs:comment "Critical alarm indicating link down."@en ;
  noria:logText "Link down detected on interface ge-0/0/1."@en ;
  noria:loggingTime "2023-10-20T14:30:00Z"^^xsd:dateTime ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:alarmSeverity [ a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; skos:hasTopConcept <Notification/Severity/Critical> ] ;
  noria:alarmProposedRepairAction <https://example.com/RepairAction1> .

<https://example.com/RepairAction1> a pep:Procedure ;
  rdfs:label "Restart Interface"@en ;
  rdfs:comment "Procedure to restart the network interface."@en .

<https://example.com/AlarmEvent2> a noria:EventRecord ;
  rdfs:label "Alarm Event 2"@en ;
  rdfs:comment "Warning for high optical power."@en ;
  noria:logText "Optical power high at 0dBm."@en ;
  noria:loggingTime "2023-10-20T15:00:00Z"^^xsd:dateTime ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:alarmSeverity [ a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; skos:hasTopConcept <Notification/Severity/Warning> ] ;
  noria:alarmProposedRepairAction <https://example.com/RepairAction2> .

<https://example.com/RepairAction2> a pep:Procedure ;
  rdfs:label "Adjust Optical Power"@en ;
  rdfs:comment "Procedure to calibrate optical power."@en .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "Backup server in data center."@en ;
  noria:resourceLogisticId "LR-DC-002" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceHostName "backup-server-01" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://example.com/ResourceType/Server> ] ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceSerialNumber "SN-654321" ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <https://example.com/ResourceState/Operational> ] ;
  noria:resourceInstallationDate "2021-06-10T09:00:00Z"^^xsd:dateTime .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Backup server model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "ServerMakers Ltd."@en ;
  rdfs:comment "Server manufacturing company."@en .