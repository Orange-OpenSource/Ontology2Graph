<https://example.com/HubNode1> a noria:ManagedElement ;
  rdfs:label "Core Network Hub"@en ;
  rdfs:comment "A high-degree central node acting as a core switch in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Router"@en ;
  rdfs:comment "A high-degree node connecting multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/RouterLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/CentralNode1> a noria:StructuralElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A node with high centrality in the data processing."@en ;
  noria:structuralElementObservable <https://example.com/ServerLoad> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking internal and external networks."@en ;
  noria:structuralElementObservable <https://example.com/FirewallStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservable <https://example.com/TrafficDistribution> ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/MultiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/DataStreams> ;
  noria:elementManagedBy <https://example.com/DataManagementTeam> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeLoad> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/HubNode2> a noria:ManagedElement ;
  rdfs:label "Edge Hub"@en ;
  rdfs:comment "An edge hub with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/EdgeTeam> .

<https://example.com/ConnectorNode2> a noria:StructuralElement ;
  rdfs:label "VPN Gateway"@en ;
  rdfs:comment "A connector node providing VPN services."@en ;
  noria:structuralElementObservable <https://example.com/VPNStatus> ;
  noria:elementManagedBy <https://example.com/NetworkSecurityTeam> .

<https://example.com/IntermediaryNode2> a noria:StructuralElement ;
  rdfs:label "Proxy Server"@en ;
  rdfs:comment "An intermediary node acting as a proxy."@en ;
  noria:structuralElementObservable <https://example.com/ProxyLoad> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/MuxNode2> a noria:StructuralElement ;
  rdfs:label "Data Mux"@en ;
  rdfs:comment "A multiplex node for data aggregation."@en ;
  noria:structuralElementObservable <https://example.com/DataMuxStatus> ;
  noria:elementManagedBy <https://example.com/DataOps> .

<https://example.com/SuperNode2> a noria:StructuralElement ;
  rdfs:label "Global Super Node"@en ;
  rdfs:comment "An overarching super node for global network management."@en ;
  noria:structuralElementObservable <https://example.com/GlobalLoad> ;
  noria:elementManagedBy <https://example.com/GlobalNetworkTeam> .

<https://example.com/HubNode3> a noria:ManagedElement ;
