@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, managing multiple links."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A network switch with high degree of connections to other nodes."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A central router in the network core."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/throughput> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiplexed connections."@en ;
  noria:structuralElementObservable <https://example.com/muxStatus> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregationMetrics> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical server resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceHostName "server1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceSerialNumber "SN987654321" ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagementIPAddress "192.168.1.10" ;
  rdfs:label "Main Application Server"@en ;
  rdfs:comment "Primary application server in data center."@en .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Location within Server Room 314."@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model identifier for Resource1."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "Acme Corp"@en ;
  rdfs:comment "Manufacturer of ProductModelX."@en .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface."@en ;
  noria:networkInterfaceType "physical"^^xsd:string ;
  noria:networkInterfaceDescription "Gigabit Ethernet Interface"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkType "optical fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Backup server resource."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceHostName "backup1.example.com"@en ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Location in Data Center 2."@en .

<https://example.com/TrafficLoad> a noria:Property ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/ConnectionStatus> a noria:Property ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the network connection."@en .

<https://example.com/latencyMeasurement> a noria:Property ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Measured network latency in ms."@en .

<https://example.com/muxStatus> a noria:Property ;
  rdfs:label "MUX Status"@en ;
  rdfs:comment "Status of multiplexing."@en .

<https://example.com/aggregationMetrics> a noria:Property ;
  rdfs:label "Aggregation Metrics"@en ;
  rdfs:comment "Metrics aggregating multiple nodes."@en .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A multiplexed resource node."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/LocusC> ;
  noria:resourceHostName "muxnode1.example.com"@en ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Multiplexed> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> .

<https://example.com/LocusC> a noria:Locus ;
  rdfs:label "Locus C"@en ;
  rdfs:comment "Location in Main Data Center."@en .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for load balancing."@en ;
  noria:structuralElementObservable <https://example.com/aggregationMetrics> .

# End of graph