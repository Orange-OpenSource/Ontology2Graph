@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, managing multiple links."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Central Network Operations"@en ;
  rdfs:comment "Organization responsible for managing core network infrastructure."@en .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a critical junction."@en ;
  noria:structuralElementObservable noria:virtualServerStatus ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node serving as a central point in the network topology."@en ;
  noria:structuralElementObservable noria:virtualServerStatus ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable noria:virtualServerStatus ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow between hubs."@en ;
  noria:structuralElementObservable noria:virtualServerStatus ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node supporting multiple data streams."@en ;
  noria:structuralElementObservable noria:virtualServerStatus ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node integrating multiple network segments."@en ;
  noria:structuralElementObservable noria:virtualServerStatus ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical network resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "host-resource1" ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  noria:resourceType <http://purl.org/ontology/bibo/Resource> ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Location within Server Room 314."@en ;
  noria:locusLine "Line:L, in Room:Server room 314" .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Fiber Optic Link A-B"@en ;
  rdfs:comment "A high-speed fiber optic connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkTerminationResource <https://example.com/resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/resource2> .

<https://example.com/resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A secondary network resource."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "host-resource2" ;
  noria:locatedAtLocus <https://example.com/locus2> ;
  noria:resourceType <http://purl.org/ontology/bibo/Resource> ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Location within Server Room 315."@en ;
  noria:locusRow "Row:5" .

<https://example.com/event1> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating the link has come up."@en ;
  noria:loggingTime "2023-10-01T12:30:00"^^xsd:dateTime ;
  noria:logText "Fiber link NLINK001 is now active." ;
  noria:logOriginatingManagedObject <https://example.com/connection1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en ;
  rdfs:comment "System monitoring network links."@en .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Wireless Link X-Y"@en ;
  rdfs:comment "A wireless connection between Resource3 and Resource4."@en ;
  noria:networkLinkId "NLINK002" ;
  noria:networkLinkType "Wireless" ;
  noria:networkLinkInstallationDate "2021-06-10T09:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/resource3> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/resource4> .

<https://example.com/resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A wireless access point."@en ;
  noria:resourceHostName "AP-Resource3" ;
  noria:resourceLogisticId "LOG54321" ;
  noria:locatedAt <https://example.com/locus3> ;
  noria:resourceType <http://purl.org/ontology/bibo/Resource> ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/locus3> a noria:Locus ;
  rdfs:label "Locus 3"@en ;
  rdfs:comment "Location in Building B, Floor 2."@en .

<https://example.com/resource4> a noria:Resource ;
  rdfs:label "Resource 4"@en ;
  rdfs:comment "A client device."@en ;
  noria:resourceHostName "ClientDevice1" ;
  noria:resourceLogisticId "LOG98765" ;
  noria:locatedAt <https://example.com/locus4> ;
  noria:resourceType <http://purl.org/ontology/bibo/Resource> ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/locus4> a noria:Locus ;
  rdfs:label "Locus 4"@en ;
  rdfs:comment "Location in Building B, Floor 2, Room 210."@en .

<https://example.com/event2> a noria:EventRecord ;
  rdfs:label "Link Down Event"@en ;
  rdfs:comment "Event indicating the wireless link has gone down."@en ;
  noria:loggingTime "2023-10-02T14:45:00"^^xsd:dateTime ;
  noria:logText "Wireless link NLINK002 is now inactive." ;
  noria:logOriginatingManagedObject <https://example.com/connection2> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> .

<https://example.com/connection3> a noria:NetworkLink ;
  rdfs:label "Virtual Link V1"@en ;
  rdfs:comment "A virtual network link for overlay network."@en ;
  noria:networkLinkId "NLINK003" ;
  noria:networkLinkType "Overlay" ;
  noria:networkLinkInstallationDate "2023-05-20T11:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/resource5> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/resource6> .

<https://example.com/resource5> a noria:Resource ;
  rdfs:label "Resource 5"@en ;
  rdfs:comment "A virtual machine."@en ;
  noria:resourceHostName "VM-Resource5" ;
  noria:resourceLogisticId "LOG11223" ;
  noria:locatedAt <https://example.com/locus5> ;
  noria:resourceType <http://purl.org/ontology/bibo/Resource> ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/locus5> a noria:Locus ;
  rdfs:label "Locus 5"@en ;
  rdfs:comment "Data Center Rack 7."@en .

<https://example.com/resource6> a noria:Resource ;
  rdfs:label "Resource 6"@en ;
  rdfs:comment "A network switch."@en ;
  noria:resourceHostName "Switch-Resource6" ;
  noria:resourceLogisticId "LOG44556" ;
  noria:locatedAt <https://example.com/locus6> ;
  noria:resourceType <http://purl.org/ontology/bibo/Resource> ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/locus6> a noria:Locus ;
  rdfs:label "Locus 6"@en ;
  rdfs:comment "Data Center Rack 8."@en .

<https://example.com/event3> a noria:EventRecord ;
  rdfs:label "Virtual Link Activation"@en ;
  rdfs:comment "Event indicating virtual link V1 is active."@en ;
  noria:loggingTime "2023-10-05T09:15:00"^^xsd:dateTime ;
  noria:logText "Virtual link NLINK003 is now active." ;
  noria:logOriginatingManagedObject <https://example.com/connection3> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> .