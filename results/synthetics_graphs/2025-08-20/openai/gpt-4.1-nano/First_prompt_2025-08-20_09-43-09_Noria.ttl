@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://example.com/HubNode1> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/OrgDept1> .

<https://example.com/HighDegreeNode2> a noria:StructuralElement ;
  rdfs:label "Distribution Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a distribution point."@en ;
  noria:structuralElementObservableData <https://example.com/PowerUsageData> ;
  noria:elementManagedBy <https://example.com/OrgDept2> .

<https://example.com/CentralNode3> a noria:FunctionalElement ;
  rdfs:label "Main Application Server"@en ;
  rdfs:comment "A central node hosting core application services."@en ;
  noria:elementDistinguishedName "AppServer01" ;
  noria:resourceForApplication <https://example.com/FinanceApp> .

<https://example.com/ConnectorNode4> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking internal and external networks."@en ;
  noria:structuralElementObservableData <https://example.com/FirewallStatus> ;
  noria:elementManagedBy <https://example.com/OrgDept3> .

<https://example.com/IntermediaryNode5> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservableData <https://example.com/TrafficLoad> ;
  noria:elementManagedBy <https://example.com/OrgDept4> .

<https://example.com/MuxNode6> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/DataStreams> ;
  noria:elementManagedBy <https://example.com/OrgDept5> .

<https://example.com/SuperNode7> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/TotalTraffic> ;
  noria:elementManagedBy <https://example.com/OrgDept6> .

<https://example.com/HubNode1> noria:structuralElementObservable <https://example.com/TrafficFlow1> .
<https://example.com/HighDegreeNode2> noria:structuralElementObservable <https://example.com/PowerUsageData> .
<https://example.com/CentralNode3> noria:structuralElementObservable <https://example.com/ServerLoad> .
<https://example.com/ConnectorNode4> noria:structuralElementObservable <https://example.com/FirewallStatus> .
<https://example.com/IntermediaryNode5> noria:structuralElementObservable <https://example.com/TrafficLoad> .
<https://example.com/MuxNode6> noria:structuralElementObservable <https://example.com/DataStreams> .
<https://example.com/SuperNode7> noria:structuralElementObservable <https://example.com/TotalTraffic> .

<https://example.com/TrafficFlow1> a noria:StructuralObservable ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Flow of network traffic through HubNode1."@en .

<https://example.com/PowerUsageData> a noria:StructuralObservable ;
  rdfs:label "Power Usage Data"@en ;
  rdfs:comment "Power consumption metrics for HighDegreeNode2."@en .

<https://example.com/ServerLoad> a noria:StructuralObservable ;
  rdfs:label "Server Load"@en ;
  rdfs:comment "Current load metrics on the central application server."@en .

<https://example.com/FirewallStatus> a noria:StructuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Operational status of the firewall connector node."@en .

<https://example.com/TrafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Traffic load metrics on the load balancer."@en .

<https://example.com/DataStreams> a noria:StructuralObservable ;
  rdfs:label "Data Streams"@en ;
  rdfs:comment "Multiple data streams multiplexed by the multiplex node."@en .

<https://example.com/TotalTraffic> a noria:StructuralObservable ;
  rdfs:label "Total Traffic"@en ;
  rdfs:comment "Aggregated total traffic at the super node."@en .

<https://example.com/OrgDept1> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Network Operations Department responsible for core hub nodes."@en .

<https://example.com/OrgDept2> a org:OrganizationalUnit ;
  rdfs:label "Data Center Management"@en ;
  rdfs:comment "Department managing data center infrastructure."@en .

<https://example.com/OrgDept3> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security devices like firewalls."@en .

<https://example.com/OrgDept4> a org:OrganizationalUnit ;
  rdfs:label "Traffic Management"@en ;
  rdfs:comment "Team handling traffic distribution and load balancing."@en .

<https://example.com/OrgDept5> a org:OrganizationalUnit ;
  rdfs:label "Data Multiplexing"@en ;
  rdfs:comment "Team managing data multiplexing devices."@en .

<https://example.com/OrgDept6> a org:OrganizationalUnit ;
  rdfs:label "Traffic Aggregation"@en ;
  rdfs:comment "Team aggregating network traffic data."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "Main core router in the network."@en .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Distribution Switch"@en ;
  rdfs:comment "Switch connecting distribution layer."@en .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Application Server"@en ;
  rdfs:comment "Server hosting core applications."@en .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Firewall Device"@en ;
  rdfs:comment "Firewall for network security."@en .

<https://example.com/Resource5> a noria:Resource ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Device balancing traffic among servers."@en .

<https://example.com/Resource6> a noria:Resource ;
  rdfs:label "Data Multiplexer"@en ;
  rdfs:comment "Device multiplexing multiple data streams."@en .

<https://example.com/Resource7> a noria:Resource ;
  rdfs:label "Super Node Aggregator"@en ;
  rdfs:comment "Aggregates data from multiple hubs."@en .

<https://example.com/TrafficFlow1> a noria:StructuralObservable ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Flow of traffic through HubNode1."@en .

<https://example.com/PowerUsageData> a noria:StructuralObservable ;
  rdfs:label "Power Usage Data"@en ;
  rdfs:comment "Power consumption metrics for HighDegreeNode2."@en .

<https://example.com/ServerLoad> a noria:StructuralObservable ;
  rdfs:label "Server Load"@en ;
  rdfs:comment "Current load on Application Server."@en .

<https://example.com/FirewallStatus> a noria:StructuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Operational status of Firewall Device."@en .

<https://example.com/TrafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Traffic load metrics on Load Balancer."@en .

<https://example.com/DataStreams> a noria:StructuralObservable ;
  rdfs:label "Data Streams"@en ;
  rdfs:comment "Multiple data streams multiplexed."@en .

<https://example.com/TotalTraffic> a noria:StructuralObservable ;
  rdfs:label "Total Traffic"@en ;
  rdfs:comment "Aggregated total traffic at Super Node."@en .
