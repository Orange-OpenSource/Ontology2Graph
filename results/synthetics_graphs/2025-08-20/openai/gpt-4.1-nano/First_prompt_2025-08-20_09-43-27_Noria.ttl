@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode1>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A switch with high connectivity in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyData> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode2>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Router 2"@en ;
  rdfs:comment "A router with high degree of connections."@en ;
  noria:structuralElementObservableData <https://example.com/throughputData> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A central server acting as a core node in the network."@en ;
  noria:structuralElementObservableData <https://example.com/serverLoad> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/ITDept> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:structuralObservableOf <https://example.com/centralNode> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:structuralObservableOf <https://example.com/connectorNode> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamQuality> ;
  noria:structuralObservableOf <https://example.com/intermediaryNode> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level analysis."@en ;
  noria:structuralElementObservableData <https://example.com/aggregateMetrics> ;
  noria:structuralObservableOf <https://example.com/multiplexNode> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/NetworkOps>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/NetworkOpsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Support"@en ;
  rdfs:comment "Support team for network operations."@en .

<https://example.com/ITDept>
  a org:OrganizationalUnit ;
  rdfs:label "IT Department"@en ;
  rdfs:comment "Department managing core servers."@en .

<https://example.com/NetworkTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "Team handling network multiplexing and data streams."@en .

<https://example.com/Server1>
  a noria:StructuralElement ;
  rdfs:label "Main Application Server"@en ;
  rdfs:comment "A critical server in the network."@en ;
  noria:elementDistinguishedName "Server1" ;
  noria:elementManagedBy <https://example.com/ITDept> .

<https://example.com/latencyData>
  a noria:Property ;
  rdfs:label "Latency Data"@en ;
  rdfs:comment "Latency measurements for high-degree switch."@en .

<https://example.com/throughputData>
  a noria:Property ;
  rdfs:label "Throughput Data"@en ;
  rdfs:comment "Throughput measurements for high-degree router."@en .

<https://example.com/serverLoad>
  a noria:Property ;
  rdfs:label "Server Load"@en ;
  rdfs:comment "Current load on the central server."@en .

<https://example.com/connectionQuality>
  a noria:Property ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Quality metrics of the connector node."@en .

<https://example.com/dataFlowRate>
  a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Data transfer rate at the intermediary node."@en .

<https://example.com/streamQuality>
  a noria:Property ;
  rdfs:label "Stream Quality"@en ;
  rdfs:comment "Quality metrics for multiplexed streams."@en .

<https://example.com/aggregateMetrics>
  a noria:Property ;
  rdfs:label "Aggregate Metrics"@en ;
  rdfs:comment "High-level metrics for super node."@en .
