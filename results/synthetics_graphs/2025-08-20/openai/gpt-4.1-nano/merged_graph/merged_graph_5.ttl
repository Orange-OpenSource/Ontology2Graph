<https://example.com/hubNode_extra_node_1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_0> .

<https://example.com/highDegreeNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, serving as a critical point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_0> .

<https://example.com/centralNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point connecting multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_0> .

<https://example.com/connectorNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different parts of the network, facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_0> .

<https://example.com/intermediaryNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data routing."@en ;
  noria:structuralElementObservable <https://example.com/routingPath> ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_0> .

<https://example.com/multiplexNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that handles multiple data streams simultaneously."@en ;
  noria:structuralElementObservableData <https://example.com/streamBandwidth> ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_0> .

<https://example.com/superNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An advanced node with super connectivity and processing capabilities."@en ;
  noria:structuralObservableOf <https://example.com/processingPower> ;
  noria:elementManagedBy <https://example.com/NetworkOperations_extra_node_0> .

<https://example.com/NetworkOperations_extra_node_0> a org:OrganizationalUnit ;
