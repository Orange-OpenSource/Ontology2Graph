<https://example.com/hubNode_extra_node_0>
  a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/highDegreeNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a critical connector in the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/centralNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/connectorNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments or systems."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/intermediaryNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that mediates communication between other nodes."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/multiplexNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple types of connections or functions."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/superNode_extra_node_0>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node with extensive connectivity, often representing a major network hub."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource1_extra_node_0>
  a noria:Resource ;
