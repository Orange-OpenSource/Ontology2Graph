<https://example.com/streamBandwidth> a noria:StructuralObservable ;
  rdfs:label "Stream Bandwidth"@en ;
  rdfs:comment "Bandwidth allocated for multiplexed streams."@en .

<https://example.com/processingPower> a noria:StructuralObservable ;
  rdfs:label "Processing Power"@en ;
  rdfs:comment "Processing capacity of the super node."@en .

