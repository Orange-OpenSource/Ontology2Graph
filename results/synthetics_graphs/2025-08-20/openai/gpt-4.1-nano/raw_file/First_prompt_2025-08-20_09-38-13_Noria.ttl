@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode1>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A switch with high connectivity in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyData> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode2>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Router 2"@en ;
  rdfs:comment "Router with multiple connections serving core network."@en ;
  noria:structuralElementObservableData <https://example.com/throughputData> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A central server acting as a core processing node."@en ;
  noria:structuralElementObservableData <https://example.com/serverLoad> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/ITDept> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Switch"@en ;
  rdfs:comment "A switch connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:structuralObservableOf <https://example.com/highDegreeNode1> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediate Router"@en ;
  rdfs:comment "Router acting as an intermediary between core and edge."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:structuralObservableOf <https://example.com/centralNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "Device multiplexing multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamEfficiency> ;
  noria:structuralObservableOf <https://example.com/connectorNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple high-degree nodes."@en ;
  noria:structuralElementObservableData <https://example.com/aggregateTraffic> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/NetworkOpsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/ITDept>
  a org:OrganizationalUnit ;
  rdfs:label "IT Department"@en ;
  rdfs:comment "Department managing core IT resources."@en .

<https://example.com/latencyData>
  a noria:StructuralObservable ;
  rdfs:label "Latency Data"@en ;
  rdfs:comment "Latency measurements for network links."@en .

<https://example.com/throughputData>
  a noria:StructuralObservable ;
  rdfs:label "Throughput Data"@en ;
  rdfs:comment "Data throughput metrics."@en .

<https://example.com/serverLoad>
  a noria:StructuralObservable ;
  rdfs:label "Server Load"@en ;
  rdfs:comment "Current load on the central server."@en .

<https://example.com/connectionQuality>
  a noria:StructuralObservable ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Quality metrics of network connections."@en .

<https://example.com/latency>
  a noria:StructuralObservable ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency measurements."@en .

<https://example.com/streamEfficiency>
  a noria:StructuralObservable ;
  rdfs:label "Stream Efficiency"@en ;
  rdfs:comment "Efficiency of data streams multiplexed."@en .

<https://example.com/aggregateTraffic>
  a noria:StructuralObservable ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Traffic volume aggregated at super node."@en .
