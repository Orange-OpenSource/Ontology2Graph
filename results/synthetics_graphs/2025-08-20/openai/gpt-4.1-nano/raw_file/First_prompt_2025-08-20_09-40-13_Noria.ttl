@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:ManagedElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high connectivity, acting as a major switch."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:ManagedElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:ManagedElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node that connects different network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/intermediaryNode> a noria:ManagedElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode> a noria:ManagedElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Super node aggregating multiple nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "A physical or logical hub node in the network."@en ;
  noria:structuralElementDistinguishedName "HubNode-01" .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, critical for network resilience."@en ;
  noria:structuralElementDistinguishedName "HighDegNode-02" .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central point in the network topology."@en ;
  noria:structuralElementDistinguishedName "CentralNode-03" .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Connects different network segments."@en ;
  noria:structuralElementDistinguishedName "Connector-04" .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Acts as an intermediary in data flow."@en ;
  noria:structuralElementDistinguishedName "Intermediary-05" .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Handles multiple data streams."@en ;
  noria:structuralElementDistinguishedName "Multiplex-06" .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple nodes for load balancing."@en ;
  noria:structuralElementDistinguishedName "SuperNode-07" .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Main server resource."@en ;
  noria:resourceLogisticId "LOG-RES-001" ;
  noria:resourceHostName "server1.example.com" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <kos/Resource/type/Server> ] ;
  noria:locatedAtLocus <https://example.com/Locus1> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Backup storage resource."@en ;
  noria:resourceLogisticId "LOG-RES-002" ;
  noria:resourceHostName "storage1.example.com" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <kos/Resource/type/Storage> ] ;
  noria:locatedAtLocus <https://example.com/Locus2> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "Line: L, in Room:Server Room 1" .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Storage room."@en ;
  noria:locusLine "Line: M, in Room:Storage Room 1" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceOf <https://example.com/Resource1> .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Backup network interface of Resource2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOf <https://example.com/Resource2> .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating eth0 link is up."@en ;
  noria:loggingTime "2024-03-15T10:15:00Z"^^xsd:dateTime ;
  noria:logText "eth0 link is now operational."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/NetworkAdmin> ;
  noria:alarmSeverity [ a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; skos:hasTopConcept <skos:Concept/Warning> ] .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Responsible for network management."@en .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en ;
  rdfs:comment "System monitoring network events."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Operations team managing network infrastructure."@en .