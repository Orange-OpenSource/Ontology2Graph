# Connect nodes via network links
<https://example.com/Link1> a noria:NetworkLink ;
  rdfs:label "Link 1"@en ;
  rdfs:comment "Optical fiber link between Node A and Node B."@en ;
  noria:networkLinkId "NLK-001" ;
  noria:networkLinkTerminationResource <https://example.com/NodeA> ;
  noria:networkLinkTerminationResource <https://example.com/NodeB> .

<https://example.com/Link2> a noria:NetworkLink ;
  rdfs:label "Link 2"@en ;
  rdfs:comment "Virtual connection between Node C and Node D."@en ;
  noria:networkLinkId "NLK-002" ;
  noria:networkLinkTerminationResource <https://example.com/NodeC> ;
  noria:networkLinkTerminationResource <https://example.com/NodeD> .

<https://example.com/Link3> a noria:NetworkLink ;
  rdfs:label "Link 3"@en ;
  rdfs:comment "High-speed link connecting Node E and Node F."@en ;
  noria:networkLinkId "NLK-003" ;
  noria:networkLinkTerminationResource <https://example.com/NodeE> ;
  noria:networkLinkTerminationResource <https://example.com/NodeF> .

