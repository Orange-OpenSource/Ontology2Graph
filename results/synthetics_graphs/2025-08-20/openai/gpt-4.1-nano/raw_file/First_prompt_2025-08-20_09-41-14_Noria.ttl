@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high connectivity degree, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node acting as a connector between different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node that intermediates data flow between source and destination."@en ;
  noria:structuralElementObservable <https://example.com/trafficFlow> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiplexing of multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregated node representing a superordinate network element."@en ;
  noria:structuralElementObservable <https://example.com/superLatency> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management and maintenance."@en .

<https://example.com/degreeMetric> a noria:structuralObservableOf ;
  rdfs:label "Node Degree Metric"@en ;
  rdfs:comment "Number of connections for a node."@en ;
  noria:structuralElementObservableData <https://example.com/degreeValue> .

<https://example.com/latencyObservable> a noria:structuralObservableOf ;
  rdfs:label "Network Latency"@en ;
  rdfs:comment "Latency measurement observable."@en ;
  noria:structuralElementObservableData <https://example.com/latencyValue> .

<https://example.com/connectionCount> a noria:structuralObservableOf ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en ;
  noria:structuralElementObservableData <https://example.com/connectionNumber> .

<https://example.com/trafficFlow> a noria:structuralObservableOf ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Data flow rate observable."@en ;
  noria:structuralElementObservableData <https://example.com/trafficRate> .

<https://example.com/streamCount> a noria:structuralObservableOf ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of multiplexed streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamNumber> .

<https://example.com/superLatency> a noria:structuralObservableOf ;
  rdfs:label "Super Node Latency"@en ;
  rdfs:comment "Aggregated latency for super node."@en ;
  noria:structuralElementObservableData <https://example.com/latencyValue> .

<https://example.com/NodeA> a noria:StructuralElement ;
  rdfs:label "Node A"@en ;
  rdfs:comment "A hub node with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/NodeB> a noria:StructuralElement ;
  rdfs:label "Node B"@en ;
  rdfs:comment "A central node in the topology."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/NodeC> a noria:StructuralElement ;
  rdfs:label "Node C"@en ;
  rdfs:comment "A connector node linking segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/NodeD> a noria:StructuralElement ;
  rdfs:label "Node D"@en ;
  rdfs:comment "An intermediary node for traffic routing."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/NodeE> a noria:StructuralElement ;
  rdfs:label "Node E"@en ;
  rdfs:comment "A multiplex node supporting multiple streams."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/NodeF> a noria:StructuralElement ;
  rdfs:label "Node F"@en ;
  rdfs:comment "A super node representing an aggregated network element."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Management Team"@en ;
  rdfs:comment "Team overseeing network nodes."@en .

<https://example.com/NodeA> noria:structuralElementObservable <https://example.com/degreeMetric> ;
  noria:structuralElementObservable <https://example.com/latencyObservable> .

