@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralElementObservable <https://example.com/connectionCountObs> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:structuralElementObservableData <https://example.com/trafficLoadData> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that primarily connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/segmentConnections> ;
  noria:structuralElementObservableData <https://example.com/connectionDetails> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that facilitates data flow between other nodes."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:structuralElementObservableData <https://example.com/dataFlowMetrics> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that handles multiple data streams simultaneously."@en ;
  noria:structuralElementObservable <https://example.com/multiplexCapacity> ;
  noria:structuralElementObservableData <https://example.com/capacityMetrics> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An aggregated node representing a cluster of nodes."@en ;
  noria:structuralElementObservable <https://example.com/clusterLoad> ;
  noria:structuralElementObservableData <https://example.com/clusterMetrics> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A core network resource responsible for data routing."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:resourceHostName "router1.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual server hosting critical applications."@en ;
  noria:resourceLogisticId "RES-002" ;
  noria:resourceHostName "vm-application.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtualServer> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Optical Fiber Link"@en ;
  rdfs:comment "A high-speed optical fiber connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A network switch connecting multiple segments."@en ;
  noria:resourceLogisticId "RES-003" ;
  noria:resourceHostName "switch1.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusC> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/switch> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceSerialNumber "SN789012" ;
  noria:resourceProductModel <https://example.com/ModelZ> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Resource 4"@en ;
  rdfs:comment "A virtual machine hosting a critical database."@en ;
  noria:resourceLogisticId "RES-004" ;
  noria:resourceHostName "db-server.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusD> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtualMachine> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceSerialNumber "SN345678" ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Connection1> a noria:NetworkLink ;
  rdfs:label "Connection between Resource1 and Resource3"@en ;
  rdfs:comment "A physical connection linking router to switch."@en ;
  noria:networkLinkId "CONN-001" ;
  noria:networkLinkType "Ethernet" ;
  noria:networkLinkInstallationDate "2021-12-01T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResource <https://example.com/Resource3> .

<https://example.com/Connection2> a noria:NetworkLink ;
  rdfs:label "Connection between Resource2 and Resource4"@en ;
  rdfs:comment "A virtual link over the data center network."@en ;
  noria:networkLinkId "CONN-002" ;
  noria:networkLinkType "Virtual Network" ;
  noria:networkLinkInstallationDate "2022-02-20T11:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource2> ;
  noria:networkLinkTerminationResource <https://example.com/Resource4> .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> ;
  noria:structuralElementObservableData <https://example.com/trafficVolumeData> .

<https://example.com/trafficVolume> a noria:StructuralObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "The total network traffic passing through the hub node."@en .

<https://example.com/trafficVolumeData> a noria:structuralElementObservableData ;
  rdfs:label "Traffic Volume Data"@en ;
  rdfs:comment "Quantitative data of traffic volume in Mbps."@en .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a key connector."@en ;
  noria:structuralElementObservable <https://example.com/connectionCount> ;
  noria:structuralElementObservableData <https://example.com/connectionCountData> .

<https://example.com/connectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections for the node."@en .

<https://example.com/connectionCountData> a noria:structuralElementObservableData ;
  rdfs:label "Connection Count Data"@en ;
  rdfs:comment "Integer value representing number of connections."@en .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node acting as a central point for traffic."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:structuralElementObservableData <https://example.com/trafficLoadData> .

<https://example.com/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load in Mbps."@en .

<https://example.com/trafficLoadData> a noria:structuralElementObservableData ;
  rdfs:label "Traffic Load Data"@en ;
  rdfs:comment "Numerical value of current traffic load."@en .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different segments."@en ;
  noria:structuralElementObservable <https://example.com/segmentConnections> ;
  noria:structuralElementObservableData <https://example.com/connectionDetails> .

<https://example.com/segmentConnections> a noria:StructuralObservable ;
  rdfs:label "Segment Connections"@en ;
  rdfs:comment "Number of segments connected."@en .

<https://example.com/connectionDetails> a noria:structuralElementObservableData ;
  rdfs:label "Connection Details"@en ;
  rdfs:comment "Details about segment connections."@en .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node facilitating data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:structuralElementObservableData <https://example.com/dataFlowMetrics> .

<https://example.com/dataFlowRate> a noria:StructuralObservable ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Data transfer rate in Mbps."@en .

<https://example.com/dataFlowMetrics> a noria:structuralElementObservableData ;
  rdfs:label "Data Flow Metrics"@en ;
  rdfs:comment "Quantitative metrics of data flow."@en .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Handles multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/multiplexCapacity> ;
  noria:structuralElementObservableData <https://example.com/capacityMetrics> .

<https://example.com/multiplexCapacity> a noria:StructuralObservable ;
  rdfs:label "Multiplex Capacity"@en ;
  rdfs:comment "Capacity in Gbps."@en .

<https://example.com/capacityMetrics> a noria:structuralElementObservableData ;
  rdfs:label "Capacity Metrics"@en ;
  rdfs:comment "Numerical capacity data."@en .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Clustered node representing a group."@en ;
  noria:structuralElementObservable <https://example.com/clusterLoad> ;
  noria:structuralElementObservableData <https://example.com/clusterMetrics> .

<https://example.com/clusterLoad> a noria:StructuralObservable ;
  rdfs:label "Cluster Load"@en ;
  rdfs:comment "Aggregate load in Mbps."@en .

<https://example.com/clusterMetrics> a noria:structuralElementObservableData ;
  rdfs:label "Cluster Metrics"@en ;
  rdfs:comment "Metrics of the cluster."@en .
