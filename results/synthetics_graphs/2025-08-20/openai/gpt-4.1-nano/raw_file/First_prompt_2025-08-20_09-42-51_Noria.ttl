@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/highDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a critical connector in the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments or systems."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that mediates communication between other nodes."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple types of connections or functions."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node with extensive connectivity, often representing a major network hub."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource1>
  a noria:Resource ;
  rdfs:label "Resource1"@en ;
  rdfs:comment "A critical server hosting core applications."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "server1.example.com" ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource2>
  a noria:Resource ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "A network switch connecting multiple segments."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "switch1.example.com" ;
  noria:locatedAtLocus <https://example.com/locus2> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/NetworkLink1>
  a noria:NetworkLink ;
  rdfs:label "FiberLink1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00"^^xsd:dateTime ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/NetworkInterface1>
  a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet Interface"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/NetworkInterface2>
  a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary network interface of Resource2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "VLAN Interface"@en ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource1> noria:resourceForApplication <https://example.com/Application1> .
<https://example.com/Resource2> noria:resourceForApplication <https://example.com/Application2> .

<https://example.com/Application1>
  a noria:Application ;
  rdfs:label "Core Application"@en ;
  rdfs:comment "Main business application hosted on Resource1."@en ;
  noria:applicationModelIdentifier "APP-CORE-001" ;
  noria:applicationType <https://w3id.org/noria/kos/application/type#service-platform> ;
  noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance#high> ;
  noria:applicationFunctionalDomain "Customer Management"@en ;
  noria:applicationFunctionalSubDomain "Customer Data"@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Application2>
  a noria:Application ;
  rdfs:label "Network Management"@en ;
  rdfs:comment "Network monitoring and control system."@en ;
  noria:applicationModelIdentifier "APP-NET-002" ;
  noria:applicationType <https://w3id.org/noria/kos/application/type#resource-facing-service> ;
  noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance#medium> ;
  noria:applicationFunctionalDomain "Network Operations"@en ;
  noria:applicationFunctionalSubDomain "Network Monitoring"@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/HubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/IntermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as a relay between core and edge."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ConnectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/SuperNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Major network aggregation point."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/MuxNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiple connection types."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource3>
  a noria:Resource ;
  rdfs:label "Resource3"@en ;
  rdfs:comment "A virtual server hosting backup services."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:resourceHostName "backup-server.example.com" ;
  noria:locatedAtLocus <https://example.com/locus3> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/locus1>
  a noria:Locus ;
  rdfs:label "Locus1"@en ;
  rdfs:comment "Main Data Center Rack"@en .

<https://example.com/locus2>
  a noria:Locus ;
  rdfs:label "Locus2"@en ;
  rdfs:comment "Edge Switch Location"@en .

<https://example.com/locus3>
  a noria:Locus ;
  rdfs:label "Locus3"@en ;
  rdfs:comment "Backup Server Location"@en .

<https://example.com/Resource4>
  a noria:Resource ;
  rdfs:label "Resource4"@en ;
  rdfs:comment "A virtual router for internal routing."@en ;
  noria:resourceLogisticId "LOG98765" ;
  noria:resourceHostName "virtual-router.example.com" ;
  noria:locatedAtLocus <https://example.com/locus4> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/locus4>
  a noria:Locus ;
  rdfs:label "Locus4"@en ;
  rdfs:comment "Virtual Network Segment"@en .

<https://example.com/Resource4> noria:resourceForApplication <https://example.com/Application3> .

<https://example.com/Application3>
  a noria:Application ;
  rdfs:label "Virtual Routing Application"@en ;
  rdfs:comment "A virtual routing service for internal network segmentation."@en ;
  noria:applicationModelIdentifier "APP-VIRT-003" ;
  noria:applicationType <https://w3id.org/noria/kos/application/type#service-platform> ;
  noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance#low> ;
  noria:applicationFunctionalDomain "Routing"@en ;
  noria:applicationFunctionalSubDomain "Internal Routing"@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

