@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, serving as a critical point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point connecting multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different parts of the network, facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data routing."@en ;
  noria:structuralElementObservable <https://example.com/routingPath> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that handles multiple data streams simultaneously."@en ;
  noria:structuralElementObservableData <https://example.com/streamBandwidth> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An advanced node with super connectivity and processing capabilities."@en ;
  noria:structuralObservableOf <https://example.com/processingPower> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes and links."@en .

<https://example.com/latencyMeasurement> a noria:StructuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Average latency observed at this node."@en .

<https://example.com/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load passing through this node."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection (e.g., active, inactive)."@en .

<https://example.com/routingPath> a noria:StructuralObservable ;
  rdfs:label "Routing Path"@en ;
  rdfs:comment "The routing path data for this node."@en .

<https://example.com/streamBandwidth> a noria:StructuralObservable ;
  rdfs:label "Stream Bandwidth"@en ;
  rdfs:comment "Bandwidth allocated for multiplexed streams."@en .

<https://example.com/processingPower> a noria:StructuralObservable ;
  rdfs:label "Processing Power"@en ;
  rdfs:comment "Processing capacity of the super node."@en .

<https://example.com/NodeA> a noria:StructuralElement ;
  rdfs:label "Node A"@en ;
  rdfs:comment "A hub node with high connectivity."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NodeB> a noria:StructuralElement ;
  rdfs:label "Node B"@en ;
  rdfs:comment "A central node connecting multiple segments."@en ;
  noria:structuralElementObservable <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NodeC> a noria:StructuralElement ;
  rdfs:label "Node C"@en ;
  rdfs:comment "A connector node linking different network parts."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NodeD> a noria:StructuralElement ;
  rdfs:label "Node D"@en ;
  rdfs:comment "An intermediary node routing data."@en ;
  noria:structuralElementObservable <https://example.com/routingPath> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NodeE> a noria:StructuralElement ;
  rdfs:label "Node E"@en ;
  rdfs:comment "A multiplex node handling multiple streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamBandwidth> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NodeF> a noria:StructuralElement ;
  rdfs:label "Node F"@en ;
  rdfs:comment "A super node with high processing capacity."@en ;
  noria:structuralObservableOf <https://example.com/processingPower> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/Link1> a noria:NetworkLink ;
  rdfs:label "Link 1"@en ;
  rdfs:comment "Optical fiber link between Node A and Node B."@en ;
  noria:networkLinkId "NLK-001" .

<https://example.com/Link2> a noria:NetworkLink ;
  rdfs:label "Link 2"@en ;
  rdfs:comment "Virtual connection between Node C and Node D."@en ;
  noria:networkLinkId "NLK-002" .

<https://example.com/Link3> a noria:NetworkLink ;
  rdfs:label "Link 3"@en ;
  rdfs:comment "High-speed link connecting Node E and Node F."@en ;
  noria:networkLinkId "NLK-003" .

<https://example.com/NodeA> noria:networkLinkConnects <https://example.com/Link1> ;
  noria:networkLinkConnects <https://example.com/Link2> .

<https://example.com/NodeB> noria:networkLinkConnects <https://example.com/Link1> .

<https://example.com/NodeC> noria:networkLinkConnects <https://example.com/Link2> .

<https://example.com/NodeD> noria:networkLinkConnects <https://example.com/Link2> .

<https://example.com/NodeE> noria:networkLinkConnects <https://example.com/Link3> .

<https://example.com/NodeF> noria:networkLinkConnects <https://example.com/Link3> .

<https://example.com/NodeA> noria:structuralElementObservable <https://example.com/trafficLoad> .

<https://example.com/NodeB> noria:structuralElementObservable <https://example.com/latencyMeasurement> .

<https://example.com/NodeC> noria:structuralElementObservableData <https://example.com/connectionStatus> .

<https://example.com/NodeD> noria:structuralElementObservable <https://example.com/routingPath> .

<https://example.com/NodeE> noria:structuralElementObservableData <https://example.com/streamBandwidth> .

<https://example.com/NodeF> noria:structuralObservableOf <https://example.com/processingPower> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Responsible for managing network nodes and links."@en .

# End of graph