@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/highDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with a high number of connections, acting as a connector in the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node that is central in the network topology, connecting multiple subnets."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node that connects different network segments or domains."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow between other nodes."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node that handles multiple types of traffic or protocols."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes or subsystems."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource1>
  a noria:Resource ;
  rdfs:label "Resource1"@en ;
  rdfs:comment "A virtual server hosting critical applications."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "server1.example.com" ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  noria:resourceType <http://purl.org/ontology/bibo/Software> ;
  noria:resourceSerialNumber "SN-987654" ;
  noria:resourceUsageState <http://skos.org/Resource/LifecycleState/Active> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource2>
  a noria:Resource ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "A physical network switch in data center."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "switch1.dc.example.com" ;
  noria:locatedAtLocus <https://example.com/locus2> ;
  noria:resourceType <http://purl.org/ontology/bibo/NetworkSwitch> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceUsageState <http://skos.org/Resource/LifecycleState/Active> ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/locus1>
  a noria:Locus ;
  rdfs:label "Locus1"@en ;
  rdfs:comment "Main server room rack position."@en ;
  noria:locusLine "Line: L, in Room:Server Room 1"@en ;
  noria:locusRow "Row: R"@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/locus2>
  a noria:Locus ;
  rdfs:label "Locus2"@en ;
  rdfs:comment "Data center rack position."@en ;
  noria:locusLine "Line: L, in Room:Data Center"@en ;
  noria:locusRow "Row: D"@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Resource1> noria:resourceForApplication <https://example.com/Application1> .

<https://example.com/Application1>
  a noria:Application ;
  rdfs:label "Core Business Application"@en ;
  rdfs:comment "Main application handling core business processes."@en ;
  noria:applicationModelIdentifier "APP-CORE-001" ;
  noria:applicationNumericalIdentifier 101 ;
  noria:applicationShortIdentifier "CoreApp" ;
  noria:applicationType <http://skos.org/application/type/Business> ;
  noria:applicationBusinessImportance <http://skos.org/application/business-importance/High> ;
  noria:applicationFunctionalDomain "Market and Customer Relationship Management"@en ;
  noria:applicationFunctionalSubDomain "Customer Data Management"@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Service1>
  a noria:Service ;
  rdfs:label "Customer Data Service"@en ;
  rdfs:comment "Service providing customer data access."@en ;
  rdfs:seeAlso <https://github.com/tmforum-apis/TMF638_ServiceInventory> ;
  rdfs:subClassOf noria:FunctionalElement ;
  rdfs:subClassOf seas:System ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/AlarmEvent1>
  a noria:EventRecord ;
  rdfs:label "Critical Network Down"@en ;
  rdfs:comment "Alarm indicating network interface failure."@en ;
  noria:logText "Interface ge-0/0/1 of Router1 is down." ;
  noria:loggingTime "2023-10-23T14:30:00Z"^^xsd:dateTime ;
  noria:alarmSeverity <http://skos.org/Notification/Severity/Critical> ;
  noria:alarmProposedRepairAction <https://example.com/RepairAction1> ;
  noria:alarmMitigatedBy <https://example.com/Procedure1> ;
  noria:logOriginatingManagedObject <https://example.com/Resource2> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/Agent1> .

<https://example.com/Procedure1>
  a pep:Procedure ;
  rdfs:label "Restart Interface"@en ;
  rdfs:comment "Procedure to restart network interface ge-0/0/1."@en .

<https://example.com/Agent1>
  a foaf:Agent ;
  rdfs:label "Network Admin Team"@en ;
  rdfs:comment "Responsible for network management."@en .

<https://example.com/RepairAction1>
  a pep:Procedure ;
  rdfs:label "Restart Interface Procedure"@en ;
  rdfs:comment "Procedure to restart network interface ge-0/0/1."@en .

<https://example.com/HubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity."@en .

<https://example.com/HighDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Connector"@en ;
  rdfs:comment "Node with many connections acting as a connector."@en .

<https://example.com/CentralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node acting as a central point in topology."@en .

<https://example.com/ConnectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en .

<https://example.com/IntermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en .

<https://example.com/MultiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple traffic types."@en .

<https://example.com/SuperNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregating node for subsystems."@en .
