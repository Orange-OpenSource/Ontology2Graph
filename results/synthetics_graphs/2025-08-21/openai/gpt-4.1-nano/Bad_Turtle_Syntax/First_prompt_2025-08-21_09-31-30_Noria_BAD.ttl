@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Network1> a noria:StructuralElement ;
  rdfs:label "Main Data Center Network"@en ;
  rdfs:comment "Core network infrastructure in the main data center."@en ;
  noria:structuralElementDistinguishedName "DCN-01" ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/SupportTeam> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Network> .

<https://w3id.org/noria/instance/SupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team responsible for network infrastructure."@en .

<https://w3id.org/noria/instance/Locus1> a noria:Locus ;
  rdfs:label "Server Room 314"@en ;
  noria:locusLine "Line:L, Column:6"@en ;
  noria:locusRow "Row:3"@en .

<https://w3id.org/noria/instance/ResourceA> a noria:Resource ;
  rdfs:label "Core Router 1"@en ;
  rdfs:comment "Main core router in the data center."@en ;
  noria:resourceLogisticId "RT-314" ;
  noria:resourceHostName "core-router-1" ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkDevice> ;
  noria:resourceProductModel <https://w3id.org/noria/instance/ModelX> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:agentManagesResource <https://w3id.org/noria/instance/SupportTeam> .

<https://w3id.org/noria/instance/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model name for ResourceA."@en ;
  noria:productManufacturedBy <https://w3id.org/noria/instance/ManufacturerY> .

<https://w3id.org/noria/instance/ManufacturerY> a org:Organization ;
  rdfs:label "Network Devices Inc."@en ;
  rdfs:comment "Manufacturer of Model X."@en .

<https://w3id.org/noria/instance/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link DCN-01 to DCN-02"@en ;
  rdfs:comment "Optical fiber link between two core networks."@en ;
  noria:networkLinkId "NL-DCN-01-DCN-02" ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkInstallationDate "2022-03-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://w3id.org/noria/instance/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/instance/ResourceB> .

<https://w3id.org/noria/instance/ResourceB> a noria:Resource ;
  rdfs:label "Core Router 2"@en ;
  noria:resourceLogisticId "SN654321" ;
  noria:resourceHostName "core-router-2" ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkDevice> ;
  noria:resourceProductModel <https://w3id.org/noria/instance/ModelY> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:agentManagesResource <https://w3id.org/noria/instance/SupportTeam> .

<https://w3id.org/noria/instance/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Manufacturer's model name for ResourceB."@en ;
  noria:productManufacturedBy <https://w3id.org/noria/instance/ManufacturerY> .

<https://w3id.org/noria/instance/Event1> a noria:EventRecord ;
  rdfs:label "Interface GigabitEthernet0/0/1 Up"@en ;
  rdfs:comment "Event indicating interface state change to up."@en ;
  noria:loggingTime "2023-10-23T14:30:00"^^xsd:dateTime ;
  noria:logText "Line protocol on Interface GigabitEthernet0/0/1, changed state to up"@en ;
  noria:logOriginatingManagedObject <https://w3id.org/noria/instance/ResourceA> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Major> ;
  noria:alarmProposedRepairAction <https://w3id.org/noria/instance/Action1> .

<https://w3id.org/noria/instance/Action1> a pep:Procedure ;
  rdfs:label "Reset Interface GigabitEthernet0/0/1"@en ;
  rdfs:comment "Procedure to reset the network interface."@en .

<https://w3id.org/noria/instance/ResourceA> noria:structuralObservableOf <https://w3id.org/noria/instance/Event1> .

<https://w3id.org/noria/instance/ResourceB> noria:structuralObservableOf <https://w3id.org/noria/instance/Event1> .

<https://w3id.org/noria/instance/Resource/Router1> a noria:Resource ;
  rdfs:label "Router1"@en ;
  noria:resourceSerialNumber "SN789012" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkDevice> ;
  noria:resourceProductModel <https://w3id.org/noria/instance/ModelZ> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> .

<https://w3id.org/noria/instance/ModelZ> a noria:ProductModel ;
  rdfs:label "Model Z"@en ;
  noria:productManufacturedBy <https://w3id.org/noria/instance/ManufacturerZ> .

<https://w3id.org/noria/instance/ManufacturerZ> a org:Organization ;
  rdfs:label "RouterMakers Ltd."@en .

<https://w3id.org/noria/instance/Event2> a noria:EventRecord ;
  rdfs:label "Resource Router1 Down"@en ;
  rdfs:comment "Event indicating Router1 is down."@en ;
  noria:loggingTime "2023-10-23T14:00:00"^^xsd:dateTime ;
  noria:logText "Router1 has lost power."@en ;
  noria:logOriginatingManagedObject <https://w3id.org/noria/instance/Resource/Router1> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Critical> .

<https://w3id.org/noria/instance/Resource/Router1> noria:structuralObservableOf <https://w3id.org/noria/instance/Event2> .

# Hub node example
<https://w3id.org/noria/instance/HubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://w3id.org/noria/instance/SupportTeam> .

# High-degree node (connected to many resources)
<https://w3id.org/noria/instance/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Core Switch"@en ;
  rdfs:comment "High-degree switch connecting multiple routers and servers."@en ;
  noria:structuralElementDistinguishedName "Switch-01" .

# Connector node
<https://w3id.org/noria/instance/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Connects different network segments."@en ;
  noria:structuralElementDistinguishedName "Connector-01" .

# Intermediary node
<https://w3id.org/noria/instance/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Device"@en ;
  rdfs:comment "Device acting as intermediary in data flow."@en ;
  noria:structuralElementDistinguishedName "Intermediary-01" .

# Super node (aggregates multiple nodes)
<https://w3id.org/noria/instance/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple network components for management."@en ;
  noria:structuralElementDistinguishedName "SuperNode-01" .

# Link between hub and high-degree node
<https://w3id.org/noria/instance/LinkHubHighDegree> a noria:NetworkLink ;
  rdfs:label "Link Hub to High Degree Node"@en ;
  noria:networkLinkId "L-HH-01" ;
  noria:networkLinkType "Ethernet"@en ;
  noria:networkLinkInstallationDate "2023-10-01T09:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://w3id.org/noria/instance/HubNode1> ;
  noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/instance/HighDegreeNode> .

# Dismissed isolated node example (not included as per instruction)