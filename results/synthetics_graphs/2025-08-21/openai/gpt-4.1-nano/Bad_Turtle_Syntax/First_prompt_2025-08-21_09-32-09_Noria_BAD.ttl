@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Network1> a noria:StructuralElement ;
  rdfs:label "Main Data Center Network"@en ;
  rdfs:comment "Core network infrastructure in the main data center."@en ;
  noria:structuralElementDistinguishedName "DCN-01" ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/SupportTeam> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Network> .

<https://w3id.org/noria/instance/SupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team responsible for network infrastructure."@en .

<https://w3id.org/noria/instance/Locus1> a noria:Locus ;
  rdfs:label "Locus in Main Data Center"@en ;
  noria:locusLine "Line: L, Column: 3"@en ;
  noria:locusRow "Row: R"@en .

<https://w3id.org/noria/instance/Router1> a noria:Resource, seas:CommunicationDevice, log:Host ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router in data center."@en ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceHostName "router1.dc.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/SupportTeam> .

<https://w3id.org/noria/instance/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link DC1 to DC2"@en ;
  rdfs:comment "Optical fiber connection between data centers."@en ;
  noria:networkLinkId "NLK-DC1-DC2" ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkInstallationDate "2022-01-15T09:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://w3id.org/noria/instance/Router1> ;
  noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/instance/Router2> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/SupportTeam> .

<https://w3id.org/noria/instance/Router2> a noria:Resource, seas:CommunicationDevice, log:Host ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Backup router in data center."@en ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceHostName "router2.dc.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/SupportTeam> .

<https://w3id.org/noria/instance/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/1"@en ;
  rdfs:comment "GigabitEthernet interface on Router1."@en ;
  noria:networkInterfaceType "physical"@en ;
  noria:networkInterfaceDescription "Main uplink interface"@en ;
  noria:networkInterfaceOf <https://w3id.org/noria/instance/Router1> ;
  noria:networkInterfaceConnects <https://w3id.org/noria/instance/NetworkLink1> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 ;
  noria:networkInterfaceLaserRxOpticalPowerAverage -2.5 ;
  noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
  noria:networkInterfaceLaserRxLowPowerWarningThreshold -4 .

<https://w3id.org/noria/instance/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/2"@en ;
  noria:networkInterfaceType "virtual"@en ;
  noria:networkInterfaceDescription "Backup uplink interface"@en ;
  noria:networkInterfaceOf <https://w3id.org/noria/instance/Router2> ;
  noria:networkInterfaceConnects <https://w3id.org/noria/instance/NetworkLink1> ;
  noria:networkInterfaceRoutingPriorityMetric 200 ;
  noria:networkInterfaceLaserTxOpticalPower -1 ;
  noria:networkInterfaceLaserRxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPowerAverage -1.5 ;
  noria:networkInterfaceLaserRxHighPowerWarningThreshold -0.5 ;
  noria:networkInterfaceLaserRxLowPowerWarningThreshold -3 .

<https://w3id.org/noria/instance/Resource1> a noria:Resource, seas:CommunicationDevice, log:Host ;
  rdfs:label "Server1"@en ;
  rdfs:comment "Application server in data center."@en ;
  noria:resourceSerialNumber "SN789012" ;
  noria:resourceHostName "server1.dc.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/SupportTeam> .

<https://w3id.org/noria/instance/Event1> a noria:EventRecord ;
  rdfs:label "Interface GigabitEthernet0/0/1 Up"@en ;
  rdfs:comment "Interface status change to up."@en ;
  noria:loggingTime "2023-10-01T12:00:00"^^xsd:dateTime ;
  noria:logText "Line protocol on Interface GigabitEthernet0/0/1, changed state to up"@en ;
  noria:logOriginatingManagedObject <https://w3id.org/noria/instance/Router1> ;
  noria:logOriginatingManagementSystem <https://w3id.org/noria/instance/SupportSystem> ;
  noria:logOriginatingAgent <https://w3id.org/noria/instance/Agent1> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Major> ;
  noria:alarmProposedRepairAction <https://w3id.org/noria/instance/RepairAction1> .

<https://w3id.org/noria/instance/Agent1> a foaf:Agent ;
  rdfs:label "Network Engineer Alice"@en ;
  rdfs:comment "Engineer responsible for network devices."@en .

<https://w3id.org/noria/instance/RepairAction1> a pep:Procedure ;
  rdfs:label "Restart Interface"@en ;
  rdfs:comment "Procedure to restart network interface."@en .

<https://w3id.org/noria/instance/SupportSystem> a noria:Application ;
  rdfs:label "Network Monitoring System"@en ;
  rdfs:comment "System that monitors network health."@en .

<https://w3id.org/noria/instance/Resource2> a noria:Resource, seas:CommunicationDevice, log:Host ;
  rdfs:label "Firewall1"@en ;
  rdfs:comment "Firewall device in data center."@en ;
  noria:resourceSerialNumber "SN345678" ;
  noria:resourceHostName "firewall1.dc.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/SupportTeam> .

<https://w3id.org/noria/instance/Event2> a noria:EventRecord ;
  rdfs:label "Firewall Configuration Change"@en ;
  rdfs:comment "Firewall configuration updated."@en ;
  noria:loggingTime "2023-10-02T14:30:00"^^xsd:dateTime ;
  noria:logText "Configuration changed by admin."@en ;
  noria:logOriginatingManagedObject <https://w3id.org/noria/instance/Resource2> ;
  noria:logOriginatingManagementSystem <https://w3id.org/noria/instance/SupportSystem> ;
  noria:logOriginatingAgent <https://w3id.org/noria/instance/Agent1> .

# Hub node example
<https://w3id.org/noria/instance/HubNode> a noria:ManagedElement ;
  rdfs:label "Central Hub Node"@en ;
  rdfs:comment "Main hub node connecting multiple network segments."@en .

# High-degree node example
<https://w3id.org/noria/instance/HighDegreeNode> a noria:ManagedElement ;
  rdfs:label "Core Switch"@en ;
  rdfs:comment "Switch with high connectivity in the network."@en .

# Central node example
<https://w3id.org/noria/instance/CentralNode> a noria:ManagedElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "Switch acting as a central point in data center."@en .

# Connector node example
<https://w3id.org/noria/instance/ConnectorNode> a noria:ManagedElement ;
  rdfs:label "Connector Router"@en ;
  rdfs:comment "Router connecting different network segments."@en .

# Intermediary node example
<https://w3id.org/noria/instance/IntermediaryNode> a noria:ManagedElement ;
  rdfs:label "Intermediate Firewall"@en ;
  rdfs:comment "Firewall acting as intermediary between segments."@en .

# Multiplex node example
<https://w3id.org/noria/instance/MultiplexNode> a noria:ManagedElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "Device multiplexing multiple data streams."@en .

# Super node example
<https://w3id.org/noria/instance/SuperNode> a noria:ManagedElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "Super node aggregating multiple high-degree nodes."@en .

# Relationships linking nodes
<https://w3id.org/noria/instance/HubNode> noria:structuralElementObservable <https://w3id.org/noria/instance/HighDegreeNode> ;
<https://w3id.org/noria/instance/HighDegreeNode> noria:structuralElementObservable <https://w3id.org/noria/instance/CentralNode> ;
<https://w3id.org/noria/instance/CentralNode> noria:structuralElementObservable <https://w3id.org/noria/instance/ConnectorNode> ;
<https://w3id.org/noria/instance/ConnectorNode> noria:structuralElementObservable <https://w3id.org/noria/instance/IntermediaryNode> ;
<https://w3id.org/noria/instance/IntermediaryNode> noria:structuralElementObservable <https://w3id.org/noria/instance/MultiplexNode> ;
<https://w3id.org/noria/instance/MultiplexNode> noria:structuralElementObservable <https://w3id.org/noria/instance/SuperNode> .

# All nodes are linked via relations, no isolated nodes included.