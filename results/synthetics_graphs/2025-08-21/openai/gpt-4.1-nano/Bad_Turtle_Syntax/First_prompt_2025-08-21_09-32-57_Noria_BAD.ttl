@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Network1> a noria:StructuralElement, seas:System ;
  rdfs:label "Main Data Center Network"@en ;
  rdfs:comment "Core network infrastructure in the main data center."@en ;
  noria:structuralElementObservableData <https://w3id.org/noria/instance/Network1#BandwidthUsage> ;
  noria:structuralElementDistinguishedName "DCN-01" ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/SupportTeam> .

<https://w3id.org/noria/instance/Network2> a noria:StructuralElement, seas:System ;
  rdfs:label "Edge Network Segment"@en ;
  rdfs:comment "Edge segment connecting to external partners."@en ;
  noria:structuralElementObservableData <https://w3id.org/noria/instance/Network2#PacketLoss> ;
  noria:structuralElementDistinguishedName "EdgeSeg-02" ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/SupportTeam> .

<https://w3id.org/noria/instance/Router1> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router in the main data center."@en ;
  noria:resourceHostName "core-router-1" ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceLogisticId "LOG-DC1-ROUTER1" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Room314> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/NetworkAdmin> .

<https://w3id.org/noria/instance/Router2> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Edge router connecting to external network."@en ;
  noria:resourceHostName "edge-router-1" ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceLogisticId "LOG-EDGE-01" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Room314> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/NetworkAdmin> .

<https://w3id.org/noria/instance/Link1> a noria:NetworkLink ;
  rdfs:label "Fiber Link DC to Edge"@en ;
  rdfs:comment "Optical fiber link connecting core data center to edge network."@en ;
  noria:networkLinkId "LINK-DC-EDGE-01" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2022-01-15T09:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://w3id.org/noria/instance/Router1> ;
  noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/instance/Router2> .

<https://w3id.org/noria/instance/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/0"@en ;
  rdfs:comment "GigabitEthernet interface on Router1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Uplink interface to core network."@en ;
  noria:networkInterfaceOf <https://w3id.org/noria/instance/Router1> ;
  noria:networkInterfaceConnects <https://w3id.org/noria/instance/Link1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 .

<https://w3id.org/noria/instance/Room314> a noria:Room ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Main server room in Building A."@en .

<https://w3id.org/noria/instance/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Specific location within Room 314."@en ;
  noria:locusLine "L" ;
  noria:locusRow "6" .

<https://w3id.org/noria/instance/SupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team responsible for network infrastructure."@en .

<https://w3id.org/noria/instance/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Lead network administrator responsible for core and edge networks."@en .

<https://w3id.org/noria/instance/ResourceManager> a foaf:Agent ;
  rdfs:label "Resource Management Agent"@en ;
  rdfs:comment "Agent responsible for resource provisioning and management."@en .

<https://w3id.org/noria/instance/Network2> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Edge Switch"@en ;
  rdfs:comment "Switch at the edge network segment."@en ;
  noria:resourceHostName "edge-switch-1" ;
  noria:resourceSerialNumber "SN789012" ;
  noria:resourceLogisticId "LOG-EDGE-SW1" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/switch> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Room314> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/SupportTeam> .

<https://w3id.org/noria/instance/Alarm1> a noria:EventRecord ;
  rdfs:label "Link Down Alarm"@en ;
  rdfs:comment "Alarm indicating fiber link failure."@en ;
  noria:loggingTime "2023-10-01T14:23:00"^^xsd:dateTime ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Major> ;
  noria:alarmProposedRepairAction <https://w3id.org/noria/instance/Resource1#RestartLink> ;
  noria:logText "Fiber link between DC and Edge is down."@en ;
  noria:logOriginatingManagedObject <https://w3id.org/noria/instance/Link1> ;
  noria:logOriginatingManagementSystem <https://w3id.org/noria/instance/NetworkMonitoringSystem> ;
  noria:alarmMitigatedBy <https://w3id.org/noria/instance/Resource/Resource1#RestartLink> .

<https://w3id.org/noria/instance/Resource1#RestartLink> a pep:Procedure ;
  rdfs:label "Restart Fiber Link"@en ;
  rdfs:comment "Procedure to restart the fiber link."@en .

<https://w3id.org/noria/instance/NetworkMonitoringSystem> a noria:Application ;
  rdfs:label "Network Monitoring System"@en ;
  rdfs:comment "System that monitors network links and interfaces."@en .

<https://w3id.org/noria/instance/Resource/Resource1> a noria:Resource ;
  rdfs:label "Fiber Link Resource"@en ;
  rdfs:comment "Physical fiber link resource."@en .

<https://w3id.org/noria/instance/Resource/Resource2> a noria:Resource ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router in data center."@en .

<https://w3id.org/noria/instance/Resource/Resource3> a noria:Resource ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Edge router."@en .

<https://w3id.org/noria/instance/Resource/Resource4> a noria:Resource ;
  rdfs:label "Edge Switch"@en ;
  rdfs:comment "Switch at network edge."@en .

<https://w3id.org/noria/instance/Resource/Resource5> a noria:Resource ;
  rdfs:label "Fiber Link"@en ;
  rdfs:comment "Fiber optic link between core and edge."@en .

# This graph includes hubs (Router1, Router2), high-degree nodes (Router1 connected to multiple interfaces and links), central nodes (Router1), connector nodes (Link1), intermediary nodes (Switch), multiplex nodes (Router1, Router2), and super nodes (Network1, Network2). All nodes are linked with at least one relation, and no isolated nodes are present.