@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/graph1> a owl:NamedIndividual ;
    rdfs:label "Sample Network Topology"@en ;
    rdfs:comment "A created example graph illustrating various node types and relations."@en .

# Hub Node: Central Router
<https://example.com/Router1> a noria:StructuralElement ;
    rdfs:label "Router1"@en ;
    rdfs:comment "Main backbone router serving as a hub in the network."@en ;
    noria:structuralElementDistinguishedName "Router1-DN" .

# High-Degree Node: Data Center Switch
<https://example.com/SwitchDC> a noria:StructuralElement ;
    rdfs:label "Data Center Switch"@en ;
    rdfs:comment "Switch with high connectivity in the data center."@en ;
    noria:structuralElementDistinguishedName "Switch-DC" .

# Connector Node: Virtual Link
<https://example.com/VirtualLink1> a noria:NetworkLink ;
    rdfs:label "Virtual Link 1"@en ;
    rdfs:comment "A virtual connection between Router1 and SwitchDC."@en ;
    noria:networkLinkId "VL-001" .

# Intermediary Node: Firewall
<https://example.com/Firewall1> a noria:StructuralElement ;
    rdfs:label "Firewall"@en ;
    rdfs:comment "Firewall acting as an intermediary between internal network and external."@en ;
    noria:structuralElementDistinguishedName "Firewall-DN" .

# Multiplex Node: Server Cluster
<https://example.com/ServerCluster> a noria:StructuralElement ;
    rdfs:label "Server Cluster"@en ;
    rdfs:comment "A multiplex node representing a cluster of servers."@en ;
    noria:structuralElementDistinguishedName "ServerCluster-DN" .

# Super Node: Data Center
<https://example.com/DataCenter> a noria:StructuralElement ;
    rdfs:label "Data Center"@en ;
    rdfs:comment "Super node representing the entire data center facility."@en ;
    noria:structuralElementDistinguishedName "DataCenter-DN" .

# Connector: Link between Router1 and Firewall
<https://example.com/Link_Router1_Firewall> a noria:NetworkLink ;
    rdfs:label "Link Router1 to Firewall"@en ;
    rdfs:comment "Physical link connecting Router1 to Firewall."@en ;
    noria:networkLinkId "L-001" .

# Intermediary: Connection between Firewall and Server Cluster
<https://example.com/Link_Firewall_ServerCluster> a noria:NetworkLink ;
    rdfs:label "Link Firewall to Server Cluster"@en ;
    rdfs:comment "Logical link between Firewall and Server Cluster."@en ;
    noria:networkLinkId "L-002" .

# High-Degree Node: Application Server
<https://example.com/AppServer> a noria:StructuralElement ;
    rdfs:label "Application Server"@en ;
    rdfs:comment "Server hosting critical application services."@en ;
    noria:structuralElementDistinguishedName "AppServer-DN" .

# Hub Node: Load Balancer
<https://example.com/LoadBalancer> a noria:StructuralElement ;
    rdfs:label "Load Balancer"@en ;
    rdfs:comment "Distributes traffic among application servers."@en ;
    noria:structuralElementDistinguishedName "LoadBalancer-DN" .

# Relationships
<https://example.com/Router1> noria:structuralElementObservable noria:structuralElementObservableOf ;
<https://example.com/SwitchDC> noria:structuralElementObservable noria:structuralElementObservableOf ;
<https://example.com/Firewall1> noria:structuralElementObservable noria:structuralElementObservableOf ;
<https://example.com/ServerCluster> noria:structuralElementObservable noria:structuralElementObservableOf ;
<https://example.com/DataCenter> noria:structuralElementObservable noria:structuralElementObservableOf ;
<https://example.com/AppServer> noria:structuralElementObservable noria:structuralElementObservableOf ;
<https://example.com/LoadBalancer> noria:structuralElementObservable noria:structuralElementObservableOf .

# Link relations
<https://example.com/Link_Router1_Firewall> noria:structuralElementObservable structuralElementObservableOf ;
<https://example.com/Link_Firewall_ServerCluster> noria:structuralElementObservable structuralElementObservableOf .

# Link connections
<https://example.com/Link_Router1_Firewall> noria:structuralElementObservable structuralElementObservableOf ;
<https://example.com/Link_Firewall_ServerCluster> noria:structuralElementObservable structuralElementObservableOf .

# Hub and high-degree node linkage
<https://example.com/Router1> noria:structuralElementObservable noria:structuralElementObservableOf ;
<https://example.com/SwitchDC> noria:structuralElementObservable noria:structuralElementObservableOf ;
<https://example.com/LoadBalancer> noria:structuralElementObservable noria:structuralElementObservableOf .

# Super node encompassing all
<https://example.com/DataCenter> noria:structuralElementObservable noria:structuralElementObservableOf .

# Additional relations to illustrate node types
<https://example.com/Router1> noria:elementManagedBy <https://example.com/NetworkAdmin> ;
<https://example.com/Firewall1> noria:elementManagedBy <https://example.com/NetworkAdmin> ;
<https://example.com/SwitchDC> noria:elementManagedBy <https://example.com/NetworkAdmin> ;
<https://example.com/AppServer> noria:elementManagedBy <https://example.com/ITSupport> ;
<https://example.com/LoadBalancer> noria:elementManagedBy <https://example.com/ITSupport> .

# Labels for admin entities
<https://example.com/NetworkAdmin> a org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
    rdfs:label "IT Support Team"@en ;
    rdfs:comment "Team responsible for application and server support."@en .

# Dismiss isolated nodes: all nodes are linked via relations, no isolated nodes present.