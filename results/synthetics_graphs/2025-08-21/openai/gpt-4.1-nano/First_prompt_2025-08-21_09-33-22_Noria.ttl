@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Graph1> a owl:Ontology ;
    rdfs:label "Sample Noria-based Knowledge Graph"@en .

# Hub Node: Central Router
<https://example.com/Router1> a noria:StructuralElement ;
    rdfs:label "Main Router"@en ;
    rdfs:comment "Core router acting as a hub in the network."@en ;
    noria:structuralElementDistinguishedName "Router1-DN" ;
    noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

# High-Degree Node: Data Center
<https://example.com/DataCenter> a noria:StructuralElement ;
    rdfs:label "Primary Data Center"@en ;
    rdfs:comment "Data center with high connectivity."@en ;
    noria:structuralElementDistinguishedName "DataCenter-01" ;
    noria:structuralElementObservableData <https://example.com/PowerUsage> .

# Power Usage Observable (High-Degree Node)
<https://example.com/PowerUsage> a noria:StructuralObservable ;
    rdfs:label "Power Consumption"@en ;
    rdfs:comment "Power consumption metric for Data Center."@en ;
    noria:structuralElementObservableData "3500 kW"^^xsd:string .

# Connector Node: Link between Router and Data Center
<https://example.com/Link1> a noria:NetworkLink ;
    rdfs:label "Fiber Link Router1 to DataCenter"@en ;
    rdfs:comment "Optical fiber connection between Router1 and DataCenter."@en ;
    noria:networkLinkId "Link-DC-Router1" ;
    noria:networkLinkInstallationDate "2022-06-15T10:00:00Z"^^xsd:dateTime .

# Connects Network Interface of Router to Link
<https://example.com/Router1-eth0> a noria:NetworkInterface ;
    rdfs:label "Router1 Ethernet0"@en ;
    rdfs:comment "Ethernet interface of Router1."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceConnects <https://example.com/Link1> ;
    noria:networkInterfaceOf <https://example.com/Router1> .

# Connects Network Interface of Data Center to Link
<https://example.com/DC-eth1> a noria:NetworkInterface ;
    rdfs:label "DataCenter Ethernet1"@en ;
    rdfs:comment "Ethernet interface of Data Center."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceConnects <https://example.com/Link1> ;
    noria:networkInterfaceOf <https://example.com/DataCenter> .

# Intermediary Node: Event Record for Link Failure
<https://example.com/Event1> a noria:EventRecord ;
    rdfs:label "Link Failure Event"@en ;
    rdfs:comment "Event indicating fiber link failure."@en ;
    noria:loggingTime "2023-04-10T14:23:00Z"^^xsd:dateTime ;
    noria:logText "Fiber link between Router1 and DataCenter is down."@en ;
    noria:logOriginatingManagedObject <https://example.com/Link1> ;
    noria:logOriginatingManagementSystem <https://example.com/NMS> ;
    noria:alarmSeverity <https://example.com/CriticalSeverity> .

# Critical Severity Concept
<https://example.com/CriticalSeverity> a skos:Concept ;
    rdfs:label "Critical"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Super Node: Network Operations Team
<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network management."@en .

# Connector: Link between Event and Resource
<https://example.com/Event1-Resource> a owl:ObjectProperty ;
    rdfs:label "relates to Resource"@en ;
    rdfs:domain <https://example.com/Event1> ;
    rdfs:range <https://example.com/Link1> .

# High-Degree Node: Monitoring System
<https://example.com/NMS> a noria:Application ;
    rdfs:label "Network Management System"@en ;
    rdfs:comment "System monitoring network events."@en .

# Intermediary Node: Power Usage Alert
<https://example.com/PowerAlert> a noria:TroubleTicket ;
    rdfs:label "Power Usage Alert"@en ;
    rdfs:comment "Alert for power consumption exceeding threshold."@en ;
    noria:troubleTicketSeverity <https://example.com/MajorSeverity> ;
    noria:troubleTicketImpacts <https://example.com/DataCenter> .

# Major Severity Concept
<https://example.com/MajorSeverity> a skos:Concept ;
    rdfs:label "Major"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Connector: Link between Power Alert and Data Center
<https://example.com/PowerAlert-Impact> a owl:ObjectProperty ;
    rdfs:label "impacts Resource"@en ;
    rdfs:domain <https://example.com/PowerAlert> ;
    rdfs:range <https://example.com/DataCenter> .

# Super Node: Resource Owner (e.g., Data Center Manager)
<https://example.com/DataCenterManager> a org:OrganizationalUnit ;
    rdfs:label "Data Center Management"@en .

# Connector: Link between Resource and Owner
<https://example.com/DataCenter-ManagedBy> a owl:ObjectProperty ;
    rdfs:label "managed by"@en ;
    rdfs:domain <https://example.com/DataCenter> ;
    rdfs:range <https://example.com/DataCenterManager> .

# Intermediary Node: Incident Response
<https://example.com/IncidentResponse> a noria:ProceduralElement ;
    rdfs:label "Incident Response Procedure"@en ;
    rdfs:comment "Procedure for handling network link failures."@en .

# Link event to procedure
<https://example.com/Event1-Response> a owl:ObjectProperty ;
    rdfs:label "related to Procedure"@en ;
    rdfs:domain <https://example.com/Event1> ;
    rdfs:range <https://example.com/IncidentResponse> .

# Dismiss isolated nodes: All nodes are linked via at least one relation, fulfilling the requirement.