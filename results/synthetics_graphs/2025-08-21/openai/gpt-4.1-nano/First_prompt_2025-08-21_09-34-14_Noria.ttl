@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central switch."@en ;
  noria:structuralElementObservableData <https://example.com/ConnectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center connecting servers and storage."@en ;
  noria:structuralElementObservableData <https://example.com/TrafficVolume> ;
  noria:structuralElementObservable <https://example.com/TrafficObservable> ;
  noria:elementManagedBy <https://example.com/DataCenterOps> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking external network to internal resources."@en ;
  noria:structuralElementObservableData <https://example.com/FirewallStatus> ;
  noria:structuralElementObservable <https://example.com/FirewallStatusObservable> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservableData <https://example.com/LoadDistributionRate> ;
  noria:structuralElementObservable <https://example.com/LoadDistributionObservable> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/StreamCount> ;
  noria:structuralElementObservable <https://example.com/StreamObservable> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An advanced super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/SuperNodeCapacity> ;
  noria:structuralElementObservable <https://example.com/SuperNodeCapacityObservable> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/DataCenterOps> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en ;
  rdfs:comment "Team managing data center network resources."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security infrastructure."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Support team for internal IT resources."@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "Team managing network devices and links."@en .

<https://example.com/ConnectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at the node."@en .

<https://example.com/TrafficVolume> a noria:StructuralObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of traffic passing through the node."@en .

<https://example.com/TrafficObservable> a noria:StructuralObservable ;
  rdfs:label "Traffic Observable"@en ;
  rdfs:comment "Observable representing traffic metrics."@en .

<https://example.com/FirewallStatus> a noria:StructuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Current status of the firewall."@en .

<https://example.com/FirewallStatusObservable> a noria:StructuralObservable ;
  rdfs:label "Firewall Status Observable"@en ;
  rdfs:comment "Observable for firewall operational status."@en .

<https://example.com/LoadDistributionRate> a noria:StructuralObservable ;
  rdfs:label "Load Distribution Rate"@en ;
  rdfs:comment "Rate at which load is distributed."@en .

<https://example.com/LoadDistributionObservable> a noria:StructuralObservable ;
  rdfs:label "Load Distribution Observable"@en ;
  rdfs:comment "Observable for load balancing metrics."@en .

<https://example.com/SuperNodeCapacity> a noria:StructuralObservable ;
  rdfs:label "Super Node Capacity"@en ;
  rdfs:comment "Capacity of the super node."@en .

<https://example.com/SuperNodeCapacityObservable> a noria:StructuralObservable ;
  rdfs:label "Super Node Capacity Observable"@en ;
  rdfs:comment "Observable for super node capacity."@en .