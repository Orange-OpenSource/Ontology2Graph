@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Hub Node: Central Resource (Main Data Center)
<https://example.com/Resource/DataCenter1> a noria:Resource ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "The primary data center hosting core network infrastructure."@en ;
  noria:resourceLogisticId "DC-001" ;
  noria:locatedAtLocus <https://example.com/Locus/Room314> ;
  noria:resourceHostName "dc1.mainnet.org" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/data-center> ;
  noria:resourceSerialNumber "SN-DC-001" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/operational> ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelX> ;
  noria:resourceManagedBy <https://example.com/Org/ITSupport> .

# High-Degree Node: Virtual Server
<https://example.com/Resource/VirtualServer1> a noria:Resource ;
  rdfs:label "Virtual Server 1"@en ;
  rdfs:comment "A virtual server hosting critical applications."@en ;
  noria:resourceLogisticId "VS-1001" ;
  noria:locatedAtLocus <https://example.com/Locus/ServerRack5> ;
  noria:resourceHostName "vs1.virtual.org" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtual-server> ;
  noria:resourceSerialNumber "SN-VS-1001" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/operational> ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelY> ;
  noria:resourceManagedBy <https://example.com/Org/CloudOps> .

# Connector Node: Network Interface of Data Center
<https://example.com/NetworkInterface/eth0> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Data Center."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "GigabitEthernet0/0/1"@en ;
  noria:networkInterfaceOf <https://example.com/Resource/DataCenter1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink/Link1> ;
  noria:networkInterfaceRoutingPriorityMetric 100 .

<https://example.com/NetworkInterface/eth1> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Backup network interface of Virtual Server."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "Virtual NIC for load balancing."@en ;
  noria:networkInterfaceOf <https://example.com/Resource/VirtualServer1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink/Link2> ;
  noria:networkInterfaceRoutingPriorityMetric 200 .

# Intermediary Node: Network Link between Data Center and Backup Link
<https://example.com/NetworkLink/Link1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber connection between Data Center and Backup Site."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "optical fiber" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource/DataCenter1> ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource/BackupSite> .

<https://example.com/NetworkLink/Link2> a noria:NetworkLink ;
  rdfs:label "Link2"@en ;
  rdfs:comment "Virtual link for load balancing."@en ;
  noria:networkLinkId "NL-002" ;
  noria:networkLinkType "virtual" ;
  noria:networkLinkInstallationDate "2021-01-20T09:30:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource/VirtualServer1> ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource/DataCenter1> .

# Super Node: Application System
<https://example.com/Application/CRMSystem> a noria:Application ;
  rdfs:label "Customer Relationship Management System"@en ;
  rdfs:comment "Core application for managing customer data."@en ;
  noria:applicationModelIdentifier "CRM-Model-2023" ;
  noria:applicationNumericalIdentifier 101 ;
  noria:applicationShortIdentifier "CRM" ;
  noria:applicationType <https://kos/application/type/customer-facing> ;
  noria:applicationBusinessImportance <https://kos/application/business-importance/high> ;
  noria:applicationFunctionalDomain "Customer Management"@en ;
  noria:applicationFunctionalSubDomain "Sales and Support"@en ;
  noria:resourceForApplication <https://example.com/Resource/CRMServer> ;
  noria:applicationSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
  noria:applicationSlaLevelDate "2023-07-01T00:00:00Z"^^xsd:dateTime ;
  noria:applicationHotlineEnabled true .

<https://example.com/Resource/CRMServer> a noria:Resource ;
  rdfs:label "CRM Server"@en ;
  rdfs:comment "Server hosting CRM application."@en ;
  noria:resourceLogisticId "SRV-CRM-01" ;
  noria:locatedAtLocus <https://example.com/Locus/ServerRoom314> ;
  noria:resourceHostName "crm.server.org" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/server> ;
  noria:resourceSerialNumber "SN-CRM-0001" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/operational> ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelZ> ;
  noria:resourceManagedBy <https://example.com/Org/ITSupport> .

# Connector Node: Event Record (Incident)
<https://example.com/EventRecord/Incident123> a noria:EventRecord ;
  rdfs:label "Incident 123"@en ;
  rdfs:comment "Network interface down detected."@en ;
  noria:loggingTime "2023-10-01T14:22:00Z"^^xsd:dateTime ;
  noria:logText "Interface ge-0/0/1 on Router1 is down."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource/Router1> ;
  noria:logOriginatingManagementSystem <https://example.com/Application/NMS> ;
  noria:alarmSeverity <https://skos.org/Notification/Severity/Major> ;
  noria:alarmProposedRepairAction <https://example.com/Procedure/RestartInterface> ;
  noria:alarmMitigatedBy <https://example.com/Procedure/ResetInterface> .

<https://example.com/Procedure/RestartInterface> a noria:OperationPlan ;
  rdfs:label "Restart Interface"@en ;
  rdfs:comment "Procedure to restart network interface."@en ;
  noria:operationPlanIdentifier "OP-RESTART-INTF" ;
  noria:operationPlanPreCondition <https://example.com/ActionPreCondition/InterfaceDown> ;
  noria:operationPlanPostCondition <https://example.com/ActionPostCondition/InterfaceRestored> .

<https://example.com/ActionPreCondition/InterfaceDown> a noria:ActionPreCondition ;
  rdfs:label "Interface Down"@en ;
  rdfs:comment "Interface is currently down."@en .

<https://example.com/ActionPostCondition/InterfaceRestored> a noria:ActionPostCondition ;
  rdfs:label "Interface Restored"@en ;
  rdfs:comment "Interface is operational again."@en .

# Intermediary Node: Change Request
<https://example.com/ChangeRequest/CR-2023-10-01> a noria:ChangeRequest ;
  rdfs:label "Network Interface Configuration Change"@en ;
  rdfs:comment "Change request to update network interface configuration."@en ;
  noria:changeRequestId "CR-2023-10-01" ;
  noria:changeRequestCreationDateTime "2023-10-01T15:00:00Z"^^xsd:dateTime ;
  noria:changeRequestDescription "Update configuration of ge-0/0/1 to fix interface down issue."@en ;
  noria:changeRequestImpact <https://example.com/Resource/Router1> ;
  noria:changeRequestStatusCurrent <https://skos.org/noria/status/Completed> ;
  noria:changeRequestInitiatorParty <https://example.com/Org/NetworkTeam> ;
  noria:changeRequestChangeCause "Configuration error"@en ;
  noria:changeRequestActualStartTime "2023-10-02T09:00:00Z"^^xsd:dateTime ;
  noria:changeRequestActualEndTime "2023-10-02T11:30:00Z"^^xsd:dateTime .

# Super Node: Organization
<https://example.com/Org/ITSupport> a org:Organization ;
  rdfs:label "IT Support Organization"@en ;
  rdfs:comment "Organization responsible for IT infrastructure support."@en .

<https://example.com/Org/CloudOps> a org:Organization ;
  rdfs:label "Cloud Operations"@en ;
  rdfs:comment "Team managing cloud infrastructure."@en .

<https://example.com/Org/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

# End of graph