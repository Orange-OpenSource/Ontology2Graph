@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch 1"@en ;
  rdfs:comment "High-degree node with many connections in the data center."@en ;
  noria:structuralElementObservable <https://example.com/observable/PortStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode2> a noria:StructuralElement ;
  rdfs:label "Core Router A"@en ;
  rdfs:comment "High-degree core router handling multiple links."@en ;
  noria:structuralElementObservable <https://example.com/observable/TrafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Switch"@en ;
  rdfs:comment "A central node connecting various subnetworks."@en ;
  noria:structuralElementObservable <https://example.com/observable/LinkStatus> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "Connector node acting as a firewall between segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/FirewallStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Intermediary node balancing load across servers."@en ;
  noria:structuralElementObservable <https://example.com/observable/LoadDistribution> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "Device multiplexing multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/DataStreamQuality> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Super node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable/SuperNodeLoad> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Support team for IT infrastructure."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security and firewall management."@en .

<https://example.com/NetworkManagement> a org:OrganizationalUnit ;
  rdfs:label "Network Management"@en ;
  rdfs:comment "Team overseeing overall network performance."@en .

<https://example.com/observable/PortStatus> a noria:StructuralObservable ;
  rdfs:label "Port Status"@en ;
  rdfs:comment "Status of network ports (up/down)."@en .

<https://example.com/observable/TrafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/observable/LinkStatus> a noria:StructuralObservable ;
  rdfs:label "Link Status"@en ;
  rdfs:comment "Status of network links."@en .

<https://example.com/observable/FirewallStatus> a noria:StructuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Operational status of firewall."@en .

<https://example.com/observable/LoadDistribution> a noria:StructuralObservable ;
  rdfs:label "Load Distribution"@en ;
  rdfs:comment "Distribution of load across servers."@en .

<https://example.com/observable/DataStreamQuality> a noria:StructuralObservable ;
  rdfs:label "Data Stream Quality"@en ;
  rdfs:comment "Quality metrics of data streams."@en .

<https://example.com/observable/SuperNodeLoad> a noria:StructuralObservable ;
  rdfs:label "Super Node Load"@en ;
  rdfs:comment "Aggregate load on super node."@en .