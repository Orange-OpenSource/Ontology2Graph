  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:elementManagedBy <https://group.example.com/teams/SecurityTeam> ;
  noria:resourceSerialNumber "SN-FW-2023-045" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/type#Firewall> ] ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus2> .

<https://w3id.org/noria/instance/Locus2> a noria:Locus ;
  rdfs:label "Rack 5, Slot 1"@en ;
  rdfs:comment "Position of the firewall within the server rack."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:locusLine "Line:5" ;
  noria:locusRow "Row:1" .

<https://group.example.com/teams/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security infrastructure."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://w3id.org/noria/instance/Link1> a noria:NetworkLink ;
  rdfs:label "Fiber Link DC1 to DC2"@en ;
  rdfs:comment "Optical fiber connection between data centers."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:networkLinkId "LINK-DC1-DC2-001" ;
  noria:networkLinkType "Optical Fiber" ;
