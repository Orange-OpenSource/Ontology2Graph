  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/type#Switch> ] ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus3> .

<https://w3id.org/noria/instance/Locus3> a noria:Locus ;
  rdfs:label "Rack 8, Slot 2"@en ;
