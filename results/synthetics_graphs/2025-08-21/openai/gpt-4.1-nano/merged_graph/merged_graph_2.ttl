  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:elementManagedBy <https://group.example.com/teams/NetworkOps> ;
  noria:structuralElementDistinguishedName "Switch-DC1-Core" ;
  noria:resourceHostName "core-switch-01.datacenter.local" ;
  noria:resourceLogisticId "LOG-DC1-CORE-01" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/type#Switch> ] ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> .

