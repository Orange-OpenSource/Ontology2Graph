<https://group.example.com/teams/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://w3id.org/noria/instance/Event1> a noria:EventRecord ;
  rdfs:label "Link Failure Event"@en ;
  rdfs:comment "Detected failure on fiber link between DC1 and DC2."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:logText "Fiber link between DC1 and DC2 is down." ;
  noria:loggingTime "2024-03-15T14:30:00Z"^^xsd:dateTime ;
  noria:logOriginatingManagedObject <https://w3id.org/noria/instance/Link1> ;
  noria:logOriginatingManagementSystem <https://group.example.com/teams/NetworkOps> ;
  noria:alarmSeverity [ a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; skos:hasTopConcept <Notification/Severity/Critical> ] .

<https://w3id.org/noria/instance/Event2> a noria:EventRecord ;
  rdfs:label "Resource Overload"@en ;
  rdfs:comment "High CPU utilization detected on core switch."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:logText "CPU utilization at 95%." ;
  noria:loggingTime "2024-03-15T15:00:00Z"^^xsd:dateTime ;
  noria:logOriginatingManagedObject <https://w3id.org/noria/instance/Network1> ;
  noria:logOriginatingManagementSystem <https://group.example.com/teams/NetworkOps> ;
  noria:alarmSeverity [ a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; skos:hasTopConcept <Notification/Severity/Major> ] .

<https://w3id.org/noria/instance/Service1> a noria:Application ;
  rdfs:label "Customer Portal"@en ;
  rdfs:comment "Web portal for customer interactions."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:applicationModelIdentifier "APP-CP-001" ;
  noria:applicationType [ a skos:Concept ; skos:inScheme <kos/application/type> ; skos:hasTopConcept <kos/application/type/customer-facing> ] ;
  noria:applicationBusinessImportance [ a skos:Concept ; skos:inScheme <kos/application/business-importance> ; skos:hasTopConcept <kos/application/importance/high> ] ;
  noria:resourceForApplication <https://w3id.org/noria/instance/Resource2> .

<https://w3id.org/noria/instance/Service2> a noria:Application ;
  rdfs:label "Internal Monitoring System"@en ;
  rdfs:comment "System for internal network monitoring."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:applicationModelIdentifier "APP-MON-002" ;
  noria:applicationType [ a skos:Concept ; skos:inScheme <kos/application/type> ; skos:hasTopConcept <kos/application/type/internal-monitoring> ] ;
  noria:applicationBusinessImportance [ a skos:Concept ; skos:inScheme <kos/application/business-importance> ; skos:hasTopConcept <kos/application/importance/medium> ] ;
  noria:resourceForApplication <https://w3id.org/noria/instance/Resource1> .

<https://w3id.org/noria/instance/TroubleTicket1> a noria:TroubleTicket ;
  rdfs:label "Link Down between DC1 and DC2"@en ;
  rdfs:comment "Customer reports link failure affecting data transfer."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity#Major> ;
  noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type#Failure> ;
  noria:troubleTicketUrgency <https://w3id.org/noria/kos/TroubleTicket/urgency#Immediate> ;
  noria:troubleTicketDetectionDateTime "2024-03-15T14:30:00Z"^^xsd:dateTime ;
  noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status#InProgress> ;
  noria:troubleTicketRelatedResource <https://w3id.org/noria/instance/Link1> ;
  noria:troubleTicketImpacts <https://w3id.org/noria/instance/Service1> ;
  noria:troubleTicketRelatedParty <https://group.example.com/teams/NetworkOps> .

<https://w3id.org/noria/instance/TroubleTicket2> a noria:TroubleTicket ;
  rdfs:label "High CPU Usage on Core Switch"@en ;
  rdfs:comment "Detected high CPU load on core switch, potential overload."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity#Major> ;
  noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type#Performance> ;
  noria:troubleTicketUrgency <https://w3id.org/noria/kos/TroubleTicket/urgency#Immediate> ;
  noria:troubleTicketDetectionDateTime "2024-03-15T15:00:00Z"^^xsd:dateTime ;
  noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status#InProgress> ;
  noria:troubleTicketRelatedResource <https://w3id.org/noria/instance/Resource1> ;
  noria:troubleTicketImpacts <https://w3id.org/noria/instance/Service2> ;
  noria:troubleTicketRelatedParty <https://group.example.com/teams/NetworkOps> .

# End of graph

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central switch."@en ;
  noria:structuralElementObservableData <https://example.com/ConnectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center connecting servers and storage."@en ;
  noria:structuralElementObservableData <https://example.com/TrafficVolume> ;
  noria:structuralElementObservable <https://example.com/TrafficObservable> ;
  noria:elementManagedBy <https://example.com/DataCenterOps> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking external network to internal resources."@en ;
  noria:structuralElementObservableData <https://example.com/FirewallStatus> ;
  noria:structuralElementObservable <https://example.com/FirewallStatusObservable> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservableData <https://example.com/LoadDistributionRate> ;
  noria:structuralElementObservable <https://example.com/LoadDistributionObservable> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/StreamCount> ;
  noria:structuralElementObservable <https://example.com/StreamObservable> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An advanced super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/SuperNodeCapacity> ;
  noria:structuralElementObservable <https://example.com/SuperNodeCapacityObservable> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/DataCenterOps> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en ;
  rdfs:comment "Team managing data center network resources."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security infrastructure."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Support team for internal IT resources."@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "Team managing network devices and links."@en .

<https://example.com/ConnectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at the node."@en .

<https://example.com/TrafficVolume> a noria:StructuralObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of traffic passing through the node."@en .

<https://example.com/TrafficObservable> a noria:StructuralObservable ;
  rdfs:label "Traffic Observable"@en ;
  rdfs:comment "Observable representing traffic metrics."@en .

<https://example.com/FirewallStatus> a noria:StructuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Current status of the firewall."@en .

<https://example.com/FirewallStatusObservable> a noria:StructuralObservable ;
  rdfs:label "Firewall Status Observable"@en ;
  rdfs:comment "Observable for firewall operational status."@en .

<https://example.com/LoadDistributionRate> a noria:StructuralObservable ;
  rdfs:label "Load Distribution Rate"@en ;
  rdfs:comment "Rate at which load is distributed."@en .

<https://example.com/LoadDistributionObservable> a noria:StructuralObservable ;
  rdfs:label "Load Distribution Observable"@en ;
  rdfs:comment "Observable for load balancing metrics."@en .

<https://example.com/SuperNodeCapacity> a noria:StructuralObservable ;
  rdfs:label "Super Node Capacity"@en ;
  rdfs:comment "Capacity of the super node."@en .

<https://example.com/SuperNodeCapacityObservable> a noria:StructuralObservable ;
  rdfs:label "Super Node Capacity Observable"@en ;
  rdfs:comment "Observable for super node capacity."@en .

<https://w3id.org/noria/instance/Graph1> a owl:Ontology ;
    rdfs:label "Sample Noria-based Knowledge Graph"@en .

# Hub Node: Central Router
<https://example.com/Router1> a noria:StructuralElement ;
    rdfs:label "Main Router"@en ;
    rdfs:comment "Core router acting as a hub in the network."@en ;
    noria:structuralElementDistinguishedName "Router1-DN" ;
    noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

# High-Degree Node: Data Center
<https://example.com/DataCenter> a noria:StructuralElement ;
    rdfs:label "Primary Data Center"@en ;
    rdfs:comment "Data center with high connectivity."@en ;
    noria:structuralElementDistinguishedName "DataCenter-01" ;
    noria:structuralElementObservableData <https://example.com/PowerUsage> .

# Power Usage Observable (High-Degree Node)
<https://example.com/PowerUsage> a noria:StructuralObservable ;
    rdfs:label "Power Consumption"@en ;
    rdfs:comment "Power consumption metric for Data Center."@en ;
    noria:structuralElementObservableData "3500 kW"^^xsd:string .

# Connector Node: Link between Router and Data Center
<https://example.com/Link1> a noria:NetworkLink ;
    rdfs:label "Fiber Link Router1 to DataCenter"@en ;
    rdfs:comment "Optical fiber connection between Router1 and DataCenter."@en ;
    noria:networkLinkId "Link-DC-Router1" ;
    noria:networkLinkInstallationDate "2022-06-15T10:00:00Z"^^xsd:dateTime .

# Connects Network Interface of Router to Link
<https://example.com/Router1-eth0> a noria:NetworkInterface ;
    rdfs:label "Router1 Ethernet0"@en ;
    rdfs:comment "Ethernet interface of Router1."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceConnects <https://example.com/Link1> ;
    noria:networkInterfaceOf <https://example.com/Router1> .

# Connects Network Interface of Data Center to Link
<https://example.com/DC-eth1> a noria:NetworkInterface ;
    rdfs:label "DataCenter Ethernet1"@en ;
    rdfs:comment "Ethernet interface of Data Center."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceConnects <https://example.com/Link1> ;
    noria:networkInterfaceOf <https://example.com/DataCenter> .

# Intermediary Node: Event Record for Link Failure
<https://example.com/Event1> a noria:EventRecord ;
    rdfs:label "Link Failure Event"@en ;
    rdfs:comment "Event indicating fiber link failure."@en ;
    noria:loggingTime "2023-04-10T14:23:00Z"^^xsd:dateTime ;
    noria:logText "Fiber link between Router1 and DataCenter is down."@en ;
    noria:logOriginatingManagedObject <https://example.com/Link1> ;
    noria:logOriginatingManagementSystem <https://example.com/NMS> ;
    noria:alarmSeverity <https://example.com/CriticalSeverity> .

# Critical Severity Concept
<https://example.com/CriticalSeverity> a skos:Concept ;
    rdfs:label "Critical"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Super Node: Network Operations Team
<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network management."@en .

# Connector: Link between Event and Resource
<https://example.com/Event1-Resource> a owl:ObjectProperty ;
    rdfs:label "relates to Resource"@en ;
    rdfs:domain <https://example.com/Event1> ;
    rdfs:range <https://example.com/Link1> .

# High-Degree Node: Monitoring System
<https://example.com/NMS> a noria:Application ;
    rdfs:label "Network Management System"@en ;
    rdfs:comment "System monitoring network events."@en .

# Intermediary Node: Power Usage Alert
<https://example.com/PowerAlert> a noria:TroubleTicket ;
    rdfs:label "Power Usage Alert"@en ;
    rdfs:comment "Alert for power consumption exceeding threshold."@en ;
    noria:troubleTicketSeverity <https://example.com/MajorSeverity> ;
    noria:troubleTicketImpacts <https://example.com/DataCenter> .

# Major Severity Concept
<https://example.com/MajorSeverity> a skos:Concept ;
    rdfs:label "Major"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Connector: Link between Power Alert and Data Center
<https://example.com/PowerAlert-Impact> a owl:ObjectProperty ;
    rdfs:label "impacts Resource"@en ;
    rdfs:domain <https://example.com/PowerAlert> ;
    rdfs:range <https://example.com/DataCenter> .

# Super Node: Resource Owner (e.g., Data Center Manager)
<https://example.com/DataCenterManager> a org:OrganizationalUnit ;
    rdfs:label "Data Center Management"@en .

# Connector: Link between Resource and Owner
<https://example.com/DataCenter-ManagedBy> a owl:ObjectProperty ;
    rdfs:label "managed by"@en ;
    rdfs:domain <https://example.com/DataCenter> ;
    rdfs:range <https://example.com/DataCenterManager> .

# Intermediary Node: Incident Response
<https://example.com/IncidentResponse> a noria:ProceduralElement ;
    rdfs:label "Incident Response Procedure"@en ;
    rdfs:comment "Procedure for handling network link failures."@en .

# Link event to procedure
<https://example.com/Event1-Response> a owl:ObjectProperty ;
    rdfs:label "related to Procedure"@en ;
    rdfs:domain <https://example.com/Event1> ;
    rdfs:range <https://example.com/IncidentResponse> .

