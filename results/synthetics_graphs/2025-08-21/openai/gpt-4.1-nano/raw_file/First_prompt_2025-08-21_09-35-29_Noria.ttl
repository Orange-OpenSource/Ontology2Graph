@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Network1> a noria:StructuralElement ;
    rdfs:label "Main Data Center Network"@en ;
    rdfs:comment "Core network infrastructure in the main data center."@en ;
    noria:structuralElementDistinguishedName "DCN-01" ;
    noria:resourceManagedBy <https://example.com/org/NetworkOps> ;
    noria:locatedAtLocus <https://example.com/locus/ServerRoom314> ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Network> .

<https://example.com/org/NetworkOps> a org:Organization ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network management."@en .

<https://example.com/locus/ServerRoom314> a noria:Locus ;
    rdfs:label "Server Room 314"@en ;
    rdfs:comment "Main server room on the 3rd floor."@en .

<https://w3id.org/noria/instance/Resource2> a noria:Resource ;
    rdfs:label "Router1"@en ;
    rdfs:comment "Core router in the main data center."@en ;
    noria:resourceSerialNumber "SN123456" ;
    noria:resourceHostName "router1.dc.example.com" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:locatedAtLocus <https://example.com/locus/ServerRoom314> ;
    noria:resourceProductModel <https://example.com/model/ModelX> ;
    noria:resourceManagedBy <https://example.com/org/NetworkOps> .

<https://example.com/model/ModelX> a noria:ProductModel ;
    rdfs:label "Model X"@en ;
    rdfs:comment "High-performance router model X."@en ;
    noria:productManufacturedBy <https://example.com/org/RouterMakers> .

<https://example.com/org/RouterMakers> a org:Organization ;
    rdfs:label "Router Manufacturers Inc."@en ;
    rdfs:comment "Manufacturer of Model X routers."@en .

<https://w3id.org/noria/instance/Interface1> a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1"@en ;
    rdfs:comment "Main uplink interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink port for external connection."@en ;
    noria:networkInterfaceOperationalStatus [ a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; skos:hasTopConcept <https://w3id.org/noria/kos/OperationalState/Up> ] ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -2.5 ;
    noria:networkInterfaceConnects <https://w3id.org/noria/instance/Link1> ;
    noria:networkInterfaceOf <https://w3id.org/noria/instance/Resource2> .

<https://w3id.org/noria/instance/Link1> a noria:NetworkLink ;
    rdfs:label "FiberLink-01"@en ;
    rdfs:comment "Optical fiber link between Router1 and Switch1."@en ;
    noria:networkLinkId "LINK-001" ;
    noria:networkLinkType "optical fiber" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
    noria:networkLinkTerminationResource <https://example.com/resource/Switch1> ;
    noria:networkLinkTerminationResourceOrigin <https://example.com/resource/Router1> .

<https://example.com/resource/Switch1> a noria:Resource ;
    rdfs:label "Switch1"@en ;
    rdfs:comment "Aggregation switch in the main data center."@en ;
    noria:resourceSerialNumber "SN654321" ;
    noria:resourceHostName "switch1.dc.example.com" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
    noria:locatedAtLocus <https://example.com/locus/ServerRoom314> ;
    noria:resourceManagedBy <https://example.com/org/NetworkOps> .

<https://example.com/locus/ServerRoom314> a noria:Locus ;
    rdfs:label "Server Room 314"@en ;
    rdfs:comment "Main server room on the 3rd floor."@en .

<https://w3id.org/noria/instance/Event1> a noria:EventRecord ;
    rdfs:label "Link Up Event"@en ;
    rdfs:comment "Event indicating link GigabitEthernet0/0/1 is up."@en ;
    noria:loggingTime "2023-10-23T14:30:00"^^xsd:dateTime ;
    noria:logText "Line protocol on Interface GigabitEthernet0/0/1 changed to up."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/instance/Interface1> ;
    noria:logOriginatingManagementSystem <https://example.com/sys/NMS1> ;
    noria:logOriginatingAgent <https://example.com/agent/TechTeam> ;
    noria:alarmSeverity [ a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; skos:hasTopConcept <skos:Concept/Warning> ] .

<https://example.com/agent/TechTeam> a foaf:Agent ;
    rdfs:label "Network Tech Team"@en ;
    rdfs:comment "Team responsible for network hardware."@en .

<https://example.com/sys/NMS1> a noria:Application ;
    rdfs:label "Network Management System 1"@en ;
    rdfs:comment "System monitoring network links."@en .

<https://example.com/agent/TechTeam> a foaf:Agent ;
    rdfs:label "Network Tech Team"@en .

<https://example.com/agent/TechTeam> rdfs:seeAlso <https://example.com/org/NetworkOps> .

<https://example.com/agent/TechTeam> a foaf:Agent ;
    rdfs:label "Network Tech Team"@en .

<https://example.com/agent/TechTeam> rdfs:seeAlso <https://example.com/org/NetworkOps> .

<https://example.com/agent/TechTeam> a foaf:Agent ;
    rdfs:label "Network Tech Team"@en .

<https://example.com/agent/TechTeam> rdfs:seeAlso <https://example.com/org/NetworkOps> .