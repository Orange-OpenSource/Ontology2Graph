@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

<https://example.com/HubNode1> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Router"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central routing point."@en ;
  noria:structuralElementObservable <https://example.com/RouterStatus> ;
  noria:structuralObservableOf <https://example.com/NetworkSwitch> .

<https://example.com/CentralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node facilitating data flow within the data center."@en ;
  noria:structuralElementObservable <https://example.com/SwitchLoad> ;
  noria:structuralElementDistinguishedName "Switch-DC-01" .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking external network to internal resources."@en ;
  noria:structuralElementObservable <https://example.com/FirewallStatus> ;
  noria:structuralElementDistinguishedName "Firewall-Conn-01" .

<https://example.com/IntermediaryNode1> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node balancing traffic between servers."@en ;
  noria:functionalElementDistinguishedName "LoadBalancer-01" .

<https://example.com/MuxNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/StreamLoad> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeStatus> .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/RouterStatus> a noria:StructuralObservable ;
  rdfs:label "Router Operational Status"@en ;
  rdfs:comment "Status of the main router, indicating its operational health."@en .

<https://example.com/SwitchLoad> a noria:StructuralObservable ;
  rdfs:label "Switch Load"@en ;
  rdfs:comment "Current load on the data center switch."@en .

<https://example.com/FirewallStatus> a noria:StructuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Operational status of the firewall connector node."@en .

<https://example.com/StreamLoad> a noria:StructuralObservable ;
  rdfs:label "Stream Load"@en ;
  rdfs:comment "Load metrics for the multiplex node."@en .

<https://example.com/SuperNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Super Node Status"@en ;
  rdfs:comment "Aggregated status of the super node."@en .

<https://example.com/HubNode1> noria:elementProperty <https://example.com/connectedTo> ;
  rdfs:label "connectedTo"@en ;
  rdfs:comment "Linking hub node to other network elements."@en .

<https://example.com/HighDegreeNode1> noria:elementProperty <https://example.com/connectedTo> ;
  rdfs:label "connectedTo"@en ;
  rdfs:comment "Connection to multiple network segments."@en .

<https://example.com/CentralNode1> noria:elementProperty <https://example.com/connectedTo> ;
  rdfs:label "connectedTo"@en ;
  rdfs:comment "Central node connecting internal and external networks."@en .

<https://example.com/ConnectorNode1> noria:elementProperty <https://example.com/connectedTo> ;
  rdfs:label "connectedTo"@en ;
  rdfs:comment "Firewall connector linking to external network."@en .

<https://example.com/IntermediaryNode1> noria:elementProperty <https://example.com/connectedTo> ;
  rdfs:label "connectedTo"@en ;
  rdfs:comment "Load balancer connecting servers."@en .

<https://example.com/MuxNode1> noria:elementProperty <https://example.com/connectedTo> ;
  rdfs:label "connectedTo"@en ;
  rdfs:comment "Multiplexer connecting multiple data streams."@en .

<https://example.com/SuperNode1> noria:elementProperty <https://example.com/connectedTo> ;
  rdfs:label "connectedTo"@en ;
  rdfs:comment "Super node connecting hubs and central nodes."@en .

<https://example.com/connectedTo> a owl:ObjectProperty ;
  rdfs:label "connectedTo"@en ;
  rdfs:comment "Relation indicating physical or logical connection between nodes."@en .

