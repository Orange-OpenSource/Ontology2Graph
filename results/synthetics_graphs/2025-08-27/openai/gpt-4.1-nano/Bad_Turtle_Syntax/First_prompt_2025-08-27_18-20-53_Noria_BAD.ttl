@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix ob: <http://www.w3.org/ns/oa#> .

<https://example.com/entity1> a noria:ManagedElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A high-performance core router acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/Org1> ;
  noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Router Load"@en ; rdfs:comment "Current load on the router."@en ] .

<https://example.com/entity2> a noria:StructuralElement ;
  rdfs:label "Switch A"@en ;
  rdfs:comment "A high-degree switch connecting multiple network segments."@en ;
  noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Switch Traffic"@en ; rdfs:comment "Traffic passing through Switch A."@en ] .

<https://example.com/entity3> a noria:StructuralElement ;
  rdfs:label "Firewall"@en ;
  rdfs:comment "A connector node providing security filtering."@en ;
  noria:structuralElementObservable [ a noria:structuralObservableOf ; rdfs:label "Firewall Status"@en ; rdfs:comment "Operational status of the firewall."@en ] .

<https://example.com/entity4> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "A central node distributing traffic among servers."@en ;
  noria:elementManagedBy <https://example.com/Org2> .

<https://example.com/entity5> a noria:Application ;
  rdfs:label "Customer Portal"@en ;
  rdfs:comment "An application providing customer access."@en ;
  noria:applicationType <https://w3id.org/noria/kos/application/type#CustomerFacingService> ;
  noria:resourceForApplication <https://example.com/entity1> , <https://example.com/entity4> .

<https://example.com/entity6> a noria:Service ;
  rdfs:label "Internet Service"@en ;
  rdfs:comment "A network service providing internet connectivity."@en ;
  noria:serviceType <https://w3id.org/noria/kos/service/type#ResourceFacingService> ;
  noria:applicationRelatedService <https://example.com/entity5> .

<https://example.com/entity7> a noria:Resource ;
  rdfs:label "Router1"@en ;
  rdfs:comment "A physical router device."@en ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceHostName "router1.company.com" ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  noria:resourceType <https://skos.org/kos/Resource/type#Physical> ;
  noria:resourceLogisticId "LOG-RT-001" .

<https://example.com/entity8> a noria:Resource ;
  rdfs:label "Switch1"@en ;
  rdfs:comment "A virtual switch in the network."@en ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceHostName "switch1.company.com" ;
  noria:locatedAtLocus <https://example.com/locus2> ;
  noria:resourceType <https://skos.org/kos/Resource/type#Virtual> .

<https://example.com/entity9> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Router1 and Switch1."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkTerminationResource <https://example.com/entity7> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/entity8> .

<https://example.com/entity10> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating fiber link is operational."@en ;
  noria:loggingTime "2023-10-01T12:30:00Z"^^xsd:dateTime ;
  noria:logText "Fiber link NL-001 is now active."@en ;
  noria:logOriginatingManagedObject <https://example.com/entity9> ;
  noria:logOriginatingManagementSystem <https://example.com/MonitoringSystem> ;
  noria:alarmSeverity <https://skos.org/kos/Notification/Severity/PerceivedSeverity#Major> ;
  noria:alarmProposedRepairAction <https://example.com/repair/activate-link> .

<https://example.com/Org1> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Responsible for network infrastructure."@en .

<https://example.com/Org2> a org:Organization ;
  rdfs:label "Application Support Team"@en ;
  rdfs:comment "Supports network applications."@en .

<https://example.com/locus1> a noria:Locus ;
  rdfs:label "Data Center Rack 1"@en ;
  rdfs:comment "Location of Router1."@en .

<https://example.com/locus2> a noria:Locus ;
  rdfs:label "Data Center Rack 2"@en ;
  rdfs:comment "Location of Switch1."@en .