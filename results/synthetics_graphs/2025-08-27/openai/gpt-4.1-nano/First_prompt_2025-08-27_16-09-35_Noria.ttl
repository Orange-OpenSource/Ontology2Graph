@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode2> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity, acting as a connector in the network."@en ;
  noria:structuralElementObservableData "Degree: 25"^^xsd:string ;
  noria:structuralElementDistinguishedName "Node-HD-02" .

<https://example.com/CentralNode3> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node with high betweenness centrality."@en ;
  noria:structuralElementObservableData "Betweenness: 0.85"^^xsd:string ;
  noria:structuralElementDistinguishedName "Node-Central-03" .

<https://example.com/ConnectorNode4> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData "Connected segments: 3"^^xsd:string ;
  noria:structuralElementDistinguishedName "Node-Connector-04" .

<https://example.com/IntermediaryNode5> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservableData "Flow rate: 1Gbps"^^xsd:string ;
  noria:structuralElementDistinguishedName "Node-Intermediary-05" .

<https://example.com/MultiplexNode6> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservableData "Streams: 4"^^xsd:string ;
  noria:structuralElementDistinguishedName "Node-Multiplex-06" .

<https://example.com/SuperNode7> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for redundancy."@en ;
  noria:structuralElementObservableData "Aggregated nodes: 10"^^xsd:string ;
  noria:structuralElementDistinguishedName "Node-Super-07" .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A critical server resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "serverA.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceSerialNumber "SN-987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:agentManagesResource <https://example.com/ITAdminTeam> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A virtual network interface."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "vnic1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualInterface> ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2023-03-10T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/VirtualNICModelY> ;
  noria:agentManagesResource <https://example.com/NetworkSupportTeam> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Optical Fiber Link"@en ;
  rdfs:comment "A high-speed optical fiber connection."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2021-06-01T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Virtual VPN Link"@en ;
  rdfs:comment "A virtual private network link."@en ;
  noria:networkLinkId "NL-002" ;
  noria:networkLinkType "VPN" ;
  noria:networkLinkInstallationDate "2022-11-15T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceB> ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/ResourceA> .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Interface GigabitEthernet0/0/1 Up"@en ;
  rdfs:comment "Interface state changed to up."@en ;
  noria:loggingTime "2022-01-01T17:12:00Z"^^xsd:dateTime ;
  noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to up"@en ;
  noria:logOriginatingManagedObject <https://example.com/ResourceA> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/NetworkAdmin> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Major> .

<https://example.com/Event2> a noria:EventRecord ;
  rdfs:label "Config Change on Router"@en ;
  rdfs:comment "Configuration changed via console."@en ;
  noria:loggingTime "2022-01-01T17:20:00Z"^^xsd:dateTime ;
  noria:logText "SYS-5-CONFIG_I: Configured from console by vty2 (10.34.195.36)"@en ;
  noria:logOriginatingManagedObject <https://example.com/ResourceA> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/NetworkAdmin> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Critical> .

<https://example.com/TroubleTicket1> a noria:TroubleTicket ;
  rdfs:label "Network Outage - Data Center"@en ;
  rdfs:comment "Major outage affecting data center connectivity."@en ;
  <http://purl.org/dc/terms/identifier> "TT-2023-0001" ;
  noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major> ;
  noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
  noria:troubleTicketCriticity <https://w3id.org/noria/kos/TroubleTicket/category/ServiceDisruption> ;
  noria:troubleTicketOrigin <https://example.com/CustomerX> ;
  noria:troubleTicketTrigger <https://example.com/Event1> ;
  noria:troubleTicketRelatedResource <https://example.com/ResourceA> ;
  noria:troubleTicketImpacts <https://example.com/ApplicationY> ;
  noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status/InProgress> ;
  noria:troubleTicketDetectionDateTime "2023-04-10T14:30:00Z"^^xsd:dateTime .

<https://example.com/ChangeRequest1> a noria:ChangeRequest ;
  rdfs:label "Upgrade Router Firmware"@en ;
  rdfs:comment "Firmware upgrade to fix security vulnerability."@en ;
  <http://purl.org/dc/terms/identifier> "CR-2023-045" ;
  noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/SoftwareUpgrade> ;
  noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/Standard> ;
  noria:changeRequestChangeCause "Security patch application." ;
  noria:changeRequestImpact <https://example.com/ResourceA> ;
  noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
  noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Planned> ;
  noria:changeRequestPlannedStartTime "2023-05-01T22:00:00Z"^^xsd:dateTime ;
  noria:changeRequestPlannedEndTime "2023-05-01T24:00:00Z"^^xsd:dateTime .

<https://example.com/Document1> a noria:DocumentAttachment ;
  rdfs:label "Network Diagram"@en ;
  rdfs:comment "Diagram illustrating network topology."@en ;
  <http://purl.org/dc/terms/identifier> "DOC-2023-001" ;
  noria:documentHRef "https://docs.example.com/network-diagram.pdf"^^xsd:anyURI .

<https://example.com/TicketNote1> a noria:TroubleTicketNote ;
  rdfs:label "Initial Report"@en ;
  rdfs:comment "Customer initial report of outage."@en ;
  <http://purl.org/dc/terms/created> "2023-04-10T14:35:00Z"^^xsd:dateTime ;
  noria:troubleTicketNoteText "Customer reports loss of connectivity in data center."@en ;
  noria:troubleTicketNoteForTicket <https://example.com/TroubleTicket1> .

<https://example.com/OperationPlan1> a noria:OperationPlan ;
  rdfs:label "Router Firmware Upgrade Procedure"@en ;
  rdfs:comment "Procedure to upgrade router firmware."@en ;
  <http://purl.org/dc/terms/identifier> "OP-2023-001" ;
  noria:operationPlanPreCondition <https://example.com/ActionPreCond1> ;
  noria:operationPlanPostCondition <https://example.com/ActionPostCond1> .

<https://example.com/ActionPreCond1> a noria:ActionPreCondition ;
  rdfs:label "Router is reachable"@en ;
  rdfs:comment "Router responds to ping."@en .

<https://example.com/ActionPostCond1> a noria:ActionPostCondition ;
  rdfs:label "Router firmware version updated"@en ;
  rdfs:comment "Firmware version reflects the new release."@en .

<https://example.com/ResourceX> a noria:Resource ;
  rdfs:label "Resource X"@en ;
  rdfs:comment "A critical application server."@en ;
  noria:resourceLogisticId "LOG999" ;
  noria:resourceHostName "appserverX.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/ApplicationServer> ;
  noria:locatedAtLocus <https://example.com/Locus3> ;
  noria:resourceSerialNumber "SN-555555" .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "Primary data center location."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Secondary Data Center"@en ;
  rdfs:comment "Backup data center location."@en .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Branch Office"@en ;
  rdfs:comment "Remote branch office location."@en .

<https://example.com/CustomerX> a foaf:Agent ;
  rdfs:label "Customer X"@en ;
  rdfs:comment "Customer organization affected by the outage."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Responsible for network configuration."@en .

<https://example.com/ITAdminTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team managing IT resources."@en .

<https://example.com/NetworkSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System"@en ;
  rdfs:comment "System monitoring network devices."@en .

<https://example.com/ApplicationY> a noria:Application ;
  rdfs:label "Application Y"@en ;
  rdfs:comment "An impacted application."@en .

