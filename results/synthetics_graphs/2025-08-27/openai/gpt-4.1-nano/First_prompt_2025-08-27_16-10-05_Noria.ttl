@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central in the topology, connecting multiple subnets."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments, acting as a bridge."@en ;
  noria:structuralElementObservableData <https://example.com/segmentCount> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that intermediates data flow between other nodes."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/ITOperations> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams simultaneously."@en ;
  noria:structuralElementObservableData <https://example.com/multistreamCount> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/NetworkAdmin> a org:Organization ;
  rdfs:label "Network Administration Team"@en ;
  rdfs:comment "Team responsible for managing network hubs and high-degree nodes."@en .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Operational team overseeing central nodes."@en .

<https://example.com/NetworkTeam> a org:Organization ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "Team managing connector nodes."@en .

<https://example.com/NetworkSupport> a org:Organization ;
  rdfs:label "Network Support"@en ;
  rdfs:comment "Support team for intermediary nodes."@en .

<https://example.com/ITOperations> a org:Organization ;
  rdfs:label "IT Operations"@en ;
  rdfs:comment "Team managing intermediary nodes."@en .

<https://example.com/NetworkEngineering> a org:Organization ;
  rdfs:label "Network Engineering"@en ;
  rdfs:comment "Team responsible for multiplex nodes."@en .

<https://example.com/NetworkManagement> a org:Organization ;
  rdfs:label "Network Management"@en ;
  rdfs:comment "Team overseeing super nodes."@en .

<https://example.com/connectionCount> a noria:structuralElementObservableData ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of connections for a high-degree node."@en .

<https://example.com/trafficVolume> a noria:structuralElementObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Traffic volume passing through the central node."@en .

<https://example.com/segmentCount> a noria:structuralElementObservableData ;
  rdfs:label "Segment Count"@en ;
  rdfs:comment "Number of network segments connected by the connector node."@en .

<https://example.com/dataFlowRate> a noria:structuralElementObservable ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through the intermediary node."@en .

<https://example.com/multistreamCount> a noria:structuralElementObservableData ;
  rdfs:label "Multistream Count"@en ;
  rdfs:comment "Number of data streams multiplexed at the multiplex node."@en .

<https://example.com/aggregateTraffic> a noria:structuralObservable ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Total traffic managed by the super node."@en .
