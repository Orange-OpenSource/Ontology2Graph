@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Network1> a noria:ManagedElement ;
  rdfs:label "Core Network Hub"@en ;
  rdfs:comment "A central hub node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:structuralElementDistinguishedName "Hub-01" ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> .

<https://w3id.org/noria/instance/Org1> a org:Organization ;
  rdfs:label "Main Network Operations"@en ;
  rdfs:comment "The primary organization managing core network components."@en .

<https://w3id.org/noria/instance/Resource1> a noria:Resource ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Main backbone router with super node characteristics."@en ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceHostName "router1.core.net" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:resourceProductModel <https://w3id.org/noria/instance/ModelX> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> .

<https://w3id.org/noria/instance/ModelX> a noria:ProductModel ;
  rdfs:label "ModelX"@en ;
  rdfs:comment "High-performance router model X."@en ;
  noria:productManufacturedBy <https://w3id.org/noria/instance/ManufacturerA> .

<https://w3id.org/noria/instance/ManufacturerA> a org:Organization ;
  rdfs:label "RouterCorp"@en ;
  rdfs:comment "Manufacturer of ModelX routers."@en .

<https://w3id.org/noria/instance/NetIf1> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/1"@en ;
  rdfs:comment "Gigabit Ethernet interface 0/0/1 on Router1."@en ;
  noria:networkInterfaceType "physical"^^xsd:string ;
  noria:networkInterfaceOperationalStatus [ a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; skos:hasTopConcept <kos/Resource/OperationalState/Up> ] ;
  noria:networkInterfaceRoutingPriorityMetric 122 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3.58 ;
  noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
  noria:networkInterfaceLaserRxLowPowerWarningThreshold -4 ;
  noria:networkInterfaceOf <https://w3id.org/noria/instance/Resource1> ;
  noria:networkInterfaceConnects <https://w3id.org/noria/instance/Link1> .

<https://w3id.org/noria/instance/Link1> a noria:NetworkLink ;
  rdfs:label "FiberLink-01"@en ;
  rdfs:comment "Optical fiber link between Router1 and Switch1."@en ;
  noria:networkLinkId "NL-0001" ;
  noria:networkLinkType "optical fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://w3id.org/noria/instance/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/instance/Resource2> .

<https://w3id.org/noria/instance/Resource2> a noria:Resource ;
  rdfs:label "Switch1"@en ;
  rdfs:comment "Distribution switch with multiplex node characteristics."@en ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceHostName "switch1.core.net" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/switch> ;
  noria:resourceProductModel <https://w3id.org/noria/instance/ModelY> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus2> .

<https://w3id.org/noria/instance/ModelY> a noria:ProductModel ;
  rdfs:label "ModelY"@en ;
  rdfs:comment "High-capacity switch model Y."@en ;
  noria:productManufacturedBy <https://w3id.org/noria/instance/ManufacturerB> .

<https://w3id.org/noria/instance/ManufacturerB> a org:Organization ;
  rdfs:label "SwitchMakers"@en ;
  rdfs:comment "Manufacturer of ModelY switches."@en .

<https://w3id.org/noria/instance/Locus1> a noria:Locus ;
  rdfs:label "Locus-DataCenter"@en ;
  rdfs:comment "Main data center location."@en .

<https://w3id.org/noria/instance/Locus2> a noria:Locus ;
  rdfs:label "Locus-ServerRoom"@en ;
  rdfs:comment "Server room in main data center."@en .

<https://w3id.org/noria/instance/HubNode> a noria:StructuralElement ;
  rdfs:label "HubNode"@en ;
  rdfs:comment "A multiplex hub node with super node characteristics."@en ;
  noria:structuralElementDistinguishedName "HubNode-01" ;
  noria:structuralElementObservableData "High degree node with multiplex connections"^^xsd:string ;
  noria:elementManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:connectedTo <https://w3id.org/noria/instance/Resource1> , <https://w3id.org/noria/instance/Resource2> .

<https://w3id.org/noria/instance/CentralNode> a noria:StructuralElement ;
  rdfs:label "CentralNode"@en ;
  rdfs:comment "A central node with high degree connectivity."@en ;
  noria:structuralElementDistinguishedName "CentralNode-01" ;
  noria:structuralElementObservableData "High degree central node"^^xsd:string ;
  noria:elementManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:connectedTo <https://w3id.org/noria/instance/Resource1> , <https://w3id.org/noria/instance/Resource2> .

<https://w3id.org/noria/instance/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "ConnectorNode"@en ;
  rdfs:comment "A connector node linking hubs and central nodes."@en ;
  noria:structuralElementDistinguishedName "Connector-01" ;
  noria:structuralElementObservableData "Connector node with intermediary role"^^xsd:string ;
  noria:elementManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:connectedTo <https://w3id.org/noria/instance/HubNode> , <https://w3id.org/noria/instance/CentralNode> .

<https://w3id.org/noria/instance/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "IntermediaryNode"@en ;
  rdfs:comment "An intermediary node facilitating multiplex connections."@en ;
  noria:structuralElementDistinguishedName "Intermediary-01" ;
  noria:structuralElementObservableData "Intermediary role in multiplex network"^^xsd:string ;
  noria:elementManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:connectedTo <https://w3id.org/noria/instance/HubNode> , <https://w3id.org/noria/instance/Resource2> .

<https://w3id.org/noria/instance/SuperNode> a noria:StructuralElement ;
  rdfs:label "SuperNode"@en ;
  rdfs:comment "A super node with multiplex and hub characteristics."@en ;
  noria:structuralElementDistinguishedName "SuperNode-01" ;
  noria:structuralElementObservableData "Super node with multiplex and hub features"^^xsd:string ;
  noria:elementManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:connectedTo <https://w3id.org/noria/instance/HubNode> , <https://w3id.org/noria/instance/CentralNode> , <https://w3id.org/noria/instance/IntermediaryNode> .

# All nodes are linked with at least one relation, no isolated nodes included.