@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Network1> a noria:StructuralElement ;
  rdfs:label "Main Data Center Network"@en ;
  rdfs:comment "Core network infrastructure in the main data center."@en ;
  noria:structuralElementDistinguishedName "DCN-01"^^xsd:string ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/SupportTeam> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Network> .

<https://w3id.org/noria/instance/ResourceSwitch> a noria:Resource ;
  rdfs:label "Switch Model X"@en ;
  rdfs:comment "High-performance network switch."@en ;
  noria:resourceSerialNumber "SN123456"^^xsd:string ;
  noria:resourceHostName "Switch-01"@en ;
  noria:resourceLogisticId "LOG-789"^^xsd:string ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
  noria:resourceProductModel <https://w3id.org/noria/instance/ModelX> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:agentManagesResource <https://w3id.org/noria/instance/NetworkAdmin> .

<https://w3id.org/noria/instance/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model name for the switch."@en ;
  noria:productManufacturedBy <https://w3id.org/organization/TechCorp> .

<https://w3id.org/noria/instance/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/1"@en ;
  rdfs:comment "GigabitEthernet interface 0/0/1."@en ;
  noria:networkInterfaceDescription "Uplink port to core router."@en ;
  noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Physical> ;
  noria:networkInterfaceOf <https://w3id.org/noria/instance/ResourceSwitch> ;
  noria:networkInterfaceConnects <https://w3id.org/noria/instance/Link1> ;
  noria:networkInterfaceRoutingPriorityMetric 100 .

<https://w3id.org/noria/instance/Link1> a noria:NetworkLink ;
  rdfs:label "Link to Router"@en ;
  rdfs:comment "Optical fiber link to core router."@en ;
  noria:networkLinkId "LINK-001"^^xsd:string ;
  noria:networkLinkType "Optical fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://w3id.org/noria/instance/Router1> ;
  noria:networkLinkTerminationResourceOrigin <https://w3id.org/noria/instance/ResourceSwitch> .

<https://w3id.org/noria/instance/Router1> a noria:Resource ;
  rdfs:label "Core Router 1"@en ;
  noria:resourceSerialNumber "SN654321"^^xsd:string ;
  noria:resourceHostName "Router1"@en ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:agentManagesResource <https://w3id.org/noria/instance/NetworkAdmin> .

<https://w3id.org/noria/instance/Locus1> a noria:Locus ;
  rdfs:label "Server Room 314"@en ;
  noria:locusLine "Line:L, Column:6"^^xsd:string ;
  noria:locusRow "Row:3"^^xsd:string .

<https://w3id.org/noria/instance/SupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team responsible for network infrastructure."@en .

<https://w3id.org/noria/instance/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Alice Smith"@en ;
  foaf:accountName "asmith"@en ;
  rdfs:comment "Network administrator responsible for network resources."@en .

<https://w3id.org/organization/TechCorp> a org:Organization ;
  rdfs:label "TechCorp Inc."@en ;
  rdfs:comment "Manufacturer of network equipment."@en .