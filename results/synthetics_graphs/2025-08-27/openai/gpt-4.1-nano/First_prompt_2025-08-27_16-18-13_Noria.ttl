@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Hub Node: Central Resource (e.g., a core router)
<https://example.com/Resource/RouterCore> a noria:Resource ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "The central backbone router connecting multiple network segments."@en ;
  noria:resourceLogisticId "LOG-CORE-001" ;
  noria:resourceHostName "core-router-01" ;
  noria:locatedAtLocus <https://example.com/Locus/Room314> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/operational> ;
  rdfs:label "Core Router" ;
  rdfs:comment "Main backbone router facilitating inter-segment communication." .

# High-Degree Node: Application Server with multiple connections
<https://example.com/Resource/AppServer1> a noria:Resource ;
  rdfs:label "Application Server 1"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:resourceHostName "app-server-01" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/server> ;
  noria:locatedAtLocus <https://example.com/Locus/Room314> ;
  noria:resourceForApplication <https://example.com/Application/CRM> ;
  noria:resourceManagementIPAddress "192.168.10.10" ;
  noria:agentManagesResource <https://example.com/Agent/ITSupport> .

# Connector Node: Network Interface connecting Resource to Network Link
<https://example.com/NetworkInterface/eth0> a noria:NetworkInterface ;
  rdfs:label "eth0" ;
  rdfs:comment "Primary network interface of AppServer1." ;
  noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/physical> ;
  noria:networkInterfaceOf <https://example.com/Resource/AppServer1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink/Link1> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 .

# Intermediary Node: Network Link between AppServer1 and Core Router
<https://example.com/NetworkLink/Link1> a noria:NetworkLink ;
  rdfs:label "Link1" ;
  rdfs:comment "Optical fiber link between AppServer1 and Core Router." ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "fiber" ;
  noria:networkLinkInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource/AppServer1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource/RouterCore> .

# Multiplex Node: Application with multiple modules
<https://example.com/Application/CRM> a noria:Application ;
  rdfs:label "Customer Relationship Management System"@en ;
  rdfs:comment "CRM application managing customer data and interactions."@en ;
  noria:applicationModelIdentifier "CRM-Model-2023" ;
  noria:applicationNumericalIdentifier 101 ;
  noria:applicationShortIdentifier "CRM" ;
  noria:applicationType <https://w3id.org/noria/kos/application/type/business> ;
  noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/importance/high> ;
  noria:applicationFunctionalDomain "Customer Management" ;
  noria:applicationFunctionalSubDomain "Sales and Support" .

<https://example.com/Application/CRM/Module1> a noria:ApplicationModule ;
  rdfs:label "CRM Module 1" ;
  noria:applicationModuleIdentifier "CRM-MOD-01" ;
  noria:applicationModuleName "Customer Data Module" ;
  noria:applicationModuleOf <https://example.com/Application/CRM> ;
  noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/active> ;
  noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla/Gold> ;
  noria:applicationModuleHotlineEnabled true ;
  noria:applicationModuleSupportGroup <https://example.com/Org/SupportTeam> ;
  noria:applicationModuleSupportLeader <https://example.com/Agent/SupportLead> .

# Super Node: Organization (e.g., IT Support Organization)
<https://example.com/Org/SupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Support team responsible for IT infrastructure."@en ;
  org:hasMember <https://example.com/Agent/SupportLead> ;
  org:hasMember <https://example.com/Agent/ITSupportAgent> .

<https://example.com/Agent/SupportLead> a foaf:Agent ;
  rdfs:label "Support Team Lead"@en ;
  rdfs:comment "Lead of the support team."@en ;
  foaf:accountName "support_lead" .

<https://example.com/Agent/ITSupportAgent> a foaf:Agent ;
  rdfs:label "IT Support Agent"@en ;
  rdfs:comment "Support agent handling incidents."@en ;
  foaf:accountName "it_support_agent" .

# Additional Nodes to ensure all nodes are linked
<https://example.com/Locus/Room314> a noria:Locus ;
  rdfs:label "Room 314"@en ;
  rdfs:comment "Server room 314 in main building."@en .

# Note: All nodes are connected via at least one relation, and node types are diverse as per instructions.