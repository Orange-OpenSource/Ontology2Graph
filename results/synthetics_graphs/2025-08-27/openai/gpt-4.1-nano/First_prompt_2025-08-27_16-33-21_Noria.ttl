@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A switch with high connectivity degree, acting as a network backbone."@en ;
  noria:structuralElementObservableData 12345 ;
  noria:structuralElementDistinguishedName "Switch-Backbone-01" .

<https://example.com/centralNode> a noria:FunctionalElement ;
  rdfs:label "Central Application Server"@en ;
  rdfs:comment "A critical application server handling core business logic."@en ;
  noria:functionalElementDistinguishedName "AppServer-Prod-01" .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A logical connector facilitating communication between subnetworks."@en ;
  noria:structuralElementObservableData 67890 .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Router"@en ;
  rdfs:comment "Router acting as an intermediary between different network segments."@en ;
  noria:structuralElementDistinguishedName "Router-Intermediary-02" .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "Device multiplexing multiple data streams."@en ;
  noria:structuralElementObservableData 98765 .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple network elements for high-level management."@en ;
  noria:structuralElementDistinguishedName "SuperNode-Alpha" .

<https://example.com/entity1> a noria:ManagedElement, foaf:Agent ;
  rdfs:label "Entity One"@en ;
  rdfs:comment "An entity representing a network device or agent."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/entity2> a noria:FunctionalElement ;
  rdfs:label "Entity Two"@en ;
  rdfs:comment "A functional component in the network."@en ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/entity3> a noria:StructuralElement ;
  rdfs:label "Entity Three"@en ;
  rdfs:comment "A structural network element."@en ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/OperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Operations Team"@en ;
  rdfs:comment "Team handling operational tasks."@en .

<https://example.com/NetworkSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support"@en ;
  rdfs:comment "Support team for network infrastructure."@en .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A physical network resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "host-resourceA" ;
  noria:resourceType <http://purl.org/ontology/bibo/ResourceType/Physical> ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagedBy <https://example.com/NetworkSupport> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A virtual network resource."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "virtual-resourceB" ;
  noria:resourceType <http://purl.org/ontology/bibo/ResourceType/Virtual> ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/OperationsTeam> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Location within Server Room 314."@en ;
  noria:locusLine "Line:L, in Room:Server room 314" .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Location within Data Center."@en ;
  noria:locusRow "Row: R, in Data Center" .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource A and Resource B."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource A."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceOf <https://example.com/ResourceA> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus "up" .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "veth0"@en ;
  rdfs:comment "Virtual interface of Resource B."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOf <https://example.com/ResourceB> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus "up" .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating the link is operational."@en ;
  noria:loggingTime "2023-10-01T12:00:00"^^xsd:dateTime ;
  noria:logText "Network link Fiber Link 1 is now active." ;
  noria:logOriginatingManagedObject <https://example.com/NetworkLink1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/NetworkAdmin> ;
  noria:alarmSeverity <http://purl.org/ontology/bibo/Severity/Major> .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en ;
  rdfs:comment "System monitoring network links."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Responsible for network configuration."@en .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Main Hub"@en ;
  rdfs:comment "Central hub node connecting multiple segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/HighDegreeSwitch> a noria:StructuralElement ;
  rdfs:label "Core Switch"@en ;
  rdfs:comment "High-degree switch acting as backbone."@en ;
  noria:structuralElementObservableData 54321 ;
  noria:structuralElementDistinguishedName "Switch-Core-01" .

<https://example.com/CentralAppServer> a noria:FunctionalElement ;
  rdfs:label "Core App Server"@en ;
  rdfs:comment "Main application server."@en ;
  noria:functionalElementDistinguishedName "AppServer-Core-01" .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Logical connector for subnet communication."@en ;
  noria:structuralElementObservableData 11223 .

<https://example.com/IntermediaryRouter> a noria:StructuralElement ;
  rdfs:label "Intermediary Router"@en ;
  rdfs:comment "Router facilitating inter-segment routing."@en ;
  noria:structuralElementDistinguishedName "Router-Intermediary-03" .

<https://example.com/MuxDevice> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "Device multiplexing multiple data streams."@en ;
  noria:structuralElementObservableData 44556 .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregating node for high-level management."@en ;
  noria:structuralElementDistinguishedName "SuperNode-Alpha" .

<https://example.com/Entity4> a noria:ManagedElement, foaf:Agent ;
  rdfs:label "Entity Four"@en ;
  rdfs:comment "An agent managing a network resource."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/Entity5> a noria:FunctionalElement ;
  rdfs:label "Entity Five"@en ;
  rdfs:comment "A functional network component."@en ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/Entity6> a noria:StructuralElement ;
  rdfs:label "Entity Six"@en ;
  rdfs:comment "A structural network element."@en ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en .

<https://example.com/OperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Operations Team"@en .

<https://example.com/NetworkSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support"@en .