@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity, linking multiple nodes."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node 1"@en ;
  rdfs:comment "Node with a high number of connections, acting as a critical connector."@en ;
  noria:structuralElementObservableData "Degree: 15"^^xsd:integer ;
  noria:structuralElementObservable <https://example.com/observable1> ;
  noria:structuralElementDistinguishedName "HighDegreeNode1" .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Node 1"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:structuralElementObservableData "Centrality: 0.85"^^xsd:float ;
  noria:structuralElementObservable <https://example.com/observable2> ;
  noria:structuralElementDistinguishedName "CentralNode1" .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node 1"@en ;
  rdfs:comment "Node acting as a connector between different network segments."@en ;
  noria:structuralElementObservableData "Connections: 3"^^xsd:integer ;
  noria:structuralElementObservable <https://example.com/observable3> ;
  noria:structuralElementDistinguishedName "ConnectorNode1" .

<https://example.com/intermediaryNode1> a noria:FunctionalElement ;
  rdfs:label "Intermediary Node 1"@en ;
  rdfs:comment "Node facilitating data flow between source and destination."@en ;
  noria:functionalElementDistinguishedName "IntermediaryNode1" .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node 1"@en ;
  rdfs:comment "Node handling multiple data streams simultaneously."@en ;
  noria:structuralElementObservableData "Streams: 4"^^xsd:integer ;
  noria:structuralElementObservable <https://example.com/observable4> ;
  noria:structuralElementDistinguishedName "MultiplexNode1" .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node 1"@en ;
  rdfs:comment "Super node aggregating multiple sub-nodes for high-level analysis."@en ;
  noria:structuralElementObservableData "Aggregated Load: 75%"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable5> ;
  noria:structuralElementDistinguishedName "SuperNode1" .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "Organization responsible for managing network nodes."@en .

<https://example.com/observable1> a noria:StructuralObservable ;
  rdfs:label "Node Degree Observable"@en ;
  rdfs:comment "Observable for node degree."@en .

<https://example.com/observable2> a noria:StructuralObservable ;
  rdfs:label "Node Centrality Observable"@en ;
  rdfs:comment "Observable for node centrality."@en .

<https://example.com/observable3> a noria:StructuralObservable ;
  rdfs:label "Connector Connections Observable"@en ;
  rdfs:comment "Observable for number of connections of connector nodes."@en .

<https://example.com/observable4> a noria:StructuralObservable ;
  rdfs:label "Multiplex Streams Observable"@en ;
  rdfs:comment "Observable for number of data streams handled."@en .

<https://example.com/observable5> a noria:StructuralObservable ;
  rdfs:label "Super Node Load Observable"@en ;
  rdfs:comment "Observable for load percentage of super nodes."@en .