@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node in the network, connecting multiple segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable1> ;
  noria:structuralObservableOf <https://example.com/StructuralObservable2> .

<https://example.com/CentralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center, linking servers and storage."@en ;
  noria:structuralElementObservable <https://example.com/structuralElementObservable1> .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node acting as a firewall boundary between segments."@en ;
  noria:structuralElementObservable <https://example.com/structuralElementObservable3> .

<https://example.com/IntermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservable <https://example.com/structuralElementObservable4> .

<https://example.com/MultiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/structuralElementObservable5> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "A super node with high capacity and multiple roles."@en ;
  noria:structuralElementObservable <https://example.com/structuralElementObservable6> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Server A"@en ;
  rdfs:comment "A high-performance application server."@en ;
  noria:resourceLogisticId "SRV-A-001" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceHostName "serverA.example.com" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Storage Array 1"@en ;
  rdfs:comment "Primary storage array for backups."@en ;
  noria:resourceLogisticId "STO-ARRAY-01" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Storage> ;
  noria:resourceHostName "storage1.example.com" .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Firewall Device"@en ;
  rdfs:comment "Firewall for network segmentation."@en ;
  noria:resourceLogisticId "FW-XYZ-123" ;
  noria:locatedAtLocus <https://example.com/Locus3> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
  noria:resourceHostName "firewall1.example.com" .

<https://example.com/structuralElementObservable1> a noria:StructuralObservable ;
  rdfs:label "Server CPU Load"@en ;
  rdfs:comment "Observable for CPU load on server."@en .

<https://example.com/structuralElementObservable2> a noria:StructuralObservable ;
  rdfs:label "Server Memory Usage"@en ;
  rdfs:comment "Observable for memory usage on server."@en .

<https://example.com/structuralElementObservable3> a noria:StructuralObservable ;
  rdfs:label "Firewall Traffic"@en ;
  rdfs:comment "Observable for traffic passing through firewall."@en .

<https://example.com/structuralElementObservable4> a noria:StructuralObservable ;
  rdfs:label "Load Balancer Traffic"@en ;
  rdfs:comment "Observable for traffic distribution by load balancer."@en .

<https://example.com/structuralElementObservable5> a noria:StructuralObservable ;
  rdfs:label "Multiplexer Data Streams"@en ;
  rdfs:comment "Observable for data streams multiplexed."@en .

<https://example.com/structuralElementObservable6> a noria:StructuralObservable ;
  rdfs:label "Super Node Throughput"@en ;
  rdfs:comment "Observable for throughput of super node."@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Rack 12"@en ;
  rdfs:comment "Locus representing rack 12 in data center."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Storage Room"@en ;
  rdfs:comment "Locus representing storage room."@en .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Firewall Zone"@en ;
  rdfs:comment "Locus representing firewall zone."@en .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Lead network admin responsible for configuration."@en .

<https://example.com/NetworkAdmin> foaf:holdsAccount <https://example.com/adminAccount> .

<https://example.com/adminAccount> a foaf:OnlineAccount ;
  foaf:accountName "netadmin" .

<https://example.com/NetworkOperationsTeam> org:hasMember <https://example.com/NetworkAdmin> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between site A and site B."@en ;
  noria:networkLinkId "LINK-AB-001" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00"^^xsd:dateTime .

<https://example.com/Resource1> noria:resourceManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/Resource2> noria:resourceManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/Resource3> noria:resourceManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/Resource1> noria:resourceForApplication <https://example.com/Application1> .
<https://example.com/Application1> a noria:Application ;
  rdfs:label "Customer Portal"@en ;
  rdfs:comment "Web portal for customer access."@en .

<https://example.com/Application1> noria:applicationType <https://kos/application/type/customer-facing> .

<https://example.com/NetworkLink1> noria:networkLinkTerminationResource <https://example.com/Resource1> .
<https://example.com/NetworkLink1> noria:networkLinkTerminationResource <https://example.com/Resource2> .

<https://example.com/Resource1> noria:locatedAtLocus <https://example.com/Locus1> .
<https://example.com/Resource2> noria:locatedAtLocus <https://example.com/Locus2> .
<https://example.com/Resource3> noria:locatedAtLocus <https://example.com/Locus3> .

<https://example.com/Resource1> noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> .
<https://example.com/Resource2> noria:resourceType <https://w3id.org/noria/kos/Resource/type/Storage> .
<https://example.com/Resource3> noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> .

<https://example.com/Resource1> noria:resourceSerialNumber "SN123456" .
<https://example.com/Resource2> noria:resourceSerialNumber "SN654321" .
<https://example.com/Resource3> noria:resourceSerialNumber "SN789012" .

<https://example.com/Resource1> noria:resourceHostName "serverA.example.com" .
<https://example.com/Resource2> noria:resourceHostName "storageA.example.com" .
<https://example.com/Resource3> noria:resourceHostName "firewallA.example.com" .

<https://example.com/structuralObject1> a noria:StructuralObservable ;
  rdfs:label "Server CPU Load"@en ;
  rdfs:comment "Observable for CPU load on server."@en .

<https://example.com/structuralObject2> a noria:StructuralObservable ;
  rdfs:label "Server Memory Usage"@en ;
  rdfs:comment "Observable for memory usage on server."@en .

<https://example.com/structuralObject3> a noria:StructuralObservable ;
  rdfs:label "Firewall Traffic"@en ;
  rdfs:comment "Observable for traffic passing through firewall."@en .

<https://example.com/structuralObject4> a noria:StructuralObservable ;
  rdfs:label "Load Balancer Traffic"@en ;
  rdfs:comment "Observable for traffic distribution by load balancer."@en .

<https://example.com/structuralObject5> a noria:StructuralObservable ;
  rdfs:label "Multiplexer Data Streams"@en ;
  rdfs:comment "Observable for data streams multiplexed."@en .

<https://example.com/structuralObject6> a noria:StructuralObservable ;
  rdfs:label "Super Node Throughput"@en ;
  rdfs:comment "Observable for throughput of super node."@en .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Lead network admin responsible for configuration."@en .

<https://example.com/NetworkAdmin> foaf:holdsAccount <https://example.com/adminAccount> .

<https://example.com/adminAccount> a foaf:OnlineAccount ;
  foaf:accountName "netadmin" .

<https://example.com/NetworkOperationsTeam> org:hasMember <https://example.com/NetworkAdmin> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between site A and site B."@en ;
  noria:networkLinkId "LINK-AB-001" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00"^^xsd:dateTime .

# Link resources to the network admin
<https://example.com/Resource1> noria:resourceManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/Resource2> noria:resourceManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/Resource3> noria:resourceManagedBy <https://example.com/NetworkAdmin> .

# Link resources to applications
<https://example.com/Resource1> noria:resourceForApplication <https://example.com/Application1> .

# Link resources to loci
<https://example.com/Resource1> noria:locatedAtLocus <https://example.com/Locus1> .
<https://example.com/Resource2> noria:locatedAtLocus <https://example.com/Locus2> .
<https://example.com/Resource3> noria:locatedAtLocus <https://example.com/Locus3> .

# Link network link to resources
<https://example.com/NetworkLink1> noria:networkLinkTerminationResource <https://example.com/Resource1> .
<https://example.com/NetworkLink1> noria:networkLinkTerminationResource <https://example.com/Resource2> .

# Link observables to resources
<https://example.com/Resource1> noria:structuralElementObservable <https://example.com/structuralObject1> .
<https://example.com/Resource1> noria:structuralElementObservable <https://example.com/structuralObject2> .
<https://example.com/Resource3> noria:structuralElementObservable <https://example.com/structuralObject3> .

# Create a sample TroubleTicket
<https://example.com/Ticket1> a noria:TroubleTicket ;
  rdfs:label "Network Outage in Data Center"@en ;
  rdfs:comment "Major outage affecting data center connectivity."@en ;
  noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major> ;
  noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
  noria:troubleTicketCriticity <https://w3id.org/noria/kos/TroubleTicket/category/ServiceDisruption> ;
  noria:troubleTicketOrigin <https://example.com/CustomerGroup> ;
  noria:troubleTicketTrigger <https://example.com/EventRecord1> ;
  noria:troubleTicketImpacts <https://example.com/Application1> ;
  noria:troubleTicketRelatedResource <https://example.com/Resource1> .

<https://example.com/EventRecord1> a noria:EventRecord ;
  rdfs:label "Network link down event"@en ;
  rdfs:comment "Detected link failure between site A and B."@en ;
  noria:loggingTime "2023-10-01T14:30:00"^^xsd:dateTime ;
  noria:logText "Link Fiber Link A-B is down."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System"@en .

