@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch in the data center."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/dataCenterSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkAdminTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A central node that connects multiple network segments."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/coreRouter> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking different network zones."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/firewall> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node balancing traffic between servers."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/loadBalancer> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/muxSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node managing multiple sub-nodes."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/superNodeEntity> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Central Hub"@en ;
  rdfs:comment "A high-degree hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Data Center Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a core switch."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/dataCenterSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkAdminTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A central node connecting multiple network segments."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/coreRouter> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking different network zones."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/firewall> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node balancing traffic."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/loadBalancer> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Mux Switch"@en ;
  rdfs:comment "A multiplex node combining multiple streams."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/muxSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node managing sub-nodes."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/superNodeEntity> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/HubNodeEntity> a noria:ManagedElement ;
  rdfs:label "Main Hub Entity"@en ;
  rdfs:comment "A central hub node with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/HighDegreeNodeEntity> a noria:StructuralElement ;
  rdfs:label "Data Center Switch Entity"@en ;
  rdfs:comment "A high-degree node acting as a core switch."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/dataCenterSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkAdminTeam> .

<https://example.com/CentralNodeEntity> a noria:StructuralElement ;
  rdfs:label "Core Router Entity"@en ;
  rdfs:comment "A central node connecting network segments."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/coreRouter> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/ConnectorNodeEntity> a noria:StructuralElement ;
  rdfs:label "Firewall Connector Entity"@en ;
  rdfs:comment "A connector node linking zones."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/firewall> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNodeEntity> a noria:StructuralElement ;
  rdfs:label "Load Balancer Entity"@en ;
  rdfs:comment "An intermediary node balancing traffic."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/loadBalancer> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/MuxNodeEntity> a noria:StructuralElement ;
  rdfs:label "Mux Switch Entity"@en ;
  rdfs:comment "A multiplex node."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/muxSwitch> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/SuperNodeEntity> a noria:StructuralElement ;
  rdfs:label "Super Node Entity"@en ;
  rdfs:comment "A super node managing sub-nodes."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/superNodeEntity> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .