@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity degree, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that serves as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:elementManagedBy <https://example.com/ConnectivitySupport> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that intermediates data flow between source and destination."@en ;
  noria:structuralElementObservable <https://example.com/trafficFlow> ;
  noria:elementManagedBy <https://example.com/TrafficManagement> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that multiplexes multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamControl> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple sub-nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/aggregationMetrics> ;
  noria:elementManagedBy <https://example.com/SuperNodeOps> .

<https://example.com/NetworkOperations> a org:Organization ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "The organization responsible for network management."@en .

<https://example.com/NetworkAdmin> a org:Organization ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "The team managing high-degree nodes."@en .

<https://example.com/NetworkTeam> a org:Organization ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "The team overseeing central nodes."@en .

<https://example.com/ConnectivitySupport> a org:Organization ;
  rdfs:label "Connectivity Support"@en ;
  rdfs:comment "Support team for connector nodes."@en .

<https://example.com/TrafficManagement> a org:Organization ;
  rdfs:label "Traffic Management"@en ;
  rdfs:comment "Team managing intermediary nodes."@en .

<https://example.com/StreamControl> a org:Organization ;
  rdfs:label "Stream Control"@en ;
  rdfs:comment "Team responsible for multiplex nodes."@en .

<https://example.com/SuperNodeOps> a org:Organization ;
  rdfs:label "Super Node Operations"@en ;
  rdfs:comment "High-level management of super nodes."@en .

<https://example.com/degreeMetric> a noria:Property ;
  rdfs:label "Degree Metric"@en ;
  rdfs:comment "A measure of node connectivity degree."@en .

<https://example.com/latencyObservable> a noria:StructuralObservable ;
  rdfs:label "Latency Observable"@en ;
  rdfs:comment "Measurement of network latency."@en .

<https://example.com/connectionQuality> a noria:Property ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Assessment of connection quality."@en .

<https://example.com/trafficFlow> a noria:Property ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Data flow rate through the node."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/aggregationMetrics> a noria:Property ;
  rdfs:label "Aggregation Metrics"@en ;
  rdfs:comment "Metrics for aggregated node performance."@en .

<https://example.com/NetworkNode> a noria:StructuralElement ;
  rdfs:label "Network Node"@en ;
  rdfs:comment "Generic network node."@en .

<https://example.com/Node1> a noria:NetworkNode ;
  rdfs:label "Node 1"@en ;
  rdfs:comment "A hub node with high connectivity."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/Node2> a noria:NetworkNode ;
  rdfs:label "Node 2"@en ;
  rdfs:comment "A high-degree node."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/Node3> a noria:NetworkNode ;
  rdfs:label "Node 3"@en ;
  rdfs:comment "A central node."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/Node4> a noria:NetworkNode ;
  rdfs:label "Node 4"@en ;
  rdfs:comment "A connector node."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:elementManagedBy <https://example.com/ConnectivitySupport> .

<https://example.com/Node5> a noria:NetworkNode ;
  rdfs:label "Node 5"@en ;
  rdfs:comment "An intermediary node."@en ;
  noria:structuralElementObservable <https://example.com/trafficFlow> ;
  noria:elementManagedBy <https://example.com/TrafficManagement> .

<https://example.com/Node6> a noria:NetworkNode ;
  rdfs:label "Node 6"@en ;
  rdfs:comment "A multiplex node."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamControl> .

<https://example.com/Node7> a noria:NetworkNode ;
  rdfs:label "Node 7"@en ;
  rdfs:comment "A super node."@en ;
  noria:structuralElementObservable <https://example.com/aggregationMetrics> ;
  noria:elementManagedBy <https://example.com/SuperNodeOps> .