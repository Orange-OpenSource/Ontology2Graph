@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a central point."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within a specific subgraph."@en ;
  noria:structuralElementObservableData <https://example.com/centralityScore> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/intermediaryLatency> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservableData <https://example.com/aggregationLevel> .

<https://example.com/Resource1>
  a noria:Resource ;
  rdfs:label "Resource1"@en ;
  rdfs:comment "An example resource representing a network device."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "router1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagedBy <https://example.com/NetworkAdminTeam> .

<https://example.com/Resource2>
  a noria:Resource ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "A virtual server resource."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "vm2.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualServer> ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Provisioned> ;
  noria:resourceInstallationDate "2021-08-01T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/NetworkLink1>
  a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkInstallationDate "2019-11-20T12:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/NetworkInterface1>
  a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet Interface"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
  noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> .

<https://example.com/NetworkInterface2>
  a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary interface of Resource2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "Virtual NIC for VM"@en ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
  noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> .

<https://example.com/LocusA>
  a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "Line: L"@en ;
  noria:locusRow "Row: R"@en .

<https://example.com/LocusB>
  a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Secondary data center."@en ;
  noria:locusLine "Line: M"@en ;
  noria:locusRow "Row: S"@en .

<https://example.com/NetworkAdminTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSupportTeam>
  a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing IT support and maintenance."@en .

<https://example.com/ModelX>
  a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance router model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ModelY>
  a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Virtual server platform."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerA>
  a org:Organization ;
  rdfs:label "Router Manufacturer A"@en ;
  rdfs:comment "Manufacturer of high-performance routers."@en .

<https://example.com/ManufacturerB>
  a org:Organization ;
  rdfs:label "Server Platform B"@en ;
  rdfs:comment "Manufacturer of virtual server platforms."@en .

<https://example.com/NetworkOperations>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Operational team managing network infrastructure."@en .

<https://example.com/NetworkAdminTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Admin Team"@en ;
  rdfs:comment "Team responsible for network administration."@en .

<https://example.com/Resource3>
  a noria:Resource ;
  rdfs:label "Resource3"@en ;
  rdfs:comment "A virtual firewall appliance."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:resourceHostName "firewall1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelZ> ;
  noria:resourceManagedBy <https://example.com/SecurityTeam> .

<https://example.com/ModelZ>
  a noria:ProductModel ;
  rdfs:label "Firewall Model Z"@en ;
  rdfs:comment "Next-gen firewall appliance."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerC> .

<https://example.com/ManufacturerC>
  a org:Organization ;
  rdfs:label "Firewall Manufacturer C"@en ;
  rdfs:comment "Manufacturer of firewall appliances."@en .

<https://example.com/SecurityTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security devices."@en .

# Relations linking nodes (examples of different types)
<https://example.com/HubNode> noria:structuralElementObservableData <https://example.com/centralityScore> .
<https://example.com/HighDegreeNode> noria:structuralElementObservableData <https://example.com/degreeMetric> .
<https://example.com/CentralNode> noria:structuralElementObservableData <https://example.com/centralityScore> .
<https://example.com/ConnectorNode> noria:structuralElementObservableData <https://example.com/connectionCount> .
<https://example.com/IntermediaryNode> noria:structuralElementObservableData <https://example.com/intermediaryLatency> .
<https://example.com/MuxNode> noria:structuralElementObservableData <https://example.com/streamCount> .
<https://example.com/SuperNode> noria:structuralElementObservableData <https://example.com/aggregationLevel> .

# All nodes are linked to at least one other node to avoid isolated nodes.