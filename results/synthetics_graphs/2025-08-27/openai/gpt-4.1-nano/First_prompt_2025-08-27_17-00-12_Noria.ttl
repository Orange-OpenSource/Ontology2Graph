@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode1>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A switch with high connectivity in the network."@en ;
  noria:structuralElementObservableData "Port count: 48"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable/PortCount> ;
  noria:structuralObservableOf <https://example.com/highDegreeNode1> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode2>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 2"@en ;
  rdfs:comment "Another high connectivity switch."@en ;
  noria:structuralElementObservableData "Port count: 24"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable/PortCount> ;
  noria:structuralObservableOf <https://example.com/highDegreeNode2> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A central router connecting multiple subnets."@en ;
  noria:structuralElementObservableData "Routing table size: 1024"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable/RoutingTableSize> ;
  noria:structuralObservableOf <https://example.com/centralNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Switch"@en ;
  rdfs:comment "A switch acting as a connector between different network segments."@en ;
  noria:structuralElementObservableData "Connected segments: 3"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable/ConnectedSegments> ;
  noria:structuralObservableOf <https://example.com/connectorNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediate Router"@en ;
  rdfs:comment "Router serving as an intermediary in the network."@en ;
  noria:structuralElementObservableData "Uptime: 365 days"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable/Uptime> ;
  noria:structuralObservableOf <https://example.com/intermediaryNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "A switch handling multiple data streams."@en ;
  noria:structuralElementObservableData "Streams handled: 10"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable/StreamsHandled> ;
  noria:structuralObservableOf <https://example.com/multiplexNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple high-degree nodes."@en ;
  noria:structuralElementObservableData "Connected nodes: 5"^^xsd:string ;
  noria:structuralElementObservable <https://example.com/observable/ConnectedNodes> ;
  noria:structuralObservableOf <https://example.com/superNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/observable/PortCount>
  a noria:StructuralObservable ;
  rdfs:label "Port Count Observable"@en ;
  rdfs:comment "Observable for the number of ports on a switch."@en .

<https://example.com/observable/RoutingTableSize>
  a noria:StructuralObservable ;
  rdfs:label "Routing Table Size Observable"@en ;
  rdfs:comment "Observable for the size of the routing table."@en .

<https://example.com/observable/Uptime>
  a noria:StructuralObservable ;
  rdfs:label "Uptime Observable"@en ;
  rdfs:comment "Observable for the uptime of a router."@en .

<https://example.com/observable/ConnectedSegments>
  a noria:StructuralObservable ;
  rdfs:label "Connected Segments Observable"@en ;
  rdfs:comment "Observable for the number of connected segments."@en .

<https://example.com/observable/StreamsHandled>
  a noria:StructuralObservable ;
  rdfs:label "Streams Handled Observable"@en ;
  rdfs:comment "Observable for the number of data streams handled."@en .

<https://example.com/observable/ConnectedNodes>
  a noria:StructuralObservable ;
  rdfs:label "Connected Nodes Observable"@en ;
  rdfs:comment "Observable for the number of connected high-degree nodes."@en .