@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, managing multiple links."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical junction."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments or domains."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow between other nodes."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple types of connections or functions."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes and functions."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Router1> a noria:StructuralElement, noria:Resource ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router in the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:structuralElementDistinguishedName "Router1-DN"^^xsd:string ;
  noria:resourceHostName "router1.example.com"^^xsd:string ;
  noria:resourceLogisticId "LOG-ROUTER1"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasValue "router" ] .

<https://example.com/Link1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between Router1 and Router2."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:networkLinkId "LINK-001"^^xsd:string ;
  noria:networkLinkType "Optical fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime .

<https://example.com/Router2> a noria:StructuralElement, noria:Resource ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Edge router in the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:structuralElementDistinguishedName "Router2-DN"^^xsd:string ;
  noria:resourceHostName "router2.example.com"^^xsd:string ;
  noria:resourceLogisticId "LOG-ROUTER2"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasValue "router" ] .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "ResourceA"@en ;
  rdfs:comment "A server hosting critical applications."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceHostName "serverA.example.com"^^xsd:string ;
  noria:resourceSerialNumber "SN-12345"^^xsd:string ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasValue "server" ] .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus1"@en ;
  rdfs:comment "Main server room."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:locusLine "Line:L, Column:6"^^xsd:string ;
  noria:locusRow "Row:3"^^xsd:string .

<https://example.com/Application1> a noria:Application ;
  rdfs:label "Application1"@en ;
  rdfs:comment "Core business application."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:applicationModelIdentifier "AppModel-XYZ"^^xsd:string ;
  noria:applicationType [ a skos:Concept ; skos:inScheme <kos/application/type> ; skos:hasValue "business" ] .

<https://example.com/Service1> a noria:Service ;
  rdfs:label "Service1"@en ;
  rdfs:comment "Customer-facing service."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:serviceType [ a skos:Concept ; skos:inScheme <kos/service/type> ; skos:hasValue "CustomerFacingService" ] ;
  rdfs:subClassOf noria:Application .

<https://example.com/TroubleTicket1> a noria:TroubleTicket ;
  rdfs:label "TroubleTicket1"@en ;
  rdfs:comment "Network outage affecting ResourceA."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:troubleTicketSeverity [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; skos:hasValue "Major" ] ;
  noria:troubleTicketType [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; skos:hasValue "Failure" ] ;
  noria:troubleTicketImpacts <https://example.com/ResourceA> ;
  noria:troubleTicketRelatedService <https://example.com/Service1> ;
  noria:troubleTicketDetectionDateTime "2023-10-01T14:30:00Z"^^xsd:dateTime .

<https://example.com/TroubleTicketNote1> a noria:TroubleTicketNote ;
  rdfs:label "Note on Ticket1"@en ;
  rdfs:comment "Customer reports no connectivity."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:troubleTicketNoteCommentType [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/commentType> ; skos:hasValue "Customer" ] ;
  noria:troubleTicketNoteOperationType [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/operationType> ; skos:hasValue "Diagnosis" ] ;
  noria:troubleTicketNoteForTicket <https://example.com/TroubleTicket1> ;
  noria:troubleTicketNoteCommentType [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/commentType> ; skos:hasValue "Customer" ] .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "ResourceB"@en ;
  rdfs:comment "Backup server."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceHostName "backupServer.example.com"^^xsd:string ;
  noria:resourceSerialNumber "SN-67890"^^xsd:string ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasValue "server" ] .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus2"@en ;
  rdfs:comment "Secondary server room."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:locusLine "Line:L, Column:12"^^xsd:string ;
  noria:locusRow "Row:5"^^xsd:string .

<https://example.com/Application2> a noria:Application ;
  rdfs:label "Application2"@en ;
  rdfs:comment "Support system."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:applicationModelIdentifier "AppModel-ABC"^^xsd:string ;
  noria:applicationType [ a skos:Concept ; skos:inScheme <kos/application/type> ; skos:hasValue "support" ] .

<https://example.com/Service2> a noria:Service ;
  rdfs:label "Service2"@en ;
  rdfs:comment "Internal support service."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:serviceType [ a skos:Concept ; skos:inScheme <kos/service/type> ; skos:hasValue "InternalSupport" ] ;
  rdfs:subClassOf noria:Application .

<https://example.com/TroubleTicket2> a noria:TroubleTicket ;
  rdfs:label "TroubleTicket2"@en ;
  rdfs:comment "Resource B is unresponsive."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:troubleTicketSeverity [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; skos:hasValue "Minor" ] ;
  noria:troubleTicketType [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; skos:hasValue "Failure" ] ;
  noria:troubleTicketImpacts <https://example.com/ResourceB> ;
  noria:troubleTicketRelatedService <https://example.com/Service2> ;
  noria:troubleTicketDetectionDateTime "2023-10-02T09:15:00Z"^^xsd:dateTime .

<https://example.com/TroubleTicketNote2> a noria:TroubleTicketNote ;
  rdfs:label "Note on Ticket2"@en ;
  rdfs:comment "Resource B is down for maintenance."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:troubleTicketNoteOperationType [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/operationType> ; skos:hasValue "Maintenance" ] ;
  noria:troubleTicketNoteForTicket <https://example.com/TroubleTicket2> .

<https://example.com/ResourceC> a noria:Resource ;
  rdfs:label "ResourceC"@en ;
  rdfs:comment "Network switch."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:locatedAtLocus <https://example.com/Locus3> ;
  noria:resourceHostName "switch1.example.com"^^xsd:string ;
  noria:resourceSerialNumber "SN-54321"^^xsd:string ;
  noria:resourceProductModel <https://example.com/ProductModelZ> ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasValue "switch" ] .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Locus3"@en ;
  rdfs:comment "Network closet."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:locusLine "Line:L, Column:2"^^xsd:string ;
  noria:locusRow "Row:1"^^xsd:string .

<https://example.com/Application3> a noria:Application ;
  rdfs:label "Application3"@en ;
  rdfs:comment "Network management system."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:applicationModelIdentifier "AppModel-NMS"^^xsd:string ;
  noria:applicationType [ a skos:Concept ; skos:inScheme <kos/application/type> ; skos:hasValue "management" ] .

<https://example.com/Service3> a noria:Service ;
  rdfs:label "Service3"@en ;
  rdfs:comment "Network monitoring service."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:serviceType [ a skos:Concept ; skos:inScheme <kos/service/type> ; skos:hasValue "Monitoring" ] ;
  rdfs:subClassOf noria:Application .

<https://example.com/TroubleTicket3> a noria:TroubleTicket ;
  rdfs:label "TroubleTicket3"@en ;
  rdfs:comment "Switch port flapping detected."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:troubleTicketSeverity [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; skos:hasValue "Warning" ] ;
  noria:troubleTicketType [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; skos:hasValue "Performance" ] ;
  noria:troubleTicketImpacts <https://example.com/ResourceC> ;
  noria:troubleTicketRelatedService <https://example.com/Service3> ;
  noria:troubleTicketDetectionDateTime "2023-10-03T16:45:00Z"^^xsd:dateTime .

<https://example.com/TroubleTicketNote3> a noria:TroubleTicketNote ;
  rdfs:label "Note on Ticket3"@en ;
  rdfs:comment "Port flapping observed on switch."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:troubleTicketNoteOperationType [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/operationType> ; skos:hasValue "Diagnosis" ] ;
  noria:troubleTicketNoteForTicket <https://example.com/TroubleTicket3> .

# Link nodes to demonstrate hubs, connectors, and high-degree nodes
<https://example.com/HubNode> noria:elementManagedBy <https://example.com/ResourceA> , <https://example.com/ResourceB> , <https://example.com/ResourceC> ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central management node connected to multiple resources."@en .

<https://example.com/HighDegreeNode> noria:structuralElementObservable <https://example.com/Router1> , <https://example.com/Router2> , <https://example.com/ResourceA> , <https://example.com/ResourceB> , <https://example.com/ResourceC> ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections acting as a critical junction."@en .

<https://example.com/CentralNode> noria:structuralElementObservable <https://example.com/ResourceA> , <https://example.com/ResourceB> , <https://example.com/ResourceC> ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node acting as a central point in the network topology."@en .

<https://example.com/ConnectorNode> noria:structuralElementObservable <https://example.com/Link1> , <https://example.com/ResourceA> , <https://example.com/ResourceB> ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en .

<https://example.com/IntermediaryNode> noria:structuralElementObservable <https://example.com/ResourceC> ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en .

<https://example.com/MultiplexNode> noria:structuralElementObservable <https://example.com/ResourceA> , <https://example.com/ResourceB> ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiple connection types."@en .

<https://example.com/SuperNode> noria:structuralElementObservable <https://example.com/ResourceA> , <https://example.com/ResourceB> , <https://example.com/ResourceC> ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple nodes and functions."@en .