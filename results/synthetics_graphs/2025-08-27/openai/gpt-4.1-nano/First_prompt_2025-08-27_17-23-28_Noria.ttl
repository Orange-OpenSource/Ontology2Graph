@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality, crucial for network integrity."@en ;
  noria:structuralElementObservableData <https://example.com/centralityScore> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/segmentLinks> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/intermediateMetrics> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservableData <https://example.com/aggregationLevel> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A core network resource."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceHostName "host1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/physical> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A virtual network resource."@en ;
  noria:resourceLogisticId "RES-002" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceHostName "vm2.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtual> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceInstallationDate "2023-03-10T12:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagedBy <https://example.com/ITSupport> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Secondary data center."@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team managing virtual resources."@en .

<https://example.com/connectionCount> a noria:structuralObservableOf ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/centralityScore> a noria:structuralObservableOf ;
  rdfs:label "Centrality Score"@en ;
  rdfs:comment "Network centrality metric."@en .

<https://example.com/segmentLinks> a noria:structuralObservableOf ;
  rdfs:label "Segment Links"@en ;
  rdfs:comment "Number of links to other segments."@en .

<https://example.com/intermediateMetrics> a noria:structuralObservableOf ;
  rdfs:label "Intermediate Metrics"@en ;
  rdfs:comment "Performance metrics of intermediary nodes."@en .

<https://example.com/streamCount> a noria:structuralObservableOf ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/aggregationLevel> a noria:structuralObservableOf ;
  rdfs:label "Aggregation Level"@en ;
  rdfs:comment "Level of data aggregation in super nodes."@en .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model for physical resources."@en ;
  rdfs:seeAlso <https://example.com/ManufacturerA> .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Manufacturer's model for virtual resources."@en ;
  rdfs:seeAlso <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "Manufacturer A"@en ;
  rdfs:comment "Leading hardware manufacturer."@en .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "Manufacturer B"@en ;
  rdfs:comment "Virtualization platform provider."@en .

<https://example.com/NetworkAdmin> a org:OrganizationalUnit ;
  rdfs:label "Network Administration"@en ;
  rdfs:comment "Admin team for physical network resources."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Support team for virtual resources."@en .