@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node connecting multiple network segments, high-degree node."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A switch with many connections acting as a hub in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyData> ;
  noria:structuralObservableOf <https://example.com/NetworkSwitch1> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "A core router acting as a central node in the network topology."@en ;
  noria:structuralElementObservableData <https://example.com/trafficData> ;
  noria:structuralObservableOf <https://example.com/RouterCore> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments, serving as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary device facilitating communication between hubs."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:structuralObservableOf <https://example.com/LoadBalancer1> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams, acting as a multiplex."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/Multiplexer1> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An advanced super node aggregating multiple nodes for high performance."@en ;
  noria:structuralElementObservableData <https://example.com/performanceMetrics> ;
  noria:structuralObservableOf <https://example.com/SuperSwitch> .

<https://example.com/NetworkOpsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/NetworkSwitch1>
  a noria:StructuralElement ;
  rdfs:label "Switch 1"@en ;
  rdfs:comment "A high-degree switch in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/RouterCore>
  a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A central router in the core network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Firewall1>
  a noria:StructuralElement ;
  rdfs:label "Firewall 1"@en ;
  rdfs:comment "A connector node providing security."@en ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/LoadBalancer1>
  a noria:StructuralElement ;
  rdfs:label "Load Balancer 1"@en ;
  rdfs:comment "An intermediary node balancing load."@en ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Multiplexer1>
  a noria:StructuralElement ;
  rdfs:label "Multiplexer 1"@en ;
  rdfs:comment "A multiplex node handling multiple streams."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/SuperSwitch>
  a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "A super node aggregating multiple high-performance nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/latencyData>
  a noria:StructuralObservable ;
  rdfs:label "Latency Data"@en ;
  rdfs:comment "Latency measurements for network nodes."@en .

<https://example.com/trafficData>
  a noria:StructuralObservable ;
  rdfs:label "Traffic Data"@en ;
  rdfs:comment "Traffic volume data for core routers."@en .

<https://example.com/connectionStatus>
  a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of network connections."@en .

<https://example.com/streamCount>
  a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams handled by multiplexers."@en .

<https://example.com/performanceMetrics>
  a noria:StructuralObservable ;
  rdfs:label "Performance Metrics"@en ;
  rdfs:comment "Aggregated performance metrics for super nodes."@en .

<https://example.com/NetworkEngineering>
  a org:OrganizationalUnit ;
  rdfs:label "Network Engineering"@en ;
  rdfs:comment "Engineering team responsible for high-performance network nodes."@en .

