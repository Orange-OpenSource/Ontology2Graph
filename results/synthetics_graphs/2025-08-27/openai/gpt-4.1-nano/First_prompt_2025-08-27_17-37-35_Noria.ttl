@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/HubNode1> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core network hub."@en ;
  noria:elementManagedBy <https://example.com/OrgDept1> .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a central point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/NodeDegree> ;
  noria:structuralObservableOf <https://example.com/HubNode1> .

<https://example.com/CentralNode1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that connects multiple network segments, serving as a central point."@en ;
  noria:structuralElementObservableData <https://example.com/TrafficVolume> ;
  noria:structuralElementObservable <https://example.com/HubNode1> .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network parts."@en ;
  noria:structuralElementObservableData <https://example.com/ConnectionCount> ;
  noria:structuralElementObservable <https://example.com/CentralNode1> .

<https://example.com/IntermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that intermediates data flow between other nodes."@en ;
  noria:structuralElementObservableData <https://example.com/IntermediaryLoad> ;
  noria:structuralElementObservable <https://example.com/ConnectorNode1> .

<https://example.com/MultiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams or functions."@en ;
  noria:structuralElementObservableData <https://example.com/StreamCount> ;
  noria:structuralElementObservable <https://example.com/IntermediaryNode1> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/SuperNodeTraffic> ;
  noria:structuralElementObservable <https://example.com/MultiplexNode1> .

<https://example.com/NodeDegree> a noria:Property ;
  rdfs:label "Node Degree"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/TrafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Amount of data passing through the node."@en .

<https://example.com/ConnectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at the node."@en .

<https://example.com/IntermediaryLoad> a noria:Property ;
  rdfs:label "Intermediary Load"@en ;
  rdfs:comment "Current load on the intermediary node."@en .

<https://example.com/StreamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/SuperNodeTraffic> a noria:Property ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Aggregated traffic passing through the super node."@en .

<https://example.com/OrgDept1> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Department"@en ;
  rdfs:comment "The department responsible for network management."@en .

<https://example.com/Node1> a noria:StructuralElement ;
  rdfs:label "Node 1"@en ;
  rdfs:comment "A regular network node with moderate connections."@en ;
  noria:structuralElementObservableData <https://example.com/Node1Load> ;
  noria:elementManagedBy <https://example.com/OrgDept1> .

<https://example.com/Node1Load> a noria:Property ;
  rdfs:label "Node 1 Load"@en ;
  rdfs:comment "Current load on Node 1."@en .

<https://example.com/Node2> a noria:StructuralElement ;
  rdfs:label "Node 2"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/Node2Traffic> ;
  noria:elementManagedBy <https://example.com/OrgDept1> .

<https://example.com/Node2Traffic> a noria:Property ;
  rdfs:label "Node 2 Traffic"@en ;
  rdfs:comment "Traffic passing through Node 2."@en .

<https://example.com/Node3> a noria:StructuralElement ;
  rdfs:label "Node 3"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/Node3Streams> ;
  noria:elementManagedBy <https://example.com/OrgDept1> .

<https://example.com/Node3Streams> a noria:Property ;
  rdfs:label "Node 3 Streams"@en ;
  rdfs:comment "Number of streams multiplexed at Node 3."@en .

<https://example.com/Node4> a noria:StructuralElement ;
  rdfs:label "Node 4"@en ;
  rdfs:comment "An intermediary node with high load."@en ;
  noria:structuralElementObservableData <https://example.com/Node4Load> ;
  noria:elementManagedBy <https://example.com/OrgDept1> .

<https://example.com/Node4Load> a noria:Property ;
  rdfs:label "Node 4 Load"@en ;
  rdfs:comment "Current load on Node 4."@en .

<https://example.com/HubNode2> a noria:StructuralElement ;
  rdfs:label "Hub Node 2"@en ;
  rdfs:comment "A hub node with high degree and central position."@en ;
  noria:structuralElementObservableData <https://example.com/HubNode2Degree> ;
  noria:elementManagedBy <https://example.com/OrgDept1> .

<https://example.com/HubNode2Degree> a noria:Property ;
  rdfs:label "Hub Node 2 Degree"@en ;
  rdfs:comment "Number of connections for Hub Node 2."@en .

<https://example.com/SuperNode2> a noria:StructuralElement ;
  rdfs:label "Super Node 2"@en ;
  rdfs:comment "A super node aggregating multiple hub nodes."@en ;
  noria:structuralElementObservableData <https://example.com/SuperNode2Traffic> ;
  noria:elementManagedBy <https://example.com/OrgDept1> .

<https://example.com/SuperNode2Traffic> a noria:Property ;
  rdfs:label "Super Node 2 Traffic"@en ;
  rdfs:comment "Total traffic passing through Super Node 2."@en .