@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity, acting as a critical junction in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node coordinating network traffic."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/throughput> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple network functions."@en ;
  noria:structuralObservableOf <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes."@en .

<https://example.com/latencyMeasurement> a noria:StructuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Measured latency between nodes."@en .

<https://example.com/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of network connections."@en .

<https://example.com/throughput> a noria:StructuralObservableData ;
  rdfs:label "Throughput"@en ;
  rdfs:comment "Data throughput rate."@en .

<https://example.com/streamCount> a noria:StructuralObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/aggregateTraffic> a noria:StructuralObservable ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Total traffic aggregated at super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A network resource, such as a server or switch."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:resourceHostName "server1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/physical> ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Location of Resource 1 in the data center."@en ;
  noria:locusLine "Line: L, Column: 6"@en ;
  noria:locusRow "Row: R"@en .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Another network resource."@en ;
  noria:resourceLogisticId "RES-002" ;
  noria:resourceHostName "switch1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtual> ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Location of Resource 2."@en ;
  noria:locusLine "Line: M, Column: 12"@en ;
  noria:locusRow "Row: S"@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource 1 and Resource 2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource1> noria:networkLinkConnects <https://example.com/NetworkLink1> .
<https://example.com/Resource2> noria:networkLinkConnects <https://example.com/NetworkLink1> .

<https://example.com/HubNode2> a noria:ManagedElement ;
  rdfs:label "Secondary Hub Node"@en ;
  rdfs:comment "A hub node with high connectivity but less central than the main hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode2> a noria:StructuralElement ;
  rdfs:label "Secondary Central Node"@en ;
  rdfs:comment "A central node with significant traffic handling capacity."@en ;
  noria:structuralObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/connectorNode2> a noria:StructuralElement ;
  rdfs:label "Secondary Connector Node"@en ;
  rdfs:comment "A connector node linking secondary network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryNode2> a noria:StructuralElement ;
  rdfs:label "Secondary Intermediary Node"@en ;
  rdfs:comment "An intermediary node in the secondary network."@en ;
  noria:structuralElementObservableData <https://example.com/throughput> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode2> a noria:StructuralElement ;
  rdfs:label "Secondary Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple streams in secondary network."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode2> a noria:StructuralElement ;
  rdfs:label "Secondary Super Node"@en ;
  rdfs:comment "Aggregates multiple network functions in secondary network."@en ;
  noria:structuralObservableOf <https://example.com/aggregateTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .