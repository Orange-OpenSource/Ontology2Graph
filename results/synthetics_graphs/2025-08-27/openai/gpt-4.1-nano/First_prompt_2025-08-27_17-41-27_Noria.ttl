@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:structuralObservableOf <https://example.com/RouterA> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:structuralObservableOf <https://example.com/Switch1> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node serving as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/throughput> ;
  noria:structuralObservableOf <https://example.com/LoadBalancer1> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamLatency> ;
  noria:structuralObservableOf <https://example.com/Multiplexer1> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level analysis."@en ;
  noria:structuralElementObservableData <https://example.com/overallTraffic> ;
  noria:structuralObservableOf <https://example.com/NetworkCluster> .

<https://example.com/RouterA> a noria:StructuralElement ;
  rdfs:label "Router A"@en ;
  rdfs:comment "Core router in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Switch1> a noria:StructuralElement ;
  rdfs:label "Switch 1"@en ;
  rdfs:comment "Distribution switch in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Firewall1> a noria:StructuralElement ;
  rdfs:label "Firewall 1"@en ;
  rdfs:comment "Security firewall device."@en ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/LoadBalancer1> a noria:StructuralElement ;
  rdfs:label "Load Balancer 1"@en ;
  rdfs:comment "Application load balancer."@en ;
  noria:elementManagedBy <https://example.com/AppOpsTeam> .

<https://example.com/Multiplexer1> a noria:StructuralElement ;
  rdfs:label "Multiplexer 1"@en ;
  rdfs:comment "Data stream multiplexer."@en ;
  noria:elementManagedBy <https://example.com/StreamTeam> .

<https://example.com/NetworkCluster> a noria:StructuralElement ;
  rdfs:label "Network Cluster"@en ;
  rdfs:comment "Cluster of network nodes for high availability."@en ;
  noria:elementManagedBy <https://example.com/ClusterAdmin> .

<https://example.com/latencyMeasurement> a noria:StructuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Average latency in milliseconds."@en .

<https://example.com/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load in Mbps."@en .

<https://example.com/connectionQuality> a noria:StructuralObservable ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Quality indicator of the connection."@en .

<https://example.com/throughput> a noria:StructuralObservable ;
  rdfs:label "Throughput"@en ;
  rdfs:comment "Data throughput in Mbps."@en .

<https://example.com/overallTraffic> a noria:StructuralObservable ;
  rdfs:label "Overall Traffic"@en ;
  rdfs:comment "Total network traffic in Gbps."@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security devices."@en .

<https://example.com/AppOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Application Operations Team"@en ;
  rdfs:comment "Team managing application resources."@en .

<https://example.com/StreamTeam> a org:OrganizationalUnit ;
  rdfs:label "Stream Management Team"@en ;
  rdfs:comment "Team managing data streams."@en .

<https://example.com/ClusterAdmin> a org:OrganizationalUnit ;
  rdfs:label "Cluster Administration"@en ;
  rdfs:comment "Admin team for network clusters."@en .