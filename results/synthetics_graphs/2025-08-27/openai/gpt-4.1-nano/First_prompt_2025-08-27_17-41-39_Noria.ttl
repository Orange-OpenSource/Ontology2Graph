<https://w3id.org/noria/instance/Network1> a noria:ManagedElement ;
  rdfs:label "Core Network Switch"@en ;
  rdfs:comment "A high-performance core switch in the main data center."@en ;
  noria:elementManagedBy <https://w3id.org/noria/instance/OrgSupportTeam> ;
  noria:structuralElementDistinguishedName "Switch-DC1-Core" ;
  noria:resourceHostName "core-switch-01.datacenter.local" ;
  noria:resourceLogisticId "LOG-DC1-CORE-01" ;
  noria:resourceSerialNumber "SN-DC1-123456" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkSwitch> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Room314> .

<https://w3id.org/noria/instance/Resource2> a noria:Resource ;
  rdfs:label "Web Server 1"@en ;
  rdfs:comment "Primary web server hosting the main website."@en ;
  noria:elementManagedBy <https://w3id.org/noria/instance/OrgWebTeam> ;
  noria:resourceHostName "webserver1.datacenter.local" ;
  noria:resourceSerialNumber "SN-WEB-0001" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> .

<https://w3id.org/noria/instance/Resource3> a noria:Resource ;
  rdfs:label "Firewall Device"@en ;
  rdfs:comment "Firewall appliance controlling network access."@en ;
  noria:elementManagedBy <https://w3id.org/noria/instance/OrgSecurityTeam> ;
  noria:resourceHostName "firewall-01.datacenter.local" ;
  noria:resourceSerialNumber "SN-FW-7890" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Room314> .

<https://w3id.org/noria/instance/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link DC1 to DC2"@en ;
  rdfs:comment "Optical fiber connection between data centers."@en ;
  noria:networkLinkId "LINK-DC1-DC2" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://w3id.org/noria/instance/Resource2> ;
  noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/instance/Resource4> .

<https://w3id.org/noria/instance/Resource4> a noria:Resource ;
  rdfs:label "Database Server"@en ;
  rdfs:comment "Main database server for customer data."@en ;
  noria:elementManagedBy <https://w3id.org/noria/instance/OrgDBTeam> ;
  noria:resourceHostName "db-server-01.datacenter.local" ;
  noria:resourceSerialNumber "SN-DB-54321" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Room315> .

<https://w3id.org/noria/instance/Room314> a noria:Room ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Main server room on the first floor."@en .

<https://w3id.org/noria/instance/Room315> a noria:Room ;
  rdfs:label "Server Room 315"@en ;
  rdfs:comment "Secondary server room on the first floor."@en .

<https://w3id.org/noria/instance/OrgSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team responsible for network infrastructure."@en .

<https://w3id.org/noria/instance/OrgWebTeam> a org:OrganizationalUnit ;
  rdfs:label "Web Services Team"@en ;
  rdfs:comment "Team managing web servers and related services."@en .

<https://w3id.org/noria/instance/OrgSecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security appliances and policies."@en .

<https://w3id.org/noria/instance/OrgDBTeam> a org:OrganizationalUnit ;
  rdfs:label "Database Support Team"@en ;
  rdfs:comment "Team managing database servers."@en .

<https://w3id.org/noria/instance/Locus1> a noria:Locus ;
  rdfs:label "Locus for Web Server 1"@en ;
  rdfs:comment "Physical location of Web Server 1."@en .

<https://w3id.org/noria/instance/Locus2> a noria:Locus ;
  rdfs:label "Locus for Database Server"@en ;
  rdfs:comment "Physical location of Database Server."@en .

