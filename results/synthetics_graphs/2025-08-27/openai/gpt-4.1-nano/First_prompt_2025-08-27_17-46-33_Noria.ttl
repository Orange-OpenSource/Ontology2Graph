@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node connecting multiple high-degree nodes in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode1>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A switch with high connectivity serving as a connector in the network."@en ;
  noria:structuralElementObservable <https://example.com/observable/PortStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode2>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Router 2"@en ;
  rdfs:comment "A router with multiple links acting as a central node."@en ;
  noria:structuralElementObservable <https://example.com/observable/TrafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Core Switch"@en ;
  rdfs:comment "A core switch acting as a central node in the topology."@en ;
  noria:structuralElementObservable <https://example.com/observable/PortStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/LinkStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary device facilitating communication between hubs."@en ;
  noria:structuralElementObservable <https://example.com/observable/TrafficFlow> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple protocols or services."@en ;
  noria:structuralElementObservable <https://example.com/observable/ProtocolUsage> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for load balancing."@en ;
  noria:structuralElementObservable <https://example.com/observable/LoadMetrics> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/NetworkOperationsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network nodes and links."@en .

<https://example.com/observable/PortStatus>
  a noria:StructuralObservable ;
  rdfs:label "Port Status"@en ;
  rdfs:comment "Indicates whether a port is up or down."@en .

<https://example.com/observable/TrafficLoad>
  a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load on a node."@en .

<https://example.com/observable/LinkStatus>
  a noria:StructuralObservable ;
  rdfs:label "Link Status"@en ;
  rdfs:comment "Status of the network link (active/inactive)."@en .

<https://example.com/observable/TrafficFlow>
  a noria:StructuralObservable ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Flow of data between nodes."@en .

<https://example.com/observable/ProtocolUsage>
  a noria:StructuralObservable ;
  rdfs:label "Protocol Usage"@en ;
  rdfs:comment "Protocols supported by multiplex nodes."@en .

<https://example.com/observable/LoadMetrics>
  a noria:StructuralObservable ;
  rdfs:label "Load Metrics"@en ;
  rdfs:comment "Metrics indicating load balancing status."@en .

<https://example.com/LoadBalancer>
  a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "A super node responsible for distributing network traffic."@en ;
  noria:structuralElementObservable <https://example.com/observable/LoadMetrics> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/Resource1>
  a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A network resource such as a server or switch."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:resourceHostName "server1.example.com" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceType <https://example.com/kos/Resource/type/Server> ;
  noria:resourceUsageState <https://example.com/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceManagedBy <https://example.com/NetworkOps> .

<https://example.com/Locus1>
  a noria:Locus ;
  rdfs:label "Locus in Server Room 314"@en ;
  rdfs:comment "Location within the server room."@en ;
  noria:locusLine "Line:L, Column:6"@en ;
  noria:locusRow "Row:3"@en .

<https://example.com/NetworkLink1>
  a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber connecting Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkInstallationDate "2021-12-01T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource2>
  a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Another network device."@en ;
  noria:resourceLogisticId "RES-002" ;
  noria:resourceHostName "switch2.example.com" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceType <https://example.com/kos/Resource/type/Switch> ;
  noria:resourceUsageState <https://example.com/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-02-20T11:00:00Z"^^xsd:dateTime ;
  noria:resourceManagedBy <https://example.com/NetworkOps> .

<https://example.com/Locus2>
  a noria:Locus ;
  rdfs:label "Locus in Data Center"@en ;
  rdfs:comment "Location in data center."@en ;
  noria:locusLine "Line:L, Column:12"@en ;
  noria:locusRow "Row:7"@en .

<https://example.com/NetworkOps>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Team managing network infrastructure."@en .

<https://example.com/NetworkOps>
  a foaf:Agent ;
  rdfs:label "Network Operator Alice"@en ;
  rdfs:comment "Network operator responsible for managing resources."@en .

<https://example.com/HubNode>
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeSwitch1>
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeRouter2>
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/CoreSwitch>
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/ConnectorNode>
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/IntermediaryNode>
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/MuxNode>
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/SuperNode>
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/LoadBalancer>
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/Resource1>
  a noria:Resource ;
  rdfs:label "Resource 1"@en .

<https://example.com/Resource2>
  a noria:Resource ;
  rdfs:label "Resource 2"@en .

<https://example.com/NetworkLink1>
  a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en .

<https://example.com/NetworkOps>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en .

<https://example.com/NetworkOps>
  a foaf:Agent ;
  rdfs:label "Network Operator Alice"@en .

# End of graph