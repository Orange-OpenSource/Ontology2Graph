@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/ConnectivityScore> ;
  noria:structuralElementDistinguishedName "HDN-001" .

<https://example.com/centralNode> a noria:FunctionalElement ;
  rdfs:label "Central Management Server"@en ;
  rdfs:comment "A core server responsible for central management tasks."@en ;
  noria:elementManagedBy <https://example.com/ITAdminTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node serving as a connector between different network domains."@en ;
  noria:structuralElementObservable <https://example.com/LinkQuality> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/Latency> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/StreamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for load balancing."@en ;
  noria:structuralElementObservableData <https://example.com/LoadAverage> .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A critical network resource."@en ;
  noria:resourceLogisticId "RES-A-123" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceHostName "serverA.example.com" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceSerialNumber "SN-RES-A-001" ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A virtual network resource."@en ;
  noria:resourceLogisticId "RES-B-456" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:resourceHostName "vmB.example.com" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Provisioned> ;
  noria:resourceSerialNumber "SN-RES-B-002" ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagedBy <https://example.com/CloudAdmin> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource A and Resource B."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/NetworkInterfaceA> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource A."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet Interface"@en ;
  noria:networkInterfaceOf <https://example.com/ResourceA> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
  noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> .

<https://example.com/NetworkInterfaceB> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary network interface of Resource B."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "Virtual Interface for management."@en ;
  noria:networkInterfaceOf <https://example.com/ResourceB> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
  noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "Line: L, in Room: Server Room 1"@en ;
  noria:locusRow "Row: R"@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Data center rack."@en ;
  noria:locusLine "Line: L2, in Data Center"@en ;
  noria:locusRow "Row: R2"@en .

<https://example.com/LinkQuality> a noria:Property ;
  rdfs:label "Link Quality"@en ;
  rdfs:comment "A measure of link quality between nodes."@en .

<https://example.com/ConnectivityScore> a noria:Property ;
  rdfs:label "Connectivity Score"@en ;
  rdfs:comment "A score indicating the connectivity robustness."@en .

<https://example.com/LinkSpeed> a noria:Property ;
  rdfs:label "Link Speed"@en ;
  rdfs:comment "Speed of the network link in Mbps."@en .

<https://example.com/StreamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/LoadAverage> a noria:Property ;
  rdfs:label "Load Average"@en ;
  rdfs:comment "Average load on the super node."@en .

<https://example.com/ResourceManagementTeam> a org:OrganizationalUnit ;
  rdfs:label "Resource Management Team"@en ;
  rdfs:comment "Team responsible for resource management."@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team managing network infrastructure."@en .

<https://example.com/CloudAdmin> a org:OrganizationalUnit ;
  rdfs:label "Cloud Administration"@en ;
  rdfs:comment "Team managing cloud resources."@en .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance server model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Virtual machine template."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "TechCorp Inc."@en ;
  rdfs:comment "Manufacturer of high-end servers."@en .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "VirtualSoft Ltd."@en ;
  rdfs:comment "Provider of VM templates."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Network support team."@en .

<https://example.com/ITAdminTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Administration Team"@en ;
  rdfs:comment "Team responsible for IT management."@en .

<https://example.com/CloudAdmin> a org:OrganizationalUnit ;
  rdfs:label "Cloud Admin Team"@en ;
  rdfs:comment "Team managing cloud infrastructure."@en .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "Main application server."@en .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "Virtualized database server."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber between Resource A and Resource B."@en .

<https://example.com/NetworkInterfaceA> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary interface of Resource A."@en .

<https://example.com/NetworkInterfaceB> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Management interface of Resource B."@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Main Server Room"@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Data Center Rack"@en .

<https://example.com/LoadAverage> a noria:Property ;
  rdfs:label "Load Average"@en .

<https://example.com/ConnectivityScore> a noria:Property ;
  rdfs:label "Connectivity Score"@en .

<https://example.com/LinkQuality> a noria:Property ;
  rdfs:label "Link Quality"@en .

<https://example.com/StreamCount> a noria:Property ;
  rdfs:label "Stream Count"@en .

<https://example.com/ResourceManagementTeam> a org:OrganizationalUnit ;
  rdfs:label "Resource Management Team"@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en .

<https://example.com/CloudAdmin> a org:OrganizationalUnit ;
  rdfs:label "Cloud Administration"@en .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "TechCorp Inc."@en .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "VirtualSoft Ltd."@en .