@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, managing multiple links."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/latency> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/throughput> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An aggregated node representing a superordinate network component."@en ;
  noria:structuralElementObservable <https://example.com/aggregateLatency> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A critical network resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceHostName "host-resource1" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A secondary network resource."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceHostName "host-resource2" .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Locus in Server Room 314."@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Locus in Data Center 1."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Optical Fiber Link"@en ;
  rdfs:comment "A high-speed optical fiber connection."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/Resource1_NetworkInterface> a noria:NetworkInterface ;
  rdfs:label "Resource1 Ethernet Interface"@en ;
  rdfs:comment "Ethernet interface of Resource 1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "GigabitEthernet0/0/1"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> .

<https://example.com/Resource2_NetworkInterface> a noria:NetworkInterface ;
  rdfs:label "Resource2 Virtual Interface"@en ;
  rdfs:comment "Virtual network interface of Resource 2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "VLAN 100"@en ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating the link is operational."@en ;
  noria:loggingTime "2023-10-01T12:00:00"^^xsd:dateTime ;
  noria:logText "The optical fiber link NLINK001 is now active."@en ;
  noria:logOriginatingManagedObject <https://example.com/NetworkLink1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/NetworkOpsAgent> ;
  noria:alarmSeverity <https://example.com/CriticalSeverity> .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en .

<https://example.com/NetworkOpsAgent> a foaf:Agent ;
  rdfs:label "Network Operations Agent"@en .

<https://example.com/CriticalSeverity> a skos:Concept ;
  rdfs:label "Critical"@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Measured traffic volume in Mbps."@en .

<https://example.com/latency> a noria:Property ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency in milliseconds."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/aggregateLatency> a noria:Property ;
  rdfs:label "Aggregate Latency"@en ;
  rdfs:comment "Average latency across the network segment."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "An additional network resource."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:locatedAtLocus <https://example.com/LocusC> ;
  noria:resourceHostName "host-resource3" .

<https://example.com/LocusC> a noria:Locus ;
  rdfs:label "Locus C"@en ;
  rdfs:comment "Locus in Main Data Center."@en .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Backup Link"@en ;
  rdfs:comment "A secondary backup link."@en ;
  noria:networkLinkId "NLINK002" ;
  noria:networkLinkInstallationDate "2023-05-20T09:30:00"^^xsd:dateTime ;
  noria:networkLinkType "Ethernet" .

<https://example.com/Resource3_NetworkInterface> a noria:NetworkInterface ;
  rdfs:label "Resource3 Ethernet Interface"@en ;
  rdfs:comment "Ethernet interface of Resource 3."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Ethernet0/1"@en ;
  noria:networkInterfaceOf <https://example.com/Resource3> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink2> .

<https://example.com/Event2> a noria:EventRecord ;
  rdfs:label "Link Down Event"@en ;
  rdfs:comment "Event indicating the link is down."@en ;
  noria:loggingTime "2023-10-02T15:45:00"^^xsd:dateTime ;
  noria:logText "The backup link NLINK002 has gone down."@en ;
  noria:logOriginatingManagedObject <https://example.com/NetworkLink2> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS2> ;
  noria:logOriginatingAgent <https://example.com/NetworkOpsAgent> ;
  noria:alarmSeverity <https://example.com/MajorSeverity> .

<https://example.com/NMS2> a noria:Application ;
  rdfs:label "Network Management System 2"@en .

<https://example.com/MajorSeverity> a skos:Concept ;
  rdfs:label "Major"@en .

<https://example.com/NetworkOpsAgent> a foaf:Agent ;
  rdfs:label "Network Operations Agent"@en .

