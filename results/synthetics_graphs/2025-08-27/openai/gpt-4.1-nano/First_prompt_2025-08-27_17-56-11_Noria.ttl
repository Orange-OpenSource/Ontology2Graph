@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Hub Node: Central Resource representing a core network device
<https://example.com/Resource/Hub1> a noria:Resource ;
  rdfs:label "Main Data Center Router"@en ;
  rdfs:comment "Core router acting as a hub for internal network traffic."@en ;
  noria:resourceLogisticId "DC-Router-001" ;
  noria:resourceHostName "core-router-01.datacenter.local" ;
  noria:locatedAtLocus <https://example.com/Locus/Room314> ;
  noria:resourceType <https://example.com/ResourceType/Router> ;
  noria:resourceSerialNumber "SN123456789" ;
  noria:resourceUsageState <https://example.com/Usage/Operational> ;
  noria:resourceInstallationDate "2022-01-15T09:00:00"^^xsd:dateTime ;
  rdfs:label "Main Data Center Router" ;
  rdfs:comment "Core router acting as a hub for internal network traffic." .

# High-Degree Node: Application representing a critical business system
<https://example.com/Application/CRM> a noria:Application ;
  rdfs:label "Customer Relationship Management System"@en ;
  rdfs:comment "Application managing customer data and interactions."@en ;
  noria:applicationModelIdentifier "CRM-Model-2023" ;
  noria:applicationNumericalIdentifier 101 ;
  noria:applicationShortIdentifier "CRM" ;
  noria:applicationType <https://example.com/Type/BusinessApplication> ;
  noria:applicationBusinessImportance <https://example.com/Impact/High> ;
  noria:applicationFunctionalDomain "Customer Management" ;
  noria:applicationFunctionalSubDomain "Sales and Support" ;
  rdfs:label "CRM System" .

# Connector Node: Network Interface connected to the core router
<https://example.com/NetworkInterface/eth0> a noria:NetworkInterface ;
  rdfs:label "eth0" ;
  rdfs:comment "Ethernet interface on core router."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "GigabitEthernet0/0/1" ;
  noria:networkInterfaceOf <https://example.com/Resource/Hub1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink/Link1> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3.5 ;
  noria:networkInterfaceLaserRxOpticalPowerAverage -3.2 ;
  noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
  noria:networkInterfaceLaserRxLowPowerWarningThreshold -5 ;
  rdfs:label "eth0" .

# Intermediary Node: Network Link connecting core router to a switch
<https://example.com/NetworkLink/Link1> a noria:NetworkLink ;
  rdfs:label "Fiber Link DC to Switch" ;
  rdfs:comment "Optical fiber connection between core router and distribution switch."@en ;
  noria:networkLinkId "Link-DC-Switch" ;
  noria:networkLinkType "optical fiber" ;
  noria:networkLinkInstallationDate "2022-01-16T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource/Hub1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource/Switch1> ;
  rdfs:label "Fiber Link DC to Switch" .

# Multiplex Node: Application Module representing a support team
<https://example.com/ApplicationModule/SupportTeam> a noria:ApplicationModule ;
  rdfs:label "Support Team NOC" ;
  rdfs:comment "Network Operations Center support team responsible for incident handling."@en ;
  noria:applicationModuleIdentifier "NOC-01" ;
  noria:applicationModuleName "NOC Support" ;
  noria:applicationModuleSupportGroup <https://example.com/Organization/NOC> ;
  noria:applicationModuleSupportLeader <https://example.com/Agent/SupportLead> ;
  noria:applicationModuleSupportTeam <https://example.com/Organization/NOC> ;
  noria:applicationModuleHotlineGroup <https://example.com/Organization/Hotline> ;
  noria:applicationModuleSlaLevel <https://example.com/Sla/Level1> ;
  noria:applicationModuleStatus <https://example.com/Status/Active> ;
  rdfs:label "NOC Support Module" .

# Super Node: Organization representing a large enterprise
<https://example.com/Organization/NOC> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "Organization responsible for network monitoring and incident response."@en ;
  org:organizationName "Enterprise NOC" .

# Additional Nodes for clarity
<https://example.com/Agent/SupportLead> a foaf:Agent ;
  rdfs:label "Support Team Lead" ;
  rdfs:comment "Lead of the NOC support team."@en .

<https://example.com/Sla/Level1> a skos:Concept ;
  rdfs:label "SLA Level 1"@en ;
  skos:inScheme <https://example.com/Scheme/SLA> .

<https://example.com/Status/Active> a skos:Concept ;
  rdfs:label "Active"@en ;
  skos:inScheme <https://example.com/Scheme/Status> .

# Dismissed isolated nodes (no relations) are not included, all nodes have at least one link.