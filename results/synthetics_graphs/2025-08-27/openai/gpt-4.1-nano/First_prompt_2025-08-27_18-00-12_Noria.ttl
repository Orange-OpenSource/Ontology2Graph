@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node in the network, managing multiple connections."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch."@en ;
  noria:structuralElementObservableData <https://example.com/observable/portCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/CentralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Server"@en ;
  rdfs:comment "A central node hosting critical applications."@en ;
  noria:structuralElementObservableData <https://example.com/observable/cpuLoad> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/observable/connectionStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic."@en ;
  noria:structuralElementObservableData <https://example.com/observable/trafficDistribution> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/MultiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/observable/streamCount> ;
  noria:elementManagedBy <https://example.com/TelecomTeam> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Global Network Super Node"@en ;
  rdfs:comment "A super node representing a global network backbone."@en ;
  noria:structuralElementObservableData <https://example.com/observable/totalBandwidth> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing core network nodes."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for data center servers."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team managing security devices and firewalls."@en .

<https://example.com/TelecomTeam> a org:OrganizationalUnit ;
  rdfs:label "Telecom Support Team"@en ;
  rdfs:comment "Team managing telecom multiplexers."@en .

<https://example.com/NetworkManagement> a org:OrganizationalUnit ;
  rdfs:label "Network Management"@en ;
  rdfs:comment "Oversees the entire network infrastructure."@en .

<https://example.com/observable/portCount> a noria:StructuralObservable ;
  rdfs:label "Port Count"@en ;
  rdfs:comment "Number of ports available on the switch."@en .

<https://example.com/observable/cpuLoad> a noria:StructuralObservable ;
  rdfs:label "CPU Load"@en ;
  rdfs:comment "Current CPU load percentage of the server."@en .

<https://example.com/observable/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the network connection (up/down)."@en .

<https://example.com/observable/trafficDistribution> a noria:StructuralObservable ;
  rdfs:label "Traffic Distribution"@en ;
  rdfs:comment "Distribution of network traffic across interfaces."@en .

<https://example.com/observable/streamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/observable/totalBandwidth> a noria:StructuralObservable ;
  rdfs:label "Total Bandwidth"@en ;
  rdfs:comment "Aggregate bandwidth capacity of the super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Physical resource representing a network device."@en ;
  noria:locatedAtLocus <https://example.com/Locus1> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "Location of core network devices."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between two core nodes."@en .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Virtual machine hosting critical applications."@en ;
  noria:locatedAtLocus <https://example.com/Locus2> .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Server Room 2"@en ;
  rdfs:comment "Secondary data center location."@en .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "L2 Switch Connection"@en ;
  rdfs:comment "Logical connection between switches."@en .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "Firewall device."@en ;
  noria:locatedAtLocus <https://example.com/Locus3> .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Security Zone"@en ;
  rdfs:comment "Security segment of the network."@en .

<https://example.com/NetworkLink3> a noria:NetworkLink ;
  rdfs:label "Firewall Link"@en ;
  rdfs:comment "Link between security zones."@en .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Resource 4"@en ;
  rdfs:comment "Load balancer device."@en ;
  noria:locatedAtLocus <https://example.com/Locus4> .

<https://example.com/Locus4> a noria:Locus ;
  rdfs:label "Application Layer"@en ;
  rdfs:comment "Layer for application traffic."@en .

<https://example.com/NetworkLink4> a noria:NetworkLink ;
  rdfs:label "Load Balancer Link"@en ;
  rdfs:comment "Connection to distribute traffic."@en .

<https://example.com/Resource5> a noria:Resource ;
  rdfs:label "Resource 5"@en ;
  rdfs:comment "Multiplexer device."@en ;
  noria:locatedAtLocus <https://example.com/Locus5> .

<https://example.com/Locus5> a noria:Locus ;
  rdfs:label "Telecom Hub"@en ;
  rdfs:comment "Telecom aggregation point."@en .

<https://example.com/NetworkLink5> a noria:NetworkLink ;
  rdfs:label "Multiplexer Link"@en ;
  rdfs:comment "Link connecting multiplexing devices."@en .

<https://example.com/Resource6> a noria:Resource ;
  rdfs:label "Resource 6"@en ;
  rdfs:comment "Global backbone node."@en ;
  noria:locatedAtLocus <https://example.com/Locus6> .

<https://example.com/Locus6> a noria:Locus ;
  rdfs:label "Global Backbone"@en ;
  rdfs:comment "Main backbone node for the entire network."@en .

<https://example.com/NetworkLink6> a noria:NetworkLink ;
  rdfs:label "Backbone Link"@en ;
  rdfs:comment "High capacity backbone link."@en .

# End of graph