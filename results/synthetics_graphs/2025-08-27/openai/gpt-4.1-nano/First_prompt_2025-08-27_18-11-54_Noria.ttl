@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/opsTeam> .

<https://example.com/highDegreeNode1>
  a noria:StructuralElement, noria:Resource ;
  rdfs:label "High-Degree Node 1"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a key resource."@en ;
  noria:structuralElementObservableData "Degree: 15"^^xsd:integer ;
  noria:structuralElementDistinguishedName "HDN1" .

<https://example.com/highDegreeNode2>
  a noria:StructuralElement, noria:Resource ;
  rdfs:label "High-Degree Node 2"@en ;
  rdfs:comment "Another high-degree node serving as a critical resource."@en ;
  noria:structuralElementObservableData "Degree: 12"^^xsd:integer ;
  noria:structuralElementDistinguishedName "HDN2" .

<https://example.com/centralNode>
  a noria:StructuralElement, noria:Resource ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node with moderate connections, linking hubs and connectors."@en ;
  noria:structuralElementObservableData "Degree: 8"^^xsd:integer ;
  noria:structuralElementDistinguishedName "CN" .

<https://example.com/connectorNode>
  a noria:StructuralElement, noria:Resource ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData "Degree: 5"^^xsd:integer ;
  noria:structuralElementDistinguishedName "ConnN" .

<https://example.com/intermediaryNode>
  a noria:StructuralElement, noria:Resource ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservableData "Degree: 4"^^xsd:integer ;
  noria:structuralElementDistinguishedName "IN" .

<https://example.com/multiplexNode>
  a noria:StructuralElement, noria:Resource ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node connecting multiple types of resources."@en ;
  noria:structuralElementObservableData "Type: Multiplex"^^xsd:string ;
  noria:structuralElementDistinguishedName "MN" .

<https://example.com/superNode>
  a noria:StructuralElement, noria:Resource ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes."@en ;
  noria:structuralElementObservableData "Aggregated Degree: 50"^^xsd:integer ;
  noria:structuralElementDistinguishedName "SN" .

<https://example.com/opsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes."@en .

<https://example.com/connection1>
  a noria:NetworkLink ;
  rdfs:label "Link between Hub and High-Degree Node 1"@en ;
  rdfs:comment "A high-capacity optical fiber link."@en ;
  noria:networkLinkId "NL1" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkTerminationResource <https://example.com/hubNode> ;
  noria:networkLinkTerminationResource <https://example.com/highDegreeNode1> .

<https://example.com/connection2>
  a noria:NetworkLink ;
  rdfs:label "Link between Hub and High-Degree Node 2"@en ;
  rdfs:comment "A secondary link for redundancy."@en ;
  noria:networkLinkId "NL2" ;
  noria:networkLinkInstallationDate "2022-02-20T11:30:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkTerminationResource <https://example.com/hubNode> ;
  noria:networkLinkTerminationResource <https://example.com/highDegreeNode2> .

<https://example.com/connection3>
  a noria:NetworkLink ;
  rdfs:label "Link between Hub and Central Node"@en ;
  rdfs:comment "A logical connection for data aggregation."@en ;
  noria:networkLinkId "NL3" ;
  noria:networkLinkInstallationDate "2022-03-10T09:45:00"^^xsd:dateTime ;
  noria:networkLinkType "Virtual Link"^^xsd:string ;
  noria:networkLinkTerminationResource <https://example.com/hubNode> ;
  noria:networkLinkTerminationResource <https://example.com/centralNode> .

<https://example.com/connection4>
  a noria:NetworkLink ;
  rdfs:label "Link between Central Node and Connector Node"@en ;
  rdfs:comment "A logical link for network segmentation."@en ;
  noria:networkLinkId "NL4" ;
  noria:networkLinkInstallationDate "2022-04-05T14:20:00"^^xsd:dateTime ;
  noria:networkLinkType "Virtual Link"^^xsd:string ;
  noria:networkLinkTerminationResource <https://example.com/centralNode> ;
  noria:networkLinkTerminationResource <https://example.com/connectorNode> .

<https://example.com/connection5>
  a noria:NetworkLink ;
  rdfs:label "Link between Connector Node and Intermediary Node"@en ;
  rdfs:comment "A link facilitating data flow."@en ;
  noria:networkLinkId "NL5" ;
  noria:networkLinkInstallationDate "2022-05-12T16:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Virtual Link"^^xsd:string ;
  noria:networkLinkTerminationResource <https://example.com/connectorNode> ;
  noria:networkLinkTerminationResource <https://example.com/intermediaryNode> .

<https://example.com/connection6>
  a noria:NetworkLink ;
  rdfs:label "Link between Intermediary Node and Multiplex Node"@en ;
  rdfs:comment "A high-capacity link for multiplexing."@en ;
  noria:networkLinkId "NL6" ;
  noria:networkLinkInstallationDate "2022-06-01T08:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkTerminationResource <https://example.com/intermediaryNode> ;
  noria:networkLinkTerminationResource <https://example.com/multiplexNode> .

<https://example.com/connection7>
  a noria:NetworkLink ;
  rdfs:label "Link between Multiplex Node and Super Node"@en ;
  rdfs:comment "An aggregated high-capacity link."@en ;
  noria:networkLinkId "NL7" ;
  noria:networkLinkInstallationDate "2022-07-15T12:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkTerminationResource <https://example.com/multiplexNode> ;
  noria:networkLinkTerminationResource <https://example.com/superNode> .

<https://example.com/connection8>
  a noria:NetworkLink ;
  rdfs:label "Link between Super Node and Hub"@en ;
  rdfs:comment "A backbone link connecting super node to hub."@en ;
  noria:networkLinkId "NL8" ;
  noria:networkLinkInstallationDate "2022-08-20T10:30:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkTerminationResource <https://example.com/superNode> ;
  noria:networkLinkTerminationResource <https://example.com/hubNode> .

# Additional relations to define hub and high-degree nodes connectivity
<https://example.com/hubNode>
  noria:structuralElementObservableData "Connected to: HDN1, HDN2, CN"^^xsd:string ;
  noria:structuralElementDistinguishedName "Hub" .

<https://example.com/highDegreeNode1>
  noria:structuralElementObservableData "Connected to: Hub, CN"^^xsd:string .

<https://example.com/highDegreeNode2>
  noria:structuralElementObservableData "Connected to: Hub, CN"^^xsd:string .

<https://example.com/centralNode>
  noria:structuralElementObservableData "Connected to: Hub, ConnN"^^xsd:string .

<https://example.com/connectorNode>
  noria:structuralElementObservableData "Connected to: CN, IN"^^xsd:string .

<https://example.com/intermediaryNode>
  noria:structuralElementObservableData "Connected to: ConnN, MN"^^xsd:string .

<https://example.com/multiplexNode>
  noria:structuralElementObservableData "Connected to: IN, SN"^^xsd:string .

<https://example.com/superNode>
  noria:structuralElementObservableData "Connected to: MN, Hub"^^xsd:string .

