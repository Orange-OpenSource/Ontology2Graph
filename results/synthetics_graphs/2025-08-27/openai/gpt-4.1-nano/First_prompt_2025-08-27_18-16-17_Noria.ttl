@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/OrgSupport> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node 1"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMetric> ;
  noria:structuralObservableOf <https://example.com/hubNode1> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Node 1"@en ;
  rdfs:comment "A central node linking key network components."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/highDegreeNode1> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node 1"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:structuralObservableOf <https://example.com/centralNode1> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node 1"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:structuralObservableOf <https://example.com/connectorNode1> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node 1"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/intermediaryNode1> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node 1"@en ;
  rdfs:comment "A super node aggregating multiple network functions."@en ;
  noria:structuralElementObservableData <https://example.com/aggregateTraffic> ;
  noria:structuralObservableOf <https://example.com/multiplexNode1> .

<https://example.com/OrgSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "The support team responsible for network management."@en .

<https://example.com/latencyMetric> a noria:StructuralObservable ;
  rdfs:label "Latency Metric"@en ;
  rdfs:comment "Average network latency in milliseconds."@en .

<https://example.com/trafficVolume> a noria:StructuralObservable ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Total network traffic in Mbps."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the network connection (up/down)."@en .

<https://example.com/dataFlowRate> a noria:StructuralObservable ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow in Mbps."@en .

<https://example.com/streamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of active data streams."@en .

<https://example.com/aggregateTraffic> a noria:StructuralObservable ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Total aggregated network traffic in Mbps."@en .