@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central router acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A switch with high connectivity degree, connecting multiple network segments."@en ;
  noria:structuralElementObservableData <https://example.com/obsData1> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center connecting servers and storage."@en ;
  noria:structuralElementObservable <https://example.com/obs1> ;
  noria:structuralElementObservableData <https://example.com/obsData2> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node acting as a firewall boundary between segments."@en ;
  noria:structuralElementObservable <https://example.com/obs2> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node balancing traffic between servers."@en ;
  noria:structuralElementObservable <https://example.com/obs3> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/obs4> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "A super node with extensive connectivity, acting as a backbone element."@en ;
  noria:structuralElementObservable <https://example.com/obs5> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing IT support and maintenance."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security and firewall management."@en .

<https://example.com/obs1> a noria:StructuralObservable ;
  rdfs:label "Switch Operational Status"@en ;
  rdfs:comment "Observable property indicating the operational status of the switch."@en .

<https://example.com/obs2> a noria:StructuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Observable property indicating the status of the firewall connector."@en .

<https://example.com/obs3> a noria:StructuralObservable ;
  rdfs:label "Load Balancer Load"@en ;
  rdfs:comment "Observable property indicating current load on load balancer."@en .

<https://example.com/obs4> a noria:StructuralObservable ;
  rdfs:label "Multiplexer Data Streams"@en ;
  rdfs:comment "Observable property indicating data streams multiplexed."@en .

<https://example.com/obs5> a noria:StructuralObservable ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Observable property indicating traffic volume through super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Server1"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceHostName "server1.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "StorageArray1"@en ;
  rdfs:comment "Primary storage array for backups."@en ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceHostName "storage1.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Storage> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:locatedAtLocus <https://example.com/locus2> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/locus1> a noria:Locus ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Location of server1."@en .

<https://example.com/locus2> a noria:Locus ;
  rdfs:label "Storage Room 2"@en ;
  rdfs:comment "Location of storage array."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between Data Center A and B."@en ;
  noria:networkLinkId "NL-AB-001" ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of server1."@en ;
  noria:networkInterfaceType "physical"^^xsd:string ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
  noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary interface for storage array."@en ;
  noria:networkInterfaceType "virtual"^^xsd:string ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink2> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
  noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Fiber Link B-C"@en ;
  rdfs:comment "Fiber link between storage and backup site."@en ;
  noria:networkLinkId "NL-BC-002" ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2021-07-20T09:30:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource2> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource3> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "BackupServer"@en ;
  rdfs:comment "Backup server for disaster recovery."@en ;
  noria:resourceSerialNumber "SN789012" ;
  noria:resourceHostName "backup.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:locatedAtLocus <https://example.com/locus3> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/locus3> a noria:Locus ;
  rdfs:label "Disaster Recovery Site"@en ;
  rdfs:comment "Location of backup server."@en .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "VirtualServer1"@en ;
  rdfs:comment "Virtual server hosting web services."@en ;
  noria:resourceSerialNumber "SN345678" ;
  noria:resourceHostName "vserver1.cloud"@en ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualServer> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:locatedAtLocus <https://example.com/locus4> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/locus4> a noria:Locus ;
  rdfs:label "Cloud Data Center"@en ;
  rdfs:comment "Location of cloud virtual resources."@en .

<https://example.com/Resource5> a noria:Resource ;
  rdfs:label "Firewall1"@en ;
  rdfs:comment "Firewall device controlling access."@en ;
  noria:resourceSerialNumber "SN987654" ;
  noria:resourceHostName "firewall1.datacenter.local"@en ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:locatedAtLocus <https://example.com/locus5> ;
  noria:resourceManagedBy <https://example.com/SecurityTeam> .

<https://example.com/locus5> a noria:Locus ;
  rdfs:label "Security Zone"@en ;
  rdfs:comment "Location of firewall device."@en .

# End of graph