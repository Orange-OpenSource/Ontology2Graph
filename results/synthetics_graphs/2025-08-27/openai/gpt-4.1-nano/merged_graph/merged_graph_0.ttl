# Additional nodes can be added following the same pattern to create hubs, high-degree nodes, central nodes, connector nodes, intermediary nodes, multiplex nodes, and super nodes, ensuring each has at least one relation with another node.

# Hub Node: Central Network Hub
<https://example.com/HubNetwork01> a noria:ManagedElement ;
  rdfs:label "Main Network Hub"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/OrgNetworkOps> .

# Organization responsible for network management
<https://example.com/OrgNetworkOps> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Organization managing core network infrastructure."@en .

# High-Degree Node: Core Router
<https://example.com/RouterCore01> a noria:StructuralElement, seas:System ;
  rdfs:label "Core Router 01"@en ;
  rdfs:comment "High-capacity core router handling main traffic."@en ;
  noria:elementManagedBy <https://example.com/OrgNetworkOps> ;
  noria:structuralElementObservable <https://example.com/observable/router01Status> .

# Observable for Router Status
<https://example.com/observable/router01Status> a noria:StructuralObservable ;
  rdfs:label "Router 01 Status"@en ;
  rdfs:comment "Operational status of Core Router 01."@en .

# Central Node: Data Center Switch
<https://example.com/SwitchDataCenter> a noria:StructuralElement, seas:System ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "Switch within the data center connecting servers."@en ;
  noria:elementManagedBy <https://example.com/OrgDataCenter> ;
  noria:structuralElementObservable <https://example.com/observable/switchStatus> .

# Organization managing Data Center
<https://example.com/OrgDataCenter> a org:Organization ;
  rdfs:label "Data Center Management"@en ;
  rdfs:comment "Organization responsible for data center operations."@en .

# Connector Node: Network Interface of Router
<https://example.com/NetworkInterface01> a noria:NetworkInterface ;
  rdfs:label "GigabitEthernet0/0/1"@en ;
  rdfs:comment "Network interface on RouterCore01."@en ;
  noria:networkInterfaceOf <https://example.com/RouterCore01> ;
  noria:networkInterfaceOperationalStatus <https://example.com/observable/router01Status> .

# Intermediary Node: Link between Router and Switch
<https://example.com/LinkRouterSwitch> a noria:NetworkLink ;
  rdfs:label "Link Router-Core to Data Center Switch"@en ;
  rdfs:comment "Physical link connecting core router to data center switch."@en ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/RouterCore01> ;
  noria:networkLinkTerminationResource <https://example.com/SwitchDataCenter> .

# Multiplex Node: Virtual Network Interface
<https://example.com/VirtualInterface01> a noria:NetworkInterface ;
  rdfs:label "VLAN 1000"@en ;
  rdfs:comment "Virtual network interface for VLAN 1000."@en ;
  noria:networkInterfaceOf <https://example.com/SwitchDataCenter> ;
  noria:networkInterfaceType "virtual" .

# Super Node: Entire Network System
<https://example.com/NetworkSystem> a seas:System ;
  rdfs:label "Enterprise Network System"@en ;
  rdfs:comment "Complete enterprise network system including routers, switches, links, and interfaces."@en ;
  seas:subSystemOf <https://example.com/HubNetwork01> ;
  seas:subSystemOf <https://example.com/RouterCore01> ;
  seas:subSystemOf <https://example.com/SwitchDataCenter> .

# Additional Nodes to ensure all nodes are linked
<https://example.com/ResourceServer01> a noria:Resource ;
  rdfs:label "Application Server 01"@en ;
  rdfs:comment "Server hosting critical applications."@en ;
  noria:resourceManagedBy <https://example.com/OrgDataCenter> ;
  noria:resourceHostName "appserver01.datacenter.local" .

<https://example.com/ResourceServer02> a noria:Resource ;
  rdfs:label "Application Server 02"@en ;
  rdfs:comment "Backup server for applications."@en ;
  noria:resourceManagedBy <https://example.com/OrgDataCenter> ;
  noria:resourceHostName "appserver02.datacenter.local" .

<https://example.com/ResourceF_extra_node_2irewall> a noria:Resource ;
  rdfs:label "Firewall Appliance"@en ;
  rdfs:comment "Firewall device securing network perimeter."@en ;
  noria:resourceManagedBy <https://example.com/OrgNetworkOps> ;
  noria:resourceHostName "firewall01.datacenter.local" .

<https://example.com/ResourceLoadBalancer> a noria:Resource ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Load balancer distributing traffic among servers."@en ;
  noria:resourceManagedBy <https://example.com/OrgDataCenter> ;
  noria:resourceHostName "loadbalancer01.datacenter.local" .

<https://example.com/ResourceSwitch> a noria:Resource ;
  rdfs:label "Edge Switch"@en ;
  rdfs:comment "Edge switch connecting access layer devices."@en ;
  noria:resourceManagedBy <https://example.com/OrgDataCenter> ;
  noria:resourceHostName "switch01.datacenter.local" .

# Link between Application Server 01 and Load Balancer
<https://example.com/LinkAppServer1-LoadBalancer> a noria:NetworkLink ;
  rdfs:label "Link AppServer1 to LoadBalancer"@en ;
  rdfs:comment "Network link between application server and load balancer."@en ;
  noria:networkLinkInstallationDate "2022-02-01T09:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceServer01> ;
  noria:networkLinkTerminationResource <https://example.com/ResourceLoadBalancer> .

# Link between Firewall and Router
<https://example.com/LinkFirewall-Router> a noria:NetworkLink ;
  rdfs:label "Firewall to Router Link"@en ;
  rdfs:comment "Connection between firewall and core router."@en ;
  noria:networkLinkInstallationDate "2022-01-20T11:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceF_extra_node_2irewall> ;
  noria:networkLinkTerminationResource <https://example.com/RouterCore01> .

# Link between Switch and Router
<https://example.com/LinkSwitch-Router> a noria:NetworkLink ;
  rdfs:label "Switch to Router Link"@en ;
  rdfs:comment "Connection between edge switch and core router."@en ;
  noria:networkLinkInstallationDate "2022-01-18T10:30:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceSwitch> ;
  noria:networkLinkTerminationResource <https://example.com/RouterCore01> .

# End of generated graph

<https://example.com/hubNode_extra_node_45> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps_extra_node_17Team> .

<https://example.com/highDegreeNode_extra_node_37> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount_extra_node_6> ;
  noria:structuralObservableOf <https://example.com/HubNode_extra_node_14> .

<https://example.com/centralNode_extra_node_37> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume_extra_node_3> ;
  noria:structuralObservableOf <https://example.com/HighDegreeNode_extra_node_15> .

<https://example.com/connectorNode_extra_node_37> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments, serving as a bridge."@en ;
  noria:structuralElementObservableData <https://example.com/segmentCount_extra_node_1> ;
  noria:structuralObservableOf <https://example.com/CentralNode_extra_node_15> .

<https://example.com/intermediaryNode_extra_node_37> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate_extra_node_2> ;
  noria:structuralObservableOf <https://example.com/connectorNode_extra_node_37> .

<https://example.com/multiplexNode_extra_node_37> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that handles multiple data streams simultaneously."@en ;
  noria:structuralElementObservableData <https://example.com/multiplexCapacity_extra_node_1> ;
  noria:structuralObservableOf <https://example.com/intermediaryNode_extra_node_37> .

<https://example.com/superNode_extra_node_37> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node representing a superordinate network component."@en ;
  noria:structuralElementObservableData <https://example.com/superNode_extra_node_37Load> ;
  noria:structuralObservableOf <https://example.com/multiplexNode_extra_node_37> .

