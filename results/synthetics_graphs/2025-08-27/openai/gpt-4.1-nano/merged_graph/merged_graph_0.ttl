<https://w3id.org/noria/graph1> a owl:NamedIndividual ;
    rdfs:label "Sample Network Topology"@en ;
    rdfs:comment "A sample knowledge graph illustrating various node types based on the NORIA schema."@en .

# Hub Node: Central Router
<https://example.com/router1> a noria:StructuralElement ;
    rdfs:label "Router1"@en ;
    rdfs:comment "Main backbone router serving core network."@en ;
    noria:elementDistinguishedName "CoreRouter-01"^^xsd:string ;
    noria:elementManagedBy <https://example.com/opsTeam_extra_node_0> .

# High-Degree Node: Data Center Switch
<https://example.com/switch1> a noria:StructuralElement ;
    rdfs:label "Switch1"@en ;
    rdfs:comment "High capacity switch in data center."@en ;
    noria:elementDistinguishedName "DC_Switch-Alpha"^^xsd:string ;
    noria:elementManagedBy <https://example.com/datacenterOps> .

# Central Node: Application Server
<https://example.com/appServer1> a noria:FunctionalElement ;
    rdfs:label "AppServer1"@en ;
    rdfs:comment "Primary application server handling user requests."@en ;
    noria:functionalElementDistinguishedName "AppServer-Prod-01"^^xsd:string ;
    noria:resourceForApplication <https://example.com/app1> .

# Connector Node: Firewall
<https://example.com/firewall1> a noria:StructuralElement ;
    rdfs:label "Firewall1"@en ;
    rdfs:comment "Firewall connecting internal network to external."@en ;
    noria:elementDistinguishedName "Firewall-Edge"^^xsd:string ;
    noria:elementManagedBy <https://example.com/securityTeam> .

# Intermediary Node: Load Balancer
<https://example.com/loadbalancer1> a noria:FunctionalElement ;
    rdfs:label "LoadBalancer1"@en ;
    rdfs:comment "Distributes traffic among application servers."@en ;
    noria:functionalElementDistinguishedName "LoadBalancer-01"^^xsd:string ;
    noria:resourceForApplication <https://example.com/app1> .

# Multiplex Node: Virtual Machine Cluster
<https://example.com/vmCluster> a noria:StructuralElement ;
    rdfs:label "VMCluster"@en ;
    rdfs:comment "Cluster of virtual machines providing scalable services."@en ;
    noria:elementDistinguishedName "VMCluster-Alpha"^^xsd:string ;
    noria:resourceManagedBy <https://example.com/virtualizationTeam> .

# Super Node: Data Center
<https://example.com/datacenter> a noria:StructuralElement ;
    rdfs:label "DataCenter"@en ;
    rdfs:comment "Main data center housing core infrastructure."@en ;
    noria:elementDistinguishedName "DC-Primary"^^xsd:string ;
    noria:resourceManagedBy <https://example.com/datacenterOps> .

# Relationships

# Hub node connected to high-degree node
<https://example.com/router1> noria:structuralElementObservable noria:structuralElementObservableData ;
    noria:structuralObservableOf <https://example.com/switch1> .

# Central node linked to connector node
<https://example.com/appServer1> noria:elementProperty <https://example.com/firewall1> .

# Intermediary node connected to high-degree node
<https://example.com/loadbalancer1> noria:structuralElementObservable noria:structuralElementObservableData ;
    noria:structuralObservableOf <https://example.com/appServer1> .

# Multiplex node linked to multiple resources
<https://example.com/vmCluster> noria:structuralElementObservable noria:structuralElementObservableData ;
    noria:structuralObservableOf <https://example.com/appServer1> , <https://example.com/datacenter> .

# Super node connected to multiple structural elements
<https://example.com/datacenter> noria:structuralElementObservable noria:structuralElementObservableData ;
    noria:structuralObservableOf <https://example.com/router1> , <https://example.com/switch1> , <https://example.com/firewall1> , <https://example.com/loadbalancer1> .

# Additional entities for context

