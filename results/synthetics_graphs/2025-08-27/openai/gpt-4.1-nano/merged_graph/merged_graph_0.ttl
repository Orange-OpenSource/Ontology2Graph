  noria:resourceSerialNumber "SN123456789" ;
  noria:resourceUsageState <https://example.com/Usage/Operational> ;
  noria:resourceInstallationDate "2022-01-15T09:00:00"^^xsd:dateTime ;
  rdfs:label "Main Data Center Router" ;
  rdfs:comment "Core router acting as a hub for internal network traffic." .

