# Connector Node: Network Interface connected to the core router
<https://example.com/NetworkInterface/eth0_extra_node_0> a noria:NetworkInterface ;
  rdfs:label "eth0" ;
  rdfs:comment "Ethernet interface on core router."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "GigabitEthernet0/0/1" ;
  noria:networkInterfaceOf <https://example.com/Resource/Hub1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink/Link1_extra_node_0> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3.5 ;
  noria:networkInterfaceLaserRxOpticalPowerAverage -3.2 ;
  noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
  noria:networkInterfaceLaserRxLowPowerWarningThreshold -5 ;
  rdfs:label "eth0" .

# Intermediary Node: Network Link connecting core router to a switch
<https://example.com/NetworkLink/Link1_extra_node_0> a noria:NetworkLink ;
  rdfs:label "Fiber Link DC to Switch" ;
  rdfs:comment "Optical fiber connection between core router and distribution switch."@en ;
  noria:networkLinkId "Link-DC-Switch" ;
  noria:networkLinkType "optical fiber" ;
  noria:networkLinkInstallationDate "2022-01-16T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource/Hub1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource/Switch1> ;
  rdfs:label "Fiber Link DC to Switch" .

