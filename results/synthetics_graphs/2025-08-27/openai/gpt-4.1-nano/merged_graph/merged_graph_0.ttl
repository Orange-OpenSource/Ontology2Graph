    rdfs:label "Sample Noria-based Knowledge Graph"@en .

# Hub Node: Central Router
<https://example.com/Router1_extra_node_1> a noria:StructuralElement ;
    rdfs:label "Main Router"@en ;
    rdfs:comment "Core network router acting as a hub in the topology."@en ;
    noria:structuralElementDistinguishedName "Router1-DN" ;
    noria:elementManagedBy <https://example.com/NetworkOps_extra_node_6Team> .

# High-Degree Node: Data Center
<https://example.com/DataCenterA> a noria:StructuralElement ;
    rdfs:label "Data Center A"@en ;
    rdfs:comment "High capacity data center serving multiple applications."@en ;
    noria:structuralElementDistinguishedName "DC-A" ;
    noria:elementManagedBy <https://example.com/DataCenterOps_extra_node_2> .

# Central Node: Application Server
<https://example.com/AppServer1> a noria:StructuralElement ;
    rdfs:label "Application Server 1"@en ;
    rdfs:comment "Critical application server hosting core services."@en ;
    noria:structuralElementDistinguishedName "AppServer1-DN" ;
    noria:elementManagedBy <https://example.com/ITSupport_extra_node_1Team_extra_node_1> .

# Connector Node: Virtual Link
<https://example.com/Link1_extra_node_1> a noria:NetworkLink ;
    rdfs:label "Fiber Link DC1-DC2"@en ;
    rdfs:comment "Fiber optic connection between Data Center 1 and Data Center 2."@en ;
    noria:networkLinkId "Link-DC1-DC2" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Optical Fiber" .

<https://example.com/NetworkLink1_extra_node_5> a noria:NetworkLink ;
    rdfs:label "Link to Router1"@en ;
    rdfs:comment "Connection between Router1 and Data Center A."@en ;
    noria:networkLinkId "Link-Router1-DC" ;
    noria:networkLinkInstallationDate "2022-02-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" .

# Intermediary Node: Virtual Machine
<https://example.com/VM1> a noria:StructuralElement ;
    rdfs:label "Virtual Machine 1"@en ;
    rdfs:comment "VM hosting application services."@en ;
    noria:structuralElementDistinguishedName "VM1-DN" ;
    noria:elementManagedBy <https://example.com/CloudOps> .

# Multiplex Node: Network Interface on AppServer1
<https://example.com/NI1> a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Primary network interface of AppServer1."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceOf <https://example.com/AppServer1> .

# Super Node: Global Network
<https://example.com/GlobalNetwork> a noria:StructuralElement ;
    rdfs:label "Global Network"@en ;
    rdfs:comment "The overarching network infrastructure."@en ;
    noria:structuralElementDistinguishedName "GlobalNet" ;
    noria:elementManagedBy <https://example.com/GlobalNetworkOps> .

# Relations linking nodes

# Hub node connected to high-degree node
<https://example.com/Router1_extra_node_1> noria:structuralElementObservableData <https://example.com/Link1_extra_node_1> .

# High-degree node connected to central node
<https://example.com/DataCenterA> noria:structuralElementObservableData <https://example.com/Link1_extra_node_1> .

# Central node connected to connector node
<https://example.com/AppServer1> noria:structuralElementObservableData <https://example.com/Link2_extra_node_0> .

# Connector node (Link to Router) connected to Router
<https://example.com/Link2_extra_node_0> a noria:NetworkLink ;
    rdfs:label "Link to Router1"@en ;
    rdfs:comment "Connection between AppServer1 and Router1."@en ;
    noria:networkLinkId "Link-APP-ROUTER" ;
    noria:networkLinkInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" .

<https://example.com/Link2_extra_node_0> noria:networkLinkTerminationResource <https://example.com/AppServer1> ;
    noria:networkLinkTerminationResourceDestination <https://example.com/Router1_extra_node_1> .

# Intermediary node (VM) linked to AppServer
<https://example.com/VM1> noria:structuralElementObservableData <https://example.com/Link3_extra_node_0> .

<https://example.com/Link3_extra_node_0> a noria:NetworkLink ;
    rdfs:label "Link VM to AppServer"@en ;
    rdfs:comment "Virtual link between VM and AppServer."@en ;
    noria:networkLinkId "Link-VM-App" ;
    noria:networkLinkInstallationDate "2022-03-01T12:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual" .

<https://example.com/Link3_extra_node_0> noria:networkLinkTerminationResource <https://example.com/VM1> ;
    noria:networkLinkTerminationResourceDestination <https://example.com/AppServer1> .

# Super node (Global Network) linked to Data Center
<https://example.com/DataCenterA> noria:structuralElementObservableData <https://example.com/GlobalLink> .

<https://example.com/GlobalLink> a noria:NetworkLink ;
    rdfs:label "Global Backbone Link"@en ;
    rdfs:comment "Main backbone connection."@en ;
    noria:networkLinkId "Global-Backbone" ;
    noria:networkLinkInstallationDate "2021-12-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Optical Fiber" .

<https://example.com/GlobalLink> noria:networkLinkTerminationResource <https://example.com/DataCenterA> ;
    noria:networkLinkTerminationResourceDestination <https://example.com/GlobalNetwork> .

# Additional entities to ensure no isolated nodes
<https://example.com/NetworkOps_extra_node_6Team> a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/DataCenterOps_extra_node_2> a org:OrganizationalUnit ;
    rdfs:label "Data Center Operations"@en ;
    rdfs:comment "Team managing data center facilities."@en .

<https://example.com/ITSupport_extra_node_1Team_extra_node_1> a org:OrganizationalUnit ;
    rdfs:label "IT Support Team"@en ;
    rdfs:comment "Support team for application servers."@en .

<https://example.com/CloudOps> a org:OrganizationalUnit ;
    rdfs:label "Cloud Operations"@en ;
    rdfs:comment "Team managing virtualized resources."@en .

<https://example.com/GlobalNetworkOps> a org:OrganizationalUnit ;
    rdfs:label "Global Network Operations"@en ;
    rdfs:comment "Team overseeing global network backbone."@en .

# End of graph

