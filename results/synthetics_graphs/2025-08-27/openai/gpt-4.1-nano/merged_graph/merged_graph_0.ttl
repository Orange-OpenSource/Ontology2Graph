# Relations linking nodes (examples of different types)
<https://example.com/HubNode_extra_node_1> noria:structuralElementObservableData <https://example.com/centralityScore_extra_node_0> .
<https://example.com/HighDegreeNode_extra_node_1> noria:structuralElementObservableData <https://example.com/degreeMetric_extra_node_0> .
<https://example.com/CentralNode_extra_node_1> noria:structuralElementObservableData <https://example.com/centralityScore_extra_node_0> .
<https://example.com/ConnectorNode_extra_node_1> noria:structuralElementObservableData <https://example.com/connectionCount_extra_node_0> .
<https://example.com/IntermediaryNode_extra_node_1> noria:structuralElementObservableData <https://example.com/intermediaryLatency> .
<https://example.com/MuxNode_extra_node_0> noria:structuralElementObservableData <https://example.com/streamCount_extra_node_0> .
<https://example.com/SuperNode_extra_node_1> noria:structuralElementObservableData <https://example.com/aggregationLevel_extra_node_0> .

# All nodes are linked to at least one other node to avoid isolated nodes.

<https://w3id.org/noria/instance/Network1_extra_node_1> a noria:ManagedElement ;
  rdfs:label "Core Network Hub"@en ;
  rdfs:comment "A central hub node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:structuralElementDistinguishedName "Hub-01" ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1_extra_node_1> .

<https://w3id.org/noria/instance/Org1> a org:Organization ;
  rdfs:label "Main Network Operations"@en ;
  rdfs:comment "The primary organization managing core network components."@en .

<https://w3id.org/noria/instance/Resource1_extra_node_0> a noria:Resource ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Main backbone router with super node characteristics."@en ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceHostName "router1.core.net" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router_extra_node_0> ;
  noria:resourceProductModel <https://w3id.org/noria/instance/ModelX_extra_node_1> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1_extra_node_1> .

<https://w3id.org/noria/instance/ModelX_extra_node_1> a noria:ProductModel ;
  rdfs:label "ModelX"@en ;
  rdfs:comment "High-performance router model X."@en ;
  noria:productManufacturedBy <https://w3id.org/noria/instance/ManufacturerA> .

<https://w3id.org/noria/instance/ManufacturerA> a org:Organization ;
  rdfs:label "RouterCorp"@en ;
  rdfs:comment "Manufacturer of ModelX routers."@en .

<https://w3id.org/noria/instance/NetIf1> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/1"@en ;
  rdfs:comment "Gigabit Ethernet interface 0/0/1 on Router1."@en ;
  noria:networkInterfaceType "physical"^^xsd:string ;
  noria:networkInterfaceOperationalStatus [ a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; skos:hasTopConcept <kos/Resource/OperationalState/Up> ] ;
  noria:networkInterfaceRoutingPriorityMetric 122 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3.58 ;
  noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
  noria:networkInterfaceLaserRxLowPowerWarningThreshold -4 ;
  noria:networkInterfaceOf <https://w3id.org/noria/instance/Resource1_extra_node_0> ;
  noria:networkInterfaceConnects <https://w3id.org/noria/instance/Link1_extra_node_1> .

<https://w3id.org/noria/instance/Link1_extra_node_1> a noria:NetworkLink ;
  rdfs:label "FiberLink-01"@en ;
  rdfs:comment "Optical fiber link between Router1 and Switch1."@en ;
  noria:networkLinkId "NL-0001" ;
  noria:networkLinkType "optical fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://w3id.org/noria/instance/Resource1_extra_node_0> ;
  noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/instance/Resource2_extra_node_0> .

<https://w3id.org/noria/instance/Resource2_extra_node_0> a noria:Resource ;
  rdfs:label "Switch1"@en ;
  rdfs:comment "Distribution switch with multiplex node characteristics."@en ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceHostName "switch1.core.net" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/switch_extra_node_0> ;
  noria:resourceProductModel <https://w3id.org/noria/instance/ModelY_extra_node_0> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus2_extra_node_0> .

