@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree core router acting as a central hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Data Center Switch"@en ;
  rdfs:comment "A switch with high connectivity degree, connecting multiple servers and network segments."@en ;
  noria:structuralElementObservableData <https://example.com/PowerUsageData> ;
  noria:structuralObservableOf <https://example.com/DataCenterSwitch> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Firewall"@en ;
  rdfs:comment "A firewall node that manages security policies for the entire network."@en ;
  noria:structuralElementObservable <https://example.com/FirewallStatus> ;
  noria:structuralElementObservableData <https://example.com/FirewallThroughput> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Link"@en ;
  rdfs:comment "A logical connector node linking two network segments."@en ;
  noria:structuralElementObservable <https://example.com/LinkStatus> ;
  noria:structuralObservableOf <https://example.com/Link> .

<https://example.com/IntermediaryNode> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "A multiplexing node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/StreamCount> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple high-degree nodes for redundancy."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeStatus> .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network infrastructure."@en .

<https://example.com/OperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Operations Support Team"@en ;
  rdfs:comment "Team handling operational tasks and maintenance."@en .

<https://example.com/DataCenterSwitch> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A switch located in the main data center."@en ;
  noria:elementManagedBy <https://example.com/DataCenterOps> .

<https://example.com/DataCenterOps> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en ;
  rdfs:comment "Operational team for data center equipment."@en .

<https://example.com/Firewall> a noria:StructuralElement ;
  rdfs:label "Firewall"@en ;
  rdfs:comment "Firewall device managing network security."@en ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Management Team"@en ;
  rdfs:comment "Team responsible for security policies and devices."@en .

<https://example.com/Link> a noria:NetworkLink ;
  rdfs:label "Link between Data Center and Branch Office"@en ;
  rdfs:comment "A physical or logical link connecting main data center to branch office."@en ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkId "Link-DC-Branch01" .

<https://example.com/PowerUsageData> a noria:structuralObservable ;
  rdfs:label "Power Usage Data"@en ;
  rdfs:comment "Monitoring data for power consumption of the switch."@en .

<https://example.com/FirewallStatus> a noria:structuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Current operational status of the firewall."@en .

<https://example.com/FirewallThroughput> a noria:structuralObservable ;
  rdfs:label "Firewall Throughput"@en ;
  rdfs:comment "Data throughput measurement of the firewall."@en .

<https://example.com/LinkStatus> a noria:structuralObservable ;
  rdfs:label "Link Status"@en ;
  rdfs:comment "Operational status of the network link."@en .

<https://example.com/SuperNodeStatus> a noria:structuralObservable ;
  rdfs:label "Super Node Status"@en ;
  rdfs:comment "Health status of the super node."@en .

<https://example.com/StreamCount> a noria:structuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/HubNodeEvent> a noria:EventRecord ;
  rdfs:label "Hub Node Event"@en ;
  rdfs:comment "Event indicating hub node status change."@en ;
  noria:logText "Hub node core router rebooted."@en ;
  noria:loggingTime "2023-10-01T12:00:00"^^xsd:dateTime ;
  noria:logOriginatingManagedObject <https://example.com/hubNode1> ;
  noria:alarmSeverity skos:Concept ; # placeholder for severity concept
  noria:alarmSeverity <https://example.com/CriticalSeverity> .

<https://example.com/CriticalSeverity> a skos:Concept ;
  rdfs:label "Critical"@en .

<https://example.com/DataCenterSwitchEvent> a noria:EventRecord ;
  rdfs:label "Data Center Switch Event"@en ;
  rdfs:comment "Status change of the main data center switch."@en ;
  noria:logText "Switch port 1/0/1 link down."@en ;
  noria:loggingTime "2023-10-02T09:30:00"^^xsd:dateTime ;
  noria:logOriginatingManagedObject <https://example.com/DataCenterSwitch> ;
  noria:alarmSeverity <https://example.com/MajorSeverity> .

<https://example.com/MajorSeverity> a skos:Concept ;
  rdfs:label "Major"@en .

<https://example.com/FirewallEvent> a noria:EventRecord ;
  rdfs:label "Firewall Event"@en ;
  rdfs:comment "An event indicating high load on the firewall."@en ;
  noria:logText "Firewall throughput exceeded threshold."@en ;
  noria:loggingTime "2023-10-03T14:45:00"^^xsd:dateTime ;
  noria:logOriginatingManagedObject <https://example.com/Firewall> ;
  noria:alarmSeverity <https://example.com/WarningSeverity> .

<https://example.com/WarningSeverity> a skos:Concept ;
  rdfs:label "Warning"@en .

<https://example.com/LinkStatusEvent> a noria:EventRecord ;
  rdfs:label "Link Status Event"@en ;
  rdfs:comment "Link operational status changed to up."@en ;
  noria:logText "Link is now operational."@en ;
  noria:loggingTime "2023-10-04T11:00:00"^^xsd:dateTime ;
  noria:logOriginatingManagedObject <https://example.com/Link> ;
  noria:alarmSeverity <https://example.com/InfoSeverity> .

<https://example.com/InfoSeverity> a skos:Concept ;
  rdfs:label "Informational"@en .

<https://example.com/SuperNodeEvent> a noria:EventRecord ;
  rdfs:label "Super Node Health Check"@en ;
  rdfs:comment "Periodic health check of the super node."@en ;
  noria:logText "Super node operational."@en ;
  noria:loggingTime "2023-10-05T08:00:00"^^xsd:dateTime ;
  noria:logOriginatingManagedObject <https://example.com/SuperNode> ;
  noria:alarmSeverity <https://example.com/NormalSeverity> .

<https://example.com/NormalSeverity> a skos:Concept ;
  rdfs:label "Normal"@en .

