@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix prov: <http://www.w3.org/ns/prov#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node in the network, connecting multiple segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central switch."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable1> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/CentralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center, connecting servers and storage."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable2> ;
  noria:elementManagedBy <https://example.com/DataCenterOps> .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking external network to internal resources."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable3> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node balancing traffic between servers."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable4> ;
  noria:elementManagedBy <https://example.com/ITOperations> .

<https://example.com/MultiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable5> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "An advanced super node with high capacity and multiple roles."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable6> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/HubNode2> a noria:ManagedElement ;
  rdfs:label "Aggregation Hub"@en ;
  rdfs:comment "A hub node with high connectivity, central to network topology."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeNode2> a noria:StructuralElement ;
  rdfs:label "Core Switch"@en ;
  rdfs:comment "A core switch with many links, acting as a high-degree node."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable7> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/CentralNode2> a noria:StructuralElement ;
  rdfs:label "Main Data Center Switch"@en ;
  rdfs:comment "A central switch within the main data center."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable8> ;
  noria:elementManagedBy <https://example.com/DataCenterTeam> .

<https://example.com/ConnectorNode2> a noria:StructuralElement ;
  rdfs:label "External Firewall"@en ;
  rdfs:comment "Firewall node connecting external and internal networks."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable9> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode2> a noria:StructuralElement ;
  rdfs:label "Application Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing application traffic."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable10> ;
  noria:elementManagedBy <https://example.com/ApplicationSupport> .

<https://example.com/MultiplexNode2> a noria:StructuralElement ;
  rdfs:label "Data Stream Multiplexer"@en ;
  rdfs:comment "A multiplex node aggregating multiple data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable11> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/SuperNode2> a noria:StructuralElement ;
  rdfs:label "High Capacity Switch"@en ;
  rdfs:comment "A super node with high throughput and multiple roles."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable12> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/HubNode3> a noria:ManagedElement ;
  rdfs:label "Edge Hub"@en ;
  rdfs:comment "An edge hub node connecting to external networks."@en ;
  noria:elementManagedBy <https://example.com/EdgeNetworkTeam> .

<https://example.com/HighDegreeNode3> a noria:StructuralElement ;
  rdfs:label "Distribution Switch"@en ;
  rdfs:comment "A high-degree distribution switch."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable13> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/CentralNode3> a noria:StructuralElement ;
  rdfs:label "Core Data Switch"@en ;
  rdfs:comment "A central switch in the core network."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable14> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/ConnectorNode3> a noria:StructuralElement ;
  rdfs:label "VPN Gateway"@en ;
  rdfs:comment "A connector node for VPN connections."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable15> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode3> a noria:StructuralElement ;
  rdfs:label "Application Proxy"@en ;
  rdfs:comment "An intermediary node acting as an application proxy."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable16> ;
  noria:elementManagedBy <https://example.com/ApplicationSupport> .

<https://example.com/MultiplexNode3> a noria:StructuralElement ;
  rdfs:label "Data Stream Combiner"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable17> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/SuperNode3> a noria:StructuralElement ;
  rdfs:label "Super High Capacity Switch"@en ;
  rdfs:comment "A super node with very high throughput."@en ;
  noria:structuralElementObservableOf <https://example.com/StructuralObservable18> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .