<https://example.com/entity1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A central hub router connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/Org1> .

<https://example.com/Org1> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "The organization responsible for network management."@en .

<https://example.com/entity2> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "High-degree switch connecting multiple devices."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable1> ;
  noria:elementManagedBy <https://example.com/Org1> .

<https://example.com/observable1> a noria:StructuralObservable ;
  rdfs:label "Switch Port Status"@en ;
  rdfs:comment "Observable property indicating port status."@en .

<https://example.com/entity3> a noria:StructuralElement ;
  rdfs:label "Edge Router"@en ;
  rdfs:comment "Connector node linking core network to branch offices."@en ;
  noria:elementManagedBy <https://example.com/Org1> .

<https://example.com/entity4> a noria:FunctionalElement ;
  rdfs:label "Firewall Service"@en ;
  rdfs:comment "A service providing network security."@en ;
  noria:elementManagedBy <https://example.com/Org1> .

<https://example.com/entity5> a noria:Application ;
  rdfs:label "Customer Portal"@en ;
  rdfs:comment "Web application for customer interactions."@en ;
  noria:applicationType <https://w3id.org/noria/kos/application/type#CustomerFacingService> ;
  noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance#High> .

<https://example.com/entity6> a noria:Service ;
