<https://example.com/entity7> a noria:Resource ;
  rdfs:label "Database Server"@en ;
  rdfs:comment "A critical database server."@en ;
  noria:resourceSerialNumber "DBS-001" ;
  noria:resourceHostName "db-server-01" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type#Server> ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  noria:resourceLogisticId "LOG-DBS-01" ;
  noria:resourceManagementIPAddress "192.168.10.10" .

<https://example.com/locus1> a noria:Locus ;
  rdfs:label "Data Center Rack 5"@en ;
  rdfs:comment "Location within the data center."@en .

<https://example.com/link1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between core router and edge router."@en ;
  noria:networkLinkId "LINK-AB" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/entity1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/entity3> .

<https://example.com/event1> a noria:EventRecord ;
  rdfs:label "Interface GigabitEthernet0/0/1 Up"@en ;
  rdfs:comment "Interface status change to up."@en ;
  noria:loggingTime "2023-10-20T14:30:00Z"^^xsd:dateTime ;
  noria:logText "Line protocol on Interface GigabitEthernet0/0/1, changed state to up."@en ;
  noria:logOriginatingManagedObject <https://example.com/entity1> ;
  noria:logOriginatingManagementSystem <https://example.com/MonitoringSystem> ;
  noria:logOriginatingAgent <https://example.com/agent1> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity#Major> ;
  noria:alarmProposedRepairAction <https://example.com/operation1> .

