@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/entity1> a noria:ManagedElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, linking multiple nodes."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Main Network Operations"@en ;
  rdfs:comment "The primary organization managing critical network hubs."@en .

<https://example.com/entity2> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high degree of connections, acting as a major junction."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/structObs1> .

<https://example.com/structObs1> a noria:StructuralObservable ;
  rdfs:label "Node Connectivity"@en ;
  rdfs:comment "Observable property indicating the number of connections."@en .

<https://example.com/entity3> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node serving as a central point in the network topology."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/entity4> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/structObs2> .

<https://example.com/structObs2> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Observable property indicating the number of connections."@en .

<https://example.com/entity5> a noria:FunctionalElement ;
  rdfs:label "Intermediary Service"@en ;
  rdfs:comment "A service acting as an intermediary between core components."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/entity6> a noria:Application ;
  rdfs:label "Multiplex Application"@en ;
  rdfs:comment "An application providing multiple services over the same infrastructure."@en ;
  noria:applicationType <https://w3id.org/noria/kos/application/type#Multiplex> ;
  noria:applicationBusinessImportance <https://example.com/importance1> .

<https://example.com/importance1> a skos:Concept ;
  skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
  rdfs:label "High Business Impact"@en .

<https://example.com/entity7> a noria:SuperNode ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/entity8> a noria:Resource ;
  rdfs:label "Resource Node"@en ;
  rdfs:comment "A resource node with moderate connectivity."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/entity9> a noria:Resource ;
  rdfs:label "Isolated Node"@en ;
  rdfs:comment "An active node with at least one connection, avoiding isolation."@en ;
  noria:resourceManagedBy <https://example.com/organization1> ;
  noria:locatedAtLocus <https://example.com/locus1> .

<https://example.com/locus1> a noria:Locus ;
  rdfs:label "Main Server Room"@en ;
  rdfs:comment "The primary server room location."@en .

<https://example.com/entity10> a noria:Resource ;
  rdfs:label "Super Resource"@en ;
  rdfs:comment "A resource with high connectivity and central role."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "A fiber optic link connecting Hub Node and Central Node."@en ;
  noria:networkLinkId "LinkA-B" ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Ethernet Link B-C"@en ;
  rdfs:comment "Ethernet connection between High-Degree Node and Connector Node."@en ;
  noria:networkLinkId "LinkB-C" .

<https://example.com/connection3> a noria:NetworkLink ;
  rdfs:label "Wireless Link C-D"@en ;
  rdfs:comment "Wireless connection from Connector Node to Intermediary Service."@en ;
  noria:networkLinkId "LinkC-D" .

<https://example.com/connection4> a noria:NetworkLink ;
  rdfs:label "Virtual Link D-E"@en ;
  rdfs:comment "Virtual connection linking Intermediary Service to Multiplex Application."@en ;
  noria:networkLinkId "LinkD-E" .

<https://example.com/connection5> a noria:NetworkLink ;
  rdfs:label "Super Link"@en ;
  rdfs:comment "A super link connecting Super Node to Resource Node."@en ;
  noria:networkLinkId "LinkSuper" .

<https://example.com/entity11> a noria:SuperNode ;
  rdfs:label "Main Super Node"@en ;
  rdfs:comment "A super node aggregating hubs, high-degree, and central nodes."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/entity12> a noria:HubNode ;
  rdfs:label "Hub Node 2"@en ;
  rdfs:comment "Another hub node with high degree."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/entity13> a noria:HighDegreeNode ;
  rdfs:label "High-Degree Node 2"@en ;
  rdfs:comment "A node with many connections, acting as a major junction."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/entity14> a noria:ConnectorNode ;
  rdfs:label "Connector Node 2"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/structObs3> .

<https://example.com/structObs3> a noria:StructuralObservable ;
  rdfs:label "Connection Load"@en ;
  rdfs:comment "Observable property indicating load on connector node."@en .

<https://example.com/entity15> a noria:MultiplexNode ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node providing multiple services and connections."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/entity16> a noria:SuperNode ;
  rdfs:label "Super Node 2"@en ;
  rdfs:comment "Another super node aggregating multiple hubs."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/entity17> a noria:Resource ;
  rdfs:label "Active Resource"@en ;
  rdfs:comment "A resource node with at least one connection."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/entity18> a noria:Resource ;
  rdfs:label "Connected Resource"@en ;
  rdfs:comment "A resource node linked to other nodes."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/entity19> a noria:Resource ;
  rdfs:label "Connected Resource 2"@en ;
  rdfs:comment "Another resource node with multiple links."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/entity20> a noria:Resource ;
  rdfs:label "Active Resource 2"@en ;
  rdfs:comment "Active resource with at least one connection."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/entity21> a noria:Resource ;
  rdfs:label "Isolated Active Node"@en ;
  rdfs:comment "An active node with at least one connection, avoiding isolation."@en ;
  noria:resourceManagedBy <https://example.com/organization1> ;
  noria:locatedAtLocus <https://example.com/locus1> .

<https://example.com/entity22> a noria:Resource ;
  rdfs:label "Super Resource 2"@en ;
  rdfs:comment "A high connectivity resource node."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/entity23> a noria:Resource ;
  rdfs:label "Resource with High Connectivity"@en ;
  rdfs:comment "A resource node with many links, central in the network."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/entity24> a noria:Resource ;
  rdfs:label "Resource with Moderate Connectivity"@en ;
  rdfs:comment "A resource node with some links."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/entity25> a noria:Resource ;
  rdfs:label "Resource with Few Links"@en ;
  rdfs:comment "A resource node with limited connectivity."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/entity26> a noria:Resource ;
  rdfs:label "Resource with Single Link"@en ;
  rdfs:comment "A resource node with only one connection."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/entity27> a noria:Resource ;
  rdfs:label "Resource with No Links"@en ;
  rdfs:comment "An active resource node with at least one connection, not isolated."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/entity28> a noria:Resource ;
  rdfs:label "Resource with Multiple Links"@en ;
  rdfs:comment "A resource node with many links, central in the network."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

