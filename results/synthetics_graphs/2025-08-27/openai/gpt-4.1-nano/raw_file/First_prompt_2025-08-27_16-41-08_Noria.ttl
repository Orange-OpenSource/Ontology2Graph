@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "The organization responsible for managing core network infrastructure."@en .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A switch with many connections, acting as a high-degree node."@en ;
  noria:structuralElementObservableData "Connected to multiple routers and servers" .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "A router acting as a central point in the network topology."@en ;
  noria:structuralElementObservableData "Routing traffic between multiple subnets" .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Link"@en ;
  rdfs:comment "A logical link connecting two network segments."@en ;
  noria:structuralElementObservableData "Connects subnet A and subnet B" .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediate Firewall"@en ;
  rdfs:comment "Firewall acting as an intermediary between internal and external networks."@en ;
  noria:structuralElementObservableData "Filters traffic between zones" .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "Device multiplexing multiple data streams."@en ;
  noria:structuralElementObservableData "Handles multiple data channels" .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple network segments."@en ;
  noria:structuralElementObservableData "Aggregates traffic from various subnets" .

<https://example.com/HubNode1> noria:elementProperty <https://example.com/hasConnection> .

<https://example.com/HighDegreeNode1> noria:elementProperty <https://example.com/connectedTo> .

<https://example.com/CentralNode1> noria:elementProperty <https://example.com/routingTo> .

<https://example.com/ConnectorNode1> noria:elementProperty <https://example.com/linksTo> .

<https://example.com/IntermediaryNode1> noria:elementProperty <https://example.com/filtersTraffic> .

<https://example.com/MultiplexNode1> noria:elementProperty <https://example.com/multipliesStreams> .

<https://example.com/SuperNode1> noria:elementProperty <https://example.com/aggregatesTraffic> .

<https://example.com/hasConnection> a owl:ObjectProperty ;
  rdfs:label "has connection"@en ;
  rdfs:comment "Connection between hub node and high-degree node."@en .

<https://example.com/connectedTo> a owl:ObjectProperty ;
  rdfs:label "connected to"@en ;
  rdfs:comment "Link between high-degree node and other network elements."@en .

<https://example.com/routingTo> a owl:ObjectProperty ;
  rdfs:label "routing to"@en ;
  rdfs:comment "Routing relation from central node to other nodes."@en .

<https://example.com/linksTo> a owl:ObjectProperty ;
  rdfs:label "links to"@en ;
  rdfs:comment "Logical link connecting nodes."@en .

<https://example.com/filtersTraffic> a owl:ObjectProperty ;
  rdfs:label "filters traffic"@en ;
  rdfs:comment "Firewall filtering relation."@en .

<https://example.com/multipliesStreams> a owl:ObjectProperty ;
  rdfs:label "multiplies streams"@en ;
  rdfs:comment "Data multiplexing relation."@en .

<https://example.com/aggregatesTraffic> a owl:ObjectProperty ;
  rdfs:label "aggregates traffic"@en ;
  rdfs:comment "Super node aggregating network traffic."@en .