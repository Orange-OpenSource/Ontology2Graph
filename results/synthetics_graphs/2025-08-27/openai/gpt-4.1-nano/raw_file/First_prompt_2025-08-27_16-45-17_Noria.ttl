@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node in the network, connecting multiple segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/physicalSwitch1> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center, connecting servers and storage."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:structuralElementObservable <https://example.com/trafficObservable> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionLatency> ;
  noria:structuralObservableOf <https://example.com/virtualLink1> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediate Router"@en ;
  rdfs:comment "An intermediary node facilitating routing between segments."@en ;
  noria:structuralElementObservableData <https://example.com/routingTableSize> ;
  noria:structuralObservable <https://example.com/routingTableObservable> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/multiplexedStream> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple high-degree nodes."@en ;
  noria:structuralElementObservableData <https://example.com/aggregationLevel> ;
  noria:structuralObservable <https://example.com/aggregationObservable> .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing core network nodes."@en .

<https://example.com/physicalSwitch1> a noria:StructuralElement ;
  rdfs:label "Physical Switch 1"@en ;
  rdfs:comment "A physical network switch in the data center."@en ;
  noria:structuralElementDistinguishedName "Switch-DC1" .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections on the switch."@en .

<https://example.com/trafficLoad> a noria:Property ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load on the node."@en .

<https://example.com/trafficObservable> a noria:StructuralObservable ;
  rdfs:label "Traffic Observable"@en ;
  rdfs:comment "Observable property for traffic load."@en .

<https://example.com/connectionLatency> a noria:Property ;
  rdfs:label "Connection Latency"@en ;
  rdfs:comment "Latency between connected nodes."@en .

<https://example.com/routingTableSize> a noria:Property ;
  rdfs:label "Routing Table Size"@en ;
  rdfs:comment "Number of entries in the routing table."@en .

<https://example.com/routingTableObservable> a noria:StructuralObservable ;
  rdfs:label "Routing Table Observable"@en ;
  rdfs:comment "Observable for routing table size."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/multiplexedStream> a noria:Application ;
  rdfs:label "Multiplexed Data Stream"@en ;
  rdfs:comment "A multiplexed data stream combining multiple sources."@en .

<https://example.com/aggregationLevel> a noria:Property ;
  rdfs:label "Aggregation Level"@en ;
  rdfs:comment "Level of data aggregation in super node."@en .

<https://example.com/aggregationObservable> a noria:StructuralObservable ;
  rdfs:label "Aggregation Observable"@en ;
  rdfs:comment "Observable property for aggregation level."@en .