@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, managing multiple links."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a connector."@en ;
  noria:structuralElementObservable <https://example.com/observable/connectionCount> ;
  noria:structuralObservableOf <https://example.com/ResourceA> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/observable/trafficFlow> ;
  noria:structuralObservableOf <https://example.com/ResourceB> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/segmentLink> ;
  noria:structuralObservableOf <https://example.com/ResourceC> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/observable/dataRate> ;
  noria:structuralObservableOf <https://example.com/ResourceD> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiplexing of multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/muxCapacity> ;
  noria:structuralObservableOf <https://example.com/ResourceE> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/observable/superNodeLoad> ;
  noria:structuralObservableOf <https://example.com/ResourceF> .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A critical resource connected to the high-degree node."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/Locus1> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A central resource linked to the central node."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:locatedAtLocus <https://example.com/Locus2> .

<https://example.com/ResourceC> a noria:Resource ;
  rdfs:label "Resource C"@en ;
  rdfs:comment "A connector resource linking network segments."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:locatedAtLocus <https://example.com/Locus3> .

<https://example.com/ResourceD> a noria:Resource ;
  rdfs:label "Resource D"@en ;
  rdfs:comment "An intermediary resource facilitating data flow."@en ;
  noria:resourceLogisticId "LOG98765" ;
  noria:locatedAtLocus <https://example.com/Locus4> .

<https://example.com/ResourceE> a noria:Resource ;
  rdfs:label "Resource E"@en ;
  rdfs:comment "A multiplexing resource supporting multiple streams."@en ;
  noria:resourceLogisticId "LOG19283" ;
  noria:locatedAtLocus <https://example.com/Locus5> .

<https://example.com/ResourceF> a noria:Resource ;
  rdfs:label "Resource F"@en ;
  rdfs:comment "A super resource aggregating multiple nodes."@en ;
  noria:resourceLogisticId "LOG74638" ;
  noria:locatedAtLocus <https://example.com/Locus6> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Location of Resource A."@en ;
  noria:locusLine "Line: L, Column: 1" .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Location of Resource B."@en ;
  noria:locusLine "Line: L, Column: 2" .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Locus 3"@en ;
  rdfs:comment "Location of Resource C."@en ;
  noria:locusLine "Line: L, Column: 3" .

<https://example.com/Locus4> a noria:Locus ;
  rdfs:label "Locus 4"@en ;
  rdfs:comment "Location of Resource D."@en ;
  noria:locusLine "Line: L, Column: 4" .

<https://example.com/Locus5> a noria:Locus ;
  rdfs:label "Locus 5"@en ;
  rdfs:comment "Location of Resource E."@en ;
  noria:locusLine "Line: L, Column: 5" .

<https://example.com/Locus6> a noria:Locus ;
  rdfs:label "Locus 6"@en ;
  rdfs:comment "Location of Resource F."@en ;
  noria:locusLine "Line: L, Column: 6" .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/observable/connectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at a node."@en .

<https://example.com/observable/trafficFlow> a noria:StructuralObservable ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Traffic flow rate through a node."@en .

<https://example.com/observable/segmentLink> a noria:StructuralObservable ;
  rdfs:label "Segment Link"@en ;
  rdfs:comment "Link segment between nodes."@en .

<https://example.com/observable/dataRate> a noria:StructuralObservable ;
  rdfs:label "Data Rate"@en ;
  rdfs:comment "Data transfer rate of a node."@en .

<https://example.com/observable/muxCapacity> a noria:StructuralObservable ;
  rdfs:label "Mux Capacity"@en ;
  rdfs:comment "Multiplexing capacity of a node."@en .

<https://example.com/observable/superNodeLoad> a noria:StructuralObservable ;
  rdfs:label "Super Node Load"@en ;
  rdfs:comment "Current load on the super node."@en .
