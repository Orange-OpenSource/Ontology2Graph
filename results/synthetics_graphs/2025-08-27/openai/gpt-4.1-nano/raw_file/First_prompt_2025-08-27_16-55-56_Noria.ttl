@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Network1> a noria:StructuralElement ;
  rdfs:label "Main Data Center Network"@en ;
  rdfs:comment "Core network infrastructure in the main data center."@en ;
  noria:structuralElementDistinguishedName "DCN-01"^^xsd:string ;
  noria:elementManagedBy <https://w3id.org/noria/instance/OrgSupport> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/OrgSupport> .

<https://w3id.org/noria/instance/Resource1> a noria:Resource ;
  rdfs:label "Core Router 1"@en ;
  rdfs:comment "Main core router in the data center."@en ;
  noria:resourceLogisticId "RT-01"^^xsd:string ;
  noria:resourceHostName "core-router-1"@en ;
  noria:resourceSerialNumber "SN123456"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/type/router> ] ;
  noria:resourceProductModel <https://w3id.org/noria/instance/ModelX> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/lifecycle/production> ] ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceManagementIPAddress "192.168.1.1"^^xsd:string ;
  noria:resourceForApplication <https://w3id.org/noria/instance/App1> .

<https://w3id.org/noria/instance/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link DCN to Building A"@en ;
  rdfs:comment "Optical fiber connection between data center core network and Building A."@en ;
  noria:networkLinkId "NL-DCN-A"^^xsd:string ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2021-12-01T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://w3id.org/noria/instance/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/instance/Resource2> .

<https://w3id.org/noria/instance/Resource2> a noria:Resource ;
  rdfs:label "Switch A1"@en ;
  rdfs:comment "Aggregation switch in Building A."@en ;
  noria:resourceLogisticId "SW-01"^^xsd:string ;
  noria:resourceHostName "switch-a1"@en ;
  noria:resourceSerialNumber "SN654321"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/type/switch> ] ;
  noria:resourceProductModel <https://w3id.org/noria/instance/ModelY> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus2> ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/lifecycle/production> ] ;
  noria:resourceInstallationDate "2022-02-20T11:00:00Z"^^xsd:dateTime .

<https://w3id.org/noria/instance/Locus1> a noria:Locus ;
  rdfs:label "Main Data Center Location"@en ;
  noria:locusLine "Line: L, Column: 1"^^xsd:string ;
  noria:locusRow "Row: R"^^xsd:string .

<https://w3id.org/noria/instance/Locus2> a noria:Locus ;
  rdfs:label "Building A Rack"@en ;
  noria:locusLine "Line: L, Column: 3"^^xsd:string ;
  noria:locusRow "Row: R"^^xsd:string .

<https://w3id.org/noria/instance/OrgSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team responsible for network infrastructure."@en .

<https://w3id.org/noria/instance/App1> a noria:Application ;
  rdfs:label "Corporate Internet Access"@en ;
  rdfs:comment "Main corporate internet access service."@en ;
  noria:applicationModelIdentifier "AppModel-001"^^xsd:string ;
  noria:applicationNumericalIdentifier 101 ;
  noria:applicationShortIdentifier "CorpIntAccess"@en ;
  noria:applicationType [ a skos:Concept ; skos:inScheme <kos/application/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/application/type/service-platform> ] ;
  noria:applicationBusinessImportance [ a skos:Concept ; skos:inScheme <kos/application/business-importance> ; skos:hasTopConcept <https://w3id.org/noria/kos/application/critical> ] ;
  noria:applicationFunctionalDomain "Internet Services"^^xsd:string ;
  noria:applicationFunctionalSubDomain "Customer Access"^^xsd:string .

<https://w3id.org/noria/instance/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance router model X."@en ;
  noria:productManufacturedBy <https://w3id.org/noria/instance/OrgVendor> .

<https://w3id.org/noria/instance/OrgVendor> a org:Organization ;
  rdfs:label "Vendor Inc."@en ;
  rdfs:comment "Manufacturer of network equipment."@en .

<https://w3id.org/noria/instance/Action1> a noria:CorrectiveMaintenanceAction ;
  rdfs:label "Restart Router 1"@en ;
  rdfs:comment "Action to restart the core router."@en ;
  noria:actionCorrelatedOperationPlan <https://w3id.org/noria/instance/OpPlan1> .

<https://w3id.org/noria/instance/OpPlan1> a noria:OperationPlan ;
  rdfs:label "Router Restart Procedure"@en ;
  rdfs:comment "Standard procedure to restart core router."@en .

<https://w3id.org/noria/instance/Event1> a noria:EventRecord ;
  rdfs:label "Router Up Event"@en ;
  rdfs:comment "Event indicating router is back online."@en ;
  noria:loggingTime "2023-10-01T14:30:00Z"^^xsd:dateTime ;
  noria:logText "Router 1 is operational."@en ;
  noria:logOriginatingManagedObject <https://w3id.org/noria/instance/Resource1> ;
  noria:logOriginatingManagementSystem <https://w3id.org/noria/instance/MonitoringSystem> .

<https://w3id.org/noria/instance/MonitoringSystem> a noria:Application ;
  rdfs:label "Network Monitoring System"@en ;
  rdfs:comment "System monitoring network devices."@en .

<https://w3id.org/noria/instance/Resource2> a noria:Resource ;
  rdfs:label "Switch A1"@en ;
  rdfs:comment "Aggregation switch in Building A."@en ;
  noria:resourceLogisticId "SW-01"^^xsd:string ;
  noria:resourceHostName "switch-a1"@en .

<https://w3id.org/noria/instance/OrgSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en .

<https://w3id.org/noria/instance/Action1> a noria:CorrectiveMaintenanceAction ;
  rdfs:label "Restart Router 1"@en ;
  noria:actionCorrelatedOperationPlan <https://w3id.org/noria/instance/OpPlan1> .

<https://w3id.org/noria/instance/OpPlan1> a noria:OperationPlan ;
  rdfs:label "Router Restart Procedure"@en .

<https://w3id.org/noria/instance/Event1> a noria:EventRecord ;
  rdfs:label "Router Up Event"@en ;
  noria:loggingTime "2023-10-01T14:30:00Z"^^xsd:dateTime ;
  noria:logText "Router 1 is operational."@en ;
  noria:logOriginatingManagedObject <https://w3id.org/noria/instance/Resource1> ;
  noria:logOriginatingManagementSystem <https://w3id.org/noria/instance/MonitoringSystem> .