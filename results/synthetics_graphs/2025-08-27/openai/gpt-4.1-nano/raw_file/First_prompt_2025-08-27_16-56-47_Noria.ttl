@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Network1> a noria:StructuralElement ;
  rdfs:label "Main Data Center Network"@en ;
  rdfs:comment "Core network infrastructure in the main data center."@en ;
  noria:structuralElementDistinguishedName "DCN-01"^^xsd:string ;
  noria:elementManagedBy <https://w3id.org/noria/instance/Org/NetworkOps> ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus/Room314> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/Org/NetworkOps> .

<https://w3id.org/noria/instance/Resource/Switch01> a noria:Resource ;
  rdfs:label "Switch 01"@en ;
  rdfs:comment "Core switch in the main data center."@en ;
  noria:resourceLogisticId "SW-DC-01"^^xsd:string ;
  noria:resourceHostName "switch01.dc.local"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/type/switch> ] ;
  noria:resourceSerialNumber "SN123456789"^^xsd:string ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/lifecycle/active> ] ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus/Row6> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/Org/NetworkOps> .

<https://w3id.org/noria/instance/NetworkInterface/eth0> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Switch 01."@en ;
  noria:networkInterfaceDescription "GigabitEthernet0/0/1"^^xsd:string ;
  noria:networkInterfaceType [ a skos:Concept ; skos:inScheme <kos/NetworkInterface/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/networkinterface/type/physical> ] ;
  noria:networkInterfaceOf <https://w3id.org/noria/instance/Resource/Switch01> ;
  noria:networkInterfaceConnects <https://w3id.org/noria/instance/NetworkLink/Link01> ;
  noria:networkInterfaceRoutingPriorityMetric 122 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 .

<https://w3id.org/noria/instance/NetworkLink/Link01> a noria:NetworkLink ;
  rdfs:label "Fiber Link DC1-DC2"@en ;
  rdfs:comment "Optical fiber connection between Data Center 1 and Data Center 2."@en ;
  noria:networkLinkId "NL-DC1-DC2"^^xsd:string ;
  noria:networkLinkType "Optical fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2021-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://w3id.org/noria/instance/Resource/Switch01> ;
  noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/instance/Resource/Switch02> .

<https://w3id.org/noria/instance/Resource/Switch02> a noria:Resource ;
  rdfs:label "Switch 02"@en ;
  rdfs:comment "Secondary switch in the main data center."@en ;
  noria:resourceLogisticId "SW-DC-02"^^xsd:string ;
  noria:resourceHostName "switch02.dc.local"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/type/switch> ] ;
  noria:resourceSerialNumber "SN987654321"^^xsd:string ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/lifecycle/active> ] ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus/Row6> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/Org/NetworkOps> .

<https://w3id.org/noria/instance/Locus/Room314> a noria:Locus ;
  rdfs:label "Room 314"@en ;
  rdfs:comment "Server room 314 in main data center."@en .

<https://w3id.org/noria/instance/Org/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://w3id.org/noria/instance/Org/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing IT support services."@en .

<https://w3id.org/noria/instance/Resource/Router01> a noria:Resource ;
  rdfs:label "Router 01"@en ;
  rdfs:comment "Main router in the network."@en ;
  noria:resourceLogisticId "RT-01"^^xsd:string ;
  noria:resourceHostName "router01.dc.local"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/type/router> ] ;
  noria:resourceSerialNumber "SN1122334455"^^xsd:string ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/lifecycle/active> ] ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus/Room314> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/Org/NetworkOps> .

<https://w3id.org/noria/instance/Resource/Server01> a noria:Resource ;
  rdfs:label "Application Server 01"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:resourceLogisticId "AS-01"^^xsd:string ;
  noria:resourceHostName "appserver01.dc.local"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/type/server> ] ;
  noria:resourceSerialNumber "SN5566778899"^^xsd:string ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/lifecycle/active> ] ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus/Room314> ;
  noria:resourceManagedBy <https://w3id.org/noria/instance/Org/ITSupport> .

<https://w3id.org/noria/instance/Locus/Row6> a noria:Locus ;
  rdfs:label "Row 6"@en ;
  rdfs:comment "Locus representing row 6 in the server room."@en .

