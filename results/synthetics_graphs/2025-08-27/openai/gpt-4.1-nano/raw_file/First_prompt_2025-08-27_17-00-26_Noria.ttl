@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A highly connected network device with many links."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:structuralElementObservable <https://example.com/latencyObservable> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A core router acting as a central point in the network."@en ;
  noria:structuralElementObservable <https://example.com/trafficFlow> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A relay point in the network path."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/throughputMeasurement> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An aggregated node representing a cluster of devices."@en ;
  noria:structuralElementObservable <https://example.com/clusterStatus> .

<https://example.com/Router1> a noria:StructuralElement ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Edge router in Building A."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> ;
  noria:structuralElementObservable <https://example.com/trafficFlow> .

<https://example.com/Router2> a noria:StructuralElement ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Core router in Data Center."@en ;
  noria:elementManagedBy <https://example.com/DataCenterOps> ;
  noria:structuralElementObservable <https://example.com/trafficFlow> .

<https://example.com/Link1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber connecting Router1 and Router2."@en ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/Router1Interface> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/1"@en ;
  rdfs:comment "Interface on Router1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceOperationalStatus <https://example.com/status/up> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3.5 ;
  noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
  noria:networkInterfaceLaserRxLowPowerWarningThreshold -5 ;
  noria:networkInterfaceOf <https://example.com/Router1> .

<https://example.com/Router2Interface> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/2"@en ;
  rdfs:comment "Interface on Router2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOperationalStatus <https://example.com/status/up> ;
  noria:networkInterfaceRoutingPriorityMetric 120 ;
  noria:networkInterfaceLaserTxOpticalPower -1.8 ;
  noria:networkInterfaceLaserRxOpticalPower -3.2 ;
  noria:networkInterfaceLaserRxHighPowerWarningThreshold -0.5 ;
  noria:networkInterfaceLaserRxLowPowerWarningThreshold -4 ;
  noria:networkInterfaceOf <https://example.com/Router2> .

<https://example.com/TrafficFlow> a noria:StructuralObservable ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Measurement of data flow through the network."@en ;
  noria:structuralElementObservableData <https://example.com/throughput> .

<https://example.com/latencyMeasurement> a noria:StructuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Latency observed between Router1 and Router2."@en .

<https://example.com/throughputMeasurement> a noria:StructuralObservable ;
  rdfs:label "Throughput Measurement"@en ;
  rdfs:comment "Data throughput rate."@en .

<https://example.com/clusterStatus> a noria:StructuralObservable ;
  rdfs:label "Cluster Status"@en ;
  rdfs:comment "Status of the super node cluster."@en .

<https://example.com/status/up> a skos:Concept ;
  rdfs:label "Up"@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/DataCenterOps> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en ;
  rdfs:comment "Team managing data center network devices."@en .