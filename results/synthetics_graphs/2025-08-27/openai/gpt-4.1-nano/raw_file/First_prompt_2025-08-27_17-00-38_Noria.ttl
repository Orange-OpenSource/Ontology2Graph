@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that serves as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:elementManagedBy <https://example.com/ConnectivitySupport> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowObservable> ;
  noria:elementManagedBy <https://example.com/DataManagement> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamSupport> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregationLatency> ;
  noria:elementManagedBy <https://example.com/NetworkSupervisors> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource1"@en ;
  rdfs:comment "A core network resource."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "core-router-1" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "A virtual server resource."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "vm-frontend-2" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualServer> ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceManagedBy <https://example.com/ServerAdmin> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "Line: L, in Room: Server Room 1"@en ;
  noria:locusRow "Row: R"@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Secondary data center."@en ;
  noria:locusLine "Line: M, in Room: Data Center 2"@en ;
  noria:locusRow "Row: S"@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource1."@en ;
  noria:networkInterfaceType "physical"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "eth1"@en ;
  rdfs:comment "Secondary network interface of Resource2."@en ;
  noria:networkInterfaceType "virtual"@en ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/down> ;
  noria:networkInterfaceRoutingPriorityMetric 200 ;
  noria:networkInterfaceLaserTxOpticalPower -1 ;
  noria:networkInterfaceLaserRxOpticalPower -4 .

<https://example.com/ServiceA> a noria:Service ;
  rdfs:label "Service A"@en ;
  rdfs:comment "Core data processing service."@en ;
  noria:serviceType <https://w3id.org/noria/kos/service/type/Processing> ;
  noria:serviceRelatedResource <https://example.com/Resource1> ;
  noria:serviceRelatedResource <https://example.com/Resource2> .

<https://example.com/Application1> a noria:Application ;
  rdfs:label "Application 1"@en ;
  rdfs:comment "Main application for data analytics."@en ;
  noria:applicationModelIdentifier "APP-XYZ" ;
  noria:applicationNumericalIdentifier 101 ;
  noria:applicationShortIdentifier "AppX" ;
  noria:applicationType <https://w3id.org/noria/kos/application/type/Analytics> ;
  noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/High> ;
  noria:applicationFunctionalDomain "Data Analytics"@en ;
  noria:applicationFunctionalSubDomain "Customer Insights"@en .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub connecting core network resources."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high connectivity, critical for network resilience."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node serving as a central point in the topology."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Connects different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:elementManagedBy <https://example.com/ConnectivitySupport> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowObservable> ;
  noria:elementManagedBy <https://example.com/DataManagement> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Supports multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamSupport> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/aggregationLatency> ;
  noria:elementManagedBy <https://example.com/NetworkSupervisors> .