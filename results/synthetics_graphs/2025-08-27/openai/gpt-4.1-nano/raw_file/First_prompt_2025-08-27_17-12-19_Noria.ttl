@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:structuralElementObservable <https://example.com/degreeObservable> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality in the network."@en ;
  noria:structuralElementObservableData <https://example.com/centralityScore> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservable <https://example.com/connectionCount> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/intermediaryLoad> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/multiplexCapacity> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservableData <https://example.com/superNodeLoad> .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A critical resource in the network."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceSerialNumber "SN-987654" ;
  noria:resourceHostName "serverA.example.com" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceManagementIPAddress "192.168.1.10" ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A vital server resource."@en ;
  noria:resourceForApplication <https://example.com/ApplicationX> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A backup resource."@en ;
  noria:resourceLogisticId "LOG54321" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:resourceSerialNumber "SN-123456" ;
  noria:resourceHostName "routerB.example.com" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Standby> ;
  noria:resourceManagementIPAddress "192.168.1.20" ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A network router resource."@en ;
  noria:resourceForApplication <https://example.com/ApplicationY> .

<https://example.com/ApplicationX> a noria:Application ;
  rdfs:label "Application X"@en ;
  rdfs:comment "Core business application."@en ;
  noria:applicationModelIdentifier "AppX-Model" ;
  noria:applicationNumericalIdentifier 101 ;
  noria:applicationShortIdentifier "AppX" ;
  noria:applicationType <https://kos/application/type/BusinessApplication> ;
  noria:applicationBusinessImportance <https://kos/application/business-importance/High> ;
  noria:applicationFunctionalDomain "Customer Management" ;
  noria:applicationFunctionalSubDomain "Customer Data" ;
  rdfs:seeAlso <https://example.com/docs/ApplicationX> .

<https://example.com/ApplicationY> a noria:Application ;
  rdfs:label "Application Y"@en ;
  rdfs:comment "Network management application."@en ;
  noria:applicationModelIdentifier "AppY-Model" ;
  noria:applicationNumericalIdentifier 102 ;
  noria:applicationShortIdentifier "AppY" ;
  noria:applicationType <https://kos/application/type/Management> ;
  noria:applicationBusinessImportance <https://kos/application/business-importance/Medium> ;
  noria:applicationFunctionalDomain "Network Operations" ;
  noria:applicationFunctionalSubDomain "Routing" ;
  rdfs:seeAlso <https://example.com/docs/ApplicationY> .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/degreeMetric> a noria:structuralObservableOf ;
  rdfs:label "Network Degree Metric"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/degreeObservable> a noria:StructuralObservable ;
  rdfs:label "Degree Observable"@en ;
  rdfs:comment "Observable for node degree."@en .

<https://example.com/centralityScore> a noria:structuralObservableOf ;
  rdfs:label "Centrality Score"@en ;
  rdfs:comment "Centrality measure of a node."@en .

<https://example.com/connectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/intermediaryLoad> a noria:structuralObservableOf ;
  rdfs:label "Intermediary Load"@en ;
  rdfs:comment "Load on intermediary node."@en .

<https://example.com/multiplexCapacity> a noria:structuralObservableOf ;
  rdfs:label "Multiplex Capacity"@en ;
  rdfs:comment "Capacity of multiplex node."@en .

<https://example.com/superNodeLoad> a noria:structuralObservableData ;
  rdfs:label "Super Node Load"@en ;
  rdfs:comment "Aggregate load on super node."@en .
