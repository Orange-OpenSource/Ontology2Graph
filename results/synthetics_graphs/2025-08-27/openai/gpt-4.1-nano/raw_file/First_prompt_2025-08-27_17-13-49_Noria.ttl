@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node connecting multiple high-degree nodes in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A switch with many connections acting as a hub in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyData> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode2> a noria:StructuralElement ;
  rdfs:label "High-Degree Router 2"@en ;
  rdfs:comment "A router with high connectivity serving as a central node."@en ;
  noria:structuralElementObservableData <https://example.com/throughputData> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A server acting as a core node with high connectivity."@en ;
  noria:structuralElementObservableData <https://example.com/serverLoad> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/ITDept> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:structuralObservableOf <https://example.com/centralNode> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary device facilitating data flow."@en ;
  noria:structuralElementObservableData <https://example.com/intermediateLatency> ;
  noria:structuralObservableOf <https://example.com/connectorNode> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamThroughput> ;
  noria:structuralObservableOf <https://example.com/centralNode> ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node with extensive connectivity."@en ;
  noria:structuralElementObservableData <https://example.com/superNodeCapacity> ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing high-degree network nodes."@en .

<https://example.com/ITDept> a org:OrganizationalUnit ;
  rdfs:label "IT Department"@en ;
  rdfs:comment "Department managing central servers and critical infrastructure."@en .

<https://example.com/NetworkSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support"@en ;
  rdfs:comment "Support team for network intermediary devices."@en .

<https://example.com/StreamManagement> a org:OrganizationalUnit ;
  rdfs:label "Stream Management Team"@en ;
  rdfs:comment "Team overseeing multiplex nodes and data streams."@en .

<https://example.com/NetworkLeadership> a org:OrganizationalUnit ;
  rdfs:label "Network Leadership"@en ;
  rdfs:comment "Leadership overseeing super nodes and overall network architecture."@en .

<https://example.com/latencyData> a noria:StructuralObservable ;
  rdfs:label "Latency Data"@en ;
  rdfs:comment "Latency measurements for high-degree switch."@en .

<https://example.com/throughputData> a noria:StructuralObservable ;
  rdfs:label "Throughput Data"@en ;
  rdfs:comment "Data throughput metrics for high-degree router."@en .

<https://example.com/serverLoad> a noria:StructuralObservable ;
  rdfs:label "Server Load"@en ;
  rdfs:comment "Current load on the central server."@en .

<https://example.com/connectionQuality> a noria:StructuralObservable ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Quality metrics of the connection at connector node."@en .

<https://example.com/intermediateLatency> a noria:StructuralObservable ;
  rdfs:label "Intermediate Latency"@en ;
  rdfs:comment "Latency measurements at intermediary node."@en .

<https://example.com/streamThroughput> a noria:StructuralObservable ;
  rdfs:label "Stream Throughput"@en ;
  rdfs:comment "Data stream throughput at multiplex node."@en .

<https://example.com/superNodeCapacity> a noria:StructuralObservable ;
  rdfs:label "Super Node Capacity"@en ;
  rdfs:comment "Capacity metrics of super node."@en .