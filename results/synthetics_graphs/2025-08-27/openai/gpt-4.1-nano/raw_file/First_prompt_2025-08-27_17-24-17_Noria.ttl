@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, managing multiple links."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical point in the network."@en ;
  noria:structuralElementObservable <https://example.com/observable/trafficLoad> ;
  noria:structuralObservableOf <https://example.com/Resource1> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/observable/latency> ;
  noria:structuralObservableOf <https://example.com/Resource2> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/connectionStatus> ;
  noria:structuralObservableOf <https://example.com/Resource3> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/observable/dataFlow> ;
  noria:structuralObservableOf <https://example.com/Resource4> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiplexing of multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/muxLoad> ;
  noria:structuralObservableOf <https://example.com/Resource5> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:structuralElementObservable <https://example.com/observable/superNodeStatus> ;
  noria:structuralObservableOf <https://example.com/Resource6> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A core network resource with high traffic load."@en ;
  noria:resourceLogisticId "LOG-RES-001" ;
  noria:locatedAtLocus <https://example.com/LocusA> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A critical server node."@en ;
  noria:resourceLogisticId "LOG-RES-002" ;
  noria:locatedAtLocus <https://example.com/LocusB> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A network switch connecting segments."@en ;
  noria:resourceLogisticId "LOG-RES-003" ;
  noria:locatedAtLocus <https://example.com/LocusC> .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Resource 4"@en ;
  rdfs:comment "A data processing intermediary."@en ;
  noria:resourceLogisticId "LOG-RES-004" ;
  noria:locatedAtLocus <https://example.com/LocusD> .

<https://example.com/Resource5> a noria:Resource ;
  rdfs:label "Resource 5"@en ;
  rdfs:comment "A multiplexing device."@en ;
  noria:resourceLogisticId "LOG-RES-005" ;
  noria:locatedAtLocus <https://example.com/LocusE> .

<https://example.com/Resource6> a noria:Resource ;
  rdfs:label "Resource 6"@en ;
  rdfs:comment "A super node aggregating multiple resources."@en ;
  noria:resourceLogisticId "LOG-RES-006" ;
  noria:locatedAtLocus <https://example.com/LocusF> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en ;
  rdfs:comment "Main server room."@en ;
  noria:locusLine "L" ;
  noria:locusRow "1" .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en ;
  rdfs:comment "Data center rack."@en ;
  noria:locusLine "L" ;
  noria:locusRow "2" .

<https://example.com/LocusC> a noria:Locus ;
  rdfs:label "Locus C"@en ;
  rdfs:comment "Network switch location."@en ;
  noria:locusLine "L" ;
  noria:locusRow "3" .

<https://example.com/LocusD> a noria:Locus ;
  rdfs:label "Locus D"@en ;
  rdfs:comment "Processing node area."@en ;
  noria:locusLine "L" ;
  noria:locusRow "4" .

<https://example.com/LocusE> a noria:Locus ;
  rdfs:label "Locus E"@en ;
  rdfs:comment "Multiplexing device zone."@en ;
  noria:locusLine "L" ;
  noria:locusRow "5" .

<https://example.com/LocusF> a noria:Locus ;
  rdfs:label "Locus F"@en ;
  rdfs:comment "Super node aggregation point."@en ;
  noria:locusLine "L" ;
  noria:locusRow "6" .

<https://example.com/observable/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/observable/latency> a noria:StructuralObservable ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency measurement."@en .

<https://example.com/observable/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of network connections."@en .

<https://example.com/observable/dataFlow> a noria:StructuralObservable ;
  rdfs:label "Data Flow"@en ;
  rdfs:comment "Flow of data through the network."@en .

<https://example.com/observable/muxLoad> a noria:StructuralObservable ;
  rdfs:label "Mux Load"@en ;
  rdfs:comment "Load on multiplexing devices."@en .

<https://example.com/observable/superNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Super Node Status"@en ;
  rdfs:comment "Operational status of the super node."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

