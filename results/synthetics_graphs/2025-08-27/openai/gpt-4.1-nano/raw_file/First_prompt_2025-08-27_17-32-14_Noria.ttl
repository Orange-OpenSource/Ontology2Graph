@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A high-degree node with many connections, critical for network traffic routing."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/TrafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A central node connecting multiple network segments."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/RouterStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking different network zones."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/FirewallStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/LoadDistribution> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/StreamCapacity> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node managing multiple sub-nodes."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/SuperNodeHealth> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Network Hub"@en ;
  rdfs:comment "A hub node with high degree of connections facilitating network traffic."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A switch with many links, acting as a high-degree node."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/TrafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A central router connecting multiple network segments."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/RouterStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Gateway"@en ;
  rdfs:comment "A connector node linking different network zones."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/FirewallStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing network load."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/LoadDistribution> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Stream Multiplexer"@en ;
  rdfs:comment "A node multiplexing multiple data streams."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/StreamCapacity> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node overseeing multiple sub-nodes."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/SuperNodeHealth> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Network Hub"@en ;
  rdfs:comment "A central hub with many connections."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

