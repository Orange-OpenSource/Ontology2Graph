@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node in the network, managing multiple connections."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Data Center Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central switch in the data center."@en ;
  noria:structuralElementObservable <https://example.com/observable/trafficLoad> ;
  noria:structuralObservableOf <https://example.com/Resource/DC_Switch1> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Firewall"@en ;
  rdfs:comment "A central node responsible for network security, connected to multiple segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/securityStatus> ;
  noria:structuralObservableOf <https://example.com/Resource/Firewall1> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node - VPN Gateway"@en ;
  rdfs:comment "A connector node linking external and internal networks via VPN."@en ;
  noria:structuralElementObservable <https://example.com/observable/vpnStatus> ;
  noria:structuralObservableOf <https://example.com/Resource/VPN_Gateway> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediate Load Balancer"@en ;
  rdfs:comment "An intermediary node balancing load between servers."@en ;
  noria:structuralElementObservable <https://example.com/observable/loadDistribution> ;
  noria:structuralObservableOf <https://example.com/Resource/LoadBalancer1> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/streamQuality> ;
  noria:structuralObservableOf <https://example.com/Resource/MultiplexSwitch> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node - Data Center Cluster"@en ;
  rdfs:comment "A super node representing a cluster of servers acting as a single entity."@en ;
  noria:structuralElementObservable <https://example.com/observable/clusterLoad> ;
  noria:structuralObservableOf <https://example.com/Resource/ServerCluster> .

<https://example.com/Resource/DC_Switch1> a noria:Resource ;
  rdfs:label "Data Center Switch 1"@en ;
  rdfs:comment "A core switch in the data center."@en ;
  noria:resourceLogisticId "DC-SW-001" ;
  noria:resourceHostName "dc-switch-1" ;
  noria:resourceType <skos:Concept> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type#Switch> ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelX> .

<https://example.com/Resource/Firewall1> a noria:Resource ;
  rdfs:label "Main Firewall"@en ;
  rdfs:comment "Firewall device securing the network perimeter."@en ;
  noria:resourceLogisticId "FW-001" ;
  noria:resourceHostName "firewall-main" ;
  noria:resourceType <skos:Concept> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type#Firewall> ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelY> .

<https://example.com/Resource/VPN_Gateway> a noria:Resource ;
  rdfs:label "VPN Gateway"@en ;
  rdfs:comment "Gateway for VPN connections."@en ;
  noria:resourceLogisticId "VPN-GW-01" ;
  noria:resourceHostName "vpn-gateway-1" ;
  noria:resourceType <skos:Concept> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type#Gateway> ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelZ> .

<https://example.com/Resource/LoadBalancer1> a noria:Resource ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Distributes network traffic among servers."@en ;
  noria:resourceLogisticId "LB-001" ;
  noria:resourceHostName "loadbalancer-1" ;
  noria:resourceType <skos:Concept> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type#LoadBalancer> ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelZ> .

<https://example.com/Resource/ServerCluster> a noria:Resource ;
  rdfs:label "Server Cluster"@en ;
  rdfs:comment "Cluster of servers acting as a super node."@en ;
  noria:resourceLogisticId "CL-01" ;
  noria:resourceHostName "server-cluster" ;
  noria:resourceType <skos:Concept> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type#Cluster> ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelZ> .

<https://example.com/ProductModel/ModelX> a noria:ProductModel ;
  rdfs:label "ModelX"@en ;
  rdfs:comment "Product model X from Manufacturer A."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ProductModel/ModelY> a noria:ProductModel ;
  rdfs:label "ModelY"@en ;
  rdfs:comment "Product model Y from Manufacturer B."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ProductModel/ModelZ> a noria:ProductModel ;
  rdfs:label "ModelZ"@en ;
  rdfs:comment "Product model Z from Manufacturer C."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerC> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "Manufacturer A"@en ;
  rdfs:comment "Leading manufacturer of network hardware."@en .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "Manufacturer B"@en ;
  rdfs:comment "Specialist in firewall devices."@en .

<https://example.com/ManufacturerC> a org:Organization ;
  rdfs:label "Manufacturer C"@en ;
  rdfs:comment "Provider of network gateways."@en .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

