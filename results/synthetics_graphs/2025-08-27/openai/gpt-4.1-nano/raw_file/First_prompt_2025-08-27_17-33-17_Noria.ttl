@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central node acting as a core router hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections serving as a central switch."@en ;
  noria:structuralElementObservable noria:structuralElementObservableOf ;
  noria:structuralObservableOf <https://example.com/structObs1> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node connecting multiple application servers."@en ;
  noria:structuralElementObservable noria:structuralElementObservableOf ;
  noria:structuralObservableOf <https://example.com/structObs2> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node acting as a firewall between segments."@en ;
  noria:structuralElementObservable noria:structuralElementObservableOf ;
  noria:structuralObservableOf <https://example.com/structObs3> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservable noria:structuralElementObservableOf ;
  noria:structuralObservableOf <https://example.com/structObs4> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable noria:structuralElementObservableOf ;
  noria:structuralObservableOf <https://example.com/structObs5> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservable noria:structuralElementObservableOf ;
  noria:structuralObservableOf <https://example.com/structObs6> .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network infrastructure."@en .

<https://example.com/structObs1> a noria:StructuralObservable ;
  rdfs:label "High-Degree Connection Count"@en ;
  rdfs:comment "Number of connections for the main switch."@en .

<https://example.com/structObs2> a noria:StructuralObservable ;
  rdfs:label "Data Center Switch Load"@en ;
  rdfs:comment "Operational load of the data center switch."@en .

<https://example.com/structObs3> a noria:StructuralObservable ;
  rdfs:label "Firewall Connection Status"@en ;
  rdfs:comment "Status of the firewall connection."@en .

<https://example.com/structObs4> a noria:StructuralObservable ;
  rdfs:label "Traffic Distribution"@en ;
  rdfs:comment "Traffic distribution metrics for load balancer."@en .

<https://example.com/structObs5> a noria:StructuralObservable ;
  rdfs:label "Stream Multiplexing Rate"@en ;
  rdfs:comment "Data stream multiplexing rate."@en .

<https://example.com/structObs6> a noria:StructuralObservable ;
  rdfs:label "Super Node Aggregation Level"@en ;
  rdfs:comment "Level of aggregation for super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Server A"@en ;
  rdfs:comment "Application server hosting web services."@en ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Router R1"@en ;
  rdfs:comment "Edge router connecting to external network."@en ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/NetworkOps> .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en .

<https://example.com/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Server Room 1"@en ;
  rdfs:comment "Location of Server A."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Main Router Location"@en ;
  rdfs:comment "Location of Router R1."@en .