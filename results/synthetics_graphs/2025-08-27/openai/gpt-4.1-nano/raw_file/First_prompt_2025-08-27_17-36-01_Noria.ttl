@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with high connectivity degree, acting as a critical network point."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node serving as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments or systems."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/intermediaryLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiplexing of multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/multiplexCapacity> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/superNodePerformance> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes and links."@en .

<https://example.com/degreeMetric> a noria:Property ;
  rdfs:label "Node Degree Metric"@en ;
  rdfs:comment "A measure of the number of connections for a node."@en .

<https://example.com/latencyObservable> a noria:StructuralObservable ;
  rdfs:label "Network Latency"@en ;
  rdfs:comment "Observable property representing network latency in milliseconds."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Observable indicating whether the node is connected or disconnected."@en .

<https://example.com/intermediaryLoad> a noria:Property ;
  rdfs:label "Intermediary Load"@en ;
  rdfs:comment "The load level on an intermediary node."@en .

<https://example.com/multiplexCapacity> a noria:Property ;
  rdfs:label "Multiplex Capacity"@en ;
  rdfs:comment "Capacity of multiplexing supported by the node."@en .

<https://example.com/superNodePerformance> a noria:Property ;
  rdfs:label "Super Node Performance"@en ;
  rdfs:comment "Performance metrics for the super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A physical resource in the network."@en ;
  noria:resourceHostName "host-resource1" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Another network resource."@en ;
  noria:resourceHostName "host-resource2" .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A third resource in the network."@en ;
  noria:resourceHostName "host-resource3" .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Resource 4"@en ;
  rdfs:comment "A fourth resource, connected to Resource 1."@en ;
  noria:resourceHostName "host-resource4" .

<https://example.com/Resource5> a noria:Resource ;
  rdfs:label "Resource 5"@en ;
  rdfs:comment "A fifth resource, connected to Resource 2."@en ;
  noria:resourceHostName "host-resource5" .

<https://example.com/Resource6> a noria:Resource ;
  rdfs:label "Resource 6"@en ;
  rdfs:comment "A sixth resource, connected to Resource 3."@en ;
  noria:resourceHostName "host-resource6" .

<https://example.com/Link1> a noria:NetworkLink ;
  rdfs:label "Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource 1 and Resource 4."@en .

<https://example.com/Link2> a noria:NetworkLink ;
  rdfs:label "Link 2"@en ;
  rdfs:comment "L2TP connection between Resource 2 and Resource 5."@en .

<https://example.com/Link3> a noria:NetworkLink ;
  rdfs:label "Link 3"@en ;
  rdfs:comment "Virtual connection between Resource 3 and Resource 6."@en .

<https://example.com/Resource1> noria:connected_to <https://example.com/Link1> ;
  noria:locatedAtLocus <https://example.com/LocusA> .

<https://example.com/Resource2> noria:connected_to <https://example.com/Link2> ;
  noria:locatedAtLocus <https://example.com/LocusB> .

<https://example.com/Resource3> noria:connected_to <https://example.com/Link3> ;
  noria:locatedAtLocus <https://example.com/LocusC> .

<https://example.com/Resource4> noria:connected_to <https://example.com/Link1> ;
  noria:locatedAtLocus <https://example.com/LocusD> .

<https://example.com/Resource5> noria:connected_to <https://example.com/Link2> ;
  noria:locatedAtLocus <https://example.com/LocusE> .

<https://example.com/Resource6> noria:connected_to <https://example.com/Link3> ;
  noria:locatedAtLocus <https://example.com/LocusF> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Locus A"@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "Locus B"@en .

<https://example.com/LocusC> a noria:Locus ;
  rdfs:label "Locus C"@en .

<https://example.com/LocusD> a noria:Locus ;
  rdfs:label "Locus D"@en .

<https://example.com/LocusE> a noria:Locus ;
  rdfs:label "Locus E"@en .

<https://example.com/LocusF> a noria:Locus ;
  rdfs:label "Locus F"@en .