@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A highly connected network switch with multiple links."@en ;
  noria:structuralElementObservableData <https://example.com/LinkCount> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A critical server acting as a central point for data processing."@en ;
  noria:structuralElementObservable <https://example.com/ServerLoad> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A network device connecting different subnetworks."@en ;
  noria:structuralElementObservable <https://example.com/ConnectionStatus> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A relay device facilitating data transfer."@en ;
  noria:structuralElementObservable <https://example.com/TransferRate> ;
  noria:elementManagedBy <https://example.com/OperationsGroup> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A device multiplexing multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/StreamCount> ;
  noria:elementManagedBy <https://example.com/TelecomDept> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An aggregated node representing a cluster of nodes."@en ;
  noria:structuralElementObservable <https://example.com/ClusterLoad> ;
  noria:elementManagedBy <https://example.com/ClusterAdmin> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A virtual machine hosting critical applications."@en ;
  noria:resourceLogisticId "VM-12345" ;
  noria:resourceHostName "vm-01.example.com" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtualMachine> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagedBy <https://example.com/ITDept> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "A physical router in the core network."@en ;
  noria:resourceLogisticId "RT-67890" ;
  noria:resourceHostName "router-core-01" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceInstallationDate "2020-05-20T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkInstallationDate "2021-03-10T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet port 0"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> ;
  noria:networkInterfaceRoutingPriorityMetric 100 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/1"@en ;
  rdfs:comment "Secondary interface of Resource2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "Virtual interface for management."@en ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> ;
  noria:networkInterfaceRoutingPriorityMetric 200 ;
  noria:networkInterfaceLaserTxOpticalPower -1 ;
  noria:networkInterfaceLaserRxOpticalPower -2 .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Link Down Event"@en ;
  rdfs:comment "Detected link failure on NetworkLink1."@en ;
  noria:loggingTime "2023-10-01T14:22:00Z"^^xsd:dateTime ;
  noria:logText "Fiber link NL-001 is down."@en ;
  noria:logOriginatingManagedObject <https://example.com/NetworkLink1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/NetworkMonitoringBot> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Major> .

<https://example.com/Event2> a noria:EventRecord ;
  rdfs:label "Resource CPU Overload"@en ;
  rdfs:comment "High CPU usage detected on Resource1."@en ;
  noria:loggingTime "2023-10-02T09:15:00Z"^^xsd:dateTime ;
  noria:logText "CPU load at 95%."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/MonitoringSystem> ;
  noria:logOriginatingAgent <https://example.com/MonitoringBot> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Critical> .

<https://example.com/TroubleTicket1> a noria:TroubleTicket ;
  rdfs:label "TT-2023-1001" ;
  rdfs:comment "Network link down affecting service."@en ;
  <http://purl.org/dc/terms/identifier> "TT-2023-1001" ;
  noria:troubleTicketCreationDateTime "2023-10-01T14:30:00Z"^^xsd:dateTime ;
  noria:troubleTicketLastUpdate "2023-10-01T15:00:00Z"^^xsd:dateTime ;
  noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major> ;
  noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
  noria:troubleTicketUrgency <https://w3id.org/noria/kos/TroubleTicket/urgency/Immediate> ;
  noria:troubleTicketOrigin <https://example.com/CustomerA> ;
  noria:troubleTicketRelatedResource <https://example.com/Resource2> ;
  noria:troubleTicketRelatedService <https://example.com/ServiceX> ;
  noria:troubleTicketImpacts <https://example.com/Resource2> .

<https://example.com/ChangeRequest1> a noria:ChangeRequest ;
  rdfs:label "CR-2023-2001" ;
  rdfs:comment "Upgrade of core router firmware."@en ;
  <http://purl.org/dc/terms/identifier> "CR-2023-2001" ;
  noria:changeRequestCreationDateTime "2023-10-02T10:00:00Z"^^xsd:dateTime ;
  noria:changeRequestLastUpdate "2023-10-02T12:00:00Z"^^xsd:dateTime ;
  noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/Internal> ;
  noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/SoftwareUpgrade> ;
  noria:changeRequestImpact <https://example.com/Resource2> ;
  noria:changeRequestOutageDuration "PT1H"^^xsd:duration ;
  noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Planned> ;
  noria:changeRequestInitiatorParty <https://example.com/ITManager> ;
  noria:changeRequestPilotParty <https://example.com/NetworkEngineer> .

<https://example.com/Document1> a noria:DocumentAttachment ;
  rdfs:label "Router Firmware Upgrade Plan"@en ;
  rdfs:comment "Detailed plan for router firmware upgrade."@en ;
  <http://purl.org/dc/terms/identifier> "DOC-2023-3001" ;
  noria:documentHRef "https://docs.example.com/CR-2023-2001/plan.pdf"^^xsd:anyURI .

<https://example.com/ServiceX> a noria:Application ;
  rdfs:label "Customer Service Application"@en ;
  rdfs:comment "Application providing customer-facing services."@en ;
  noria:applicationModelIdentifier "CS-APP-001" ;
  noria:applicationNumericalIdentifier 101 ;
  noria:applicationShortIdentifier "CustServ" ;
  noria:applicationType <https://w3id.org/noria/kos/application/type/CustomerFacing> ;
  noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/importance/High> ;
  noria:applicationFunctionalDomain "Customer Management"@en ;
  noria:applicationFunctionalSubDomain "Order Processing"@en .

<https://example.com/ITManager> a foaf:Agent ;
  rdfs:label "IT Manager"@en ;
  rdfs:comment "Responsible for IT infrastructure."@en .

<https://example.com/NetworkEngineer> a foaf:Agent ;
  rdfs:label "Network Engineer"@en ;
  rdfs:comment "Handles network device configurations."@en .

<https://example.com/CustomerA> a foaf:Agent ;
  rdfs:label "Customer A"@en ;
  rdfs:comment "Client organization."@en .

<https://example.com/MonitoringSystem> a noria:Application ;
  rdfs:label "Monitoring System"@en ;
  rdfs:comment "System monitoring network and resources."@en .

<https://example.com/MonitoringBot> a foaf:Agent ;
  rdfs:label "Monitoring Bot"@en ;
  rdfs:comment "Automated monitoring agent."@en .

<https://example.com/NetworkMonitoringBot> a foaf:Agent ;
  rdfs:label "Network Monitoring Bot"@en ;
  rdfs:comment "Bot responsible for network health checks."@en .

<https://example.com/ClusterAdmin> a foaf:Agent ;
  rdfs:label "Cluster Administrator"@en ;
  rdfs:comment "Admin responsible for resource clusters."@en .

<https://example.com/Cluster1> a noria:Resource ;
  rdfs:label "Resource Cluster 1"@en ;
  rdfs:comment "Cluster of resources for high availability."@en ;
  noria:resourceLogisticId "CL-001" ;
  noria:resourceHostName "cluster-01" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/cluster> ;
  noria:resourceManagedBy <https://example.com/ClusterAdmin> .

<https://example.com/ClusterLoad> a noria:StructuralObservable ;
  rdfs:label "Cluster Load"@en ;
  rdfs:comment "Aggregate load of resource cluster."@en ;
  rdfs:seeAlso <https://example.com/Cluster1> .

<https://example.com/LinkCount> a noria:StructuralObservable ;
  rdfs:label "Link Count"@en ;
  rdfs:comment "Number of links connected to high-degree node."@en .

<https://example.com/ServerLoad> a noria:StructuralObservable ;
  rdfs:label "Server Load"@en ;
  rdfs:comment "Current load on the central server."@en .

<https://example.com/TransferRate> a noria:StructuralObservable ;
  rdfs:label "Transfer Rate"@en ;
  rdfs:comment "Data transfer rate on intermediary node."@en .

<https://example.com/StreamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/Resource/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "A backup server."@en ;
  noria:resourceLogisticId "BS-002" ;
  noria:resourceHostName "backup-01.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/server> ;
  noria:resourceManagedBy <https://example.com/ITSupport> .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for IT support."@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team managing network infrastructure."@en .

<https://example.com/OperationsGroup> a org:OrganizationalUnit ;
  rdfs:label "Operations Group"@en ;
  rdfs:comment "Group overseeing operational activities."@en .

<https://example.com/CustomerSupport> a org:OrganizationalUnit ;
  rdfs:label "Customer Support"@en ;
  rdfs:comment "Customer support team."@en .

<https://example.com/ClusterSupport> a org:OrganizationalUnit ;
  rdfs:label "Cluster Support Team"@en ;
  rdfs:comment "Support team for resource clusters."@en .

<https://example.com/ClusterAdmin> a foaf:Agent ;
  rdfs:label "Cluster Admin"@en ;
  rdfs:comment "Administrator of resource clusters."@en .