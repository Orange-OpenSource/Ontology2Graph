@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "The organization responsible for managing core network nodes."@en .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/observableData1> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high betweenness centrality, acting as a core connector."@en ;
  noria:structuralElementObservableData <https://example.com/observableData2> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/observableData3> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/observableData4> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/observableData5> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for redundancy."@en ;
  noria:structuralElementObservableData <https://example.com/observableData6> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/observableData1> a noria:StructuralObservable ;
  rdfs:label "Observable Data 1"@en ;
  rdfs:comment "Observable data for high-degree node."@en .

<https://example.com/observableData2> a noria:StructuralObservable ;
  rdfs:label "Observable Data 2"@en ;
  rdfs:comment "Observable data for central node."@en .

<https://example.com/observableData3> a noria:StructuralObservable ;
  rdfs:label "Observable Data 3"@en ;
  rdfs:comment "Observable data for connector node."@en .

<https://example.com/observableData4> a noria:StructuralObservable ;
  rdfs:label "Observable Data 4"@en ;
  rdfs:comment "Observable data for intermediary node."@en .

<https://example.com/observableData5> a noria:StructuralObservable ;
  rdfs:label "Observable Data 5"@en ;
  rdfs:comment "Observable data for multiplex node."@en .

<https://example.com/observableData6> a noria:StructuralObservable ;
  rdfs:label "Observable Data 6"@en ;
  rdfs:comment "Observable data for super node."@en .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Network Link 1"@en ;
  rdfs:comment "A network link connecting hub node to high-degree node."@en ;
  noria:networkLinkId "NL-001" .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Network Link 2"@en ;
  rdfs:comment "A network link connecting high-degree node to central node."@en ;
  noria:networkLinkId "NL-002" .

<https://example.com/connection3> a noria:NetworkLink ;
  rdfs:label "Network Link 3"@en ;
  rdfs:comment "A network link connecting central node to connector node."@en ;
  noria:networkLinkId "NL-003" .

<https://example.com/connection4> a noria:NetworkLink ;
  rdfs:label "Network Link 4"@en ;
  rdfs:comment "A network link connecting connector node to intermediary node."@en ;
  noria:networkLinkId "NL-004" .

<https://example.com/connection5> a noria:NetworkLink ;
  rdfs:label "Network Link 5"@en ;
  rdfs:comment "A network link connecting intermediary node to multiplex node."@en ;
  noria:networkLinkId "NL-005" .

<https://example.com/connection6> a noria:NetworkLink ;
  rdfs:label "Network Link 6"@en ;
  rdfs:comment "A network link connecting multiplex node to super node."@en ;
  noria:networkLinkId "NL-006" .

<https://example.com/hubNode1> noria:structuralElementObservable <https://example.com/observableData1> ;
  noria:structuralElementObservable <https://example.com/observableData2> ;
  noria:structuralElementObservable <https://example.com/observableData3> ;
  noria:structuralElementObservable <https://example.com/observableData4> ;
  noria:structuralElementObservable <https://example.com/observableData5> ;
  noria:structuralElementObservable <https://example.com/observableData6> .

<https://example.com/highDegreeNode1> noria:structuralElementObservable <https://example.com/observableData1> .

<https://example.com/centralNode1> noria:structuralElementObservable <https://example.com/observableData2> .

<https://example.com/connectorNode1> noria:structuralElementObservable <https://example.com/observableData3> .

<https://example.com/intermediaryNode1> noria:structuralElementObservable <https://example.com/observableData4> .

<https://example.com/multiplexNode1> noria:structuralElementObservable <https://example.com/observableData5> .

<https://example.com/superNode1> noria:structuralElementObservable <https://example.com/observableData6> .

<https://example.com/hubNode1> noria:connectedTo <https://example.com/highDegreeNode1> .

<https://example.com/highDegreeNode1> noria:connectedTo <https://example.com/centralNode1> .

<https://example.com/centralNode1> noria:connectedTo <https://example.com/connectorNode1> .

<https://example.com/connectorNode1> noria:connectedTo <https://example.com/intermediaryNode1> .

<https://example.com/intermediaryNode1> noria:connectedTo <https://example.com/multiplexNode1> .

<https://example.com/multiplexNode1> noria:connectedTo <https://example.com/superNode1> .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "Responsible for core network management."@en .

# All nodes are linked via the specified network links, and each node has at least one connection, fulfilling the hub/high-degree/central/connector/intermediary/multiplex/super node roles.