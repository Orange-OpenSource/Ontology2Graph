@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNodeA> a noria:StructuralElement ;
  rdfs:label "Main Switch A"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch in the core network."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableSwitchA> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/CentralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch 1"@en ;
  rdfs:comment "A central node within the data center, connecting servers and storage."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableSwitch1> ;
  noria:elementManagedBy <https://example.com/DataCenterOps> .

<https://example.com/ConnectorNodeX> a noria:StructuralElement ;
  rdfs:label "Connector Node X"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableConnectorX> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/IntermediaryNodeY> a noria:StructuralElement ;
  rdfs:label "Intermediary Node Y"@en ;
  rdfs:comment "An intermediary node facilitating communication between hubs."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableIntermediaryY> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/MultiplexNodeZ> a noria:StructuralElement ;
  rdfs:label "Multiplex Node Z"@en ;
  rdfs:comment "A multiplex node connecting multiple types of network resources."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableMultiplexZ> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/SuperNodeAlpha> a noria:StructuralElement ;
  rdfs:label "Super Node Alpha"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes for high-level management."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableSuperAlpha> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/HubNode2> a noria:ManagedElement ;
  rdfs:label "Edge Hub Node"@en ;
  rdfs:comment "A hub node with high connectivity at the network edge."@en ;
  noria:elementManagedBy <https://example.com/EdgeNetworkTeam> .

<https://example.com/HighDegreeNodeB> a noria:StructuralElement ;
  rdfs:label "Distribution Switch B"@en ;
  rdfs:comment "A high-degree node distributing traffic across multiple segments."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableSwitchB> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/CentralNode2> a noria:StructuralElement ;
  rdfs:label "Main Data Center Switch 2"@en ;
  rdfs:comment "A central node within the data center, connecting servers and storage."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableSwitch2> ;
  noria:elementManagedBy <https://example.com/DataCenterOps> .

<https://example.com/ConnectorNodeY> a noria:StructuralElement ;
  rdfs:label "Connector Node Y"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableConnectorY> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/IntermediaryNodeZ> a noria:StructuralElement ;
  rdfs:label "Intermediary Node Z"@en ;
  rdfs:comment "An intermediary node facilitating communication between hubs."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableIntermediaryZ> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/MultiplexNodeW> a noria:StructuralElement ;
  rdfs:label "Multiplex Node W"@en ;
  rdfs:comment "A multiplex node connecting multiple types of network resources."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableMultiplexW> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/SuperNodeBeta> a noria:StructuralElement ;
  rdfs:label "Super Node Beta"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes for high-level management."@en ;
  noria:structuralElementObservableOf <https://example.com/structuralObservableSuperBeta> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .