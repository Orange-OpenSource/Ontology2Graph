@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central within a subnetwork."@en ;
  noria:structuralElementObservableData <https://example.com/centralityScore> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:elementManagedBy <https://example.com/ConnectivityGroup> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/intermediaryLoad> ;
  noria:elementManagedBy <https://example.com/IntermediaryOps> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/StreamManagement> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs."@en ;
  noria:structuralElementObservableData <https://example.com/aggregationLevel> ;
  noria:elementManagedBy <https://example.com/SuperNodeOps> .

<https://example.com/Network1> a noria:Resource ;
  rdfs:label "Network1"@en ;
  rdfs:comment "Core network resource."@en ;
  noria:resourceLogisticId "LN-001" ;
  noria:resourceHostName "core-router-1" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Network> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "Edge device in branch office."@en ;
  noria:resourceLogisticId "ED-045" ;
  noria:resourceHostName "edge-switch-5" ;
  noria:locatedAtLocus <https://example.com/LocusB> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Device> ;
  noria:resourceManagedBy <https://example.com/EdgeOps> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between core and edge."@en ;
  noria:networkLinkId "NL-1001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Network1> ;
  noria:networkLinkTerminationResource <https://example.com/Resource2> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet port"@en ;
  noria:networkInterfaceOf <https://example.com/Network1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> .

<https://example.com/Network2> a noria:Resource ;
  rdfs:label "Network2"@en ;
  rdfs:comment "Secondary network resource."@en ;
  noria:resourceLogisticId "LN-002" ;
  noria:resourceHostName "backup-router" ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Network> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Link2"@en ;
  rdfs:comment "Backup link between core and remote site."@en ;
  noria:networkLinkId "NL-1002" ;
  noria:networkLinkType "Microwave" ;
  noria:networkLinkInstallationDate "2021-03-10T09:30:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Network2> ;
  noria:networkLinkTerminationResource <https://example.com/Resource2> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource3"@en ;
  rdfs:comment "Virtual machine hosting application."@en ;
  noria:resourceLogisticId "VM-007" ;
  noria:resourceHostName "vm-host-01" ;
  noria:locatedAtLocus <https://example.com/LocusC> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
  noria:resourceManagedBy <https://example.com/VMAdmin> .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Resource4"@en ;
  rdfs:comment "Database server."@en ;
  noria:resourceLogisticId "DB-003" ;
  noria:resourceHostName "db-server-3" ;
  noria:locatedAtLocus <https://example.com/LocusD> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceManagedBy <https://example.com/DBAdmin> .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "LocusA"@en ;
  rdfs:comment "Main Data Center"@en .

<https://example.com/LocusB> a noria:Locus ;
  rdfs:label "LocusB"@en ;
  rdfs:comment "Branch Office"@en .

<https://example.com/LocusC> a noria:Locus ;
  rdfs:label "LocusC"@en ;
  rdfs:comment "Virtual Machine Host Location"@en .

<https://example.com/LocusD> a noria:Locus ;
  rdfs:label "LocusD"@en ;
  rdfs:comment "Database Server Location"@en .

<https://example.com/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for core network infrastructure."@en .

<https://example.com/EdgeOps> a org:OrganizationalUnit ;
  rdfs:label "Edge Operations"@en ;
  rdfs:comment "Team managing edge devices."@en .

<https://example.com/VMAdmin> a org:OrganizationalUnit ;
  rdfs:label "VM Administration"@en ;
  rdfs:comment "Team managing virtual machines."@en .

<https://example.com/DBAdmin> a org:OrganizationalUnit ;
  rdfs:label "Database Administration"@en ;
  rdfs:comment "Team managing database servers."@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Team"@en ;
  rdfs:comment "General network management team."@en .

<https://example.com/SuperNodeOps> a org:OrganizationalUnit ;
  rdfs:label "Super Node Operations"@en ;
  rdfs:comment "Team overseeing super nodes."@en .

<https://example.com/StreamManagement> a org:OrganizationalUnit ;
  rdfs:label "Stream Management"@en ;
  rdfs:comment "Team managing data streams."@en .

<https://example.com/IntermediaryOps> a org:OrganizationalUnit ;
  rdfs:label "Intermediary Operations"@en ;
  rdfs:comment "Team responsible for intermediary nodes."@en .

<https://example.com/NetworkAdmin> a org:OrganizationalUnit ;
  rdfs:label "Network Administration"@en ;
  rdfs:comment "Team managing network infrastructure."@en .

<https://example.com/ConnectivityGroup> a org:OrganizationalUnit ;
  rdfs:label "Connectivity Group"@en ;
  rdfs:comment "Group responsible for connectivity."@en .

<https://example.com/Network1> a noria:Resource ;
  rdfs:label "Network1"@en ;
  rdfs:comment "Core network resource."@en .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource2"@en ;
  rdfs:comment "Edge device in branch office."@en .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource3"@en ;
  rdfs:comment "Virtual machine hosting application."@en .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Resource4"@en ;
  rdfs:comment "Database server."@en .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/NetworkOps> ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a connector."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node central within a subnetwork."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> ;
  noria:structuralElementObservableData <https://example.com/centralityScore> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:elementManagedBy <https://example.com/ConnectivityGroup> ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Acts as an intermediary in data flow."@en ;
  noria:elementManagedBy <https://example.com/IntermediaryOps> ;
  noria:structuralElementObservableData <https://example.com/intermediaryLoad> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Handles multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/StreamManagement> ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple hubs."@en ;
  noria:elementManagedBy <https://example.com/SuperNodeOps> ;
  noria:structuralElementObservableData <https://example.com/aggregationLevel> .