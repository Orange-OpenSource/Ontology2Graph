@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A highly connected node with many links, acting as a backbone switch."@en ;
  noria:structuralElementObservableData <https://example.com/NodeTrafficData> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node serving as a central point in the network topology."@en ;
  noria:structuralElementObservableData <https://example.com/NodeStatus> ;
  noria:structuralElementObservable <https://example.com/structuralObservableOf> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/ConnectorTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkSupportTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow between hubs."@en ;
  noria:structuralElementObservable <https://example.com/structuralElementObservable> ;
  noria:structuralElementObservableData <https://example.com/IntermediaryTrafficData> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple protocols."@en ;
  noria:structuralElementObservableData <https://example.com/MultiplexTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkEngineeringTeam> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node aggregating several sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeStatus> ;
  noria:structuralElementObservableData <https://example.com/SuperNodeTraffic> .

<https://example.com/NodeTrafficData> a noria:Property ;
  rdfs:label "Node Traffic Data"@en ;
  rdfs:comment "Traffic volume and flow data for a node."@en .

<https://example.com/NodeStatus> a noria:StructuralObservable ;
  rdfs:label "Node Status"@en ;
  rdfs:comment "Operational status of a node."@en .

<https://example.com/ConnectorTraffic> a noria:Property ;
  rdfs:label "Connector Traffic"@en ;
  rdfs:comment "Traffic data specific to connector nodes."@en .

<https://example.com/IntermediaryTrafficData> a noria:Property ;
  rdfs:label "Intermediary Traffic Data"@en ;
  rdfs:comment "Traffic metrics for intermediary nodes."@en .

<https://example.com/MultiplexTraffic> a noria:Property ;
  rdfs:label "Multiplex Traffic"@en ;
  rdfs:comment "Traffic handling multiple protocols."@en .

<https://example.com/SuperNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Super Node Status"@en ;
  rdfs:comment "Overall status of the super node."@en .

<https://example.com/SuperNodeTraffic> a noria:Property ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Aggregated traffic data for the super node."@en .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network nodes."@en .

<https://example.com/NetworkSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team for network infrastructure."@en .

<https://example.com/structuralObservable> a noria:StructuralObservable ;
  rdfs:label "Structural Observable"@en ;
  rdfs:comment "Observable property related to structural elements."@en .

<https://example.com/structuralElementObservable> a noria:structuralElementObservable ;
  rdfs:label "Structural Element Observable"@en ;
  rdfs:comment "Relationship between a structural element and its observable."@en .

<https://example.com/structuralObservableOf> a noria:structuralObservableOf ;
  rdfs:label "Structural Observable Of"@en ;
  rdfs:comment "Relates a structural observable to its element."@en .

<https://example.com/structuralElementObservableData> a noria:structuralElementObservableData ;
  rdfs:label "Structural Element Observable Data"@en ;
  rdfs:comment "Data associated with a structural observable."@en .
