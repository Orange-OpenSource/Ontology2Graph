@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch in the data center."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:structuralObservableOf <https://example.com/ServerRack1> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A central node routing traffic between multiple subnets."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:structuralElementDistinguishedName "CoreRouter01" .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking internal and external networks."@en ;
  noria:structuralElementObservable <https://example.com/connectionStatus> ;
  noria:structuralElementObservableData <https://example.com/connectionLatency> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservable <https://example.com/trafficDistribution> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/segmentTraffic> .

<https://example.com/ServerRack1> a noria:StructuralElement ;
  rdfs:label "Server Rack 1"@en ;
  rdfs:comment "A server rack hosting multiple servers."@en ;
  noria:structuralElementObservable <https://example.com/serverTemperature> .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A virtual machine hosting critical applications."@en ;
  noria:resourceLogisticId "VM-ResourceA-001" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceHostName "vm-resourcea-01" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtualMachine> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceSerialNumber "SN123456789" ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagementIPAddress "192.168.100.10" ;
  noria:agentManagesResource <https://example.com/ResourceAdminTeam> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A physical network switch."@en ;
  noria:resourceLogisticId "Switch-ResourceB-002" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceHostName "switch-resourceb-02" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/switch> ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/operational> ;
  noria:resourceSerialNumber "SN987654321" ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:agentManagesResource <https://example.com/NetworkAdminTeam> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between ResourceA and ResourceB."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of ResourceA."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet port eth0"@en ;
  noria:networkInterfaceOf <https://example.com/ResourceA> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> ;
  noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/up> .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/1"@en ;
  rdfs:comment "Management interface of ResourceB."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "Virtual interface for management."@en ;
  noria:networkInterfaceOf <https://example.com/ResourceB> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> ;
  noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/up> .

<https://example.com/ServerTemperature> a noria:StructuralObservable ;
  rdfs:label "Server Temperature"@en ;
  rdfs:comment "Temperature sensor reading for ResourceA."@en ;
  noria:structuralElementObservableData <https://example.com/TemperatureValue> .

<https://example.com/TemperatureValue> a noria:structuralElementObservableData ;
  rdfs:label "Temperature Value"@en ;
  rdfs:comment "Numeric temperature value in Celsius."@en .

<https://example.com/latencyMeasurement> a noria:structuralElementObservableData ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Measured network latency in milliseconds."@en .

<https://example.com/trafficLoad> a noria:structuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load in Mbps."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection between nodes."@en .

<https://example.com/connectionLatency> a noria:structuralElementObservableData ;
  rdfs:label "Connection Latency"@en ;
  rdfs:comment "Latency of the connection in milliseconds."@en .

<https://example.com/segmentTraffic> a noria:structuralObservable ;
  rdfs:label "Segment Traffic"@en ;
  rdfs:comment "Aggregated traffic for network segments."@en .

<https://example.com/streamCount> a noria:structuralElementObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/ResourceAdminTeam> a org:OrganizationalUnit ;
  rdfs:label "Resource Management Team"@en ;
  rdfs:comment "Team responsible for managing resources."@en .

<https://example.com/NetworkAdminTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Administration Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Location of ResourceA in the data center."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Location of ResourceB in the data center."@en .