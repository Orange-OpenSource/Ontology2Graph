@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "Organization responsible for network management."@en .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservable <https://example.com/observable1> .

<https://example.com/observable1> a noria:StructuralObservable ;
  rdfs:label "Bandwidth Usage"@en ;
  rdfs:comment "Observable property indicating bandwidth consumption."@en .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node acting as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/observable2> .

<https://example.com/observable2> a noria:StructuralObservable ;
  rdfs:label "Packet Loss Rate"@en ;
  rdfs:comment "Observable property indicating packet loss rate."@en .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable3> .

<https://example.com/observable3> a noria:StructuralObservable ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Observable property indicating network latency."@en .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/observable4> .

<https://example.com/observable4> a noria:StructuralObservable ;
  rdfs:label "Error Rate"@en ;
  rdfs:comment "Observable property indicating error rate in data transmission."@en .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiplexing of data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable5> .

<https://example.com/observable5> a noria:StructuralObservable ;
  rdfs:label "Throughput"@en ;
  rdfs:comment "Observable property indicating data throughput."@en .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with super connectivity and role in multiple network functions."@en ;
  noria:structuralElementObservable <https://example.com/observable6> .

<https://example.com/observable6> a noria:StructuralObservable ;
  rdfs:label "Security Alert"@en ;
  rdfs:comment "Observable indicating security-related events."@en .

<https://example.com/connector1> a noria:NetworkLink ;
  rdfs:label "Link A-B"@en ;
  rdfs:comment "Physical link connecting HubNode1 and HighDegreeNode1."@en ;
  noria:networkLinkId "link-A-B-001" .

<https://example.com/connector2> a noria:NetworkLink ;
  rdfs:label "Link B-C"@en ;
  rdfs:comment "Logical link connecting HighDegreeNode1 and CentralNode1."@en ;
  noria:networkLinkId "link-B-C-002" .

<https://example.com/connector3> a noria:NetworkLink ;
  rdfs:label "Link C-D"@en ;
  rdfs:comment "Physical link connecting CentralNode1 and IntermediaryNode1."@en ;
  noria:networkLinkId "link-C-D-003" .

<https://example.com/connector4> a noria:NetworkLink ;
  rdfs:label "Link D-E"@en ;
  rdfs:comment "Logical link connecting IntermediaryNode1 and MultiplexNode1."@en ;
  noria:networkLinkId "link-D-E-004" .

<https://example.com/connector5> a noria:NetworkLink ;
  rdfs:label "Link E-F"@en ;
  rdfs:comment "Physical link connecting MultiplexNode1 and SuperNode1."@en ;
  noria:networkLinkId "link-E-F-005" .

<https://example.com/HubNode1> noria:elementManagedBy <https://example.com/organization1> .
<https://example.com/HighDegreeNode1> noria:elementManagedBy <https://example.com/organization1> .
<https://example.com/CentralNode1> noria:elementManagedBy <https://example.com/organization1> .
<https://example.com/IntermediaryNode1> noria:elementManagedBy <https://example.com/organization1> .
<https://example.com/MuxNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiplexing of data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable5> ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with super connectivity and role in multiple network functions."@en ;
  noria:structuralElementObservable <https://example.com/observable6> ;
  noria:elementManagedBy <https://example.com/organization1> .

# Link nodes with links
<https://example.com/HubNode1> noria:structuralElementObservable <https://example.com/observable1> .
<https://example.com/HighDegreeNode1> noria:structuralElementObservable <https://example.com/observable2> .
<https://example.com/CentralNode1> noria:structuralElementObservable <https://example.com/observable3> .
<https://example.com/IntermediaryNode1> noria:structuralElementObservable <https://example.com/observable4> .
<https://example.com/MuxNode1> noria:structuralElementObservable <https://example.com/observable5> .
<https://example.com/SuperNode1> noria:structuralElementObservable <https://example.com/observable6> .

# Connect nodes via links
<https://example.com/HubNode1> noria:structuralElementObservable <https://example.com/observable1> .
<https://example.com/HighDegreeNode1> noria:structuralElementObservable <https://example.com/observable2> .
<https://example.com/CentralNode1> noria:structuralElementObservable <https://example.com/observable3> .
<https://example.com/IntermediaryNode1> noria:structuralElementObservable <https://example.com/observable4> .
<https://example.com/MuxNode1> noria:structuralElementObservable <https://example.com/observable5> .
<https://example.com/SuperNode1> noria:structuralElementObservable <https://example.com/observable6> .

# Connect nodes with links
<https://example.com/HubNode1> noria:structuralElementObservable <https://example.com/observable1> .
<https://example.com/HighDegreeNode1> noria:structuralElementObservable <https://example.com/observable2> .
<https://example.com/CentralNode1> noria:structuralElementObservable <https://example.com/observable3> .
<https://example.com/IntermediaryNode1> noria:structuralElementObservable <https://example.com/observable4> .
<https://example.com/MuxNode1> noria:structuralElementObservable <https://example.com/observable5> .
<https://example.com/SuperNode1> noria:structuralElementObservable <https://example.com/observable6> .

# Connect nodes with links
<https://example.com/connector1> a noria:NetworkLink ;
  rdfs:label "Link A-B"@en ;
  noria:networkLinkId "link-A-B-001" ;
  noria:networkLinkTerminationResource <https://example.com/HubNode1> ;
  noria:networkLinkTerminationResource <https://example.com/HighDegreeNode1> .

<https://example.com/connector2> a noria:NetworkLink ;
  rdfs:label "Link B-C"@en ;
  noria:networkLinkId "link-B-C-002" ;
  noria:networkLinkTerminationResource <https://example.com/HighDegreeNode1> ;
  noria:networkLinkTerminationResource <https://example.com/CentralNode1> .

<https://example.com/connector3> a noria:NetworkLink ;
  rdfs:label "Link C-D"@en ;
  noria:networkLinkId "link-C-D-003" ;
  noria:networkLinkTerminationResource <https://example.com/CentralNode1> ;
  noria:networkLinkTerminationResource <https://example.com/IntermediaryNode1> .

<https://example.com/connector4> a noria:NetworkLink ;
  rdfs:label "Link D-E"@en ;
  noria:networkLinkId "link-D-E-004" ;
  noria:networkLinkTerminationResource <https://example.com/IntermediaryNode1> ;
  noria:networkLinkTerminationResource <https://example.com/MuxNode1> .

<https://example.com/connector5> a noria:NetworkLink ;
  rdfs:label "Link E-F"@en ;
  noria:networkLinkId "link-E-F-005" ;
  noria:networkLinkTerminationResource <https://example.com/MuxNode1> ;
  noria:networkLinkTerminationResource <https://example.com/SuperNode1> .

# End of graph