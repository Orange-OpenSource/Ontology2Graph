@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/highDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a critical connector."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node that is central in the network topology, connecting multiple subnets."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node that connects different network segments or domains."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow between other nodes."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node that handles multiple data streams or protocols."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node that aggregates multiple nodes or functions."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/EntityHub>
  a noria:ManagedElement ;
  rdfs:label "Entity Hub"@en ;
  rdfs:comment "A hub node that manages multiple entities."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/EntityHighDegree>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Entity"@en ;
  rdfs:comment "An entity with many relations, acting as a key connector."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/CentralEntity>
  a noria:StructuralElement ;
  rdfs:label "Central Entity"@en ;
  rdfs:comment "Entity that is central in the network, linking multiple components."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/ConnectorEntity>
  a noria:StructuralElement ;
  rdfs:label "Connector Entity"@en ;
  rdfs:comment "Entity that connects different parts of the network."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/IntermediaryEntity>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Entity"@en ;
  rdfs:comment "Entity acting as an intermediary in data flow."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/MultiplexEntity>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Entity"@en ;
  rdfs:comment "Entity handling multiple data streams or protocols."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/SuperEntity>
  a noria:StructuralElement ;
  rdfs:label "Super Entity"@en ;
  rdfs:comment "An overarching entity aggregating multiple components."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> .

<https://example.com/Entity1>
  a noria:StructuralElement ;
  rdfs:label "Entity 1"@en ;
  rdfs:comment "An example entity linked to the hub node."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:elementManagedBy <https://example.com/EntityManager> .

<https://example.com/Entity2>
  a noria:StructuralElement ;
  rdfs:label "Entity 2"@en ;
  rdfs:comment "Another entity connected to Entity 1."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:elementManagedBy <https://example.com/EntityManager> .

<https://example.com/Entity3>
  a noria:StructuralElement ;
  rdfs:label "Entity 3"@en ;
  rdfs:comment "Entity linked to Entity 2, forming a multiplex node."@en ;
  rdfs:isDefinedBy <https://w3id.org/noria/> ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:elementManagedBy <https://example.com/EntityManager> .

<https://example.com/EntityManager>
  a org:OrganizationalUnit ;
  rdfs:label "Entity Management Team"@en ;
  rdfs:comment "Team responsible for managing entities."@en .

<https://example.com/Entity1> noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Entity2> .

<https://example.com/Entity2> noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Entity3> .

<https://example.com/Entity3> noria:structuralElementObservable noria:structuralElementObservableData .

<https://example.com/Entity1> noria:elementManagedBy <https://example.com/EntityManager> .
<https://example.com/Entity2> noria:elementManagedBy <https://example.com/EntityManager> .
<https://example.com/Entity3> noria:elementManagedBy <https://example.com/EntityManager> .

<https://example.com/Entity1> noria:structuralElementDistinguishedName "Entity1_DN" .
<https://example.com/Entity2> noria:structuralElementDistinguishedName "Entity2_DN" .
<https://example.com/Entity3> noria:structuralElementDistinguishedName "Entity3_DN" .

<https://example.com/Entity1> rdfs:label "Entity 1"@en ; rdfs:comment "An example entity linked to the hub node."@en .
<https://example.com/Entity2> rdfs:label "Entity 2"@en ; rdfs:comment "Another entity connected to Entity 1."@en .
<https://example.com/Entity3> rdfs:label "Entity 3"@en ; rdfs:comment "Entity linked to Entity 2, forming a multiplex node."@en .

<https://example.com/Entity1> noria:elementManagedBy <https://example.com/EntityManager> .
<https://example.com/Entity2> noria:elementManagedBy <https://example.com/EntityManager> .
<https://example.com/Entity3> noria:elementManagedBy <https://example.com/EntityManager> .

<https://example.com/Entity1> noria:structuralElementObservable noria:structuralElementObservableData .
<https://example.com/Entity2> noria:structuralElementObservable noria:structuralElementObservableData .
<https://example.com/Entity3> noria:structuralElementObservable noria:structuralElementObservableData .

<https://example.com/Entity1> noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/Entity2> .

