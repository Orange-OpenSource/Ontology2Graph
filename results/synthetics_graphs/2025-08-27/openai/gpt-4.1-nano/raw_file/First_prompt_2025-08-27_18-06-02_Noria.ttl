@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with a high number of connections, critical for network resilience."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/HighDegreeObservable> ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/centralNode> a noria:FunctionalElement ;
  rdfs:label "Central Functional Node"@en ;
  rdfs:comment "A central node responsible for core functionalities."@en ;
  noria:elementManagedBy <https://example.com/ITTeam> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node acting as a connector between different network segments."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/ConnectorObservable> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node serving as an intermediary in data flow."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/IntermediaryObservable> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node that handles multiple data streams simultaneously."@en ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:structuralObservableOf <https://example.com/observable/MultiplexObservable> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/NetworkAdmin> a org:OrganizationalUnit ;
  rdfs:label "Network Administration"@en ;
  rdfs:comment "Team managing high-degree nodes and critical network components."@en .

<https://example.com/ITTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for core functional nodes."@en .

<https://example.com/NetworkSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team managing connector nodes and network links."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Team managing intermediary nodes."@en .

<https://example.com/observable/HighDegreeObservable> a noria:StructuralObservable ;
  rdfs:label "High Degree Observable"@en ;
  rdfs:comment "Observable property for high-degree nodes."@en .

<https://example.com/observable/ConnectorObservable> a noria:StructuralObservable ;
  rdfs:label "Connector Observable"@en ;
  rdfs:comment "Observable property for connector nodes."@en .

<https://example.com/observable/IntermediaryObservable> a noria:StructuralObservable ;
  rdfs:label "Intermediary Observable"@en ;
  rdfs:comment "Observable property for intermediary nodes."@en .

<https://example.com/observable/MultiplexObservable> a noria:StructuralObservable ;
  rdfs:label "Multiplex Observable"@en ;
  rdfs:comment "Observable property for multiplex nodes."@en .