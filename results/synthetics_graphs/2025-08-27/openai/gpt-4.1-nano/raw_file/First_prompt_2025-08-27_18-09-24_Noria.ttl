@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/HubNode> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/HighDegreeNode> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments, serving as a bridge."@en ;
  noria:structuralElementObservableData <https://example.com/segmentCount> ;
  noria:structuralObservableOf <https://example.com/CentralNode> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:structuralObservableOf <https://example.com/connectorNode> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that handles multiple data streams simultaneously."@en ;
  noria:structuralElementObservableData <https://example.com/multiplexCapacity> ;
  noria:structuralObservableOf <https://example.com/intermediaryNode> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node representing a superordinate network component."@en ;
  noria:structuralElementObservableData <https://example.com/superNodeLoad> ;
  noria:structuralObservableOf <https://example.com/multiplexNode> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network infrastructure."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of connections associated with the node."@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "The volume of traffic passing through the node."@en .

<https://example.com/segmentCount> a noria:Property ;
  rdfs:label "Segment Count"@en ;
  rdfs:comment "Number of network segments connected by the node."@en .

<https://example.com/dataFlowRate> a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through the node."@en .

<https://example.com/multiplexCapacity> a noria:Property ;
  rdfs:label "Multiplex Capacity"@en ;
  rdfs:comment "Capacity of multiplexing at the node."@en .

<https://example.com/superNodeLoad> a noria:Property ;
  rdfs:label "Super Node Load"@en ;
  rdfs:comment "Current load on the super node."@en .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Connection 1"@en ;
  rdfs:comment "A physical optical fiber link."@en ;
  noria:networkLinkId "NL-001" .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Connection 2"@en ;
  rdfs:comment "A virtual L2TP connection."@en ;
  noria:networkLinkId "NL-002" .

<https://example.com/HubNode> noria:connectedTo <https://example.com/connection1> , <https://example.com/connection2> .

<https://example.com/HighDegreeNode> noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralElementObservable <https://example.com/HubNode> .

<https://example.com/CentralNode> noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralElementObservable <https://example.com/HighDegreeNode> .

<https://example.com/ConnectorNode> noria:structuralElementObservableData <https://example.com/segmentCount> ;
  noria:structuralElementObservable <https://example.com/CentralNode> .

<https://example.com/IntermediaryNode> noria:structuralElementObservableData <https://example.com/dataFlowRate> ;
  noria:structuralElementObservable <https://example.com/ConnectorNode> .

<https://example.com/MuxNode> noria:structuralElementObservableData <https://example.com/multiplexCapacity> ;
  noria:structuralElementObservable <https://example.com/IntermediaryNode> .

<https://example.com/SuperNode> noria:structuralElementObservableData <https://example.com/superNodeLoad> ;
  noria:structuralElementObservable <https://example.com/MuxNode> .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity."@en .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a junction."@en .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node serving as a core in the topology."@en .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Connects different network segments."@en .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Acts as an intermediary in data flow."@en .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Handles multiple data streams."@en .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Represents a superordinate network component."@en .