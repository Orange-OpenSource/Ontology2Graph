@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity, acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "Organization responsible for managing core network infrastructure."@en .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with a high number of connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/observableData1> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservableData <https://example.com/observableData2> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/observableData3> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/observableData4> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/observableData5> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with super connectivity, integrating multiple functions."@en ;
  noria:structuralElementObservableData <https://example.com/observableData6> .

<https://example.com/resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Physical server hosting critical applications."@en ;
  noria:resourceLogisticId "LOG12345" ;
  noria:resourceHostName "server1.datacenter.org" ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/physical> ;
  noria:resourceSerialNumber "SN987654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/productModel1> ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/locus1> a noria:Locus ;
  rdfs:label "Locus in Server Room 314"@en ;
  rdfs:comment "Specific location within the server room."@en ;
  noria:locusLine "L" ;
  noria:locusRow "6" .

<https://example.com/productModel1> a noria:ProductModel ;
  rdfs:label "Dell PowerEdge R740"@en ;
  rdfs:comment "Dell server model R740."@en ;
  noria:productManufacturedBy <https://example.com/organization2> .

<https://example.com/organization2> a org:Organization ;
  rdfs:label "Dell Inc."@en ;
  rdfs:comment "Manufacturer of the server."@en .

<https://example.com/networkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet Interface"@en ;
  noria:networkInterfaceOf <https://example.com/resource1> ;
  noria:networkInterfaceConnects <https://example.com/networkLink1> .

<https://example.com/networkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between Resource 1 and Resource 2."@en ;
  noria:networkLinkId "NLINK001" ;
  noria:networkLinkType "optical fiber" ;
  noria:networkLinkInstallationDate "2021-03-10T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/resource2> .

<https://example.com/resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Virtual machine hosting application."@en ;
  noria:resourceLogisticId "LOG67890" ;
  noria:resourceHostName "vm-host2.datacenter.org" ;
  noria:locatedAtLocus <https://example.com/locus2> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtual> ;
  noria:resourceSerialNumber "SN123456789" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:resourceInstallationDate "2022-01-20T11:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/productModel2> ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/locus2> a noria:Locus ;
  rdfs:label "Locus in Data Center 2"@en ;
  rdfs:comment "Location within data center 2."@en ;
  noria:locusLine "A" ;
  noria:locusRow "12" .

<https://example.com/productModel2> a noria:ProductModel ;
  rdfs:label "HP ProLiant DL380"@en ;
  rdfs:comment "HP server model DL380."@en ;
  noria:productManufacturedBy <https://example.com/organization3> .

<https://example.com/organization3> a org:Organization ;
  rdfs:label "HP Inc."@en ;
  rdfs:comment "Manufacturer of the HP server."@en .

<https://example.com/event1> a noria:EventRecord ;
  rdfs:label "Interface Up Event"@en ;
  rdfs:comment "Event indicating network interface eth0 is up."@en ;
  noria:loggingTime "2023-10-01T14:22:00Z"^^xsd:dateTime ;
  noria:logText "Interface eth0 on Resource 1 is now operational."@en ;
  noria:logOriginatingManagedObject <https://example.com/resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/managementSystem1> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Major> .

<https://example.com/managementSystem1> a noria:Application ;
  rdfs:label "SNMP Management System"@en ;
  rdfs:comment "System managing network devices via SNMP."@en .

<https://example.com/troubleTicket1> a noria:TroubleTicket ;
  rdfs:label "Network Interface Down"@en ;
  rdfs:comment "Ticket for network interface eth0 down."@en ;
  noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major> ;
  noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
  noria:troubleTicketCriticity <https://w3id.org/noria/kos/TroubleTicket/category/ServiceImpact> ;
  noria:troubleTicketDetectionDateTime "2023-10-01T14:20:00Z"^^xsd:dateTime ;
  noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status/InProgress> ;
  noria:troubleTicketRelatedResource <https://example.com/resource1> ;
  noria:troubleTicketRelatedResource <https://example.com/resource2> .

<https://example.com/troubleTicketNote1> a noria:TroubleTicketNote ;
  rdfs:label "Note on Interface Down"@en ;
  rdfs:comment "Customer reported interface eth0 is down."@en ;
  noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Customer> ;
  noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> ;
  noria:troubleTicketNoteForTicket <https://example.com/troubleTicket1> ;
  noria:troubleTicketNoteCorrelatedExecution <https://example.com/event1> ;
  noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Customer> .

<https://example.com/changeRequest1> a noria:ChangeRequest ;
  rdfs:label "Upgrade Network Switch"@en ;
  rdfs:comment "Change request to upgrade core network switch."@en ;
  noria:changeRequestCreationDateTime "2023-09-15T09:00:00Z"^^xsd:dateTime ;
  noria:changeRequestActualStartTime "2023-10-05T22:00:00Z"^^xsd:dateTime ;
  noria:changeRequestActualEndTime "2023-10-05T23:30:00Z"^^xsd:dateTime ;
  noria:changeRequestImpact <https://example.com/resource1> ;
  noria:changeRequestImpact <https://example.com/resource2> ;
  noria:changeRequestChangeCause <https://w3id.org/noria/kos/ChangeRequest/cause/Configuration> ;
  noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/NetworkUpgrade> ;
  noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/Upgrade> ;
  noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Completed> .

<https://example.com/document1> a noria:DocumentAttachment ;
  rdfs:label "Network Diagram"@en ;
  rdfs:comment "Diagram illustrating network topology."@en ;
  noria:documentExternalId "DOC123" ;
  noria:documentHRef "http://docs.example.com/topology.pdf"^^xsd:anyURI ;
  noria:documentStatusHistory <https://example.com/event1> .

<https://example.com/event2> a noria:EventRecord ;
  rdfs:label "Configuration Change Event"@en ;
  rdfs:comment "Event indicating configuration change on Resource 2."@en ;
  noria:loggingTime "2023-10-02T10:15:00Z"^^xsd:dateTime ;
  noria:logText "Configuration updated on Resource 2."@en ;
  noria:logOriginatingManagedObject <https://example.com/resource2> ;
  noria:logOriginatingManagementSystem <https://example.com/managementSystem1> .

<https://example.com/troubleTicket2> a noria:TroubleTicket ;
  rdfs:label "Resource 2 Unreachable"@en ;
  rdfs:comment "Trouble ticket for Resource 2 being unreachable."@en ;
  noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major> ;
  noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
  noria:troubleTicketCriticity <https://w3id.org/noria/kos/TroubleTicket/category/ServiceImpact> ;
  noria:troubleTicketDetectionDateTime "2023-10-02T09:45:00Z"^^xsd:dateTime ;
  noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status/InProgress> ;
  noria:troubleTicketRelatedResource <https://example.com/resource2> .

<https://example.com/troubleTicketNote2> a noria:TroubleTicketNote ;
  rdfs:label "Unreachable Resource"@en ;
  rdfs:comment "Resource 2 is not responding to pings."@en ;
  noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/System> ;
  noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> ;
  noria:troubleTicketNoteForTicket <https://example.com/troubleTicket2> ;
  noria:troubleTicketNoteCorrelatedExecution <https://example.com/event2> .

# End of graph