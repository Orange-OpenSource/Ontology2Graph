@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A switch with high connectivity degree, acting as a backbone connector."@en ;
  noria:structuralElementObservableData "Degree: 50"^^xsd:integer ;
  noria:structuralElementDistinguishedName "Switch-Backbone-01" .

<https://example.com/centralNode> a noria:FunctionalElement ;
  rdfs:label "Central Application Server"@en ;
  rdfs:comment "A critical server hosting core applications."@en ;
  noria:functionalElementDistinguishedName "AppServer-01" .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "Firewall node acting as a connector between internal and external networks."@en ;
  noria:structuralElementObservableData "Firewall throughput: 10Gbps"^^xsd:string .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Intermediary node distributing traffic among servers."@en ;
  noria:structuralElementDistinguishedName "LoadBalancer-01" .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "Device multiplexing multiple data streams."@en ;
  noria:structuralElementObservableData "Streams multiplexed: 8"^^xsd:integer .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple high-degree nodes."@en ;
  noria:structuralElementObservableData "Connected high-degree nodes: 5"^^xsd:integer .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Server-Alpha"@en ;
  rdfs:comment "A virtual server hosting critical services."@en ;
  noria:resourceLogisticId "LOG-ServerAlpha-001" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceHostName "server-alpha" ;
  noria:resourceType <skos:Concept> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtualServer> ;
  noria:resourceProductModel <https://example.com/ProductModelX> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Router-Delta"@en ;
  rdfs:comment "Core network router."@en ;
  noria:resourceLogisticId "LOG-RouterDelta-002" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceHostName "router-delta" ;
  noria:resourceType <skos:Concept> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus1"@en ;
  rdfs:comment "Main server room."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus2"@en ;
  rdfs:comment "Data center rack 3."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "FiberLink-01"@en ;
  rdfs:comment "Optical fiber link between Resource1 and Resource2."@en ;
  noria:networkLinkId "NL-OpticalFiber-01" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Gigabit Ethernet port"@en ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <skos:Concept> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> .

<https://example.com/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/1"@en ;
  rdfs:comment "Main interface of Resource2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "Virtual interface for internal routing"@en ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceOperationalStatus <skos:Concept> ;
  noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> .

<https://example.com/AlarmEvent1> a noria:EventRecord ;
  rdfs:label "LinkDownAlarm"@en ;
  rdfs:comment "Alarm indicating link failure."@en ;
  noria:loggingTime "2023-10-01T14:30:00"^^xsd:dateTime ;
  noria:logText "FiberLink-01 is down."@en ;
  noria:alarmSeverity <skos:Concept> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Critical> ;
  noria:alarmProposedRepairAction <https://example.com/RepairAction1> ;
  noria:logOriginatingManagedObject <https://example.com/NetworkLink1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> .

<https://example.com/RepairAction1> a pep:Procedure ;
  rdfs:label "Reset Fiber Link"@en ;
  rdfs:comment "Procedure to reset the fiber link."@en .

<https://example.com/AlarmEvent2> a noria:EventRecord ;
  rdfs:label "RouterReboot"@en ;
  rdfs:comment "Alarm for router reboot."@en ;
  noria:loggingTime "2023-10-02T09:15:00"^^xsd:dateTime ;
  noria:logText "Router-Delta has rebooted unexpectedly."@en ;
  noria:alarmSeverity <skos:Concept> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Major> ;
  noria:logOriginatingManagedObject <https://example.com/Resource2> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS2> .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en .

<https://example.com/NMS2> a noria:Application ;
  rdfs:label "Network Management System 2"@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "ModelX"@en ;
  rdfs:comment "Manufacturer's model code for Resource1."@en ;
  org:organization <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "ACME Corp."@en .

