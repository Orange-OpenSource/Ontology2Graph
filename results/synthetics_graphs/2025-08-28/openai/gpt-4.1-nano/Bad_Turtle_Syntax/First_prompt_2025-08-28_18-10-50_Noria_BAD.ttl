@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a central point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/degreeMetric> ;
  noria:structuralObservableOf <https://example.com/NodeA> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that connects multiple subnetworks, serving as a core component."@en ;
  noria:structuralElementDistinguishedName "CN-001" .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that links different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionType> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/intermediaryRole> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node supporting multiple types of connections."@en ;
  noria:structuralElementObservableData <https://example.com/multiplexCapability> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching node aggregating multiple nodes."@en ;
  noria:structuralElementObservableData <https://example.com/superNodeCapacity> .

<https://example.com/NodeA> a noria:StructuralElement ;
  rdfs:label "Node A"@en ;
  rdfs:comment "A high-degree node with many connections."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/NodeB> a noria:StructuralElement ;
  rdfs:label "Node B"@en ;
  rdfs:comment "A connector node linking subnetworks."@en ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network hubs and high-degree nodes."@en .

<https://example.com/NetworkSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team for connector and intermediary nodes."@en .

<https://example.com/degreeMetric> a noria:Property ;
  rdfs:label "Degree Metric"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/connectionType> a noria:Property ;
  rdfs:label "Connection Type"@en ;
  rdfs:comment "Type of connection (e.g., fiber, wireless)."@en .

<https://example.com/intermediaryRole> a noria:Property ;
  rdfs:label "Intermediary Role"@en ;
  rdfs:comment "Role played by the intermediary node."@en .

<https://example.com/multiplexCapability> a noria:Property ;
  rdfs:label "Multiplex Capability"@en ;
  rdfs:comment "Supports multiple connection types."@en .

<https://example.com/superNodeCapacity> a noria:Property ;
  rdfs:label "Super Node Capacity"@en ;
  rdfs:comment "Capacity of the super node in terms of throughput."@en .

<https://example.com/NodeC> a noria:StructuralElement ;
  rdfs:label "Node C"@en ;
  rdfs:comment "A multiplex node supporting various connection types."@en ;
  noria:structuralElementObservableData <https://example.com/multiplexCapability> .

<https://example.com/NodeD> a noria:StructuralElement ;
  rdfs:label "Node D"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservableData <https://example.com/superNodeCapacity> .

<https://example.com/NodeA> noria:structuralElementObservable <https://example.com/NodeB> ;
<https://example.com/NodeA> noria:structuralElementObservable <https://example.com/NodeC> .

<https://example.com/NodeB> noria:structuralElementObservable <https://example.com/NodeA> ;
<https://example.com/NodeB> noria:structuralElementObservable <https://example.com/NodeD> .

<https://example.com/NodeC> noria:structuralElementObservable <https://example.com/NodeA> .

<https://example.com/NodeD> noria:structuralElementObservable <https://example.com/NodeB> .

