@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode1>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A switch with high connectivity in the network."@en ;
  noria:structuralElementObservableData "Port count: 48"^^xsd:string ;
  noria:structuralObservableOf <https://example.com/highDegreeNode1> ;
  noria:structuralElementDistinguishedName "Switch1-DN"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode2>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Router 2"@en ;
  rdfs:comment "A router with multiple connections."@en ;
  noria:structuralElementObservableData "Routing protocols: OSPF, BGP"^^xsd:string ;
  noria:structuralObservableOf <https://example.com/highDegreeNode2> ;
  noria:structuralElementDistinguishedName "Router2-DN"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A central server acting as a core node."@en ;
  noria:structuralElementObservableData "CPU: 32 cores, RAM: 256GB"^^xsd:string ;
  noria:structuralObservableOf <https://example.com/centralServer> ;
  noria:structuralElementDistinguishedName "CentralServer-DN"^^xsd:string ;
  noria:elementManagedBy <https://example.com/ITAdmin> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservableData "Connected to Switch1 and Router2"^^xsd:string ;
  noria:structuralObservableOf <https://example.com/connectorNode> ;
  noria:structuralElementDistinguishedName "ConnectorNode-DN"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Device"@en ;
  rdfs:comment "An intermediary device facilitating data flow."@en ;
  noria:structuralElementObservableData "Status: Active"^^xsd:string ;
  noria:structuralObservableOf <https://example.com/intermediaryDevice> ;
  noria:structuralElementDistinguishedName "IntermediaryDevice-DN"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservableData "Streams: 4"^^xsd:string ;
  noria:structuralObservableOf <https://example.com/multiplexNode> ;
  noria:structuralElementDistinguishedName "MultiplexNode-DN"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservableData "Aggregates: 10 nodes"^^xsd:string ;
  noria:structuralObservableOf <https://example.com/superNode> ;
  noria:structuralElementDistinguishedName "SuperNode-DN"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/ITAdmin>
  a foaf:Agent ;
  rdfs:label "IT Administration"@en ;
  rdfs:comment "Administrator responsible for core servers."@en .

<https://example.com/NetworkOperations>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Operational unit managing network infrastructure."@en .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Device"@en ;
  rdfs:comment "Device connecting multiple network segments."@en ;
  noria:structuralElementObservableData "Status: Active"^^xsd:string ;
  noria:structuralObservableOf <https://example.com/connectorNode> ;
  noria:structuralElementDistinguishedName "ConnectorDevice-DN"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/intermediaryDevice>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Device"@en ;
  rdfs:comment "Device facilitating data transfer."@en ;
  noria:structuralElementObservableData "Status: Active"^^xsd:string ;
  noria:structuralObservableOf <https://example.com/intermediaryDevice> ;
  noria:structuralElementDistinguishedName "IntermediaryDevice-DN"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplexing Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservableData "Streams: 4"^^xsd:string ;
  noria:structuralObservableOf <https://example.com/multiplexNode> ;
  noria:structuralElementDistinguishedName "MultiplexNode-DN"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple nodes."@en ;
  noria:structuralElementObservableData "Nodes: 10"^^xsd:string ;
  noria:structuralObservableOf <https://example.com/superNode> ;
  noria:structuralElementDistinguishedName "SuperNode-DN"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .