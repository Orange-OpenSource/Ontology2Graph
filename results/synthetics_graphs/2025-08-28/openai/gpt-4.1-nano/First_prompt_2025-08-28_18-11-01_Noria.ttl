@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/HubSwitch> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node that manages key traffic flows within the network."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/CoreRouter> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:structuralObservableOf <https://example.com/EdgeSwitch> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow between hubs."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:structuralObservableOf <https://example.com/IntermediateRouter> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/Multiplexer> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node aggregating several hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/aggregateTraffic> ;
  noria:structuralObservableOf <https://example.com/SuperRouter> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network nodes."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at this node."@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "The amount of traffic passing through the node."@en .

<https://example.com/connectionStatus> a noria:Property ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Current status of the connection (e.g., active, inactive)."@en .

<https://example.com/latency> a noria:Property ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency measured in milliseconds."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/aggregateTraffic> a noria:Property ;
  rdfs:label "Aggregate Traffic"@en ;
  rdfs:comment "Total traffic aggregated at the super node."@en .

<https://example.com/HubSwitch> a noria:StructuralElement ;
  rdfs:label "Hub Switch"@en ;
  rdfs:comment "A switch acting as a hub in the network."@en .

<https://example.com/CoreRouter> a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A core router managing main traffic routes."@en .

<https://example.com/EdgeSwitch> a noria:StructuralElement ;
  rdfs:label "Edge Switch"@en ;
  rdfs:comment "An edge switch connecting end devices."@en .

<https://example.com/IntermediateRouter> a noria:StructuralElement ;
  rdfs:label "Intermediate Router"@en ;
  rdfs:comment "A router facilitating data transfer between core and edge."@en .

<https://example.com/Multiplexer> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A device combining multiple data streams."@en .

<https://example.com/SuperRouter> a noria:StructuralElement ;
  rdfs:label "Super Router"@en ;
  rdfs:comment "An overarching router aggregating multiple sub-networks."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Physical server hosting network services."@en ;
  noria:resourceLogisticId "SRV-001" ;
  noria:resourceHostName "server1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/physical> ;
  noria:locatedAtLocus <https://example.com/Room314> .

<https://example.com/Room314> a noria:Room ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Main server room on the 3rd floor."@en .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Virtual machine for application hosting."@en ;
  noria:resourceLogisticId "VM-045" ;
  noria:resourceHostName "vm-host.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/virtual> ;
  noria:locatedAtLocus <https://example.com/ServerRackA> .

<https://example.com/ServerRackA> a noria:Locus ;
  rdfs:label "Server Rack A"@en ;
  rdfs:comment "Rack A in the data center."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Resource1 and Resource2."@en ;
  noria:networkLinkId "LINK-001" ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "Network switch in the main corridor."@en ;
  noria:resourceLogisticId "SW-789" ;
  noria:resourceHostName "switch-main-corridor" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/physical> ;
  noria:locatedAtLocus <https://example.com/Room314> .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Ethernet Link"@en ;
  rdfs:comment "Ethernet connection between Resource3 and Resource1."@en ;
  noria:networkLinkId "LINK-002" ;
  noria:networkLinkType "Ethernet" .

<https://example.com/HubNode> a noria:StructuralElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting core network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/HubSwitch> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, critical for network resilience."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/EdgeSwitch> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node managing main traffic flow."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/CoreRouter> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Links different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:structuralObservableOf <https://example.com/EdgeSwitch> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Facilitates data transfer between core and edge."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:structuralObservableOf <https://example.com/IntermediateRouter> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Handles multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/Multiplexer> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates several hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/aggregateTraffic> ;
  noria:structuralObservableOf <https://example.com/SuperRouter> .