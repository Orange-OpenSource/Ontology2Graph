@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Graph1> a owl:NamedIndividual ;
    rdfs:label "Sample Network Graph"@en ;
    rdfs:comment "A created knowledge graph demonstrating various node types linked according to the Noria schema."@en .

# Hub Node: Central Router
<https://example.com/router1> a noria:StructuralElement ;
    rdfs:label "Router1"@en ;
    rdfs:comment "Main router acting as a hub in the network."@en ;
    noria:structuralElementDistinguishedName "Router1-DN" .

# High-Degree Node: Core Switch
<https://example.com/switch1> a noria:StructuralElement ;
    rdfs:label "CoreSwitch"@en ;
    rdfs:comment "Core switch with high connectivity."@en ;
    noria:structuralElementDistinguishedName "Switch-Core-01" .

# Central Node: Data Center
<https://example.com/datacenter> a noria:StructuralElement ;
    rdfs:label "DataCenter"@en ;
    rdfs:comment "Main data center hosting critical infrastructure."@en ;
    noria:structuralElementDistinguishedName "DC-001" .

# Connector Node: Firewall
<https://example.com/firewall> a noria:StructuralElement ;
    rdfs:label "Firewall"@en ;
    rdfs:comment "Firewall connecting internal network to external."@en ;
    noria:structuralElementDistinguishedName "Firewall-Edge" .

# Intermediary Node: Load Balancer
<https://example.com/loadbalancer> a noria:FunctionalElement ;
    rdfs:label "LoadBalancer"@en ;
    rdfs:comment "Distributes traffic among servers."@en ;
    noria:functionalElementDistinguishedName "LB-01" .

# Multiplex Node: Virtual Machine Cluster
<https://example.com/vmcluster> a noria:StructuralElement ;
    rdfs:label "VMCluster"@en ;
    rdfs:comment "Cluster of virtual machines acting as multiplex node."@en ;
    noria:structuralElementDistinguishedName "VM-Cluster-Alpha" .

# Super Node: Network Backbone
<https://example.com/backbone> a noria:StructuralElement ;
    rdfs:label "NetworkBackbone"@en ;
    rdfs:comment "Super node representing the entire network backbone."@en ;
    noria:structuralElementDistinguishedName "Backbone-Global" .

# Relationships

# Hub node connected to high-degree node
<https://example.com/router1> noria:elementProperty <https://example.com/connection1> .

<https://example.com/connection1> a noria:NetworkLink ;
    rdfs:label "Connection Router1 to Switch1"@en ;
    rdfs:comment "Link between Router1 and Switch1."@en ;
    noria:networkLinkId "Link-001" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
    noria:networkLinkType "Optical Fiber" .

# High-degree node connected to data center
<https://example.com/switch1> noria:elementProperty <https://example.com/connection2> .

<https://example.com/connection2> a noria:NetworkLink ;
    rdfs:label "Connection Switch1 to DataCenter"@en ;
    rdfs:comment "Link between Switch1 and DataCenter."@en ;
    noria:networkLinkId "Link-002" ;
    noria:networkLinkInstallationDate "2022-02-20T12:30:00"^^xsd:dateTime ;
    noria:networkLinkType "L2 Ethernet" .

# Central node connected to firewall
<https://example.com/firewall> noria:elementProperty <https://example.com/connection3> .

<https://example.com/connection3> a noria:NetworkLink ;
    rdfs:label "Connection Firewall to DataCenter"@en ;
    rdfs:comment "Link between Firewall and DataCenter."@en ;
    noria:networkLinkId "Link-003" ;
    noria:networkLinkInstallationDate "2022-03-10T09:45:00"^^xsd:dateTime ;
    noria:networkLinkType "Virtual Private Network" .

# Intermediary node (Load Balancer) connected to multiple resources
<https://example.com/loadbalancer> noria:elementProperty <https://example.com/connection4> .

<https://example.com/connection4> a noria:NetworkLink ;
    rdfs:label "Connection LoadBalancer to WebServer"@en ;
    rdfs:comment "Link between LoadBalancer and WebServer."@en ;
    noria:networkLinkId "Link-004" ;
    noria:networkLinkInstallationDate "2022-04-05T14:00:00"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" .

# Multiplex node (VM Cluster) connected to load balancer
<https://example.com/vmcluster> noria:elementProperty <https://example.com/connection5> .

<https://example.com/connection5> a noria:NetworkLink ;
    rdfs:label "Connection VMCluster to LoadBalancer"@en ;
    rdfs:comment "Link between VMCluster and LoadBalancer."@en ;
    noria:networkLinkId "Link-005" ;
    noria:networkLinkInstallationDate "2022-05-01T11:15:00"^^xsd:dateTime ;
    noria:networkLinkType "Virtual Network" .

# Super node (Network Backbone) connected to all major nodes
<https://example.com/backbone> noria:elementProperty <https://example.com/connection6> .

<https://example.com/connection6> a noria:NetworkLink ;
    rdfs:label "Connection Backbone to Router1"@en ;
    rdfs:comment "Backbone link to Router1."@en ;
    noria:networkLinkId "Link-006" ;
    noria:networkLinkInstallationDate "2021-12-01T08:00:00"^^xsd:dateTime ;
    noria:networkLinkType "Optical Fiber" .

<https://example.com/backbone> noria:elementProperty <https://example.com/connection7> .

<https://example.com/connection7> a noria:NetworkLink ;
    rdfs:label "Connection Backbone to Switch1"@en ;
    rdfs:comment "Backbone link to Switch1."@en ;
    noria:networkLinkId "Link-007" ;
    noria:networkLinkInstallationDate "2021-12-01T08:00:00"^^xsd:dateTime ;
    noria:networkLinkType "Optical Fiber" .

# Additional Nodes to ensure no isolated nodes
<https://example.com/isolatedNode> a noria:StructuralElement ;
    rdfs:label "IsolatedNode"@en ;
    rdfs:comment "An isolated node that will be dismissed as per instructions."@en .

# Link to connect the isolated node to the network (to dismiss it)
<https://example.com/connection8> a noria:NetworkLink ;
    rdfs:label "Connection to IsolatedNode"@en ;
    rdfs:comment "Link to isolated node, to be dismissed."@en ;
    noria:networkLinkId "Link-008" ;
    noria:networkLinkInstallationDate "2022-06-01T10:00:00"^^xsd:dateTime ;
    noria:networkLinkType "Unknown" .

<https://example.com/isolatedNode> noria:elementProperty <https://example.com/connection8> .

# End of graph
.