@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/highDegreeNode2> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch in the core network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode3> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center, connecting servers and storage."@en ;
  noria:structuralElementObservableData <https://example.com/portStatus> ;
  noria:elementManagedBy <https://example.com/DataCenterTeam> .

<https://example.com/connectorNode4> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node acting as a firewall boundary between segments."@en ;
  noria:structuralElementObservableData <https://example.com/trafficFlow> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode5> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node balancing load across servers."@en ;
  noria:structuralElementObservableData <https://example.com/serverResponseTime> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/multiplexNode6> a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamThroughput> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode7> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/overallTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing core network nodes."@en .

<https://example.com/DataCenterTeam> a org:OrganizationalUnit ;
  rdfs:label "Data Center Team"@en ;
  rdfs:comment "Team managing data center infrastructure."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for network security."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Support team for IT infrastructure."@en .

<https://example.com/latencyMeasurement> a noria:StructuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Measured latency between nodes."@en .

<https://example.com/portStatus> a noria:StructuralObservable ;
  rdfs:label "Port Status"@en ;
  rdfs:comment "Status of network ports (up/down)."@en .

<https://example.com/trafficFlow> a noria:StructuralObservable ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Flow of traffic through the firewall connector."@en .

<https://example.com/serverResponseTime> a noria:StructuralObservable ;
  rdfs:label "Server Response Time"@en ;
  rdfs:comment "Response time of servers behind load balancer."@en .

<https://example.com/streamThroughput> a noria:StructuralObservable ;
  rdfs:label "Stream Throughput"@en ;
  rdfs:comment "Data throughput in multiplexing switch."@en .

<https://example.com/overallTraffic> a noria:StructuralObservable ;
  rdfs:label "Overall Traffic"@en ;
  rdfs:comment "Aggregated network traffic at super node."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between core router and main switch."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "High-capacity core router."@en ;
  noria:resourceLogisticId "CR-001" ;
  noria:resourceHostName "core-router-1" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "Main network switch in data center."@en ;
  noria:resourceLogisticId "MS-002" ;
  noria:resourceHostName "main-switch-1" .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Firewall"@en ;
  rdfs:comment "Firewall boundary node."@en ;
  noria:resourceLogisticId "FW-003" ;
  noria:resourceHostName "firewall-1" .

<https://example.com/Resource4> a noria:Resource ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Load balancing device."@en ;
  noria:resourceLogisticId "LB-004" ;
  noria:resourceHostName "loadbalancer-1" .

<https://example.com/Resource5> a noria:Resource ;
  rdfs:label "Web Server 1"@en ;
  rdfs:comment "Web server behind load balancer."@en ;
  noria:resourceLogisticId "WS-005" ;
  noria:resourceHostName "webserver1" .

<https://example.com/Resource6> a noria:Resource ;
  rdfs:label "Web Server 2"@en ;
  rdfs:comment "Web server behind load balancer."@en ;
  noria:resourceLogisticId "WS-006" ;
  noria:resourceHostName "webserver2" .

<https://example.com/Resource7> a noria:Resource ;
  rdfs:label "Multiplex Switch"@en ;
  rdfs:comment "Switch for multiplexing streams."@en ;
  noria:resourceLogisticId "MS-007" ;
  noria:resourceHostName "multiplex-switch-1" .

<https://example.com/Resource8> a noria:Resource ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregated super node."@en ;
  noria:resourceLogisticId "SN-008" ;
  noria:resourceHostName "super-node-1" .

<https://example.com/Connection1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber between core router and main switch."@en .

<https://example.com/Connection2> a noria:NetworkLink ;
  rdfs:label "Firewall Connection"@en ;
  rdfs:comment "Connection from firewall to load balancer."@en .

<https://example.com/Connection3> a noria:NetworkLink ;
  rdfs:label "Load Balancer to Web Servers"@en ;
  rdfs:comment "Connection from load balancer to web servers."@en .

<https://example.com/Connection4> a noria:NetworkLink ;
  rdfs:label "Multiplexing Stream"@en ;
  rdfs:comment "Stream connection through multiplex switch."@en .

<https://example.com/Connection5> a noria:NetworkLink ;
  rdfs:label "Super Node Link"@en ;
  rdfs:comment "Link connecting super node to core network."@en .
