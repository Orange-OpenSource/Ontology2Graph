@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central router acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/OrgSupport> .

<https://example.com/highDegreeNode2> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree switch connecting multiple network segments."@en ;
  noria:structuralElementObservableData "Switch port utilization"@en ;
  noria:structuralObservableOf <https://example.com/HubNode1> .

<https://example.com/centralNode3> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node connecting servers and storage."@en ;
  noria:structuralElementObservableData "Switch temperature"@en ;
  noria:structuralElementObservable <https://example.com/TemperatureObservable> .

<https://example.com/connectorNode4> a noria:StructuralElement ;
  rdfs:label "Fiber Connector"@en ;
  rdfs:comment "A connector node linking fiber optic cables."@en ;
  noria:structuralElementObservableData "Optical power level"@en ;
  noria:structuralElementObservable <https://example.com/OpticalPowerObservable> .

<https://example.com/intermediaryNode5> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:elementManagedBy <https://example.com/ITTeam> .

<https://example.com/multiplexNode6> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplexing node combining multiple data streams."@en ;
  noria:structuralElementObservableData "Stream count"@en ;
  noria:structuralObservableOf <https://example.com/HubNode1> .

<https://example.com/superNode7> a noria:StructuralElement ;
  rdfs:label "Super Switch"@en ;
  rdfs:comment "A super node aggregating multiple network segments."@en ;
  noria:structuralElementObservableData "Aggregate throughput"@en ;
  noria:structuralObservableOf <https://example.com/centralNode3> .

<https://example.com/HubNode1> noria:elementManagedBy <https://example.com/OrgSupport> .

<https://example.com/HighDegreeNode2> noria:elementManagedBy <https://example.com/ITTeam> .

<https://example.com/CentralNode3> noria:elementManagedBy <https://example.com/ITTeam> .

<https://example.com/ConnectorNode4> noria:elementManagedBy <https://example.com/SupportTeam> .

<https://example.com/IntermediaryNode5> noria:elementManagedBy <https://example.com/ITTeam> .

<https://example.com/MultiplexNode6> noria:elementManagedBy <https://example.com/SupportTeam> .

<https://example.com/SuperNode7> noria:elementManagedBy <https://example.com/OrgSupport> .

<https://example.com/OrgSupport> a org:OrganizationalUnit ;
  rdfs:label "Network Support Organization"@en ;
  rdfs:comment "Organization responsible for network infrastructure support."@en .

<https://example.com/ITTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Operations Team"@en ;
  rdfs:comment "Team managing core IT infrastructure."@en .

<https://example.com/SupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Support Team"@en ;
  rdfs:comment "Team providing technical support."@en .

<https://example.com/TemperatureObservable> a noria:StructuralObservable ;
  rdfs:label "Temperature Observable"@en ;
  rdfs:comment "Temperature measurement of network equipment."@en .

<https://example.com/OpticalPowerObservable> a noria:StructuralObservable ;
  rdfs:label "Optical Power Observable"@en ;
  rdfs:comment "Optical power level measurement."@en .

<https://example.com/HubNode1> noria:elementManagedBy <https://example.com/OrgSupport> .

<https://example.com/HighDegreeNode2> noria:elementManagedBy <https://example.com/ITTeam> .

<https://example.com/CentralNode3> noria:elementManagedBy <https://example.com/ITTeam> .

<https://example.com/ConnectorNode4> noria:elementManagedBy <https://example.com/SupportTeam> .

<https://example.com/IntermediaryNode5> noria:elementManagedBy <https://example.com/ITTeam> .

<https://example.com/MultiplexNode6> noria:elementManagedBy <https://example.com/SupportTeam> .

<https://example.com/SuperNode7> noria:elementManagedBy <https://example.com/OrgSupport> .