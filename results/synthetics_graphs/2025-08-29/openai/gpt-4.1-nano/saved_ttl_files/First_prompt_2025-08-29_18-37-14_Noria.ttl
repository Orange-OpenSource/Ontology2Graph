<https://example.com/structuralObservable2> a noria:StructuralObservable ;
  rdfs:label "Link Status Observable"@en ;
  rdfs:comment "Observable property indicating link operational status."@en ;
  rdfs:seeAlso <https://w3id.org/noria/ontology#NetworkLink> .

<https://example.com/linkStatus1> a noria:structuralElementObservable ;
  rdfs:label "Link Operational Status"@en ;
  rdfs:comment "Indicates whether the link is active or down."@en ;
  noria:structuralObservableOf <https://example.com/connection2> .

<https://example.com/event2> a noria:EventRecord ;
  rdfs:label "Link Failure Event"@en ;
  rdfs:comment "Event indicating link failure."@en ;
  noria:loggingTime "2024-03-15T10:20:00Z"^^xsd:dateTime ;
  noria:logText "Fiber Link B-C has gone down."@en ;
  noria:logOriginatingManagedObject <https://example.com/connection2> .

