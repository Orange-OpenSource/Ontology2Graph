<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity, managing multiple links."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/organization1> a org:Organization ;
  rdfs:label "Central Network Operations"@en ;
  rdfs:comment "Organization responsible for managing core network hubs."@en .

<https://example.com/highDegreeNode1> a noria:ManagedElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high degree of connections, acting as a connector."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/centralNode1> a noria:ManagedElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/connectorNode1> a noria:ManagedElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/intermediaryNode1> a noria:ManagedElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/multiplexNode1> a noria:ManagedElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/superNode1> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Super node aggregating multiple nodes."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Physical server hosting critical applications."@en ;
  noria:resourceManagedBy <https://example.com/organization1> .

<https://example.com/application1> a noria:Application ;
  rdfs:label "Application Alpha"@en ;
  rdfs:comment "Core business application."@en ;
  noria:applicationType <https://w3id.org/noria/kos/application/type#BusinessApplication> ;
  noria:resourceForApplication <https://example.com/resource1> .

<https://example.com/service1> a noria:Service ;
  rdfs:label "Service X"@en ;
  rdfs:comment "End-to-end customer-facing service."@en ;
  noria:serviceType <https://w3id.org/noria/kos/service/type#CustomerFacingService> ;
  noria:applicationRelatedService <https://example.com/application1> .

<https://example.com/connection1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber connection between HubNode1 and HighDegreeNode1."@en ;
  noria:networkLinkId "Link-AB-001" .

<https://example.com/structuralObservable1> a noria:StructuralObservable ;
  rdfs:label "Resource Status Observable"@en ;
  rdfs:comment "Observable property indicating resource operational status."@en ;
  rdfs:seeAlso <https://w3id.org/noria/ontology#Resource> .

<https://example.com/resourceStatus1> a noria:structuralElementObservable ;
  rdfs:label "Resource Operational Status"@en ;
  rdfs:comment "Indicates whether the resource is operational or not."@en ;
  noria:structuralObservableOf <https://example.com/resource1> .

<https://example.com/event1> a noria:EventRecord ;
  rdfs:label "Resource Failure Event"@en ;
  rdfs:comment "Event indicating resource failure."@en ;
  noria:loggingTime "2024-03-15T10:15:00Z"^^xsd:dateTime ;
  noria:logText "Resource Resource 1 has failed."@en ;
  noria:logOriginatingManagedObject <https://example.com/resource1> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity#Critical> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity#Major> .

<https://example.com/connector1> a noria:ManagedElement ;
  rdfs:label "Connector Node 1"@en ;
  rdfs:comment "Connects HubNode1 to HighDegreeNode1."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/intermediary1> a noria:ManagedElement ;
  rdfs:label "Intermediary Node 1"@en ;
  rdfs:comment "Acts as an intermediary in data routing."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/multiplex1> a noria:ManagedElement ;
  rdfs:label "Multiplex Node 1"@en ;
  rdfs:comment "Handles multiplexing of multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/supernode1> a noria:ManagedElement ;
  rdfs:label "Super Node 1"@en ;
  rdfs:comment "Aggregates multiple nodes for high-level management."@en ;
  noria:elementManagedBy <https://example.com/organization1> .

<https://example.com/agent1> a foaf:Agent ;
  rdfs:label "Network Engineer Alice"@en ;
  rdfs:comment "Responsible for managing resources and nodes."@en ;
  foaf:accountName "alice" .

<https://example.com/agent2> a foaf:Agent ;
  rdfs:label "Network Support Bob"@en ;
  rdfs:comment "Supports network infrastructure."@en ;
  foaf:accountName "bob" .

<https://example.com/connection2> a noria:NetworkLink ;
  rdfs:label "Fiber Link B-C"@en ;
  rdfs:comment "Connection between HighDegreeNode1 and CentralNode1."@en ;
