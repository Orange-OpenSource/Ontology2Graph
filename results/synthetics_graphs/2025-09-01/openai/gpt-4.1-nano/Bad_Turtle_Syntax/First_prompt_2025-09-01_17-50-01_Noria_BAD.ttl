@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://example.com/OrgSupportTeam> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a critical junction."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/Router1> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the topology."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:structuralObservableOf <https://example.com/SwitchA> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/segmentCount> ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:structuralObservableOf <https://example.com/Router2> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/Server1> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Highly connected super node with multiple roles."@en ;
  noria:structuralElementObservableData <https://example.com/roleCount> ;
  noria:structuralObservableOf <https://example.com/DataCenter> .

<https://example.com/Router1> a noria:StructuralElement ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router in the network."@en ;
  noria:elementDistinguishedName "Router1"@en ;
  noria:elementManagedBy <https://example.com/OrgNetworkTeam> .

<https://example.com/Router2> a noria:StructuralElement ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Edge router connecting to external network."@en ;
  noria:elementDistinguishedName "Router2"@en ;
  noria:elementManagedBy <https://example.com/OrgNetworkTeam> .

<https://example.com/SwitchA> a noria:StructuralElement ;
  rdfs:label "SwitchA"@en ;
  rdfs:comment "Distribution switch in the data center."@en ;
  noria:elementDistinguishedName "SwitchA"@en ;
  noria:elementManagedBy <https://example.com/OrgDataCenter> .

<https://example.com/Firewall1> a noria:StructuralElement ;
  rdfs:label "Firewall1"@en ;
  rdfs:comment "Firewall protecting the internal network."@en ;
  noria:elementDistinguishedName "Firewall1"@en ;
  noria:elementManagedBy <https://example.com/OrgSecurityTeam> .

<https://example.com/Server1> a noria:StructuralElement ;
  rdfs:label "Server1"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:elementDistinguishedName "Server1"@en ;
  noria:elementManagedBy <https://example.com/OrgITSupport> .

<https://example.com/DataCenter> a noria:StructuralElement ;
  rdfs:label "DataCenter"@en ;
  rdfs:comment "Main data center facility."@en ;
  noria:elementDistinguishedName "DataCenter"@en ;
  noria:elementManagedBy <https://example.com/OrgDataCenter> .

<https://example.com/connectionCount> a noria:structuralElementObservableData ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at the node."@en .

<https://example.com/trafficLoad> a noria:structuralElementObservableData ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load in Mbps."@en .

<https://example.com/segmentCount> a noria:structuralElementObservableData ;
  rdfs:label "Segment Count"@en ;
  rdfs:comment "Number of network segments connected."@en .

<https://example.com/latency> a noria:structuralElementObservableData ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency in milliseconds."@en .

<https://example.com/streamCount> a noria:structuralElementObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/roleCount> a noria:structuralElementObservableData ;
  rdfs:label "Role Count"@en ;
  rdfs:comment "Number of roles assigned to the super node."@en .

<https://example.com/OrgNetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/OrgDataCenter> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en ;
  rdfs:comment "Team managing data center resources."@en .

<https://example.com/OrgSecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for network security."@en .

<https://example.com/OrgITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Team providing IT support services."@en ;