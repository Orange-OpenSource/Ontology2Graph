# Link nodes to their respective links
<https://example.com/Router1> noria:locatedAtLocus <https://example.com/Locus1> .
<https://example.com/Router2> noria:locatedAtLocus <https://example.com/Locus2> .
<https://example.com/SwitchA> noria:locatedAtLocus <https://example.com/Locus3> .
<https://example.com/Firewall1> noria:locatedAtLocus <https://example.com/Locus4> .
<https://example.com/Server1> noria:locatedAtLocus <https://example.com/Locus5> .

<https://example.com/connectionCount> a noria:structuralObservableData ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/trafficVolume> a noria:structuralObservableData ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of network traffic."@en .

<https://example.com/connectionType> a noria:structuralObservableData ;
  rdfs:label "Connection Type"@en ;
  rdfs:comment "Type of connection (fiber, copper, wireless)."@en .

<https://example.com/latency> a noria:structuralObservableData ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency in ms."@en .

<https://example.com/streamCount> a noria:structuralObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of multiplexed streams."@en .

<https://example.com/totalTraffic> a noria:structuralObservableData ;
  rdfs:label "Total Traffic"@en ;
  rdfs:comment "Total network traffic."@en .

# Connect hub node to network management team
<https://example.com/hubNode_extra_node_1> noria:elementManagedBy <https://example.com/NetworkOperations> .

# Connect high-degree node to core router
<https://example.com/highDegreeNode> noria:structuralObservableOf <https://example.com/Router1> .

# Connect central node to switch
<https://example.com/centralNode> noria:structuralObservableOf <https://example.com/SwitchA> .

# Connect connector node to firewall
<https://example.com/connectorNode> noria:structuralObservableOf <https://example.com/Firewall1> .

# Connect intermediary node to router2
<https://example.com/intermediaryNode> noria:structuralObservableOf <https://example.com/Router2> .

# Connect multiplex node to server
<https://example.com/muxNode> noria:structuralObservableOf <https://example.com/Server1> .

# Connect super node to data center
<https://example.com/superNode> noria:structuralObservableOf <https://example.com/DataCenter> .

# Connect links to their endpoints
<https://example.com/Link1> noria:networkLinkTerminationResource <https://example.com/Router1> .
<https://example.com/Link1> noria:networkLinkTerminationResourceDestination <https://example.com/Router2> .

<https://example.com/Link2> noria:networkLinkTerminationResource <https://example.com/SwitchA> .
<https://example.com/Link2> noria:networkLinkTerminationResourceDestination <https://example.com/Firewall1> .

<https://example.com/Link3> noria:networkLinkTerminationResource <https://example.com/Router2> .
# End of graph
