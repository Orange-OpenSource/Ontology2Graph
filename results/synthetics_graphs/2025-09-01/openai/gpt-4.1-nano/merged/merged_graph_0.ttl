@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a core switch."@en ;
  noria:structuralElementObservableData 1000 ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "A central node connecting multiple network segments."@en ;
  noria:structuralElementObservableData 500 ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node acting as a firewall between segments."@en ;
  noria:structuralElementObservableData 300 ;
  noria:structuralElementObservable <https://example.com/securityObservable> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node balancing traffic between servers."@en ;
  noria:structuralElementObservableData 200 ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData 150 ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes."@en ;
  noria:structuralElementObservableData 2000 ;
  noria:elementManagedBy <https://example.com/NetworkManagementTeam_extra_node_2> .

<https://example.com/NetworkOperationsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/SecurityTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for network security."@en .

<https://example.com/ITSupportTeam>
  a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing technical support for network devices."@en .

<https://example.com/latencyObservable>
  a noria:StructuralObservable ;
  rdfs:label "Latency Observable"@en ;
  rdfs:comment "Observable measuring network latency in milliseconds."@en .

<https://example.com/securityObservable>
  a noria:StructuralObservable ;
  rdfs:label "Security Observable"@en ;
  rdfs:comment "Observable indicating security status levels."@en .

<https://example.com/connection1>
  a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link connecting HubNode and DataCenterSwitch."@en ;
  noria:networkLinkId "Link-001" ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/connection2>
  a noria:NetworkLink ;
  rdfs:label "Ethernet Link B-C"@en ;
  rdfs:comment "Ethernet connection between DataCenterSwitch and CentralRouter."@en ;
  noria:networkLinkId "Link-002" ;
  noria:networkLinkType "Ethernet" .

<https://example.com/connection3>
  a noria:NetworkLink ;
  rdfs:label "Firewall Connection"@en ;
  rdfs:comment "Connection from Firewall to LoadBalancer."@en ;
  noria:networkLinkId "Link-003" ;
  noria:networkLinkType "Virtual" .

<https://example.com/HubNode>
  a noria:StructuralElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/DataCenterSwitch>
  a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "High-degree switch in data center core."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/CentralRouter>
  a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "Router acting as a central point in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/Firewall>
  a noria:StructuralElement ;
  rdfs:label "Firewall"@en ;
  rdfs:comment "Firewall node controlling access."@en ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/LoadBalancer>
  a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Distributes traffic among servers."@en ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/MultiplexSwitch>
  a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "Switch combining multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/SuperNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple hubs and high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkManagementTeam_extra_node_2> .

<https://example.com/NetworkManagementTeam_extra_node_2>
  a org:OrganizationalUnit ;
  rdfs:label "Network Management Team"@en ;
  rdfs:comment "Team overseeing network infrastructure."@en .

<https://example.com/NetworkSecurityTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Security Team"@en ;
  rdfs:comment "Team responsible for security."@en .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode1>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A switch with many connections acting as a high-degree node."@en ;
  noria:structuralElementObservableData <https://example.com/latencyData> ;
  noria:structuralObservableOf <https://example.com/NetworkSwitch1> .

<https://example.com/NetworkSwitch1>
  a noria:StructuralElement ;
  rdfs:label "Core Switch 1"@en ;
  rdfs:comment "A core network switch serving as a central connector."@en ;
  noria:elementDistinguishedName "CoreSwitch1" .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "A router acting as a central node in the network."@en ;
  noria:elementDistinguishedName "CentralRouter" ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:structuralObservableOf <https://example.com/LinkA> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary device facilitating communication."@en ;
  noria:elementDistinguishedName "IntermediaryNode1" ;
  noria:elementManagedBy <https://example.com/NetworkSupportTeam> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:elementDistinguishedName "SuperNodeX" ;
  noria:elementManagedBy <https://example.com/NetworkManagementTeam_extra_node_1> .

<https://example.com/NetworkOperationsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/NetworkSupportTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team providing support for network devices."@en .

<https://example.com/latencyData>
  a noria:StructuralObservable ;
  rdfs:label "Latency Data"@en ;
  rdfs:comment "Latency measurements for network links."@en .

<https://example.com/trafficLoad>
  a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load on the node."@en .

<https://example.com/streamCount>
  a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams handled by the multiplex node."@en .

<https://example.com/LinkA>
  a noria:NetworkLink ;
  rdfs:label "Link A"@en ;
  rdfs:comment "A network link connecting nodes."@en ;
  noria:networkLinkId "LinkA" .

<https://example.com/NetworkManagementTeam_extra_node_1>
  a org:OrganizationalUnit ;
  rdfs:label "Network Management Team"@en ;
  rdfs:comment "Team managing network infrastructure."@en .

<https://example.com/hubNode_extra_node_1> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/Router1> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node with moderate degree, serving as a key point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/SwitchA> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionType> ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow between hubs."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:structuralObservableOf <https://example.com/Router2> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/Server1> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/totalTraffic> ;
  noria:structuralObservableOf <https://example.com/DataCenter> .

<https://example.com/Router1> a noria:StructuralElement ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router connecting multiple network segments."@en ;
  noria:elementDistinguishedName "Router1-Core" .

<https://example.com/SwitchA> a noria:StructuralElement ;
  rdfs:label "SwitchA"@en ;
  rdfs:comment "Distribution switch in the main data center."@en ;
  noria:elementDistinguishedName "SwitchA-DC" .

<https://example.com/Firewall1> a noria:StructuralElement ;
  rdfs:label "Firewall1"@en ;
  rdfs:comment "Firewall protecting the internal network."@en ;
  noria:elementDistinguishedName "Firewall-Internal" .

<https://example.com/Router2> a noria:StructuralElement ;
  rdfs:label "Router2"@en ;
