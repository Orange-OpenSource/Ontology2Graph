@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode>
  a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a core switch."@en ;
  noria:structuralElementObservableData 1000 ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "A central node connecting multiple network segments."@en ;
  noria:structuralElementObservableData 500 ;
  noria:structuralElementObservable <https://example.com/latencyObservable> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node acting as a firewall between segments."@en ;
  noria:structuralElementObservableData 300 ;
  noria:structuralElementObservable <https://example.com/securityObservable> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node balancing traffic between servers."@en ;
  noria:structuralElementObservableData 200 ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData 150 ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes."@en ;
  noria:structuralElementObservableData 2000 ;
  noria:elementManagedBy <https://example.com/NetworkManagementTeam> .

<https://example.com/NetworkOperationsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/SecurityTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for network security."@en .

<https://example.com/ITSupportTeam>
  a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing technical support for network devices."@en .

<https://example.com/latencyObservable>
  a noria:StructuralObservable ;
  rdfs:label "Latency Observable"@en ;
  rdfs:comment "Observable measuring network latency in milliseconds."@en .

<https://example.com/securityObservable>
  a noria:StructuralObservable ;
  rdfs:label "Security Observable"@en ;
  rdfs:comment "Observable indicating security status levels."@en .

<https://example.com/connection1>
  a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link connecting HubNode and DataCenterSwitch."@en ;
  noria:networkLinkId "Link-001" ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/connection2>
  a noria:NetworkLink ;
  rdfs:label "Ethernet Link B-C"@en ;
  rdfs:comment "Ethernet connection between DataCenterSwitch and CentralRouter."@en ;
  noria:networkLinkId "Link-002" ;
  noria:networkLinkType "Ethernet" .

<https://example.com/connection3>
  a noria:NetworkLink ;
  rdfs:label "Firewall Connection"@en ;
  rdfs:comment "Connection from Firewall to LoadBalancer."@en ;
  noria:networkLinkId "Link-003" ;
  noria:networkLinkType "Virtual" .

<https://example.com/HubNode>
  a noria:StructuralElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/DataCenterSwitch>
  a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "High-degree switch in data center core."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/CentralRouter>
  a noria:StructuralElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "Router acting as a central point in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/Firewall>
  a noria:StructuralElement ;
  rdfs:label "Firewall"@en ;
  rdfs:comment "Firewall node controlling access."@en ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/LoadBalancer>
  a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Distributes traffic among servers."@en ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/MultiplexSwitch>
  a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "Switch combining multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/SuperNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple hubs and high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkManagementTeam> .

<https://example.com/NetworkManagementTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Management Team"@en ;
  rdfs:comment "Team overseeing network infrastructure."@en .

<https://example.com/NetworkSecurityTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Security Team"@en ;
  rdfs:comment "Team responsible for security."@en .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/Router1> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node with moderate degree, serving as a key point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/SwitchA> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionType> ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow between hubs."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:structuralObservableOf <https://example.com/Router2> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/Server1> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/totalTraffic> ;
  noria:structuralObservableOf <https://example.com/DataCenter> .

<https://example.com/Router1> a noria:StructuralElement ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router connecting multiple network segments."@en ;
  noria:elementDistinguishedName "Router1-Core" .

<https://example.com/SwitchA> a noria:StructuralElement ;
  rdfs:label "SwitchA"@en ;
  rdfs:comment "Distribution switch in the main data center."@en ;
  noria:elementDistinguishedName "SwitchA-DC" .

<https://example.com/Firewall1> a noria:StructuralElement ;
  rdfs:label "Firewall1"@en ;
  rdfs:comment "Firewall protecting the internal network."@en ;
  noria:elementDistinguishedName "Firewall-Internal" .

<https://example.com/Router2> a noria:StructuralElement ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Edge router connecting to external network."@en ;
  noria:elementDistinguishedName "Router2-Edge" .

<https://example.com/Server1> a noria:StructuralElement ;
  rdfs:label "Server1"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:elementDistinguishedName "Server1-App" .

<https://example.com/DataCenter> a noria:StructuralElement ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "Primary data center housing core network infrastructure."@en ;
  noria:elementDistinguishedName "DataCenter-Main" .

<https://example.com/connectionCount> a noria:structuralObservableData ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at the node."@en .

<https://example.com/trafficVolume> a noria:structuralObservableData ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of traffic passing through the node."@en .

<https://example.com/connectionType> a noria:structuralObservableData ;
  rdfs:label "Connection Type"@en ;
  rdfs:comment "Type of connection (fiber, copper, wireless)."@en .

<https://example.com/latency> a noria:structuralObservableData ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency in milliseconds."@en .

<https://example.com/streamCount> a noria:structuralObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/totalTraffic> a noria:structuralObservableData ;
  rdfs:label "Total Traffic"@en ;
  rdfs:comment "Aggregated traffic in the data center."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Support team for network infrastructure."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Lead network administrator responsible for core network."@en .

<https://example.com/SupportEngineer> a foaf:Agent ;
  rdfs:label "Support Engineer"@en ;
  rdfs:comment "Engineer providing support for network devices."@en .

<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with many connections, acting as a critical connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/Router1> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Moderately connected node serving as a key point."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/SwitchA> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node acting as a connector between segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionType> ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Facilitates data flow between hubs."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:structuralObservableOf <https://example.com/Router2> .

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Handles multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/Server1> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Aggregates multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/totalTraffic> ;
  noria:structuralObservableOf <https://example.com/DataCenter> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between Router1 and Router2."@en ;
  noria:networkLinkId "NL-001" .

<https://example.com/Link2> a noria:NetworkLink ;
  rdfs:label "Link2"@en ;
  rdfs:comment "Connection between SwitchA and Firewall1."@en ;
  noria:networkLinkId "NL-002" .

<https://example.com/Link3> a noria:NetworkLink ;
  rdfs:label "Link3"@en ;
  rdfs:comment "Connection from Router2 to external network."@en ;
  noria:networkLinkId "NL-003" .

<https://example.com/Router1> a noria:StructuralElement ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router in the network."@en ;
  noria:elementDistinguishedName "Router1-Core" .

<https://example.com/Router2> a noria:StructuralElement ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Edge router connecting to external network."@en ;
  noria:elementDistinguishedName "Router2-Edge" .

<https://example.com/SwitchA> a noria:StructuralElement ;
  rdfs:label "SwitchA"@en ;
  rdfs:comment "Distribution switch in data center."@en ;
  noria:elementDistinguishedName "SwitchA-DC" .

<https://example.com/Firewall1> a noria:StructuralElement ;
  rdfs:label "Firewall1"@en ;
  rdfs:comment "Firewall protecting internal network."@en ;
  noria:elementDistinguishedName "Firewall-Internal" .

<https://example.com/Server1> a noria:StructuralElement ;
  rdfs:label "Server1"@en ;
  rdfs:comment "Application server."@en ;
  noria:elementDistinguishedName "Server1-App" .

<https://example.com/DataCenter> a noria:StructuralElement ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "Primary data center."@en ;
  noria:elementDistinguishedName "DataCenter-Main" .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team managing network infrastructure."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Support team for network devices."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Lead network admin."@en .

<https://example.com/SupportEngineer> a foaf:Agent ;
  rdfs:label "Support Engineer"@en ;
  rdfs:comment "Engineer providing support."@en .

# Link nodes to their respective links
<https://example.com/Router1> noria:locatedAtLocus <https://example.com/Locus1> .
<https://example.com/Router2> noria:locatedAtLocus <https://example.com/Locus2> .
<https://example.com/SwitchA> noria:locatedAtLocus <https://example.com/Locus3> .
<https://example.com/Firewall1> noria:locatedAtLocus <https://example.com/Locus4> .
<https://example.com/Server1> noria:locatedAtLocus <https://example.com/Locus5> .

<https://example.com/connectionCount> a noria:structuralObservableData ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/trafficVolume> a noria:structuralObservableData ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of network traffic."@en .

<https://example.com/connectionType> a noria:structuralObservableData ;
  rdfs:label "Connection Type"@en ;
  rdfs:comment "Type of connection (fiber, copper, wireless)."@en .

<https://example.com/latency> a noria:structuralObservableData ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency in ms."@en .

<https://example.com/streamCount> a noria:structuralObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of multiplexed streams."@en .

<https://example.com/totalTraffic> a noria:structuralObservableData ;
  rdfs:label "Total Traffic"@en ;
  rdfs:comment "Total network traffic."@en .

# Connect hub node to network management team
<https://example.com/hubNode> noria:elementManagedBy <https://example.com/NetworkOperations> .

# Connect high-degree node to core router
<https://example.com/highDegreeNode> noria:structuralObservableOf <https://example.com/Router1> .

# Connect central node to switch
<https://example.com/centralNode> noria:structuralObservableOf <https://example.com/SwitchA> .

# Connect connector node to firewall
<https://example.com/connectorNode> noria:structuralObservableOf <https://example.com/Firewall1> .

# Connect intermediary node to router2
<https://example.com/intermediaryNode> noria:structuralObservableOf <https://example.com/Router2> .

# Connect multiplex node to server
<https://example.com/muxNode> noria:structuralObservableOf <https://example.com/Server1> .

# Connect super node to data center
<https://example.com/superNode> noria:structuralObservableOf <https://example.com/DataCenter> .

# Connect links to their endpoints
<https://example.com/Link1> noria:networkLinkTerminationResource <https://example.com/Router1> .
<https://example.com/Link1> noria:networkLinkTerminationResourceDestination <https://example.com/Router2> .

<https://example.com/Link2> noria:networkLinkTerminationResource <https://example.com/SwitchA> .
<https://example.com/Link2> noria:networkLinkTerminationResourceDestination <https://example.com/Firewall1> .

<https://example.com/Link3> noria:networkLinkTerminationResource <https://example.com/Router2> .
# End of graph
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Entity1> a noria:ManagedElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A high-capacity core router in the backbone network."@en ;
  noria:elementDistinguishedName "CoreRouter-01" ;
  noria:elementManagedBy <https://w3id.org/noria/instance/Org1> ;
  noria:structuralElementObservable [ a noria:structuralObservableOf ;
    noria:structuralObservableOf <https://w3id.org/noria/instance/Entity1> ;
    noria:structuralElementObservableData "Operational status: Active"^^xsd:string
  ] ;
  rdfs:seeAlso <https://w3id.org/noria/doc/Entity1> .

<https://w3id.org/noria/instance/Entity2> a noria:StructuralElement ;
  rdfs:label "Edge Switch"@en ;
  rdfs:comment "An edge switch connecting access points to the core network."@en ;
  noria:structuralElementDistinguishedName "EdgeSwitch-Alpha" ;
  noria:structuralElementObservable [ a noria:structuralObservableOf ;
    noria:structuralObservableOf <https://w3id.org/noria/instance/Entity2> ;
    noria:structuralElementObservableData "Operational status: Up"^^xsd:string
  ] ;
  rdfs:seeAlso <https://w3id.org/noria/doc/Entity2> .

<https://w3id.org/noria/instance/Entity3> a noria:Resource ;
  rdfs:label "Server Rack 12"@en ;
  rdfs:comment "Rack containing multiple servers in Data Center 3."@en ;
  noria:resourceLogisticId "Rack12-DC3" ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:resourceHostName "rack12-dc3" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/type/serverRack> ] ;
  noria:resourceProductModel [ a noria:ProductModel ; rdfs:label "Dell PowerEdge R740"^^xsd:string ] ;
  noria:resourceSerialNumber "SN123456789" ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <https://w3id.org/noria/kos/resource/lifecycle/operational> ] ;
  rdfs:seeAlso <https://w3id.org/noria/doc/Entity3> .

<https://w3id.org/noria/instance/Org1> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for network infrastructure management."@en .

<https://w3id.org/noria/instance/Link1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between Data Center A and B."@en ;
  noria:networkLinkId "Link-AB-001" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical fiber"^^xsd:string ;
  noria:networkLinkTerminationResourceOrigin <https://w3id.org/noria/instance/Entity1> ;
  noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/instance/Entity4> .

<https://w3id.org/noria/instance/Entity4> a noria:Resource ;
  rdfs:label "Data Center B"@en ;
  rdfs:comment "Secondary data center in the regional network."@en ;
  noria:siteId "DCB-Region1" ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus2> .

<https://w3id.org/noria/instance/Locus1> a noria:Locus ;
  rdfs:label "Room 314"@en ;
  rdfs:comment "Main server room in Building 1."@en ;
  noria:locusLine "Line:L, Column:6"^^xsd:string ;
  noria:locusRow "Row:3"^^xsd:string .

<https://w3id.org/noria/instance/Locus2> a noria:Locus ;
  rdfs:label "Room 101"@en ;
  rdfs:comment "Backup server room in Building 2."@en ;
  noria:locusLine "Line:L, Column:1"^^xsd:string ;
  noria:locusRow "Row:1"^^xsd:string .

<https://w3id.org/noria/instance/Entity5> a noria:Application ;
  rdfs:label "Customer Portal"@en ;
  rdfs:comment "Web application for customer interactions."@en ;
  noria:applicationModelIdentifier "CP-Model-2023"^^xsd:string ;
  noria:applicationNumericalIdentifier 101 ;
  noria:applicationShortIdentifier "CustPortal"^^xsd:string ;
  noria:applicationType [ a skos:Concept ; skos:inScheme <kos/application/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/application/type/webApp> ] ;
