@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode_extra_node_3> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical connector."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/Router1> .

<https://example.com/centralNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node with moderate degree, serving as a key point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/SwitchA> .

<https://example.com/connectorNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node acting as a connector between different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionType> ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/intermediaryNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow between hubs."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:structuralObservableOf <https://example.com/Router2> .

<https://example.com/multiplexNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount_extra_node_3> ;
  noria:structuralObservableOf <https://example.com/Server1> .

<https://example.com/superNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/totalTraffic> ;
  noria:structuralObservableOf <https://example.com/DataCenter> .

<https://example.com/Router1> a noria:StructuralElement ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router connecting multiple network segments."@en ;
  noria:elementDistinguishedName "Router1-Core" .

<https://example.com/SwitchA> a noria:StructuralElement ;
  rdfs:label "SwitchA"@en ;
  rdfs:comment "Distribution switch in the main data center."@en ;
  noria:elementDistinguishedName "SwitchA-DC" .

<https://example.com/Firewall1> a noria:StructuralElement ;
  rdfs:label "Firewall1"@en ;
  rdfs:comment "Firewall protecting the internal network."@en ;
  noria:elementDistinguishedName "Firewall-Internal" .

<https://example.com/Router2> a noria:StructuralElement ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Edge router connecting to external network."@en ;
  noria:elementDistinguishedName "Router2-Edge" .

<https://example.com/Server1> a noria:StructuralElement ;
  rdfs:label "Server1"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:elementDistinguishedName "Server1-App" .

<https://example.com/DataCenter> a noria:StructuralElement ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "Primary data center housing core network infrastructure."@en ;
  noria:elementDistinguishedName "DataCenter-Main" .

<https://example.com/connectionCount> a noria:structuralObservableData ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at the node."@en .

<https://example.com/trafficVolume> a noria:structuralObservableData ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of traffic passing through the node."@en .

<https://example.com/connectionType> a noria:structuralObservableData ;
  rdfs:label "Connection Type"@en ;
  rdfs:comment "Type of connection (fiber, copper, wireless)."@en .

<https://example.com/latency> a noria:structuralObservableData ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency in milliseconds."@en .

<https://example.com/streamCount_extra_node_3> a noria:structuralObservableData ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/totalTraffic> a noria:structuralObservableData ;
  rdfs:label "Total Traffic"@en ;
  rdfs:comment "Aggregated traffic in the data center."@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Support team for network infrastructure."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Lead network administrator responsible for core network."@en .

<https://example.com/SupportEngineer> a foaf:Agent ;
  rdfs:label "Support Engineer"@en ;
  rdfs:comment "Engineer providing support for network devices."@en .

<https://example.com/HubNode_extra_node_3> a noria:ManagedElement ;
  rdfs:comment "Central hub node with high connectivity."@en ;

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:comment "Node with many connections, acting as a critical connector."@en ;

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:comment "Moderately connected node serving as a key point."@en ;

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:comment "Node acting as a connector between segments."@en ;

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:comment "Facilitates data flow between hubs."@en ;

<https://example.com/MuxNode> a noria:StructuralElement ;
  rdfs:comment "Handles multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount_extra_node_3> ;

<https://example.com/SuperNode_extra_node_3> a noria:StructuralElement ;
  rdfs:comment "Aggregates multiple hubs and central nodes."@en ;

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between Router1 and Router2."@en ;
  noria:networkLinkId "NL-001" .

<https://example.com/Link2> a noria:NetworkLink ;
  rdfs:label "Link2"@en ;
  rdfs:comment "Connection between SwitchA and Firewall1."@en ;
  noria:networkLinkId "NL-002" .

<https://example.com/Link3> a noria:NetworkLink ;
  rdfs:label "Link3"@en ;
  rdfs:comment "Connection from Router2 to external network."@en ;
  noria:networkLinkId "NL-003" .

  rdfs:comment "Core router in the network."@en ;


  rdfs:comment "Distribution switch in data center."@en ;

  rdfs:comment "Firewall protecting internal network."@en ;

  rdfs:comment "Application server."@en ;

  rdfs:comment "Primary data center."@en ;

  rdfs:comment "Team managing network infrastructure."@en .

  rdfs:comment "Support team for network devices."@en .

  rdfs:comment "Lead network admin."@en .

  rdfs:comment "Engineer providing support."@en .

# Link nodes to their respective links
<https://example.com/Router1> noria:locatedAtLocus <https://example.com/Locus1> .
<https://example.com/Router2> noria:locatedAtLocus <https://example.com/Locus2> .
<https://example.com/SwitchA> noria:locatedAtLocus <https://example.com/Locus3> .
<https://example.com/Firewall1> noria:locatedAtLocus <https://example.com/Locus4> .
<https://example.com/Server1> noria:locatedAtLocus <https://example.com/Locus5> .

  rdfs:comment "Number of active connections."@en .

  rdfs:comment "Volume of network traffic."@en .


  rdfs:comment "Network latency in ms."@en .

<https://example.com/streamCount_extra_node_3> a noria:structuralObservableData ;
  rdfs:comment "Number of multiplexed streams."@en .

  rdfs:comment "Total network traffic."@en .

# Connect hub node to network management team
<https://example.com/hubNode_extra_node_3> noria:elementManagedBy <https://example.com/NetworkOperations> .

# Connect high-degree node to core router
<https://example.com/highDegreeNode_extra_node_3> noria:structuralObservableOf <https://example.com/Router1> .

# Connect central node to switch
<https://example.com/centralNode_extra_node_3> noria:structuralObservableOf <https://example.com/SwitchA> .

# Connect connector node to firewall
<https://example.com/connectorNode_extra_node_3> noria:structuralObservableOf <https://example.com/Firewall1> .

# Connect intermediary node to router2
<https://example.com/intermediaryNode_extra_node_3> noria:structuralObservableOf <https://example.com/Router2> .

# Connect multiplex node to server
<https://example.com/muxNode> noria:structuralObservableOf <https://example.com/Server1> .

# Connect super node to data center
<https://example.com/superNode_extra_node_3> noria:structuralObservableOf <https://example.com/DataCenter> .

# Connect links to their endpoints
<https://example.com/Link1> noria:networkLinkTerminationResource <https://example.com/Router1> .
<https://example.com/Link1> noria:networkLinkTerminationResourceDestination <https://example.com/Router2> .

<https://example.com/Link2> noria:networkLinkTerminationResource <https://example.com/SwitchA> .
<https://example.com/Link2> noria:networkLinkTerminationResourceDestination <https://example.com/Firewall1> .

<https://example.com/Link3> noria:networkLinkTerminationResource <https://example.com/Router2> .
# End of graph