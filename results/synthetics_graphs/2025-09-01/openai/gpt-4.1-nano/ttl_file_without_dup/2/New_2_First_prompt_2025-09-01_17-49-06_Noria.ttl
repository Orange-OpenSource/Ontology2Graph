  noria:operationPlanPostCondition <https://w3id.org/noria/instance/ActionPostCond1> .

<https://w3id.org/noria/instance/ActionPreCond1> a noria:ActionPreCondition ;
  rdfs:label "Check Fiber Link Status"@en ;
  rdfs:comment "Verify if the fiber link is down before attempting repair."@en .

<https://w3id.org/noria/instance/ActionPostCond1> a noria:ActionPostCondition ;
  rdfs:label "Verify Link Restoration"@en ;
  rdfs:comment "Ensure the fiber link is operational after repair."@en .

<https://w3id.org/noria/instance/ChangeReq1> a noria:ChangeRequest ;
  rdfs:label "Change Request for Fiber Repair"@en ;
  rdfs:comment "Request to repair fiber link fiber between Data Center A and B."@en ;
  noria:changeRequestCategory [ a skos:Concept ; skos:inScheme <kos/ChangeRequest/category> ; skos:hasTopConcept <https://w3id.org/noria/kos/change/category/maintenance> ] ;
  noria:changeRequestType [ a skos:Concept ; skos:inScheme <kos/ChangeRequest/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/change/type/maintenance> ] ;
  noria:changeRequestImpact <https://w3id.org/noria/instance/Entity4> ;
  noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
  noria:changeRequestStatusCurrent [ a skos:Concept ; skos:inScheme <kos/ChangeRequest/status> ; skos:hasTopConcept <https://w3id.org/noria/kos/change/status/planned> ] ;
  noria:changeRequestInitiatorParty <https://w3id.org/noria/instance/Org1> ;
  noria:changeRequestActorParty <https://w3id.org/noria/instance/Engineer1> .

<https://w3id.org/noria/instance/Engineer1> a foaf:Agent ;
  rdfs:label "Network Engineer Alice"@en ;
  rdfs:comment "Engineer responsible for fiber link repair."@en .

