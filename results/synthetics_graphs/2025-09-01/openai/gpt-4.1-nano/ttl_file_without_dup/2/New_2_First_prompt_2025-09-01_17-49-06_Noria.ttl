  noria:alarmProposedRepairAction <https://w3id.org/noria/instance/Action1> .

<https://w3id.org/noria/instance/MonitoringSystem> a noria:Application ;
  rdfs:label "Network Monitoring System"@en ;
  rdfs:comment "System monitoring network links and resources."@en .

