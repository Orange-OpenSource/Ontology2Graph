<https://w3id.org/noria/instance/Ticket1> a noria:TroubleTicket ;
  rdfs:label "Ticket #12345"@en ;
  rdfs:comment "Network outage affecting customer portal."@en ;
  noria:troubleTicketSeverity [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; skos:hasTopConcept <https://w3id.org/noria/kos/severity/major> ] ;
