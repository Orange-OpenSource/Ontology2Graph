  noria:troubleTicketImpacts <https://w3id.org/noria/instance/Entity5> .

<https://w3id.org/noria/instance/Event1> a noria:EventRecord ;
  rdfs:label "Network Outage Event"@en ;
  rdfs:comment "Detected network outage affecting customer portal."@en ;
  noria:loggingTime "2023-10-01T14:30:00"^^xsd:dateTime ;
  noria:logText "Network link fiber between Data Center A and B is down."^^xsd:string ;
  noria:logOriginatingManagedObject <https://w3id.org/noria/instance/Link1> ;
  noria:logOriginatingManagementSystem <https://w3id.org/noria/instance/MonitoringSystem> ;
