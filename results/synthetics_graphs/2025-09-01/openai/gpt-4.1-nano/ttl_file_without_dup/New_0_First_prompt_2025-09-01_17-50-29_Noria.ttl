@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode_extra_node_2>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam_extra_node_2> .

<https://example.com/highDegreeNode1>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A switch with many connections acting as a high-degree node."@en ;
  noria:structuralElementObservableData <https://example.com/latencyData> ;
  noria:structuralObservableOf <https://example.com/NetworkSwitch1> .

<https://example.com/NetworkSwitch1>
  rdfs:label "Core Switch 1"@en ;
  rdfs:comment "A core network switch serving as a central connector."@en ;
  noria:elementDistinguishedName "CoreSwitch1" .

<https://example.com/centralNode_extra_node_2>
  rdfs:label "Central Router"@en ;
  rdfs:comment "A router acting as a central node in the network."@en ;
  noria:elementDistinguishedName "CentralRouter" ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam_extra_node_2> .

<https://example.com/connectorNode_extra_node_2>
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:structuralObservableOf <https://example.com/LinkA> .

<https://example.com/intermediaryNode_extra_node_2>
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary device facilitating communication."@en ;
  noria:elementDistinguishedName "IntermediaryNode1" ;
  noria:elementManagedBy <https://example.com/NetworkSupportTeam> .

<https://example.com/multiplexNode_extra_node_2>
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount_extra_node_2> .

<https://example.com/superNode_extra_node_2>
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:elementDistinguishedName "SuperNodeX" ;
  noria:elementManagedBy <https://example.com/NetworkManagementTeam_extra_node_2> .

<https://example.com/NetworkOperationsTeam_extra_node_2>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/NetworkSupportTeam>
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team providing support for network devices."@en .

<https://example.com/latencyData>
  a noria:StructuralObservable ;
  rdfs:label "Latency Data"@en ;
  rdfs:comment "Latency measurements for network links."@en .

<https://example.com/trafficLoad>
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load on the node."@en .

<https://example.com/streamCount_extra_node_2>
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams handled by the multiplex node."@en .

<https://example.com/LinkA>
  a noria:NetworkLink ;
  rdfs:label "Link A"@en ;
  rdfs:comment "A network link connecting nodes."@en ;
  noria:networkLinkId "LinkA" .

<https://example.com/NetworkManagementTeam_extra_node_2>
  rdfs:label "Network Management Team"@en ;
  rdfs:comment "Team managing network infrastructure."@en .