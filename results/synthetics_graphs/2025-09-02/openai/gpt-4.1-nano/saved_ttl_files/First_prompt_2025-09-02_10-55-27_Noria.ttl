  rdfs:comment "A critical server in the data center."@en ;
  noria:resourceSerialNumber "SRV-42-XYZ" ;
  noria:locatedAtLocus <https://example.com/locus/Server42Location> .

<https://example.com/Resource/RouterA> a noria:Resource ;
  rdfs:label "RouterA"@en ;
  rdfs:comment "Main router connecting internal network segments."@en ;
  noria:resourceSerialNumber "RT-AX-2023" ;
  noria:locatedAtLocus <https://example.com/locus/RouterALocation> .

<https://example.com/locus/Server42Location> a noria:Locus ;
