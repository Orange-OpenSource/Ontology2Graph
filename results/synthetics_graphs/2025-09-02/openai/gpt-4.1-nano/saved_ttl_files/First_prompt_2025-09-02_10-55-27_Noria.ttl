@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A central hub node with high connectivity, managing multiple links."@en ;
  noria:elementManagedBy <https://example.com/organization/opsTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a critical point in the network."@en ;
  noria:structuralElementObservableData <https://example.com/observable/trafficLoad> ;
  noria:structuralObservableOf <https://example.com/Resource/Server42> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A central node linking multiple subsystems, facilitating data flow."@en ;
  noria:structuralElementObservable <https://example.com/observable/status> ;
  noria:structuralElementDistinguishedName "CN-Server-01" .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/observable/connectionQuality> ;
  noria:structuralObservableOf <https://example.com/Resource/RouterA> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating communication between primary nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable/latency> ;
  noria:structuralElementDistinguishedName "INT-Node-07" .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/observable/streamCount> ;
  noria:structuralObservableOf <https://example.com/Resource/Server99> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node aggregating several subsystems."@en ;
  noria:structuralElementObservable <https://example.com/observable/systemHealth> ;
  noria:structuralElementDistinguishedName "SN-Global" .

<https://example.com/Resource/Server42> a noria:Resource ;
  rdfs:label "Server42"@en ;
  rdfs:comment "A critical server in the data center."@en ;
  noria:resourceLogisticId "SRV-42-XYZ" ;
  noria:locatedAtLocus <https://example.com/locus/Server42Location> .

<https://example.com/Resource/RouterA> a noria:Resource ;
  rdfs:label "RouterA"@en ;
  rdfs:comment "Main router connecting internal network segments."@en ;
  noria:resourceSerialNumber "RT-AX-2023" ;
  noria:locatedAtLocus <https://example.com/locus/RouterALocation> .

<https://example.com/locus/Server42Location> a noria:Locus ;
  rdfs:label "Server42 Location"@en ;
  rdfs:comment "Data center rack 3, row 5, position 12."@en ;
  noria:locusLine "Line:5" ;
  noria:locusRow "Row:3" .

<https://example.com/locus/RouterALocation> a noria:Locus ;
  rdfs:label "RouterA Location"@en ;
  rdfs:comment "Main corridor, rack 7."@en ;
  noria:locusLine "Line:7" ;
  noria:locusRow "Row:1" .

<https://example.com/organization/opsTeam> a org:OrganizationalUnit ;
  rdfs:label "Operations Team"@en ;
  rdfs:comment "Network operations team responsible for managing core infrastructure."@en .

<https://example.com/observable/trafficLoad> a noria:Property ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load in Mbps."@en .

<https://example.com/observable/status> a noria:Property ;
  rdfs:label "Status"@en ;
  rdfs:comment "Operational status of the node (e.g., active, degraded)."@en .

<https://example.com/observable/connectionQuality> a noria:Property ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Quality metric of the network connection (e.g., good, poor)."@en .

<https://example.com/observable/latency> a noria:Property ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency in milliseconds."@en .

<https://example.com/observable/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/observable/systemHealth> a noria:Property ;
  rdfs:label "System Health"@en ;
  rdfs:comment "Overall health status of the system (e.g., healthy, warning, critical)."@en .

<https://example.com/Resource/Server99> a noria:Resource ;
  rdfs:label "Server99"@en ;
  rdfs:comment "Backup server for critical applications."@en ;
  noria:resourceLogisticId "SRV-99-ABC" ;
  noria:locatedAtLocus <https://example.com/locus/Server99Location> .

<https://example.com/locus/Server99Location> a noria:Locus ;
  rdfs:label "Server99 Location"@en ;
  rdfs:comment "Data center rack 4, row 2, position 8."@en ;
  noria:locusLine "Line:2" ;
  noria:locusRow "Row:4" .

<https://example.com/Resource/Server99> a noria:Resource ;
  rdfs:label "Server99"@en ;
  rdfs:comment "Backup server for critical applications."@en ;
  noria:resourceSerialNumber "SRV-99-XYZ" ;
  noria:locatedAtLocus <https://example.com/locus/Server99Location> .

