@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/noria/instance/Network1> a noria:ManagedElement ;
  rdfs:label "Core Network Switch"@en ;
  rdfs:comment "A high-performance core switch in the network backbone."@en ;
  noria:elementManagedBy <https://w3id.org/noria/instance/OrgSupportTeam> ;
  noria:structuralElementDistinguishedName "Switch-Backbone-01" ;
  noria:resourceSerialNumber "SN123456789" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkSwitch> ;
  noria:resourceLogisticId "LOG-NS-001" ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus1> ;
  noria:resourceHostName "core-switch-01" .

<https://w3id.org/noria/instance/Resource2> a noria:Resource ;
  rdfs:label "Web Server 2"@en ;
  rdfs:comment "A virtual web server hosting customer applications."@en ;
  noria:elementManagedBy <https://w3id.org/noria/instance/OrgITTeam> ;
  noria:resourceSerialNumber "SN987654321" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualServer> ;
  noria:resourceLogisticId "LOG-VS-002" ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/Locus2> ;
  noria:resourceHostName "websrv2.company.com" ;
  noria:resourceProductModel <https://w3id.org/noria/instance/ModelVMware> .

<https://w3id.org/noria/instance/Locus1> a noria:Locus ;
  rdfs:label "Server Room 314, Rack 5"@en ;
  noria:locusLine "Line:L, Column:6" ;
  noria:locusRow "Row:3" .

<https://w3id.org/noria/instance/Locus2> a noria:Locus ;
  rdfs:label "Data Center A, Rack 12"@en ;
  noria:locusLine "Line:L, Column:12" ;
  noria:locusRow "Row:1" .

<https://w3id.org/noria/instance/OrgSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team responsible for network infrastructure."@en .

<https://w3id.org/noria/instance/OrgITTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Operations Team"@en ;
  rdfs:comment "Team managing IT resources including servers and virtual machines."@en .

<https://w3id.org/noria/instance/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link Paris-Papeete"@en ;
  rdfs:comment "Optical fiber link connecting Paris data center to Papeete."@en ;
  noria:networkLinkId "NL-Paris-Papeete-01" ;
  noria:networkLinkType "Optical fiber" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://w3id.org/noria/instance/ResourceParis> ;
  noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/instance/ResourcePapeete> .

<https://w3id.org/noria/instance/ResourceParis> a noria:Resource ;
  rdfs:label "Paris Data Center"@en ;
  rdfs:comment "Main data center located in Paris."@en ;
  noria:resourceSerialNumber "SNDC-Paris-001" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/DataCenter> ;
  noria:resourceLogisticId "LOG-DC-Paris" ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/LocusParis> .

<https://w3id.org/noria/instance/ResourcePapeete> a noria:Resource ;
  rdfs:label "Papeete Data Center"@en ;
  rdfs:comment "Data center located in Papeete."@en ;
  noria:resourceSerialNumber "SNDC-Papeete-001" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/DataCenter> ;
  noria:resourceLogisticId "LOG-DC-Papeete" ;
  noria:locatedAtLocus <https://w3id.org/noria/instance/LocusPapeete> .

<https://w3id.org/noria/instance/LocusParis> a noria:Locus ;
  rdfs:label "Paris Location"@en .

<https://w3id.org/noria/instance/LocusPapeete> a noria:Locus ;
  rdfs:label "Papeete Location"@en .

<https://w3id.org/noria/instance/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "ge-0/0/1"@en ;
  rdfs:comment "Gigabit Ethernet interface on core switch."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceDescription "Uplink port to external network."@en ;
  noria:networkInterfaceOf <https://w3id.org/noria/instance/Network1> ;
  noria:networkInterfaceConnects <https://w3id.org/noria/instance/NetworkLink1> .

<https://w3id.org/noria/instance/NetworkInterface2> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Virtual network interface on Web Server 2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceDescription "Virtual NIC for internal communication."@en ;
  noria:networkInterfaceOf <https://w3id.org/noria/instance/Resource2> ;
  noria:networkInterfaceConnects <https://w3id.org/noria/instance/NetworkLink2> .

<https://w3id.org/noria/instance/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Internal Virtual Link"@en ;
  rdfs:comment "Virtual network link for internal VM communication."@en ;
  noria:networkLinkId "NL-Virtual-002" ;
  noria:networkLinkType "virtual" ;
  noria:networkLinkInstallationDate "2021-03-10T09:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://w3id.org/noria/instance/Resource2> ;
  noria:networkLinkTerminationResource <https://w3id.org/noria/instance/Resource2> .

<https://w3id.org/noria/instance/Resource3> a noria:Resource ;
  rdfs:label "Firewall Appliance"@en ;
  rdfs:comment "Firewall device for perimeter security."@en ;
  noria:resourceSerialNumber "SN-FW-001" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
  noria:resourceLogisticId "LOG-FW-001" ;
  noria:elementManagedBy <https://w3id.org/noria/instance/OrgSecurity> .

<https://w3id.org/noria/instance/OrgSecurity> a org:OrganizationalUnit ;
  rdfs:label "Security Operations"@en ;
  rdfs:comment "Security team managing firewall and security policies."@en .
