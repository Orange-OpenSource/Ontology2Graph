  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://example.com/ResourceType/NetworkDevice> ] ;
  noria:resourceProductModel <https://example.com/ProductModelW> ;
