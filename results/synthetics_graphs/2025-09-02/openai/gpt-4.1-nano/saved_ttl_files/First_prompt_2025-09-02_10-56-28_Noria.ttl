@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode1>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A high-degree network switch acting as a central connector."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:structuralElementDistinguishedName "Switch-1" .

<https://example.com/highDegreeNode2>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 2"@en ;
  rdfs:comment "Another high-degree switch connected to multiple nodes."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:structuralElementDistinguishedName "Switch-2" .

<https://example.com/centralNode>
  a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "A central node with high connectivity, acting as a core router."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/hubNode> ;
  noria:structuralElementDistinguishedName "Router-1" .

<https://example.com/connectorNode>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/centralNode> ;
  noria:structuralElementDistinguishedName "Connector-1" .

<https://example.com/intermediaryNode>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating communication between hubs."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/connectorNode> ;
  noria:structuralElementDistinguishedName "Intermediary-1" .

<https://example.com/multiplexNode>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node connecting multiple different network types."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/intermediaryNode> ;
  noria:structuralElementDistinguishedName "Multiplex-1" .

<https://example.com/superNode>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralObservableOf <https://example.com/hubNode> , <https://example.com/highDegreeNode1> , <https://example.com/highDegreeNode2> ;
  noria:structuralElementDistinguishedName "SuperNode-Alpha" .

<https://example.com/NetworkOperationsTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/ResourceA>
  a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "A virtual machine connected to the central router."@en ;
  noria:locatedAtLocus <https://example.com/Room101> ;
  noria:resourceHostName "vm-resourceA" ;
  noria:resourceLogisticId "VM-A-001" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://example.com/ResourceType/VirtualMachine> ] ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsDept> .

<https://example.com/Room101>
  a noria:Room ;
  rdfs:label "Server Room 101"@en ;
  rdfs:comment "Main server room in Building 1."@en .

<https://example.com/ProductModelX>
  a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model identifier for Resource A."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerY> .

<https://example.com/ManufacturerY>
  a org:Organization ;
  rdfs:label "Manufacturer Y"@en ;
  rdfs:comment "Manufacturer of the hardware resources."@en .

<https://example.com/ResourceB>
  a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "A physical switch in the network."@en ;
  noria:locatedAtLocus <https://example.com/Room102> ;
  noria:resourceHostName "switch-resourceB" ;
  noria:resourceLogisticId "SW-B-002" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://example.com/ResourceType/PhysicalSwitch> ] ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsDept> .

<https://example.com/NetworkOpsDept>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations Department"@en ;
  rdfs:comment "Department responsible for network hardware and links."@en .

<https://example.com/NetworkLink1>
  a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource A and Resource B."@en ;
  noria:networkLinkId "Link-001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/ResourceC>
  a noria:Resource ;
  rdfs:label "Resource C"@en ;
  rdfs:comment "A virtual server in data center."@en ;
  noria:locatedAtLocus <https://example.com/Room102> ;
  noria:resourceHostName "vm-resourceC" ;
  noria:resourceLogisticId "VM-C-003" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://example.com/ResourceType/VirtualServer> ] ;
  noria:resourceProductModel <https://example.com/ProductModelZ> ;
  noria:resourceManagedBy <https://example.com/ITDept> .

<https://example.com/ITDept>
  a org:OrganizationalUnit ;
  rdfs:label "IT Department"@en ;
  rdfs:comment "Department managing virtual resources."@en .

<https://example.com/ProductModelZ>
  a noria:ProductModel ;
  rdfs:label "Model Z"@en ;
  rdfs:comment "Another manufacturer model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerZ> .

<https://example.com/ManufacturerZ>
  a org:Organization ;
  rdfs:label "Manufacturer Z"@en ;
  rdfs:comment "Manufacturer of Resource C."@en .

<https://example.com/ResourceD>
  a noria:Resource ;
  rdfs:label "Resource D"@en ;
  rdfs:comment "A network device in data center."@en ;
  noria:locatedAtLocus <https://example.com/Room102> ;
  noria:resourceHostName "device-resourceD" ;
  noria:resourceLogisticId "DEV-D-004" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://example.com/ResourceType/NetworkDevice> ] ;
  noria:resourceProductModel <https://example.com/ProductModelW> ;
  noria:resourceManagedBy <https://example.com/ITDept> .

<https://example.com/ProductModelW>
  a noria:ProductModel ;
  rdfs:label "Model W"@en ;
  rdfs:comment "Network device model W."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerW> .

<https://example.com/ManufacturerW>
  a org:Organization ;
  rdfs:label "Manufacturer W"@en ;
  rdfs:comment "Manufacturer of network device."@en .

<https://example.com/Room102>
  a noria:Room ;
  rdfs:label "Server Room 102"@en ;
  rdfs:comment "Secondary server room."@en .

<https://example.com/ResourceE>
  a noria:Resource ;
  rdfs:label "Resource E"@en ;
  rdfs:comment "A virtual network interface."@en ;
  noria:locatedAtLocus <https://example.com/Room102> ;
  noria:resourceHostName "vnic-resourceE" ;
  noria:resourceLogisticId "VNIC-005" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://example.com/ResourceType/VirtualNetworkInterface> ] ;
  noria:resourceProductModel <https://example.com/ProductModelV> ;
  noria:resourceManagedBy <https://example.com/ITDept> .

<https://example.com/ProductModelV>
  a noria:ProductModel ;
  rdfs:label "Model V"@en ;
  rdfs:comment "Virtual network interface model V."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerV> .

<https://example.com/ManufacturerV>
  a org:Organization ;
  rdfs:label "Manufacturer V"@en ;
  rdfs:comment "Manufacturer of virtual network interface."@en .

<https://example.com/Room103>
  a noria:Room ;
  rdfs:label "Data Center 103"@en ;
  rdfs:comment "Main data center."@en .

<https://example.com/ResourceF>
  a noria:Resource ;
  rdfs:label "Resource F"@en ;
  rdfs:comment "A network link in data center."@en ;
  noria:locatedAtLocus <https://example.com/Room103> ;
  noria:networkLinkId "Link-002" ;
  noria:networkLinkType "Ethernet" ;
  noria:networkLinkInstallationDate "2021-03-10T09:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceD> .

<https://example.com/ResourceG>
  a noria:Resource ;
  rdfs:label "Resource G"@en ;
  rdfs:comment "A network resource in data center."@en ;
  noria:locatedAtLocus <https://example.com/Room103> ;
