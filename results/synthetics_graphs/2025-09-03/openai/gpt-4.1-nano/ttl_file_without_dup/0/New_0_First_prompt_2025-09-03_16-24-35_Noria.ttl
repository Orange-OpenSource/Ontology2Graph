@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1_extra_node_1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam_extra_node_1> .

<https://example.com/highDegreeNode1_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch in the core network."@en ;
  noria:structuralElementObservableData 100 ;
  noria:structuralElementDistinguishedName "Switch-01" .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A central node with high connectivity, hosting critical services."@en ;
  noria:structuralElementObservableData "Operational"^^xsd:string .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking internal and external network segments."@en ;
  noria:structuralElementObservableData "Firewall"^^xsd:string .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservableData "Load Balancer"^^xsd:string .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData "Multiplexer"^^xsd:string .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple high-degree nodes for redundancy."@en ;
  noria:structuralElementObservableData "SuperNode"^^xsd:string .

<https://example.com/NetworkOperationsTeam_extra_node_1> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "The team responsible for managing network infrastructure."@en .

<https://example.com/Resource1_extra_node_1> a noria:Resource ;
  rdfs:label "Server01"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:resourceLogisticId "SRV-001" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceHostName "server01.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ProductModel1> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam_extra_node_1> .

<https://example.com/ProductModel1> a noria:ProductModel ;
  rdfs:label "Dell PowerEdge R740"@en ;
  rdfs:comment "Dell server model R740."@en ;
  noria:productManufacturedBy <https://example.com/DellInc> .

<https://example.com/DellInc> a org:Organization ;
  rdfs:label "Dell Inc."@en ;
  rdfs:comment "Manufacturer of Dell servers."@en .

<https://example.com/ITSupportTeam_extra_node_1> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for IT resource management."@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "Primary data center location."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between Data Center A and B."@en ;
  noria:networkLinkId "NL-AB-001" ;
  noria:networkLinkInstallationDate "2021-06-01T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource1_extra_node_1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2_extra_node_1> .

<https://example.com/Resource2_extra_node_1> a noria:Resource ;
  rdfs:label "Switch02"@en ;
  rdfs:comment "Aggregation switch in Data Center B."@en ;
  noria:resourceLogisticId "SW-002" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceHostName "switch02.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/Active> ;
  noria:resourceInstallationDate "2022-02-20T11:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelSwitchX> ;
  noria:resourceManagedBy <https://example.com/NetworkOpsTeam_extra_node_1> .

<https://example.com/ModelSwitchX> a noria:ProductModel ;
  rdfs:label "Cisco Catalyst 9300"@en ;
  rdfs:comment "Cisco switch model 9300."@en ;
  noria:productManufacturedBy <https://example.com/Cisco> .

<https://example.com/Cisco> a org:Organization ;
  rdfs:label "Cisco Systems"@en ;
  rdfs:comment "Manufacturer of Cisco network devices."@en .

<https://example.com/NetworkOpsTeam_extra_node_1> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team managing network infrastructure."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Secondary Data Center"@en ;
  rdfs:comment "Backup data center location."@en .

<https://example.com/Firewall1> a noria:StructuralElement ;
  rdfs:label "Firewall"@en ;
  rdfs:comment "Firewall device connecting internal and external networks."@en ;
  noria:structuralElementObservableData "Active"^^xsd:string .

<https://example.com/LoadBalancer1> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Distributes traffic among application servers."@en ;
  noria:structuralElementObservableData "Operational"^^xsd:string .

<https://example.com/Multiplexer1> a noria:StructuralElement ;
  rdfs:label "Data Multiplexer"@en ;
  rdfs:comment "Combines multiple data streams."@en ;
  noria:structuralElementObservableData "Multiplexed"^^xsd:string .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Redundant Super Node"@en ;
  rdfs:comment "Aggregates multiple high-degree nodes for redundancy."@en ;
  noria:structuralElementObservableData "Redundant"^^xsd:string .