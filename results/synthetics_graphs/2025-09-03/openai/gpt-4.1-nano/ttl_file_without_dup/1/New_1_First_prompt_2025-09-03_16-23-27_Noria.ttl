@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode_extra_node_2>
  a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node connecting multiple high-degree nodes."@en ;
  noria:elementManagedBy <https://example.com/OrgSupport> .

<https://example.com/highDegreeNode1_extra_node_2>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Switch 1"@en ;
  rdfs:comment "A high-degree network switch acting as a connector in the core network."@en ;
  noria:structuralElementObservableData <https://example.com/observable/trafficLoad> ;
  noria:structuralObservableOf <https://example.com/hubNode_extra_node_2> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/highDegreeNode2>
  a noria:StructuralElement ;
  rdfs:label "High-Degree Router 2"@en ;
  rdfs:comment "A central router with high connectivity, serving as a core connector."@en ;
  noria:structuralElementObservableData <https://example.com/observable/latency> ;
  noria:structuralObservableOf <https://example.com/hubNode_extra_node_2> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/centralNode_extra_node_2>
  a noria:StructuralElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A critical server acting as a central node in the network."@en ;
  noria:structuralElementObservableData <https://example.com/observable/serverLoad> ;
  noria:structuralObservableOf <https://example.com/highDegreeNode1_extra_node_2> ;
  noria:elementManagedBy <https://example.com/ITDept> .

<https://example.com/connectorNode_extra_node_2>
  a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/observable/connectionStatus> ;
  noria:structuralObservableOf <https://example.com/highDegreeNode2> ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/intermediaryNode_extra_node_2>
  a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary device facilitating communication between core nodes."@en ;
  noria:structuralElementObservableData <https://example.com/observable/packetLoss> ;
  noria:structuralObservableOf <https://example.com/centralNode_extra_node_2> ;
  noria:elementManagedBy <https://example.com/NetworkSupport> .

<https://example.com/multiplexNode_extra_node_2>
  a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplexing device combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/observable/streamEfficiency> ;
  noria:structuralObservableOf <https://example.com/connectorNode_extra_node_2> ;
  noria:elementManagedBy <https://example.com/TelecomTeam> .

<https://example.com/superNode_extra_node_2>
  a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple high-degree nodes for load balancing."@en ;
  noria:structuralElementObservableData <https://example.com/observable/loadDistribution> ;
  noria:structuralObservableOf <https://example.com/multiplexNode_extra_node_2> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/OrgSupport>
  a org:OrganizationalUnit ;
  rdfs:label "Support Organization"@en ;
  rdfs:comment "Support organization responsible for managing hub nodes."@en .

<https://example.com/NetworkTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Network Core Team"@en ;
  rdfs:comment "Team managing high-degree network nodes."@en .

<https://example.com/ITDept>
  a org:OrganizationalUnit ;
  rdfs:label "IT Department"@en ;
  rdfs:comment "Department managing central servers."@en .

<https://example.com/NetworkOps>
  a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Team overseeing network connectors and intermediary devices."@en .

<https://example.com/NetworkSupport>
  a org:OrganizationalUnit ;
  rdfs:label "Network Support"@en ;
  rdfs:comment "Support team for intermediary nodes."@en .

<https://example.com/TelecomTeam>
  a org:OrganizationalUnit ;
  rdfs:label "Telecom Team"@en ;
  rdfs:comment "Team managing multiplex nodes."@en .

<https://example.com/NetworkManagement>
  a org:OrganizationalUnit ;
  rdfs:label "Network Management"@en ;
  rdfs:comment "Team responsible for super nodes."@en .

<https://example.com/observable/trafficLoad>
  a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load in Mbps."@en .

<https://example.com/observable/latency>
  a noria:StructuralObservable ;
  rdfs:label "Network Latency"@en ;
  rdfs:comment "Average latency in milliseconds."@en .

<https://example.com/observable/serverLoad>
  a noria:StructuralObservable ;
  rdfs:label "Server Load"@en ;
  rdfs:comment "Current server CPU load percentage."@en .

<https://example.com/observable/connectionStatus>
  a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection (up/down)."@en .

<https://example.com/observable/packetLoss>
  a noria:StructuralObservable ;
  rdfs:label "Packet Loss"@en ;
  rdfs:comment "Packet loss percentage."@en .

<https://example.com/observable/streamEfficiency>
  a noria:StructuralObservable ;
  rdfs:label "Stream Efficiency"@en ;
  rdfs:comment "Efficiency of data streams in percentage."@en .

<https://example.com/observable/loadDistribution>
  a noria:StructuralObservable ;
  rdfs:label "Load Distribution"@en ;
  rdfs:comment "Distribution of load across multiplexed streams."@en .