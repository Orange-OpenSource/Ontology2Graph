@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode_extra_node_3> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node connecting multiple network segments, high degree node."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam_extra_node_3> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Switch"@en ;
  rdfs:comment "A switch with many connections acting as a hub in the network."@en ;
  noria:structuralElementObservableData <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/NetworkSwitch1> .

<https://example.com/centralNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "Central Router"@en ;
  rdfs:comment "A core router with multiple links, acting as a central node."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> ;
  noria:structuralElementObservable <https://example.com/TrafficFlowObservable> .

<https://example.com/connectorNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting two different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> ;
  noria:structuralElementObservable <https://example.com/ConnectionStatusObservable> .

<https://example.com/intermediaryNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "Intermediary Device"@en ;
  rdfs:comment "Device acting as an intermediary in data flow."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdmin> .

<https://example.com/multiplexNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "Device performing multiplexing of multiple signals."@en ;
  noria:structuralElementObservableData <https://example.com/multiplexRatio> .

<https://example.com/superNode_extra_node_3> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> .

<https://example.com/NetworkSwitch1> a noria:StructuralElement ;
  rdfs:label "Network Switch 1"@en ;
  rdfs:comment "A high-degree switch acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam_extra_node_3> ;
  noria:structuralElementObservableData <https://example.com/connectionCount> .

<https://example.com/TrafficFlowObservable> a noria:StructuralObservable ;
  rdfs:label "Traffic Flow Observable"@en ;
  rdfs:comment "Observable representing traffic flow through the network."@en .

<https://example.com/ConnectionStatusObservable> a noria:StructuralObservable ;
  rdfs:label "Connection Status Observable"@en ;
  rdfs:comment "Observable indicating connection status of nodes."@en .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of connections for a node."@en .

<https://example.com/trafficLoad> a noria:Property ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load on the node."@en .

<https://example.com/multiplexRatio> a noria:Property ;
  rdfs:label "Multiplex Ratio"@en ;
  rdfs:comment "Ratio of multiplexed signals."@en .

<https://example.com/aggregateTraffic> a noria:Property ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Total traffic aggregated at super node."@en .

<https://example.com/NetworkOpsTeam_extra_node_3> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network management."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Primary network administrator responsible for device management."@en .

<https://example.com/Resource1_extra_node_3> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A network resource, such as a server or device."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:locatedAtLocus <https://example.com/Room314> .

<https://example.com/Room314> a noria:Room ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Physical location of resources."@en .

<https://example.com/Resource2_extra_node_3> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Another network resource."@en ;
  noria:resourceLogisticId "RES-002" ;
  noria:locatedAtLocus <https://example.com/Room314> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between Resource 1 and Resource 2."@en ;
  noria:networkLinkId "LINK-AB" .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Fiber Link B-C"@en ;
  rdfs:comment "Optical fiber link between Resource 2 and a core switch."@en ;
  noria:networkLinkId "LINK-BC" .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Resource 3"@en ;
  rdfs:comment "Core network switch."@en ;
  noria:resourceLogisticId "RES-003" .

<https://example.com/NetworkSwitch2> a noria:StructuralElement ;
  rdfs:label "Core Switch"@en ;
  rdfs:comment "Core network switch acting as central node."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam_extra_node_3> ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> .

<https://example.com/trafficLoad> a noria:Property ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Traffic load on core switch."@en .

<https://example.com/aggregateTraffic> a noria:Property ;
  rdfs:label "Aggregate Traffic"@en ;
  rdfs:comment "Total traffic at super node."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Responsible for device management."@en .