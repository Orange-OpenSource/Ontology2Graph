@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central node with high connectivity acting as a hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with a high number of connections, acting as a connector in the network."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/trafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node that connects different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/connectionQuality> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node that acts as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node that multiplexes multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level analysis."@en ;
  noria:structuralObservableOf <https://example.com/aggregationLevel> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network nodes."@en .

<https://example.com/latencyMeasurement> a noria:StructuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Average latency between nodes."@en .

<https://example.com/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current traffic load on the node."@en .

<https://example.com/connectionQuality> a noria:StructuralObservable ;
  rdfs:label "Connection Quality"@en ;
  rdfs:comment "Quality metrics of the connection."@en .

<https://example.com/dataFlowRate> a noria:StructuralObservable ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow through the node."@en .

<https://example.com/streamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of streams multiplexed."@en .

<https://example.com/aggregationLevel> a noria:StructuralObservable ;
  rdfs:label "Aggregation Level"@en ;
  rdfs:comment "Level of data aggregation in super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "Physical resource representing a network device."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:resourceHostName "switch01.company.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkDevice> ;
  noria:locatedAtLocus <https://example.com/Room1> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceInstallationDate "2020-05-20T10:00:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:resourceManagementIPAddress "192.168.1.10" .

<https://example.com/Room1> a noria:Room ;
  rdfs:label "Server Room 1"@en ;
  rdfs:comment "Main server room in building A."@en .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model name for Resource 1."@en ;
  org:organization <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "ACME Corp"@en ;
  rdfs:comment "Manufacturer of the resource."@en .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Resource 2"@en ;
  rdfs:comment "Virtual resource representing a virtual server."@en ;
  noria:resourceLogisticId "RES-002" ;
  noria:resourceHostName "vm01.company.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualServer> ;
  noria:locatedAtLocus <https://example.com/Room2> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceInstallationDate "2021-07-15T09:30:00Z"^^xsd:dateTime ;
  noria:resourceProductModel <https://example.com/ModelY> ;
  noria:resourceManagementIPAddress "192.168.1.20" .

<https://example.com/Room2> a noria:Room ;
  rdfs:label "Data Center 2"@en ;
  rdfs:comment "Secondary data center."@en .

<https://example.com/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Manufacturer's model name for Resource 2."@en ;
  org:organization <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "Beta Inc"@en ;
  rdfs:comment "Manufacturer of the virtual resource."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between Resource 1 and Resource 2."@en ;
  noria:networkLinkId "NL-AB-001" ;
  noria:networkLinkInstallationDate "2019-03-10T08:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/Resource1_NetworkLink> a noria:NetworkLink ;
  rdfs:label "Link between Resource1 and Resource2"@en ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource1_NetworkInterface> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource 1."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceOf <https://example.com/Resource1> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> .

<https://example.com/Resource2_NetworkInterface> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Resource 2."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> .

<https://example.com/TrafficEvent1> a noria:EventRecord ;
  rdfs:label "High Traffic Alert"@en ;
  rdfs:comment "An alert indicating high traffic load on Resource 1."@en ;
  noria:loggingTime "2024-03-15T14:22:00Z"^^xsd:dateTime ;
  noria:logText "Traffic load exceeded threshold."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Major> ;
  noria:alarmProposedRepairAction <https://example.com/RepairAction1> .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en .

<https://example.com/RepairAction1> a pep:Procedure ;
  rdfs:label "Restart Network Interface"@en ;
  rdfs:comment "Procedure to restart the network interface to resolve high traffic issues."@en .

<https://example.com/TrafficEvent2> a noria:EventRecord ;
  rdfs:label "Link Down"@en ;
  rdfs:comment "Event indicating the network link is down."@en ;
  noria:loggingTime "2024-03-15T14:30:00Z"^^xsd:dateTime ;
  noria:logText "Network link NL-AB-001 is down."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Critical> ;
  noria:alarmMitigatedBy <https://example.com/RestartLinkProcedure> .

<https://example.com/RestartLinkProcedure> a pep:Procedure ;
  rdfs:label "Restart Network Link"@en ;
  rdfs:comment "Procedure to restart the network link NL-AB-001."@en .

<https://example.com/Resource1> noria:structuralElementObservable <https://example.com/latencyMeasurement> .

<https://example.com/Resource2> noria:structuralElementObservable <https://example.com/trafficLoad> .

<https://example.com/Resource1> noria:structuralElementObservable <https://example.com/connectionQuality> .

<https://example.com/Resource2> noria:structuralElementObservable <https://example.com/dataFlowRate> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Network Super Node"@en ;
  rdfs:comment "Aggregated super node for high-level network analysis."@en ;
  noria:structuralObservableOf <https://example.com/aggregationLevel> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/aggregationLevel> a noria:StructuralObservable ;
  rdfs:label "Aggregation Level"@en ;
  rdfs:comment "Level of data aggregation in the super node."@en .
