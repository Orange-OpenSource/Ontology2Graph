@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://example.com/HubNode1> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkAdminOrg> .

<https://example.com/HighDegreeNode2_extra_node_4> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch in the core network."@en ;
  noria:structuralElementObservableData <https://example.com/PowerUsageData> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam_extra_node_4> .

<https://example.com/CentralNode3_extra_node_4> a noria:StructuralElement ;
  rdfs:label "Main Router"@en ;
  rdfs:comment "A central node routing traffic between multiple subnets."@en ;
  noria:structuralElementObservable <https://example.com/TrafficLoad> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam_extra_node_4> .

<https://example.com/ConnectorNode4_extra_node_4> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking internal and external networks."@en ;
  noria:structuralElementObservable <https://example.com/FirewallStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam_extra_node_4> .

<https://example.com/IntermediaryNode5> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservable <https://example.com/LoadDistributionMetrics> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam_extra_node_4> .

<https://example.com/MultiplexNode6> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/StreamBandwidth> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering_extra_node_4> .

<https://example.com/SuperNode7> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeTraffic> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership_extra_node_4> .

<https://example.com/NetworkAdminOrg> a org:Organization ;
  rdfs:label "Network Administration Organization"@en ;
  rdfs:comment "Organization responsible for managing core network nodes."@en .

<https://example.com/NetworkOperationsTeam_extra_node_4> a org:Organization ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for operational management of network devices."@en .

<https://example.com/SecurityTeam_extra_node_4> a org:Organization ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security-related network nodes."@en .

<https://example.com/ITSupportTeam_extra_node_4> a org:Organization ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing technical support for network infrastructure."@en .

<https://example.com/PowerUsageData> a noria:StructuralObservable ;
  rdfs:label "Power Usage Data"@en ;
  rdfs:comment "Power consumption metrics of the node."@en .

<https://example.com/TrafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load on the node."@en .

<https://example.com/FirewallStatus> a noria:StructuralObservable ;
  rdfs:label "Firewall Status"@en ;
  rdfs:comment "Operational status of the firewall."@en .

<https://example.com/LoadDistributionMetrics> a noria:StructuralObservable ;
  rdfs:label "Load Distribution Metrics"@en ;
  rdfs:comment "Metrics related to load balancing."@en .

<https://example.com/SuperNodeTraffic> a noria:StructuralObservable ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Aggregated traffic data for super node."@en .

<https://example.com/StreamBandwidth> a noria:StructuralObservable ;
  rdfs:label "Stream Bandwidth"@en ;
  rdfs:comment "Bandwidth metrics for multiplexed streams."@en .

<https://example.com/SuperNodeTraffic> a noria:StructuralObservable ;
  rdfs:label "Super Node Traffic"@en ;
  rdfs:comment "Traffic data for the super node."@en .
