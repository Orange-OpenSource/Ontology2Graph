@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode1_extra_node_2> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity, linking multiple nodes."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_2> .

<https://example.com/highDegreeNode1_extra_node_2> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with a high number of connections, acting as a connector."@en ;
  noria:structuralElementObservableData <https://example.com/observableData1> ;
  noria:elementManagedBy <https://example.com/organization2> .

<https://example.com/centralNode1_extra_node_2> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:structuralElementObservable <https://example.com/observable1> ;
  noria:elementManagedBy <https://example.com/organization3> .

<https://example.com/connectorNode1_extra_node_2> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:structuralElementObservableData <https://example.com/observableData2> ;
  noria:elementManagedBy <https://example.com/organization4> .

<https://example.com/intermediaryNode1_extra_node_2> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/observable2> ;
  noria:elementManagedBy <https://example.com/organization5> .

<https://example.com/multiplexNode1_extra_node_2> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node supporting multiple types of connections."@en ;
  noria:structuralElementObservableData <https://example.com/observableData3> ;
  noria:elementManagedBy <https://example.com/organization6> .

<https://example.com/superNode1_extra_node_2> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Node with super connectivity, acting as a super hub."@en ;
  noria:structuralElementObservable <https://example.com/observable3> ;
  noria:elementManagedBy <https://example.com/organization7> .

<https://example.com/organization1_extra_node_2> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "Responsible for managing hub nodes."@en .

<https://example.com/organization2> a org:OrganizationalUnit ;
  rdfs:label "Data Center A"@en ;
  rdfs:comment "Manages high-degree nodes."@en .

<https://example.com/organization3> a org:OrganizationalUnit ;
  rdfs:label "Core Network Team"@en ;
  rdfs:comment "Oversees central nodes."@en .

<https://example.com/organization4> a org:OrganizationalUnit ;
  rdfs:label "Edge Support Group"@en ;
  rdfs:comment "Supports connector nodes."@en .

<https://example.com/organization5> a org:OrganizationalUnit ;
  rdfs:label "Intermediary Management"@en ;
  rdfs:comment "Handles intermediary nodes."@en .

<https://example.com/organization6> a org:OrganizationalUnit ;
  rdfs:label "Multiplex Support"@en ;
  rdfs:comment "Supports multiplex nodes."@en .

<https://example.com/organization7> a org:OrganizationalUnit ;
  rdfs:label "Super Node Admin"@en ;
  rdfs:comment "Manages super nodes."@en .

<https://example.com/observable1> a noria:StructuralObservable ;
  rdfs:label "Node Status Observable"@en ;
  rdfs:comment "Observable for node operational status."@en .

<https://example.com/observable2> a noria:StructuralObservable ;
  rdfs:label "Connection Data Observable"@en ;
  rdfs:comment "Observable for connection metrics."@en .

<https://example.com/observable3> a noria:StructuralObservable ;
  rdfs:label "Super Node Traffic Observable"@en ;
  rdfs:comment "Observable for super node traffic levels."@en .

<https://example.com/observableData1> a noria:structuralElementObservableData ;
  rdfs:label "Node Load Data"@en ;
  rdfs:comment "Data representing node load and capacity."@en .

<https://example.com/observableData2> a noria:structuralElementObservableData ;
  rdfs:label "Connection Quality Data"@en ;
  rdfs:comment "Metrics for connection quality and throughput."@en .

<https://example.com/observableData3> a noria:structuralElementObservableData ;
  rdfs:label "Super Node Traffic Data"@en ;
  rdfs:comment "Traffic volume and flow data for super nodes."@en .

[] a noria:ManagedElement ;
  rdfs:label "Network Topology Sample"@en ;
  rdfs:comment "Sample network topology with various node types and links."@en ;
  noria:structuralElementObservable <https://example.com/observable1> ;
  noria:structuralElementObservable <https://example.com/observable2> ;
  noria:structuralElementObservable <https://example.com/observable3> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_2> ;
  noria:elementManagedBy <https://example.com/organization2> ;
  noria:elementManagedBy <https://example.com/organization3> ;
  noria:elementManagedBy <https://example.com/organization4> ;
  noria:elementManagedBy <https://example.com/organization5> ;
  noria:elementManagedBy <https://example.com/organization6> ;
  noria:elementManagedBy <https://example.com/organization7> .

[] a noria:StructuralElement ;
  rdfs:label "Link between Hub and High-Degree Node"@en ;
  rdfs:comment "A network link connecting the hub node to a high-degree node."@en ;
  noria:structuralElementObservableData <https://example.com/observableData2> ;
  noria:structuralElementObservable <https://example.com/observable2> ;
  noria:structuralElementObservableOf <https://example.com/hubNode1_extra_node_2> ;
  noria:structuralElementObservableOf <https://example.com/highDegreeNode1_extra_node_2> ;
  noria:elementManagedBy <https://example.com/organization4> .

[] a noria:StructuralElement ;
  rdfs:label "Link between Central and Super Node"@en ;
  rdfs:comment "A link connecting the central node to a super node."@en ;
  noria:structuralElementObservableData <https://example.com/observableData3> ;
  noria:structuralElementObservable <https://example.com/observable3> ;
  noria:structuralElementObservableOf <https://example.com/centralNode1_extra_node_2> ;
  noria:structuralElementObservableOf <https://example.com/superNode1_extra_node_2> ;
  noria:elementManagedBy <https://example.com/organization7> .

[] a noria:StructuralElement ;
  rdfs:label "Link between Intermediary and Multiplex Nodes"@en ;
  rdfs:comment "A connection linking an intermediary node to a multiplex node."@en ;
  noria:structuralElementObservableData <https://example.com/observableData2> ;
  noria:structuralElementObservable <https://example.com/observable2> ;
  noria:structuralElementObservableOf <https://example.com/intermediaryNode1_extra_node_2> ;
  noria:structuralElementObservableOf <https://example.com/multiplexNode1_extra_node_2> ;
  noria:elementManagedBy <https://example.com/organization5> .

[] a noria:StructuralElement ;
  rdfs:label "Link between Hub and Central Node"@en ;
  rdfs:comment "A high-capacity link connecting hub to central node."@en ;
  noria:structuralElementObservableData <https://example.com/observableData1> ;
  noria:structuralElementObservable <https://example.com/observable1> ;
  noria:structuralElementObservableOf <https://example.com/hubNode1_extra_node_2> ;
  noria:structuralElementObservableOf <https://example.com/centralNode1_extra_node_2> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_2> .

[] a noria:StructuralElement ;
  rdfs:label "Link between Super and Hub Nodes"@en ;
  rdfs:comment "A super node connection to the hub node."@en ;
  noria:structuralElementObservableData <https://example.com/observableData3> ;
  noria:structuralElementObservable <https://example.com/observable3> ;
  noria:structuralElementObservableOf <https://example.com/superNode1_extra_node_2> ;
  noria:structuralElementObservableOf <https://example.com/hubNode1_extra_node_2> ;
  noria:elementManagedBy <https://example.com/organization7> .