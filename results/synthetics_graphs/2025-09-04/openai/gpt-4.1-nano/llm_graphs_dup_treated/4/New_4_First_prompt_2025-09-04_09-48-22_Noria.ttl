@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node in the network, connecting multiple segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch."@en ;
  noria:structuralElementObservableData <https://example.com/observable/portCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/CentralNode> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center, connecting servers and storage."@en ;
  noria:structuralElementObservableData <https://example.com/observable/trafficLoad> ;
  noria:elementManagedBy <https://example.com/DataCenterOps> .

<https://example.com/ConnectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking external network to internal resources."@en ;
  noria:structuralElementObservableData <https://example.com/observable/connectionStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/IntermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservableData <https://example.com/observable/trafficDistribution> ;
  noria:elementManagedBy <https://example.com/ITOperations> .

<https://example.com/MultiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/observable/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering> .

<https://example.com/SuperNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node managing multiple sub-nodes."@en ;
  noria:structuralElementObservableData <https://example.com/observable/subNodeCount> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Server A"@en ;
  rdfs:comment "A high-performance application server."@en ;
  noria:resourceLogisticId "SRV-A-001" ;
  noria:resourceHostName "serverA.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/server> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Storage Array 1"@en ;
  rdfs:comment "Primary storage array for backups."@en ;
  noria:resourceLogisticId "STO-ARRAY-01" ;
  noria:resourceHostName "storage01.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/storage> ;
  noria:resourceSerialNumber "SN654321" ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/active> ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/StorageTeam> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server rack location."@en ;
  noria:locusLine "Line: L, in Rack 5"@en ;
  noria:locusRow "Row: R3"@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Storage array location."@en ;
  noria:locusLine "Line: L, in Storage Room"@en ;
  noria:locusRow "Row: R1"@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/DataCenterOps> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en ;
  rdfs:comment "Team managing data center resources."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team handling security infrastructure."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Support team for IT resources."@en .

<https://example.com/StorageTeam> a org:OrganizationalUnit ;
  rdfs:label "Storage Support Team"@en ;
  rdfs:comment "Team managing storage resources."@en .

<https://example.com/NetworkLeadership> a org:OrganizationalUnit ;
  rdfs:label "Network Leadership"@en ;
  rdfs:comment "Oversees network infrastructure."@en .

<https://example.com/observable/portCount> a noria:StructuralObservable ;
  rdfs:label "Port Count"@en ;
  rdfs:comment "Number of ports available on the switch."@en .

<https://example.com/observable/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/observable/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of the connection (up/down)."@en .

<https://example.com/observable/streamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/observable/subNodeCount> a noria:StructuralObservable ;
  rdfs:label "Sub Node Count"@en ;
  rdfs:comment "Number of sub-nodes under a super node."@en .

<https://example.com/observable/trafficDistribution> a noria:StructuralObservable ;
  rdfs:label "Traffic Distribution"@en ;
  rdfs:comment "Distribution of traffic among servers."@en .

<https://example.com/observable/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/observable/portCount> a noria:StructuralObservable .

