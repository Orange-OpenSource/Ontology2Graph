@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://example.com/hubNode1_extra_node_0> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/OrgSupportTeam> .

<https://example.com/highDegreeNode2> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "High-degree node with many connections in the network."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralElementDistinguishedName "Switch-01"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/centralNode3> a noria:FunctionalElement ;
  rdfs:label "Authentication Server"@en ;
  rdfs:comment "A central node responsible for user authentication."@en ;
  noria:functionalElementDistinguishedName "AuthServer-01"^^xsd:string ;
  noria:elementManagedBy <https://example.com/AuthTeam> .

<https://example.com/connectorNode4> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "Connector node linking internal network to external firewall."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralElementDistinguishedName "Firewall-Conn"^^xsd:string ;
  noria:elementManagedBy <https://example.com/SecurityOps> .

<https://example.com/intermediaryNode5> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Intermediary node distributing traffic among servers."@en ;
  noria:functionalElementDistinguishedName "LoadBalancer-01"^^xsd:string ;
  noria:elementManagedBy <https://example.com/InfraTeam> .

<https://example.com/multiplexNode6> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralElementDistinguishedName "Mux-Stream"^^xsd:string ;
  noria:elementManagedBy <https://example.com/StreamOps> .

<https://example.com/superNode7> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:elementManagedBy <https://example.com/ManagementTeam> .

<https://example.com/HubNode1> noria:connected_to <https://example.com/HighDegreeNode2> ;
  noria:connected_to <https://example.com/CentralNode3> .

<https://example.com/HighDegreeNode2> noria:connected_to <https://example.com/HubNode1> ;
  noria:connected_to <https://example.com/IntermediaryNode5> .

<https://example.com/CentralNode3> noria:connected_to <https://example.com/HubNode1> ;
  noria:connected_to <https://example.com/MultiplexNode6> .

<https://example.com/IntermediaryNode5> noria:connected_to <https://example.com/HighDegreeNode2> ;
  noria:connected_to <https://example.com/SuperNode7> .

<https://example.com/MultiplexNode6> noria:connected_to <https://example.com/CentralNode3> ;
  noria:connected_to <https://example.com/FirewallNode8> .

<https://example.com/FirewallNode8> a noria:StructuralElement ;
  rdfs:label "Firewall Node"@en ;
  rdfs:comment "Firewall node connecting internal network to external."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralElementDistinguishedName "Firewall-External"^^xsd:string ;
  noria:elementManagedBy <https://example.com/SecurityOps> .

<https://example.com/SuperNode7> noria:connected_to <https://example.com/FirewallNode8> .

<https://example.com/HubNode1> rdfs:label "Core Router Hub"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en .

<https://example.com/HighDegreeNode2> rdfs:label "Main Switch"@en ;
  rdfs:comment "High-degree node with many connections in the network."@en .

<https://example.com/CentralNode3> rdfs:label "Authentication Server"@en ;
  rdfs:comment "A central node responsible for user authentication."@en .

<https://example.com/IntermediaryNode5> rdfs:label "Load Balancer"@en ;
  rdfs:comment "Intermediary node distributing traffic among servers."@en .

<https://example.com/MultiplexNode6> rdfs:label "Multiplexer"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en .

<https://example.com/SuperNode7> rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en .

<https://example.com/FirewallNode8> rdfs:label "Firewall Node"@en ;
  rdfs:comment "Firewall node connecting internal network to external."@en .

<https://example.com/OrgSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Support Team"@en ;
  rdfs:comment "Support team managing core network infrastructure."@en .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Team responsible for network operation and maintenance."@en .

<https://example.com/AuthTeam> a org:OrganizationalUnit ;
  rdfs:label "Authentication Team"@en ;
  rdfs:comment "Team managing authentication servers."@en .

<https://example.com/SecurityOps> a org:OrganizationalUnit ;
  rdfs:label "Security Operations"@en ;
  rdfs:comment "Team responsible for security infrastructure."@en .

<https://example.com/InfraTeam> a org:OrganizationalUnit ;
  rdfs:label "Infrastructure Team"@en ;
  rdfs:comment "Team managing infrastructure components."@en .

<https://example.com/StreamOps> a org:OrganizationalUnit ;
  rdfs:label "Stream Operations"@en ;
  rdfs:comment "Team managing data streams and multiplexers."@en .

<https://example.com/ManagementTeam> a org:OrganizationalUnit ;
  rdfs:label "Management Team"@en ;
  rdfs:comment "High-level management of network nodes."@en .