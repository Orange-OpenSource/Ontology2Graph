  noria:elementManagedBy <https://example.com/NetworkOpsTeam_extra_node_11> .

<https://example.com/HighDegreeNode_extra_node_11> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch."@en ;
  noria:structuralElementObservableData <https://example.com/observable/portCount> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam_extra_node_11> .

<https://example.com/CentralNode_extra_node_11> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center, connecting servers and storage."@en ;
  noria:structuralElementObservableData <https://example.com/observable/trafficLoad> ;
  noria:elementManagedBy <https://example.com/DataCenterOps_extra_node_11> .

<https://example.com/ConnectorNode_extra_node_11> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking external network to internal resources."@en ;
  noria:structuralElementObservableData <https://example.com/observable/connectionStatus> ;
  noria:elementManagedBy <https://example.com/SecurityTeam_extra_node_11> .

<https://example.com/IntermediaryNode_extra_node_11> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservableData <https://example.com/observable/trafficDistribution_extra_node_11> ;
  noria:elementManagedBy <https://example.com/ITOperations_extra_node_11> .

<https://example.com/MultiplexNode_extra_node_11> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/observable/streamCount_extra_node_11> ;
  noria:elementManagedBy <https://example.com/NetworkEngineering_extra_node_11> .

<https://example.com/SuperNode_extra_node_11> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node managing multiple sub-nodes."@en ;
  noria:structuralElementObservableData <https://example.com/observable/subNodeCount> ;
  noria:elementManagedBy <https://example.com/NetworkLeadership_extra_node_11> .

