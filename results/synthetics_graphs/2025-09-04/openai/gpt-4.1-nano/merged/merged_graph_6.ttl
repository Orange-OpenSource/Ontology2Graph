  noria:structuralElementObservable <https://example.com/observable2_extra_node_2> ;
  noria:structuralElementObservableOf <https://example.com/hubNode1_extra_node_2> ;
  noria:structuralElementObservableOf <https://example.com/highDegreeNode1_extra_node_2> ;
  noria:elementManagedBy <https://example.com/organization4> .

[] a noria:StructuralElement ;
  rdfs:label "Link between Central and Super Node"@en ;
  rdfs:comment "A link connecting the central node to a super node."@en ;
  noria:structuralElementObservableData <https://example.com/observableData3> ;
  noria:structuralElementObservable <https://example.com/observable3_extra_node_2> ;
  noria:structuralElementObservableOf <https://example.com/centralNode1_extra_node_2> ;
  noria:structuralElementObservableOf <https://example.com/superNode1_extra_node_2> ;
  noria:elementManagedBy <https://example.com/organization7> .

[] a noria:StructuralElement ;
  rdfs:label "Link between Intermediary and Multiplex Nodes"@en ;
