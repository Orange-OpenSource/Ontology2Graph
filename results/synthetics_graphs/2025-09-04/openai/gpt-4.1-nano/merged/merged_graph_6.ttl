@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://example.com/hubNode1_extra_node_7> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central router acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode2_extra_node_7> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A switch with high connectivity degree."@en ;
  noria:structuralElementObservableData <https://example.com/latencyMeasurement> ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam_extra_node_7> .

<https://example.com/centralNode3_extra_node_7> a noria:Resource ;
  rdfs:label "Data Center Server"@en ;
  rdfs:comment "A central server hosting critical applications."@en ;
  noria:locatedAtLocus <https://example.com/Room314> ;
  noria:resourceManagedBy <https://example.com/ITSupport> .

<https://example.com/connectorNode4_extra_node_7> a noria:NetworkInterface ;
  rdfs:label "GigabitEthernet0/0/1"@en ;
  rdfs:comment "Main uplink interface."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1_extra_node_7> ;
  noria:networkInterfaceOf <https://example.com/Resource1_extra_node_7> .

<https://example.com/intermediaryNode5_extra_node_7> a noria:Resource ;
  rdfs:label "Firewall Appliance"@en ;
  rdfs:comment "Firewall device acting as an intermediary node."@en ;
  noria:resourceSerialNumber "FW-12345" ;
  noria:resourceManagedBy <https://example.com/SecurityTeam_extra_node_7> .

<https://example.com/multiplexNode6_extra_node_7> a noria:Resource ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "A multiplex node distributing traffic."@en ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/LoadBalancer> ;
  noria:resourceManagedBy <https://example.com/ITSupport> .

<https://example.com/superNode7_extra_node_7> a noria:StructuralElement ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "A super node representing the entire data center."@en ;
  noria:structuralElementObservableData <https://example.com/powerConsumption> ;
  noria:elementManagedBy <https://example.com/DataCenterOps_extra_node_7> .

<https://example.com/Resource1_extra_node_7> a noria:Resource ;
  rdfs:label "Application Server 1"@en ;
  rdfs:comment "Application server hosting backend services."@en ;
  noria:locatedAtLocus <https://example.com/Room314> ;
  noria:resourceManagedBy <https://example.com/ITSupport> .

<https://example.com/NetworkLink1_extra_node_7> a noria:NetworkLink ;
  rdfs:label "Fiber Optic Link A-B"@en ;
  rdfs:comment "Optical fiber link between core router and main switch."@en ;
  noria:networkLinkId "Link-FO-001" ;
  noria:networkLinkType "optical fiber" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1_extra_node_7> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2_extra_node_7> .

<https://example.com/Room314> a noria:Room ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Main server room on floor 3."@en .

<https://example.com/latencyMeasurement> a noria:structuralObservable ;
  rdfs:label "Latency Measurement"@en ;
  rdfs:comment "Average latency in milliseconds."@en ;
  noria:structuralElementObservableData "2ms"^^xsd:decimal .

<https://example.com/powerConsumption> a noria:structuralObservable ;
  rdfs:label "Power Consumption"@en ;
  rdfs:comment "Power usage in kilowatts."@en ;
  noria:structuralElementObservableData "150kW"^^xsd:string .

<https://example.com/NetworkOpsTeam_extra_node_7> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Support team for IT resources."@en .

<https://example.com/SecurityTeam_extra_node_7> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team managing security devices."@en .

<https://example.com/DataCenterOps_extra_node_7> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en ;
  rdfs:comment "Team managing data center infrastructure."@en .

<https://example.com/hubNode1_extra_node_1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "Central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/OrgSupportTeam> .

<https://example.com/highDegreeNode2_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "High-degree node with many connections in the network."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralElementDistinguishedName "Switch-01"^^xsd:string ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam_extra_node_1> .

<https://example.com/centralNode3_extra_node_1> a noria:FunctionalElement ;
  rdfs:label "Authentication Server"@en ;
  rdfs:comment "A central node responsible for user authentication."@en ;
  noria:functionalElementDistinguishedName "AuthServer-01"^^xsd:string ;
  noria:elementManagedBy <https://example.com/AuthTeam_extra_node_1> .

<https://example.com/connectorNode4_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "Connector node linking internal network to external firewall."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralElementDistinguishedName "Firewall-Conn"^^xsd:string ;
  noria:elementManagedBy <https://example.com/SecurityOps> .

<https://example.com/intermediaryNode5_extra_node_1> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "Intermediary node distributing traffic among servers."@en ;
  noria:functionalElementDistinguishedName "LoadBalancer-01"^^xsd:string ;
  noria:elementManagedBy <https://example.com/InfraTeam> .

<https://example.com/multiplexNode6_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralElementDistinguishedName "Mux-Stream"^^xsd:string ;
  noria:elementManagedBy <https://example.com/StreamOps> .

<https://example.com/superNode7_extra_node_1> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes for high-level management."@en ;
  noria:elementManagedBy <https://example.com/ManagementTeam> .

<https://example.com/HubNode1_extra_node_1> noria:connected_to <https://example.com/HighDegreeNode2_extra_node_1> ;
  noria:connected_to <https://example.com/CentralNode3_extra_node_1> .

<https://example.com/HighDegreeNode2_extra_node_1> noria:connected_to <https://example.com/HubNode1_extra_node_1> ;
  noria:connected_to <https://example.com/IntermediaryNode5_extra_node_1> .

<https://example.com/CentralNode3_extra_node_1> noria:connected_to <https://example.com/HubNode1_extra_node_1> ;
  noria:connected_to <https://example.com/MultiplexNode6_extra_node_1> .

<https://example.com/IntermediaryNode5_extra_node_1> noria:connected_to <https://example.com/HighDegreeNode2_extra_node_1> ;
  noria:connected_to <https://example.com/SuperNode7_extra_node_1> .

<https://example.com/MultiplexNode6_extra_node_1> noria:connected_to <https://example.com/CentralNode3_extra_node_1> ;
  noria:connected_to <https://example.com/FirewallNode8> .

<https://example.com/FirewallNode8> a noria:StructuralElement ;
  rdfs:label "Firewall Node"@en ;
  rdfs:comment "Firewall node connecting internal network to external."@en ;
  noria:structuralElementObservable noria:structuralElementObservableData ;
  noria:structuralElementDistinguishedName "Firewall-External"^^xsd:string ;
  noria:elementManagedBy <https://example.com/SecurityOps> .

<https://example.com/SuperNode7_extra_node_1> noria:connected_to <https://example.com/FirewallNode8> .

