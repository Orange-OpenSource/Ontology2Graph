  noria:structuralElementObservable <https://example.com/observable2_extra_node_2> ;
  noria:structuralElementObservableOf <https://example.com/intermediaryNode1_extra_node_2> ;
  noria:structuralElementObservableOf <https://example.com/multiplexNode1_extra_node_2> ;
  noria:elementManagedBy <https://example.com/organization5> .

[] a noria:StructuralElement ;
  rdfs:label "Link between Hub and Central Node"@en ;
