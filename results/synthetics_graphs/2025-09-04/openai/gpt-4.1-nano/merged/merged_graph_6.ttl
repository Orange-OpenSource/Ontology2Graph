<https://example.com/NetworkLink1_extra_node_11> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between site A and site B."@en ;
  noria:networkLinkId "NL-A-B-001" ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource1_extra_node_11> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2_extra_node_11> .

<https://example.com/Event1_extra_node_11> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating the fiber link is operational."@en ;
  noria:loggingTime "2023-10-01T12:30:00"^^xsd:dateTime ;
  noria:logText "Fiber link NL-A-B is now active."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1_extra_node_11> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1_extra_node_11> ;
  noria:logOriginatingAgent <https://example.com/NetworkEngineer1> ;
  noria:logOriginatingAgent <https://example.com/NetworkEngineer2> .

<https://example.com/NetworkEngineer1> a foaf:Agent ;
  rdfs:label "Engineer Alice"@en ;
  rdfs:comment "Network engineer responsible for link maintenance."@en .

<https://example.com/NetworkEngineer2> a foaf:Agent ;
  rdfs:label "Engineer Bob"@en ;
  rdfs:comment "Network engineer responsible for link monitoring."@en .

<https://example.com/NMS1_extra_node_11> a noria:Application ;
  rdfs:label "Network Management System 1"@en ;
  rdfs:comment "System monitoring network links and resources."@en .

<https://example.com/Alarm1> a noria:EventRecord ;
  rdfs:label "Link Down Alarm"@en ;
  rdfs:comment "Alarm indicating link failure."@en ;
  noria:loggingTime "2023-10-01T12:00:00"^^xsd:dateTime ;
  noria:logText "Fiber link NL-A-B is down."@en ;
  noria:alarmSeverity <https://www.w3.org/2004/02/skos/core#Major> ;
  noria:logOriginatingManagedObject <https://example.com/Resource1_extra_node_11> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1_extra_node_11> ;
  noria:logOriginatingAgent <https://example.com/NetworkEngineer2> .

# Note: The above creates a network graph with hubs, high-degree nodes, central nodes, connector, intermediary, multiplex, and super nodes, all linked via relations, with descriptive labels and comments for clarity. Isolated nodes are dismissed; all nodes are interconnected via relations.

<https://example.com/hubNode1_extra_node_10> a noria:ManagedElement ;
  rdfs:label "Hub Node 1"@en ;
  rdfs:comment "A central hub node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_10> .

<https://example.com/organization1_extra_node_10> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "The main organization managing critical network infrastructure."@en .

<https://example.com/highDegreeNode1_extra_node_10> a noria:StructuralElement ;
  rdfs:label "High-Degree Node 1"@en ;
  rdfs:comment "A node with high degree of connections, acting as a connector."@en ;
  noria:structuralElementObservable <https://example.com/observable1_extra_node_10> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_10> .

<https://example.com/centralNode1_extra_node_10> a noria:StructuralElement ;
  rdfs:label "Central Node 1"@en ;
  rdfs:comment "A central node linking multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable2_extra_node_10> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_10> .

<https://example.com/connectorNode1_extra_node_10> a noria:StructuralElement ;
  rdfs:label "Connector Node 1"@en ;
  rdfs:comment "A connector node linking intermediary nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable3_extra_node_10> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_10> .

<https://example.com/intermediaryNode1_extra_node_10> a noria:StructuralElement ;
  rdfs:label "Intermediary Node 1"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservable <https://example.com/observable4> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_10> .

