<https://example.com/hubNode1_extra_node_1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree core router acting as a central hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam_extra_node_1> .

<https://example.com/HighDegreeNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Main Data Center Switch"@en ;
  rdfs:comment "A switch with high connectivity degree, connecting multiple servers and network segments."@en ;
  noria:structuralElementDistinguishedName "Switch-DC1" ;
  noria:elementManagedBy <https://example.com/ITSupportTeam_extra_node_1> .

<https://example.com/CentralNode_extra_node_1> a noria:FunctionalElement ;
  rdfs:label "Authentication Service"@en ;
  rdfs:comment "A critical service responsible for user authentication across the system."@en ;
  noria:functionalElementDistinguishedName "AuthService01" ;
  noria:elementManagedBy <https://example.com/AuthTeam_extra_node_1> .

<https://example.com/ConnectorNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A firewall node connecting internal network to external internet."@en ;
  noria:structuralElementDistinguishedName "Firewall-Conn" ;
  noria:elementManagedBy <https://example.com/SecurityTeam_extra_node_1> .

<https://example.com/IntermediaryNode_extra_node_1> a noria:FunctionalElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:functionalElementDistinguishedName "LoadBalancer01" ;
  noria:elementManagedBy <https://example.com/ITSupportTeam_extra_node_1> .

<https://example.com/MultiplexNode_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplexing node combining multiple data streams."@en ;
  noria:structuralElementDistinguishedName "Mux-Stream" ;
  noria:elementManagedBy <https://example.com/NetworkOps> .

<https://example.com/SuperNode_extra_node_1> a noria:ManagedElement ;
  rdfs:label "Global Network Super Node"@en ;
  rdfs:comment "A super node with extensive connectivity acting as a backbone."@en ;
  noria:elementManagedBy <https://example.com/GlobalNetworkTeam> .

<https://example.com/HubNode2_extra_node_1> a noria:ManagedElement ;
