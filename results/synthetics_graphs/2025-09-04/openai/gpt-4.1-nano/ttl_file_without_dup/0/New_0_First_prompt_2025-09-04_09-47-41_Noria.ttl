@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1_extra_node_1> a noria:ManagedElement ;
  rdfs:label "Hub Node 1"@en ;
  rdfs:comment "A central hub node with high connectivity in the network."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_1> .

<https://example.com/organization1_extra_node_1> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "The main organization managing critical network infrastructure."@en .

<https://example.com/highDegreeNode1_extra_node_1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node 1"@en ;
  rdfs:comment "A node with high degree of connections, acting as a connector."@en ;
  noria:structuralElementObservable <https://example.com/observable1_extra_node_1> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_1> .

<https://example.com/centralNode1_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Central Node 1"@en ;
  rdfs:comment "A central node linking multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable2_extra_node_1> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_1> .

<https://example.com/connectorNode1_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Connector Node 1"@en ;
  rdfs:comment "A connector node linking intermediary nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable3_extra_node_1> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_1> .

<https://example.com/intermediaryNode1_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node 1"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservable <https://example.com/observable4> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_1> .

<https://example.com/multiplexNode1_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node 1"@en ;
  rdfs:comment "A multiplex node connecting multiple types of network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable5> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_1> .

<https://example.com/superNode1_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Super Node 1"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable6> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_1> .

<https://example.com/observable1_extra_node_1> a noria:StructuralObservable ;
  rdfs:label "Observable 1"@en ;
  rdfs:comment "Observable property for high-degree node connectivity."@en .

<https://example.com/observable2_extra_node_1> a noria:StructuralObservable ;
  rdfs:label "Observable 2"@en ;
  rdfs:comment "Observable property for central node activity."@en .

<https://example.com/observable3_extra_node_1> a noria:StructuralObservable ;
  rdfs:label "Observable 3"@en ;
  rdfs:comment "Observable property for connector node status."@en .

<https://example.com/observable4> a noria:StructuralObservable ;
  rdfs:label "Observable 4"@en ;
  rdfs:comment "Observable property for intermediary node load."@en .

<https://example.com/observable5> a noria:StructuralObservable ;
  rdfs:label "Observable 5"@en ;
  rdfs:comment "Observable property for multiplex node throughput."@en .

<https://example.com/observable6> a noria:StructuralObservable ;
  rdfs:label "Observable 6"@en ;
  rdfs:comment "Observable property for super node aggregation level."@en .

<https://example.com/organization1_extra_node_1> a org:Organization ;
  rdfs:label "Network Management Org"@en ;
  rdfs:comment "Organization responsible for network nodes."@en .

<https://example.com/connectorNode2_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Connector Node 2"@en ;
  rdfs:comment "A connector node linking high-degree nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable7> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_1> .

<https://example.com/observable7> a noria:StructuralObservable ;
  rdfs:label "Observable 7"@en ;
  rdfs:comment "Observable property for connector node connectivity."@en .

<https://example.com/multiplexNode2_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node 2"@en ;
  rdfs:comment "A multiplex node with multiple connection types."@en ;
  noria:structuralElementObservable <https://example.com/observable8> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_1> .

<https://example.com/observable8> a noria:StructuralObservable ;
  rdfs:label "Observable 8"@en ;
  rdfs:comment "Observable property for multiplex node throughput."@en .

<https://example.com/superNode2_extra_node_1> a noria:StructuralElement ;
  rdfs:label "Super Node 2"@en ;
  rdfs:comment "An advanced super node aggregating multiple hubs."@en ;
  noria:structuralElementObservable <https://example.com/observable9> ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_1> .

<https://example.com/observable9> a noria:StructuralObservable ;
  rdfs:label "Observable 9"@en ;
  rdfs:comment "Observable property for super node activity."@en .
