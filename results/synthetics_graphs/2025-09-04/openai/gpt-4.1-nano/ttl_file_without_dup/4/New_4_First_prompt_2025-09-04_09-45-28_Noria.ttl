  noria:applicationModelIdentifier "BMA-2023" ;
  noria:applicationNumericalIdentifier 102 ;
  noria:applicationShortIdentifier "BMA" ;
  noria:applicationType <http://w3id.org/noria/kos/application/type/Management> ;
  noria:applicationBusinessImportance <http://w3id.org/noria/kos/application/business-importance/Medium> ;
  noria:applicationFunctionalDomain "Disaster Recovery" .

<https://example.com/HubNode3_extra_node_4> a noria:ManagedElement ;
