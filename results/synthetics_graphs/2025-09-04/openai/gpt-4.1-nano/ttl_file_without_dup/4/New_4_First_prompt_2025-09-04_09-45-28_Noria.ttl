@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/hubNode1_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "Central hub node with high connectivity, linking multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/organization1_extra_node_4> a org:Organization ;
  rdfs:label "Network Operations Center"@en ;
  rdfs:comment "Primary organization managing the network infrastructure."@en .

<https://example.com/highDegreeNode1_extra_node_4> a noria:ManagedElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "Node with high degree of connections, acting as a connector in the network."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/centralNode1_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "Node serving as a central point in the network topology."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/connectorNode1_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "Node connecting different network segments."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/intermediaryNode1_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "Node acting as an intermediary in data flow."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/multiplexNode1_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/superNode1_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "Super node aggregating multiple nodes."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Resource A"@en ;
  rdfs:comment "Core network resource responsible for data routing."@en ;
  noria:resourceManagedBy <https://example.com/organization1_extra_node_4> ;
  noria:locatedAtLocus <https://example.com/Locus1_extra_node_4> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Resource B"@en ;
  rdfs:comment "Backup server resource."@en ;
  noria:resourceManagedBy <https://example.com/organization1_extra_node_4> ;
  noria:locatedAtLocus <https://example.com/Locus2_extra_node_4> .

<https://example.com/Locus1_extra_node_4> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main server room location."@en ;
  noria:locusLine "Line:L, in Room:Server room 314" .

<https://example.com/Locus2_extra_node_4> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Secondary server room location."@en ;
  noria:locusLine "Line:L, in Room:Backup room 215" .

<https://example.com/NetworkLink1_extra_node_4> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between Resource A and Resource B."@en ;
  noria:networkLinkId "FiberLink-001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical fiber" .

<https://example.com/NetworkInterfaceA> a noria:NetworkInterface ;
  rdfs:label "Interface eth0"@en ;
  rdfs:comment "Primary network interface of Resource A."@en ;
  noria:networkInterfaceType "physical" ;
  noria:networkInterfaceOf <https://example.com/ResourceA> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1_extra_node_4> .

<https://example.com/NetworkInterfaceB> a noria:NetworkInterface ;
  rdfs:label "Interface eth1"@en ;
  rdfs:comment "Backup network interface of Resource B."@en ;
  noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOf <https://example.com/ResourceB> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1_extra_node_4> .

<https://example.com/Event1_extra_node_4> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating the network link is operational."@en ;
  noria:loggingTime "2023-10-01T12:00:00"^^xsd:dateTime ;
  noria:logText "Fiber Link 1 is now active." ;
  noria:logOriginatingManagedObject <https://example.com/NetworkLink1_extra_node_4> ;
  noria:alarmSeverity <http://www.w3.org/ns/seas#Warning> .

<https://example.com/Event2> a noria:EventRecord ;
  rdfs:label "Link Down Event"@en ;
  rdfs:comment "Event indicating the network link failure."@en ;
  noria:loggingTime "2023-10-02T09:30:00"^^xsd:dateTime ;
  noria:logText "Fiber Link 1 has failed." ;
  noria:logOriginatingManagedObject <https://example.com/NetworkLink1_extra_node_4> ;
  noria:alarmSeverity <http://www.w3.org/ns/seas#Critical> .

<https://example.com/Service1> a noria:Service ;
  rdfs:label "Data Routing Service"@en ;
  rdfs:comment "Core data routing service in the network."@en ;
  noria:serviceType <http://w3id.org/noria/kos/service/type/ResourceFacingService> ;
  rdfs:seeAlso <https://github.com/tmforum-apis/TMF638_ServiceInventory> .

<https://example.com/Application1> a noria:Application ;
  rdfs:label "Network Management Application"@en ;
  rdfs:comment "Application managing network resources."@en ;
  noria:applicationModelIdentifier "NMA-2023" ;
  noria:applicationNumericalIdentifier 101 ;
  noria:applicationShortIdentifier "NMA" ;
  noria:applicationType <http://w3id.org/noria/kos/application/type/Management> ;
  noria:applicationBusinessImportance <http://w3id.org/noria/kos/application/business-importance/High> ;
  noria:applicationFunctionalDomain "Network Operations" .

<https://example.com/HubNode2_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Secondary Hub Node"@en ;
  rdfs:comment "Backup hub node with high connectivity."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/IntermediaryNode2_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Intermediary Node 2"@en ;
  rdfs:comment "Intermediate node facilitating data flow."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/SuperNode2_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Super Node 2"@en ;
  rdfs:comment "Aggregated super node for network management."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/ConnectorNode2_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Connector Node 2"@en ;
  rdfs:comment "Node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/MultiplexNode2_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Multiplex Node 2"@en ;
  rdfs:comment "Node multiplexing multiple data streams."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/CentralNode2_extra_node_4> a noria:ManagedElement ;
  rdfs:label "Central Node 2"@en ;
  rdfs:comment "Central node in a different network segment."@en ;
  noria:elementManagedBy <https://example.com/organization1_extra_node_4> .

<https://example.com/ResourceC> a noria:Resource ;
  rdfs:label "Resource C"@en ;
  rdfs:comment "Secondary resource for load balancing."@en ;
  noria:resourceManagedBy <https://example.com/organization1_extra_node_4> ;
  noria:locatedAtLocus <https://example.com/Locus3> .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Locus 3"@en ;
  rdfs:comment "Backup server location."@en ;
  noria:locusLine "Line:L, in Backup Room 215" .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Fiber Link 2"@en ;
  rdfs:comment "Secondary optical fiber link."@en ;
  noria:networkLinkId "FiberLink-002" ;
  noria:networkLinkInstallationDate "2022-02-20T11:00:00"^^xsd:dateTime ;
  noria:networkLinkType "Optical fiber" .

<https://example.com/Event3> a noria:EventRecord ;
  rdfs:label "Link Repaired Event"@en ;
  rdfs:comment "Event indicating the network link has been repaired."@en ;
  noria:loggingTime "2023-10-03T14:00:00"^^xsd:dateTime ;
  noria:logText "Fiber Link 2 is now operational." ;
  noria:logOriginatingManagedObject <https://example.com/NetworkLink2> ;
  noria:alarmSeverity <http://www.w3.org/ns/seas#Warning> .

<https://example.com/Service2> a noria:Service ;
  rdfs:label "Backup Data Service"@en ;
  rdfs:comment "Secondary data service for redundancy."@en ;
  noria:serviceType <http://w3id.org/noria/kos/service/type/ResourceFacingService> .

<https://example.com/Application2> a noria:Application ;
  rdfs:label "Backup Management Application"@en ;
