@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix prov: <http://www.w3.org/ns/prov#> .

<https://example.com/hubNode1_extra_node_7> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/highDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a switch in the core network."@en ;
  noria:structuralElementObservable <https://example.com/observable/connectionCount> ;
  noria:elementManagedBy <https://example.com/NetworkOperationsTeam> .

<https://example.com/centralNode1> a noria:StructuralElement ;
  rdfs:label "Central Server"@en ;
  rdfs:comment "A central node with high connectivity, serving as a data aggregation point."@en ;
  noria:structuralElementObservable <https://example.com/observable/serverLoad> ;
  noria:elementManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/connectorNode1> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking internal and external networks."@en ;
  noria:structuralElementObservable <https://example.com/observable/trafficFlow> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic among servers."@en ;
  noria:structuralElementObservable <https://example.com/observable/trafficDistribution> ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/multiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexer"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/superNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An overarching super node managing multiple sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable/superNodeStatus> ;
  noria:elementManagedBy <https://example.com/ManagementBoard> .

<https://example.com/NetworkOperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team providing technical support for servers and applications."@en .

<https://example.com/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team managing security devices and policies."@en .

<https://example.com/OperationsTeam> a org:OrganizationalUnit ;
  rdfs:label "Operations Team"@en ;
  rdfs:comment "Team overseeing operational aspects of network devices."@en .

<https://example.com/ManagementBoard> a org:OrganizationalUnit ;
  rdfs:label "Management Board"@en ;
  rdfs:comment "Oversees high-level management of network infrastructure."@en .

<https://example.com/observable/connectionCount> a noria:StructuralObservable ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections at the node."@en .

<https://example.com/observable/serverLoad> a noria:StructuralObservable ;
  rdfs:label "Server Load"@en ;
  rdfs:comment "Current load percentage of the server."@en .

<https://example.com/observable/trafficFlow> a noria:StructuralObservable ;
  rdfs:label "Traffic Flow"@en ;
  rdfs:comment "Traffic volume passing through the node."@en .

<https://example.com/observable/trafficDistribution> a noria:StructuralObservable ;
  rdfs:label "Traffic Distribution"@en ;
  rdfs:comment "Distribution ratio of traffic among different servers."@en .

<https://example.com/observable/streamCount> a noria:StructuralObservable ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/observable/superNodeStatus> a noria:StructuralObservable ;
  rdfs:label "Super Node Status"@en ;
  rdfs:comment "Operational status of the super node."@en .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Resource 1"@en ;
  rdfs:comment "A network resource, such as a server or switch."@en ;
  noria:resourceLogisticId "RES-001" ;
  noria:resourceHostName "server1.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/server> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/operational> ;
  noria:locatedAtLocus <https://example.com/locus1> ;
  noria:resourceProductModel <https://example.com/ProductModel1> ;
  noria:agentManagesResource <https://example.com/ITSupportTeam> .

<https://example.com/locus1> a noria:Locus ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "Primary data center location."@en .

<https://example.com/ProductModel1> a noria:ProductModel ;
  rdfs:label "Dell PowerEdge R740"@en ;
  rdfs:comment "Dell server model R740."@en ;
  noria:productManufacturedBy <https://example.com/DellInc> .

<https://example.com/DellInc> a org:Organization ;
  rdfs:label "Dell Inc."@en ;
  rdfs:comment "Manufacturer of Dell PowerEdge servers."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Optic Link A-B"@en ;
  rdfs:comment "Optical fiber link between Data Center A and B."@en ;
  noria:networkLinkId "NL-AB-001" ;
  noria:networkLinkInstallationDate "2019-03-20T09:00:00Z"^^xsd:dateTime .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Ethernet Link B-C"@en ;
  rdfs:comment "Ethernet connection between Data Center B and C."@en ;
  noria:networkLinkId "NL-BC-002" ;
  noria:networkLinkInstallationDate "2020-07-10T11:00:00Z"^^xsd:dateTime .

<https://example.com/connectorNode2> a noria:StructuralElement ;
  rdfs:label "Firewall Node"@en ;
  rdfs:comment "Firewall node connecting internal network to external."@en ;
  noria:structuralElementObservable <https://example.com/observable/trafficFlow> ;
  noria:elementManagedBy <https://example.com/SecurityTeam> .

<https://example.com/intermediaryNode2> a noria:StructuralElement ;
  rdfs:label "Load Balancer 2"@en ;
  rdfs:comment "Distributes incoming traffic to backend servers."@en ;
  noria:structuralElementObservable <https://example.com/observable/trafficDistribution> ;
  noria:elementManagedBy <https://example.com/OperationsTeam> .

<https://example.com/multiplexNode2> a noria:StructuralElement ;
  rdfs:label "Data Stream Multiplexer"@en ;
  rdfs:comment "Multiplexes multiple data streams for transmission."@en ;
  noria:structuralElementObservable <https://example.com/observable/streamCount> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/superNode2> a noria:StructuralElement ;
  rdfs:label "Global Super Node"@en ;
  rdfs:comment "Super node managing multiple sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/observable/superNodeStatus> ;
  noria:elementManagedBy <https://example.com/ManagementBoard> .