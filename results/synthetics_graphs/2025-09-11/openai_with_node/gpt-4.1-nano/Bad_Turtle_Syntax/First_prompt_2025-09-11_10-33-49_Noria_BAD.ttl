@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Hub Node: Central Application System
<https://example.com/centralApp> a noria:Application ;
  rdfs:label "Central Application System"@en ;
  rdfs:comment "Main application coordinating network monitoring and incident management."@en ;
  noria:applicationType <kos/application/type/ManagementSystem> ;
  noria:applicationShortIdentifier "CentralApp" ;
  noria:applicationModelIdentifier "ModelX-2023" .

# High-Degree Node: Network Infrastructure Hub
<https://example.com/NetworkHub> a noria:Resource ;
  rdfs:label "Network Infrastructure Hub"@en ;
  rdfs:comment "Core network infrastructure resource connecting multiple network segments."@en ;
  noria:resourceType <kos/Resource/type/NetworkDevice> ;
  noria:locatedAtLocus <https://example.com/RoomA> ;
  noria:resourceSerialNumber "SN-987654" ;
  noria:resourceLogisticId "LOG-12345" .

# Connector Node: Router1
<https://example.com/Router1> a noria:StructuralElement, noria:Resource ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Main router connecting internal network to external ISP."@en ;
  noria:resourceType <kos/Resource/type/Router> ;
  noria:resourceSerialNumber "R-001" ;
  noria:locatedAtLocus <https://example.com/RoomA> ;
  noria:resourceHostName "router1.company.com" .

# Intermediary Node: Link between Router1 and Switch1
<https://example.com/Link_R1_Switch1> a noria:NetworkLink ;
  rdfs:label "Link R1 to Switch1"@en ;
  rdfs:comment "Optical fiber link connecting Router1 to Switch1."@en ;
  noria:networkLinkId "NL-0001" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkTerminationResource <https://example.com/Router1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Switch1> .

# Multiplex Node: Application Module for Logging
<https://example.com/LogModule> a noria:ApplicationModule ;
  rdfs:label "Logging Module"@en ;
  rdfs:comment "Application module responsible for centralized logging."@en ;
  noria:applicationModuleIdentifier "LogMod-01" ;
  noria:applicationModuleName "Central Logging Module" ;
  noria:applicationModuleStatus <skos:Concept/Active> ;
  noria:applicationModuleSlaLevel <skos:Concept/Gold> ;
  noria:applicationModuleHotlineEnabled true .

# Super Node: Enterprise Network System
<https://example.com/EnterpriseNetwork> a noria:StructuralElement, noria:ManagedElement ;
  rdfs:label "Enterprise Network System"@en ;
  rdfs:comment "Super node representing the entire enterprise network infrastructure."@en ;
  noria:structuralElementDistinguishedName "ENT-NET-001" .

# Connector Node: Incident Trouble Ticket
<https://example.com/Ticket123> a noria:TroubleTicket ;
  rdfs:label "Ticket #123"@en ;
  rdfs:comment "Reported incident affecting core router."@en ;
  rdfs:seeAlso <https://example.com/incidentDetails> ;
  noria:troubleTicketSeverity <skos:Concept/Critical> ;
  noria:troubleTicketType <skos:Concept/Failure> ;
  noria:troubleTicketOrigin <https://example.com/CustomerA> ;
  noria:troubleTicketDetectionDateTime "2024-03-15T14:30:00Z"^^xsd:dateTime ;
  noria:troubleTicketStatusCurrent <skos:Concept/InProgress> ;
  noria:troubleTicketImpacts <https://example.com/Router1> ;
  noria:troubleTicketRelatedResource <https://example.com/Router1> .

# Intermediary Node: Event Record for Router Failure
<https://example.com/EventRecord567> a noria:EventRecord ;
  rdfs:label "Router Failure Event"@en ;
  rdfs:comment "Event indicating failure of Router1."@en ;
  noria:loggingTime "2024-03-15T14:31:00Z"^^xsd:dateTime ;
  noria:logText "Router1 has gone down unexpectedly."@en ;
  noria:logOriginatingManagedObject <https://example.com/Router1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:alarmSeverity <skos:Concept/Critical> ;
  noria:alarmMitigatedBy <https://example.com/Procedure123> .

# Connector Node: Procedure for Router Recovery
<https://example.com/Procedure123> a pep:Procedure ;
  rdfs:label "Router Recovery Procedure"@en ;
  rdfs:comment "Procedure to restore Router1 operation."@en ;
  rdfs:seeAlso <https://example.com/RecoverySteps> .

# Intermediary Node: Change Request for Router Firmware Update
<https://example.com/ChangeReq456> a noria:ChangeRequest ;
  rdfs:label "Firmware Update for Router1"@en ;
  rdfs:comment "Scheduled firmware update to fix known bugs."@en ;
  noria:changeRequestCreationDateTime "2024-03-14T09:00:00Z"^^xsd:dateTime ;
  noria:changeRequestImpact <https://example.com/Router1> ;
  noria:changeRequestType <skos:Concept/SoftwareUpgrade> ;
  noria:changeRequestStatusCurrent <skos:Concept/Planned> ;
  noria:changeRequestActorParty <https://example.com/ITTeam> .

# Organization node: IT Support Team
<https://example.com/ITTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for network maintenance and incident response."@en .

# Resource node: Customer A
<https://example.com/CustomerA> a foaf:Agent ;
  rdfs:label "Customer A"@en ;
  rdfs:comment "Client reporting the incident."@en .

# Resource node: NMS System
<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System"@en ;
  rdfs:comment "System monitoring network devices."@en .

# Resource node: Switch1
<https://example.com/Switch1> a noria:StructuralElement, noria:Resource ;
  rdfs:label "Switch1"@en ;
  rdfs:comment "Core switch in data center."@en ;
  noria:resourceType <kos/Resource/type/Switch> ;
  noria:resourceSerialNumber "SW-1234" ;
  noria:locatedAtLocus <https://example.com/RoomA> .

# Location node: RoomA
<https://example.com/RoomA> a noria:Room ;
  rdfs:label "Server Room A"@en ;
  rdfs:comment "Main server room."@en .

# End of Graph