@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode1> a noria:ManagedElement ;
  rdfs:label "Core Router Hub"@en ;
  rdfs:comment "A high-degree central hub node connecting multiple network segments."@en ;
  noria:elementManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central switch."@en ;
  noria:structuralElementObservable <https://example.com/observable/PortStatus> ;
  noria:structuralObservableOf <https://example.com/ResourceSwitch1> .

<https://example.com/CentralNode1> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node within the data center connecting servers and storage."@en ;
  noria:structuralElementObservable <https://example.com/observable/TrafficLoad> ;
  noria:structuralObservableOf <https://example.com/ResourceSwitch2> .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/observable/LinkStatus> ;
  noria:structuralObservableOf <https://example.com/ResourceLink1> .

<https://example.com/IntermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Router"@en ;
  rdfs:comment "An intermediary node facilitating traffic between hubs."@en ;
  noria:structuralElementObservable <https://example.com/observable/PacketLoss> ;
  noria:structuralObservableOf <https://example.com/ResourceRouter1> .

<https://example.com/MultiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplexing Switch"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/observable/StreamThroughput> ;
  noria:structuralObservableOf <https://example.com/ResourceMux1> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple network components."@en ;
  noria:structuralElementObservable <https://example.com/observable/OverallHealth> ;
  noria:structuralObservableOf <https://example.com/ResourceSuper1> .

<https://example.com/ResourceSwitch1> a noria:Resource ;
  rdfs:label "Switch 1"@en ;
  rdfs:comment "A network switch serving as a high-degree node."@en ;
  noria:resourceLogisticId "SW-001" ;
  noria:resourceHostName "switch1.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/switch> ;
  noria:locatedAtLocus <https://example.com/Locus1> .

<https://example.com/ResourceSwitch2> a noria:Resource ;
  rdfs:label "Switch 2"@en ;
  rdfs:comment "A central switch within the data center."@en ;
  noria:resourceLogisticId "SW-002" ;
  noria:resourceHostName "switch2.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/switch> ;
  noria:locatedAtLocus <https://example.com/Locus2> .

<https://example.com/ResourceLink1> a noria:Resource ;
  rdfs:label "Link 1"@en ;
  rdfs:comment "A physical optical fiber link."@en ;
  noria:resourceLogisticId "LINK-001" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/link> ;
  noria:locatedAtLocus <https://example.com/Locus3> .

<https://example.com/ResourceRouter1> a noria:Resource ;
  rdfs:label "Router 1"@en ;
  rdfs:comment "An intermediary router node."@en ;
  noria:resourceLogisticId "RT-001" ;
  noria:resourceHostName "router1.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:locatedAtLocus <https://example.com/Locus4> .

<https://example.com/ResourceMux1> a noria:Resource ;
  rdfs:label "Mux 1"@en ;
  rdfs:comment "A multiplexing switch."@en ;
  noria:resourceLogisticId "MUX-001" ;
  noria:resourceHostName "mux1.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/mux> ;
  noria:locatedAtLocus <https://example.com/Locus5> .

<https://example.com/ResourceSuper1> a noria:Resource ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "An aggregated super node."@en ;
  noria:resourceLogisticId "SN-001" ;
  noria:resourceHostName "supernode.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/supernode> ;
  noria:locatedAtLocus <https://example.com/Locus6> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Locus in Server Room 314."@en ;
  noria:locusLine "L" ;
  noria:locusRow "6" .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Locus in Storage Room 2."@en ;
  noria:locusLine "A" ;
  noria:locusRow "3" .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Locus 3"@en ;
  rdfs:comment "Locus in Main Data Hall."@en ;
  noria:locusLine "M" ;
  noria:locusRow "1" .

<https://example.com/Locus4> a noria:Locus ;
  rdfs:label "Locus 4"@en ;
  rdfs:comment "Locus in Router Rack."@en ;
  noria:locusLine "R" ;
  noria:locusRow "2" .

<https://example.com/Locus5> a noria:Locus ;
  rdfs:label "Locus 5"@en ;
  rdfs:comment "Locus in Multiplexer Cabinet."@en ;
  noria:locusLine "M" ;
  noria:locusRow "5" .

<https://example.com/Locus6> a noria:Locus ;
  rdfs:label "Locus 6"@en ;
  rdfs:comment "Locus in Super Node Enclosure."@en ;
  noria:locusLine "S" ;
  noria:locusRow "1" .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/observable/PortStatus> a noria:StructuralObservable ;
  rdfs:label "Port Status"@en ;
  rdfs:comment "Status of network ports."@en .

<https://example.com/observable/TrafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/observable/LinkStatus> a noria:StructuralObservable ;
  rdfs:label "Link Status"@en ;
  rdfs:comment "Operational status of links."@en .

<https://example.com/observable/PacketLoss> a noria:StructuralObservable ;
  rdfs:label "Packet Loss"@en ;
  rdfs:comment "Packet loss rate."@en .

<https://example.com/observable/StreamThroughput> a noria:StructuralObservable ;
  rdfs:label "Stream Throughput"@en ;
  rdfs:comment "Data throughput rate."@en .

<https://example.com/observable/OverallHealth> a noria:StructuralObservable ;
  rdfs:label "Overall Network Health"@en ;
  rdfs:comment "Aggregated health status of the network."@en .