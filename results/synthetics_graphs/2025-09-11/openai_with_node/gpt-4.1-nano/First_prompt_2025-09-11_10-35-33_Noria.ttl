@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservable <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/Router1> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node with high centrality, critical for network operation."@en ;
  noria:structuralElementObservable <https://example.com/trafficVolume> ;
  noria:structuralObservableOf <https://example.com/ServerA> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/segmentConnections> ;
  noria:structuralObservableOf <https://example.com/SwitchX> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowRate> ;
  noria:structuralObservableOf <https://example.com/FirewallY> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/LoadBalancerZ> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple sub-nodes."@en ;
  noria:structuralElementObservable <https://example.com/subNodeCount> ;
  noria:structuralObservableOf <https://example.com/ClusterNode> .

<https://example.com/Router1> a noria:StructuralElement ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router in the network."@en ;
  noria:elementDistinguishedName "Router1" .

<https://example.com/ServerA> a noria:StructuralElement ;
  rdfs:label "ServerA"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:elementDistinguishedName "ServerA" .

<https://example.com/SwitchX> a noria:StructuralElement ;
  rdfs:label "SwitchX"@en ;
  rdfs:comment "Network switch connecting segments."@en ;
  noria:elementDistinguishedName "SwitchX" .

<https://example.com/FirewallY> a noria:StructuralElement ;
  rdfs:label "FirewallY"@en ;
  rdfs:comment "Security firewall device."@en ;
  noria:elementDistinguishedName "FirewallY" .

<https://example.com/LoadBalancerZ> a noria:StructuralElement ;
  rdfs:label "LoadBalancerZ"@en ;
  rdfs:comment "Load balancer distributing traffic."@en ;
  noria:elementDistinguishedName "LoadBalancerZ" .

<https://example.com/ClusterNode> a noria:StructuralElement ;
  rdfs:label "ClusterNode"@en ;
  rdfs:comment "Node in a server cluster."@en ;
  noria:elementDistinguishedName "ClusterNode" .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/trafficVolume> a noria:Property ;
  rdfs:label "Traffic Volume"@en ;
  rdfs:comment "Volume of network traffic in Mbps."@en .

<https://example.com/segmentConnections> a noria:Property ;
  rdfs:label "Segment Connections"@en ;
  rdfs:comment "Number of segment connections."@en .

<https://example.com/dataFlowRate> a noria:Property ;
  rdfs:label "Data Flow Rate"@en ;
  rdfs:comment "Rate of data flow in Mbps."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams handled."@en .

<https://example.com/subNodeCount> a noria:Property ;
  rdfs:label "Sub-Node Count"@en ;
  rdfs:comment "Number of sub-nodes in the super node."@en .

