@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Core Network Hub"@en ;
  rdfs:comment "A high-degree central node acting as a core hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "Main Router"@en ;
  rdfs:comment "A high-degree node with many connections, acting as a central router."@en ;
  noria:structuralElementObservableData <https://example.com/latency> ;
  noria:structuralElementDistinguishedName "Router-01" .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Data Center Switch"@en ;
  rdfs:comment "A central node connecting multiple network segments."@en ;
  noria:structuralElementObservableData <https://example.com/throughput> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Firewall Connector"@en ;
  rdfs:comment "A connector node linking different network zones."@en ;
  noria:structuralElementObservableData <https://example.com/connectionStatus> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Load Balancer"@en ;
  rdfs:comment "An intermediary node distributing traffic."@en ;
  noria:structuralElementObservableData <https://example.com/trafficLoad> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplexing Device"@en ;
  rdfs:comment "A multiplex node combining multiple data streams."@en ;
  noria:structuralElementObservableData <https://example.com/streamCount> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and central nodes."@en ;
  noria:structuralElementObservableData <https://example.com/aggregateTraffic> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Server A"@en ;
  rdfs:comment "A critical application server."@en ;
  noria:resourceLogisticId "SRV-A-001" ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceHostName "serverA.example.com" .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Router B"@en ;
  rdfs:comment "Edge router connecting to external network."@en ;
  noria:resourceLogisticId "RTR-B-002" ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:resourceHostName "routerB.example.com" .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Switch C"@en ;
  rdfs:comment "A core network switch."@en ;
  noria:resourceLogisticId "SWC-003" ;
  noria:locatedAtLocus <https://example.com/Locus3> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
  noria:resourceHostName "switchC.example.com" .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Server Room 1"@en ;
  rdfs:comment "Location of Server A."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Main Building"@en ;
  rdfs:comment "Location of Router B."@en .

<https://example.com/Locus3> a noria:Locus ;
  rdfs:label "Data Center"@en ;
  rdfs:comment "Location of Switch C."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber link between Server A and Switch C."@en ;
  noria:networkLinkId "NL-1001" ;
  noria:networkLinkType "Optical Fiber" .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "Ethernet Link 2"@en ;
  rdfs:comment "Ethernet connection between Router B and Switch C."@en ;
  noria:networkLinkId "NL-1002" ;
  noria:networkLinkType "Ethernet" .

<https://example.com/Resource1> noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .
<https://example.com/Resource2> noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .
<https://example.com/Resource3> noria:resourceManagedBy <https://example.com/NetworkOpsTeam> .

<https://example.com/NetworkOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Link Up Event"@en ;
  rdfs:comment "Event indicating fiber link is operational."@en ;
  noria:loggingTime "2024-03-15T10:00:00Z"^^xsd:dateTime ;
  noria:logText "Fiber link NL-1001 is now active." ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/NetworkMonitoringBot> ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Major> .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en .

<https://example.com/NetworkMonitoringBot> a foaf:Agent ;
  rdfs:label "NetMonBot"@en ;
  rdfs:comment "Automated network monitoring bot."@en .

<https://example.com/Alarm1> a noria:EventRecord ;
  rdfs:label "Link Down Alarm"@en ;
  rdfs:comment "Alarm indicating fiber link NL-1001 is down."@en ;
  noria:loggingTime "2024-03-15T09:55:00Z"^^xsd:dateTime ;
  noria:logText "Fiber link NL-1001 has failed." ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Critical> ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:logOriginatingAgent <https://example.com/NetworkMonitoringBot> .

<https://example.com/Resource1> noria:structuralElementObservable <https://example.com/latency> .
<https://example.com/Resource2> noria:structuralElementObservable <https://example.com/connectionStatus> .
<https://example.com/Resource3> noria:structuralElementObservable <https://example.com/trafficLoad> .

<https://example.com/latency> a noria:StructuralObservable ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency measurement."@en .

<https://example.com/connectionStatus> a noria:StructuralObservable ;
  rdfs:label "Connection Status"@en ;
  rdfs:comment "Status of network connection."@en .

<https://example.com/trafficLoad> a noria:StructuralObservable ;
  rdfs:label "Traffic Load"@en ;
  rdfs:comment "Current network traffic load."@en .

<https://example.com/NetworkLink1> noria:structuralElementObservable <https://example.com/latency> .
<https://example.com/NetworkLink2> noria:structuralElementObservable <https://example.com/connectionStatus> .

<https://example.com/Alarm1> a noria:EventRecord ;
  rdfs:label "Fiber Link Down Alarm"@en ;
  rdfs:comment "Critical alarm for fiber link failure."@en ;
  noria:loggingTime "2024-03-15T09:55:00Z"^^xsd:dateTime ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/Critical> .

