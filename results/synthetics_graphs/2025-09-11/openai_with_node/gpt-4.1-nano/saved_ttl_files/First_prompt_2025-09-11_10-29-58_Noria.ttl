@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/hubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a network hub."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/highDegreeNode> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector."@en ;
  noria:structuralElementObservable <https://example.com/connectionCount> ;
  noria:structuralObservableOf <https://example.com/Router1> .

<https://example.com/centralNode> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that is central to multiple network segments."@en ;
  noria:structuralElementObservable <https://example.com/latency> ;
  noria:structuralObservableOf <https://example.com/LinkA> .

<https://example.com/connectorNode> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A node connecting different network domains."@en ;
  noria:structuralElementObservable <https://example.com/connectionType> ;
  noria:structuralObservableOf <https://example.com/Firewall1> .

<https://example.com/intermediaryNode> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "A node acting as an intermediary in data flow."@en ;
  noria:structuralElementObservable <https://example.com/dataFlowStatus> ;
  noria:structuralObservableOf <https://example.com/Server2> .

<https://example.com/multiplexNode> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/streamCount> ;
  noria:structuralObservableOf <https://example.com/Multiplexer1> .

<https://example.com/superNode> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple nodes."@en ;
  noria:structuralElementObservable <https://example.com/aggregateTraffic> ;
  noria:structuralObservableOf <https://example.com/ClusterNode> .

<https://example.com/Router1> a noria:StructuralElement ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router in the network."@en ;
  noria:elementDistinguishedName "Router1" .

<https://example.com/Firewall1> a noria:StructuralElement ;
  rdfs:label "Firewall1"@en ;
  rdfs:comment "Firewall protecting the internal network."@en ;
  noria:elementDistinguishedName "Firewall1" .

<https://example.com/Server2> a noria:StructuralElement ;
  rdfs:label "Server2"@en ;
  rdfs:comment "Application server in the data center."@en ;
  noria:elementDistinguishedName "Server2" .

<https://example.com/Multiplexer1> a noria:StructuralElement ;
  rdfs:label "Multiplexer1"@en ;
  rdfs:comment "Device multiplexing multiple data streams."@en ;
  noria:elementDistinguishedName "Multiplexer1" .

<https://example.com/ClusterNode> a noria:StructuralElement ;
  rdfs:label "ClusterNode"@en ;
  rdfs:comment "A cluster of nodes for load balancing."@en ;
  noria:elementDistinguishedName "ClusterNode" .

<https://example.com/connectionCount> a noria:Property ;
  rdfs:label "Connection Count"@en ;
  rdfs:comment "Number of active connections."@en .

<https://example.com/latency> a noria:Property ;
  rdfs:label "Latency"@en ;
  rdfs:comment "Network latency in milliseconds."@en .

<https://example.com/connectionType> a noria:Property ;
  rdfs:label "Connection Type"@en ;
  rdfs:comment "Type of network connection (e.g., fiber, copper)."@en .

<https://example.com/dataFlowStatus> a noria:Property ;
  rdfs:label "Data Flow Status"@en ;
  rdfs:comment "Status of data flow (e.g., active, idle)."@en .

<https://example.com/streamCount> a noria:Property ;
  rdfs:label "Stream Count"@en ;
  rdfs:comment "Number of data streams multiplexed."@en .

<https://example.com/aggregateTraffic> a noria:Property ;
  rdfs:label "Aggregated Traffic"@en ;
  rdfs:comment "Total network traffic handled by super node."@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Network Administrator"@en ;
  rdfs:comment "Primary network administrator responsible for core nodes."@en .

<https://example.com/Connection1> a noria:NetworkLink ;
  rdfs:label "Connection1"@en ;
  rdfs:comment "Fiber link between Router1 and Server2."@en ;
  noria:networkLinkId "Link-001" .

<https://example.com/Connection2> a noria:NetworkLink ;
  rdfs:label "Connection2"@en ;
  rdfs:comment "Copper link between Firewall1 and Router1."@en ;
  noria:networkLinkId "Link-002" .

<https://example.com/Router1-Connection> a noria:NetworkLink ;
  rdfs:label "Router1-Connection"@en ;
  rdfs:comment "Connection from Router1 to Server2."@en ;
  noria:networkLinkId "Link-R1-S2" ;
  noria:networkLinkTerminationResource <https://example.com/Router1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Server2> .

<https://example.com/Firewall1-Connection> a noria:NetworkLink ;
  rdfs:label "Firewall1-Connection"@en ;
  rdfs:comment "Connection from Firewall1 to Router1."@en ;
  noria:networkLinkId "Link-FW-R1" ;
  noria:networkLinkTerminationResource <https://example.com/Firewall1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Router1> .

<https://example.com/HubNode> noria:elementManagedBy <https://example.com/NetworkTeam> .
<https://example.com/HighDegreeNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/CentralNode> noria:elementManagedBy <https://example.com/NetworkTeam> .
<https://example.com/ConnectorNode> noria:elementManagedBy <https://example.com/NetworkTeam> .
<https://example.com/IntermediaryNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/MuxNode> noria:elementManagedBy <https://example.com/NetworkAdmin> .
<https://example.com/SuperNode> noria:elementManagedBy <https://example.com/NetworkTeam> .

# End of graph