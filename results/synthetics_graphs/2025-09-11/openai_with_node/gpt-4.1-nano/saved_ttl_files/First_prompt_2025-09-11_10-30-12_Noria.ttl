# Additional nodes to create hubs, high-degree, central, connector, intermediary, multiplex, super nodes

<https://example.com/centralNode/Hub1> a noria:ManagedElement ;
    rdfs:label "Core Hub Node"@en ;
    rdfs:comment "Central node connecting multiple network segments."@en ;
    noria:elementManagedBy <https://example.com/org/NetOpsTeam> .

<https://example.com/connector/Connector1> a noria:ManagedElement ;
    rdfs:label "Connector Node"@en ;
    rdfs:comment "Node acting as a connector between different network domains."@en ;
    noria:elementManagedBy <https://example.com/org/NetOpsTeam> .

<https://example.com/intermediary/Intermediary1> a noria:ManagedElement ;
    rdfs:label "Intermediary Node"@en ;
    rdfs:comment "Node serving as an intermediary in data flow."@en ;
    noria:elementManagedBy <https://example.com/org/NetOpsTeam> .

<https://example.com/highDegree/HighDegreeNode> a noria:ManagedElement ;
    rdfs:label "High-Degree Node"@en ;
    rdfs:comment "Node with many connections, acting as a high-degree hub."@en ;
    noria:elementManagedBy <https://example.com/org/NetOpsTeam> .

<https://example.com/super/SuperNode> a noria:ManagedElement ;
    rdfs:label "Super Node"@en ;
    rdfs:comment "Super node aggregating multiple hubs and high-degree nodes."@en ;
    noria:elementManagedBy <https://example.com/org/NetOpsTeam> .

<https://example.com/multiplex/MuxNode> a noria:ManagedElement ;
    rdfs:label "Multiplex Node"@en ;
    rdfs:comment "Node multiplexing multiple data streams."@en ;
    noria:elementManagedBy <https://example.com/org/NetOpsTeam> .

# Link nodes to ensure no isolated nodes, e.g., connect hub to high-degree node and connector to hub

<https://example.com/centralNode/Hub1> noria:elementManagedBy <https://example.com/org/NetOpsTeam> ;
    noria:structuralElementObservable <https://example.com/highDegree/HighDegreeNode> .

<https://example.com/highDegree/HighDegreeNode> noria:elementManagedBy <https://example.com/org/NetOpsTeam> ;
    noria:structuralElementObservable <https://example.com/connector/Connector1> .

<https://example.com/connector/Connector1> noria:elementManagedBy <https://example.com/org/NetOpsTeam> ;
    noria:structuralElementObservable <https://example.com/intermediary/Intermediary1> .

<https://example.com/intermediary/Intermediary1> noria:elementManagedBy <https://example.com/org/NetOpsTeam> ;
    noria:structuralElementObservable <https://example.com/multiplex/MuxNode> .

<https://example.com/multiplex/MuxNode> noria:elementManagedBy <https://example.com/org/NetOpsTeam> ;
    noria:structuralElementObservable <https://example.com/super/SuperNode> .

<https://example.com/super/SuperNode> noria:elementManagedBy <https://example.com/org/NetOpsTeam> .

# Dismiss isolated nodes (none here), all nodes are linked via relations or managed by the same team.