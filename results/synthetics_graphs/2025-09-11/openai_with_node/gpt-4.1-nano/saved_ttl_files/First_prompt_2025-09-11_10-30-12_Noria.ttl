<https://w3id.org/noria/instance/Network1> a noria:StructuralElement ;
    rdfs:label "Main Data Center Network"@en ;
    rdfs:comment "Core network infrastructure for enterprise data center."@en ;
    noria:structuralElementDistinguishedName "DCN-01" ;
    noria:elementManagedBy <https://example.com/org/NetOpsTeam> ;
    noria:locatedAtLocus <https://example.com/locus/Room314> .

<https://example.com/org/NetOpsTeam> a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/locus/Room314> a noria:Locus ;
    rdfs:label "Server Room 314"@en ;
    rdfs:comment "Main server room on the 3rd floor."@en .

<https://example.com/resource/Switch01> a noria:Resource ;
    rdfs:label "Switch 01"@en ;
    rdfs:comment "Core switch in data center."@en ;
    noria:resourceSerialNumber "SN-DC-001" ;
    noria:resourceHostName "switch01.datacenter.local" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
    noria:resourceProductModel <https://example.com/model/ModelX> ;
    noria:resourceManagedBy <https://example.com/org/NetOpsTeam> ;
    noria:locatedAtLocus <https://example.com/locus/Room314> .

<https://example.com/model/ModelX> a noria:ProductModel ;
    rdfs:label "Model X"@en ;
    rdfs:comment "High-performance network switch model."@en ;
    noria:productManufacturedBy <https://example.com/org/NetEquipManufacturer> .

<https://example.com/org/NetEquipManufacturer> a org:Organization ;
    rdfs:label "NetEquip Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

<https://example.com/network/Link1> a noria:NetworkLink ;
    rdfs:label "Fiber Link DC to Building A"@en ;
    rdfs:comment "Optical fiber link connecting data center to Building A."@en ;
    noria:networkLinkId "NL-DC-A" ;
    noria:networkLinkType "Optical Fiber" ;
    noria:networkLinkInstallationDate "2022-01-15T09:00:00"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <https://example.com/resource/Switch01> ;
    noria:networkLinkTerminationResourceDestination <https://example.com/resource/RouterA> .

<https://example.com/resource/RouterA> a noria:Resource ;
    rdfs:label "Router A"@en ;
    rdfs:comment "Edge router in Building A."@en ;
    noria:resourceSerialNumber "SN-RT-A" ;
    noria:resourceHostName "routerA.buildingA.local" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceManagedBy <https://example.com/org/NetOpsTeam> ;
    noria:locatedAtLocus <https://example.com/locus/RoomA> .

<https://example.com/locus/RoomA> a noria:Locus ;
    rdfs:label "Room A"@en ;
    rdfs:comment "Network equipment room in Building A."@en .

<https://example.com/event/Event1> a noria:EventRecord ;
    rdfs:label "Link Up Event"@en ;
    rdfs:comment "Event indicating fiber link is operational."@en ;
    noria:loggingTime "2023-10-20T14:30:00"^^xsd:dateTime ;
    noria:logText "Fiber link NL-DC-A is now active."@en ;
    noria:logOriginatingManagedObject <https://example.com/network/Link1> ;
    noria:logOriginatingManagementSystem <https://example.com/sys/NetMonSys> .

<https://example.com/sys/NetMonSys> a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "System monitoring network links and devices."@en .

<https://example.com/event/Event2> a noria:EventRecord ;
