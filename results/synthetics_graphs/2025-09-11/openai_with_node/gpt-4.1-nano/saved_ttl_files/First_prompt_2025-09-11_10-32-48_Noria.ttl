@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<https://example.com/HubNode1> a noria:ManagedElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core hub in the network."@en ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en ;
  noria:structuralElementObservable <https://example.com/ResourceStatusObservable> ;
  noria:elementManagedBy <https://example.com/NetworkOperations> .

<https://example.com/CentralNode1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point for specific services."@en ;
  noria:structuralElementObservable <https://example.com/ServiceAvailability> ;
  noria:elementManagedBy <https://example.com/ITSupport> .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en ;
  noria:structuralElementObservable <https://example.com/LinkStatus> ;
  noria:elementManagedBy <https://example.com/NetworkTeam> .

<https://example.com/IntermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en ;
  noria:structuralElementObservable <https://example.com/IntermediaryStatus> ;
  noria:elementManagedBy <https://example.com/Operations> .

<https://example.com/MultiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en ;
  noria:structuralElementObservable <https://example.com/StreamLoad> ;
  noria:elementManagedBy <https://example.com/DataCenterOps> .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes."@en ;
  noria:structuralElementObservable <https://example.com/SuperNodeStatus> ;
  noria:elementManagedBy <https://example.com/NetworkManagement> .

<https://example.com/Resource1> a noria:Resource ;
  rdfs:label "Server01"@en ;
  rdfs:comment "Main application server."@en ;
  noria:resourceLogisticId "SN-001" ;
  noria:resourceHostName "server01.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagedBy <https://example.com/ITSupportTeam> .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "RouterA"@en ;
  rdfs:comment "Edge router for branch office."@en ;
  noria:resourceLogisticId "RT-045" ;
  noria:resourceHostName "routerA.branch.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/NetworkTeam> .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "FiberLink1"@en ;
  rdfs:comment "Optical fiber link between core hub and server."@en ;
  noria:networkLinkId "NL-1001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/HubNode1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource1> .

<https://example.com/NetworkLink2> a noria:NetworkLink ;
  rdfs:label "WirelessLink1"@en ;
  rdfs:comment "Wireless link connecting router to branch."@en ;
  noria:networkLinkId "NL-2002" ;
  noria:networkLinkType "Wireless" ;
  noria:networkLinkInstallationDate "2023-03-10T09:30:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource2> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource3> .

<https://example.com/Resource3> a noria:Resource ;
  rdfs:label "Switch01"@en ;
  rdfs:comment "Aggregation switch in branch office."@en ;
  noria:resourceLogisticId "SW-007" ;
  noria:resourceHostName "switch01.branch.example.com" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/NetworkOps> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Main Data Center"@en ;
  rdfs:comment "Primary data center location."@en .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Branch Office"@en ;
  rdfs:comment "Branch office location."@en .

<https://example.com/NetworkTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for network infrastructure."@en .

<https://example.com/ITSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team managing servers and applications."@en .

<https://example.com/NetworkOps> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Operational team for network devices."@en .

<https://example.com/Operations> a org:OrganizationalUnit ;
  rdfs:label "Operations Team"@en ;
  rdfs:comment "Team overseeing intermediary nodes."@en .

<https://example.com/DataCenterOps> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en ;
  rdfs:comment "Team managing super nodes and hubs."@en .

<https://example.com/SuperNodeStatus> a skos:Concept ;
  rdfs:label "Super Node Status"@en .

<https://example.com/StreamLoad> a skos:Concept ;
  rdfs:label "Stream Load"@en .

<https://example.com/IntermediaryStatus> a skos:Concept ;
  rdfs:label "Intermediary Status"@en .

<https://example.com/LinkStatus> a skos:Concept ;
  rdfs:label "Link Status"@en .

<https://example.com/ResourceStatusObservable> a noria:StructuralObservable ;
  rdfs:label "Resource Status Observable"@en .

<https://example.com/ServiceAvailability> a noria:StructuralObservable ;
  rdfs:label "Service Availability"@en .

<https://example.com/ResourceStatusObservable> a noria:StructuralObservable ;
  rdfs:label "Resource Status Observable"@en .

<https://example.com/NetworkManagement> a org:OrganizationalUnit ;
  rdfs:label "Network Management"@en .

<https://example.com/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en .

<https://example.com/NetworkOperations> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en .

<https://example.com/Operations> a org:OrganizationalUnit ;
  rdfs:label "Operations"@en .

<https://example.com/DataCenterOps> a org:OrganizationalUnit ;
  rdfs:label "Data Center Operations"@en .

<https://example.com/HubNode1> a noria:StructuralElement ;
  rdfs:label "Core Hub Node"@en ;
  rdfs:comment "A high-degree central node acting as a core hub in the network."@en .

<https://example.com/HighDegreeNode1> a noria:StructuralElement ;
  rdfs:label "High-Degree Node"@en ;
  rdfs:comment "A node with many connections, acting as a connector in the network."@en .

<https://example.com/CentralNode1> a noria:StructuralElement ;
  rdfs:label "Central Node"@en ;
  rdfs:comment "A node that acts as a central point for specific services."@en .

<https://example.com/ConnectorNode1> a noria:StructuralElement ;
  rdfs:label "Connector Node"@en ;
  rdfs:comment "A connector node linking different network segments."@en .

<https://example.com/IntermediaryNode1> a noria:StructuralElement ;
  rdfs:label "Intermediary Node"@en ;
  rdfs:comment "An intermediary node facilitating data flow."@en .

<https://example.com/MultiplexNode1> a noria:StructuralElement ;
  rdfs:label "Multiplex Node"@en ;
  rdfs:comment "A multiplex node handling multiple data streams."@en .

<https://example.com/SuperNode1> a noria:StructuralElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple hubs and high-degree nodes."@en .