@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# Entities
<https://example.com/Entity1> a noria:ManagedElement ;
  rdfs:label "Core Router"@en ;
  rdfs:comment "A high-capacity core router acting as a central hub in the network."@en ;
  noria:elementManagedBy <https://example.com/Org1> .

<https://example.com/Entity2> a noria:StructuralElement ;
  rdfs:label "Main Switch"@en ;
  rdfs:comment "A high-degree switch connecting multiple network segments."@en ;
  noria:structuralElementDistinguishedName "Switch-01" .

<https://example.com/Entity3> a noria:FunctionalElement ;
  rdfs:label "Firewall Service"@en ;
  rdfs:comment "A critical security service providing firewall functionalities."@en .

<https://example.com/Entity4> a noria:Application ;
  rdfs:label "Customer Portal"@en ;
  rdfs:comment "Web application for customer interactions."@en ;
  noria:applicationType <https://w3id.org/noria/kos/application/type/customer-facing> .

<https://example.com/Entity5> a noria:Resource ;
  rdfs:label "Database Server"@en ;
  rdfs:comment "A virtualized database server hosting customer data."@en ;
  noria:resourceSerialNumber "DBS-2023-XYZ" .

<https://example.com/Entity6> a noria:Resource ;
  rdfs:label "Backup Storage"@en ;
  rdfs:comment "Storage resource for backups."@en ;
  noria:resourceLogisticId "STORAGE-001" .

<https://example.com/Entity7> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface."@en ;
  noria:networkInterfaceType "physical" .

<https://example.com/Entity8> a noria:NetworkLink ;
  rdfs:label "Link1"@en ;
  rdfs:comment "Optical fiber link between core router and main switch."@en ;
  noria:networkLinkId "LINK-001" .

<https://example.com/Org1> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Operations team responsible for network infrastructure."@en .

# Relationships
<https://example.com/Entity1> noria:elementManagedBy <https://example.com/Org1> ;
  rdfs:label "Managed by Network Operations"@en ;
  rdfs:comment "Managed by the Network Operations team."@en .

<https://example.com/Entity2> noria:structuralElementObservable <https://example.com/Entity2Obs> .

<https://example.com/Entity2Obs> a noria:StructuralObservable ;
  rdfs:label "Switch Status"@en ;
  rdfs:comment "Observable property indicating the status of the main switch."@en .

<https://example.com/Entity3> noria:elementProperty <https://example.com/FirewallStatus> .

<https://example.com/FirewallStatus> a noria:Property ;
  rdfs:label "Firewall Operational Status"@en ;
  rdfs:comment "Indicates whether the firewall service is active or inactive."@en .

<https://example.com/Entity4> noria:applicationType <https://w3id.org/noria/kos/application/type/customer-facing> ;
  rdfs:label "Application Type"@en ;
  rdfs:comment "Type of application, e.g., customer-facing."@en .

<https://example.com/Entity4> noria:resourceForApplication <https://example.com/Entity4> .

<https://example.com/Entity5> noria:resourceSerialNumber "DBS-2023-XYZ" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/database> .

<https://example.com/Entity6> noria:resourceLogisticId "STORAGE-001" .

<https://example.com/Entity7> noria:networkInterfaceType "virtual" ;
  noria:networkInterfaceOf <https://example.com/Entity5> .

<https://example.com/Entity8> noria:networkLinkId "LINK-001" ;
  noria:networkLinkTerminationResource <https://example.com/Entity1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Entity2> .

# Additional Nodes to create hubs, hubs with high degree, central nodes, etc.
<https://example.com/HubNode> a noria:ManagedElement ;
  rdfs:label "Main Hub Node"@en ;
  rdfs:comment "A hub node connecting multiple network components."@en ;
  noria:elementManagedBy <https://example.com/Org1> .

<https://example.com/HighDegreeNode> a noria:StructuralElement ;
  rdfs:label "High Degree Switch"@en ;
  rdfs:comment "A switch with high connectivity in the network."@en ;
  noria:structuralElementDistinguishedName "Switch-HighDegree" .

<https://example.com/CentralNode> a noria:FunctionalElement ;
  rdfs:label "Central Firewall"@en ;
  rdfs:comment "A central security node."@en .

<https://example.com/ConnectorNode> a noria:Resource ;
  rdfs:label "Connector Resource"@en ;
  rdfs:comment "A resource acting as a connector between different network segments."@en .

<https://example.com/IntermediaryNode> a noria:Application ;
  rdfs:label "Intermediary Application"@en ;
  rdfs:comment "An application mediating between services."@en .

<https://example.com/MuxNode> a noria:Resource ;
  rdfs:label "Multiplex Resource"@en ;
  rdfs:comment "A resource multiplexing multiple functions."@en .

<https://example.com/SuperNode> a noria:ManagedElement ;
  rdfs:label "Super Node"@en ;
  rdfs:comment "A super node aggregating multiple network elements."@en .

# Link nodes to ensure no isolated nodes
<https://example.com/HubNode> noria:elementManagedBy <https://example.com/Org1> .
<https://example.com/HighDegreeNode> noria:structuralElementObservable <https://example.com/HighDegreeObs> .

<https://example.com/HighDegreeObs> a noria:StructuralObservable ;
  rdfs:label "High Degree Switch Status"@en ;
  rdfs:comment "Observable for high degree switch."@en .

<https://example.com/CentralNode> noria:elementManagedBy <https://example.com/Org1> .

<https://example.com/ConnectorNode> noria:elementManagedBy <https://example.com/Org1> .

<https://example.com/IntermediaryNode> noria:elementManagedBy <https://example.com/Org1> .

<https://example.com/MuxNode> noria:elementManagedBy <https://example.com/Org1> .

<https://example.com/SuperNode> noria:elementManagedBy <https://example.com/Org1> .

# End of graph