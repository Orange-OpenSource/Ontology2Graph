@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/Network1> a noria:StructuralElement ;
  rdfs:label "Main Data Center Network"@en ;
  rdfs:comment "Core network infrastructure for enterprise data center."@en ;
  noria:structuralElementDistinguishedName "DCN-001" ;
  noria:elementManagedBy <https://example.com/Org/NetOpsTeam> ;
  noria:locatedAtLocus <https://example.com/Locus/Room314> .

<https://example.com/Org/NetOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations Team"@en ;
  rdfs:comment "Team responsible for managing network infrastructure."@en .

<https://example.com/Locus/Room314> a noria:Locus ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Main server room on 3rd floor."@en .

<https://example.com/Resource/Router1> a noria:Resource ;
  rdfs:label "Router1"@en ;
  rdfs:comment "Core router in data center."@en ;
  noria:resourceSerialNumber "SN-RT-314" ;
  noria:resourceHostName "router1.datacenter.local" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasValue "Router" ] ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelX> ;
  noria:locatedAtLocus <https://example.com/Locus/Room314> ;
  noria:resourceManagedBy <https://example.com/Org/NetOpsTeam> .

<https://example.com/ProductModel/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance enterprise router model."@en ;
  noria:productManufacturedBy <https://example.com/Org/RouterMakers> .

<https://example.com/Org/RouterMakers> a org:Organization ;
  rdfs:label "Router Manufacturer Inc."@en ;
  rdfs:comment "Manufacturer of Model X routers."@en .

<https://example.com/NetworkLink/Link1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Router1 and Router2."@en ;
  noria:networkLinkId "NL-001" ;
  noria:networkLinkType "Optical Fiber" ;
  noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource/Router1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource/Router2> .

<https://example.com/Resource/Router2> a noria:Resource ;
  rdfs:label "Router2"@en ;
  rdfs:comment "Backup core router."@en ;
  noria:resourceSerialNumber "SN-RT-315" ;
  noria:resourceHostName "router2.datacenter.local" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasValue "Router" ] ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelY> ;
  noria:locatedAtLocus <https://example.com/Locus/Room314> ;
  noria:resourceManagedBy <https://example.com/Org/NetOpsTeam> .

<https://example.com/ProductModel/ModelY> a noria:ProductModel ;
  rdfs:label "Model Y"@en ;
  rdfs:comment "Backup router model."@en ;
  noria:productManufacturedBy <https://example.com/Org/RouterMakers> .

<https://example.com/Resource/Firewall1> a noria:Resource ;
  rdfs:label "Firewall1"@en ;
  rdfs:comment "Perimeter firewall device."@en ;
  noria:resourceSerialNumber "SN-FW-001" ;
  noria:resourceHostName "firewall.datacenter.local" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasValue "Firewall" ] ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelZ> ;
  noria:locatedAtLocus <https://example.com/Locus/Room314> ;
  noria:resourceManagedBy <https://example.com/Org/SecurityTeam> .

<https://example.com/ProductModel/ModelZ> a noria:ProductModel ;
  rdfs:label "Model Z"@en ;
  rdfs:comment "Enterprise firewall device."@en ;
  noria:productManufacturedBy <https://example.com/Org/FirewallMakers> .

<https://example.com/Org/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Operations"@en ;
  rdfs:comment "Team responsible for security devices."@en .

<https://example.com/Resource/Server1> a noria:Resource ;
  rdfs:label "Server1"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:resourceSerialNumber "SN-SRV-101" ;
  noria:resourceHostName "appserver1.datacenter.local" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasValue "Server" ] ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelA> ;
  noria:locatedAtLocus <https://example.com/Locus/Room314> ;
  noria:resourceManagedBy <https://example.com/Org/ITSupport> .

<https://example.com/ProductModel/ModelA> a noria:ProductModel ;
  rdfs:label "Model A"@en ;
  rdfs:comment "Application server model A."@en ;
  noria:productManufacturedBy <https://example.com/Org/ServerMakers> .

<https://example.com/Org/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support"@en ;
  rdfs:comment "Support team for enterprise IT infrastructure."@en .

<https://example.com/Resource/Server2> a noria:Resource ;
  rdfs:label "Server2"@en ;
  rdfs:comment "Backup application server."@en ;
  noria:resourceSerialNumber "SN-SRV-102" ;
  noria:resourceHostName "backupappserver.datacenter.local" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasValue "Server" ] ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelA> ;
  noria:locatedAtLocus <https://example.com/Locus/Room314> ;
  noria:resourceManagedBy <https://example.com/Org/ITSupport> .

<https://example.com/Resource/LoadBalancer1> a noria:Resource ;
  rdfs:label "LoadBalancer1"@en ;
  rdfs:comment "Load balancer for web services."@en ;
  noria:resourceSerialNumber "SN-LB-001" ;
  noria:resourceHostName "loadbalancer.datacenter.local" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasValue "LoadBalancer" ] ;
  noria:resourceProductModel <https://example.com/ProductModel/ModelLB> ;
  noria:locatedAtLocus <https://example.com/Locus/Room314> ;
  noria:resourceManagedBy <https://example.com/Org/ITSupport> .

<https://example.com/ProductModel/ModelLB> a noria:ProductModel ;
  rdfs:label "Model LB"@en ;
  rdfs:comment "Load balancer model LB."@en ;
  noria:productManufacturedBy <https://example.com/Org/LoadBalancerMakers> .

<https://example.com/Org/LoadBalancerMakers> a org:Organization ;
  rdfs:label "Load Balancer Inc."@en ;
  rdfs:comment "Manufacturer of load balancer devices."@en .

<https://example.com/Org/FirewallMakers> a org:Organization ;
  rdfs:label "Firewall Corp."@en ;
  rdfs:comment "Manufacturer of firewall devices."@en .

<https://example.com/Org/ServerMakers> a org:Organization ;
  rdfs:label "Server Mfg."@en ;
  rdfs:comment "Server hardware manufacturer."@en .

<https://example.com/Org/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Team responsible for general IT support."@en .

<https://example.com/Org/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Operations"@en ;
  rdfs:comment "Security management team."@en .

<https://example.com/Org/NetOpsTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Operations"@en ;
  rdfs:comment "Network management team."@en .

<https://example.com/Org/LoadBalancerMakers> a org:Organization ;
  rdfs:label "Load Balancer Manufacturer"@en .

<https://example.com/Org/FirewallMakers> a org:Organization ;
  rdfs:label "Firewall Manufacturer"@en .

<https://example.com/Org/RouterMakers> a org:Organization ;
  rdfs:label "Router Manufacturer"@en .

