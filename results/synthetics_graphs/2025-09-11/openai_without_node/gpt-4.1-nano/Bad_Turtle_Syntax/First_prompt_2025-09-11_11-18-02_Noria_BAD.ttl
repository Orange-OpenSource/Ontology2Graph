@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/Network1> a noria:StructuralElement, seas:System ;
  rdfs:label "Main Data Center Network"@en ;
  rdfs:comment "Core network infrastructure in the main data center."@en ;
  noria:structuralElementDistinguishedName "DCN-01"^^xsd:string ;
  noria:resourceManagedBy <https://example.com/SupportTeam> ;
  noria:locatedAtLocus <https://example.com/Locus1> .

<https://example.com/Resource1> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Core Router 1"@en ;
  rdfs:comment "Main core router in the data center."@en ;
  noria:resourceLogisticId "RT-DC-01"^^xsd:string ;
  noria:resourceHostName "core-router-1.datacenter.example.com"^^xsd:string ;
  noria:resourceSerialNumber "SN123456789"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/Resource/type/Router> ] ;
  noria:resourceProductModel <https://example.com/ModelX> ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagementIPAddress "192.168.0.1"^^xsd:string ;
  noria:agentManagesResource <https://example.com/NetworkAdmin> .

<https://example.com/ModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "High-performance router model X."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "Network Devices Inc."@en ;
  rdfs:comment "Manufacturer of network devices."@en .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus in Server Room 314"@en ;
  rdfs:comment "Specific location within the server room."@en ;
  noria:locusLine "Line:L, in Room:Server Room 314"^^xsd:string ;
  noria:locusRow "Row:6"^^xsd:string .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link DCN to Building A"@en ;
  rdfs:comment "Optical fiber link connecting data center to Building A."@en ;
  noria:networkLinkId "NL-DC-BLD-A"^^xsd:string ;
  noria:networkLinkType "Optical fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/Resource1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/Resource2> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Edge Switch 5"@en ;
  rdfs:comment "Switch at the edge of Building A."@en ;
  noria:resourceLogisticId "SW-BA-05"^^xsd:string ;
  noria:resourceHostName "edge-switch-5.buildinga.example.com"^^xsd:string ;
  noria:resourceSerialNumber "SN987654321"^^xsd:string ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> ; skos:hasTopConcept <https://w3id.org/noria/kos/Resource/type/Switch> ] ;
  noria:locatedAtLocus <https://example.com/Locus2> .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus in Building A"@en ;
  rdfs:comment "Location in Building A, Floor 1."@en ;
  noria:locusLine "Line:L, in Building A"^^xsd:string ;
  noria:locusRow "Row:1"^^xsd:string .

<https://example.com/SupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team responsible for network infrastructure support."@en .

<https://example.com/NetworkAdmin> a foaf:Agent ;
  rdfs:label "Alice Smith"@en ;
  rdfs:comment "Senior Network Administrator."@en ;
  foaf:accountName "asmith"^^xsd:string ;
  foaf:holdsAccount <https://example.com/Account1> .

<https://example.com/Account1> a foaf:OnlineAccount ;
  foaf:accountName "asmith"^^xsd:string ;
  foaf:accountServiceHomepage <https://example.com/SupportPortal> .

<https://example.com/SupportPortal> a foaf:Document ;
  rdfs:label "Support Portal"@en ;
  rdfs:comment "Internal support portal for network management."@en .
