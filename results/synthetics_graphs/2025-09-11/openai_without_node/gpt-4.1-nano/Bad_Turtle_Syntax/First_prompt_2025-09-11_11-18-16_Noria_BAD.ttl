@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/Network1> a noria:StructuralElement ;
    rdfs:label "Main Data Center Network"@en ;
    rdfs:comment "Core network infrastructure in the main data center."@en ;
    noria:structuralElementDistinguishedName "DCN-001" ;
    noria:elementManagedBy <https://example.com/OrgSupport> ;
    noria:locatedAtLocus <https://example.com/LocusA> .

<https://example.com/OrgSupport> a org:Organization ;
    rdfs:label "Network Support Team"@en ;
    rdfs:comment "Support team responsible for network infrastructure."@en .

<https://example.com/LocusA> a noria:Locus ;
    rdfs:label "Rack 12, Row A"@en ;
    noria:locusLine "Line: A" ;
    noria:locusRow "12" .

<https://example.com/ResourceServer1> a noria:Resource ;
    rdfs:label "Web Server 1"@en ;
    rdfs:comment "Primary web server hosting customer portal."@en ;
    noria:resourceSerialNumber "WS-12345" ;
    noria:resourceHostName "webserver1.datacenter.local" ;
    noria:resourceLogisticId "LOG-WS-001" ;
    noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <http://example.com/ResourceType/Server> ] ;
    noria:resourceProductModel <https://example.com/ProductModelX> ;
    noria:locatedAtLocus <https://example.com/LocusA> ;
    noria:resourceManagedBy <https://example.com/OrgSupport> .

<https://example.com/ProductModelX> a noria:ProductModel ;
    rdfs:label "Model X"@en ;
    rdfs:comment "High-performance web server model."@en ;
    noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
    rdfs:label "TechManufacture Inc."@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Primary network interface of Web Server 1."@en ;
    noria:networkInterfaceType [ a skos:Concept ; skos:inScheme <kos/NetworkInterface/type> ; skos:hasTopConcept <http://example.com/NetworkInterfaceType/Physical> ] ;
    noria:networkInterfaceDescription "Gigabit Ethernet port 0" ;
    noria:networkInterfaceOf <https://example.com/ResourceServer1> ;
    noria:networkInterfaceConnects <https://example.com/Link1> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -2 .

<https://example.com/Link1> a noria:NetworkLink ;
    rdfs:label "Link between Web Server and Switch"@en ;
    rdfs:comment "Optical fiber connection."@en ;
    noria:networkLinkId "NL-001" ;
    noria:networkLinkType "Optical fiber" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <https://example.com/ResourceServer1> ;
    noria:networkLinkTerminationResourceDestination <https://example.com/Switch1> .

<https://example.com/Switch1> a noria:Resource ;
    rdfs:label "Core Switch 1"@en ;
    rdfs:comment "Main switch in the data center."@en ;
    noria:resourceSerialNumber "SW-98765" ;
    noria:resourceHostName "switch1.datacenter.local" ;
    noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <http://example.com/ResourceType/Switch> ] ;
    noria:resourceManagedBy <https://example.com/OrgSupport> .

<https://example.com/Event1> a noria:EventRecord ;
    rdfs:label "Interface GigabitEthernet0/0/1 Up"@en ;
    rdfs:comment "Interface transitioned to up state."@en ;
    noria:loggingTime "2023-10-23T14:30:00"^^xsd:dateTime ;
    noria:logText "Line protocol on Interface GigabitEthernet0/0/1, changed state to up"@en ;
    noria:logOriginatingManagedObject <https://example.com/ResourceServer1> ;
    noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
    noria:alarmSeverity [ a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; skos:hasTopConcept <http://example.com/Severity/Critical> ] .

<https://example.com/NMS1> a noria:Application ;
    rdfs:label "Network Management System"@en ;
    rdfs:comment "System monitoring network devices."@en .

<https://example.com/TroubleTicket1> a noria:TroubleTicket ;
    rdfs:label "Network Link Down"@en ;
    rdfs:comment "Reported outage on network link NL-001."@en ;
    http://purl.org/dc/terms/identifier "TT-20231023-001" ;
    noria:troubleTicketSeverity <http://example.com/Severity/Critical> ;
    noria:troubleTicketType <http://example.com/Type/Failure> ;
    noria:troubleTicketOrigin <https://example.com/CustomerA> ;
    noria:troubleTicketDetectionDateTime "2023-10-23T14:25:00"^^xsd:dateTime ;
    noria:troubleTicketRelatedResource <https://example.com/ResourceServer1> ;
    noria:troubleTicketRelatedService <https://example.com/ServiceWebApp> ;
    noria:troubleTicketImpacts <https://example.com/ResourceServer1> .

<https://example.com/CustomerA> a foaf:Agent ;
    rdfs:label "Customer A"@en ;
    rdfs:comment "Client reporting the outage."@en .

<https://example.com/ServiceWebApp> a noria:Application ;
    rdfs:label "Customer Web Application"@en ;
    rdfs:comment "Web application used by customers."@en .

<https://example.com/ChangeRequest1> a noria:ChangeRequest ;
    rdfs:label "Upgrade Network Link NL-001"@en ;
    rdfs:comment "Planned upgrade to improve link reliability."@en ;
    http://purl.org/dc/terms/identifier "CR-20231023-001" ;
    noria:changeRequestCategory <http://example.com/Category/Upgrade> ;
    noria:changeRequestType <http://example.com/Type/SoftwareUpgrade> ;
    noria:changeRequestImpact <https://example.com/Link1> ;
    noria:changeRequestPlannedStartTime "2023-11-01T09:00:00"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2023-11-01T12:00:00"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2023-11-01T09:15:00"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2023-11-01T11:45:00"^^xsd:dateTime ;
    noria:changeRequestIsRegulated true ;
    noria:changeRequestInitiatorParty <https://example.com/EngineerA> ;
    noria:changeRequestPilotParty <https://example.com/EngineerA> .

<https://example.com/EngineerA> a foaf:Agent ;
    rdfs:label "Engineer Alice"@en ;
    rdfs:comment "Engineer responsible for the upgrade."@en .

<https://example.com/Document1> a noria:DocumentAttachment ;
    rdfs:label "Upgrade Plan Document"@en ;
    rdfs:comment "Detailed plan for network upgrade."@en ;
    noria:documentExternalId "DOC-20231023-PLAN" ;
    noria:documentHRef "http://docs.example.com/upgrade-plan.pdf"^^xsd:anyURI .

<https://example.com/OperationPlan1> a noria:OperationPlan ;
    rdfs:label "Upgrade Link NL-001"@en ;
    rdfs:comment "Operation plan for upgrading the network link."@en ;
    noria:operationPlanPreCondition <https://example.com/ActionPreCond1> ;
    noria:operationPlanPostCondition <https://example.com/ActionPostCond1> .

<https://example.com/ActionPreCond1> a noria:ActionPreCondition ;
    rdfs:label "Check link status"@en ;
    rdfs:comment "Ensure link is down before upgrade."@en .

<https://example.com/ActionPostCond1> a noria:ActionPostCondition ;
    rdfs:label "Verify link is operational"@en ;
    rdfs:comment "Confirm link is up after upgrade."@en .