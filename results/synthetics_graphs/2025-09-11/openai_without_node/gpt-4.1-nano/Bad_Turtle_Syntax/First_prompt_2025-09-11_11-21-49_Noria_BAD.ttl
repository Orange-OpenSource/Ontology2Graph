@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/Entity1> a noria:ManagedElement ;
  rdfs:label "Main Router"@en ;
  rdfs:comment "Core routing device in the data center."@en ;
  noria:elementDistinguishedName "Router_DC1_01" ;
  noria:elementManagedBy <https://example.com/OrgSupportTeam> ;
  noria:structuralElementObservable noria:structuralObservableOf ;
  noria:locatedAtLocus <https://example.com/Room314> .

<https://example.com/OrgSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Data Center Support Team"@en ;
  rdfs:comment "Support team responsible for core network devices."@en .

<https://example.com/Room314> a noria:Room ;
  rdfs:label "Server Room 314"@en ;
  rdfs:comment "Main server room on the 3rd floor."@en .

<https://example.com/ResourceA> a noria:Resource ;
  rdfs:label "Web Server A"@en ;
  rdfs:comment "Public-facing web server."@en ;
  noria:resourceLogisticId "WSA-2023-001" ;
  noria:resourceHostName "webserverA.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type#Server> ;
  noria:resourceSerialNumber "SN123456789" ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ; skos:hasTopConcept <https://w3id.org/noria/kos/Resource/LifecycleState#Active> ] ;
  noria:locatedAtLocus <https://example.com/Locus1> ;
  noria:resourceManagedBy <https://example.com/OrgSupportTeam> .

<https://example.com/Locus1> a noria:Locus ;
  rdfs:label "Locus 1"@en ;
  rdfs:comment "Main rack position in Server Room 314."@en ;
  noria:locusLine "Line:L, in Room 314"@en ;
  noria:locusRow "Row:3"@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link 1"@en ;
  rdfs:comment "Optical fiber connection between Router_DC1_01 and ResourceA."@en ;
  noria:networkLinkId "NL-2023-001" ;
  noria:networkLinkType "Optical fiber"@en ;
  noria:networkLinkInstallationDate "2023-02-15T10:00:00"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/ResourceB> a noria:Resource ;
  rdfs:label "Database Server B"@en ;
  rdfs:comment "Internal database server."@en ;
  noria:resourceLogisticId "DBS-2023-002" ;
  noria:resourceHostName "dbserverB.datacenter.local" ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type#Server> ;
  noria:resourceSerialNumber "SN987654321" ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ; skos:hasTopConcept <https://w3id.org/noria/kos/Resource/LifecycleState#Active> ] ;
  noria:locatedAtLocus <https://example.com/Locus2> ;
  noria:resourceManagedBy <https://example.com/OrgSupportTeam> .

<https://example.com/Locus2> a noria:Locus ;
  rdfs:label "Locus 2"@en ;
  rdfs:comment "Position in Data Center rack."@en ;
  noria:locusLine "Line:L, in Room 314"@en ;
  noria:locusRow "Row:4"@en .

<https://example.com/Event1> a noria:EventRecord ;
  rdfs:label "Router Up Event"@en ;
  rdfs:comment "Router_DC1_01 interface went up."@en ;
  noria:loggingTime "2023-03-20T14:22:00"^^xsd:dateTime ;
  noria:logText "Interface ge-0/0/0 is now up."@en ;
  noria:logOriginatingManagedObject <https://example.com/Resource1> ;
  noria:logOriginatingManagementSystem <https://example.com/NMS1> ;
  noria:alarmSeverity [ a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; skos:hasTopConcept <Notification/Severity/Warning> ] .

<https://example.com/NMS1> a noria:Application ;
  rdfs:label "Network Management System 1"@en ;
  rdfs:comment "System monitoring network devices."@en .

<https://example.com/Alarm1> a noria:EventRecord ;
  rdfs:label "High CPU Usage"@en ;
  rdfs:comment "CPU usage exceeded threshold on ResourceA."@en ;
  noria:loggingTime "2023-03-20T15:00:00"^^xsd:dateTime ;
  noria:logText "CPU usage at 95%."@en ;
  noria:logOriginatingManagedObject <https://example.com/ResourceA> ;
  noria:alarmSeverity [ a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; skos:hasTopConcept <Notification/Severity/Major> ] .

<https://example.com/TroubleTicket1> a noria:TroubleTicket ;
  rdfs:label "Network Outage in Data Center"@en ;
  rdfs:comment "Complete network outage affecting core routers."@en ;
  http://purl.org/dc/terms/identifier "TT-2023-001" ;
  noria:troubleTicketSeverity [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; skos:hasTopConcept <kos/TroubleTicket/severity#Critical> ] ;
  noria:troubleTicketType [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; skos:hasTopConcept <kos/TroubleTicket/type#Failure> ] ;
  noria:troubleTicketOrigin <https://example.com/Resource1> ;
  noria:troubleTicketImpacts <https://example.com/ResourceA> , <https://example.com/ResourceB> ;
  noria:troubleTicketStatusCurrent <https://example.com/StatusInProgress> ;
  noria:troubleTicketDetectionDateTime "2023-03-20T14:30:00"^^xsd:dateTime .

<https://example.com/StatusInProgress> a skos:Concept ;
  skos:inScheme <kos/TroubleTicket/status> ;
  skos:hasTopConcept <kos/TroubleTicket/status#InProgress> .

<https://example.com/ChangeRequest1> a noria:ChangeRequest ;
  rdfs:label "Upgrade Core Router Firmware"@en ;
  rdfs:comment "Firmware upgrade to fix security vulnerability."@en ;
  http://purl.org/dc/terms/identifier "CR-2023-001" ;
  noria:changeRequestCategory [ a skos:Concept ; skos:inScheme <kos/ChangeRequest/category> ; skos:hasTopConcept <kos/ChangeRequest/category#Internal> ] ;
  noria:changeRequestType [ a skos:Concept ; skos:inScheme <kos/ChangeRequest/type> ; skos:hasTopConcept <kos/ChangeRequest/type#SoftwareUpgrade> ] ;
  noria:changeRequestImpact <https://example.com/Resource1> ;
  noria:changeRequestActualStartTime "2023-03-21T09:00:00"^^xsd:dateTime ;
  noria:changeRequestActualEndTime "2023-03-21T12:00:00"^^xsd:dateTime ;
  noria:changeRequestStatusCurrent <https://example.com/StatusPlanned> .

<https://example.com/StatusPlanned> a skos:Concept ;
  skos:inScheme <kos/ChangeRequest/status> ;
  skos:hasTopConcept <kos/ChangeRequest/status#Planned> .