@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/Network1> a noria:StructuralElement, seas:System ;
  rdfs:label "Main Data Center Network"@en ;
  rdfs:comment "Core network infrastructure for enterprise data center."@en ;
  noria:structuralElementDistinguishedName "DCN-001"^^xsd:string ;
  noria:elementManagedBy <https://example.com/OrgSupportTeam> ;
  noria:locatedAtLocus <https://example.com/LocusA> .

<https://example.com/OrgSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Team responsible for network infrastructure management."@en .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Data Center Main Hall"@en ;
  rdfs:comment "Main hall of the data center where core network devices are located."@en ;
  noria:locusLine "L1"^^xsd:string ;
  noria:locusRow "R1"^^xsd:string .

<https://example.com/ResourceA> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Core Router 1"@en ;
  rdfs:comment "Primary core router for enterprise network."@en ;
  noria:resourceLogisticId "RES-CORE-01"^^xsd:string ;
  noria:resourceHostName "core-router-1"^^xsd:string ;
  noria:resourceSerialNumber "SN123456789"^^xsd:string ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceManagedBy <https://example.com/OrgSupportTeam> .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X1000"@en ;
  rdfs:comment "High-performance enterprise router model."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerY> .

<https://example.com/ManufacturerY> a org:Organization ;
  rdfs:label "RouterCorp Inc."@en ;
  rdfs:comment "Manufacturer of network devices."@en .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link DCN-001 to DCN-002"@en ;
  rdfs:comment "Optical fiber connection between main data center and backup."@en ;
  noria:networkLinkId "NL-DCN-001-DCN-002"^^xsd:string ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResource <https://example.com/ResourceA> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/ResourceB> .

<https://example.com/ResourceB> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Core Router 2"@en ;
  rdfs:comment "Backup core router for enterprise network."@en ;
  noria:resourceLogisticId "RES-CORE-02"^^xsd:string ;
  noria:resourceHostName "core-router-2"^^xsd:string ;
  noria:resourceSerialNumber "SN987654321"^^xsd:string ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/router> ;
  noria:resourceProductModel <https://example.com/ProductModelY> ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceManagedBy <https://example.com/OrgSupportTeam> .

<https://example.com/ProductModelY> a noria:ProductModel ;
  rdfs:label "Model Y2000"@en ;
  rdfs:comment "High-availability enterprise router."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerZ> .

<https://example.com/ManufacturerZ> a org:Organization ;
  rdfs:label "NetworkMakers Ltd."@en ;
  rdfs:comment "Manufacturer of advanced network devices."@en .

<https://example.com/ResourceC> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Switch 1"@en ;
  rdfs:comment "Core network switch for data center."@en ;
  noria:resourceLogisticId "RES-SW-01"^^xsd:string ;
  noria:resourceHostName "switch-1"^^xsd:string ;
  noria:resourceSerialNumber "SN1122334455"^^xsd:string ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/switch> ;
  noria:resourceProductModel <https://example.com/ProductModelZ> ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceManagedBy <https://example.com/OrgSupportTeam> .

<https://example.com/ProductModelZ> a noria:ProductModel ;
  rdfs:label "Switch Model Z300"@en ;
  rdfs:comment "High-speed core switch."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerA> .

<https://example.com/ManufacturerA> a org:Organization ;
  rdfs:label "SwitchMakers Co."@en ;
  rdfs:comment "Manufacturer of network switches."@en .

<https://example.com/ResourceD> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Firewall 1"@en ;
  rdfs:comment "Enterprise firewall for perimeter security."@en ;
  noria:resourceLogisticId "RES-FW-01"^^xsd:string ;
  noria:resourceHostName "firewall-1"^^xsd:string ;
  noria:resourceSerialNumber "SN5566778899"^^xsd:string ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/firewall> ;
  noria:resourceProductModel <https://example.com/ProductModelFirewall> ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceManagedBy <https://example.com/OrgSupportTeam> .

<https://example.com/ProductModelFirewall> a noria:ProductModel ;
  rdfs:label "Firewall Model F500"@en ;
  rdfs:comment "Next-gen enterprise firewall."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerB> .

<https://example.com/ManufacturerB> a org:Organization ;
  rdfs:label "SecureNet Inc."@en ;
  rdfs:comment "Manufacturer of security appliances."@en .