@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/Network1> a noria:StructuralElement ;
    rdfs:label "Main Office Network"@en ;
    rdfs:comment "Core network infrastructure at the main office."@en ;
    noria:structuralElementDistinguishedName "MainOfficeNet01" ;
    noria:elementManagedBy <https://example.com/Org/ITSupport> ;
    noria:locatedAtLocus <https://example.com/Locus/Room314> .

<https://example.com/Org/ITSupport> a org:OrganizationalUnit ;
    rdfs:label "IT Support Team"@en ;
    rdfs:comment "The team responsible for network management."@en .

<https://example.com/Locus/Room314> a noria:Locus ;
    rdfs:label "Server Room 314"@en ;
    rdfs:comment "Data center server room."@en ;
    noria:locusLine "Line:L, in Room:Server Room 314"@en ;
    noria:locusRow "Row:6"@en .

<https://example.com/Resource/Router1> a noria:Resource ;
    rdfs:label "Router1"@en ;
    rdfs:comment "Main router in the network."@en ;
    noria:resourceSerialNumber "SN123456" ;
    noria:resourceHostName "router1.example.com" ;
    noria:resourceLogisticId "Asset-RT-001" ;
    noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <kos/Resource/type/Router> ] ;
    noria:resourceProductModel <https://example.com/ProductModel/ModelX> ;
    noria:locatedAtLocus <https://example.com/Locus/Room314> ;
    noria:resourceManagedBy <https://example.com/Org/ITSupport> .

<https://example.com/ProductModel/ModelX> a noria:ProductModel ;
    rdfs:label "Model X"@en ;
    rdfs:comment "High-performance enterprise router."@en ;
    noria:productManufacturedBy <https://example.com/Org/RouterMakers> .

<https://example.com/Org/RouterMakers> a org:Organization ;
    rdfs:label "Router Manufacturer Inc."@en ;
    rdfs:comment "Manufacturer of network routers."@en .

<https://example.com/NetworkLink/WANLink> a noria:NetworkLink ;
    rdfs:label "WAN Link"@en ;
    rdfs:comment "Optical fiber link between main office and data center."@en ;
    noria:networkLinkId "NL-98765" ;
    noria:networkLinkType "Optical fiber"@en ;
    noria:networkLinkInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource <https://example.com/Resource/Router1> ;
    noria:networkLinkTerminationResourceDestination <https://example.com/Resource/Router2> .

<https://example.com/Resource/Router2> a noria:Resource ;
    rdfs:label "Router2"@en ;
    rdfs:comment "Backup router in the network."@en ;
    noria:resourceSerialNumber "SN654321" ;
    noria:resourceHostName "router2.example.com" ;
    noria:resourceLogisticId "Asset-RT-002" ;
    noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <kos/Resource/type/Router> ] ;
    noria:resourceProductModel <https://example.com/ProductModel/ModelY> ;
    noria:locatedAtLocus <https://example.com/Locus/Room314> ;
    noria:resourceManagedBy <https://example.com/Org/ITSupport> .

<https://example.com/ProductModel/ModelY> a noria:ProductModel ;
    rdfs:label "Model Y"@en ;
    rdfs:comment "Backup enterprise router."@en ;
    noria:productManufacturedBy <https://example.com/Org/RouterMakers> .

<https://example.com/Event/Log1> a noria:EventRecord ;
    rdfs:label "Interface GigabitEthernet0/0/1 Up"@en ;
    rdfs:comment "Interface GigabitEthernet0/0/1 changed to up."@en ;
    noria:loggingTime "2023-10-20T14:30:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to up"@en ;
    noria:logOriginatingManagedObject <https://example.com/Resource/Router1> ;
    noria:logOriginatingManagementSystem <https://example.com/Systems/NMS1> ;
    noria:alarmSeverity [ a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; skos:hasTopConcept <Notification/Severity/Critical> ] .

<https://example.com/Systems/NMS1> a noria:Application ;
    rdfs:label "Network Management System 1"@en ;
    rdfs:comment "System monitoring network devices."@en .

<https://example.com/TroubleTicket/Ticket123> a noria:TroubleTicket ;
    rdfs:label "Network Interface Down"@en ;
    rdfs:comment "Reported interface down on Router1."@en ;
    rdfs:seeAlso <https://example.com/Document/Ticket123Details> ;
    noria:troubleTicketSeverity [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; skos:hasTopConcept <kos/TroubleTicket/Severity/Critical> ] ;
    noria:troubleTicketType [ a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; skos:hasTopConcept <kos/TroubleTicket/Type/Failure> ] ;
    noria:troubleTicketOrigin <https://example.com/Resource/Router1> ;
    noria:troubleTicketRelatedResource <https://example.com/Resource/Router1> ;
    noria:troubleTicketRelatedService <https://example.com/Service/NetworkService> ;
    noria:troubleTicketDetectionDateTime "2023-10-20T14:25:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <https://example.com/Status/InProgress> .

<https://example.com/Service/NetworkService> a noria:Service ;
    rdfs:label "Main Network Service"@en ;
    rdfs:comment "Core network data path."@en ;
    noria:serviceType <https://example.com/kos/service/type/CustomerFacingService> .

<https://example.com/Status/InProgress> a skos:Concept ;
    skos:inScheme <kos/Status> ;
    skos:hasTopConcept <kos/Status/InProgress> .

<https://example.com/Document/Ticket123Details> a noria:DocumentAttachment ;
    rdfs:label "Ticket Details Document"@en ;
    rdfs:comment "Detailed report of the network interface issue."@en ;
    noria:documentExternalId "DOC-98765" ;
    noria:documentHRef "https://docs.example.com/Ticket123" .

