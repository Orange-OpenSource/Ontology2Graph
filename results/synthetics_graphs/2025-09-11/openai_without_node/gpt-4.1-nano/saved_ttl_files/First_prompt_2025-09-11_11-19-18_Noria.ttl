@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/Entity1> a noria:ManagedElement ;
  rdfs:label "Core Router 1"@en ;
  rdfs:comment "Main core router in data center."@en ;
  noria:elementDistinguishedName "core-router-1.dc1" ;
  noria:elementManagedBy <https://example.com/OrgSupportTeam> ;
  noria:structuralElementObservable [ a noria:StructuralObservable ;
    rdfs:label "Router Operational Status"@en ;
    rdfs:comment "Current operational status of Core Router 1."@en ;
    noria:structuralElementObservableData 100 ;
    noria:structuralObservableOf <https://example.com/CoreRouter1> ;
  ] .

<https://example.com/Resource2> a noria:Resource ;
  rdfs:label "Server 42"@en ;
  rdfs:comment "Application server hosting critical services."@en ;
  noria:resourceLogisticId "AS-42" ;
  noria:resourceHostName "server42.datacenter.local" ;
  noria:resourceType [ a skos:Concept ; skos:inScheme <kos/Resource/type> ; skos:hasTopConcept <https://example.com/ResourceType/ApplicationServer> ] ;
  noria:locatedAtLocus <https://example.com/LocusA> ;
  noria:resourceManagedBy <https://example.com/ITSupportOrg> ;
  noria:resourceProductModel <https://example.com/ProductModelX> ;
  noria:resourceSerialNumber "SN123456" ;
  noria:resourceUsageState [ a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; skos:hasTopConcept <https://example.com/UsageState/Operational> ] .

<https://example.com/NetworkInterface1> a noria:NetworkInterface ;
  rdfs:label "eth0"@en ;
  rdfs:comment "Primary network interface of Server 42."@en ;
  noria:networkInterfaceDescription "Gigabit Ethernet interface eth0."@en ;
  noria:networkInterfaceType [ a skos:Concept ; skos:inScheme <kos/NetworkInterface/type> ; skos:hasTopConcept <https://example.com/InterfaceType/Physical> ] ;
  noria:networkInterfaceOf <https://example.com/Resource2> ;
  noria:networkInterfaceConnects <https://example.com/NetworkLink1> ;
  noria:networkInterfaceRoutingPriorityMetric 10 ;
  noria:networkInterfaceLaserTxOpticalPower -2 ;
  noria:networkInterfaceLaserRxOpticalPower -3 ;
  noria:networkInterfaceLaserRxOpticalPowerAverage -2.5 ;
  noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
  noria:networkInterfaceLaserRxLowPowerWarningThreshold -4 .

<https://example.com/NetworkLink1> a noria:NetworkLink ;
  rdfs:label "Fiber Link A-B"@en ;
  rdfs:comment "Optical fiber link between core switch and server rack."@en ;
  noria:networkLinkId "Link-AB" ;
  noria:networkLinkType "Optical Fiber"@en ;
  noria:networkLinkInstallationDate "2022-01-15T09:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/CoreSwitch> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource2> .

<https://example.com/OrgSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Data Center Support Team"@en ;
  rdfs:comment "Support team responsible for data center infrastructure."@en .

<https://example.com/CoreRouter1> a noria:StructuralElement ;
  rdfs:label "Core Router 1"@en ;
  rdfs:comment "Main core router in data center."@en .

<https://example.com/LocusA> a noria:Locus ;
  rdfs:label "Rack 42"@en ;
  rdfs:comment "Rack location for Server 42."@en .

<https://example.com/ProductModelX> a noria:ProductModel ;
  rdfs:label "Model X"@en ;
  rdfs:comment "Manufacturer's model identifier for Server 42."@en ;
  noria:productManufacturedBy <https://example.com/ManufacturerY> .

<https://example.com/ManufacturerY> a org:Organization ;
  rdfs:label "TechManufacture Inc."@en ;
  rdfs:comment "Manufacturer of hardware products."@en .

<https://example.com/ResourceType/ApplicationServer> a skos:Concept ;
  skos:inScheme <kos/Resource/type> ;
  skos:hasTopConcept <https://example.com/ResourceType/ApplicationServer> ;
  skos:prefLabel "Application Server"@en .

<https://example.com/InterfaceType/Physical> a skos:Concept ;
  skos:inScheme <kos/NetworkInterface/type> ;
  skos:hasTopConcept <https://example.com/InterfaceType/Physical> ;
  skos:prefLabel "Physical"@en .

<https://example.com/UsageState/Operational> a skos:Concept ;
  skos:inScheme <kos/Resource/LifecycleState> ;
  skos:hasTopConcept <https://example.com/UsageState/Operational> ;
  skos:prefLabel "Operational"@en .