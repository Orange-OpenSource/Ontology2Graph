ex:RouterUpgradePlan
    a noria:OperationPlan ;
    rdfs:label "Edge Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading firmware on edge routers."@en ;
    noria:operationPlanPreCondition ex:RouterUpgradePreCheck ;
    noria:operationPlanPostCondition ex:RouterUpgradePostCheck .

ex:RouterUpgradePreCheck
    a noria:ActionPreCondition ;
    rdfs:label "Router Upgrade Pre-Conditions"@en ;
    rdfs:comment "Checks to perform before initiating a router firmware upgrade."@en ;
    dcterms:description "Verify device health, backup configuration, confirm maintenance window."@en .

ex:RouterUpgradePostCheck
    a noria:ActionPostCondition ;
    rdfs:label "Router Upgrade Post-Conditions"@en ;
    rdfs:comment "Checks to perform after a router firmware upgrade to confirm success."@en ;
    dcterms:description "Verify network connectivity, check log for errors, confirm service restoration."@en .

