ex:NIC_DB01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "eth0 on DB01"@en ;
    rdfs:comment "Primary network interface for Database Server DB01."@en ;
    noria:networkInterfaceOf ex:Server_DB01 ;
    noria:networkInterfaceDescription "Main data interface for Core Banking App DB"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus [
        a skos:Concept ;
        skos:prefLabel "up"@en ;
