    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

ex:Switch_Core01
    a noria:Resource ;
    rdfs:label "Core Switch 01"@en ;
    rdfs:comment "Central switch for the data center network."@en ;
    noria:resourceLogisticId "SW-CORE-001"^^xsd:string ;
    noria:resourceHostName "core01.example.com"^^xsd:string ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Network Switch"@en ;
