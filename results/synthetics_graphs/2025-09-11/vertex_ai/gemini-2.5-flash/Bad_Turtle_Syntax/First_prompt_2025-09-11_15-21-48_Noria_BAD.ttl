    noria:networkLinkInstallationDate "2023-03-10T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin ex:Server_DB01 ;
    noria:networkLinkTerminationResourceDestination ex:Switch_Core01 ;
    noria:resourceManagedBy ex:NetworkTeam .

# --- Dynamic Elements (Tickets and Events) ---

ex:Event_DB_CPU_Spike
    a noria:EventRecord ;
    rdfs:label "CPU Spike Alert on DB01"@en ;
    rdfs:comment "Automated alert indicating high CPU utilization on Database Server DB01."@en ;
    noria:loggingTime "2024-05-15T09:30:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on db01.example.com exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject ex:Server_DB01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystem ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Major"@en ;
        skos:inScheme <Notification/Severity/PerceivedSeverity>
    ] .

ex:MonitoringSystem
    a noria:Application ;
    rdfs:label "Infrastructure Monitoring System"@en ;
    rdfs:comment "System responsible for collecting metrics and generating alerts."@en ;
    noria:applicationShortIdentifier "MONSYS"^^xsd:string .

ex:TT_20240515_DBIssue
    a noria:TroubleTicket ;
    rdfs:label "Incident: High CPU on Core Banking DB"@en ;
    rdfs:comment "Trouble ticket opened due to a major CPU spike affecting the Core Banking Application database."@en ;
    dcterms:created "2024-05-15T09:35:00Z"^^xsd:dateTime ;
    dcterms:identifier "TT-20240515-001"^^xsd:string ;
    noria:documentExternalId "INC-98765"^^xsd:string ;
    noria:documentHRef <http://itsm.example.com/tickets/TT-20240515-001> ;
    noria:troubleTicketSeverity [
        a skos:Concept ;
        skos:prefLabel "Major"@en ;
        skos:inScheme <kos/TroubleTicket/severity>
    ] ;
    noria:troubleTicketType [
        a skos:Concept ;
        skos:prefLabel "Failure"@en ;
        skos:inScheme <kos/TroubleTicket/type>
    ] ;
    noria:troubleTicketPriority [
        a skos:Concept ;
        skos:prefLabel "P2"@en ;
        skos:inScheme <kos/TroubleTicket/priority>
    ] ;
    noria:troubleTicketOrigin [
        a skos:Concept ;
        skos:prefLabel "Supervision"@en ;
        skos:inScheme <kos/TroubleTicket/origin>
    ] ;
    noria:troubleTicketTrigger ex:Event_DB_CPU_Spike ;
    noria:troubleTicketUrgency [
        a skos:Concept ;
        skos:prefLabel "Immediate Intervention"@en ;
        skos:inScheme <kos/TroubleTicket/urgency>
    ] ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory [
        a skos:Concept ;
        skos:prefLabel "Performance Degradation"@en ;
        skos:inScheme <kos/TroubleTicket/trouble-category>
    ] ;
    noria:troubleTicketCause "Unexpected high load on database server."@en ;
    noria:troubleTicketDetectionDateTime "2024-05-15T09:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-05-15T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent [
        a skos:Concept ;
        skos:prefLabel "InProgress"@en ;
        skos:inScheme <kos/TroubleTicket/status>
    ] ;
    noria:troubleTicketRelatedParty ex:JaneSmith ;
    noria:troubleTicketRelatedService ex:CoreBankingApp_Prod ;
    noria:troubleTicketRelatedResource ex:Server_DB01 ;
    noria:troubleTicketImpacts ex:CoreBankingApp_Prod, ex:Server_DB01 .

ex:TTNote_DBIssue_1
    a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for TT-20240515-001"@en ;
    rdfs:comment "First note on the CPU spike incident, detailing initial findings."@en ;
    dcterms:created "2024-05-15T09:40:00Z"^^xsd:dateTime ;
    dcterms:creator ex:JaneSmith ;
    dcterms:isPartOf ex:TT_20240515_DBIssue ;
    noria:logText "Confirmed CPU spike. Investigating running processes. Database queries seem normal."^^xsd:string ;
    noria:troubleTicketNoteCommentType [
        a skos:Concept ;
        skos:prefLabel "Internal"@en ;
        skos:inScheme <kos/TroubleTicket/commentType>
    ] ;
    noria:troubleTicketNoteOperationType [
        a skos:Concept ;
        skos:prefLabel "Diagnosis"@en ;
        skos:inScheme <kos/TroubleTicket/operationType>
    ] .

