@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# Knowledge Graph based on NORIA schema

# --- Organizations and Agents ---

ex:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main corporate entity responsible for the entire infrastructure."@en ;
    org:hasUnit ex:ITOperationsDept .

ex:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for managing IT infrastructure and applications."@en ;
    org:unitOf ex:OrangeCorp ;
    org:hasMember ex:JaneSmith .

ex:NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team within IT Operations managing network resources."@en ;
    org:unitOf ex:ITOperationsDept ;
    org:hasMember ex:JohnDoe ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email"@en ;
        skos:inScheme <kos/org/agent-contact-method>
    ] ;
    noria:agentInstructions "For critical issues, use the dedicated hotline after hours."^^xsd:string .

ex:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Network Engineer, responsible for core network devices."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    org:memberOf ex:NetworkTeam ;
    noria:agentManagesResource ex:Router_Edge01, ex:Switch_Core01 .

ex:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "IT Service Manager, responsible for incident and change management."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    org:memberOf ex:ITOperationsDept .

# --- Applications and Services ---

ex:CoreBankingApp
    a noria:Application ;
    rdfs:label "Core Banking Application"@en ;
    rdfs:comment "Mission-critical application for core banking operations."@en ;
    noria:applicationModelIdentifier "CBA-V2.1"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001^^xsd:int ;
    noria:applicationShortIdentifier "CBA"^^xsd:string ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Financial System"@en ;
        skos:inScheme <kos/application/type>
    ] ;
    noria:applicationBusinessImportance [
        a skos:Concept ;
        skos:prefLabel "Critical"@en ;
        skos:inScheme <kos/application/business-importance>
    ] ;
    noria:applicationFunctionalDomain "Financial Services Management"@en ;
    noria:applicationFunctionalSubDomain "Core Transaction Processing"@en ;
    noria:elementManagedBy ex:ITOperationsDept .

ex:CoreBankingApp_Prod
    a noria:ApplicationModule ;
    rdfs:label "Core Banking Application - Production Instance"@en ;
    rdfs:comment "The production instance of the Core Banking Application."@en ;
    noria:applicationModuleOf ex:CoreBankingApp ;
    noria:applicationModuleName "CBA_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-CBA-001"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Production"@en ;
        skos:inScheme <https://w3id.org/noria/kos/application/status>
    ] ;
    noria:applicationModuleSlaLevel [
        a skos:Concept ;
        skos:prefLabel "Platinum"@en ;
        skos:inScheme <https://w3id.org/noria/kos/application/sla-level>
    ] ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true^^xsd:boolean .

ex:CustomerPortal
    a noria:Application ;
    rdfs:label "Customer Self-Service Portal"@en ;
    rdfs:comment "Web application allowing customers to manage their accounts."@en ;
    noria:applicationModelIdentifier "CSP-V1.5"^^xsd:string ;
    noria:applicationShortIdentifier "CSP"^^xsd:string ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Web Application"@en ;
        skos:inScheme <kos/application/type>
    ] ;
    noria:applicationBusinessImportance [
        a skos:Concept ;
        skos:prefLabel "High"@en ;
        skos:inScheme <kos/application/business-importance>
    ] ;
    noria:elementManagedBy ex:ITOperationsDept .

ex:CustomerPortal_Dev
    a noria:ApplicationModule ;
    rdfs:label "Customer Self-Service Portal - Development Instance"@en ;
    rdfs:comment "The development instance of the Customer Self-Service Portal."@en ;
    noria:applicationModuleOf ex:CustomerPortal ;
    noria:applicationModuleName "CSP_DEV"^^xsd:string ;
    noria:applicationModuleIdentifier "DEV-CSP-001"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Development"@en ;
        skos:inScheme <https://w3id.org/noria/kos/application/status>
    ] .

ex:FinancialDataService
    a noria:Service ;
    rdfs:label "Financial Data Exchange Service"@en ;
    rdfs:comment "An end-to-end service for secure financial data exchange, relying on Core Banking App."@en ;
    noria:serviceType [
        a skos:Concept ;
        skos:prefLabel "Customer Facing Service"@en ;
        skos:inScheme <kos/service/type>
    ] ;
    noria:elementManagedBy ex:ITOperationsDept .

# --- Resources and Infrastructure ---

ex:DataCenter_A
    a bot:Site ;
    rdfs:label "Main Data Center A"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-A-PARIS"^^xsd:string ;
    noria:siteType "Data Center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string .

ex:DataCenter_A_Room_1
    a noria:Room ;
    rdfs:label "Server Room 1, Data Center A"@en ;
    rdfs:comment "Dedicated server room within Data Center A."@en ;
    bot:hasSpace ex:Rack_A1_Locus .

ex:Rack_A1_Locus
    a noria:Locus ;
    rdfs:label "Rack A1 Locus"@en ;
    rdfs:comment "Specific location for Rack A1 within Server Room 1."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

ex:Server_DB01
    a noria:Resource ;
    rdfs:label "Database Server DB01"@en ;
    rdfs:comment "Dedicated server hosting the Core Banking Application database."@en ;
    noria:resourceLogisticId "SRV-DB-001"^^xsd:string ;
    noria:resourceHostName "db01.example.com"^^xsd:string ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Database Server"@en ;
        skos:inScheme <kos/Resource/type>
    ] ;
    noria:resourceSerialNumber "SN-DB01-XYZ"^^xsd:string ;
    noria:resourceUsageState [
        a skos:Concept ;
        skos:prefLabel "In Production"@en ;
        skos:inScheme <kos/Resource/LifecycleState>
    ] ;
    noria:resourceInstallationDate "2023-03-10T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CoreBankingApp_Prod ;
    noria:locatedAtLocus ex:Rack_A1_Locus ;
    noria:resourceManagedBy ex:ITOperationsDept ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

ex:Router_Edge01
    a noria:Resource ;
