    noria:networkInterfaceConnects ex:Link_DB01_Core01 .

ex:NIC_Core01_Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core01"@en ;
    rdfs:comment "Interface on Core Switch 01 connected to DB01."@en ;
    noria:networkInterfaceOf ex:Switch_Core01 ;
