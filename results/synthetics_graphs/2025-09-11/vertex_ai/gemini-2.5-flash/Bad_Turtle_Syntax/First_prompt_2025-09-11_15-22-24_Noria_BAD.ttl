@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix pep: <https://w3id.org/pep/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <http://example.com/noria-kg/> .

# --- SKOS Concepts for controlled vocabularies (dummy definitions for demonstration) ---
<http://example.com/kos/application/type/WebApplication> a skos:Concept ; skos:prefLabel "Web Application"@en .
<http://example.com/kos/application/type/LogManagement> a skos:Concept ; skos:prefLabel "Log Management System"@en .
<http://example.com/kos/application/business-importance/High> a skos:Concept ; skos:prefLabel "High Business Importance"@en .
<http://example.com/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en .
<http://example.com/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en .

<http://example.com/kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server"@en .
<http://example.com/kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router"@en .
<http://example.com/kos/Resource/LifecycleState/Active> a skos:Concept ; skos:prefLabel "Active"@en .

<http://example.com/kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Up"@en .
<http://example.com/kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down"@en .
<http://example.com/kos/Resource/AdministrativeState/Enabled> a skos:Concept ; skos:prefLabel "Enabled"@en .

<http://example.com/kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major"@en .
<http://example.com/kos/TroubleTicket/type/Incident> a skos:Concept ; skos:prefLabel "Incident"@en .
<http://example.com/kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en .
<http://example.com/kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer"@en .
<http://example.com/kos/TroubleTicket/trouble-category/ServiceOutage> a skos:Concept ; skos:prefLabel "Service Outage"@en .
<http://example.com/kos/TroubleTicket/problemResponsibility/NetworkOperations> a skos:Concept ; skos:prefLabel "Network Operations"@en .

<http://example.com/kos/Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en .
<http://example.com/kos/Notification/EventType/Alert> a skos:Concept ; skos:prefLabel "Alert"@en .

# --- Organizations and Agents ---
ex:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The central department responsible for managing IT infrastructure and applications."@en ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <http://example.com/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline after hours."@en .

ex:NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team managing network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentPreferredContactMethod <http://example.com/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate network-related incidents directly to this team."@en ;
    org:memberOf ex:ITOperationsDept .

ex:AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead administrator for the Customer Portal production environment."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    org:memberOf ex:ITOperationsDept .

ex:BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead developer for the Customer Portal development environment."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf ex:ITOperationsDept .

ex:CustomerSupport
    a org:OrganizationalUnit ;
    rdfs:label "Customer Support Center"@en ;
    rdfs:comment "First line of contact for customer inquiries and incident reporting."@en ;
    org:memberOf ex:ITOperationsDept .

# --- Applications ---
ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "The main web application allowing customers to manage their services."@en ;
    noria:applicationShortIdentifier "CUSTPORTAL"^^xsd:string ;
    noria:applicationModelIdentifier "CP-V2.1"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationType <http://example.com/kos/application/type/WebApplication> ;
    noria:applicationBusinessImportance <http://example.com/kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:elementManagedBy ex:ITOperationsDept .

ex:LogManagementApp
    a noria:Application ;
    rdfs:label "Central Log Management System"@en ;
    rdfs:comment "Application responsible for collecting, storing, and analyzing logs from all IT systems."@en ;
    noria:applicationShortIdentifier "LOGSYS"^^xsd:string ;
    noria:applicationType <http://example.com/kos/application/type/LogManagement> ;
    noria:elementManagedBy ex:NetworkTeam .

# --- Application Modules ---
ex:CustomerPortalProd
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "The production instance of the Customer Portal application, serving live users."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CUSTPORTAL_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept ;
    noria:applicationModuleSupportLeader ex:AliceSmith ;
    noria:applicationModuleStatus <http://example.com/kos/application/status/InProduction> ;
    noria:applicationModuleHotlineEnabled true .

ex:CustomerPortalDev
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en ;
    rdfs:comment "The development instance of the Customer Portal application, used for testing and new feature development."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CUSTPORTAL_DEV"^^xsd:string ;
    noria:applicationModuleIdentifier "DEV"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept ;
    noria:applicationModuleSupportLeader ex:BobJohnson ;
    noria:applicationModuleStatus <http://example.com/kos/application/status/Development> ;
    noria:applicationModuleHotlineEnabled false .

# --- Locations ---
ex:MainDataCenter
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "The primary data center facility hosting critical IT infrastructure."@en ;
    noria:siteId "DC-NYC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddressCityName "New York"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated server room within the Main Data Center."@en ;
    bot:hasSpace ex:MainDataCenter . # Assuming bot:Site can contain bot:Space

ex:RackA1Locus
    a noria:Locus ;
    rdfs:label "Rack A1 Locus"@en ;
    rdfs:comment "Specific location for Rack A1 in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace ex:ServerRoomA .

ex:RackA2Locus
    a noria:Locus ;
    rdfs:label "Rack A2 Locus"@en ;
    rdfs:comment "Specific location for Rack A2 in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:hasSpace ex:ServerRoomA .

ex:RackB1Locus
    a noria:Locus ;
    rdfs:label "Rack B1 Locus"@en ;
    rdfs:comment "Specific location for Rack B1 in Server Room A."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace ex:ServerRoomA .

# --- Resources ---
ex:WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server for the Customer Portal production environment."@en ;
    noria:resourceHostName "websrv01.example.com"^^xsd:string ;
    noria:resourceType <http://example.com/kos/Resource/type/Server> ;
    noria:resourceLogisticId "ASSET-WS01-2023"^^xsd:string ;
    noria:resourceSerialNumber "SN-WS01-XYZ"^^xsd:string ;
    noria:resourceUsageState <http://example.com/kos/Resource/LifecycleState/Active> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalProd ;
    noria:resourceManagedBy ex:ITOperationsDept ;
    noria:locatedAtLocus ex:RackA1Locus ;
    noria:resourceManagementIPAddress "192.168.1.10"^^observable:IPAddress .

ex:DBSrv02
    a noria:Resource ;
    rdfs:label "Database Server 02"@en ;
    rdfs:comment "Database server supporting the Customer Portal production environment."@en ;
    noria:resourceHostName "dbsrv02.example.com"^^xsd:string ;
    noria:resourceType <http://example.com/kos/Resource/type/Server> ;
    noria:resourceLogisticId "ASSET-DB02-2023"^^xsd:string ;
    noria:resourceSerialNumber "SN-DB02-ABC"^^xsd:string ;
    noria:resourceUsageState <http://example.com/kos/Resource/LifecycleState/Active> ;
    noria:resourceInstallationDate "2023-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalProd ;
    noria:resourceManagedBy ex:ITOperationsDept ;
    noria:locatedAtLocus ex:RackA2Locus ;
    noria:resourceManagementIPAddress "192.168.1.20"^^observable:IPAddress .

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for internal network traffic in the data center."@en ;
    noria:resourceHostName "corerouter01.example.com"^^xsd:string ;
    noria:resourceType <http://example.com/kos/Resource/type/Router> ;
    noria:resourceLogisticId "ASSET-CR01-2022"^^xsd:string ;
    noria:resourceSerialNumber "SN-CR01-DEF"^^xsd:string ;
    noria:resourceUsageState <http://example.com/kos/Resource/LifecycleState/Active> ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:NetworkTeam ;
    noria:locatedAtLocus ex:RackB1Locus ;
    noria:resourceManagementIPAddress "10.0.0.1"^^observable:IPAddress .

# --- Network Interfaces ---
ex:WebSrv01Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for Web Server 01."@en ;
    noria:networkInterfaceOf ex:WebSrv01 ;
    noria:networkInterfaceDescription "Primary interface to production network."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <http://example.com/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <http://example.com/kos/Resource/OperationalState/Up> .

ex:DBSrv02Eth0
    a noria:NetworkInterface ;
    rdfs:label "DBSrv02 Ethernet 0"@en ;
    rdfs:comment "Main network interface for Database Server 02."@en ;
    noria:networkInterfaceOf ex:DBSrv02 ;
    noria:networkInterfaceDescription "Primary interface to production network."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <http://example.com/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <http://example.com/kos/Resource/OperationalState/Up> .

ex:CoreRouter01Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the server network."@en ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to server farm."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <http://example.com/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <http://example.com/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

# --- Network Links ---
ex:LinkWebDB
    a noria:NetworkLink ;
    rdfs:label "Link between WebSrv01 and DBSrv02"@en ;
    rdfs:comment "Logical link representing the communication path between the web server and the database server."@en ;
    noria:networkLinkId "LINK-WS01-DB02"^^xsd:string ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-01-15T12:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin ex:WebSrv01 ;
    noria:networkLinkTerminationResourceDestination ex:DBSrv02 ;
    noria:networkInterfaceConnects ex:WebSrv01Eth0, ex:DBSrv02Eth0 .

ex:LinkRouterWebSrv
    a noria:NetworkLink ;
    rdfs:label "Link between CoreRouter01 and WebSrv01"@en ;
    rdfs:comment "Physical link connecting the core router to the web server."@en ;
    noria:networkLinkId "LINK-CR01-WS01"^^xsd:string ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-05-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin ex:CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination ex:WebSrv01 ;
    noria:networkInterfaceConnects ex:CoreRouter01Gi0_0_1, ex:WebSrv01Eth0 .

# --- Trouble Tickets ---
ex:TT20240701-001
    a noria:TroubleTicket ;
    rdfs:label "Customer Portal Outage - July 1st, 2024"@en ;
    rdfs:comment "Incident reported by customers regarding inability to access the Customer Portal."@en ;
    dcterms:identifier "TT-20240701-001"^^xsd:string ;
    dcterms:created "2024-07-01T09:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <http://example.com/kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <http://example.com/kos/TroubleTicket/type/Incident> ;
    noria:troubleTicketOrigin <http://example.com/kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketCause "Database connection pool exhaustion on DBSrv02."^^xsd:string ;
    noria:troubleTicketCategory <http://example.com/kos/TroubleTicket/trouble-category/ServiceOutage> ;
    noria:problemResponsibility <http://example.com/kos/TroubleTicket/problemResponsibility/NetworkOperations> ;
    noria:troubleTicketDetectionDateTime "2024-07-01T09:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <http://example.com/kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService ex:CustomerPortalProd ;
    noria:troubleTicketRelatedResource ex:DBSrv02 ;
    noria:troubleTicketRelatedParty ex:CustomerSupport .

# --- Event Records ---
ex:EventLogDBSrv02
    a noria:EventRecord ;
    rdfs:label "DBSrv02 Log Event: Connection Error"@en ;
    rdfs:comment "Log entry indicating a database connection error on DBSrv02."@en ;
    noria:loggingTime "2024-07-01T09:16:30Z"^^xsd:dateTime ;
    noria:logText "ERROR: Database connection limit exceeded. Source IP: 192.168.1.10"^^xsd:string ;
    noria:logOriginatingManagedObject ex:DBSrv02 ;
    noria:logOriginatingManagementSystem ex:LogManagementApp ;
    noria:alarmSeverity <http://example.com/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <http://example.com/kos/Notification/EventType/Alert> .

ex:EventLogWebSrv01NetworkDown
    a noria:EventRecord ;
    rdfs:label "WebSrv01 Network Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that the network interface on WebSrv01 went down."@en ;
    noria:loggingTime "2024-07-01T09:10:00Z"^^xsd:dateTime ;
    noria:logText "Interface eth0 on websrv01.example.com changed state to down."^^xsd:string ;
    noria:logOriginatingManagedObject ex:WebSrv01 ;
    noria:logOriginatingManagementSystem ex:LogManagementApp ;
    noria:alarmSeverity <http://example.com/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <http://example.com/kos/Notification/EventType/Alert> .

ex:TT20240701-001 noria:troubleTicketTrigger ex:EventLogDBSrv02 .
ex:TT20240701-001 noria:documentStatusHistory ex:EventLogDBSrv02 . # Example of linking an event to a TT's status history

