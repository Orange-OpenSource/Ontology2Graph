    noria:changeRequestPlannedEndTime "2024-05-20T23:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory [
        a skos:Concept ;
        skos:prefLabel "Software Upgrade" ;
        skos:inScheme <kos/ChangeRequest/category>
    ] ;
    noria:changeRequestType [
        a skos:Concept ;
        skos:prefLabel "Standard Change" ;
        skos:inScheme <kos/ChangeRequest/type>
    ] ;
    noria:changeRequestChangeCause [
        a skos:Concept ;
        skos:prefLabel "Software Upgrade" ;
        skos:inScheme <kos/ChangeRequest/cause>
    ] ;
    noria:changeRequestImpact ex:CustomerPortalDevModule ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ;
    noria:changeRequestStatusCurrent [
        a skos:Concept ;
        skos:prefLabel "Scheduled" ;
        skos:inScheme <kos/ChangeRequest/statu_extra_node_5>>
    ] ;
    noria:changeRequestInitiatorParty ex:JaneSmith ;
    noria:changeRequestPilotParty ex:JaneSmith ;
    noria:changeRequestActorParty ex:ITOperationsDept ;
    noria:changeRequestIsRegulated false .



# =============================================================================
