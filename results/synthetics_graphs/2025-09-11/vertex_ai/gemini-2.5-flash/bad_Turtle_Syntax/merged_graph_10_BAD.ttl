@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix ex: <http://example.com/data/> .
@prefix ex: <http://example.com/noria-kg/> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix ldp: <http://www.w3.org/ns/ldp#> . # Used for ldp:member property as per schema comments

# --- Organizations and Agents ---

ex:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main corporate entity managing the IT infrastructure." ;
    org:hasUnit ex:ITOperationsDept .

ex:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "Department responsible for overall IT infrastructure and application operations." ;
    org:unitOf ex:OrangeCorp ;
    noria:elementManagedBy ex:JaneSmith ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)" .

ex:NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Specialized team within IT Operations managing network resources." ;
    org:unitOf ex:ITOperationsDept ;
    noria:elementManagedBy ex:JohnDoe ;
    noria:agentWorkingHours "24/7 On-call rotation" .

ex:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Network Engineer responsible for critical network infrastructure." ;
    foaf:memberOf ex:NetworkTeam ;
    noria:agentManagesResource ex:Router01, ex:FirewallFW01 ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] ;
    noria:agentInstructions "Contact via internal chat for urgent issues, otherwise email." .

ex:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Application Manager overseeing core business applications." ;
    foaf:memberOf ex:ITOperationsDept ;
    noria:agentManagesResource ex:CoreBankingApp, ex:CustomerPortalApp ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Phone" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] .

# --- Applications and Application Modules ---

ex:CoreBankingApp
    a noria:Application ;
    rdfs:label "Core Banking Application" ;
    rdfs:comment "The primary application for managing customer bank accounts and transactions." ;
    noria:applicationShortIdentifier "CBA" ;
    noria:applicationModelIdentifier "CBA-V2.1" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:elementManagedBy ex:JaneSmith ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Financial Service" ;
        skos:inScheme <kos/application/type>
    ] ;
    noria:applicationBusinessImportance [
        a skos:Concept ;
        skos:prefLabel "Critical" ;
        skos:inScheme <kos/application/business-importance>
    ] ;
    noria:applicationFunctionalDomain "Market and Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Account Management" .

ex:CoreBankingProdModule
    a noria:ApplicationModule ;
    rdfs:label "Core Banking Production Module" ;
    rdfs:comment "The production instance of the Core Banking Application." ;
    noria:applicationModuleOf ex:CoreBankingApp ;
    noria:applicationModuleName "CBA_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith ;
    noria:applicationModuleSlaLevel [
        a skos:Concept ;
        skos:prefLabel "Tier 1" ;
        skos:inScheme <https://w3id.org/noria/kos/application/sla-level>
    ] ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Production" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status>
    ] .

ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "Customer Portal Application" ;
    rdfs:comment "Web application allowing customers to access their banking information." ;
    noria:applicationShortIdentifier "CPA" ;
    noria:applicationModelIdentifier "CPA-V1.5" ;
    noria:applicationNumericalIdentifier 102 ;
    noria:elementManagedBy ex:JaneSmith ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Web Service" ;
        skos:inScheme <kos/application/type>
    ] .

ex:CustomerPortalDevModule
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module" ;
    rdfs:comment "The development instance of the Customer Portal Application." ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CPA_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleSupportTeam ex:ITOperationsDept ;
    noria:applicationModuleSupportLeader ex:JaneSmith ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Development" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status>
    ] .

ex:LogManagementSystem
    a noria:Application ;
    rdfs:label "Central Log Management System" ;
    rdfs:comment "System for collecting, parsing, and storing logs from various IT resources." ;
    noria:applicationShortIdentifier "LMS" ;
    noria:elementManagedBy ex:ITOperationsDept ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Monitoring Tool" ;
        skos:inScheme <kos/application/type>
    ] .

# --- Resources and Network Components ---

ex:Router01
    a noria:Resource ;
    rdfs:label "Production Router 01" ;
    rdfs:comment "Core router in the production network, handling critical traffic." ;
    noria:resourceLogisticId "RTR-P-001" ;
    noria:resourceHostName "router-prod-01.example.com" ;
    noria:resourceProductModel ex:CiscoASR9K ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Router" ;
        skos:inScheme <kos/Resource/type>
    ] ;
    noria:resourceSerialNumber "XYZ123456789" ;
    noria:resourceUsageState [
        a skos:Concept ;
        skos:prefLabel "In Use" ;
        skos:inScheme <kos/Resource/LifecycleState>
    ] ;
    noria:resourceInstallationDate "2020-03-10T00:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:NetworkTeam ;
    noria:locatedAtLocus ex:DataCenterA_Rack1_U42 ;
    noria:resourceManagementIPAddress ex:Router01_MgmtIP .

ex:Router01_MgmtIP
    a observable:IPAddress ;
    rdfs:label "Router01 Management IP" ;
    observable:ipAddressValue "10.0.0.1" .

ex:ServerDB01
    a noria:Resource ;
    rdfs:label "Database Server 01" ;
    rdfs:comment "Database server hosting the Core Banking Application's primary database." ;
    noria:resourceLogisticId "SRV-DB-001" ;
    noria:resourceHostName "db-prod-01.example.com" ;
    noria:resourceProductModel ex:HPProLiantDL380 ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Database Server" ;
        skos:inScheme <kos/Resource/type>
    ] ;
    noria:resourceSerialNumber "ABC987654321" ;
    noria:resourceUsageState [
        a skos:Concept ;
        skos:prefLabel "In Use" ;
        skos:inScheme <kos/Resource/LifecycleState>
    ] ;
    noria:resourceInstallationDate "2021-01-15T00:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:ITOperationsDept ;
    noria:resourceForApplication ex:CoreBankingApp ;
    noria:locatedAtLocus ex:DataCenterA_Rack1_U20 .

ex:FirewallFW01
    a noria:Resource ;
    rdfs:label "Edge Firewall 01" ;
    rdfs:comment "Perimeter firewall protecting the internal network." ;
    noria:resourceLogisticId "FW-EDGE-001" ;
    noria:resourceHostName "fw-edge-01.example.com" ;
    noria:resourceProductModel ex:PaloAltoPA500 ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Firewall" ;
        skos:inScheme <kos/Resource/type>
    ] ;
    noria:resourceSerialNumber "DEF654321098" ;
    noria:resourceManagedBy ex:NetworkTeam ;
    noria:locatedAtLocus ex:DataCenterA_Rack1_U10 .

ex:VirtualMachine01
    a noria:Resource ;
    rdfs:label "Customer Portal VM 01" ;
    rdfs:comment "Virtual machine hosting part of the Customer Portal application." ;
    noria:resourceHostName "vm-portal-01.example.com" ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Virtual Machine" ;
        skos:inScheme <kos/Resource/type>
    ] ;
    noria:resourceForApplication ex:CustomerPortalApp ;
    noria:clusterController ex:VMwareCluster01 .

ex:VMwareCluster01
    a noria:Resource ;
    rdfs:label "VMware Production Cluster 01" ;
    rdfs:comment "VMware vSphere cluster managing virtual machines." ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Virtualization Platform" ;
        skos:inScheme <kos/Resource/type>
    ] .

# --- Product Models ---

ex:CiscoASR9K
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series" ;
    rdfs:comment "High-end router series from Cisco Systems." ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:HPProLiantDL380
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380" ;
    rdfs:comment "Popular rack server model from HP." ;
    noria:productManufacturedBy ex:HPE .

ex:PaloAltoPA500
    a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-500" ;
    rdfs:comment "Next-generation firewall appliance." ;
    noria:productManufacturedBy ex:PaloAltoNetworks .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems" ;
    rdfs:comment "Manufacturer of networking hardware." .

ex:HPE
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise" ;
    rdfs:comment "Manufacturer of servers and IT solutions." .

ex:PaloAltoNetworks
    a org:Organization ;
    rdfs:label "Palo Alto Networks" ;
    rdfs:comment "Manufacturer of cybersecurity products." .

# --- Network Interfaces ---

ex:Router01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "Router01 Ethernet 0/0/0" ;
    rdfs:comment "Physical interface on Router01 connected to the firewall." ;
    noria:networkInterfaceOf ex:Router01 ;
    noria:networkInterfaceConnects ex:Link_Router01_FW01 ;
    noria:networkInterfaceDescription "Uplink to Firewall FW01" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus [
        a skos:Concept ;
        skos:prefLabel "up" ;
        skos:inScheme <kos/Resource/AdministrativeState>
    ] ;
    noria:networkInterfaceOperationalStatus [
        a skos:Concept ;
        skos:prefLabel "up" ;
        skos:inScheme <kos/Resource/OperationalState>
    ] ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

ex:FirewallFW01_Eth1
    a noria:NetworkInterface ;
    rdfs:label "FirewallFW01 Ethernet 0/0/1" ;
    rdfs:comment "Physical interface on FirewallFW01 connected to Router01." ;
    noria:networkInterfaceOf ex:FirewallFW01 ;
    noria:networkInterfaceConnects ex:Link_Router01_FW01 ;
    noria:networkInterfaceDescription "Downlink from Router01" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus [
        a skos:Concept ;
        skos:prefLabel "up" ;
        skos:inScheme <kos/Resource/AdministrativeState>
    ] ;
    noria:networkInterfaceOperationalStatus [
        a skos:Concept ;
        skos:prefLabel "up" ;
        skos:inScheme <kos/Resource/OperationalState>
    ] .

# --- Network Links ---

ex:Link_Router01_FW01
    a noria:NetworkLink ;
    rdfs:label "Link between Router01 and FirewallFW01" ;
    rdfs:comment "Direct physical link connecting Router01 and FirewallFW01." ;
    noria:networkLinkId "LINK-R01-FW01" ;
    noria:networkLinkTerminationResourceOrigin ex:Router01 ;
    noria:networkLinkTerminationResourceDestination ex:FirewallFW01 ;
    noria:networkLinkInstallationDate "2020-03-10T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy ex:NetworkTeam .

# --- Locations ---

ex:DataCenterA
    a bot:Site ;
    rdfs:label "Main Data Center A" ;
    rdfs:comment "Primary data center facility." ;
    noria:siteId "DC-A" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" ;
    bot:hasSpace ex:DataCenterA_Room1 .

ex:DataCenterA_Room1
    a noria:Room ;
    rdfs:label "Data Center A - Server Room 1" ;
    rdfs:comment "Main server room within Data Center A." ;
    bot:hasSpace ex:DataCenterA_Rack1_U42, ex:DataCenterA_Rack1_U20, ex:DataCenterA_Rack1_U10 .

ex:DataCenterA_Rack1_U42
    a noria:Locus ;
    rdfs:label "Data Center A - Rack 1, Unit 42" ;
    rdfs:comment "Specific location for Router01 within Rack 1." ;
    noria:locusLine "A" ;
    noria:locusRow "42" .

ex:DataCenterA_Rack1_U20
    a noria:Locus ;
    rdfs:label "Data Center A - Rack 1, Unit 20" ;
    rdfs:comment "Specific location for ServerDB01 within Rack 1." ;
    noria:locusLine "A" ;
    noria:locusRow "20" .

ex:DataCenterA_Rack1_U10
    a noria:Locus ;
    rdfs:label "Data Center A - Rack 1, Unit 10" ;
    rdfs:comment "Specific location for FirewallFW01 within Rack 1." ;
    noria:locusLine "A" ;
    noria:locusRow "10" .

# --- Services ---

ex:OnlineBankingService
    a noria:Service ;
    rdfs:label "Online Banking Service" ;
    rdfs:comment "End-to-end service enabling customers to perform banking operations online." ;
    seas:subSystemOf ex:CoreBankingApp, ex:CustomerPortalApp ;
    noria:serviceType [
        a skos:Concept ;
        skos:prefLabel "Customer Facing Service" ;
        skos:inScheme <kos/service/type>
    ] ;
    noria:elementManagedBy ex:JaneSmith .

# --- Trouble Tickets and Events ---

ex:TT_20240515_001
    a noria:TroubleTicket ;
    rdfs:label "TT-20240515-001: Core Banking DB Connectivity Issue" ;
    rdfs:comment "Incident reported regarding intermittent connectivity to the Core Banking database." ;
    dcterms:created "2024-05-15T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-05-15T11:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-DB-2024-001" ;
    noria:documentHRef "http://itsm.example.com/tickets/TT-20240515-001" ;
    noria:troubleTicketSeverity [
        a skos:Concept ;
        skos:prefLabel "Major" ;
        skos:inScheme <kos/TroubleTicket/severity>
    ] ;
    noria:troubleTicketType [
        a skos:Concept ;
        skos:prefLabel "Failure" ;
        skos:inScheme <kos/TroubleTicket/type>
    ] ;
    noria:troubleTicketPriority [
        a skos:Concept ;
        skos:prefLabel "P2" ;
        skos:inScheme <kos/TroubleTicket/priority>
    ] ;
    noria:troubleTicketOrigin [
        a skos:Concept ;
        skos:prefLabel "Supervision" ;
        skos:inScheme <kos/TroubleTicket/origin>
    ] ;
    noria:troubleTicketTrigger ex:Event_DB_Failure ;
    noria:troubleTicketUrgency [
        a skos:Concept ;
        skos:prefLabel "Immediate Intervention" ;
        skos:inScheme <kos/TroubleTicket/urgency>
    ] ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory [
        a skos:Concept ;
        skos:prefLabel "Corrupted service" ;
        skos:inScheme <kos/TroubleTicket/trouble-category>
    ] ;
    noria:troubleTicketCause "Network latency affecting database connections." ;
    noria:problemResponsibility [
        a skos:Concept ;
        skos:prefLabel "Managed backbone networks" ;
        skos:inScheme <kos/TroubleTicket/problemResponsibility>
    ] ;
    noria:troubleTicketDetectionDateTime "2024-05-15T09:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-05-15T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent [
        a skos:Concept ;
        skos:prefLabel "InProgress" ;
        skos:inScheme <kos/TroubleTicket/status>
    ] ;
    noria:troubleTicketRelatedParty ex:JaneSmith ;
    noria:troubleTicketRelatedService ex:CoreBankingProdModule ;
    noria:troubleTicketRelatedResource ex:ServerDB01 ;
    noria:troubleTicketImpacts ex:ServerDB01, ex:CoreBankingProdModule .

ex:TT_20240515_002
    a noria:TroubleTicket ;
    rdfs:label "TT-20240515-002: Router01 Interface Down" ;
    rdfs:comment "Critical incident: Router01's uplink interface went down." ;
    dcterms:created "2024-05-15T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity [
        a skos:Concept ;
        skos:prefLabel "Critical" ;
        skos:inScheme <kos/TroubleTicket/severity>
    ] ;
    noria:troubleTicketTrigger ex:Event_Router_Down ;
    noria:troubleTicketRelatedParty ex:NetworkTeam ;
    noria:troubleTicketRelatedResource ex:Router01 ;
    noria:troubleTicketStatusCurrent [
        a skos:Concept ;
        skos:prefLabel "Initialised" ;
        skos:inScheme <kos/TroubleTicket/status>
    ] .

ex:Event_DB_Failure
    a noria:EventRecord ;
    rdfs:label "Database Connectivity Alarm" ;
    rdfs:comment "Alarm indicating a loss of connectivity to the production database." ;
    noria:loggingTime "2024-05-15T09:55:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: DB connection pool exhausted on db-prod-01." ;
    noria:logOriginatingManagedObject ex:ServerDB01 ;
    noria:logOriginatingManagementSystem ex:LogManagementSystem ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Critical" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity>
    ] ;
    dcterms:type [
        a skos:Concept ;
        skos:prefLabel "Operational Alarm" ;
        skos:inScheme <kos/Notification/EventType>
    ] .

ex:Event_Router_Down
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event" ;
    rdfs:comment "Log entry indicating a network interface on Router01 changed state to down." ;
    noria:loggingTime "2024-05-15T11:58:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down." ;
    noria:logOriginatingManagedObject ex:Router01 ;
    noria:logOriginatingManagementSystem ex:LogManagementSystem ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Major" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity>
    ] ;
    dcterms:type [
        a skos:Concept ;
        skos:prefLabel "State Change" ;
        skos:inScheme <kos/Notification/EventType>
    ] .

