ex:DevOpsTeam
    a org:OrganizationalUnit ;
    rdfs:label "DevOps Team" ;
    rdfs:comment "Team responsible for application development and operations, including deployment and maintenance." ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri" .

ex:NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations" ;
    rdfs:comment "Team responsible for managing and maintaining the network infrastructure." ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:inScheme <kos/org/agent-contact-method> ;
        rdfs:label "Email"
    ] .

ex:SecurityOps
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations" ;
    rdfs:comment "Team responsible for monitoring and responding to cybersecurity threats." .

ex:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Lead Engineer in the DevOps Team, specializing in application performance." ;
    foaf:member ex:DevOpsTeam .

