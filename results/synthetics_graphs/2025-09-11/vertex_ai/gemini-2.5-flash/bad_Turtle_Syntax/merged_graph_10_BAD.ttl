# --- Operation Plans ---

ex:RouterOSUpgradePlan
    a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure" ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems." ;
    noria:operationPlanPreCondition ex:RouterOSUpgradePreCondition ;
    noria:operationPlanPostCondition ex:RouterOSUpgradePostCondition .

ex:RouterOSUpgradePreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Router OS Upgrade Pre-Condition" ;
    rdfs:comment "Verify router health, backup configuration, and download new OS image." .

