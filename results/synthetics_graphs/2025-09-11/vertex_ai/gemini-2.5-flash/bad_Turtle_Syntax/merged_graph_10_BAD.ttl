# =============================================================================
# Structural Entities (Resources, Network Interfaces, Network Links)
# =============================================================================

ex:WebServer01
    a noria:Resource ;
    rdfs:label "Web Server 01" ;
    rdfs:comment "Virtual server hosting the web frontend for the Online Banking application." ;
    noria:resourceHostName "web01.example.com" ;
    noria:resourceForApplication ex:OnlineBankingProdModule ;
    noria:resourceManagedBy ex:DevOpsTeam ;
    noria:locatedAtLocus ex:RackA1_U20 ;
    noria:resourceType [
        a skos:Concept ;
        skos:inScheme <kos/Resource/type> ;
        rdfs:label "Virtual Server"
    ] ;
    noria:resourceUsageState [
        a skos:Concept ;
        skos:inScheme <kos/Resource/LifecycleState> ;
        rdfs:label "In Production"
    ] .

ex:DBServer01
    a noria:Resource ;
    rdfs:label "Database Server 01" ;
    rdfs:comment "Physical server hosting the database for the Online Banking application." ;
    noria:resourceHostName "db01.example.com" ;
    noria:resourceForApplication ex:OnlineBankingProdModule ;
    noria:resourceManagedBy ex:DevOpsTeam ;
    noria:locatedAtLocus ex:RackA1_U21 ;
    noria:resourceType [
        a skos:Concept ;
        skos:inScheme <kos/Resource/type> ;
        rdfs:label "Physical Server"
    ] ;
    noria:resourceInstallationDate "2023-01-10T09:00:00Z"^^xsd:dateTime .

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01" ;
    rdfs:comment "Main router in the data center network, providing connectivity to servers and external networks." ;
    noria:resourceHostName "cr01.example.com" ;
    noria:resourceManagedBy ex:NetworkOps ;
    noria:locatedAtLocus ex:RackB2_U5 ;
    noria:resourceType [
        a skos:Concept ;
        skos:inScheme <kos/Resource/type> ;
        rdfs:label "Network Router"
    ] ;
    noria:resourceSerialNumber "CR01-SN-XYZ789" .

ex:WebServer01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "web01-eth0" ;
    rdfs:comment "Ethernet interface on Web Server 01, connected to the internal network." ;
    noria:networkInterfaceOf ex:WebServer01 ;
    noria:networkInterfaceAdministrativeStatus [
        a skos:Concept ;
        skos:inScheme <kos/Resource/AdministrativeState> ;
        rdfs:label "up"
    ] ;
    noria:networkInterfaceOperationalStatus [
        a skos:Concept ;
        skos:inScheme <kos/Resource/OperationalState> ;
        rdfs:label "up"
    ] .

ex:DBServer01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "db01-eth0" ;
    rdfs:comment "Ethernet interface on Database Server 01, connected to the internal network." ;
    noria:networkInterfaceOf ex:DBServer01 ;
    noria:networkInterfaceOperationalStatus [
        a skos:Concept ;
        skos:inScheme <kos/Resource/OperationalState> ;
        rdfs:label "up"
    ] .

ex:CoreRouter01_Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "cr01-Gi0/0/1" ;
    rdfs:comment "Gigabit Ethernet interface 0/0/1 on Core Router 01, connected to the server network." ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceAdministrativeStatus [
        a skos:Concept ;
        skos:inScheme <kos/Resource/AdministrativeState> ;
        rdfs:label "up"
    ] .

ex:CoreRouter01_Gi0_0_2
    a noria:NetworkInterface ;
    rdfs:label "cr01-Gi0/0/2" ;
    rdfs:comment "Gigabit Ethernet interface 0/0/2 on Core Router 01, serving as an internet uplink." ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceOperationalStatus [
        a skos:Concept ;
        skos:inScheme <kos/Resource/OperationalState> ;
        rdfs:label "up"
    ] .

ex:Link_Web_DB
    a noria:NetworkLink ;
    rdfs:label "Link between Web and DB Servers" ;
    rdfs:comment "Direct network link connecting the web server to the database server for application traffic." ;
    noria:networkInterfaceConnects ex:WebServer01_Eth0 ;
    noria:networkInterfaceConnects ex:DBServer01_Eth0 ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime .

ex:Link_Web_Router
    a noria:NetworkLink ;
    rdfs:label "Link from Web Server to Core Router" ;
    rdfs:comment "Network link connecting the web server to the core router for external access." ;
    noria:networkInterfaceConnects ex:WebServer01_Eth0 ;
    noria:networkInterfaceConnects ex:CoreRouter01_Gi0_0_1 ;
    noria:networkLinkType "Fiber Optic" .

ex:Link_Router_Internet
    a noria:NetworkLink ;
    rdfs:label "Internet Uplink from Core Router" ;
    rdfs:comment "Network link providing internet connectivity from the core router." ;
    noria:networkInterfaceConnects ex:CoreRouter01_Gi0_0_2 ;
    noria:networkLinkType "Internet Uplink" .

# =============================================================================
# Dynamic Entities (Event Records, Trouble Tickets)
# =============================================================================

ex:Log_WebServerCPU
    a noria:EventRecord ;
    rdfs:label "High CPU Alert on Web Server" ;
    rdfs:comment "Automated alert indicating high CPU utilization on web01.example.com, potentially impacting application performance." ;
    noria:loggingTime "2024-04-20T14:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject ex:WebServer01 ;
    noria:logText "CPU utilization exceeded 90% for 5 minutes." ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:inScheme <Notification/Severity/PerceivedSeverity> ;
        rdfs:label "Major"
    ] .

ex:Log_DBConnectionError
    a noria:EventRecord ;
    rdfs:label "Database Connection Error" ;
    rdfs:comment "Log entry indicating intermittent connection issues to the database, possibly due to network or database server problems." ;
    noria:loggingTime "2024-04-20T14:35:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject ex:DBServer01 ;
    noria:logText "Failed to establish connection to database 'online_bank_prod'." ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:inScheme <Notification/Severity/PerceivedSeverity> ;
        rdfs:label "Minor"
    ] .

ex:TT_OnlineBankingIssue
    a noria:TroubleTicket ;
    rdfs:label "Online Banking Performance Degradation" ;
    rdfs:comment "Ticket opened due to slow response times reported by customers on the online banking platform, traced to high CPU on web server." ;
    noria:troubleTicketDetectionDateTime "2024-04-20T14:32:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity [
        a skos:Concept ;
        skos:inScheme <kos/TroubleTicket/severity> ;
        rdfs:label "Major"
    ] ;
    noria:troubleTicketPriority [
        a skos:Concept ;
        skos:inScheme <kos/TroubleTicket/priority> ;
        rdfs:label "P2"
    ] ;
    noria:troubleTicketRelatedService ex:OnlineBankingProdModule ;
    noria:troubleTicketRelatedResource ex:WebServer01 ;
    noria:troubleTicketTrigger ex:Log_WebServerCPU ;
    noria:troubleTicketRelatedParty ex:JohnDoe ;
    noria:troubleTicketStatusCurrent [
        a skos:Concept ;
        skos:inScheme <kos/TroubleTicket/status> ;
        rdfs:label "InProgress"
    ] .

ex:SecurityIncidentTT
    a noria:TroubleTicket ;
    rdfs:label "Database Security Alert" ;
    rdfs:comment "Ticket opened for suspicious database connection attempts, indicating a potential security breach." ;
    noria:troubleTicketDetectionDateTime "2024-04-20T14:40:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity [
        a skos:Concept ;
        skos:inScheme <kos/TroubleTicket/severity> ;
        rdfs:label "Critical"
    ] ;
    noria:troubleTicketPriority [
        a skos:Concept ;
        skos:inScheme <kos/TroubleTicket/priority> ;
        rdfs:label "P1"
    ] ;
    noria:troubleTicketRelatedResource ex:DBServer01 ;
    noria:troubleTicketTrigger ex:Log_DBConnectionError ;
    noria:troubleTicketRelatedParty ex:SecurityOps ;
    noria:troubleTicketStatusCurrent [
        a skos:Concept ;
        skos:inScheme <kos/TroubleTicket/status> ;
        rdfs:label "InProgress"
    ] .

