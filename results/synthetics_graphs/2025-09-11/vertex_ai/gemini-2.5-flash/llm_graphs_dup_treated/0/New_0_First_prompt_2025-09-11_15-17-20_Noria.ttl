# --- Organizations and Agents ---

ex:OrangeCor_extra_node_10
    a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main corporate entity managing the IT infrastructure." ;
    org:hasUnit ex:ITOperationsDep_extra_node_10 .

ex:ITOperationsDep_extra_node_10
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "Department responsible for overall IT infrastructure and application operations." ;
    org:unitOf ex:OrangeCor_extra_node_10 ;
    noria:elementManagedBy ex:JaneSmit_extra_node_10 ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)" .

ex:NetworkTea_extra_node_10
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Specialized team within IT Operations managing network resources." ;
    org:unitOf ex:ITOperationsDep_extra_node_10 ;
    noria:elementManagedBy ex:JohnDo_extra_node_10 ;
    noria:agentWorkingHours "24/7 On-call rotation" .

ex:JohnDo_extra_node_10
    a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Network Engineer responsible for critica_extra_node_10 network infrastructure." ;
    foaf:memberOf ex:NetworkTea_extra_node_10 ;
    noria:agentManagesResource ex:Router0_extra_node_10, ex:FirewallFW0_extra_node_10 ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] ;
    noria:agentInstructions "Contact via interna_extra_node_10 chat for urgent issues, otherwise emai_extra_node_10." .

ex:JaneSmit_extra_node_10
    a foaf:Person ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Application Manager overseeing core business applications." ;
    foaf:memberOf ex:ITOperationsDep_extra_node_10 ;
    noria:agentManagesResource ex:CoreBankingAp_extra_node_10, ex:CustomerPortalAp_extra_node_10 ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Phone" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] .

