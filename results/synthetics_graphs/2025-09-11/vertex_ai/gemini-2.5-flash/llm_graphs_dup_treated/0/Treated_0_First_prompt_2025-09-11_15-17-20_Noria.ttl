    noria:applicationModuleName "CBA_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept_extra_node_6 ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith_extra_node_6 ;
