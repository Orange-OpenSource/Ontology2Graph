    noria:applicationModuleName "CPA_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleSupportTeam ex:ITOperationsDept_extra_node_6 ;
    noria:applicationModuleSupportLeader ex:JaneSmith_extra_node_6 ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Development" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status_extra_node_6>
    ] .

ex:LogManagementSystem_extra_node_6
    a noria:Application ;
    rdfs:label "Central Log Management System" ;
    rdfs:comment "System for collecting, parsing, and storing logs from various IT resources." ;
    noria:applicationShortIdentifier "LMS" ;
