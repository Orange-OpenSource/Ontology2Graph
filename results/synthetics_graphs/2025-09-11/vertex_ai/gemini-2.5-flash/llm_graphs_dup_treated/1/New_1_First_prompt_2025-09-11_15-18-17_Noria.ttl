# --- Organizations and Agents ---

ex:OrangeCor_extra_node_5
    a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main organizational entity for this knowledge graph." ;
    org:hasUnit ex:ITOperationsDep_extra_node_5 .

ex:ITOperationsDep_extra_node_5
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "A department within Orange Corp responsible for IT operations." ;
    org:unitOf ex:OrangeCor_extra_node_5 ;
    org:hasMember ex:JaneSmit_extra_node_5, ex:JohnDo_extra_node_5 .

ex:NetworkTea_extra_node_5
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "A specialized team within IT Operations focusing on network infrastructure." ;
    org:unitOf ex:ITOperationsDep_extra_node_5 ;
    org:hasMember ex:JohnDo_extra_node_5 ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)" ;
    noria:agentInstructions "Contact via interna_extra_node_5 ticketing system for critica_extra_node_5 issues." .

ex:JohnDo_extra_node_5
    a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Network Engineer responsible for core network infrastructure." ;
    foaf:memberOf ex:NetworkTea_extra_node_5 ;
    noria:agentManagesResource ex:Router0_extra_node_5, ex:Router02, ex:FirewallFW0_extra_node_5 ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] .

ex:JaneSmit_extra_node_5
    a foaf:Person ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Application Manager overseeing critica_extra_node_5 business applications." ;
    foaf:memberOf ex:ITOperationsDep_extra_node_5 ;
    noria:agentManagesResource ex:CoreBankingAp_extra_node_5, ex:CustomerPortalAp_extra_node_5 ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Phone" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] .

