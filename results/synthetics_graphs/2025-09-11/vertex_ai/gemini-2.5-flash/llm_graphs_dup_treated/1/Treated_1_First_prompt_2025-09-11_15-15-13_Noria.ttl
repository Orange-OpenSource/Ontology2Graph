    noria:applicationModuleName "CBA_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept_extra_node_7 ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith_extra_node_7 ;
    noria:applicationModuleSlaLevel [
        a skos:Concept ;
        skos:prefLabel "Tier 1" ;
        skos:inScheme <https://w3id.org/noria/kos/application/sla-level>
    ] ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Production" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status>
    ] .

ex:CustomerPortalApp_extra_node_7
    a noria:Application ;
    rdfs:label "Customer Portal Application" ;
    rdfs:comment "Web application allowing customers to access their banking information." ;
    noria:applicationShortIdentifier "CPA" ;
    noria:applicationModelIdentifier "CPA-V1.5" ;
    noria:applicationNumericalIdentifier 102 ;
    noria:elementManagedBy ex:JaneSmith_extra_node_7 ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Web Service" ;
        skos:inScheme <kos/application/type>
    ] .

ex:CustomerPortalDevModule_extra_node_7
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module" ;
    rdfs:comment "The development instance of the Customer Portal Application." ;
    noria:applicationModuleOf ex:CustomerPortalApp_extra_node_7 ;
    noria:applicationModuleName "CPA_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleSupportTeam ex:ITOperationsDept_extra_node_7 ;
    noria:applicationModuleSupportLeader ex:JaneSmith_extra_node_7 ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Development" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status>
    ] .

ex:LogManagementSystem_extra_node_7
    a noria:Application ;
    rdfs:label "Central Log Management System" ;
    rdfs:comment "System for collecting, parsing, and storing logs from various IT resources." ;
    noria:applicationShortIdentifier "LMS" ;
    noria:elementManagedBy ex:ITOperationsDept_extra_node_7 ;
    noria:applicationType [
        a skos:Concept ;
