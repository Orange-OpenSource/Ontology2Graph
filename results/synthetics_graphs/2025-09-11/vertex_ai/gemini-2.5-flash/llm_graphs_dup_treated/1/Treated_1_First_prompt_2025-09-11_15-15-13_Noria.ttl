# --- Trouble Tickets and Events ---

ex:Event_DB_Failure_extra_node_7
    a noria:EventRecord ;
    rdfs:label "Database Connection Failure Event" ;
    rdfs:comment "Log entry indicating a critical_extra_node_7 failure in database connectivity." ;
    noria:loggingTime "2024-05-15T10:30:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Database connection pool exhausted for db-prod-01." ;
    noria:logOriginatingManagedObject ex:ServerDB01_extra_node_7 ;
    noria:logOriginatingManagementSystem ex:LogManagementSystem_extra_node_7 ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Critical" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity>
    ] ;
    noria:alarmProposedRepairAction ex:RestartDBServiceProcedure .

ex:Event_Router_Down_extra_node_7
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event" ;
    rdfs:comment "Alert indicating that a critical_extra_node_7 network interface on Router01_extra_node_7 went down." ;
    noria:loggingTime "2024-05-15T11:00:00Z"^^xsd:dateTime ;
    noria:logText "INTERFACE_STATUS: ge-0/0/0 on router_extra_node_7-prod-01 changed state to down." ;
    noria:logOriginatingManagedObject ex:Router01_extra_node_7 ;
    noria:logOriginatingManagementSystem ex:LogManagementSystem_extra_node_7 ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Major" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity>
    ] .

