# --- Organizations and Agents ---

ex:OrangeCorp_extra_node_7
    a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main corporate entity managing the IT infrastructure." ;
    org:hasUnit ex:ITOperationsDept_extra_node_7 .

ex:ITOperationsDept_extra_node_7
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "Department responsible for overall IT infrastructure and application operations." ;
    org:unitOf ex:OrangeCorp_extra_node_7 ;
    noria:elementManagedBy ex:JaneSmith_extra_node_7 ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)" .

ex:NetworkTeam_extra_node_7
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Specialized team within IT Operations managing network resources." ;
    org:unitOf ex:ITOperationsDept_extra_node_7 ;
    noria:elementManagedBy ex:JohnDoe_extra_node_7 ;
    noria:agentWorkingHours "24/7 On-call rotation" .

ex:JohnDoe_extra_node_7
    a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Network Engineer responsible for critical_extra_node_7 network infrastructure." ;
    foaf:memberOf ex:NetworkTeam_extra_node_7 ;
    noria:agentManagesResource ex:Router01_extra_node_7, ex:FirewallFW01_extra_node_7 ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] ;
    noria:agentInstructions "Contact via internal_extra_node_7 chat for urgent issues, otherwise email_extra_node_7." .

ex:JaneSmith_extra_node_7
    a foaf:Person ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Application Manager overseeing core business applications." ;
    foaf:memberOf ex:ITOperationsDept_extra_node_7 ;
    noria:agentManagesResource ex:CoreBankingApp_extra_node_7, ex:CustomerPortalApp_extra_node_7 ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Phone" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] .

# --- Applications and Application Modules ---

ex:CoreBankingApp_extra_node_7
    a noria:Application ;
    rdfs:label "Core Banking Application" ;
    rdfs:comment "The primary application for managing customer bank accounts and transactions." ;
    noria:applicationShortIdentifier "CBA" ;
    noria:applicationModelIdentifier "CBA-V2.1" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:elementManagedBy ex:JaneSmith_extra_node_7 ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Financial Service" ;
        skos:inScheme <kos/application/type>
    ] ;
    noria:applicationBusinessImportance [
        a skos:Concept ;
        skos:prefLabel "Critical" ;
        skos:inScheme <kos/application/business-importance>
    ] ;
    noria:applicationFunctionalDomain "Market and Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Account Management" .

ex:CoreBankingProdModule_extra_node_7
    a noria:ApplicationModule ;
    rdfs:label "Core Banking Production Module" ;
    rdfs:comment "The production instance of the Core Banking Application." ;
