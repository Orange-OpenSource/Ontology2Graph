# --- Organizations and Agents ---

ex:OrangeCor_extra_node_1
    a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main corporate entity managing the IT infrastructure." ;
    org:hasUnit ex:ITOperationsDep_extra_node_1 .

ex:ITOperationsDep_extra_node_1
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "Department responsible for IT infrastructure and application operations." ;
    org:unitOf ex:OrangeCor_extra_node_1 ;
    org:hasUnit ex:NetworkTea_extra_node_1, ex:ApplicationSu_extra_node_1portTeam .

ex:NetworkTea_extra_node_1
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Team responsible for managing network infrastructure." ;
    org:unitOf ex:ITOperationsDep_extra_node_1 ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)" ;
    noria:agentPreferredContactMethod <http://example.com/kos/contact/emai_extra_node_1> ;
    noria:agentInstructions "For critica_extra_node_1 network issues, use the dedicated hotline." ;
    noria:agentManagesResource ex:Router0_extra_node_1, ex:FirewallFW0_extra_node_1 .

ex:ApplicationSu_extra_node_1portTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Su_extra_node_1port Team" ;
    rdfs:comment "Team responsible for su_extra_node_1porting business applications." ;
    org:unitOf ex:ITOperationsDep_extra_node_1 ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <http://example.com/kos/contact/ticketing_system> ;
    noria:agentInstructions "All application issues must be reported via the ticketing system." ;
    noria:agentManagesResource ex:ServerDB0_extra_node_1, ex:VirtualMachine0_extra_node_1 ;
    noria:elementManagedBy ex:JaneSmit_extra_node_1 .

ex:JohnDo_extra_node_1
    a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Network Engineer, responsible for core network devices." ;
    org:memberOf ex:NetworkTea_extra_node_1 ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentManagesResource ex:Router0_extra_node_1, ex:FirewallFW0_extra_node_1 .

ex:JaneSmit_extra_node_1
    a foaf:Person ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Lead Application Su_extra_node_1port Specialist." ;
    org:memberOf ex:ApplicationSu_extra_node_1portTeam ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentManagesResource ex:ServerDB0_extra_node_1, ex:VirtualMachine0_extra_node_1 ;
    noria:elementManagedBy ex:CoreBankingProdModul_extra_node_1 .

