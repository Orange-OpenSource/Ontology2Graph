# --- Organizations and Agents ---

ex:OrangeCorp_extra_node_0
    a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main corporate entity managing the IT infrastructure." ;
    org:hasUnit ex:ITOperationsDept_extra_node_0 .

ex:ITOperationsDept_extra_node_0
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "Department responsible for IT infrastructure and application operations." ;
    org:unitOf ex:OrangeCorp_extra_node_0 ;
    org:hasUnit ex:NetworkTeam_extra_node_0, ex:ApplicationSupportTeam .

ex:NetworkTeam_extra_node_0
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Team responsible for managing network infrastructure." ;
    org:unitOf ex:ITOperationsDept_extra_node_0 ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)" ;
    noria:agentPreferredContactMethod <http://example.com/kos/contact/email_extra_node_0> ;
    noria:agentInstructions "For critical_extra_node_0 network issues, use the dedicated hotline." ;
    noria:agentManagesResource ex:Router01_extra_node_0, ex:FirewallFW01_extra_node_0 .

ex:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team" ;
    rdfs:comment "Team responsible for supporting business applications." ;
    org:unitOf ex:ITOperationsDept_extra_node_0 ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <http://example.com/kos/contact/ticketing_system> ;
    noria:agentInstructions "All application issues must be reported via the ticketing system." ;
    noria:agentManagesResource ex:ServerDB01_extra_node_0, ex:VirtualMachine01_extra_node_0 ;
    noria:elementManagedBy ex:JaneSmith_extra_node_0 .

ex:JohnDoe_extra_node_0
    a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Network Engineer, responsible for core network devices." ;
    org:memberOf ex:NetworkTeam_extra_node_0 ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentManagesResource ex:Router01_extra_node_0, ex:FirewallFW01_extra_node_0 .

ex:JaneSmith_extra_node_0
    a foaf:Person ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Lead Application Support Specialist." ;
    org:memberOf ex:ApplicationSupportTeam ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentManagesResource ex:ServerDB01_extra_node_0, ex:VirtualMachine01_extra_node_0 ;
    noria:elementManagedBy ex:CoreBankingProdModule_extra_node_0 .

