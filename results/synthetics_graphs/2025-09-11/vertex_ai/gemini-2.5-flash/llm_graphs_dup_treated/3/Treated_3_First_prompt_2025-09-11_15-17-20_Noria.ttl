    rdfs:comment "Next-generation firewall appliance." ;
    noria:productManufacturedBy ex:PaloAltoNetworks .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems" ;
    rdfs:comment "Manufacturer of networking hardware." .

ex:HPE
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise" ;
