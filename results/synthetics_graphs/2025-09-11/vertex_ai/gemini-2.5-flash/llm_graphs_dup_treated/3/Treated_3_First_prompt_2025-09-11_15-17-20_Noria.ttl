@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix ex: <http://example.com/noria-kg/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix pep: <https://w3id.org/pep/> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- Organizations and Agents ---

ex:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main corporate entity managing the IT infrastructure." ;
    org:hasUnit ex:ITOperationsDept .

ex:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "Department responsible for overall IT infrastructure and application operations." ;
    org:unitOf ex:OrangeCorp ;
    noria:elementManagedBy ex:JaneSmith ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)" .

ex:NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Specialized team within IT Operations managing network resources." ;
    org:unitOf ex:ITOperationsDept ;
    noria:elementManagedBy ex:JohnDoe ;
    noria:agentWorkingHours "24/7 On-call rotation" .

ex:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Network Engineer responsible for critical network infrastructure." ;
    foaf:memberOf ex:NetworkTeam ;
    noria:agentManagesResource ex:Router01, ex:FirewallFW01 ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] ;
    noria:agentInstructions "Contact via internal chat for urgent issues, otherwise email." .

ex:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Application Manager overseeing core business applications." ;
    foaf:memberOf ex:ITOperationsDept ;
    noria:agentManagesResource ex:CoreBankingApp, ex:CustomerPortalApp ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Phone" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] .

# --- Applications and Application Modules ---

ex:CoreBankingApp
    a noria:Application ;
    rdfs:label "Core Banking Application" ;
    rdfs:comment "The primary application for managing customer bank accounts and transactions." ;
    noria:applicationShortIdentifier "CBA" ;
    noria:applicationModelIdentifier "CBA-V2.1" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:elementManagedBy ex:JaneSmith ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Financial Service" ;
        skos:inScheme <kos/application/type>
    ] ;
    noria:applicationBusinessImportance [
        a skos:Concept ;
        skos:prefLabel "Critical" ;
        skos:inScheme <kos/application/business-importance>
    ] ;
    noria:applicationFunctionalDomain "Market and Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Account Management" .

ex:CoreBankingProdModule
    a noria:ApplicationModule ;
    rdfs:label "Core Banking Production Module" ;
    rdfs:comment "The production instance of the Core Banking Application." ;
    noria:applicationModuleOf ex:CoreBankingApp ;
    noria:applicationModuleName "CBA_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith ;
    noria:applicationModuleSlaLevel [
        a skos:Concept ;
        skos:prefLabel "Tier 1" ;
        skos:inScheme <https://w3id.org/noria/kos/application/sla-level>
    ] ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Production" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status>
    ] .

ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "Customer Portal Application" ;
    rdfs:comment "Web application allowing customers to access their banking information." ;
    noria:applicationShortIdentifier "CPA" ;
    noria:applicationModelIdentifier "CPA-V1.5" ;
    noria:applicationNumericalIdentifier 102 ;
    noria:elementManagedBy ex:JaneSmith ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Web Service" ;
        skos:inScheme <kos/application/type>
    ] .

ex:CustomerPortalDevModule
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module" ;
    rdfs:comment "The development instance of the Customer Portal Application." ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CPA_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleSupportTeam ex:ITOperationsDept ;
    noria:applicationModuleSupportLeader ex:JaneSmith ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Development" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status>
    ] .

ex:LogManagementSystem
    a noria:Application ;
    rdfs:label "Central Log Management System" ;
    rdfs:comment "System for collecting, parsing, and storing logs from various IT resources." ;
    noria:applicationShortIdentifier "LMS" ;
    noria:elementManagedBy ex:ITOperationsDept ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Monitoring Tool" ;
        skos:inScheme <kos/application/type>
    ] .

# --- Resources and Network Components ---

ex:Router01
    a noria:Resource ;
    rdfs:label "Production Router 01" ;
    rdfs:comment "Core router in the production network, handling critical traffic." ;
    noria:resourceLogisticId "RTR-P-001" ;
    noria:resourceHostName "router-prod-01.example.com" ;
    noria:resourceProductModel ex:CiscoASR9K ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Router" ;
        skos:inScheme <kos/Resource/type>
    ] ;
    noria:resourceSerialNumber "XYZ123456789" ;
    noria:resourceUsageState [
        a skos:Concept ;
        skos:prefLabel "In Use" ;
        skos:inScheme <kos/Resource/LifecycleState>
    ] ;
    noria:resourceInstallationDate "2020-03-10T00:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:NetworkTeam ;
    noria:locatedAtLocus ex:DataCenterA_Rack1_U42 ;
    noria:resourceManagementIPAddress ex:Router01_MgmtIP .

ex:Router01_MgmtIP
    a observable:IPAddress ;
    rdfs:label "Router01 Management IP" ;
    observable:ipAddressValue "10.0.0.1" .

ex:ServerDB01
    a noria:Resource ;
    rdfs:label "Database Server 01" ;
    rdfs:comment "Database server hosting the Core Banking Application's primary database." ;
    noria:resourceLogisticId "SRV-DB-001" ;
    noria:resourceHostName "db-prod-01.example.com" ;
    noria:resourceProductModel ex:HPProLiantDL380 ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Database Server" ;
        skos:inScheme <kos/Resource/type>
    ] ;
    noria:resourceSerialNumber "ABC987654321" ;
    noria:resourceUsageState [
        a skos:Concept ;
        skos:prefLabel "In Use" ;
        skos:inScheme <kos/Resource/LifecycleState>
    ] ;
    noria:resourceInstallationDate "2021-01-15T00:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:ITOperationsDept ;
    noria:resourceForApplication ex:CoreBankingApp ;
    noria:locatedAtLocus ex:DataCenterA_Rack1_U20 .

ex:FirewallFW01
    a noria:Resource ;
    rdfs:label "Edge Firewall 01" ;
    rdfs:comment "Perimeter firewall protecting the internal network." ;
    noria:resourceLogisticId "FW-EDGE-001" ;
    noria:resourceHostName "fw-edge-01.example.com" ;
    noria:resourceProductModel ex:PaloAltoPA500 ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Firewall" ;
        skos:inScheme <kos/Resource/type>
    ] ;
    noria:resourceSerialNumber "DEF654321098" ;
    noria:resourceManagedBy ex:NetworkTeam ;
    noria:locatedAtLocus ex:DataCenterA_Rack1_U10 .

ex:VirtualMachine01
    a noria:Resource ;
    rdfs:label "Customer Portal VM 01" ;
    rdfs:comment "Virtual machine hosting part of the Customer Portal application." ;
    noria:resourceHostName "vm-portal-01.example.com" ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Virtual Machine" ;
        skos:inScheme <kos/Resource/type>
    ] ;
    noria:resourceForApplication ex:CustomerPortalApp ;
    noria:clusterController ex:VMwareCluster01 .

ex:VMwareCluster01
    a noria:Resource ;
    rdfs:label "VMware Production Cluster 01" ;
    rdfs:comment "VMware vSphere cluster managing virtual machines." ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Virtualization Platform" ;
        skos:inScheme <kos/Resource/type>
    ] .

