    noria:troubleTicketCategory [
        a skos:Concept ;
        skos:prefLabel "Corrupted service" ;
        skos:inScheme <kos/TroubleTicket/trouble-category>
    ] ;
    noria:troubleTicketCause "Network latency affecting database connections." ;
    noria:problemResponsibility [
        a skos:Concept ;
        skos:prefLabel "Managed backbone networks" ;
        skos:inScheme <kos/TroubleTicket/problemResponsibility>
    ] ;
    noria:troubleTicketDetectionDateTime "2024-05-15T09:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-05-15T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent [
