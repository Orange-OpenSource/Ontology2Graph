    noria:loggingTime "2024-05-15T11:58:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down." ;
    noria:logOriginatingManagedObject ex:Router01 ;
    noria:logOriginatingManagementSystem ex:LogManagementSystem ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Major" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity>
    ] ;
    dcterms:type [
        a skos:Concept ;
        skos:prefLabel "State Change" ;
        skos:inScheme <kos/Notification/EventType>
    ] .

