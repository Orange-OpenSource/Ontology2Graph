# --- Network Interfaces ---

ex:Router01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "Router01 Ethernet 0/0/0" ;
    rdfs:comment "Physical interface on Router01 connected to the firewall." ;
    noria:networkInterfaceOf ex:Router01 ;
    noria:networkInterfaceConnects ex:Link_Router01_FW01 ;
    noria:networkInterfaceDescription "Uplink to Firewall FW01" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus [
        a skos:Concept ;
        skos:prefLabel "up" ;
        skos:inScheme <kos/Resource/AdministrativeState>
    ] ;
    noria:networkInterfaceOperationalStatus [
        a skos:Concept ;
        skos:prefLabel "up" ;
        skos:inScheme <kos/Resource/OperationalState>
    ] ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

ex:FirewallFW01_Eth1
    a noria:NetworkInterface ;
    rdfs:label "FirewallFW01 Ethernet 0/0/1" ;
    rdfs:comment "Physical interface on FirewallFW01 connected to Router01." ;
    noria:networkInterfaceOf ex:FirewallFW01 ;
    noria:networkInterfaceConnects ex:Link_Router01_FW01 ;
    noria:networkInterfaceDescription "Downlink from Router01" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus [
        a skos:Concept ;
        skos:prefLabel "up" ;
        skos:inScheme <kos/Resource/AdministrativeState>
    ] ;
    noria:networkInterfaceOperationalStatus [
        a skos:Concept ;
        skos:prefLabel "up" ;
        skos:inScheme <kos/Resource/OperationalState>
    ] .

# --- Network Links ---

ex:Link_Router01_FW01
    a noria:NetworkLink ;
    rdfs:label "Link between Router01 and FirewallFW01" ;
    rdfs:comment "Direct physical link connecting Router01 and FirewallFW01." ;
    noria:networkLinkId "LINK-R01-FW01" ;
    noria:networkLinkTerminationResourceOrigin ex:Router01 ;
    noria:networkLinkTerminationResourceDestination ex:FirewallFW01 ;
    noria:networkLinkInstallationDate "2020-03-10T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy ex:NetworkTeam .

# --- Locations ---

ex:DataCenterA
    a bot:Site ;
    rdfs:label "Main Data Center A" ;
    rdfs:comment "Primary data center facility." ;
    noria:siteId "DC-A" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" ;
    bot:hasSpace ex:DataCenterA_Room1 .

ex:DataCenterA_Room1
    a noria:Room ;
    rdfs:label "Data Center A - Server Room 1" ;
    rdfs:comment "Main server room within Data Center A." ;
    bot:hasSpace ex:DataCenterA_Rack1_U42, ex:DataCenterA_Rack1_U20, ex:DataCenterA_Rack1_U10 .

ex:DataCenterA_Rack1_U42
    a noria:Locus ;
    rdfs:label "Data Center A - Rack 1, Unit 42" ;
    rdfs:comment "Specific location for Router01 within Rack 1." ;
    noria:locusLine "A" ;
    noria:locusRow "42" .

ex:DataCenterA_Rack1_U20
    a noria:Locus ;
    rdfs:label "Data Center A - Rack 1, Unit 20" ;
    rdfs:comment "Specific location for ServerDB01 within Rack 1." ;
    noria:locusLine "A" ;
    noria:locusRow "20" .

ex:DataCenterA_Rack1_U10
    a noria:Locus ;
    rdfs:label "Data Center A - Rack 1, Unit 10" ;
    rdfs:comment "Specific location for FirewallFW01 within Rack 1." ;
    noria:locusLine "A" ;
    noria:locusRow "10" .

# --- Services ---

ex:OnlineBankingService
    a noria:Service ;
    rdfs:label "Online Banking Service" ;
    rdfs:comment "End-to-end service enabling customers to perform banking operations online." ;
    seas:subSystemOf ex:CoreBankingApp, ex:CustomerPortalApp ;
    noria:serviceType [
        a skos:Concept ;
        skos:prefLabel "Customer Facing Service" ;
        skos:inScheme <kos/service/type>
    ] ;
    noria:elementManagedBy ex:JaneSmith .

