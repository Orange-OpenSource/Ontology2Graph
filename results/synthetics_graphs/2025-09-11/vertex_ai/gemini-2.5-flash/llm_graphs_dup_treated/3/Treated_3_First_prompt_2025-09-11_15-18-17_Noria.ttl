# --- Organizations and Agents ---

ex:OrangeCorp_extra_node_2
    a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main organizational entity for this knowledge graph." ;
    org:hasUnit ex:ITOperationsDept_extra_node_2 .

ex:ITOperationsDept_extra_node_2
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "A department within Orange Corp responsible for IT operations." ;
    org:unitOf ex:OrangeCorp_extra_node_2 ;
    org:hasMember ex:JaneSmith_extra_node_2, ex:JohnDoe_extra_node_2 .

ex:NetworkTeam_extra_node_2
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "A specialized team within IT Operations focusing on network infrastructure." ;
    org:unitOf ex:ITOperationsDept_extra_node_2 ;
    org:hasMember ex:JohnDoe_extra_node_2 ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)" ;
    noria:agentInstructions "Contact via internal_extra_node_2 ticketing system for critical_extra_node_2 issues." .

ex:JohnDoe_extra_node_2
    a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Network Engineer responsible for core network infrastructure." ;
    foaf:memberOf ex:NetworkTeam_extra_node_2 ;
    noria:agentManagesResource ex:Router01, ex:Router02, ex:FirewallFW01 ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] .

ex:JaneSmith_extra_node_2
    a foaf:Person ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Application Manager overseeing critical_extra_node_2 business applications." ;
    foaf:memberOf ex:ITOperationsDept_extra_node_2 ;
    noria:agentManagesResource ex:CoreBankingApp_extra_node_2, ex:CustomerPortalApp_extra_node_2 ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Phone" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] .

# --- Applications and Modules ---

ex:CoreBankingApp_extra_node_2
    a noria:Application ;
    rdfs:label "Core Banking Application" ;
    rdfs:comment "The primary application for managing customer banking operations." ;
