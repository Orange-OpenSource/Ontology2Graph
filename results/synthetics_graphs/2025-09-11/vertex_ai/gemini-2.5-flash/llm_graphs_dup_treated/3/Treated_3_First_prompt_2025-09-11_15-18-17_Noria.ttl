    noria:applicationModelIdentifier "CBA-V3.2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Business Critical" ;
        skos:inScheme <kos/application/type>
    ] ;
    noria:applicationBusinessImportance [
        a skos:Concept ;
        skos:prefLabel "High" ;
        skos:inScheme <kos/application/business-importance>
    ] ;
    noria:applicationFunctionalDomain "Financial Services" ;
    noria:elementManagedBy ex:JaneSmith_extra_node_2 .

ex:CoreBankingProdModule
