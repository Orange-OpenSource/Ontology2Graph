    rdfs:label "Central Log Management System" ;
    rdfs:comment "System responsible for collecting, storing, and analyzing logs from various IT components." ;
    noria:applicationShortIdentifier "LMS" ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Infrastructure Support" ;
        skos:inScheme <kos/application/type>
    ] ;
    noria:elementManagedBy ex:ITOperationsDept_extra_node_2 .

