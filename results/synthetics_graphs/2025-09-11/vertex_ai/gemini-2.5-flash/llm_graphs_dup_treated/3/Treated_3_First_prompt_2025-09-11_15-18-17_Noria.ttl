    noria:applicationModuleName "CBA_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept_extra_node_2 ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith_extra_node_2 ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Production" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status_extra_node_2>
    ] ;
    noria:applicationModuleSlaLevel [
        a skos:Concept ;
        skos:prefLabel "Platinum" ;
        skos:inScheme <https://w3id.org/noria/kos/application/sla-level>
    ] ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

ex:CustomerPortalApp_extra_node_2
    a noria:Application ;
    rdfs:label "Customer Portal Application" ;
    rdfs:comment "Web application allowing customers to access their accounts." ;
    noria:applicationShortIdentifier "CPA" ;
    noria:applicationModelIdentifier "CPA-V1.5" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Customer Facing" ;
        skos:inScheme <kos/application/type>
    ] ;
