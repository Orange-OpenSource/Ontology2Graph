    noria:applicationModuleName "CPA_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept_extra_node_2 ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith_extra_node_2 ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Development" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status_extra_node_2>
    ] .

ex:LogManagementSystem
