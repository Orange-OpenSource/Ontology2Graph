@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix pep: <https://w3id.org/pep/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix ex: <http://example.com/noria-kg/> .

# Define some dummy SKOS concepts for properties that expect them
# In a real scenario, these would come from a separate KOS (Knowledge Organization System) file.
ex:AppStatusInProduction
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status_extra_node_0> ;
    rdfs:label "In Production"@en .

ex:AppStatusDevelopment
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status_extra_node_0> ;
    rdfs:label "Development"@en .

ex:ResTypeServer
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Server"@en .

ex:ResTypeRouter
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Router"@en .

ex:NetIntOperationalStatusUp
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Up"@en .

ex:NetIntOperationalStatusDown
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Down"@en .

ex:TTSeverityMajor
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en .

ex:TTSeverityCritical
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Critical"@en .

ex:TTStatusInProgress
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status_extra_node_0> ;
    rdfs:label "In Progress"@en .

ex:TTStatusResolved
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status_extra_node_0> ;
    rdfs:label "Resolved"@en .

ex:AlarmSeverityCritical
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical"@en .

ex:AlarmSeverityWarning
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning"@en .

# --- Organizations and Agents ---
ex:ITOperationsDept_extra_node_0
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The central department responsible for IT infrastructure and application operations."@en ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)" ;
    noria:agentInstructions "Contact via internal_extra_node_0 ticketing system for all requests." .

ex:NetworkTeam_extra_node_0
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call rotation" ;
    noria:agentInstructions "For critical_extra_node_0 network issues, use emergency hotline." .

ex:AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Administrator for Customer Portal Production."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    org:memberOf ex:ITOperationsDept_extra_node_0 .

ex:BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead Developer for Customer Portal Development Environment."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    org:memberOf ex:ITOperationsDept_extra_node_0 .

ex:CustomerSupport
    a org:OrganizationalUnit ;
    rdfs:label "Customer Support Center"@en ;
    rdfs:comment "First-line support for customer-facing services."@en ;
    noria:agentWorkingHours "24/7" .

# --- Applications ---
ex:CustomerPortalApp_extra_node_0
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "The main web application allowing customers to manage their services."@en ;
    noria:applicationShortIdentifier "CUSTPORT" ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:elementManagedBy ex:ITOperationsDept_extra_node_0 .

ex:LogManagementApp
    a noria:Application ;
    rdfs:label "Central Log Management System"@en ;
    rdfs:comment "System responsible for collecting, storing, and analyzing logs from all IT infrastructure."@en ;
    noria:applicationShortIdentifier "LOGSYS" ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:elementManagedBy ex:NetworkTeam_extra_node_0 .

# --- Application Modules ---
ex:CustomerPortalProd
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "The live production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp_extra_node_0 ;
    noria:applicationModuleName "CUSTPORT_PROD" ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept_extra_node_0 ;
    noria:applicationModuleSupportLeader ex:AliceSmith ;
    noria:applicationModuleStatus ex:AppStatusInProduction ;
    noria:applicationModuleHotlineEnabled true .

ex:CustomerPortalDev
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en ;
    rdfs:comment "The development instance of the Customer Portal application for testing and new features."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp_extra_node_0 ;
    noria:applicationModuleName "CUSTPORT_DEV" ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept_extra_node_0 ;
    noria:applicationModuleSupportLeader ex:BobJohnson ;
    noria:applicationModuleStatus ex:AppStatusDevelopment ;
    noria:applicationModuleHotlineEnabled false .

# --- Resources ---
ex:WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server_extra_node_0 hosting the Customer Portal production frontend."@en ;
    noria:resourceHostName "web-srv-01.example.com" ;
    noria:resourceType ex:ResTypeServer ;
    noria:resourceForApplication ex:CustomerPortalProd ;
    noria:resourceManagedBy ex:ITOperationsDept_extra_node_0 ;
    noria:locatedAtLocus ex:RackA1Locus ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime .

ex:DBSrv02
    a noria:Resource ;
    rdfs:label "Database Server 02"@en ;
    rdfs:comment "Database server_extra_node_0 supporting the Customer Portal production backend."@en ;
    noria:resourceHostName "db-srv-02.example.com" ;
    noria:resourceType ex:ResTypeServer ;
    noria:resourceForApplication ex:CustomerPortalProd ;
    noria:resourceManagedBy ex:ITOperationsDept_extra_node_0 ;
    noria:locatedAtLocus ex:RackA2Locus ;
    noria:resourceInstallationDate "2023-01-15T11:00:00Z"^^xsd:dateTime .

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router_extra_node_0 for internal_extra_node_0 network traffic, including application connectivity."@en ;
    noria:resourceHostName "core-rtr-01.example.com" ;
    noria:resourceType ex:ResTypeRouter ;
    noria:resourceManagedBy ex:NetworkTeam_extra_node_0 ;
    noria:locatedAtLocus ex:RackB1Locus ;
    noria:resourceInstallationDate "2022-05-20T09:00:00Z"^^xsd:dateTime .

# --- Network Interfaces ---
ex:WebSrv01Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for Web Server 01."@en ;
    noria:networkInterfaceOf ex:WebSrv01 ;
    noria:networkInterfaceDescription "Primary interface to application network" ;
    noria:networkInterfaceOperationalStatus ex:NetIntOperationalStatusUp .

ex:DBSrv02Eth0
    a noria:NetworkInterface ;
    rdfs:label "DBSrv02 Ethernet 0"@en ;
    rdfs:comment "Main network interface for Database Server 02."@en ;
    noria:networkInterfaceOf ex:DBSrv02 ;
    noria:networkInterfaceDescription "Primary interface to application network" ;
    noria:networkInterfaceOperationalStatus ex:NetIntOperationalStatusUp .

ex:CoreRouter01Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Uplink interface for Core Router 01."@en ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to core network" ;
    noria:networkInterfaceOperationalStatus ex:NetIntOperationalStatusUp .

# --- Network Links ---
ex:LinkWebDB
    a noria:NetworkLink ;
    rdfs:label "Link between WebSrv01 and DBSrv02"@en ;
    rdfs:comment "Logical link connecting the web server_extra_node_0 to the database server_extra_node_0."@en ;
    noria:networkLinkId "APP-LINK-001" ;
    noria:networkLinkType "Internal Application Link" ;
    noria:networkLinkTerminationResourceOrigin ex:WebSrv01 ;
    noria:networkLinkTerminationResourceDestination ex:DBSrv02 ;
    noria:networkLinkInstallationDate "2023-01-15T12:00:00Z"^^xsd:dateTime .

ex:WebSrv01Eth0 noria:networkInterfaceConnects ex:LinkWebDB .
ex:DBSrv02Eth0 noria:networkInterfaceConnects ex:LinkWebDB .

# --- Locations ---
ex:MainDataCenter_extra_node_0
    a bot:Site ;
    rdfs:label "Main Data Center - Paris"@en ;
    rdfs:comment "The primary data center facility."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "Data Center" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressPostalCode "75000" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Donnée" .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server_extra_node_0 room within the Main Data Center."@en ;
    bot:hasSpace ex:MainDataCenter_extra_node_0 . # bot:hasSpace can relate a Site to a Space (Room is a Space)

ex:RackA1Locus
    a noria:Locus ;
    rdfs:label "Rack A1, Server Room A"@en ;
    rdfs:comment "Specific location of Rack A1 within Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace ex:ServerRoomA .

ex:RackA2Locus
    a noria:Locus ;
    rdfs:label "Rack A2, Server Room A"@en ;
    rdfs:comment "Specific location of Rack A2 within Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasSpace ex:ServerRoomA .

ex:RackB1Locus
    a noria:Locus ;
    rdfs:label "Rack B1, Server Room A"@en ;
    rdfs:comment "Specific location of Rack B1 within Server Room A."@en ;
    noria:locusLine "B" ;
    noria:locusRow "1" ;
    bot:hasSpace ex:ServerRoomA .

# --- Trouble Tickets ---
ex:TT20240701-001
    a noria:TroubleTicket ;
    rdfs:label "Customer Portal Login Failure"@en ;
    rdfs:comment "Users are unable to log in to the Customer Portal production environment."@en ;
    noria:troubleTicketSeverity ex:TTSeverityMajor ;
    noria:troubleTicketCause "Database connection pool exhaustion on DBSrv02." ;
    noria:troubleTicketRelatedService ex:CustomerPortalProd ;
    noria:troubleTicketRelatedResource ex:DBSrv02 ;
    noria:troubleTicketRelatedParty ex:CustomerSupport ;
    noria:troubleTicketStatusCurrent ex:TTStatusInProgress ;
    noria:troubleTicketDetectionDateTime "2024-07-01T09:30:00Z"^^xsd:dateTime ;
    noria:documentHRef <http://itsm.example.com/tickets/TT20240701-001> .

ex:TT20240701-002
    a noria:TroubleTicket ;
    rdfs:label "Core Router Interface Down"@en ;
    rdfs:comment "GigabitEthernet 0/0/1 on Core Router 01 is showing an 'administratively down' status_extra_node_0."@en ;
    noria:troubleTicketSeverity ex:TTSeverityCritical ;
    noria:troubleTicketCause "Interface Gi0/0/1 on core-rtr-01 was manually shut down without proper change management." ;
    noria:troubleTicketRelatedResource ex:CoreRouter01 ;
    noria:troubleTicketRelatedParty ex:NetworkTeam_extra_node_0 ;
    noria:troubleTicketStatusCurrent ex:TTStatusResolved ;
    noria:troubleTicketDetectionDateTime "2024-07-01T14:15:00Z"^^xsd:dateTime ;
    noria:documentHRef <http://itsm.example.com/tickets/TT20240701-002> .

# --- Event Records (for Trouble Ticket status_extra_node_0 history) ---
ex:EventTT001Created
    a noria:EventRecord ;
    rdfs:label "TT20240701-001 Created Event"@en ;
    rdfs:comment "Log entry for the creation of Trouble Ticket 20240701-001."@en ;
    noria:loggingTime "2024-07-01T09:30:05Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem ex:LogManagementApp ;
    noria:logText "New Trouble Ticket created: Customer Portal Login Failure." ;
    noria:alarmSeverity ex:AlarmSeverityWarning ;
    noria:logOriginatingManagedObject ex:CustomerPortalProd .

ex:EventTT001InProgress
    a noria:EventRecord ;
    rdfs:label "TT20240701-001 Status Change to In Progress"@en ;
    rdfs:comment "Log entry for status_extra_node_0 change of Trouble Ticket 20240701-001 to In Progress."@en ;
    noria:loggingTime "2024-07-01T09:45:10Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem ex:LogManagementApp ;
    noria:logText "Trouble Ticket TT20240701-001 status_extra_node_0 changed to In Progress by Alice Smith." ;
    noria:alarmSeverity ex:AlarmSeverityWarning ;
    noria:logOriginatingAgent ex:AliceSmith .

ex:TT20240701-001 noria:documentStatusHistory ex:EventTT001Created, ex:EventTT001InProgress .

ex:EventTT002Created
    a noria:EventRecord ;
    rdfs:label "TT20240701-002 Created Event"@en ;
    rdfs:comment "Log entry for the creation of Trouble Ticket 20240701-002."@en ;
    noria:loggingTime "2024-07-01T14:15:02Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem ex:LogManagementApp ;
    noria:logText "New Trouble Ticket created: Core Router Interface Down." ;
    noria:alarmSeverity ex:AlarmSeverityCritical ;
    noria:logOriginatingManagedObject ex:CoreRouter01 .

ex:EventTT002Resolved
    a noria:EventRecord ;
    rdfs:label "TT20240701-002 Status Change to Resolved"@en ;
    rdfs:comment "Log entry for status_extra_node_0 change of Trouble Ticket 20240701-002 to Resolved."@en ;
    noria:loggingTime "2024-07-01T14:45:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem ex:LogManagementApp ;
    noria:logText "Trouble Ticket TT20240701-002 status_extra_node_0 changed to Resolved after interface brought up_extra_node_0." ;
    noria:alarmSeverity ex:AlarmSeverityWarning ;
    noria:logOriginatingAgent ex:BobJohnson .

ex:TT20240701-002 noria:documentStatusHistory ex:EventTT002Created, ex:EventTT002Resolved .
