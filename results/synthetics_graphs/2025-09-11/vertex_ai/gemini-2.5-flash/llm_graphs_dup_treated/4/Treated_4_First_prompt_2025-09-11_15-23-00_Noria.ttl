# --- Organizations and Agents ---

ex:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main corporate entity responsible for the entire infrastructure."@en .

ex:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for managing IT infrastructure and services."@en ;
    org:subOrganizationOf ex:OrangeCorp .

ex:NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team within IT Operations managing network resources."@en ;
    org:subOrganizationOf ex:ITOperationsDept .

ex:JohnDoe_extra_node_5
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Network Engineer, responsible for critical_extra_node_5 network infrastructure."@en ;
