# --- Organizations and Agents ---

ex:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main corporate entity responsible for the entire infrastructure."@en .

ex:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for managing IT infrastructure and services."@en ;
    org:subOrganizationOf ex:OrangeCorp .

ex:NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team within IT Operations managing network resources."@en ;
    org:subOrganizationOf ex:ITOperationsDept .

ex:JohnDoe_extra_node_1
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Network Engineer, responsible for critical_extra_node_1 network infrastructure."@en ;
    org:memberOf ex:NetworkTeam ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <http://example.com/kos/contact/email> ;
    noria:agentInstructions "Contact via internal_extra_node_1 ticketing system for non-urgent issues."^^xsd:string .

ex:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "IT Service Manager, overseeing application modules and incident response."@en ;
    org:memberOf ex:ITOperationsDept ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <http://example.com/kos/contact/phone> .

# --- Locations ---

ex:MainDataCenter
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for core services."@en ;
    noria:siteId "DC-MAIN-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "USA"^^xsd:string .

ex:ServerRoom_A
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Dedicated server_extra_node_1 room within the Main Data Center."@en ;
    bot:hasSpace ex:MainDataCenter . # bot:hasSpace is inverse of bot:containsZone, so MainDataCenter contains ServerRoom_A

ex:Rack_A1_Position
    a noria:Locus ;
    rdfs:label "Rack A1 Position"@en ;
    rdfs:comment "Specific location for Rack A1 within Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasZone ex:ServerRoom_A . # bot:hasZone is inverse of bot:containsZone, so ServerRoom_A contains Rack_A1_Position

# --- Applications and Services ---

