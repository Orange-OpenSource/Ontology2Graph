@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix pep: <https://w3id.org/pep/> .
@prefix seas: <https://w3id.org/seas/> .

# Declare example.com as the base for our entities
@prefix ex: <http://example.com/data/> .

# =============================================================================
# Entities and their relationships
# =============================================================================

# --- Organizations and Agents ---
ex:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "The central department responsible for managing IT infrastructure and applications." ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the emergency hotline." ;
.

ex:NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team" ;
    rdfs:comment "A specialized unit within IT Operations focusing on network infrastructure." ;
    org:unitOf ex:ITOperationsDept ;
    noria:agentWorkingHours "24/7 On-call rotation" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
.

ex:AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith" ;
    rdfs:comment "Lead administrator for the Customer Portal application." ;
    org:memberOf ex:ITOperationsDept ;
    foaf:mbox <mailto:alice.smith@example.com> ;
.

ex:BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson" ;
    rdfs:comment "Support leader for development environments." ;
    org:memberOf ex:ITOperationsDept ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
.

ex:CustomerSupport
    a org:OrganizationalUnit ;
    rdfs:label "Customer Support Center" ;
    rdfs:comment "First-line support for customer-facing services." ;
    noria:agentWorkingHours "24/7" ;
.

# --- Applications ---
ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "Customer Portal Application" ;
    rdfs:comment "Web application allowing customers to manage their accounts and services." ;
    noria:applicationShortIdentifier "CustPortal" ;
    noria:applicationModelIdentifier "CP-V2.1" ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:elementManagedBy ex:ITOperationsDept ;
.

ex:LogManagementApp
    a noria:Application ;
    rdfs:label "Centralized Log Management System" ;
    rdfs:comment "System for collecting, parsing, and analyzing logs from various IT components." ;
    noria:applicationShortIdentifier "LogMan" ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:elementManagedBy ex:NetworkTeam ;
.

# --- Application Modules ---
ex:CustomerPortalProd
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Instance" ;
    rdfs:comment "The live, production environment of the Customer Portal." ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CustPortal_Prod" ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept ;
    noria:applicationModuleSupportLeader ex:AliceSmith ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-15T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
.

ex:CustomerPortalDev
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Instance" ;
    rdfs:comment "The development environment for new features of the Customer Portal." ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CustPortal_Dev" ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept ;
    noria:applicationModuleSupportLeader ex:BobJohnson ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InDevelopment> ;
    noria:applicationModuleHotlineEnabled false ;
.

# --- Resources ---
ex:WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01" ;
    rdfs:comment "Primary web server hosting the Customer Portal production frontend." ;
    noria:resourceHostName "websrv01.example.com" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/WebServer> ;
    noria:resourceForApplication ex:CustomerPortalProd ;
    noria:resourceManagedBy ex:ITOperationsDept ;
    noria:locatedAtLocus ex:RackA1Locus ;
    noria:resourceInstallationDate "2022-03-10T00:00:00Z"^^xsd:dateTime ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InUse> ;
    noria:resourceManagementIPAddress "192.168.1.101" ;
.

ex:DBSrv02
    a noria:Resource ;
    rdfs:label "Database Server 02" ;
    rdfs:comment "Database server supporting the Customer Portal production backend." ;
    noria:resourceHostName "dbsrv02.example.com" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/DatabaseServer> ;
    noria:resourceForApplication ex:CustomerPortalProd ;
    noria:resourceManagedBy ex:ITOperationsDept ;
    noria:locatedAtLocus ex:RackA2Locus ;
    noria:resourceInstallationDate "2022-03-10T00:00:00Z"^^xsd:dateTime ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InUse> ;
    noria:resourceManagementIPAddress "192.168.1.102" ;
.

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01" ;
    rdfs:comment "Main router for internal network traffic." ;
    noria:resourceHostName "corerouter01.example.com" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkRouter> ;
    noria:resourceManagedBy ex:NetworkTeam ;
    noria:locatedAtLocus ex:RackB1Locus ;
    noria:resourceInstallationDate "2021-05-20T00:00:00Z"^^xsd:dateTime ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InUse> ;
    noria:resourceManagementIPAddress "10.0.0.1" ;
.

# --- Network Interfaces ---
ex:WebSrv01Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0" ;
    rdfs:comment "Network interface for WebSrv01, connected to the internal network." ;
    noria:networkInterfaceOf ex:WebSrv01 ;
    noria:networkInterfaceDescription "Main production interface" ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceConnects ex:LinkWebDB ;
.

ex:DBSrv02Eth0
    a noria:NetworkInterface ;
    rdfs:label "DBSrv02 Ethernet 0" ;
    rdfs:comment "Network interface for DBSrv02, connected to the internal network." ;
    noria:networkInterfaceOf ex:DBSrv02 ;
    noria:networkInterfaceDescription "Main production interface" ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceConnects ex:LinkWebDB ;
.

ex:CoreRouter01Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/0/1" ;
    rdfs:comment "Uplink interface for CoreRouter01." ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to ISP" ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -7 ;
.

# --- Network Links ---
ex:LinkWebDB
    a noria:NetworkLink ;
    rdfs:label "Link between WebSrv01 and DBSrv02" ;
    rdfs:comment "Logical link connecting the web server to the database server." ;
    noria:networkLinkId "LINK-WEB-DB-001" ;
    noria:networkLinkTerminationResourceOrigin ex:WebSrv01 ;
    noria:networkLinkTerminationResourceDestination ex:DBSrv02 ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-03-10T00:00:00Z"^^xsd:dateTime ;
.

# --- Locations ---
ex:MainDataCenter
    a bot:Site ;
    rdfs:label "Main Data Center" ;
    rdfs:comment "The primary data center facility." ;
    noria:siteId "DC-MAIN-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "USA" ;
.

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A" ;
    rdfs:comment "A server room within the main data center." ;
    bot:hasSpace ex:MainDataCenter ; # bot:hasSpace is inverse of bot:containsZone, bot:Site is a bot:Space
.

ex:RackA1Locus
    a noria:Locus ;
    rdfs:label "Rack A1, Server Room A" ;
    rdfs:comment "Specific location for WebSrv01." ;
    bot:hasSpace ex:ServerRoomA ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
.

ex:RackA2Locus
    a noria:Locus ;
    rdfs:label "Rack A2, Server Room A" ;
    rdfs:comment "Specific location for DBSrv02." ;
    bot:hasSpace ex:ServerRoomA ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
.

ex:RackB1Locus
    a noria:Locus ;
    rdfs:label "Rack B1, Server Room A" ;
    rdfs:comment "Specific location for CoreRouter01." ;
    bot:hasSpace ex:ServerRoomA ;
    noria:locusLine "B" ;
    noria:locusRow "1" ;
.

# --- Trouble Tickets ---
ex:TT20240701-001
    a noria:TroubleTicket ;
    rdfs:label "Customer Portal Login Issue" ;
    rdfs:comment "Customers unable to log in to the portal due to database connectivity problems." ;
    dcterms:created "2024-07-01T09:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-2024-001" ;
    noria:documentHRef "http://itsm.example.com/tickets/INC-2024-001" ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <https://w3id.org/noria/kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <https://w3id.org/noria/kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <https://w3id.org/noria/kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketCause "Database connection pool exhausted, leading to login failures." ;
    noria:troubleTicketDetectionDateTime "2024-07-01T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService ex:CustomerPortalProd ;
    noria:troubleTicketRelatedResource ex:DBSrv02 ;
    noria:troubleTicketRelatedParty ex:CustomerSupport ;
.

# --- Event Records ---
ex:EventLogWebSrv01_CPU_High
    a noria:EventRecord ;
    rdfs:label "WebSrv01 High CPU Alert" ;
    rdfs:comment "Alert indicating high CPU utilization on WebSrv01." ;
    noria:loggingTime "2024-07-01T08:55:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on websrv01.example.com exceeded 90% for 5 minutes." ;
    noria:logOriginatingManagedObject ex:WebSrv01 ;
    noria:logOriginatingManagementSystem ex:LogManagementApp ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:type <https://w3id.org/noria/kos/Notification/EventType/ThresholdCrossingAlert> ;
.

ex:EventLogDBSrv02_ConnError
    a noria:EventRecord ;
    rdfs:label "DBSrv02 Connection Error" ;
    rdfs:comment "Log entry indicating a database connection error from DBSrv02." ;
    noria:loggingTime "2024-07-01T09:05:00Z"^^xsd:dateTime ;
    noria:logText "Failed to establish connection to database: Connection refused." ;
    noria:logOriginatingManagedObject ex:DBSrv02 ;
    noria:logOriginatingManagementSystem ex:LogManagementApp ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <https://w3id.org/noria/kos/Notification/EventType/OperationalAlarm> ;
    noria:alarmProposedRepairAction ex:RestartDBServicePlan ;
.

ex:RestartDBServicePlan
    a noria:OperationPlan ;
    rdfs:label "Restart Database Service Procedure" ;
    rdfs:comment "Standard operating procedure for restarting the database service." ;
    noria:operationPlanPreCondition ex:DBServiceDownPreCondition ;
    noria:operationPlanPostCondition ex:DBServiceUpPostCondition ;
.

ex:DBServiceDownPreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Database Service Down" ;
    rdfs:comment "Condition: Database service is not running or unreachable." ;
.

ex:DBServiceUpPostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Database Service Up" ;
    rdfs:comment "Expected outcome: Database service is running and accessible." ;
.

ex:TT20240701-001 noria:documentStatusHistory ex:EventLogDBSrv02_ConnError .
