@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix pep: <https://w3id.org/pep/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix ex: <http://example.com/noria/> .

# --- Organizations and Agents ---

ex:ITOperationsDept
    a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The central department responsible for managing IT infrastructure and services."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for all requests."^^xsd:string .

ex:NetworkServicesInc
    a org:Organization ;
    rdfs:label "Network Services Inc."@en ;
    rdfs:comment "External vendor providing network infrastructure services."@en ;
    noria:agentPreferredContactMethod ex:EmailContactMethod ;
    noria:agentInstructions "For critical issues, use dedicated hotline."^^xsd:string .

ex:AliceSmith
    a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer in the IT Operations Department."@en ;
    org:memberOf ex:ITOperationsDept ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"^^xsd:string .

ex:BobJohnson
    a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    org:memberOf ex:ITOperationsDept ;
    noria:agentPreferredContactMethod ex:PhoneContactMethod .

ex:EmailContactMethod
    a skos:Concept ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via email."@en .

ex:PhoneContactMethod
    a skos:Concept ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via phone."@en .

# --- Locations ---

ex:MainDataCenter
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for the organization."@en ;
    noria:siteId "DC-MIA-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Miami"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "33101"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A specific server room within the Main Data Center."@en ;
    bot:hasSpace ex:MainDataCenter .

ex:Rack12Unit5
    a noria:Locus ;
    rdfs:label "Rack 12, Unit 5"@en ;
    rdfs:comment "Specific location within Server Room A where a resource is housed."@en ;
    noria:locusLine "L12"^^xsd:string ;
    noria:locusRow "U5"^^xsd:string ;
    bot:containsZone ex:ServerRoomA .

# --- Product Models ---

ex:CiscoCatalyst9300
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Product model for a network switch."@en ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:DellPowerEdgeR750
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "Product model for a server."@en ;
    noria:productManufacturedBy ex:DellTechnologies .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

ex:DellTechnologies
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server and computing equipment."@en .

# --- Resources ---

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary network router in the data center."@en ;
    noria:resourceLogisticId "CR01-DC-MIA"^^xsd:string ;
    noria:resourceHostName "core-router-01.example.com"^^xsd:string ;
    noria:resourceProductModel ex:CiscoCatalyst9300 ;
    noria:resourceType ex:NetworkRouterType ;
    noria:resourceSerialNumber "SN-CR01-XYZ"^^xsd:string ;
    noria:resourceUsageState ex:InProductionState ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack12Unit5 ;
    noria:resourceManagementIPAddress ex:CoreRouter01MgmtIP ;
    noria:resourceManagedBy ex:ITOperationsDept ;
    noria:resourceForApplication ex:CustomerPortalApp .

ex:AppServer01
    a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting the Customer Portal Application."@en ;
    noria:resourceLogisticId "AS01-DC-MIA"^^xsd:string ;
    noria:resourceHostName "app-server-01.example.com"^^xsd:string ;
    noria:resourceProductModel ex:DellPowerEdgeR750 ;
    noria:resourceType ex:WebServerType ;
    noria:resourceSerialNumber "SN-AS01-ABC"^^xsd:string ;
    noria:resourceUsageState ex:InProductionState ;
    noria:resourceInstallationDate "2022-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack12Unit5 ;
    noria:resourceManagementIPAddress ex:AppServer01MgmtIP ;
    noria:resourceManagedBy ex:ITOperationsDept ;
    noria:resourceForApplication ex:CustomerPortalApp .

ex:DBServer01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Server hosting the database for the Customer Portal Application."@en ;
    noria:resourceLogisticId "DB01-DC-MIA"^^xsd:string ;
    noria:resourceHostName "db-server-01.example.com"^^xsd:string ;
    noria:resourceProductModel ex:DellPowerEdgeR750 ;
    noria:resourceType ex:DatabaseServerType ;
    noria:resourceSerialNumber "SN-DB01-DEF"^^xsd:string ;
    noria:resourceUsageState ex:InProductionState ;
    noria:resourceInstallationDate "2022-03-01T15:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack12Unit5 ;
    noria:resourceManagementIPAddress ex:DBServer01MgmtIP ;
    noria:resourceManagedBy ex:ITOperationsDept ;
    noria:resourceForApplication ex:CustomerPortalApp .

ex:NetworkRouterType
    a skos:Concept ;
    rdfs:label "Network Router"@en ;
    rdfs:comment "Type of resource: network router."@en .

ex:WebServerType
    a skos:Concept ;
    rdfs:label "Web Server"@en ;
    rdfs:comment "Type of resource: web server."@en .

ex:DatabaseServerType
    a skos:Concept ;
    rdfs:label "Database Server"@en ;
    rdfs:comment "Type of resource: database server."@en .

ex:InProductionState
    a skos:Concept ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Resource is currently in active production use."@en .

ex:CoreRouter01MgmtIP
    a observable:IPAddress ;
    rdfs:label "192.168.1.1" ;
    rdfs:comment "Management IP address for Core Router 01." .

ex:AppServer01MgmtIP
    a observable:IPAddress ;
    rdfs:label "192.168.1.10" ;
    rdfs:comment "Management IP address for Application Server 01." .

ex:DBServer01MgmtIP
    a observable:IPAddress ;
    rdfs:label "192.168.1.20" ;
    rdfs:comment "Management IP address for Database Server 01." .

# --- Network Interfaces ---

ex:CoreRouter01Eth0_1
    a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 Ethernet 0/1"@en ;
    rdfs:comment "Network interface on Core Router 01 connected to the application segment."@en ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceAdministrativeStatus ex:InterfaceStatusUp ;
    noria:networkInterfaceOperationalStatus ex:InterfaceStatusUp .

ex:AppServer01Eth0
    a noria:NetworkInterface ;
    rdfs:label "AppServer01 Ethernet 0"@en ;
    rdfs:comment "Network interface on Application Server 01."@en ;
    noria:networkInterfaceOf ex:AppServer01 ;
    noria:networkInterfaceAdministrativeStatus ex:InterfaceStatusUp ;
    noria:networkInterfaceOperationalStatus ex:InterfaceStatusUp .

ex:DBServer01Eth0
    a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0"@en ;
    rdfs:comment "Network interface on Database Server 01."@en ;
    noria:networkInterfaceOf ex:DBServer01 ;
    noria:networkInterfaceAdministrativeStatus ex:InterfaceStatusUp ;
    noria:networkInterfaceOperationalStatus ex:InterfaceStatusUp .

ex:InterfaceStatusUp
    a skos:Concept ;
    rdfs:label "Up"@en ;
    rdfs:comment "Network interface is administratively and operationally up."@en .

ex:InterfaceStatusDown
    a skos:Concept ;
    rdfs:label "Down"@en ;
    rdfs:comment "Network interface is administratively or operationally down."@en .

# --- Network Links ---

ex:LinkRouterAppServer
    a noria:NetworkLink ;
    rdfs:label "Link: Core Router to App Server"@en ;
    rdfs:comment "Network link connecting Core Router 01 to Application Server 01."@en ;
    noria:networkLinkId "NL-CR01-AS01"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin ex:CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination ex:AppServer01 ;
    noria:networkLinkInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    ex:CoreRouter01Eth0_1 noria:networkInterfaceConnects ex:LinkRouterAppServer ;
    ex:AppServer01Eth0 noria:networkInterfaceConnects ex:LinkRouterAppServer .

ex:LinkAppServerDBServer
    a noria:NetworkLink ;
    rdfs:label "Link: App Server to DB Server"@en ;
    rdfs:comment "Network link connecting Application Server 01 to Database Server 01."@en ;
    noria:networkLinkId "NL-AS01-DB01"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin ex:AppServer01 ;
    noria:networkLinkTerminationResourceDestination ex:DBServer01 ;
    noria:networkLinkInstallationDate "2022-03-01T16:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps"^^xsd:string ;
    ex:AppServer01Eth0 noria:networkInterfaceConnects ex:LinkAppServerDBServer ;
    ex:DBServer01Eth0 noria:networkInterfaceConnects ex:LinkAppServerDBServer .

# --- Applications & Modules ---

ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "Web application allowing customers to manage their accounts."@en ;
    noria:applicationModelIdentifier "CPA-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CPA"^^xsd:string ;
    noria:applicationType ex:WebApplicationType ;
    noria:applicationBusinessImportance ex:HighBusinessImportance ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Customer Self-Service"^^xsd:string .

ex:CustomerPortalAppProd
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Application - Production Module"@en ;
    rdfs:comment "The production instance of the Customer Portal Application."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CPA_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-01"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsDept ;
    noria:applicationModuleSupportTeam ex:ITOperationsDept ;
    noria:applicationModuleStatus ex:InProductionStatus ;
    noria:applicationModuleAdministrationLeader ex:AliceSmith ;
    noria:applicationModuleSupportLeader ex:BobJohnson .

ex:WebApplicationType
    a skos:Concept ;
    rdfs:label "Web Application"@en ;
    rdfs:comment "Type of application: web-based."@en .

ex:HighBusinessImportance
    a skos:Concept ;
    rdfs:label "High"@en ;
    rdfs:comment "High business importance for the application."@en .

ex:InProductionStatus
    a skos:Concept ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application module is currently in production."@en .

# --- Services ---

ex:CustomerFacingWebservice
    a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "End-to-end service providing customer access to the portal."@en ;
    noria:serviceType ex:CustomerFacingServiceType ;
    ex:CustomerPortalAppProd seas:subSystemOf ex:CustomerFacingWebservice .

ex:CustomerFacingServiceType
    a skos:Concept ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "Service directly exposed to customers."@en .

# --- Event Records ---

ex:RouterDownEvent
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:logOriginatingManagedObject ex:CoreRouter01 ;
    noria:logOriginatingManagementSystem ex:NetworkMonitoringSystem ;
    noria:logOriginatingAgent ex:NetworkServicesInc ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:loggingTime "2024-03-15T09:30:00Z"^^xsd:dateTime ;
    noria:alarmSeverity ex:CriticalSeverity .

ex:AppErrorLog
    a noria:EventRecord ;
    rdfs:label "Application Error Log"@en ;
    rdfs:comment "Log entry indicating a critical error in the Customer Portal Application."@en ;
    noria:logOriginatingManagedObject ex:AppServer01 ;
    noria:logOriginatingManagementSystem ex:ApplicationMonitoringSystem ;
    noria:logText "ERROR: CustomerPortalApp: Database connection failed for user 'portal_user'."^^xsd:string ;
    noria:loggingTime "2024-03-15T09:35:00Z"^^xsd:dateTime ;
    noria:alarmSeverity ex:MajorSeverity .

ex:NetworkMonitoringSystem
    a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "System responsible for monitoring network devices."@en .

ex:ApplicationMonitoringSystem
    a noria:Application ;
    rdfs:label "Application Monitoring System"@en ;
    rdfs:comment "System responsible for monitoring application health."@en .

ex:CriticalSeverity
    a skos:Concept ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Highest severity level for an alarm."@en .

ex:MajorSeverity
    a skos:Concept ;
    rdfs:label "Major"@en ;
    rdfs:comment "Major severity level for an alarm."@en .

# --- Trouble Tickets ---

ex:TT-20240315-001
    a noria:TroubleTicket ;
    rdfs:label "Customer Portal Outage - Core Router Interface Down"@en ;
    rdfs:comment "Trouble ticket opened due to a critical outage of the Customer Portal, caused by a router interface failure."@en ;
    noria:documentExternalId "INC-2024-00123"^^xsd:string ;
    noria:documentHRef "http://itsm.example.com/tickets/INC-2024-00123"^^xsd:anyURI ;
    noria:troubleTicketSeverity ex:BlockingSeverity ;
    noria:troubleTicketType ex:FailureTicketType ;
    noria:troubleTicketPriority ex:P1Priority ;
    noria:troubleTicketOrigin ex:SupervisionOrigin ;
    noria:troubleTicketTrigger ex:RouterDownEvent ;
    noria:troubleTicketStatusCurrent ex:InProgressStatus ;
    noria:troubleTicketRelatedParty ex:ITOperationsDept ;
    noria:troubleTicketRelatedService ex:CustomerFacingWebservice ;
    noria:troubleTicketRelatedResource ex:CoreRouter01 ;
    noria:troubleTicketCause "Core Router interface GigabitEthernet0/0/1 went down, impacting connectivity to application servers."^^xsd:string ;
    noria:troubleTicketDetectionDateTime "2024-03-15T09:30:00Z"^^xsd:dateTime .

ex:BlockingSeverity
    a skos:Concept ;
    rdfs:label "Blocking"@en ;
    rdfs:comment "Severity indicating a complete service blockage."@en .

ex:FailureTicketType
    a skos:Concept ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Trouble ticket type: system failure."@en .

ex:P1Priority
    a skos:Concept ;
    rdfs:label "P1"@en ;
    rdfs:comment "Priority 1: highest urgency and impact."@en .

ex:SupervisionOrigin
    a skos:Concept ;
    rdfs:label "Supervision"@en ;
    rdfs:comment "Trouble ticket originated from automated monitoring/supervision."@en .

ex:InProgressStatus
    a skos:Concept ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Trouble ticket is currently being worked on."@en .

# --- Operation Plans & Conditions ---

ex:RouterInterfaceRestartProcedure
    a noria:OperationPlan ;
    rdfs:label "Router Interface Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a router interface."@en ;
    noria:operationPlanPreCondition ex:RouterInterfaceDownPreCondition ;
    noria:operationPlanPostCondition ex:RouterInterfaceUpPostCondition .

ex:RouterInterfaceDownPreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Router Interface is Down"@en ;
    rdfs:comment "Pre-condition: The target router interface must be in a 'down' operational state."@en .

ex:RouterInterfaceUpPostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Router Interface is Up"@en ;
    rdfs:comment "Post-condition: The target router interface must be in an 'up' operational state and pingable."@en .

# --- Change Requests ---

ex:CR-20240316-001
    a noria:ChangeRequest ;
    rdfs:label "Core Router Firmware Upgrade"@en ;
    rdfs:comment "Planned firmware upgrade for Core Router 01 to address known vulnerabilities."@en ;
    noria:documentExternalId "CHG-2024-00500"^^xsd:string ;
    noria:documentHRef "http://itsm.example.com/changes/CHG-2024-00500"^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-03-20T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-20T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory ex:PreventativeMaintenanceCategory ;
    noria:changeRequestType ex:StandardChangeType ;
    noria:changeRequestChangeCause ex:SoftwareUpgradeCause ;
    noria:changeRequestImpact ex:CoreRouter01 ;
    noria:changeRequestStatusCurrent ex:ScheduledStatus ;
    noria:changeRequestInitiatorParty ex:AliceSmith ;
    noria:changeRequestPilotParty ex:AliceSmith .

ex:PreventativeMaintenanceCategory
    a skos:Concept ;
    rdfs:label "Preventative Maintenance"@en ;
    rdfs:comment "Change category: preventative maintenance."@en .

ex:StandardChangeType
    a skos:Concept ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Change type: pre-approved, low-risk change."@en .

ex:SoftwareUpgradeCause
    a skos:Concept ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Cause of change: software or firmware upgrade."@en .

ex:ScheduledStatus
    a skos:Concept ;
    rdfs:label "Scheduled"@en ;
    rdfs:comment "Change request is scheduled for execution."@en .
