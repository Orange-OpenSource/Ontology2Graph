@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix pep: <https://w3id.org/pep/> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix ex: <http://example.com/noria-kg/> .

ex:AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team" ;
    rdfs:comment "Team responsible for supporting critical business applications." ;
    org:unitOf ex:OrangeCorp ;
    noria:agentWorkingHours "Mon-Sun 8:00-20:00 CET" . 

ex:JaneSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Application Lead, member of the Application Support Team." ;
    org:memberOf ex:AppSupportTeam ;
    noria:agentWorkingHours "Mon-Fri 8:00-16:00 CET" .

ex:CustomerPortalProdModule
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module" ;
    rdfs:comment "Production instance of the Customer Portal application." ;
    noria:applicationModuleName "CPORTAL_PROD" ;
    noria:applicationModuleIdentifier "PROD-001" ;
    noria:applicationModuleAdministrationTeam ex:AppSupportTeam ;
    noria:applicationModuleSupportTeam ex:AppSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith ;
    noria:applicationModuleStatus ex:InProductionStatus .

ex:InProductionStatus
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production" .

