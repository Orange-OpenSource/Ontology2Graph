@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix pep: <https://w3id.org/pep/> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix ex: <http://example.com/noria-kg/> .




ex:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team" ;
    rdfs:comment "Team providing level 2 support for critical business applications." ;
    org:unitOf ex:OrangeCorp ;
    noria:agentWorkingHours "8:00-18:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Ticketing System" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] ;
    noria:agentInstructions "Submit all application-related issues via the internal ticketing system." .

ex:CRM_Prod_Module
    a noria:ApplicationModule ;
    rdfs:label "CRM Production Module" ;
    rdfs:comment "The production instance of the CRM application." ;
    noria:applicationModuleOf ex:CRM_Application ;
    noria:applicationModuleName "CRM-V3_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleSupportTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Production" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status>
    ] ;
    noria:applicationModuleSlaLevel [
        a skos:Concept ;
        skos:prefLabel "Platinum" ;
        skos:inScheme <https://w3id.org/noria/kos/application/sla-level>
    ] ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

