@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix pep: <https://w3id.org/pep/> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix ex: <http://example.com/noria-kg/> .

# --- Organizations and Agents ---

ex:OrangeCorp_extra_node_5
    a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main telecommunications company." ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method_extra_node_5>
    ] ;
    noria:agentInstructions "Contact via official support channels for all inquiries." .

ex:NetworkOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Team responsible for managing the core network infrastructure." ;
    org:unitOf ex:OrangeCorp_extra_node_5 ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Hotline" ;
        skos:inScheme <kos/org/agent-contact-method_extra_node_5>
    ] ;
    noria:agentInstructions "For critical incidents, use the dedicated hotline. For routine changes, use the ticketing system." .

ex:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team" ;
    rdfs:comment "Team providing level 2 support for critical business applications." ;
    org:unitOf ex:OrangeCorp_extra_node_5 ;
    noria:agentWorkingHours "8:00-18:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Ticketing System" ;
        skos:inScheme <kos/org/agent-contact-method_extra_node_5>
    ] ;
    noria:agentInstructions "Submit all application-related issues via the internal ticketing system." .

ex:JohnDoe_extra_node_5
    a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Network Engineer, member of the Network Operations Team." ;
    org:memberOf ex:NetworkOperationsTeam ;
    noria:agentManagesResource ex:CoreRouter01, ex:WANLink_Paris_Lyon ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)" .

ex:JaneSmith_extra_node_5
    a foaf:Person ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Application Specialist, member of the Application Support Team." ;
    org:memberOf ex:ApplicationSupportTeam ;
    noria:agentManagesResource ex:AppServer_CRM_Prod ;
    noria:agentWorkingHours "8:30-16:30 (Mon-Fri)" .

# --- Locations ---

ex:ParisDataCenter
    a bot:Site ;
    rdfs:label "Paris Data Center" ;
    rdfs:comment "Main data center located in Paris." ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A" ;
    rdfs:comment "A server room within the Paris Data Center." ;
    bot:hasSpace ex:RackA1, ex:RackA2 ;
    bot:hasBuilding ex:ParisDataCenter .

ex:RackA1
    a noria:Locus ;
    rdfs:label "Rack A1" ;
    rdfs:comment "Rack A1 in Server Room A." ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasZone ex:ServerRoomA .

# --- Applications and Modules ---

ex:CRM_Application
    a noria:Application ;
    rdfs:label "Customer Relationship Management (CRM)" ;
    rdfs:comment "Core application for managing customer interactions." ;
    noria:applicationModelIdentifier "CRM-V3" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Business Critical_extra_node_5" ;
        skos:inScheme <kos/application/type_extra_node_5>
    ] ;
    noria:applicationBusinessImportance [
        a skos:Concept ;
        skos:prefLabel "High" ;
        skos:inScheme <kos/application/business-importance_extra_node_5>
    ] ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales & Marketing" .

ex:CRM_Prod_Module
    a noria:ApplicationModule ;
    rdfs:label "CRM Production Module" ;
    rdfs:comment "The production instance of the CRM application." ;
    noria:applicationModuleOf ex:CRM_Application ;
    noria:applicationModuleName "CRM-V3_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleSupportTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Production" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status_extra_node_5>
    ] ;
    noria:applicationModuleSlaLevel [
        a skos:Concept ;
        skos:prefLabel "Platinum" ;
        skos:inScheme <https://w3id.org/noria/kos/application/sla-level>
    ] ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

# --- Resources and Network ---

ex:AppServer_CRM_Prod
    a noria:Resource ;
    rdfs:label "CRM Production Application Server" ;
    rdfs:comment "Server hosting the CRM Production Module." ;
    noria:resourceLogisticId "AS-CRM-001" ;
    noria:resourceHostName "app-crm-prod-01" ;
    noria:resourceProductModel ex:HP_ProLiant_DL380 ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Application Server" ;
        skos:inScheme <kos/Resource/type_extra_node_5>
    ] ;
    noria:resourceSerialNumber "SN123456789" ;
    noria:resourceUsageState [
        a skos:Concept ;
        skos:prefLabel "In Use" ;
        skos:inScheme <kos/Resource/LifecycleState_extra_node_5>
    ] ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CRM_Prod_Module ;
    noria:locatedAtLocus ex:RackA1 ;
    noria:resourceManagementIPAddress ex:IP_10_0_0_10 ;
    noria:resourceManagedBy ex:ApplicationSupportTeam .

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01" ;
    rdfs:comment "Main router in the Paris Data Center." ;
    noria:resourceLogisticId "CR-PAR-001" ;
    noria:resourceHostName "core-router-par-01" ;
    noria:resourceProductModel ex:Cisco_ASR9K ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Router" ;
        skos:inScheme <kos/Resource/type_extra_node_5>
    ] ;
    noria:resourceSerialNumber "SN987654321" ;
    noria:resourceUsageState [
        a skos:Concept ;
        skos:prefLabel "In Use" ;
        skos:inScheme <kos/Resource/LifecycleState_extra_node_5>
    ] ;
    noria:resourceInstallationDate "2021-06-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:RackA1 ;
    noria:resourceManagementIPAddress ex:IP_192_168_1_1 ;
    noria:resourceManagedBy ex:NetworkOperationsTeam .

ex:WANLink_Paris_Lyon
    a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-Lyon" ;
    rdfs:comment "High-capacity WAN link connecting Paris and Lyon data centers." ;
    noria:networkLinkId "WAN-PAR-LYO-01" ;
    noria:networkLinkTerminationResourceOrigin ex:CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination ex:CoreRouter02 ; # Assuming CoreRouter02 exists elsewhere
    noria:networkLinkInstallationDate "2021-06-01T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" ;
    noria:resourceManagedBy ex:NetworkOperationsTeam .

ex:CoreRouter02
    a noria:Resource ;
    rdfs:label "Core Router 02 (Lyon)" ;
    rdfs:comment "Main router in the Lyon Data Center." ;
    noria:resourceHostName "core-router-lyo-01" ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Router" ;
        skos:inScheme <kos/Resource/type_extra_node_5>
    ] ;
    noria:resourceManagedBy ex:NetworkOperationsTeam .

ex:Eth0_CRM_Prod
    a noria:NetworkInterface ;
    rdfs:label "eth0 on app-crm-prod-01" ;
    rdfs:comment "Ethernet interface for CRM Production Server." ;
    noria:networkInterfaceOf ex:AppServer_CRM_Prod ;
    noria:networkInterfaceAdministrativeStatus [
        a skos:Concept ;
        skos:prefLabel "up_extra_node_5" ;
        skos:inScheme <kos/Resource/AdministrativeState_extra_node_5>
    ] ;
    noria:networkInterfaceOperationalStatus [
        a skos:Concept ;
        skos:prefLabel "up_extra_node_5" ;
        skos:inScheme <kos/Resource/OperationalState_extra_node_5>
    ] ;
    noria:networkInterfaceType "physical" .

ex:GigabitEthernet0_0_1_CR01
    a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on core-router-par-01" ;
    rdfs:comment "Interface connecting Core Router 01 to WAN Link Paris-Lyon." ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceConnects ex:WANLink_Paris_Lyon ;
    noria:networkInterfaceAdministrativeStatus [
        a skos:Concept ;
        skos:prefLabel "up_extra_node_5" ;
        skos:inScheme <kos/Resource/AdministrativeState_extra_node_5>
    ] ;
    noria:networkInterfaceOperationalStatus [
        a skos:Concept ;
        skos:prefLabel "up_extra_node_5" ;
        skos:inScheme <kos/Resource/OperationalState_extra_node_5>
    ] ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceType "physical" .

# --- Product Models ---

ex:HP_ProLiant_DL380
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380" ;
    rdfs:comment "Server product model from HP." ;
    noria:productManufacturedBy ex:HPE_extra_node_5 .

ex:Cisco_ASR9K
    a noria:ProductModel ;
    rdfs:label "Cisco_extra_node_5 ASR 9000 Series" ;
    rdfs:comment "High-end router product model from Cisco_extra_node_5." ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:HPE_extra_node_5
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise" ;
    rdfs:comment "Manufacturer of server hardware." .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco_extra_node_5 Systems" ;
    rdfs:comment "Manufacturer of networking equipment." .

# --- IP Addresses (as observable:IPAddress) ---
# Note: observable:ipAddress is an ObjectProperty, so its range should be a class.
# We'll define these as instances of observable:IPAddress.

ex:IP_10_0_0_10
    a observable:IPAddress ;
    rdfs:label "10.0.0.10_extra_node_5" ;
    rdfs:comment "Management IP address for app-crm-prod-01." ;
    observable:addressValue "10.0.0.10_extra_node_5" .

ex:IP_192_168_1_1
    a observable:IPAddress ;
    rdfs:label "192.168.1.1" ;
    rdfs:comment "Management IP address for core-router-par-01." ;
    observable:addressValue "192.168.1.1" .

# --- Events ---

ex:Event_InterfaceDown_extra_node_5
    a noria:EventRecord ;
    rdfs:label "Interface Down Event on Core Router 01" ;
    rdfs:comment "Log entry indicating a network interface went down_extra_node_5." ;
    noria:logOriginatingManagedObject ex:CoreRouter01 ;
    noria:logOriginatingManagementSystem ex:NetworkMonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down_extra_node_5" ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Major" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity_extra_node_5>
    ] .

ex:NetworkMonitoringSystem
    a noria:Application ;
    rdfs:label "Network Monitoring System" ;
    rdfs:comment "Application responsible for monitoring network devices." ;
    noria:applicationShortIdentifier "NMS" .

# --- Trouble Tickets ---

ex:TT_20240423_001
    a noria:TroubleTicket ;
    rdfs:label "WAN Link Paris-Lyon Down" ;
    rdfs:comment "Trouble ticket created due to the WAN link between Paris and Lyon being down_extra_node_5." ;
    dcterms:identifier "TT-20240423-001" ;
    noria:documentExternalId "CUST-INC-9876" ;
    noria:documentHRef "http://ticketing.example.com/TT-20240423-001" ;
    noria:troubleTicketSeverity [
        a skos:Concept ;
        skos:prefLabel "Blocking" ;
        skos:inScheme <kos/TroubleTicket/severity_extra_node_5>
    ] ;
    noria:troubleTicketType [
        a skos:Concept ;
        skos:prefLabel "Failure" ;
        skos:inScheme <kos/TroubleTicket/type_extra_node_5>
    ] ;
    noria:troubleTicketPriority [
        a skos:Concept ;
        skos:prefLabel "P1" ;
        skos:inScheme <kos/TroubleTicket/priority_extra_node_5>
    ] ;
    noria:troubleTicketOrigin [
        a skos:Concept ;
        skos:prefLabel "Supervision" ;
        skos:inScheme <kos/TroubleTicket/origin_extra_node_5>
    ] ;
    noria:troubleTicketTrigger ex:Event_InterfaceDown_extra_node_5 ;
    noria:troubleTicketStatusCurrent [
        a skos:Concept ;
        skos:prefLabel "InProgress" ;
        skos:inScheme <kos/TroubleTicket/status_extra_node_5>
    ] ;
    noria:troubleTicketRelatedParty ex:NetworkOperationsTeam ;
    noria:troubleTicketRelatedService ex:CRM_Prod_Module ;
    noria:troubleTicketRelatedResource ex:WANLink_Paris_Lyon, ex:CoreRouter01 ;
    noria:troubleTicketCause "Fiber cut on WAN link." ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime .

# --- Change Requests ---

ex:CR_20240501_001
    a noria:ChangeRequest ;
    rdfs:label "Core Router OS Upgrade" ;
    rdfs:comment "Planned OS upgrade for Core Router 01 to enhance security and performance." ;
    dcterms:identifier "CR-20240501-001" ;
    noria:documentExternalId "PROJ-SEC-005" ;
    noria:documentHRef "http://changemgmt.example.com/CR-20240501-001" ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory [
        a skos:Concept ;
        skos:prefLabel "Internal intervention" ;
        skos:inScheme <kos/ChangeRequest/category_extra_node_5>
    ] ;
    noria:changeRequestType [
        a skos:Concept ;
        skos:prefLabel "Standard" ;
        skos:inScheme <kos/ChangeRequest/type_extra_node_5>
    ] ;
    noria:changeRequestChangeCause [
        a skos:Concept ;
        skos:prefLabel "Software upgrade" ;
        skos:inScheme <kos/ChangeRequest/cause_extra_node_5>
    ] ;
    noria:changeRequestImpact ex:CoreRouter01 ;
    noria:changeRequestStatusCurrent [
        a skos:Concept ;
        skos:prefLabel "Scheduled" ;
        skos:inScheme <kos/ChangeRequest/status_extra_node_5>
    ] ;
    noria:changeRequestInitiatorParty ex:JohnDoe_extra_node_5 ;
    noria:changeRequestPilotParty ex:JohnDoe_extra_node_5 ;
    noria:changeRequestIsRegulated false .

# --- Operation Plans and Conditions ---

ex:RouterOSUpgradePlan
    a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure" ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems." ;
    noria:operationPlanPreCondition ex:RouterOSUpgradePreCheck ;
    noria:operationPlanPostCondition ex:RouterOSUpgradePostCheck .

ex:RouterOSUpgradePreCheck
    a noria:ActionPreCondition ;
    rdfs:label "Router OS Upgrade Pre-Conditions" ;
    rdfs:comment "Checks to perform before a router OS upgrade, e.g., backup complete, dual-homed setup verified." .

ex:RouterOSUpgradePostCheck
    a noria:ActionPostCondition ;
    rdfs:label "Router OS Upgrade Post-Conditions" ;
    rdfs:comment "Checks to perform after a router OS up_extra_node_5grade, e.g., routing protocols converged, interfaces up_extra_node_5, traffic flowing." .

ex:CR_20240501_001
    noria:actionCorrelatedOperationPlan ex:RouterOSUpgradePlan .
