@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix pep: <https://w3id.org/pep/> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix ex: <http://example.com/noria-kg/> .

# =============================================================================
# Organizations and Agents
# =============================================================================

ex:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "The department responsible for managing IT infrastructure and services within ExampleCorp." ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)" ;
    noria:agentPreferredContactMethod ex:EmailContactMethod_extra_node_0 ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. For non-critical, open a ticket via the internal portal." .

ex:NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Specialized team managing core and access network infrastructure for ExampleCorp." ;
    noria:agentWorkingHours "24/7 On-Call" ;
    noria:agentPreferredContactMethod ex:PhoneContactMethod_extra_node_0 ;
    noria:agentInstructions "Always call the on-call engineer for network outages or critical performance degradation." ;
    org:unitOf ex:ITOperationsDept .

ex:AppSupportTeam_extra_node_0
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team" ;
    rdfs:comment "Team responsible for supporting critical business applications, including the Customer Portal." ;
    noria:agentWorkingHours "8:00 AM - 5:00 PM (Mon-Fri)" ;
    noria:agentPreferredContactMethod ex:TicketingSystemContactMethod_extra_node_0 ;
    noria:agentInstructions "Submit all application-related issues via the ticketing system for proper tracking and escalation." ;
    org:unitOf ex:ITOperationsDept .

ex:JohnDoe_extra_node_0
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe" ;
    rdfs:comment "Senior Network Engineer responsible for core routing infrastructure in the Paris Data Center." ;
    foaf:mbox <mailto:john.doe@example.com> ;
    org:memberOf ex:NetworkTeam ;
    noria:agentManagesResource ex:CoreRouter01, ex:CoreRouter02 .

ex:JaneSmith_extra_node_0
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Lead Application Support Engineer for the Customer Portal, overseeing its operational health." ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    org:memberOf ex:AppSupportTeam_extra_node_0 ;
    noria:agentManagesResource ex:CustomerPortalAppModule .

ex:EmailContactMethod_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method_extra_node_0> ;
    rdfs:label "Email" .

ex:PhoneContactMethod_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method_extra_node_0> ;
    rdfs:label "Phone" .

ex:TicketingSystemContactMethod_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method_extra_node_0> ;
    rdfs:label "Ticketing System" .

# =============================================================================
# Applications and Application Modules
# =============================================================================

ex:CustomerPortalApp_extra_node_0
    a noria:Application ;
    rdfs:label "Customer Portal Application" ;
    rdfs:comment "The primary web application enabling customers to manage their services, view bills, and access support." ;
    noria:applicationModelIdentifier "CP-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CustPortal" ;
    noria:applicationType ex:WebApplicationType ;
    noria:applicationBusinessImportance ex:HighImportance_extra_node_0 ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Self-Service Portal" .

ex:WebApplicationType
    a skos:Concept ;
    skos:inScheme <kos/application/type_extra_node_0> ;
    rdfs:label "Web Application" .

ex:HighImportance_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance_extra_node_0> ;
    rdfs:label "High" .

ex:CustomerPortalAppModule
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module" ;
    rdfs:comment "The live production instance of the Customer Portal application, serving end-users." ;
    noria:applicationModuleOf ex:CustomerPortalApp_extra_node_0 ;
    noria:applicationModuleName "CustPortal_Prod" ;
    noria:applicationModuleIdentifier "CP-PROD-01" ;
    noria:applicationModuleAdministrationTeam ex:AppSupportTeam_extra_node_0 ;
    noria:applicationModuleSupportTeam ex:AppSupportTeam_extra_node_0 ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith_extra_node_0 ;
    noria:applicationModuleStatus ex:InProductionStatus_extra_node_0 .

ex:InProductionStatus_extra_node_0
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status_extra_node_0> ;
    rdfs:label "In Production" .

# =============================================================================
# Resources and Network Infrastructure
# =============================================================================

ex:DataCenterParis
    a bot:Site ;
    rdfs:label "Paris Data Center" ;
    rdfs:comment "The main data center facility for ExampleCorp, located in Paris, France." ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

ex:ServerRoomA_extra_node_0
    a noria:Room ;
    rdfs:label "Server Room A" ;
    rdfs:comment "A dedicated server room within the Paris Data Center, housing critical network and compute infrastructure." ;
    bot:hasSpace ex:RackA1, ex:RackA2 ;
    bot:hasBuilding ex:DataCenterParis .

ex:RackA1
    a noria:Locus ;
    rdfs:label "Rack A1" ;
    rdfs:comment "Rack A1 in Server Room A, containing core network devices and web servers." ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasElement ex:CoreRouter01, ex:WebServer01_extra_node_0 .

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01" ;
    rdfs:comment "Primary core router in the Paris Data Center, handling high-volume network traffic." ;
    noria:resourceLogisticId "LOG-CR01-PAR" ;
    noria:resourceHostName "cr01.paris.example.com" ;
    noria:resourceProductModel ex:CiscoASR9K_extra_node_0 ;
    noria:resourceType ex:RouterType_extra_node_0 ;
    noria:resourceSerialNumber "XYZ123456" ;
    noria:resourceUsageState ex:OperationalState_extra_node_0 ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:NetworkTeam ;
    noria:locatedAtLocus ex:RackA1 ;
    noria:resourceManagementIPAddress ex:IP_10_0_0_1 .

ex:CoreRouter02
    a noria:Resource ;
    rdfs:label "Core Router 02" ;
    rdfs:comment "Secondary core router in the Paris Data Center, providing redundancy for network services." ;
    noria:resourceLogisticId "LOG-CR02-PAR" ;
    noria:resourceHostName "cr02.paris.example.com" ;
    noria:resourceProductModel ex:CiscoASR9K_extra_node_0 ;
    noria:resourceType ex:RouterType_extra_node_0 ;
    noria:resourceSerialNumber "XYZ654321" ;
    noria:resourceUsageState ex:OperationalState_extra_node_0 ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:NetworkTeam ;
    noria:locatedAtLocus ex:RackA1 ;
    noria:resourceManagementIPAddress ex:IP_10_0_0_2 .

ex:WebServer01_extra_node_0
    a noria:Resource ;
    rdfs:label "Web Server 01" ;
    rdfs:comment "Server hosting the Customer Portal application, part of the web tier infrastructure." ;
    noria:resourceLogisticId "LOG-WS01-PAR" ;
    noria:resourceHostName "web01.portal.example.com" ;
    noria:resourceProductModel ex:HPProLiantDL380_extra_node_0 ;
    noria:resourceType ex:ServerType_extra_node_0 ;
    noria:resourceSerialNumber "ABC987654" ;
    noria:resourceUsageState ex:OperationalState_extra_node_0 ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:AppSupportTeam_extra_node_0 ;
    noria:resourceForApplication ex:CustomerPortalApp_extra_node_0 ;
    noria:locatedAtLocus ex:RackA1 ;
    noria:resourceManagementIPAddress ex:IP_192_168_1_10 .

ex:CiscoASR9K_extra_node_0
    a noria:ProductModel ;
    rdfs:label "Cisco_extra_node_0 ASR 9000 Series" ;
    rdfs:comment "High-end modular router series from Cisco_extra_node_0, used for carrier-grade networking." ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:HPProLiantDL380_extra_node_0
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380" ;
    rdfs:comment "A popular rack server model from Hewlett Packard Enterprise, known for its versatility." ;
    noria:productManufacturedBy ex:HPE_extra_node_0 .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco_extra_node_0 Systems" ;
    rdfs:comment "Multinational technology conglomerate specializing in networking hardware and software." .

ex:HPE_extra_node_0
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise" ;
    rdfs:comment "Global edge-to-cloud company providing IT infrastructure, software, and services." .

ex:RouterType_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/Resource/type_extra_node_0> ;
    rdfs:label "Router" .

ex:ServerType_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/Resource/type_extra_node_0> ;
    rdfs:label "Server" .

ex:OperationalState_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState_extra_node_0> ;
    rdfs:label "Operational" .

ex:IP_10_0_0_1
    a observable:IPAddress ;
    rdfs:label "10.0.0.1" ;
    observable:ipAddressValue "10.0.0.1" .

ex:IP_10_0_0_2
    a observable:IPAddress ;
    rdfs:label "10.0.0.2" ;
    observable:ipAddressValue "10.0.0.2" .

ex:IP_192_168_1_10
    a observable:IPAddress ;
    rdfs:label "192.168.1.10" ;
    observable:ipAddressValue "192.168.1.10" .

# Network Interfaces
ex:CR01_Eth0_0
    a noria:NetworkInterface ;
    rdfs:label "cr01.paris.example.com Ethernet0/0" ;
    rdfs:comment "Uplink interface for Core Router 01, connecting to the WAN." ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceType ex:PhysicalInterfaceType_extra_node_0 ;
    noria:networkInterfaceAdministrativeStatus ex:UpState ;
    noria:networkInterfaceOperationalStatus ex:UpState ;
    noria:networkInterfaceConnects ex:WANLinkParisLyon .

ex:CR02_Eth0_0
    a noria:NetworkInterface ;
    rdfs:label "cr02.paris.example.com Ethernet0/0" ;
    rdfs:comment "Uplink interface for Core Router 02, providing redundant connectivity to the WAN." ;
    noria:networkInterfaceOf ex:CoreRouter02 ;
    noria:networkInterfaceType ex:PhysicalInterfaceType_extra_node_0 ;
    noria:networkInterfaceAdministrativeStatus ex:UpState ;
    noria:networkInterfaceOperationalStatus ex:UpState ;
    noria:networkInterfaceConnects ex:WANLinkParisLyon .

ex:WS01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "web01.portal.example.com Ethernet0" ;
    rdfs:comment "Primary network interface for Web Server 01, connecting to the internal network." ;
    noria:networkInterfaceOf ex:WebServer01_extra_node_0 ;
    noria:networkInterfaceType ex:VirtualInterfaceType ;
    noria:networkInterfaceAdministrativeStatus ex:UpState ;
    noria:networkInterfaceOperationalStatus ex:UpState .

ex:PhysicalInterfaceType_extra_node_0
    a skos:Concept ;
    rdfs:label "Physical Interface" .

ex:VirtualInterfaceType
    a skos:Concept ;
    rdfs:label "Virtual Interface" .

ex:UpState
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState_extra_node_0> ;
    rdfs:label "Up" .

ex:DownState
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState_extra_node_0> ;
    rdfs:label "Down" .

# Network Links
ex:WANLinkParisLyon
    a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-Lyon" ;
    rdfs:comment "High-speed fiber optic WAN link connecting the Paris and Lyon data centers, crucial for inter-DC communication." ;
    noria:networkLinkId "WAN-PAR-LYO-01" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2019-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin ex:CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination ex:CoreRouterLyon01 ;
    noria:resourceManagedBy ex:NetworkTeam .

ex:CoreRouterLyon01
    a noria:Resource ;
    rdfs:label "Core Router Lyon 01" ;
    rdfs:comment "Core router in the Lyon Data Center, serving as the remote termination point for the WAN link." ;
    noria:resourceHostName "cr01.lyon.example.com" ;
    noria:resourceType ex:RouterType_extra_node_0 ;
    noria:resourceManagedBy ex:NetworkTeam .

# =============================================================================
# Dynamic Elements (Events, Tickets, Changes)
# =============================================================================

# Event Record: Network Interface Down
ex:Event_CR01_Eth0_Down
    a noria:EventRecord ;
    rdfs:label "Event: CR01 Ethernet0/0 Down" ;
    rdfs:comment "Log entry from the NMS indicating that the primary uplink interface of Core Router 01 went down_extra_node_0." ;
    noria:loggingTime "2023-10-26T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject ex:CR01_Eth0_0 ;
    noria:logOriginatingManagementSystem ex:NMSApplication ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface Ethernet0/0, changed state to down_extra_node_0" ;
    noria:alarmSeverity ex:MajorSeverity_extra_node_0 .

ex:NMSApplication
    a noria:Application ;
    rdfs:label "Network Monitoring System" ;
    rdfs:comment "Application responsible for real-time monitoring and alerting on network device status_extra_node_0." ;
    noria:applicationShortIdentifier "NMS" .

ex:MajorSeverity_extra_node_0
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity_extra_node_0> ;
    rdfs:label "Major" .

# Trouble Ticket triggered by the event
ex:TT_20231026_001
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket: Core Router 01 Uplink Down" ;
    rdfs:comment "Incident reported due to the primary core router uplink failure, impacting the Customer Portal's connectivity." ;
    dcterms:created "2023-10-26T10:10:00Z"^^xsd:dateTime ;
    noria:documentExternalId "TT-2023-10-26-001" ;
    noria:documentHRef <http://ticketing.example.com/TT-2023-10-26-001> ;
    noria:troubleTicketSeverity ex:BlockingSeverity ;
    noria:troubleTicketType ex:FailureType_extra_node_0 ;
    noria:troubleTicketPriority ex:P1Priority_extra_node_0 ;
    noria:troubleTicketOrigin ex:SupervisionOrigin ;
    noria:troubleTicketTrigger ex:Event_CR01_Eth0_Down ;
    noria:troubleTicketStatusCurrent ex:InProgressStatus_extra_node_0 ;
    noria:troubleTicketRelatedParty ex:NetworkTeam ;
    noria:troubleTicketRelatedService ex:CustomerPortalApp_extra_node_0 ;
    noria:troubleTicketRelatedResource ex:CoreRouter01 ;
    noria:troubleTicketCause "Physical fiber cut affecting WAN link between Paris and Lyon." ;
    noria:troubleTicketDetectionDateTime "2023-10-26T10:05:00Z"^^xsd:dateTime .

ex:BlockingSeverity
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity_extra_node_0> ;
    rdfs:label "Blocking" .

ex:FailureType_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type_extra_node_0> ;
    rdfs:label "Failure" .

ex:P1Priority_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority_extra_node_0> ;
    rdfs:label "P1" .

ex:SupervisionOrigin
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin_extra_node_0> ;
    rdfs:label "Supervision" .

ex:InProgressStatus_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status_extra_node_0> ;
    rdfs:label "InProgress" .

# Change Request for a planned maintenance
ex:CR_20231115_001
    a noria:ChangeRequest ;
    rdfs:label "Change Request: Core Router Software Upgrade" ;
    rdfs:comment "Planned software upgrade for Core Router 02 to enhance security and performance, requiring a brief service interruption." ;
    dcterms:created "2023-10-01T09:00:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CR-2023-11-15-001" ;
    noria:documentHRef <http://changemgmt.example.com/CR-2023-11-15-001> ;
    noria:changeRequestPlannedStartTime "2023-11-15T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2023-11-15T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory ex:PreventativeMaintenanceCategory ;
    noria:changeRequestType ex:StandardChangeType_extra_node_0 ;
    noria:changeRequestChangeCause ex:SoftwareUpgradeCause_extra_node_0 ;
    noria:changeRequestImpact ex:CoreRouter02 ;
    noria:changeRequestStatusCurrent ex:ScheduledStatus_extra_node_0 ;
    noria:changeRequestInitiatorParty ex:JohnDoe_extra_node_0 ;
    noria:changeRequestPilotParty ex:JohnDoe_extra_node_0 ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration .

ex:PreventativeMaintenanceCategory
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category_extra_node_0> ;
    rdfs:label "Preventative Maintenance" .

ex:StandardChangeType_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type_extra_node_0> ;
    rdfs:label "Standard Change" .

ex:SoftwareUpgradeCause_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause_extra_node_0> ;
    rdfs:label "Software Upgrade" .

ex:ScheduledStatus_extra_node_0
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status_extra_node_0> ;
    rdfs:label "Scheduled" .

# Operation Plan for the Change Request
ex:OP_RouterUpgrade
    a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure" ;
    rdfs:comment "A standardized procedure detailing the steps for upgrading Cisco_extra_node_0 ASR 9000 series router software, including pre-checks and post-checks." ;
    noria:operationPlanPreCondition ex:PreCond_BackupComplete ;
    noria:operationPlanPostCondition ex:PostCond_ServiceRestored .

ex:PreCond_BackupComplete
    a noria:ActionPreCondition ;
    rdfs:label "Backup Complete" ;
    rdfs:comment "Pre-condition: Ensure full configuration backup is completed and verified before initiating the software upgrade." .

ex:PostCond_ServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored" ;
    rdfs:comment "Post-condition: Verify all critical network services are fully operational and stable after the upgrade." .

ex:CR_20231115_001 noria:actionCorrelatedOperationPlan ex:OP_RouterUpgrade .
