# --- Network Interfaces ---
ex:Router_Core_01_GE0_0_1 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigabitEthernet0/0/1" ;
    rdfs:comment "Network interface on Core Router 01 connecting to the web server segment." ;
    noria:networkInterfaceOf ex:Router_Core_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus [
        a skos:Concept ;
        skos:prefLabel "up_extra_node_2" ;
        skos:inScheme <kos/Resource/AdministrativeState_extra_node_2>
    ] ;
    noria:networkInterfaceOperationalStatus [
        a skos:Concept ;
        skos:prefLabel "up_extra_node_2" ;
        skos:inScheme <kos/Resource/OperationalState_extra_node_2>
    ] ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower 0 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -2 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

ex:WebServer_CP_01_ETH0 a noria:NetworkInterface ;
    rdfs:label "Web Server CP 01 Ethernet0" ;
    rdfs:comment "Network interface on Web Server CP 01 connecting to the core router." ;
    noria:networkInterfaceOf ex:WebServer_CP_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus [
        a skos:Concept ;
        skos:prefLabel "up_extra_node_2" ;
        skos:inScheme <kos/Resource/AdministrativeState_extra_node_2>
    ] ;
    noria:networkInterfaceOperationalStatus [
        a skos:Concept ;
        skos:prefLabel "up_extra_node_2" ;
        skos:inScheme <kos/Resource/OperationalState_extra_node_2>
    ] .

# --- Network Links ---
ex:Link_Router_Web_CP a noria:NetworkLink ;
    rdfs:label "Link between Core Router 01 and Web Server CP 01" ;
    rdfs:comment "Direct network link connecting Core Router 01 to Web Server CP 01, carrying customer portal traffic." ;
    noria:networkLinkId "LINK-RTR01-WEB01" ;
    noria:networkLinkTerminationResourceOrigin ex:Router_Core_01 ;
    noria:networkLinkTerminationResourceDestination ex:WebServer_CP_01 ;
    noria:networkLinkInstallationDate "2021-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy ex:NOC_Team .

ex:Router_Core_01_GE0_0_1 noria:networkInterfaceConnects ex:Link_Router_Web_CP .
ex:WebServer_CP_01_ETH0 noria:networkInterfaceConnects ex:Link_Router_Web_CP .

# --- Services ---
ex:InternetAccessService a noria:Service ;
    rdfs:label "Corporate Internet Access Service" ;
    rdfs:comment "Provides internet access for corporate users and external facing applications." ;
    noria:serviceType [
        a skos:Concept ;
        skos:prefLabel "Customer Facing Service" ;
        skos:inScheme <kos/service/type_extra_node_2>
    ] ;
    seas:subSystem ex:CustomerPortalApp .

ex:VPNService a noria:Service ;
    rdfs:label "Corporate VPN Service" ;
    rdfs:comment "Provides secure remote access to corporate network resources for employees." ;
    noria:serviceType [
        a skos:Concept ;
        skos:prefLabel "Resource Facing Service" ;
        skos:inScheme <kos/service/type_extra_node_2>
    ] ;
    seas:subSystem ex:Router_Core_01 .

# --- Event Records ---
ex:Event_InterfaceDown_extra_node_2 a noria:EventRecord ;
    rdfs:label "Interface Down Event on Core Router 01" ;
    rdfs:comment "Log entry indicating a network interface went down_extra_node_2, impacting connectivity." ;
    noria:logOriginatingManagedObject ex:Router_Core_01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystemApp ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down_extra_node_2" ;
    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Major" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity_extra_node_2>
    ] ;
    noria:alarmProposedRepairAction ex:OpPlan_InterfaceRestart ;
    noria:alarmMitigatedBy ex:CorrectiveAction_RestartInterface .

ex:Event_LoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt on Web Server CP 01" ;
    rdfs:comment "Security event: multiple failed login attempts detected on the web server." ;
    noria:logOriginatingManagedObject ex:WebServer_CP_01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystemApp ;
    noria:logOriginatingAgent ex:ExternalAttacker ;
    noria:logText "AUTH-4-LOGIN_FAILED: User 'baduser' failed to login from 192.168.1.100" ;
    noria:loggingTime "2023-10-26T10:15:00Z"^^xsd:dateTime ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Warning" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity_extra_node_2>
    ] .

ex:Event_ConfigChange_RTR01 a noria:EventRecord ;
    rdfs:label "Configuration Change Event on Core Router 01" ;
    rdfs:comment "Log entry indicating a configuration change was applied to Core Router 01 by an engineer." ;
    noria:logOriginatingManagedObject ex:Router_Core_01 ;
    noria:logOriginatingAgent ex:JohnDoe_extra_node_2 ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by vty0 (10.0.0.5)" ;
    noria:loggingTime "2023-11-01T02:30:00Z"^^xsd:dateTime .

ex:Event_InterfaceUp a noria:EventRecord ;
    rdfs:label "Interface Up Event on Core Router 01" ;
    rdfs:comment "Log entry indicating a network interface came up_extra_node_2 after a restart procedure." ;
    noria:logOriginatingManagedObject ex:Router_Core_01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystemApp ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to up_extra_node_2" ;
    noria:loggingTime "2023-10-26T09:18:00Z"^^xsd:dateTime ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Cleared" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity_extra_node_2>
    ] .

# --- Trouble Tickets ---
ex:TT_20231026_001 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Unreachable" ;
    rdfs:comment "Trouble ticket opened due to customer portal being inaccessible, impacting critical business operations." ;
    noria:documentExternalId "TT-CP-2023-001" ;
    noria:documentHRef <http://ticketing.example.com/TT-CP-2023-001> ;
    noria:troubleTicketSeverity [
        a skos:Concept ;
        skos:prefLabel "Blocking" ;
        skos:inScheme <kos/TroubleTicket/severity_extra_node_2>
    ] ;
    noria:troubleTicketType [
        a skos:Concept ;
        skos:prefLabel "Failure" ;
        skos:inScheme <kos/TroubleTicket/type_extra_node_2>
    ] ;
    noria:troubleTicketCriticity [
        a skos:Concept ;
        skos:prefLabel "Interrupted service" ;
        skos:inScheme <kos/TroubleTicket/category_extra_node_2>
    ] ;
