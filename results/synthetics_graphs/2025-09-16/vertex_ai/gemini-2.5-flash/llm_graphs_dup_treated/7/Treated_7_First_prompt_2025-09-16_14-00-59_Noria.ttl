        skos:prefLabel "Customer" ;
        skos:inScheme <kos/TroubleTicket/origin_extra_node_2>
    ] ;
    noria:troubleTicketTrigger ex:Event_InterfaceDown_extra_node_2 ;
    noria:troubleTicketUrgency [
        a skos:Concept ;
        skos:prefLabel "Immediate Intervention" ;
        skos:inScheme <kos/TroubleTicket/urgency>
    ] ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory [
        a skos:Concept ;
        skos:prefLabel "Total breakdown" ;
        skos:inScheme <kos/TroubleTicket/trouble-category_extra_node_2>
    ] ;
    noria:problemCategory [
        a skos:Concept ;
        skos:prefLabel "Network equipment failure" ;
        skos:inScheme <kos/TroubleTicket/trouble-category_extra_node_2>
    ] ;
    noria:troubleTicketCause "Network interface failure on core router GE0/0/1." ;
    noria:problemResponsibility [
        a skos:Concept ;
        skos:prefLabel "Managed backbone networks" ;
        skos:inScheme <kos/TroubleTicket/problemResponsibility>
    ] ;
    noria:troubleTicketDetectionDateTime "2023-10-26T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2023-10-26T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2023-10-26T09:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2023-10-26T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent [
        a skos:Concept ;
        skos:prefLabel "InProgress" ;
        skos:inScheme <kos/TroubleTicket/status_extra_node_2>
    ] ;
    noria:troubleTicketRelatedParty ex:NOC_Team ;
    noria:troubleTicketRelatedService ex:CustomerPortalApp ;
    noria:troubleTicketRelatedResource ex:Router_Core_01 .

# --- Trouble Ticket Notes ---
