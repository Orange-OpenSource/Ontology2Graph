    noria:resourceProductModel ex:Cisco_ASR9K ;
    noria:resourceType [
        a skos:Concept ;
        skos:prefLabel "Router" ;
        skos:inScheme <kos/Resource/type_extra_node_2>
    ] ;
    noria:resourceSerialNumber "ABC12345DEF" ;
    noria:resourceUsageState [
        a skos:Concept ;
        skos:prefLabel "In Production" ;
        skos:inScheme <kos/Resource/LifecycleState_extra_node_2>
    ] ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalApp ;
    noria:locatedAtLocus ex:Rack_A1_L06 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> ;
    noria:resourceManagedBy ex:NOC_Team .

ex:WebServer_CP_01 a noria:Resource ;
