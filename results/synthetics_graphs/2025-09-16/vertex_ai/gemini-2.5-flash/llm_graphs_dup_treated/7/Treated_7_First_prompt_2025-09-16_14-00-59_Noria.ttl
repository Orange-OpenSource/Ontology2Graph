@prefix time: <http://www.w3.org/2006/time#> .

# --- Organizations and Agents ---
ex:OrangeCorp_extra_node_2 a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main organization managing the IT infrastructure for various services." ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method_extra_node_2>
    ] ;
    noria:agentInstructions "Contact via ticketing system for all issues." .

ex:NOC_Team a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Team" ;
    rdfs:comment "Team responsible for 24/7 network monitoring and first-level incident response." ;
    org:unitOf ex:OrangeCorp_extra_node_2 ;
    noria:agentWorkingHours "24/7 Shift-based" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Phone" ;
        skos:inScheme <kos/org/agent-contact-method_extra_node_2>
    ] ;
    noria:agentInstructions "For critical incidents, call the hotline immediately." .

ex:AppSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team" ;
    rdfs:comment "Team responsible for maintaining critical business applications." ;
    org:unitOf ex:OrangeCorp_extra_node_2 ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Ticketing System" ;
        skos:inScheme <kos/org/agent-contact-method_extra_node_2>
    ] .

ex:JohnDoe_extra_node_2 a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Lead Engineer for the NOC Team, responsible for core network infrastructure." ;
    org:memberOf ex:NOC_Team ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method_extra_node_2>
    ] ;
    noria:agentManagesResource ex:Router_Core_01 .

ex:JaneSmith_extra_node_2 a foaf:Person ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Application Manager for the Customer Portal, overseeing its operations." ;
    org:memberOf ex:AppSupportTeam ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method_extra_node_2>
    ] ;
    noria:agentManagesResource ex:WebServer_CP_01 .

ex:ExternalAttacker a foaf:Agent ;
    rdfs:label "External Attacker" ;
    rdfs:comment "An unknown external entity attempting unauthorized access to systems." .

ex:CiscoSystems a org:Organization ;
    rdfs:label "Cisco_extra_node_2 Systems Inc." ;
    rdfs:comment "Manufacturer of network equipment, including routers and switches." .

ex:HPE_extra_node_2 a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise" ;
    rdfs:comment "Manufacturer of enterprise servers and IT solutions." .

ex:HotlineTeam a org:OrganizationalUnit ;
    rdfs:label "Hotline Support Team" ;
    rdfs:comment "Dedicated team for urgent application support, available 24/7." ;
    org:unitOf ex:OrangeCorp_extra_node_2 .

# --- Locations ---
ex:DataCenter_Paris a bot:Site ;
    rdfs:label "Paris Data Center" ;
    rdfs:comment "Main data center located in Paris, hosting critical infrastructure." ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

ex:ServerRoom_A1 a noria:Room ;
    rdfs:label "Server Room A1" ;
    rdfs:comment "A secure server room within the Paris Data Center, housing network and compute racks." ;
    bot:hasSpace ex:DataCenter_Paris .

ex:Rack_A1_L06 a noria:Locus ;
    rdfs:label "Rack A1-L06" ;
    rdfs:comment "Specific rack location in Server Room A1, where core network devices are installed." ;
    noria:locusLine "A1" ;
    noria:locusRow "06" ;
    bot:hasSpace ex:ServerRoom_A1 .

# --- Product Models ---
ex:Cisco_ASR9K a noria:ProductModel ;
    rdfs:label "Cisco_extra_node_2 ASR 9000 Series" ;
    rdfs:comment "Product model for Cisco_extra_node_2 ASR 9000 series routers, known for high performance." ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:HP_ProLiant_DL380 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10" ;
    rdfs:comment "Product model for HP ProLiant DL380 Gen10 servers, commonly used for web applications." ;
    noria:productManufacturedBy ex:HPE_extra_node_2 .

# --- Applications ---
ex:CustomerPortalApp a noria:Application ;
    rdfs:label "Customer Portal Application" ;
    rdfs:comment "Web application allowing customers to manage their services and view billing information." ;
    noria:applicationModelIdentifier "CUSTPORTAL" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CP" ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Customer Facing Service" ;
        skos:inScheme <kos/application/type_extra_node_2>
    ] ;
    noria:applicationBusinessImportance [
        a skos:Concept ;
        skos:prefLabel "Critical" ;
        skos:inScheme <kos/application/business-importance_extra_node_2>
    ] ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Self-Service" .

ex:MonitoringSystemApp a noria:Application ;
    rdfs:label "Network Monitoring System" ;
    rdfs:comment "Application for monitoring network devices, servers, and services, generating alerts." ;
    noria:applicationModelIdentifier "NMS" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType [
        a skos:Concept ;
        skos:prefLabel "Internal Tool" ;
        skos:inScheme <kos/application/type_extra_node_2>
    ] ;
    noria:applicationBusinessImportance [
        a skos:Concept ;
        skos:prefLabel "High" ;
        skos:inScheme <kos/application/business-importance_extra_node_2>
    ] ;
    noria:applicationFunctionalDomain "Service Development, Management and Operations" ;
    noria:applicationFunctionalSubDomain "Fault Management" .

# --- Application Modules ---
ex:CustomerPortal_Prod a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module" ;
    rdfs:comment "The live production instance of the Customer Portal application, serving end-users." ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CUSTPORTAL_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam ex:AppSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith_extra_node_2 ;
    noria:applicationModuleSupportTeam ex:AppSupportTeam ;
    noria:applicationModuleSupportLeader ex:JaneSmith_extra_node_2 ;
    noria:applicationModuleSupportGroup ex:NOC_Team ;
    noria:applicationModuleHotlineGroup ex:HotlineTeam ;
    noria:applicationModuleSlaLevel ex:SLA_Gold ;
    noria:applicationModuleSlaLevelDate "2023-01-01"^^xsd:date ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Production" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status_extra_node_2>
    ] .

ex:CustomerPortal_Dev a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module" ;
    rdfs:comment "Development instance of the Customer Portal application, used for testing new features." ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CUSTPORTAL_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleAdministrationTeam ex:AppSupportTeam ;
    noria:applicationModuleStatus [
        a skos:Concept ;
        skos:prefLabel "In Development" ;
        skos:inScheme <https://w3id.org/noria/kos/application/status_extra_node_2>
    ] .

# --- Resources ---
ex:Router_Core_01 a noria:Resource ;
    rdfs:label "Core Router 01" ;
    rdfs:comment "Main core router in Paris Data Center, handling critical network traffic." ;
    noria:resourceLogisticId "RTR-PAR-01-CORE" ;
