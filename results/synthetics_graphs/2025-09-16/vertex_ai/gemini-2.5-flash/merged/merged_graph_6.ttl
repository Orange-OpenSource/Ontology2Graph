        skos:inScheme <http://example.com/noria/kos/application/type>
    ] .

# --- Trouble Ticket ---
ex:TT_20240423_001 a noria:TroubleTicket ;
    rdfs:label "WAN Link Down Incident" ;
    rdfs:comment "Trouble ticket created due to WAN link failure, impacting the Corporate Internet Access Service." ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-2024-001" ;
    noria:documentHRef "http://itsm.example.com/tickets/INC-2024-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity [
        a skos:Concept ;
        skos:prefLabel "Blocking" ;
        skos:inScheme <http://example.com/noria/kos/TroubleTicket/severity>
    ] ;
    noria:troubleTicketType [
        a skos:Concept ;
        skos:prefLabel "Failure" ;
        skos:inScheme <http://example.com/noria/kos/TroubleTicket/type>
    ] ;
    noria:troubleTicketPriority [
        a skos:Concept ;
        skos:prefLabel "P1" ;
        skos:inScheme <http://example.com/noria/kos/TroubleTicket/priority>
    ] ;
    noria:troubleTicketOrigin [
        a skos:Concept ;
        skos:prefLabel "Supervision" ;
        skos:inScheme <http://example.com/noria/kos/TroubleTicket/origin>
    ] ;
    noria:troubleTicketTrigger ex:Event_RouterInterfaceDown ;
    noria:troubleTicketStatusCurrent [
        a skos:Concept ;
        skos:prefLabel "InProgress" ;
        skos:inScheme <http://example.com/noria/kos/TroubleTicket/status>
    ] ;
    noria:troubleTicketRelatedParty ex:NOC_Team ;
    noria:troubleTicketRelatedService ex:InternetAccess_Service ;
    noria:troubleTicketRelatedResource ex:Router_Core_01 ;
    noria:troubleTicketCause "Physical fiber cut on WAN link, requiring external provider intervention." ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T14:00:00Z"^^xsd:dateTime .

ex:TT_20240423_001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note" ;
    rdfs:comment "Confirmed interface down on router-core-par-01 GE0/0/0. Escalating to L2 for physical inspection and coordination with Provider A." ;
    dcterms:created "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    dcterms:creator ex:JohnDoe ;
    dcterms:isPartOf ex:TT_20240423_001 ;
    noria:troubleTicketNoteCommentType [
        a skos:Concept ;
        skos:prefLabel "Internal" ;
        skos:inScheme <http://example.com/noria/kos/TroubleTicket/commentType>
    ] ;
    noria:troubleTicketNoteOperationType [
        a skos:Concept ;
        skos:prefLabel "Diagnosis" ;
        skos:inScheme <http://example.com/noria/kos/TroubleTicket/operationType>
    ] .

