        skos:inScheme <http://example.com/noria/kos/ChangeRequest/status>
    ] ;
    noria:changeRequestInitiatorParty ex:JaneSmith ;
    noria:changeRequestPilotParty ex:JaneSmith ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration .

# --- Operation Plan ---
ex:DBUpgrade_OperationPlan a noria:OperationPlan ;
    rdfs:label "Database Upgrade Procedure" ;
    rdfs:comment "Standard operating procedure for upgrading the Customer Portal database, including backup and verification steps." ;
    noria:operationPlanPreCondition ex:DBUpgrade_PreCondition ;
    noria:operationPlanPostCondition ex:DBUpgrade_PostCondition .

ex:DBUpgrade_PreCondition a noria:ActionPreCondition ;
    rdfs:label "Database Backup Verified" ;
    rdfs:comment "Ensure a full database backup is completed and verified before starting the upgrade to allow for rollback." .

ex:DBUpgrade_PostCondition a noria:ActionPostCondition ;
    rdfs:label "Application Functionality Verified" ;
    rdfs:comment "Verify all critical functionalities of the Customer Portal application after the database upgrade to confirm success." .

ex:CR_20240501_001 noria:actionCorrelatedOperationPlan ex:DBUpgrade_OperationPlan .

