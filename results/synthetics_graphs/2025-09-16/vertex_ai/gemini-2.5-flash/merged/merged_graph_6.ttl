# --- Organizations and Agents ---
ex:OrangeCorp a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main organization managing the IT infrastructure for various services." ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] ;
    noria:agentInstructions "Contact via ticketing system for all issues." .

ex:NOC_Team a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Team" ;
    rdfs:comment "Team responsible for 24/7 network monitoring and first-level incident response." ;
    org:unitOf ex:OrangeCorp ;
    noria:agentWorkingHours "24/7 Shift-based" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Phone" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] ;
    noria:agentInstructions "For critical incidents, call the hotline immediately." .

ex:AppSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team" ;
    rdfs:comment "Team responsible for maintaining critical business applications." ;
    org:unitOf ex:OrangeCorp ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Ticketing System" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] .

ex:JohnDoe a foaf:Person ;
    rdfs:label "John Doe" ;
    rdfs:comment "Lead Engineer for the NOC Team, responsible for core network infrastructure." ;
    org:memberOf ex:NOC_Team ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] ;
    noria:agentManagesResource ex:Router_Core_01 .

ex:JaneSmith a foaf:Person ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Application Manager for the Customer Portal, overseeing its operations." ;
    org:memberOf ex:AppSupportTeam ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00" ;
    noria:agentPreferredContactMethod [
        a skos:Concept ;
        skos:prefLabel "Email" ;
        skos:inScheme <kos/org/agent-contact-method>
    ] ;
    noria:agentManagesResource ex:WebServer_CP_01 .

ex:ExternalAttacker a foaf:Agent ;
    rdfs:label "External Attacker" ;
    rdfs:comment "An unknown external entity attempting unauthorized access to systems." .

ex:CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems Inc." ;
    rdfs:comment "Manufacturer of network equipment, including routers and switches." .

ex:HPE a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise" ;
    rdfs:comment "Manufacturer of enterprise servers and IT solutions." .

ex:HotlineTeam a org:OrganizationalUnit ;
    rdfs:label "Hotline Support Team" ;
    rdfs:comment "Dedicated team for urgent application support, available 24/7." ;
    org:unitOf ex:OrangeCorp .

# --- Locations ---
ex:DataCenter_Paris a bot:Site ;
    rdfs:label "Paris Data Center" ;
    rdfs:comment "Main data center located in Paris, hosting critical infrastructure." ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

ex:ServerRoom_A1 a noria:Room ;
    rdfs:label "Server Room A1" ;
    rdfs:comment "A secure server room within the Paris Data Center, housing network and compute racks." ;
    bot:hasSpace ex:DataCenter_Paris .

ex:Rack_A1_L06 a noria:Locus ;
    rdfs:label "Rack A1-L06" ;
    rdfs:comment "Specific rack location in Server Room A1, where core network devices are installed." ;
    noria:locusLine "A1" ;
    noria:locusRow "06" ;
    bot:hasSpace ex:ServerRoom_A1 .

