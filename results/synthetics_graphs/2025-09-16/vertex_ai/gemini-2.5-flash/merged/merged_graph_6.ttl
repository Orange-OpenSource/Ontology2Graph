# --- Event Records ---
ex:Event_InterfaceDown a noria:EventRecord ;
    rdfs:label "Interface Down Event on Core Router 01" ;
    rdfs:comment "Log entry indicating a network interface went down, impacting connectivity." ;
    noria:logOriginatingManagedObject ex:Router_Core_01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystemApp ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down" ;
    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Major" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity>
    ] ;
    noria:alarmProposedRepairAction ex:OpPlan_InterfaceRestart ;
    noria:alarmMitigatedBy ex:CorrectiveAction_RestartInterface .

ex:Event_LoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt on Web Server CP 01" ;
    rdfs:comment "Security event: multiple failed login attempts detected on the web server." ;
    noria:logOriginatingManagedObject ex:WebServer_CP_01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystemApp ;
    noria:logOriginatingAgent ex:ExternalAttacker ;
    noria:logText "AUTH-4-LOGIN_FAILED: User 'baduser' failed to login from 192.168.1.100" ;
    noria:loggingTime "2023-10-26T10:15:00Z"^^xsd:dateTime ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Warning" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity>
    ] .

ex:Event_ConfigChange_RTR01 a noria:EventRecord ;
    rdfs:label "Configuration Change Event on Core Router 01" ;
    rdfs:comment "Log entry indicating a configuration change was applied to Core Router 01 by an engineer." ;
    noria:logOriginatingManagedObject ex:Router_Core_01 ;
    noria:logOriginatingAgent ex:JohnDoe ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by vty0 (10.0.0.5)" ;
    noria:loggingTime "2023-11-01T02:30:00Z"^^xsd:dateTime .

ex:Event_InterfaceUp a noria:EventRecord ;
    rdfs:label "Interface Up Event on Core Router 01" ;
    rdfs:comment "Log entry indicating a network interface came up after a restart procedure." ;
    noria:logOriginatingManagedObject ex:Router_Core_01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystemApp ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to up" ;
    noria:loggingTime "2023-10-26T09:18:00Z"^^xsd:dateTime ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Cleared" ;
        skos:inScheme <Notification/Severity/PerceivedSeverity>
    ] .

