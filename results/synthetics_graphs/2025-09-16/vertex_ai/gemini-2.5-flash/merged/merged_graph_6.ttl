# --- Event Records ---
ex:Event_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event" ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down, detected by the NMS." ;
