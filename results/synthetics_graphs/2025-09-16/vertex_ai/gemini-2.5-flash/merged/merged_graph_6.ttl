    noria:logOriginatingManagedObject ex:Router_Core_01 ;
    noria:logOriginatingManagementSystem ex:NMS_System ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GE0/0/0, changed state to down" ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Critical" ;
        skos:inScheme <http://example.com/noria/kos/Notification/Severity/PerceivedSeverity>
    ] .

ex:NMS_System a noria:Application ;
