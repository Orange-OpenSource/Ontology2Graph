        skos:prefLabel "Monitoring Tool" ;
        skos:inScheme <http://example.com/noria/kos/application/type>
    ] .

ex:Event_AppErrorLog a noria:EventRecord ;
    rdfs:label "Application Error Log" ;
    rdfs:comment "Log entry indicating an error in the Customer Portal application, potentially impacting user experience." ;
    noria:loggingTime "2024-04-23T10:10:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject ex:Server_App_01 ;
    noria:logOriginatingManagementSystem ex:AppLog_System ;
    noria:logText "ERROR: Customer transaction failed for user 'testuser'." ;
    noria:alarmSeverity [
        a skos:Concept ;
        skos:prefLabel "Major" ;
        skos:inScheme <http://example.com/noria/kos/Notification/Severity/PerceivedSeverity>
    ] .

ex:AppLog_System a noria:Application ;
