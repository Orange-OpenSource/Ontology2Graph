# --- Operation Plans and Conditions ---
ex:OpPlan_InterfaceRestart a noria:OperationPlan ;
    rdfs:label "Network Interface Restart Procedure" ;
    rdfs:comment "Standard operating procedure for restarting a network interface to restore connectivity." ;
    noria:operationPlanPreCondition ex:PreCond_InterfaceDown ;
    noria:operationPlanPostCondition ex:PostCond_InterfaceUp .

ex:PreCond_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Interface is Down" ;
    rdfs:comment "The network interface must be in an operational 'down' state to execute the restart procedure." .

ex:PostCond_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Interface is Up" ;
    rdfs:comment "The network interface should return to an operational 'up' state after the procedure is completed." .

# --- Procedure Execution Containers ---
ex:CorrectiveAction_RestartInterface a pep:ProcedureExecutionContainer ;
    rdfs:label "Corrective Action: Restart Interface GE0/0/1" ;
    rdfs:comment "Container for events related to the execution of restarting the network interface GE0/0/1." ;
    dcterms:created "2023-10-26T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator ex:JohnDoe ;
    pep:member ex:Event_InterfaceUp .

