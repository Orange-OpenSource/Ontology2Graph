    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory [
        a skos:Concept ;
        skos:prefLabel "Internal intervention" ;
        skos:inScheme <http://example.com/noria/kos/ChangeRequest/category>
    ] ;
