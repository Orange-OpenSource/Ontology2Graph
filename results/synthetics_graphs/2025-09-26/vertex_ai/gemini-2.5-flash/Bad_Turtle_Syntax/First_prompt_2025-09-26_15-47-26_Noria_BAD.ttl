    noria:applicationModuleName "CustPortal_WebServer"^^xsd:string ;
    noria:applicationModuleIdentifier "WS-MOD-001"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:DevOpsTeamA ;
