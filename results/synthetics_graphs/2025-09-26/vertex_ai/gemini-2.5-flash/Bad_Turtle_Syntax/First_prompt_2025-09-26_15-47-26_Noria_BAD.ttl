# --- Location Elements ---
ex:DataCenterParis
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center location in Paris, France, hosting critical IT infrastructure."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    wgs84_pos:lat "48.8718"^^xsd:float ;
    wgs84_pos:long "2.3314"^^xsd:float ;
.

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A secure server room within the Paris Data Center, housing web and API servers."@en ;
    bot:hasSpace ex:DataCenterParis ;
    bot:containsZone ex:RackAisle1 ;
.

ex:ServerRoomB
    a noria:Room ;
    rdfs:label "Server Room B"@en ;
    rdfs:comment "A secure server room within the Paris Data Center, housing database servers and core network equipment."@en ;
    bot:hasSpace ex:DataCenterParis ;
    bot:containsZone ex:RackAisle2 ;
.

