@base <https://w3id.org/noria/> .

@prefix ex: <http://example.com/data/> .

# --- SKOS Concept Schemes and Concepts ---
# Application Type
<kos/application/type>
    a skos:ConceptScheme ;
    dcterms:title "Application Type Concept Scheme"@en ;
    rdfs:comment "Defines various types of applications within the IT landscape."@en ;
.
<kos/application/type/WebApplication>
    a skos:Concept ;
    skos:prefLabel "Web Application"@en ;
    skos:altLabel "Online Service"@en ;
    skos:definition "An application accessible via a web browser."@en ;
    skos:inScheme <kos/application/type> ;
.
<kos/application/type/DatabaseApplication>
    a skos:Concept ;
    skos:prefLabel "Database Application"@en ;
    skos:definition "An application primarily focused on data storage and retrieval."@en ;
    skos:inScheme <kos/application/type> ;
.
<kos/application/type/MonitoringTool>
    a skos:Concept ;
    skos:prefLabel "Monitoring Tool"@en ;
    skos:definition "Software used for observing and tracking system performance and events."@en ;
    skos:inScheme <kos/application/type> ;
.
<kos/application/type/BillingSystem>
    a skos:Concept ;
    skos:prefLabel "Billing System"@en ;
    skos:definition "An application managing customer invoices and payments."@en ;
    skos:inScheme <kos/application/type> ;
.

# Application Business Importance
<kos/application/business-importance>
    a skos:ConceptScheme ;
    dcterms:title "Application Business Importance Concept Scheme"@en ;
    rdfs:comment "Categorizes applications based on their criticality to business operations."@en ;
.
<kos/application/business-importance/Critical>
    a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:definition "Application whose failure would severely impact core business functions."@en ;
    skos:inScheme <kos/application/business-importance> ;
.
<kos/application/business-importance/High>
    a skos:Concept ;
    skos:prefLabel "High"@en ;
    skos:definition "Application important for business, but with some redundancy or workaround."@en ;
    skos:inScheme <kos/application/business-importance> ;
.

# Application Module Status
<https://w3id.org/noria/kos/application/status>
    a skos:ConceptScheme ;
    dcterms:title "Application Module Status Concept Scheme"@en ;
    rdfs:comment "Describes the operational status of an application module."@en ;
.
<https://w3id.org/noria/kos/application/status/InProduction>
    a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:definition "The module is currently active and serving live traffic."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
.
<https://w3id.org/noria/kos/application/status/Maintenance>
    a skos:Concept ;
    skos:prefLabel "Under Maintenance"@en ;
    skos:definition "The module is temporarily offline for maintenance."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
.

# Service Type
<kos/service/type>
    a skos:ConceptScheme ;
    dcterms:title "Service Type Concept Scheme"@en ;
    rdfs:comment "Classifies different types of IT services."@en ;
.
<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:prefLabel "Customer-Facing Service"@en ;
    skos:definition "A service directly consumed or experienced by end-customers."@en ;
    skos:inScheme <kos/service/type> ;
.
<kos/service/type/InternalService>
    a skos:Concept ;
    skos:prefLabel "Internal Service"@en ;
    skos:definition "A service used by internal staff or other IT systems, not directly by end-customers."@en ;
    skos:inScheme <kos/service/type> ;
.

# Resource Type
<kos/Resource/type>
    a skos:ConceptScheme ;
    dcterms:title "Resource Type Concept Scheme"@en ;
    rdfs:comment "Defines categories for various IT resources."@en ;
.
<kos/Resource/type/Server>
    a skos:Concept ;
    skos:prefLabel "Server"@en ;
    skos:definition "A computer program or a device that provides functionality for other programs or devices, called 'clients'."@en ;
    skos:inScheme <kos/Resource/type> ;
.
<kos/Resource/type/NetworkDevice>
    a skos:Concept ;
    skos:prefLabel "Network Device"@en ;
    skos:definition "Hardware used to connect computers or other electronic devices together to share files or resources."@en ;
    skos:inScheme <kos/Resource/type> ;
.
<kos/Resource/type/VirtualMachine>
    a skos:Concept ;
    skos:prefLabel "Virtual Machine"@en ;
    skos:definition "An emulation of a computer system."@en ;
    skos:inScheme <kos/Resource/type> ;
.

# Resource Operational State
<kos/Resource/OperationalState>
    a skos:ConceptScheme ;
    dcterms:title "Resource Operational State Concept Scheme"@en ;
    rdfs:comment "Describes the current operational status of a resource."@en ;
.
<kos/Resource/OperationalState/Up>
    a skos:Concept ;
    skos:prefLabel "Up"@en ;
    skos:definition "The resource is fully operational."@en ;
    skos:inScheme <kos/Resource/OperationalState> ;
.
<kos/Resource/OperationalState/Down>
    a skos:Concept ;
    skos:prefLabel "Down"@en ;
    skos:definition "The resource is not operational."@en ;
    skos:inScheme <kos/Resource/OperationalState> ;
.
<kos/Resource/OperationalState/Degraded>
    a skos:Concept ;
    skos:prefLabel "Degraded"@en ;
    skos:definition "The resource is operational but with reduced performance or functionality."@en ;
    skos:inScheme <kos/Resource/OperationalState> ;
.

# Resource Administrative State
<kos/Resource/AdministrativeState>
    a skos:ConceptScheme ;
    dcterms:title "Resource Administrative State Concept Scheme"@en ;
    rdfs:comment "Describes the desired administrative state of a resource."@en ;
.
<kos/Resource/AdministrativeState/Enabled>
    a skos:Concept ;
    skos:prefLabel "Enabled"@en ;
    skos:definition "The resource is administratively allowed to operate."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
.
<kos/Resource/AdministrativeState/Disabled>
    a skos:Concept ;
    skos:prefLabel "Disabled"@en ;
    skos:definition "The resource is administratively prevented from operating."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
.

# Resource Lifecycle State
<kos/Resource/LifecycleState>
    a skos:ConceptScheme ;
    dcterms:title "Resource Lifecycle State Concept Scheme"@en ;
    rdfs:comment "Describes the stage of a resource in its lifecycle."@en ;
.
<kos/Resource/LifecycleState/InProduction>
    a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:definition "The resource is actively used in the production environment."@en ;
    skos:inScheme <kos/Resource/LifecycleState> ;
.
<kos/Resource/LifecycleState/Decommissioned>
    a skos:Concept ;
    skos:prefLabel "Decommissioned"@en ;
    skos:definition "The resource has been removed from service."@en ;
    skos:inScheme <kos/Resource/LifecycleState> ;
.

# Network Interface Type
<kos/NetworkInterface/type>
    a skos:ConceptScheme ;
    dcterms:title "Network Interface Type Concept Scheme"@en ;
    rdfs:comment "Classifies different types of network interfaces."@en ;
.
<kos/NetworkInterface/type/PhysicalEthernet>
    a skos:Concept ;
    skos:prefLabel "Physical Ethernet Interface"@en ;
    skos:definition "A physical network interface using Ethernet technology."@en ;
    skos:inScheme <kos/NetworkInterface/type> ;
.
<kos/NetworkInterface/type/Loopback>
    a skos:Concept ;
    skos:prefLabel "Loopback Interface"@en ;
    skos:definition "A virtual network interface used for internal communication."@en ;
    skos:inScheme <kos/NetworkInterface/type> ;
.

# Agent Contact Method
<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    dcterms:title "Agent Contact Method Concept Scheme"@en ;
    rdfs:comment "Defines preferred methods for contacting agents or teams."@en ;
.
<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:prefLabel "Email"@en ;
    skos:definition "Contact via electronic mail."@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
.
<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:prefLabel "Phone"@en ;
    skos:definition "Contact via telephone."@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
.

# Trouble Ticket Severity
<kos/TroubleTicket/severity>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Severity Concept Scheme"@en ;
    rdfs:comment "Categorizes trouble tickets based on the impact of the incident."@en ;
.
<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:definition "Highest severity, immediate business impact, service down."@en ;
    skos:inScheme <kos/TroubleTicket/severity> ;
.
<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    skos:prefLabel "Major"@en ;
    skos:definition "Significant business impact, degraded service or partial outage."@en ;
    skos:inScheme <kos/TroubleTicket/severity> ;
.
<kos/TroubleTicket/severity/Minor>
    a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:definition "Low business impact, cosmetic issue or minor functionality loss."@en ;
    skos:inScheme <kos/TroubleTicket/severity> ;
.

# Trouble Ticket Type
<kos/TroubleTicket/type>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Type Concept Scheme"@en ;
    rdfs:comment "Classifies the nature of the reported issue."@en ;
.
<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    skos:prefLabel "Failure"@en ;
    skos:definition "An unexpected cessation of service or functionality."@en ;
    skos:inScheme <kos/TroubleTicket/type> ;
.
<kos/TroubleTicket/type/Assistance>
    a skos:Concept ;
    skos:prefLabel "Assistance"@en ;
    skos:definition "Request for help or guidance."@en ;
    skos:inScheme <kos/TroubleTicket/type> ;
.

# Trouble Ticket Priority
<kos/TroubleTicket/priority>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Priority Concept Scheme"@en ;
    rdfs:comment "Determines the order in which trouble tickets should be addressed."@en ;
.
<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    skos:prefLabel "P1 - Critical"@en ;
    skos:definition "Highest priority, requires immediate attention."@en ;
    skos:inScheme <kos/TroubleTicket/priority> ;
.
<kos/TroubleTicket/priority/P2>
    a skos:Concept ;
    skos:prefLabel "P2 - High"@en ;
    skos:definition "High priority, requires prompt attention."@en ;
    skos:inScheme <kos/TroubleTicket/priority> ;
.

# Trouble Ticket Origin
<kos/TroubleTicket/origin>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Origin Concept Scheme"@en ;
    rdfs:comment "Indicates who or what initiated the trouble ticket."@en ;
.
<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    skos:prefLabel "Customer"@en ;
    skos:definition "Ticket initiated by an external customer."@en ;
    skos:inScheme <kos/TroubleTicket/origin> ;
.
<kos/TroubleTicket/origin/Supervision>
    a skos:Concept ;
    skos:prefLabel "Supervision System"@en ;
    skos:definition "Ticket initiated by an automated monitoring or supervision system."@en ;
    skos:inScheme <kos/TroubleTicket/origin> ;
.

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Urgency Concept Scheme"@en ;
    rdfs:comment "Describes the time sensitivity of resolving the issue."@en ;
.
<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    skos:prefLabel "Immediate Intervention"@en ;
    skos:definition "Requires action without delay."@en ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
.
<kos/TroubleTicket/urgency/DeferredIntervention>
    a skos:Concept ;
    skos:prefLabel "Deferred Intervention"@en ;
    skos:definition "Action can be scheduled for a later time."@en ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
.

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Category Concept Scheme"@en ;
    rdfs:comment "Classifies the technical nature or impact of the trouble."@en ;
.
<kos/TroubleTicket/trouble-category/ServiceInterruption>
    a skos:Concept ;
    skos:prefLabel "Service Interruption"@en ;
    skos:definition "Complete loss of service."@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
.
<kos/TroubleTicket/trouble-category/PerformanceDegradation>
    a skos:Concept ;
    skos:prefLabel "Performance Degradation"@en ;
    skos:definition "Service is slow or performing below expected levels."@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
.

# Trouble Ticket Status
<kos/TroubleTicket/status>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Status Concept Scheme"@en ;
    rdfs:comment "Describes the current lifecycle stage of a trouble ticket."@en ;
.
<kos/TroubleTicket/status/InProgress>
    a skos:Concept ;
    skos:prefLabel "In Progress"@en ;
    skos:definition "The ticket is actively being worked on."@en ;
    skos:inScheme <kos/TroubleTicket/status> ;
.
<kos/TroubleTicket/status/Resolved>
    a skos:Concept ;
    skos:prefLabel "Resolved"@en ;
    skos:definition "The issue has been fixed, awaiting customer confirmation or closure."@en ;
    skos:inScheme <kos/TroubleTicket/status> ;
.

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Comment Type Concept Scheme"@en ;
    rdfs:comment "Categorizes the type of comment added to a trouble ticket note."@en ;
.
<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    skos:prefLabel "Internal Comment"@en ;
    skos:definition "Comment intended for internal team members only."@en ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
.
<kos/TroubleTicket/commentType/CustomerFacing>
    a skos:Concept ;
    skos:prefLabel "Customer-Facing Comment"@en ;
    skos:definition "Comment intended for communication with the customer."@en ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
.

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Operation Type Concept Scheme"@en ;
    rdfs:comment "Describes the nature of the operation or action recorded in a note."@en ;
.
<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    skos:prefLabel "Diagnosis"@en ;
    skos:definition "Activities related to identifying the root cause of an issue."@en ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
.
<kos/TroubleTicket/operationType/Resolution>
    a skos:Concept ;
    skos:prefLabel "Resolution"@en ;
    skos:definition "Actions taken to fix the identified issue."@en ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
.

# Alarm Severity
<Notification/Severity/PerceivedSeverity>
    a skos:ConceptScheme ;
    dcterms:title "Perceived Severity Concept Scheme"@en ;
    rdfs:comment "Describes the perceived severity of an alarm or event."@en ;
.
<Notification/Severity/PerceivedSeverity/Critical>
    a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:definition "An alarm indicating a severe, service-impacting condition."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
.
<Notification/Severity/PerceivedSeverity/Warning>
    a skos:Concept ;
    skos:prefLabel "Warning"@en ;
    skos:definition "An alarm indicating a potential problem that is not yet service-impacting."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
.

# Change Request Category
<kos/ChangeRequest/category>
    a skos:ConceptScheme ;
    dcterms:title "Change Request Category Concept Scheme"@en ;
    rdfs:comment "Classifies change requests based on their nature or origin."@en ;
.
<kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    skos:prefLabel "Internal Intervention"@en ;
    skos:definition "Change initiated and performed by internal teams."@en ;
    skos:inScheme <kos/ChangeRequest/category> ;
.
<kos/ChangeRequest/category/CustomerRequest>
    a skos:Concept ;
    skos:prefLabel "Customer Request"@en ;
    skos:definition "Change requested by a customer."@en ;
    skos:inScheme <kos/ChangeRequest/category> ;
.

# Change Request Type
<kos/ChangeRequest/type>
    a skos:ConceptScheme ;
    dcterms:title "Change Request Type Concept Scheme"@en ;
    rdfs:comment "Describes the impact and risk level of a change request."@en ;
.
<kos/ChangeRequest/type/StandardChange>
    a skos:Concept ;
    skos:prefLabel "Standard Change"@en ;
    skos:definition "Pre-approved, low-risk, routine change."@en ;
    skos:inScheme <kos/ChangeRequest/type> ;
.
<kos/ChangeRequest/type/NormalChange>
    a skos:Concept ;
    skos:prefLabel "Normal Change"@en ;
    skos:definition "Requires assessment and authorization, non-emergency."@en ;
    skos:inScheme <kos/ChangeRequest/type> ;
.

# Change Request Cause
<kos/ChangeRequest/cause>
    a skos:ConceptScheme ;
    dcterms:title "Change Request Cause Concept Scheme"@en ;
    rdfs:comment "Indicates the reason for initiating a change request."@en ;
.
<kos/ChangeRequest/cause/PreventativeMaintenance>
    a skos:Concept ;
    skos:prefLabel "Preventative Maintenance"@en ;
    skos:definition "Change performed to prevent future issues."@en ;
    skos:inScheme <kos/ChangeRequest/cause> ;
.
<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    skos:prefLabel "Software Upgrade"@en ;
    skos:definition "Change to update software versions."@en ;
    skos:inScheme <kos/ChangeRequest/cause> ;
.

# Change Request Status
<kos/ChangeRequest/status>
    a skos:ConceptScheme ;
    dcterms:title "Change Request Status Concept Scheme"@en ;
    rdfs:comment "Describes the current lifecycle stage of a change request."@en ;
.
<kos/ChangeRequest/status/Scheduled>
    a skos:Concept ;
    skos:prefLabel "Scheduled"@en ;
    skos:definition "The change is planned for a future date/time."@en ;
    skos:inScheme <kos/ChangeRequest/status> ;
.
<kos/ChangeRequest/status/Implemented>
    a skos:Concept ;
    skos:prefLabel "Implemented"@en ;
    skos:definition "The change has been successfully applied."@en ;
    skos:inScheme <kos/ChangeRequest/status> ;
.

# --- Organizational Entities ---
ex:DevOpsTeamA
    a org:OrganizationalUnit ;
    rdfs:label "DevOps Team A"@en ;
    rdfs:comment "The primary team responsible for the Customer Portal application and its underlying infrastructure."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via internal ticketing system for critical issues. For non-critical, use email."@en ;
.

ex:BillingTeam
    a org:OrganizationalUnit ;
    rdfs:label "Billing Operations Team"@en ;
    rdfs:comment "Team responsible for managing the Customer Billing System and related financial processes."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For urgent billing inquiries, call the hotline. Otherwise, use the billing support portal."@en ;
.

ex:AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Engineer for DevOps Team A, specializing in web application architecture."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    org:memberOf ex:DevOpsTeamA ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

ex:BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior System Administrator for the Customer Portal infrastructure, focusing on server and network operations."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf ex:DevOpsTeamA ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

ex:CarolWhite
    a foaf:Person ;
    rdfs:label "Carol White"@en ;
    rdfs:comment "Billing System Specialist, responsible for data integrity and reporting."@en ;
    foaf:mbox <mailto:carol.white@example.com> ;
    org:memberOf ex:BillingTeam ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

ex:CustomerPortalAdminCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Customer Portal Admin Account"@en ;
    rdfs:comment "Corporate User Identifier for administrative access to the Customer Portal, held by Bob Johnson."@en ;
    foaf:accountName "portal_admin_bob" ;
    foaf:holdsAccount ex:BobJohnson ;
.

ex:BillingSystemAdminCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Billing System Admin Account"@en ;
    rdfs:comment "Corporate User Identifier for administrative access to the Customer Billing System, held by Carol White."@en ;
    foaf:accountName "billing_admin_carol" ;
    foaf:holdsAccount ex:CarolWhite ;
.

# --- Functional Elements (Applications and Services) ---
ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "The main web application allowing customers to manage their services, view bills, and update profiles."@en ;
    noria:applicationModelIdentifier "CP-V2.1"^^xsd:string ;
    noria:applicationShortIdentifier "CustPortal"^^xsd:string ;
    noria:applicationType <kos/application/type/WebApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Self-Service Management"@en ;
    noria:elementManagedBy ex:DevOpsTeamA ;
.

ex:CustomerBillingSystem
    a noria:Application ;
    rdfs:label "Customer Billing System"@en ;
    rdfs:comment "Core system for generating invoices, processing payments, and managing customer financial data."@en ;
    noria:applicationModelIdentifier "CBS-V3.0"^^xsd:string ;
    noria:applicationNumericalIdentifier 2001^^xsd:int ;
    noria:applicationShortIdentifier "CustBilling"^^xsd:string ;
    noria:applicationType <kos/application/type/BillingSystem> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Financial Management"@en ;
    noria:applicationFunctionalSubDomain "Billing and Invoicing"@en ;
    noria:elementManagedBy ex:BillingTeam ;
.

ex:WebServerModule
