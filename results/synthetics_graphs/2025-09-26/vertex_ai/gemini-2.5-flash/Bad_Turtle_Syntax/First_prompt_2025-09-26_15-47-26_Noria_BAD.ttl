.

# --- Procedural Elements ---
ex:ServerMaintenancePlan
    a noria:OperationPlan ;
    rdfs:label "Standard Server Maintenance Procedure"@en ;
    rdfs:comment "A documented procedure for performing routine maintenance on physical servers, including hardware upgrades and software patching."@en ;
    noria:operationPlanPreCondition ex:MaintenanceWindowApproved ;
    noria:operationPlanPostCondition ex:ServerOperationalChecklist ;
.

ex:DBOptimizationPlan
    a noria:OperationPlan ;
    rdfs:label "Database Index Optimization Procedure"@en ;
    rdfs:comment "A documented procedure for analyzing and optimizing database indexes to improve query performance."@en ;
    noria:operationPlanPreCondition ex:PerformanceBaselineEstablished ;
    noria:operationPlanPostCondition ex:QueryPerformanceImproved ;
.

ex:RestartWebServerProcessPlan
    a noria:OperationPlan ;
    rdfs:label "Restart Web Server Process Procedure"@en ;
    rdfs:comment "Procedure to safely restart the web server process on a given server."@en ;
    noria:operationPlanPreCondition ex:CheckActiveSessions ;
    noria:operationPlanPostCondition ex:VerifyWebServerStatus ;
.

ex:MaintenanceWindowApproved
    a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Approved"@en ;
    rdfs:comment "Condition: A scheduled maintenance window must be formally approved and communicated to all stakeholders."@en ;
.

ex:ServerOperationalChecklist
    a noria:ActionPostCondition ;
    rdfs:label "Server Operational Checklist Completed"@en ;
    rdfs:comment "Outcome: All services on the server are verified to be operational, and system health checks pass after maintenance."@en ;
.

ex:PerformanceBaselineEstablished
    a noria:ActionPreCondition ;
    rdfs:label "Performance Baseline Established"@en ;
    rdfs:comment "Condition: Current database performance metrics must be collected to establish a baseline before optimization."@en ;
.

ex:QueryPerformanceImproved
    a noria:ActionPostCondition ;
    rdfs:label "Query Performance Improved"@en ;
    rdfs:comment "Outcome: Post-optimization, key database queries must show a measurable improvement in execution time."@en ;
.

ex:CheckActiveSessions
    a noria:ActionPreCondition ;
    rdfs:label "Check Active Sessions"@en ;
    rdfs:comment "Condition: Verify the number of active user sessions before restarting the web server to minimize impact."@en ;
.

ex:VerifyWebServerStatus
    a noria:ActionPostCondition ;
    rdfs:label "Verify Web Server Status"@en ;
    rdfs:comment "Outcome: Confirm that the web server process is running and accessible after restart."@en ;
.

ex:RAMUpgradeAction
    a pep:ProcedureExecution ;
    rdfs:label "RAM Upgrade Execution for Server 01"@en ;
    rdfs:comment "The actual execution of the RAM upgrade procedure on Physical Server 01, performed by Bob Johnson."@en ;
    pep:usedProcedure ex:ServerMaintenancePlan ;
    pep:madeBy ex:BobJohnson ;
    dcterms:created "2024-03-20T02:15:00Z"^^xsd:dateTime ;
    dcterms:isPartOf ex:CR-20240320-001 ;
    pep:hasSimpleResult "RAM upgrade successful, server rebooted."@en ;
.

ex:DBConnPoolResizeAction
    a pep:ProcedureExecution ;
    rdfs:label "Database Connection Pool Resize"@en ;
    rdfs:comment "Action taken to increase the database connection pool size on srv-db-03 to resolve login issues."@en ;
    pep:madeBy ex:BobJohnson ;
    dcterms:created "2024-03-15T10:15:00Z"^^xsd:dateTime ;
    dcterms:isPartOf ex:TT-20240315-001 ;
    pep:hasSimpleResult "Connection pool increased from 50 to 100. Service restored."@en ;
.

ex:IndexOptimizationAction
    a pep:ProcedureExecution ;
    rdfs:label "Database Index Optimization Execution"@en ;
    rdfs:comment "Execution of the database index optimization procedure on Database Server 03."@en ;
    pep:usedProcedure ex:DBOptimizationPlan ;
    pep:madeBy ex:BobJohnson ;
    dcterms:created "2024-03-25T01:30:00Z"^^xsd:dateTime ;
    dcterms:isPartOf ex:CR-20240325-002 ;
    pep:hasSimpleResult "Indexes rebuilt and optimized. Query performance improved by 25%."@en ;
.

# --- RCA objects ---
ex:DBConnectionExhaustionPattern
    a noria:AnomalyPattern ;
    rdfs:label "Database Connection Exhaustion Anomaly Pattern"@en ;
    rdfs:comment "Describes a pattern of high login failures combined with database connection errors, indicating connection pool exhaustion."@en ;
    folio:hasFailureModeType "Resource Exhaustion"@en ;
    folio:hasCause "Insufficient connection pool size"@en ;
    folio:hasEffect "Service Interruption"@en ;
.

# --- Relationships to ensure all nodes are connected and demonstrate schema usage ---
ex:DevOpsTeamA
    noria:agentManagesResource ex:PhysicalServer01 , ex:VirtualServer02 , ex:DatabaseServer03 , ex:CoreSwitch01 , ex:EdgeRouter01 , ex:ManagementSwitch01 , ex:ISPNetwork , ex:VMwarevCenter ;
    noria:agentManagesResource ex:CustomerPortalApp , ex:WebServerModule , ex:APIGatewayModule , ex:DatabaseService , ex:MonitoringSystem ;
.

ex:BillingTeam
    noria:agentManagesResource ex:CustomerBillingSystem , ex:BillingEngineModule ;
.

ex:CustomerPortalApp
    seas:subSystemOf ex:DatabaseService ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
.

ex:CustomerBillingSystem
    seas:subSystemOf ex:DatabaseService ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
.

ex:WebServerModule
    seas:subSystemOf ex:CustomerPortalApp ;
    noria:applicationModuleRelatedParty ex:DevOpsTeamA ;
.

ex:APIGatewayModule
    seas:subSystemOf ex:CustomerPortalApp ;
    noria:applicationModuleRelatedParty ex:DevOpsTeamA ;
.

ex:BillingEngineModule
    seas:subSystemOf ex:CustomerBillingSystem ;
    noria:applicationModuleRelatedParty ex:BillingTeam ;
.

ex:PhysicalServer01
    noria:elementProperty ex:Server01Eth0 ;
    noria:elementProperty ex:Server01Eth1 ;
.

ex:VirtualServer02
    noria:elementProperty ex:VM02Eth0 ;
.

ex:DatabaseServer03
    noria:elementProperty ex:DB03Eth0 ;
.

ex:Server01Eth0 noria:structuralObservableOf ex:PhysicalServer01 ;
.

ex:VM02Eth0 noria:structuralObservableOf ex:VirtualServer02 ;
.

ex:DB03Eth0 noria:structuralObservableOf ex:DatabaseServer03 ;
.

ex:CoreSwitch01 noria:elementProperty ex:CoreSwitchLink1 ;
    noria:elementProperty ex:CoreSwitchLink2 ;
    noria:elementProperty ex:CoreSwitchLink3 ;
.

ex:EdgeRouter01 noria:elementProperty ex:InternetUplink ;
.

ex:DataCenterParis bot:containsZone ex:ServerRoomA , ex:ServerRoomB ;
.

ex:ServerRoomA bot:containsZone ex:RackAisle1 ;
.

ex:ServerRoomB bot:containsZone ex:RackAisle2 ;
.

ex:RackAisle1 bot:containsZone ex:RackAisle1Slot5 ;
.

ex:RackAisle2 bot:containsZone ex:RackAisle2Slot10 ;
.

ex:TT-20240315-001 noria:documentStatusHistory ex:EventRecordLoginFailure ;
.

ex:CR-20240320-001 noria:documentStatusHistory ex:RAMUpgradeAction ;
.

ex:CR-20240325-002 noria:documentStatusHistory ex:IndexOptimizationAction ;
.

ex:RAMUpgradeAction noria:actionCorrelatedOperationPlan ex:ServerMaintenancePlan ;
.

ex:IndexOptimizationAction noria:actionCorrelatedOperationPlan ex:DBOptimizationPlan ;
.

ex:TT-20240315-001 noria:troubleTicketImpacts ex:CustomerPortalApp , ex:DatabaseServer03 ;
.

ex:TT-20240316-002 noria:troubleTicketImpacts ex:CustomerBillingSystem , ex:DatabaseServer03 ;
.

ex:CR-20240320-001 noria:changeRequestImpact ex:PhysicalServer01 ;
.

ex:CR-20240325-002 noria:changeRequestImpact ex:DatabaseServer03 ;
.

# Example of a specific observable for a resource
ex:PhysicalServer01CPUUsage
    a noria:StructuralObservable ;
    rdfs:label "Physical Server 01 CPU Usage"@en ;
    rdfs:comment "An observable property representing the CPU utilization of Physical Server 01."@en ;
    noria:structuralObservableOf ex:PhysicalServer01 ;
    ex:cpuUsageValue 75.5^^xsd:float ; # Direct value for the observable
.

ex:PhysicalServer01 noria:structuralElementObservable ex:PhysicalServer01CPUUsage ;
.

# Define the custom datatype property for CPU usage value
ex:cpuUsageValue
    a owl:DatatypeProperty ;
    rdfs:label "CPU Usage Value"@en ;
    rdfs:comment "The measured value of CPU usage for a StructuralObservable instance."@en ;
    rdfs:domain noria:StructuralObservable ;
    rdfs:range xsd:float ;
.
