# --- Dynamic Elements (Trouble Tickets, Change Requests, Events) ---
ex:TT-20240315-001
    a noria:TroubleTicket ;
    rdfs:label "Customer Portal Login Issue"@en ;
    rdfs:comment "Customers are unable to log in to the portal since 2024-03-15 09:00 UTC due to database connection errors."@en ;
    dcterms:identifier "TT-20240315-001"^^xsd:string ;
    dcterms:created "2024-03-15T09:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "EXT-REF-CUST-12345"^^xsd:string ;
    noria:documentHRef <http://ticketing.example.com/TT-20240315-001> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger ex:EventRecordLoginFailure ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServiceInterruption> ;
    noria:troubleTicketCause "Database connection pool exhaustion on srv-db-03."@en ;
    noria:troubleTicketDetectionDateTime "2024-03-15T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService ex:CustomerPortalApp ;
    noria:troubleTicketRelatedResource ex:DatabaseServer03 ;
    noria:troubleTicketRelatedParty ex:DevOpsTeamA ;
.

ex:TT-20240316-002
    a noria:TroubleTicket ;
    rdfs:label "Billing System Report Generation Delay"@en ;
    rdfs:comment "Monthly billing reports are delayed due to slow database queries."@en ;
    dcterms:identifier "TT-20240316-002"^^xsd:string ;
    dcterms:created "2024-03-16T08:00:00Z"^^xsd:dateTime ;
    noria:documentHRef <http://ticketing.example.com/TT-20240316-002> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/PerformanceDegradation> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger ex:EventRecordSlowQuery ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Prometheus"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/PerformanceDegradation> ;
    noria:troubleTicketCause "Inefficient database queries and high I/O wait on srv-db-03."@en ;
    noria:troubleTicketDetectionDateTime "2024-03-16T07:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService ex:CustomerBillingSystem ;
    noria:troubleTicketRelatedResource ex:DatabaseServer03 ;
    noria:troubleTicketRelatedParty ex:BillingTeam ;
.

ex:EventRecordLoginFailure
    a noria:EventRecord ;
    rdfs:label "Login Failure Alert"@en ;
    rdfs:comment "Automated alert indicating a high rate of login failures on the Customer Portal web server."@en ;
    noria:loggingTime "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject ex:WebServerModule ;
    noria:logOriginatingManagementSystem ex:MonitoringSystem ;
    noria:logText "High volume of failed login attempts detected on Customer Portal web server. Error: DB_CONN_EXHAUSTION."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    folio:hasFailureMode ex:DBConnectionExhaustionPattern ;
.

ex:EventRecordSlowQuery
    a noria:EventRecord ;
    rdfs:label "Slow Database Query Alert"@en ;
    rdfs:comment "Automated alert from database monitoring system indicating slow query execution on the billing database."@en ;
    noria:loggingTime "2024-03-16T07:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject ex:DatabaseServer03 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystem ;
    noria:logText "Database query 'SELECT * FROM invoices WHERE date > ...' exceeded 5-second threshold."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
.

ex:EventRecordHighCPU
    a noria:EventRecord ;
    rdfs:label "High CPU Usage Alert on Server 01"@en ;
    rdfs:comment "Automated alert indicating sustained high CPU usage on Physical Server 01."@en ;
    noria:loggingTime "2024-03-17T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject ex:PhysicalServer01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystem ;
    noria:logText "CPU usage on srv-web-01 exceeded 90% for 15 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmProposedRepairAction ex:RestartWebServerProcessPlan ;
.

ex:TT-Note-20240315-001-01
    a noria:TroubleTicketNote ;
    rdfs:label "Initial Investigation Note for TT-001"@en ;
    rdfs:comment "Initial investigation shows high CPU usage on srv-web-01 and database connection errors originating from srv-db-03. Escalated to DB team."@en ;
    dcterms:created "2024-03-15T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator ex:AliceSmith ;
    dcterms:isPartOf ex:TT-20240315-001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
.

ex:TT-Note-20240315-001-02
    a noria:TroubleTicketNote ;
    rdfs:label "Resolution Note for TT-001"@en ;
    rdfs:comment "Increased database connection pool size on srv-db-03. Monitored for 30 minutes, login functionality restored. Closing ticket."@en ;
    dcterms:created "2024-03-15T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator ex:BobJohnson ;
    dcterms:isPartOf ex:TT-20240315-001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ;
    noria:troubleTicketNoteCorrelatedExecution ex:DBConnPoolResizeAction ;
.

ex:CR-20240320-001
    a noria:ChangeRequest ;
    rdfs:label "Physical Server 01 RAM Upgrade"@en ;
    rdfs:comment "Planned upgrade of RAM for Physical Server 01 to improve performance and stability for the Customer Portal web server."@en ;
    dcterms:identifier "CR-20240320-001"^^xsd:string ;
