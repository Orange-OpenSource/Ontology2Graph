    rdfs:label "Billing Engine Module"@en ;
    rdfs:comment "Core module of the Customer Billing System responsible for calculating charges and generating invoices."@en ;
    noria:applicationModuleOf ex:CustomerBillingSystem ;
    noria:applicationModuleName "CustBilling_Engine"^^xsd:string ;
    noria:applicationModuleIdentifier "BE-MOD-001"^^xsd:string ;
