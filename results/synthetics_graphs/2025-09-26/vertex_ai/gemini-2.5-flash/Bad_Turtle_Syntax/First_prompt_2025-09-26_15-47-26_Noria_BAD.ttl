    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
.

ex:DatabaseService
    a noria:Service ;
    rdfs:label "Customer Database Service"@en ;
    rdfs:comment "Backend database service supporting both the Customer Portal and Customer Billing System."@en ;
    noria:serviceType <kos/service/type/InternalService> ;
    noria:elementManagedBy ex:DevOpsTeamA ;
.

ex:MonitoringSystem
