# =============================================================================
# Knowledge Organization System (KOS) Concepts
# =============================================================================

# KOS for agent-contact-method
noria-kos:org/agent-contact-method
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

noria-kos:org/agent-contact-method/Email
    a skos:Concept ;
    skos:inScheme noria-kos:org/agent-contact-method ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

noria-kos:org/agent-contact-method/Phone
    a skos:Concept ;
    skos:inScheme noria-kos:org/agent-contact-method ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

