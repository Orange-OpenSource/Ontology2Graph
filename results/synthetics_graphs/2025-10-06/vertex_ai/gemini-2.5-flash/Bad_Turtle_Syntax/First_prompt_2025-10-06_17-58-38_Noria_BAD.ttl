# =============================================================================
# Synthetic Knowledge Graph Instances
# =============================================================================

# Organizations and Agents
noria-data:OrangeIT
    a org:Organization ;
    rdfs:label "Orange IT Department"@en ;
    rdfs:comment "The main IT organization within Orange."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-data:NetworkOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "A team responsible for network infrastructure operations."@en ;
    org:unitOf noria-data:OrangeIT ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "For critical issues, use hotline. For routine, use ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone .

noria-data:AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "A team responsible for application support."@en ;
    org:unitOf noria-data:OrangeIT ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sat)"^^xsd:string ;
    noria:agentInstructions "Submit a ticket via the application portal."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-data:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee in the Network Operations Team."@en ;
    foaf:mbox <mailto:john.doe@orange.com> ;
    foaf:member noria-data:NetworkOperationsTeam ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Direct contact for urgent network issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone .

noria-data:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An employee in the Application Support Team."@en ;
    foaf:mbox <mailto:jane.smith@orange.com> ;
    foaf:member noria-data:AppSupportTeam ;
    noria:agentWorkingHours "10:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for application-specific queries."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-data:JDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "The corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    foaf:holdsAccount noria-data:JohnDoe .

# Locations
noria-data:ParisDataCenter
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Republique"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Republique"^^xsd:string .

noria-data:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace noria-data:ParisDataCenter .

noria-data:RackL6
