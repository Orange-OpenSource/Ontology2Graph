noria:WebServer01 noria:resourceForApplication noria:CustomerPortalApp .

# =============================================================================
# Dynamic Elements (Event Records, Trouble Tickets, Change Requests, Document Attachments)
# =============================================================================

# Event Record
noria:EventRecord_WebServerDown
    a noria:EventRecord ;
    rdfs:label "Web Server 01 Down Event"@en ;
    rdfs:comment "An event indicating that Web Server 01 went down."@en ;
    noria:logOriginatingManagedObject noria:WebServer01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemApp ;
    noria:logOriginatingAgent noria:JohnDoe ; # Could be an automated agent, but for creativity, let's say John manually triggered an alert.
    noria:logText "CRITICAL: Web Server 01 (webserver01.noria.local) is unreachable."^^xsd:string ;
    noria:loggingTime "2024-04-23T14:30:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:RestartWebServerOperationPlan . # Forward reference to an OperationPlan
    # noria:alarmMonitoredAttribute could be added here, e.g., "CPU_Usage=95%"

noria:EventRecord_InterfaceFlap
    a noria:EventRecord ;
    rdfs:label "Interface Flap Event on Core Router 01"@en ;
    rdfs:comment "An event indicating an interface on Core Router 01 flapped."@en ;
    noria:logOriginatingManagedObject noria:CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemApp ;
    noria:logText "WARNING: Interface Eth1 on corerouter01.noria.local flapped."^^xsd:string ;
    noria:loggingTime "2024-04-23T14:25:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# Trouble Ticket
noria:TroubleTicket_001
    a noria:TroubleTicket ;
    rdfs:label "TT-20240423-001: Web Server 01 Unreachable"@en ;
    rdfs:comment "Trouble ticket created due to Web Server 01 being unreachable, impacting Customer Portal."@en ;
    noria:documentExternalId "CUST-INC-9876"^^xsd:string ;
    noria:documentHRef <https://itsm.example.com/ticket/TT-20240423-001>^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_WebServerDown ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network connectivity issue to Web Server 01."^^xsd:string ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T14:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T15:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T15:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T16:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:JohnDoe ;
    noria:troubleTicketRelatedService noria:CustomerPortalProdModule ;
    noria:troubleTicketRelatedResource noria:WebServer01 ;
    noria:troubleTicketImpacts noria:WebServer01, noria:CustomerPortalProdModule .

# Trouble Ticket Note
noria:TroubleTicketNote_001_01
    a noria:TroubleTicketNote ;
    rdfs:label "TT-001 Note 1: Initial Diagnosis"@en ;
    rdfs:comment "Initial diagnosis indicates no local server issue, suspecting network."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:created "2024-04-23T14:35:00Z"^^xsd:dateTime ;
    dcterms:creator noria:JohnDoe ;
    dcterms:description "Checked server logs, no errors. Pinging server from local network fails. Escalating to network team."^^xsd:string .

noria:TroubleTicketNote_001_02
    a noria:TroubleTicketNote ;
    rdfs:label "TT-001 Note 2: Network Team Engaged"@en ;
    rdfs:comment "Network team engaged, investigating link to Core Router 01."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:created "2024-04-23T14:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:JohnDoe ;
    dcterms:description "Network team confirmed link instability on Eth1 of Core Router 01. Initiating change request for port replacement."^^xsd:string .

noria:TroubleTicket_001 dcterms:hasPart noria:TroubleTicketNote_001_01, noria:TroubleTicketNote_001_02 .

# Change Request
noria:ChangeRequest_001
    a noria:ChangeRequest ;
    rdfs:label "CR-20240423-001: Replace Router Port"@en ;
    rdfs:comment "Change request to replace faulty Ethernet port on Core Router 01."@en ;
    noria:documentExternalId "NET-CR-001"^^xsd:string ;
    noria:documentHRef <https://itsm.example.com/change/CR-20240423-001>^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-04-23T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-23T15:30:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-23T15:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-23T15:25:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ; # Example, could be HardwareFailure
    noria:changeRequestImpact noria:CoreRouter01, noria:LinkWebServer01ToRouter01 ;
    noria:changeRequestOutageDuration "PT20M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RoutineMaintenance> ;
    noria:changeRequestInitiatorParty noria:JohnDoe ;
    noria:changeRequestPilotParty noria:JohnDoe ;
    noria:changeRequestActorParty noria:JohnDoe ;
    noria:changeRequestIsRegulated "false"^^xsd:boolean .

noria:TroubleTicket_001 dcterms:relation noria:ChangeRequest_001 . # Link TT to CR

# Document Attachment
noria:NetworkDiagramAttachment
    a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for DC-PAR-01"@en ;
    rdfs:comment "PDF document containing the network topology for Paris Data Center."@en ;
    dcterms:title "DC-PAR-01_Network_Diagram.pdf"^^xsd:string ;
    dcterms:format "application/pdf"^^xsd:string ;
    dcterms:identifier "DOC-NET-001"^^xsd:string .

noria:TroubleTicket_001 dcterms:hasPart noria:NetworkDiagramAttachment .

# =============================================================================
# Procedural Elements (Anomaly Patterns, Operation Plans, Action Pre/Post Conditions)
# =============================================================================

# Anomaly Pattern
noria:NetworkLinkFlapAnomaly
    a noria:AnomalyPattern ;
    rdfs:label "Network Link Flap Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing a network link flapping, characterized by frequent up/down events."@en ;
    folio:hasFailureMode "Intermittent Connectivity"^^xsd:string .

# Operation Plan
noria:RestartWebServerOperationPlan
    a noria:OperationPlan ;
    rdfs:label "Restart Web Server Operation Plan"@en ;
    rdfs:comment "Standard operating procedure for restarting a web server."@en ;
    folio:hasControlMethod "Automated Script"^^xsd:string .

noria:ReplaceRouterPortOperationPlan
    a noria:OperationPlan ;
    rdfs:label "Replace Router Port Operation Plan"@en ;
    rdfs:comment "Procedure for replacing a faulty Ethernet port on a core router."@en ;
    folio:hasControlMethod "Manual Procedure"^^xsd:string .

# Action Pre-Condition
noria:WebServerUnreachablePreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Web Server Unreachable Pre-Condition"@en ;
    rdfs:comment "Condition: Web server is not reachable via network."@en .

noria:RouterPortFaultyPreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Router Port Faulty Pre-Condition"@en ;
    rdfs:comment "Condition: Router interface shows error counters or intermittent connectivity."@en .

noria:ReplaceRouterPortOperationPlan noria:operationPlanPreCondition noria:RouterPortFaultyPreCondition .
noria:RestartWebServerOperationPlan noria:operationPlanPreCondition noria:WebServerUnreachablePreCondition .

# Action Post-Condition
noria:WebServerReachablePostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Web Server Reachable Post-Condition"@en ;
    rdfs:comment "Expected outcome: Web server is reachable and responding to requests."@en .

noria:RouterPortOperationalPostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Router Port Operational Post-Condition"@en ;
    rdfs:comment "Expected outcome: Replaced router interface is stable and error-free."@en .

noria:ReplaceRouterPortOperationPlan noria:operationPlanPostCondition noria:RouterPortOperationalPostCondition .
noria:RestartWebServerOperationPlan noria:operationPlanPostCondition noria:WebServerReachablePostCondition .

# Link EventRecord to AnomalyPattern
noria:EventRecord_InterfaceFlap dcterms:conformsTo noria:NetworkLinkFlapAnomaly .

# Link TroubleTicketNote to ProcedureExecutionContainer (e.g., the ChangeRequest itself)
noria:TroubleTicketNote_001_02 noria:troubleTicketNoteCorrelatedExecution noria:ChangeRequest_001 .

# Link ChangeRequest to OperationPlan
noria:ChangeRequest_001 noria:actionCorrelatedOperationPlan noria:ReplaceRouterPortOperationPlan .

