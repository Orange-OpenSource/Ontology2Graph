# =============================================================================
# Organization related entities
# =============================================================================

# Organizations
noria:OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "A major telecommunications company."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Contact via official channels for all inquiries."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:NetworkOperationsCenter
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "The team responsible for monitoring and managing network infrastructure."@en ;
    org:unitOf noria:OrangeTelecom ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "For critical issues, use hotline. For non-critical, use ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting specific applications."@en ;
    org:unitOf noria:OrangeTelecom ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit tickets via the IT Service Management portal."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

# Agents (Persons)
noria:JohnDoe
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A senior network engineer at Orange Telecom."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:JaneSmith
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Support Leader."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Escalate via team lead first."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

# CorporateUserIdentifier
noria:JohnDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for John Doe within the corporate IT system."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountIdentifier "JD001"^^xsd:string ;
    observable:accountLogin "jdoe@orange.com"^^xsd:string .

noria:JaneSmithCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Jane Smith within the corporate IT system."@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountIdentifier "JS002"^^xsd:string ;
    observable:accountLogin "jsmith@orange.com"^^xsd:string .

noria:JohnDoe foaf:holdsAccount noria:JohnDoeCUid .
noria:JaneSmith foaf:holdsAccount noria:JaneSmithCUid .

# =============================================================================
# Location related entities
# =============================================================================

# Site
noria:DataCenterParis
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

# Room
noria:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace noria:DataCenterParis .

# Locus
noria:RackA1Locus
    a noria:Locus ;
    rdfs:label "Rack A1 Locus"@en ;
    rdfs:comment "Specific location for Rack A1 in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:containsZone noria:ServerRoomA .

# =============================================================================
# Structural Elements (Resources, Network Interfaces, Network Links, Product Models)
# =============================================================================

# Product Model
noria:ServerModelX
    a noria:ProductModel ;
    rdfs:label "Server Model X"@en ;
    rdfs:comment "Product model for a high-performance server."@en ;
    noria:productManufacturedBy noria:OrangeTelecom . # Assuming Orange manufactures some internal models or rebrands.

noria:RouterModelY
    a noria:ProductModel ;
    rdfs:label "Router Model Y"@en ;
    rdfs:comment "Product model for a core network router."@en ;
    noria:productManufacturedBy noria:OrangeTelecom .

# Resources
noria:WebServer01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "A web server hosting critical applications."@en ;
    noria:resourceLogisticId "LOG-WS01-456"^^xsd:string ;
    noria:resourceHostName "webserver01.noria.local"^^xsd:string ;
    noria:resourceProductModel noria:ServerModelX ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WS01-7890"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:RackA1Locus ;
    noria:resourceManagementIPAddress "10.0.0.10"^^observable:IPAddress ;
    noria:resourceManagedBy noria:NetworkOperationsCenter ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

noria:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "A core network router in the data center."@en ;
