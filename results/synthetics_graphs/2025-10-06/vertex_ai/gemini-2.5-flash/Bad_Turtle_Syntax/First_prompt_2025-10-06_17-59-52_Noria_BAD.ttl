# =============================================================================
# Synthetic Knowledge Graph based on NORIA Schema
# =============================================================================

# --- KOS Concepts (for ranges of ObjectProperties) ---

# Agent Contact Method KOS
<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# Application Type KOS
<kos/application/type>
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/type/MonitoringSystem>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring System"@en ;
    rdfs:comment "An application used for monitoring IT infrastructure."@en .

<kos/application/type/TicketingSystem>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Ticketing System"@en ;
    rdfs:comment "An application used for managing support tickets."@en .

<kos/application/type/Database>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Database"@en ;
    rdfs:comment "An application providing database services."@en .

