# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Synthetic Knowledge Graph based on NORIA Schema
# =============================================================================

# --- KOS Concepts Definitions ---
# These are placeholder SKOS concepts to satisfy the ranges of ObjectProperties.

noria:kos/org/agent-contact-method
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

noria:kos/org/agent-contact-method#Email
    a skos:Concept ;
    skos:inScheme noria:kos/org/agent-contact-method ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via email."@en .

noria:kos/org/agent-contact-method#Phone
    a skos:Concept ;
    skos:inScheme noria:kos/org/agent-contact-method ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via phone."@en .

noria:kos/application/type
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

noria:kos/application/type#WebApplication
    a skos:Concept ;
    skos:inScheme noria:kos/application/type ;
    rdfs:label "Web Application"@en ;
    rdfs:comment "An application accessible via a web browser."@en .

noria:kos/application/type#DatabaseService
    a skos:Concept ;
    skos:inScheme noria:kos/application/type ;
    rdfs:label "Database Service"@en ;
    rdfs:comment "A service providing database functionality."@en .

noria:kos/application/business-importance
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

noria:kos/application/business-importance#Critical
    a skos:Concept ;
    skos:inScheme noria:kos/application/business-importance ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical to business operations."@en .

noria:kos/application/business-importance#High
    a skos:Concept ;
    skos:inScheme noria:kos/application/business-importance ;
    rdfs:label "High"@en ;
    rdfs:comment "Application has high business importance."@en .

noria:kos/application/sla-level
    a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying Service Level Agreement levels for applications."@en .

noria:kos/application/sla-level#Gold
    a skos:Concept ;
    skos:inScheme noria:kos/application/sla-level ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "Highest SLA level with maximum availability and performance guarantees."@en .

noria:kos/application/status
    a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

noria:kos/application/status#InProduction
    a skos:Concept ;
    skos:inScheme noria:kos/application/status ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application module is currently in production."@en .

noria:kos/service/type
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

noria:kos/service/type#CustomerFacingService
    a skos:Concept ;
    skos:inScheme noria:kos/service/type ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by customers."@en .

noria:kos/TroubleTicket/severity
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .

noria:kos/TroubleTicket/severity#Major
    a skos:Concept ;
    skos:inScheme noria:kos/TroubleTicket/severity ;
    rdfs:label "Major"@en ;
    rdfs:comment "Major incident affecting multiple users or critical services."@en .

noria:kos/TroubleTicket/type
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of trouble tickets."@en .

noria:kos/TroubleTicket/type#Failure
    a skos:Concept ;
    skos:inScheme noria:kos/TroubleTicket/type ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Ticket related to a system or service failure."@en .

noria:kos/TroubleTicket/category
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Criticity Scheme"@en ;
    rdfs:comment "A scheme for classifying the criticity of trouble tickets from a customer impact perspective."@en .

noria:kos/TroubleTicket/category#InterruptedService
    a skos:Concept ;
    skos:inScheme noria:kos/TroubleTicket/category ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "Service is completely interrupted for customers."@en .

noria:kos/TroubleTicket/priority
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A scheme for classifying the priority of trouble tickets."@en .

noria:kos/TroubleTicket/priority#P1
    a skos:Concept ;
    skos:inScheme noria:kos/TroubleTicket/priority ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate attention required."@en .

noria:kos/TroubleTicket/origin
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

noria:kos/TroubleTicket/origin#Customer
    a skos:Concept ;
    skos:inScheme noria:kos/TroubleTicket/origin ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Ticket originated from a customer report."@en .

noria:kos/TroubleTicket/urgency
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A scheme for classifying the urgency of trouble tickets."@en .

noria:kos/TroubleTicket/urgency#ImmediateIntervention
    a skos:Concept ;
    skos:inScheme noria:kos/TroubleTicket/urgency ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Immediate intervention required to resolve the issue."@en .

noria:kos/TroubleTicket/trouble-category
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the technical impact or nature of the incident."@en .

noria:kos/TroubleTicket/trouble-category#TotalBreakdown
    a skos:Concept ;
    skos:inScheme noria:kos/TroubleTicket/trouble-category ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Complete failure of a system or component."@en .

noria:kos/TroubleTicket/problemResponsibility
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying the final area of responsibility for a problem."@en .

noria:kos/TroubleTicket/problemResponsibility#ManagedBackboneNetworks
    a skos:Concept ;
    skos:inScheme noria:kos/TroubleTicket/problemResponsibility ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility lies with the team managing backbone networks."@en .

noria:kos/TroubleTicket/status
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current activity status of trouble tickets."@en .

noria:kos/TroubleTicket/status#InProgress
    a skos:Concept ;
    skos:inScheme noria:kos/TroubleTicket/status ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Trouble ticket is currently being worked on."@en .

noria:kos/TroubleTicket/commentType
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the provenance type of trouble ticket notes."@en .

noria:kos/TroubleTicket/commentType#Internal
    a skos:Concept ;
    skos:inScheme noria:kos/TroubleTicket/commentType ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team use."@en .

noria:kos/TroubleTicket/operationType
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the operation type of trouble ticket notes."@en .

noria:kos/TroubleTicket/operationType#Diagnosis
    a skos:Concept ;
    skos:inScheme noria:kos/TroubleTicket/operationType ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Note describing diagnostic steps taken."@en .

noria:kos/ChangeRequest/category
    a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the nature of change requests."@en .

noria:kos/ChangeRequest/category#InternalIntervention
    a skos:Concept ;
    skos:inScheme noria:kos/ChangeRequest/category ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request for an internal intervention."@en .

noria:kos/ChangeRequest/type
    a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of change requests based on impact and risk."@en .

noria:kos/ChangeRequest/type#Standard
    a skos:Concept ;
    skos:inScheme noria:kos/ChangeRequest/type ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk and impact."@en .

noria:kos/ChangeRequest/cause
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying the cause or reason for change requests."@en .

noria:kos/ChangeRequest/cause#SoftwareUpgrade
    a skos:Concept ;
    skos:inScheme noria:kos/ChangeRequest/cause ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change requested due to a software upgrade."@en .

noria:kos/ChangeRequest/status
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of change requests."@en .

noria:kos/ChangeRequest/status#Scheduled
    a skos:Concept ;
    skos:inScheme noria:kos/ChangeRequest/status ;
    rdfs:label "Scheduled"@en ;
    rdfs:comment "Change request is scheduled for implementation."@en .

noria:kos/ChangeRequest/specification
    a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    rdfs:comment "A scheme for classifying standard operation plan items for recurring activities."@en .

noria:kos/ChangeRequest/specification#RoutineMaintenance
    a skos:Concept ;
    skos:inScheme noria:kos/ChangeRequest/specification ;
    rdfs:label "Routine Maintenance"@en ;
    rdfs:comment "Standard specification for routine maintenance."@en .

noria:kos/Resource/OperationalState
    a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of resources."@en .

noria:kos/Resource/OperationalState#Up
    a skos:Concept ;
    skos:inScheme noria:kos/Resource/OperationalState ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is operational."@en .

noria:kos/Resource/OperationalState#Down
    a skos:Concept ;
    skos:inScheme noria:kos/Resource/OperationalState ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

noria:kos/Resource/AdministrativeState
    a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of resources."@en .

noria:kos/Resource/AdministrativeState#Enabled
    a skos:Concept ;
    skos:inScheme noria:kos/Resource/AdministrativeState ;
    rdfs:label "Enabled"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

noria:kos/Resource/AdministrativeState#Disabled
    a skos:Concept ;
    skos:inScheme noria:kos/Resource/AdministrativeState ;
    rdfs:label "Disabled"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

noria:kos/Notification/Severity/PerceivedSeverity
    a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the perceived severity of notifications/alarms."@en .

noria:kos/Notification/Severity/PerceivedSeverity#Critical
    a skos:Concept ;
    skos:inScheme noria:kos/Notification/Severity/PerceivedSeverity ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Critical severity alarm."@en .

noria:kos/Notification/Severity/PerceivedSeverity#Warning
    a skos:Concept ;
    skos:inScheme noria:kos/Notification/Severity/PerceivedSeverity ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Warning severity notification."@en .

noria:kos/Resource/type
    a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of network element resources."@en .

noria:kos/Resource/type#WebServer
    a skos:Concept ;
    skos:inScheme noria:kos/Resource/type ;
    rdfs:label "Web Server"@en ;
    rdfs:comment "A server hosting web applications."@en .

noria:kos/Resource/type#Router
    a skos:Concept ;
    skos:inScheme noria:kos/Resource/type ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network device that forwards data packets."@en .

noria:kos/Resource/LifecycleState
    a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying the lifecycle state of resources."@en .

noria:kos/Resource/LifecycleState#InUse
    a skos:Concept ;
    skos:inScheme noria:kos/Resource/LifecycleState ;
    rdfs:label "In Use"@en ;
    rdfs:comment "Resource is currently in active use."@en .

# --- Organizational Entities ---

noria:person/alice
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "A synthetic employee, Alice Smith, who is a lead engineer."@en ;
    foaf:name "Alice Smith"^^xsd:string ;
    foaf:mbox "mailto:alice.smith@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method#Email ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string .

noria:person/bob
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "A synthetic employee, Bob Johnson, who is a network administrator."@en ;
    foaf:name "Bob Johnson"^^xsd:string ;
    foaf:mbox "mailto:bob.johnson@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method#Phone ;
    noria:agentInstructions "Call directly for any network-related issues."^^xsd:string .

noria:org/it-operations
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The department responsible for IT infrastructure and operations."@en ;
    org:unitOf noria:org/example-company ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Follow incident management procedures for contact."^^xsd:string .

noria:org/network-support-team
    a org:OrganizationalUnit ;
    rdfs:label "Network Support Team"@en ;
    rdfs:comment "A team within IT Operations specializing in network infrastructure support."@en ;
    org:unitOf noria:org/it-operations ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method#Phone ;
    noria:agentInstructions "For network issues, open a ticket and call the hotline."^^xsd:string .

noria:org/example-company
    a org:Organization ;
    rdfs:label "Example Corp"@en ;
    rdfs:comment "A fictional company for demonstration purposes."@en .

noria:org/server-admin-team
    a org:OrganizationalUnit ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team responsible for managing server infrastructure."@en ;
    org:unitOf noria:org/it-operations ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method#Email ;
    noria:agentInstructions "Submit requests via ticketing system."^^xsd:string .

noria:org/vendor-acme
    a org:Organization ;
    rdfs:label "ACME Hardware Inc."@en ;
    rdfs:comment "A fictional hardware manufacturer."@en .

# --- Corporate User Identifier ---

noria:cuid/alice-smith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Unique corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "CUID-ASMITH-001"^^xsd:string ;
    foaf:holdsAccount noria:person/alice .

# --- Location Entities ---

noria:site/datacenter-paris
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

noria:room/server-room-a
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace noria:site/datacenter-paris .

noria:locus/rack-a1-u23
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location within Server Room A for a server rack unit."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace noria:room/server-room-a .

# --- Structural Entities ---

noria:productmodel/hp-dl380-gen10
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Product model for a common server type."@en ;
    noria:productManufacturedBy noria:org/vendor-acme .

noria:resource/webserver-01
    a noria:Resource ;
    rdfs:label "WebServer-01"@en ;
    rdfs:comment "A web server resource hosting the customer portal."@en ;
    noria:structuralElementDistinguishedName "WS-01-PROD"^^xsd:string ;
    noria:resourceLogisticId "LOG-WS-01-P"^^xsd:string ;
    noria:resourceHostName "webserver01.example.com"^^xsd:string ;
    noria:resourceProductModel noria:productmodel/hp-dl380-gen10 ;
    noria:resourceType noria:kos/Resource/type#WebServer ;
    noria:resourceSerialNumber "SN123456789"^^xsd:string ;
    noria:resourceUsageState noria:kos/Resource/LifecycleState#InUse ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.10"^^xsd:string ;
    noria:locatedAtLocus noria:locus/rack-a1-u23 ;
    noria:resourceManagedBy noria:org/server-admin-team .

noria:resource/router-core-01
    a noria:Resource ;
    rdfs:label "CoreRouter-01"@en ;
    rdfs:comment "A core network router resource."@en ;
    noria:structuralElementDistinguishedName "CR-01-PAR"^^xsd:string ;
    noria:resourceLogisticId "LOG-CR-01-P"^^xsd:string ;
    noria:resourceHostName "router-core-01.example.com"^^xsd:string ;
    noria:resourceType noria:kos/Resource/type#Router ;
    noria:resourceSerialNumber "SN987654321"^^xsd:string ;
    noria:resourceUsageState noria:kos/Resource/LifecycleState#InUse ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.1"^^xsd:string ;
    noria:locatedAtLocus noria:locus/rack-a1-u23 ;
    noria:resourceManagedBy noria:org/network-support-team .

noria:networkinterface/webserver-01-eth0
    a noria:NetworkInterface ;
    rdfs:label "WebServer-01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface 0 of WebServer-01."@en ;
    noria:networkInterfaceDescription "Primary network interface for web traffic."^^xsd:string ;
