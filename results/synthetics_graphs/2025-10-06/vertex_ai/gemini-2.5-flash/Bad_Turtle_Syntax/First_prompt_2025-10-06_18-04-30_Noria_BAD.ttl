# =============================================================================
# Organization related entities
# =============================================================================

noria-org:OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company."@en ;
    dcterms:identifier "ORG-001"^^xsd:string .

noria-org:NetworkOperationsCenter
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "The team responsible for monitoring and managing the network infrastructure."@en ;
    org:unitOf noria-org:OrangeTelecom ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "For critical network issues, call the hotline immediately."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone .

noria-org:ApplicationSupport
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "The team responsible for supporting business applications."@en ;
    org:unitOf noria-org:OrangeTelecom ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all application issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-agent:AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer at NOC."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    org:memberOf noria-org:NetworkOperationsCenter ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-agent:BobJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Lead."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf noria-org:ApplicationSupport ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone .

noria-agent:CUid_AliceSmith
    a noria:CorporateUserIdentifier ;
