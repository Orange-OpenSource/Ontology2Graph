# =============================================================================
# Dynamic elements (Events, Tickets, Changes)
# =============================================================================

noria-event:Router_Core_01_LinkDown
    a noria:EventRecord ;
    rdfs:label "Router Core 01 Link Down Event"@en ;
    rdfs:comment "An event indicating that a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject noria-resource:Router_Core_01 ;
    noria:logOriginatingManagementSystem noria-app:Monitoring_Platform ;
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Critical ;
    noria:alarmProposedRepairAction noria-op:Router_Interface_Troubleshoot_OP .

noria-event:CRM_Login_Failure
    a noria:EventRecord ;
    rdfs:label "CRM Login Failure Event"@en ;
    rdfs:comment "An event indicating a failed login attempt on the CRM system."@en ;
    noria:loggingTime "2024-04-23T11:30:15Z"^^xsd:dateTime ;
    noria:logText "User 'jdoe' failed to login to CRM_Prod_EU from IP 192.168.1.10"^^xsd:string ;
    noria:logOriginatingManagedObject noria-appmod:CRM_Prod_EU ;
    noria:logOriginatingManagementSystem noria-app:Monitoring_Platform ;
    noria:logOriginatingAgent noria-agent:JohnDoe ; # Assuming JohnDoe is a foaf:Agent
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Warning .

noria-tt:TT_20240423_001
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket for Core Router 01 Link Down"@en ;
    rdfs:comment "Trouble ticket created due to a critical link down event on Core Router 01."@en ;
    noria:documentExternalId "INC-0012345"^^xsd:string ;
    noria:documentHRef <https://itsm.example.com/ticket/INC-0012345> ;
    noria:troubleTicketSeverity noria-kos:TroubleTicket/severity/Critical ;
    noria:troubleTicketType noria-kos:TroubleTicket/type/Incident ;
    noria:troubleTicketCriticity noria-kos:TroubleTicket/category/ServiceInterrupted ;
    noria:troubleTicketPriority noria-kos:TroubleTicket/priority/P1 ;
    noria:troubleTicketOrigin noria-kos:TroubleTicket/origin/MonitoringSystem ;
    noria:troubleTicketTrigger noria-event:Router_Core_01_LinkDown ;
    noria:troubleTicketUrgency noria-kos:TroubleTicket/urgency/Immediate ;
    noria:troubleTicketSupervisionTool "NMS-V1.5"^^xsd:string ;
    noria:troubleTicketCategory noria-kos:TroubleTicket/trouble-category/NetworkOutage ;
    noria:troubleTicketCause "Fiber cut detected on GE0/0/1"^^xsd:string ;
    noria:problemCategory noria-kos:TroubleTicket/trouble-category/NetworkOutage ;
    noria:problemResponsibility noria-kos:TroubleTicket/problemResponsibility/NetworkTeam ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent noria-kos:TroubleTicket/status/InProgress ;
    noria:troubleTicketRelatedParty noria-agent:AliceSmith ;
    noria:troubleTicketRelatedService noria-service:Customer_VPN_Service ;
    noria:troubleTicketRelatedResource noria-resource:Router_Core_01 ;
    noria:troubleTicketImpacts noria-service:Customer_VPN_Service, noria-resource:Router_Core_01 .

noria-ttnote:TT_20240423_001_Note_01
    a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket 001 Note 01 - Initial Diagnosis"@en ;
    rdfs:comment "First note on TT_20240423_001, detailing initial diagnosis steps."@en ;
    dcterms:created "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator noria-agent:AliceSmith ;
    dcterms:description "Confirmed interface GE0/0/1 is down. Initiated remote diagnostics. Suspect fiber issue."^^xsd:string ;
    dcterms:isPartOf noria-tt:TT_20240423_001 ;
    noria:troubleTicketNoteCommentType noria-kos:TroubleTicket/commentType/Internal ;
    noria:troubleTicketNoteOperationType noria-kos:TroubleTicket/operationType/Diagnosis .

noria-ttnote:TT_20240423_001_Note_02
    a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket 001 Note 02 - Resolution Steps"@en ;
    rdfs:comment "Second note on TT_20240423_001, detailing resolution steps."@en ;
    dcterms:created "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    dcterms:creator noria-agent:AliceSmith ;
    dcterms:description "Fiber team dispatched. Link restored after fiber repair. Monitoring for stability."^^xsd:string ;
    dcterms:isPartOf noria-tt:TT_20240423_001 ;
    noria:troubleTicketNoteCommentType noria-kos:TroubleTicket/commentType/CustomerVisible ;
    noria:troubleTicketNoteOperationType noria-kos:TroubleTicket/operationType/Resolution ;
    noria:troubleTicketNoteCorrelatedExecution noria-event:Router_Core_01_LinkUp_Event . # Assuming a 'link up' event is also recorded

noria-event:Router_Core_01_LinkUp_Event
    a noria:EventRecord ;
    rdfs:label "Router Core 01 Link Up Event"@en ;
    rdfs:comment "An event indicating that a network interface on Core Router 01 came up after repair."@en ;
    noria:loggingTime "2024-04-23T11:25:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1, changed state to up"^^xsd:string ;
    noria:logOriginatingManagedObject noria-resource:Router_Core_01 ;
    noria:logOriginatingManagementSystem noria-app:Monitoring_Platform ;
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Warning ; # Warning as it's a state change, not necessarily an alarm
    noria:alarmMitigatedBy noria-tt:TT_20240423_001 . # This event is part of the resolution of the TT

noria-cr:CR_20240425_005
    a noria:ChangeRequest ;
    rdfs:label "Change Request for OS Upgrade on Core Router 01"@en ;
    rdfs:comment "Change request to upgrade the operating system of Core Router 01."@en ;
    noria:documentExternalId "CR-0005678"^^xsd:string ;
    noria:documentHRef <https://itsm.example.com/change/CR-0005678> ;
    noria:changeRequestPlannedStartTime "2024-04-27T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-27T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-27T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-27T03:45:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory noria-kos:ChangeRequest/category/SoftwareUpgrade ;
    noria:changeRequestType noria-kos:ChangeRequest/type/Normal ;
    noria:changeRequestChangeCause noria-kos:ChangeRequest/cause/PerformanceImprovement ;
    noria:changeRequestImpact noria-resource:Router_Core_01 ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ;
    noria:changeRequestStatusCurrent noria-kos:ChangeRequest/status/InProgress ;
    noria:changeRequestSpecification noria-kos:ChangeRequest/specification/StandardOSUpdate ;
    noria:changeRequestInitiatorParty noria-agent:AliceSmith ;
    noria:changeRequestPilotParty noria-agent:AliceSmith ;
    noria:changeRequestActorParty noria-agent:AliceSmith ;
    noria:changeRequestIsRegulated "false"^^xsd:boolean .

noria-doc:CR_20240425_005_Diagram
    a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for CR-0005678"@en ;
    rdfs:comment "Attached network diagram showing the scope of the OS upgrade."@en ;
    dcterms:isPartOf noria-cr:CR_20240425_005 ;
    dcterms:format "application/pdf"^^xsd:string ;
    dcterms:title "Core_Network_Diagram_v2.pdf"^^xsd:string .

# =============================================================================
# Procedural elements
# =============================================================================

noria-op:Router_Interface_Troubleshoot_OP
    a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "A standard operating procedure for diagnosing and resolving router interface issues."@en ;
    noria:operationPlanPreCondition noria-apc:Interface_Status_Down ;
    noria:operationPlanPostCondition noria-apoc:Interface_Status_Up_Traffic_Restored .

noria-apc:Interface_Status_Down
    a noria:ActionPreCondition ;
    rdfs:label "Interface Status Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition: A network interface is reported as being in a 'down' operational state."@en .

noria-apoc:Interface_Status_Up_Traffic_Restored
    a noria:ActionPostCondition ;
    rdfs:label "Interface Status Up and Traffic Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: The network interface is in an 'up' operational state and traffic flow is verified."@en .

noria-anom:High_CPU_Low_Throughput
    a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Throughput Anomaly Pattern"@en ;
    rdfs:comment "An anomaly pattern indicating a potential performance bottleneck or issue where CPU utilization is high but network throughput is unexpectedly low."@en .

