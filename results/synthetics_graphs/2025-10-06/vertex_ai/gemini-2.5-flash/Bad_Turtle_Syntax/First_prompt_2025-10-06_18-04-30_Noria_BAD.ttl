# Example of an alarm monitored attribute (though the range is not explicitly defined as a class in the schema, it's a property of an EventRecord)
# For this, I'll create a dummy resource property to illustrate the concept.
noria-inst:MonitoredAttribute_CPU_Usage
    a noria:StructuralObservable ;
    rdfs:label "CPU Usage Monitored Attribute"@en ;
    rdfs:comment "Represents the CPU usage as a monitored attribute."@en .

noria-event:High_CPU_Alarm
    a noria:EventRecord ;
    rdfs:label "High CPU Usage Alarm"@en ;
    rdfs:comment "An alarm indicating high CPU usage on a server."@en ;
    noria:loggingTime "2024-04-23T15:00:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on app-server-05 exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject noria-resource:App_Server_05 ;
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Major ;
    noria:alarmMonitoredAttribute noria-inst:MonitoredAttribute_CPU_Usage .

# Example of troubleTicketCharacteristic (no specific class for this in schema, so it's an object property to an anonymous class or a concept)
# I'll create a simple concept for this.
noria-kos:TroubleTicket/Characteristic/PerformanceIssue
