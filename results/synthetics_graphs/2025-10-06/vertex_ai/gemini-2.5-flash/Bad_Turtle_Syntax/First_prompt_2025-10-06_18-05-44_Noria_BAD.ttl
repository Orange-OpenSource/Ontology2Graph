    rdfs:label "Email"@en ;
    rdfs:comment "Contact via email."@en .

noria-kos:org/agent-contact-method/Phone
    a skos:Concept ;
    skos:inScheme noria-kos:org/agent-contact-method ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Contact via phone."@en .

