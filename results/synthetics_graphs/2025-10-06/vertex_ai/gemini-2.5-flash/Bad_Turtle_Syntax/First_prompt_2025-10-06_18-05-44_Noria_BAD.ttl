# =============================================================================
# SKOS Concept Schemes and Concepts (Controlled Vocabularies)
# =============================================================================

noria-kos:org/agent-contact-method
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

noria-kos:org/agent-contact-method/Email
    a skos:Concept ;
