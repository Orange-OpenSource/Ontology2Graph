# =============================================================================
# Organizations and Agents
# =============================================================================

noria-data:GlobalTechCorp
    a org:Organization ;
    rdfs:label "GlobalTech Corp"@en ;
    rdfs:comment "A global technology corporation."@en ;
    dcterms:identifier "GTC-001"^^xsd:string .

noria-data:NetworkOperationsCenter
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "The team responsible for monitoring and managing network infrastructure."@en ;
    org:unitOf noria-data:GlobalTechCorp ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone ;
    noria:agentInstructions "Call hotline for critical issues, use ticketing system for others."^^xsd:string .

noria-data:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "The team responsible for supporting critical business applications."@en ;
    org:unitOf noria-data:GlobalTechCorp ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email ;
    noria:agentInstructions "Email for non-urgent requests, open a P1 ticket for outages."^^xsd:string .

noria-data:AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer at GlobalTech Corp."@en ;
    org:memberOf noria-data:NetworkOperationsCenter ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email ;
    noria:agentInstructions "Contact via internal chat for quick questions."^^xsd:string .

noria-data:BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Lead at GlobalTech Corp."@en ;
    org:memberOf noria-data:ApplicationSupportTeam ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone ;
    noria:agentInstructions "Available for urgent calls during working hours."^^xsd:string .

noria-data:AliceSmith-CUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within GlobalTech Corp's IT systems."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountIdentifier "asmith-corp-id-12345"^^xsd:string ;
    foaf:holdsAccount noria-data:AliceSmith .

# =============================================================================
# Locations
# =============================================================================

noria-data:DataCenter-Paris
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris, France."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

noria-data:ServerRoom-A
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace noria-data:DataCenter-Paris .

noria-data:Rack-A1-U1
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 1"@en ;
    rdfs:comment "Specific location within Server Room A for a resource."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:containsZone noria-data:ServerRoom-A .

# =============================================================================
# Product Models
# =============================================================================

noria-data:Cisco-ASR9K-Model
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "Product model for Cisco ASR 9000 series routers."@en ;
    noria:productManufacturedBy noria-data:GlobalTechCorp . # Assuming GlobalTech Corp manufactures it for this example, or I could create a "Cisco Systems" org. Let's create Cisco.

noria-data:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "A multinational technology conglomerate that develops, manufactures, and sells networking hardware."@en .

noria-data:Cisco-ASR9K-Model
    noria:productManufacturedBy noria-data:CiscoSystems .

noria-data:Dell-PowerEdge-R740-Model
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740 Server"@en ;
    rdfs:comment "Product model for Dell PowerEdge R740 rack servers."@en .

noria-data:DellTechnologies
    a org:Organization ;
    rdfs:label "Dell Technologies Inc."@en ;
    rdfs:comment "An American multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria-data:Dell-PowerEdge-R740-Model
    noria:productManufacturedBy noria-data:DellTechnologies .

# =============================================================================
# Resources
# =============================================================================

noria-data:Router-Core-01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router in the Paris Data Center."@en ;
    noria:structuralElementDistinguishedName "router-core-01.gtc.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceHostName "router-core-01"^^xsd:string ;
    noria:resourceProductModel noria-data:Cisco-ASR9K-Model ;
    noria:resourceType noria-kos:Resource/type/Router ;
    noria:resourceSerialNumber "FOC12345678"^^xsd:string ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/Production ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:IPv4Address ; # This should be a literal, not a class.
    observable:ipAddress "10.0.0.1"^^xsd:string ; # Corrected to use observable:ipAddress with a string literal.
    noria:locatedAtLocus noria-data:Rack-A1-U1 ;
    noria:resourceManagedBy noria-data:NetworkOperationsCenter .

noria-data:AppServer-DB01
    a noria:Resource ;
    rdfs:label "Application Database Server 01"@en ;
    rdfs:comment "Database server for the Customer Portal application."@en ;
    noria:structuralElementDistinguishedName "app-db01.gtc.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-SRV-001"^^xsd:string ;
    noria:resourceHostName "app-db01"^^xsd:string ;
    noria:resourceProductModel noria-data:Dell-PowerEdge-R740-Model ;
    noria:resourceType noria-kos:Resource/type/Server ;
    noria:resourceSerialNumber "ABC98765432"^^xsd:string ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/Production ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    observable:ipAddress "192.168.1.10"^^xsd:string ;
    noria:locatedAtLocus noria-data:Rack-A1-U1 ;
    noria:resourceManagedBy noria-data:ApplicationSupportTeam .

noria-data:AppServer-Web01
    a noria:Resource ;
    rdfs:label "Application Web Server 01"@en ;
    rdfs:comment "Web server for the Customer Portal application."@en ;
    noria:structuralElementDistinguishedName "app-web01.gtc.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-SRV-002"^^xsd:string ;
    noria:resourceHostName "app-web01"^^xsd:string ;
    noria:resourceProductModel noria-data:Dell-PowerEdge-R740-Model ;
    noria:resourceType noria-kos:Resource/type/Server ;
    noria:resourceSerialNumber "DEF65432109"^^xsd:string ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/Production ;
    noria:resourceInstallationDate "2023-03-20T14:35:00Z"^^xsd:dateTime ;
    observable:ipAddress "192.168.1.11"^^xsd:string ;
    noria:locatedAtLocus noria-data:Rack-A1-U1 ;
    noria:resourceManagedBy noria-data:ApplicationSupportTeam .

# =============================================================================
# Network Interfaces
# =============================================================================

noria-data:Router-Core-01-GE0-0-1
    a noria:NetworkInterface ;
    rdfs:label "Router Core 01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Network interface GE0/0/1 on Core Router 01."@en ;
    noria:networkInterfaceOf noria-data:Router-Core-01 ;
    noria:networkInterfaceDescription "Uplink to ISP A"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus noria-kos:Resource/AdministrativeState/Enabled ;
    noria:networkInterfaceOperationalStatus noria-kos:Resource/OperationalState/Up ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-3"^^xsd:int ;
