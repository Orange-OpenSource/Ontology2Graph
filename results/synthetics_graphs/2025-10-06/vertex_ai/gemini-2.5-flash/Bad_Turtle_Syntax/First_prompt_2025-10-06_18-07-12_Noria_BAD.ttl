noria-op:RouterRestartProcedure
    a noria:OperationPlan ;
    rdfs:label "Router Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network router."@en ;
    dcterms:identifier "SOP-RTR-001"^^xsd:string .

noria-precond:RouterReachable
    a noria:ActionPreCondition ;
    rdfs:label "Router Reachable Pre-Condition"@en ;
    rdfs:comment "Pre-condition: The router must be reachable via management interface."@en .

noria-postcond:ServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: All affected services must be restored and stable."@en .

noria-op:RouterRestartProcedure
    noria:operationPlanPreCondition noria-precond:RouterReachable ;
    noria:operationPlanPostCondition noria-postcond:ServiceRestored .

noria-anomaly:HighCPULoadPattern
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing a recurring anomaly of high CPU load on servers."@en .

# Linking dynamic elements to procedural elements
noria-event:Alarm_CPU_High
    noria:alarmProposedRepairAction noria-op:RouterRestartProcedure . # Example, assuming a server restart is a proposed action for high CPU.

noria-ttnote:TT2024001_Note1
    noria:troubleTicketNoteCorrelatedExecution noria-event:Log_NI_Down . # Example of correlating a note to an event record.

# Example of an event being mitigated by a procedure execution (represented by another event or a container)
noria-event:InterfaceUpEvent
    a noria:EventRecord ;
    rdfs:label "Network Interface Up Event"@en ;
    rdfs:comment "Log record indicating a network interface came up after intervention."@en ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to up"^^xsd:string ;
    noria:loggingTime "2024-03-15T13:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria-resource:Router01 ;
    noria:logOriginatingManagementSystem noria-app:Monitoring_Platform ;
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Warning . # Severity might be lower as it's a positive change.

noria-tt:TT2024001
    noria:documentStatusHistory noria-event:Log_NI_Down ;
    noria:documentStatusHistory noria-event:InterfaceUpEvent .

noria-event:InterfaceUpEvent
    noria:alarmMitigatedBy noria-tt:TT2024001 . # The TT itself acts as a ProcedureExecutionContainer for the resolution process.

# Example of action correlated operation plan
noria-cr:CR2024005
    noria:actionCorrelatedOperationPlan noria-op:RouterRestartProcedure . # Assuming the upgrade procedure includes a restart.

