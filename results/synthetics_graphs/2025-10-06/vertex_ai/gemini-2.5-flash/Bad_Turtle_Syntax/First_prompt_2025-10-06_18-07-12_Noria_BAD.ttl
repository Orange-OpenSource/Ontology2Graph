# Organization Related Entities
# =============================================================================

noria-org:OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company."@en ;
    dcterms:identifier "ORG-001"^^xsd:string .

noria-org:NOC_Team
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Center Team"@en ;
    rdfs:comment "Team responsible for monitoring and managing network infrastructure."@en ;
    org:unitOf noria-org:OrangeTelecom ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "For critical issues, call the hotline immediately."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone .

noria-org:L2_Support
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Level 2 Support Team"@en ;
    rdfs:comment "Team providing advanced technical support for applications and infrastructure."@en ;
    org:unitOf noria-org:OrangeTelecom ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Escalate from NOC for complex incidents."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-agent:AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "An employee of Orange Telecom, part of the NOC Team."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:member noria-org:NOC_Team ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-agent:BobJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "An employee of Orange Telecom, leading the L2 Support Team."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:member noria-org:L2_Support ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Available for escalations and technical guidance."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone .

noria-cuid:ASmith001
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith's corporate account."@en ;
    foaf:accountName "asmith001"^^xsd:string ;
    observable:accountLogin "asmith001"^^xsd:string ;
    observable:accountIdentifier "CUID-AS001"^^xsd:string ;
    foaf:holdsAccount noria-agent:AliceSmith .

