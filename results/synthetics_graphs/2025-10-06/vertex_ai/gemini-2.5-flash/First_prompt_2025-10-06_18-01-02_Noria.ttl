# --- Dynamic Elements ---

<eventrecord/log_webserver_cpu_spike>
    a noria:EventRecord ;
    rdfs:label "Web Server CPU Spike Log"@en ;
    rdfs:comment "An event record indicating a CPU spike on Web Server 01."@en ;
    noria:logOriginatingManagedObject <resource/web_server_01> ;
    noria:logOriginatingManagementSystem <application/monitoring_dashboard> ;
    noria:logOriginatingAgent <agent/john_doe> ; # Could be a system agent, but for creativity, let's say John configured the alert.
    noria:logText "CPU usage on webserver01.example.com exceeded 90% for 5 minutes."^^xsd:string ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <operationplan/restart_web_service> .

<eventrecord/log_router_interface_down>
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "An event record indicating a network interface on Core Router 01 went down."@en ;
    noria:logOriginatingManagedObject <networkinterface/core_router_01_ge0_0_0> ;
    noria:logOriginatingManagementSystem <application/monitoring_dashboard> ;
    noria:logText "Interface GigabitEthernet0/0/0 on corerouter01.example.com changed state to down."^^xsd:string ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<troubleticket/tt_20240420_001>
    a noria:TroubleTicket ;
    rdfs:label "TT-20240420-001: Web Server CPU High"@en ;
    rdfs:comment "Trouble ticket created due to high CPU usage on the web server impacting customer portal performance."@en ;
    noria:documentExternalId "CUST-REQ-98765"^^xsd:string ;
    noria:documentHRef <https://ticketing.example.com/tt/20240420-001> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <eventrecord/log_webserver_cpu_spike> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Prometheus"^^xsd:string ;
    noria:troubleTicketCause "Unexpected traffic surge and inefficient database queries."^^xsd:string ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <agent/john_doe> ;
    noria:troubleTicketPartyIntervention <org/application_support_team> ;
    noria:troubleTicketRelatedService <application/customer_portal> ;
    noria:troubleTicketRelatedResource <resource/web_server_01> ;
    noria:troubleTicketImpacts <application/customer_portal> ;
    noria:troubleTicketImpacts <resource/web_server_01> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ; # Example, could be Application team
    noria:documentStatusHistory <eventrecord/tt_status_change_inprogress> .

<eventrecord/tt_status_change_inprogress>
    a noria:EventRecord ;
    rdfs:label "TT-20240420-001 Status Change to InProgress"@en ;
    rdfs:comment "Event record for the status change of TT-20240420-001 to InProgress."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Trouble ticket TT-20240420-001 status changed to InProgress."^^xsd:string ;
    dcterms:references <troubleticket/tt_20240420_001> .

<troubleticketnote/tt_20240420_001_note_01>
    a noria:TroubleTicketNote ;
    rdfs:label "TT-20240420-001 Note 01: Initial Diagnosis"@en ;
    rdfs:comment "First note on the trouble ticket, detailing initial diagnosis steps."@en ;
    noria:logText "Initial diagnosis: identified high CPU on webserver01. Investigating database connection pool."^^xsd:string ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution <troubleticket/tt_20240420_001> . # A note is part of the container

<changerequest/cr_20240425_001>
    a noria:ChangeRequest ;
    rdfs:label "CR-20240425-001: Web Server Software Upgrade"@en ;
