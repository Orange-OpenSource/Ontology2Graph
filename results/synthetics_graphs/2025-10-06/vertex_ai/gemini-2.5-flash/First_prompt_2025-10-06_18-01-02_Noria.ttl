    dcterms:isPartOf <changerequest/cr_20240425_001> .

# --- Procedural Elements ---

<operationplan/restart_web_service>
    a noria:OperationPlan ;
    rdfs:label "Restart Web Service Operation Plan"@en ;
    rdfs:comment "A standard operating procedure to restart the web service on a server."@en ;
    noria:operationPlanPreCondition <actionprecondition/web_service_down_check> ;
    noria:operationPlanPostCondition <actionpostcondition/web_service_up_check> .

<actionprecondition/web_service_down_check>
    a noria:ActionPreCondition ;
    rdfs:label "Web Service Down Check"@en ;
    rdfs:comment "Pre-condition: Verify that the web service is indeed down before attempting a restart."@en .

<actionpostcondition/web_service_up_check>
    a noria:ActionPostCondition ;
    rdfs:label "Web Service Up Check"@en ;
    rdfs:comment "Post-condition: Verify that the web service is up and responding after restart."@en .

<anomalypattern/high_cpu_anomaly>
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Anomaly Pattern"@en ;
    rdfs:comment "A pattern describing a high CPU usage anomaly, potentially indicating a performance issue or attack."@en ;
    folio:hasCause "Excessive load or inefficient code execution."^^xsd:string .

# --- Structural Observable ---

<structuralobservable/cpu_usage>
    a noria:StructuralObservable ;
    rdfs:label "CPU Usage Observable"@en ;
    rdfs:comment "An observable property representing the CPU utilization of a resource."@en .

<resource/web_server_01> noria:structuralElementObservable <structuralobservable/cpu_usage> .
<structuralobservable/cpu_usage> noria:structuralObservableOf <resource/web_server_01> .

# --- Linking EventRecord to OperationPlan (using pep:Procedure) ---
# The schema states noria:alarmProposedRepairAction has range pep:Procedure, and noria:OperationPlan is a pep:Procedure.
<eventrecord/log_webserver_cpu_spike> noria:alarmProposedRepairAction <operationplan/restart_web_service> .

# --- Linking EventRecord to ProcedureExecutionContainer (using noria:alarmMitigatedBy) ---
# The schema states noria:alarmMitigatedBy has range pep:ProcedureExecutionContainer, and noria:TroubleTicket is a pep:ProcedureExecutionContainer.
<eventrecord/log_webserver_cpu_spike> noria:alarmMitigatedBy <troubleticket/tt_20240420_001> .

# --- Example of a specific action (EventRecord as a ProcedureExecution) ---
<eventrecord/action_restart_web_service>
    a noria:EventRecord ;
    rdfs:label "Action: Restart Web Service on Web Server 01"@en ;
    rdfs:comment "An event record representing the execution of restarting the web service."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingAgent <agent/john_doe> ;
    noria:logOriginatingManagedObject <resource/web_server_01> ;
    noria:logText "Executed 'systemctl restart apache2' on webserver01.example.com."^^xsd:string ;
    noria:actionCorrelatedOperationPlan <operationplan/restart_web_service> .

# --- Linking TroubleTicketNote to its correlated execution (if any) ---
# The schema states noria:troubleTicketNoteCorrelatedExecution has range pep:ProcedureExecutionContainer.
# A specific action (EventRecord) can be considered a ProcedureExecution, and a TroubleTicket is a ProcedureExecutionContainer.
# For this example, let's link the note to the action that was performed.
<troubleticketnote/tt_20240420_001_note_01> noria:troubleTicketNoteCorrelatedExecution <eventrecord/action_restart_web_service> .

# --- Agent manages resource ---
<agent/jane_smith> noria:agentManagesResource <resource/core_router_01> .
<agent/jane_smith> noria:agentManagesResource <networklink/datacenter_uplink_a> .

