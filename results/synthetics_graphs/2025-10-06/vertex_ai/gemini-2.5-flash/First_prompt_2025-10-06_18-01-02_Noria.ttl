# === SYNTHETIC KNOWLEDGE GRAPH INSTANCES =====================================

# --- Organization related entities ---

<agent/john_doe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A synthetic employee, John Doe, working in the IT department."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:accountName "jdoe"^^xsd:string .

<agent/jane_smith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A synthetic employee, Jane Smith, leading the Network Operations team."@en ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Always use the ticketing system first."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:accountName "jsmith"^^xsd:string .

<org/it_department>
    a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department of the company."@en ;
    org:hasMember <agent/john_doe> ;
    org:hasMember <agent/jane_smith> .

<org/network_operations_team>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "A team within the IT Department responsible for network infrastructure."@en ;
    org:unitOf <org/it_department> ;
    org:hasMember <agent/jane_smith> ;
    org:headOf <agent/jane_smith> .

<org/application_support_team>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "A team within the IT Department responsible for application support."@en ;
    org:unitOf <org/it_department> .

<org/hardware_vendor_inc>
    a org:Organization ;
    rdfs:label "Hardware Vendor Inc."@en ;
    rdfs:comment "A synthetic hardware manufacturing company."@en .

# --- Corporate User Identifier ---

<cuid/jdoe_corp>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe."@en ;
    foaf:accountName "jdoe_corp_login"^^xsd:string ;
    observable:accountLogin "jdoe_corp_login"^^xsd:string ;
    observable:accountIdentifier "CUID-JD-001"^^xsd:string .

<agent/john_doe> foaf:holdsAccount <cuid/jdoe_corp> .

# --- Location related entities ---

<site/main_datacenter>
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "The primary data center facility."@en ;
    noria:siteId "DC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

<room/server_room_a>
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the main data center."@en ;
    bot:hasSpace <site/main_datacenter> .

