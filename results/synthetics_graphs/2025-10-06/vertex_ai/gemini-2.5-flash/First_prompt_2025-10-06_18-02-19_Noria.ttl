# --- Organization related entities ---

<agent/john.doe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee, John Doe, acting as an agent."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    foaf:mbox "mailto:john.doe@example.com"^^xsd:anyURI .

<agent/jane.smith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An employee, Jane Smith, acting as an agent."@en ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Always use the ticketing system first."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    foaf:mbox "mailto:jane.smith@example.com"^^xsd:anyURI .

<org/ITOperations>
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The department responsible for IT operations."@en ;
    org:hasMember <agent/john.doe> .

<org/NetworkTeam>
    a org:OrganizationalUnit ;
    rdfs:label "Network Team"@en ;
    rdfs:comment "The team responsible for network infrastructure."@en ;
    org:hasMember <agent/jane.smith> .

<org/AcmeCorp>
    a org:Organization ;
    rdfs:label "Acme Corp"@en ;
    rdfs:comment "A fictional company."@en ;
    org:hasUnit <org/ITOperations> .

<cuid/john.doe.cuid>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Unique corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "CUID-JD-001"^^xsd:string .

# --- Location related entities ---

<site/datacenter-paris>
    a bot:Site ;
    rdfs:label "Paris Datacenter"@en ;
    rdfs:comment "Main datacenter located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

<room/server-room-a>
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Paris Datacenter."@en ;
    bot:hasSpace <site/datacenter-paris> .

<locus/rack-a1-u1>
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 1"@en ;
    rdfs:comment "Specific location within Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace <room/server-room-a> .

# --- Structural Elements ---

<productmodel/hp-dl380-gen10>
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Product model for a specific HP server."@en ;
    noria:productManufacturedBy <org/AcmeCorp> . # Assuming AcmeCorp manufactures it for this example

<resource/webserver-01>
    a noria:Resource ;
    rdfs:label "WebServer-01"@en ;
    rdfs:comment "A physical server hosting web services."@en ;
    noria:resourceLogisticId "LOG-WS-001"^^xsd:string ;
    noria:resourceHostName "webserver01.example.com"^^xsd:string ;
    noria:resourceSerialNumber "SN-WS-001-XYZ"^^xsd:string ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "192.168.1.10"^^xsd:string ;
    noria:resourceManagedBy <org/ITOperations> ;
    noria:resourceProductModel <productmodel/hp-dl380-gen10> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:locatedAtLocus <locus/rack-a1-u1> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

<resource/router-core-01>
    a noria:Resource ;
    rdfs:label "CoreRouter-01"@en ;
    rdfs:comment "A core network router."@en ;
    noria:resourceLogisticId "LOG-CR-001"^^xsd:string ;
    noria:resourceHostName "core-router01.example.com"^^xsd:string ;
    noria:resourceSerialNumber "SN-CR-001-ABC"^^xsd:string ;
    noria:resourceInstallationDate "2022-05-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.1"^^xsd:string ;
    noria:resourceManagedBy <org/NetworkTeam> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> .

<resource/dbserver-01>
    a noria:Resource ;
    rdfs:label "DBServer-01"@en ;
    rdfs:comment "A database server."@en ;
    noria:resourceLogisticId "LOG-DB-001"^^xsd:string ;
    noria:resourceHostName "dbserver01.example.com"^^xsd:string ;
    noria:resourceSerialNumber "SN-DB-001-DEF"^^xsd:string ;
    noria:resourceInstallationDate "2023-03-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "192.168.1.20"^^xsd:string ;
    noria:resourceManagedBy <org/ITOperations> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> .

<networkinterface/webserver-01-eth0>
    a noria:NetworkInterface ;
    rdfs:label "WebServer-01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for WebServer-01."@en ;
    noria:networkInterfaceDescription "Primary network interface for web traffic."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceOf <resource/webserver-01> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-8"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-7"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

<networkinterface/router-core-01-ge0-0-0>
    a noria:NetworkInterface ;
    rdfs:label "CoreRouter-01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface for CoreRouter-01."@en ;
    noria:networkInterfaceDescription "Uplink to ISP."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceOf <resource/router-core-01> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "50"^^xsd:int .

<networklink/webserver-to-router>
    a noria:NetworkLink ;
    rdfs:label "Link: WebServer-01 to CoreRouter-01"@en ;
    rdfs:comment "Network link connecting WebServer-01 to CoreRouter-01."@en ;
    noria:networkLinkId "NL-WS01-CR01"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin <resource/webserver-01> ;
    noria:networkLinkTerminationResourceDestination <resource/router-core-01> ;
    noria:networkInterfaceConnects <networkinterface/webserver-01-eth0> .

<networkinterface/dbserver-01-eth0>
    a noria:NetworkInterface ;
    rdfs:label "DBServer-01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DBServer-01."@en ;
    noria:networkInterfaceDescription "Primary network interface for database traffic."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceOf <resource/dbserver-01> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networklink/dbserver-to-router>
    a noria:NetworkLink ;
    rdfs:label "Link: DBServer-01 to CoreRouter-01"@en ;
    rdfs:comment "Network link connecting DBServer-01 to CoreRouter-01."@en ;
    noria:networkLinkId "NL-DB01-CR01"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-03-10T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin <resource/dbserver-01> ;
    noria:networkLinkTerminationResourceDestination <resource/router-core-01> .

# --- Functional Elements ---

<application/customer-portal>
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "The main customer-facing web application."@en ;
    noria:applicationModelIdentifier "CP-APP"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CustPortal"^^xsd:string ;
    noria:applicationType <kos/application/type/WebFrontend> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Customer Self-Service"^^xsd:string ;
    noria:elementManagedBy <org/ITOperations> ;
    noria:resourceForApplication <resource/webserver-01> .

<application/billing-service>
    a noria:Application ;
    rdfs:label "Billing Service Application"@en ;
    rdfs:comment "Backend application for billing operations."@en ;
    noria:applicationModelIdentifier "BS-APP"^^xsd:string ;
    noria:applicationNumericalIdentifier "1002"^^xsd:int ;
    noria:applicationShortIdentifier "BillingSvc"^^xsd:string ;
    noria:applicationType <kos/application/type/Database> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Financial Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Invoice Processing"^^xsd:string ;
    noria:elementManagedBy <org/ITOperations> ;
    noria:resourceForApplication <resource/dbserver-01> .

<applicationmodule/customer-portal-prod>
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "Production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf <application/customer-portal> ;
    noria:applicationModuleName "CP-APP_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD"^^xsd:string ;
    noria:applicationModuleAdministrationTeam <org/ITOperations> ;
    noria:applicationModuleAdministrationLeader <agent/john.doe> ;
    noria:applicationModuleSupportTeam <org/ITOperations> ;
    noria:applicationModuleSupportLeader <agent/jane.smith> ;
    noria:applicationModuleSupportGroup <org/NetworkTeam> ;
    noria:applicationModuleHotlineGroup <org/ITOperations> ;
    noria:applicationModuleSlaLevel <kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleStatus <kos/application/status/InProduction> .

<service/e-commerce-platform>
    a noria:Service ;
    rdfs:label "E-commerce Platform Service"@en ;
    rdfs:comment "End-to-end service for online sales, comprising customer portal and billing."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <applicationmodule/customer-portal-prod> . # Example of linking an ApplicationModule to a Service

# --- Dynamic Elements ---

<eventrecord/network-interface-down>
    a noria:EventRecord ;
    rdfs:label "Network Interface Down Event"@en ;
    rdfs:comment "An event indicating a network interface went down."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Interface ge-0/0/0 on core-router01 changed state to down."^^xsd:string ;
    noria:logOriginatingManagedObject <resource/router-core-01> ;
    noria:logOriginatingManagementSystem <application/billing-service> ; # Example: Billing service monitoring system
    noria:logOriginatingAgent <agent/jane.smith> ; # Example: Jane performed a maintenance action
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <operationplan/interface-troubleshooting> ;
    noria:alarmMonitoredAttribute [
        rdfs:label "Interface State" ;
        rdf:value "down"^^xsd:string
    ] ;
    noria:alarmMitigatedBy <troubleticket/tt-2024-001> .

<troubleticket/tt-2024-001>
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket 2024-001: Core Router Interface Down"@en ;
    rdfs:comment "Ticket opened due to critical network interface failure on core router."@en ;
    noria:documentExternalId "EXT-TT-98765"^^xsd:string ;
    noria:documentHRef "https://ticketing.example.com/tt-2024-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <eventrecord/network-interface-down> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Fiber cut suspected"^^xsd:string ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <agent/jane.smith> ;
    noria:troubleTicketPartyIntervention <org/NetworkTeam> ; # Example of linking to an org unit
    noria:troubleTicketRelatedService <service/e-commerce-platform> ;
    noria:troubleTicketRelatedResource <resource/router-core-01> ;
    noria:troubleTicketImpacts <application/customer-portal> ;
    noria:troubleTicketImpacts <application/billing-service> ;
    noria:troubleTicketCharacteristic [
        rdfs:label "Impacted Customer Count" ;
        rdf:value "5000"^^xsd:int
    ] ;
    noria:troubleTicketFreezeItem <eventrecord/tt-freeze-event-001> .

<eventrecord/tt-freeze-event-001>
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Event"@en ;
    rdfs:comment "Event recording a freeze period for TT-2024-001."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Trouble ticket TT-2024-001 frozen for external vendor coordination."^^xsd:string ;
    noria:logOriginatingAgent <agent/john.doe> .

<troubleticketnote/tt-2024-001-note-01>
    a noria:TroubleTicketNote ;
    rdfs:label "TT-2024-001 Note 1: Initial Diagnosis"@en ;
    rdfs:comment "First note on the trouble ticket, detailing initial diagnosis steps."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution <eventrecord/network-interface-down> .

<changerequest/cr-2024-005>
    a noria:ChangeRequest ;
    rdfs:label "Change Request 2024-005: Router Firmware Upgrade"@en ;
    rdfs:comment "Planned firmware upgrade for CoreRouter-01."@en ;
    noria:documentExternalId "EXT-CR-12345"^^xsd:string ;
    noria:documentHRef "https://changemanagement.example.com/cr-2024-005"^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-05-01T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-05-01T02:45:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact <resource/router-core-01> ;
    noria:changeRequestImpact <networkinterface/router-core-01-ge0-0-0> ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RoutineMaintenance> ;
    noria:changeRequestInitiatorParty <agent/john.doe> ;
    noria:changeRequestPilotParty <agent/jane.smith> ;
    noria:changeRequestActorParty <agent/jane.smith> ;
    noria:changeRequestIsRegulated "false"^^xsd:boolean ;
    noria:documentStatusHistory <eventrecord/cr-status-update-001> .

<eventrecord/cr-status-update-001>
    a noria:EventRecord ;
    rdfs:label "CR Status Update Event"@en ;
    rdfs:comment "Event recording a status update for CR-2024-005."@en ;
    noria:loggingTime "2024-05-01T02:45:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-2024-005 status updated to Implemented."^^xsd:string ;
    noria:logOriginatingAgent <agent/jane.smith> .

<documentattachment/router-config-backup>
    a noria:DocumentAttachment ;
    rdfs:label "Router Config Backup CR-2024-005"@en ;
    rdfs:comment "Backup configuration file for CoreRouter-01 before firmware upgrade."@en ;
    dcterms:isPartOf <changerequest/cr-2024-005> ;
    dcterms:format "application/octet-stream"^^xsd:string ;
    dcterms:identifier "router_core_01_config_20240501.bak"^^xsd:string .

# --- Procedural Elements ---

<anomalypattern/high-cpu-usage>
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Usage Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage on a server."@en ;
    folio:hasCause "Software bug or misconfiguration"^^xsd:string .

<operationplan/interface-troubleshooting>
    a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for troubleshooting network interface issues."@en ;
    noria:operationPlanPreCondition <actionprecondition/interface-down-alert> ;
    noria:operationPlanPostCondition <actionpostcondition/interface-up-confirmed> .

<actionprecondition/interface-down-alert>
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Alert Received"@en ;
    rdfs:comment "Pre-condition: A critical alert indicating a network interface is down has been received."@en .

<actionpostcondition/interface-up-confirmed>
    a noria:ActionPostCondition ;
    rdfs:label "Interface Up Confirmed"@en ;
    rdfs:comment "Post-condition: The network interface is confirmed to be operational and traffic is flowing."@en .

<operationplan/firmware-upgrade-procedure>
    a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading router firmware."@en ;
    noria:operationPlanPreCondition <actionprecondition/backup-completed> ;
    noria:operationPlanPostCondition <actionpostcondition/firmware-version-verified> .

<actionprecondition/backup-completed>
    a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup Completed"@en ;
    rdfs:comment "Pre-condition: A full configuration backup of the device has been successfully completed."@en .

<actionpostcondition/firmware-version-verified>
    a noria:ActionPostCondition ;
    rdfs:label "New Firmware Version Verified"@en ;
    rdfs:comment "Post-condition: The device is running the new firmware version and is fully operational."@en .

# Linking EventRecord to OperationPlan via actionCorrelatedOperationPlan
# Assuming EventRecord can represent an action, as it's a pep:ProcedureExecution
<eventrecord/firmware-upgrade-action>
    a noria:EventRecord ;
    rdfs:label "Firmware Upgrade Action Log"@en ;
    rdfs:comment "Log entry for the firmware upgrade action on CoreRouter-01."@en ;
    noria:loggingTime "2024-05-01T02:30:00Z"^^xsd:dateTime ;
    noria:logText "Executed firmware upgrade command on core-router01."^^xsd:string ;
    noria:logOriginatingManagedObject <resource/router-core-01> ;
    noria:logOriginatingAgent <agent/jane.smith> ;
    noria:actionCorrelatedOperationPlan <operationplan/firmware-upgrade-procedure> .

