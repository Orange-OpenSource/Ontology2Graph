# =============================================================================
# Observables (specific instances of properties)
# =============================================================================

# These are typically values of DatatypeProperties or ObjectProperties pointing to SKOS concepts.
# The schema defines classes like noria:StructuralObservable, but these are abstract.
# The actual observables are represented by the DatatypeProperties and ObjectProperties themselves.
# For example, noria:networkInterfaceAdministrativeStatus is an ObjectProperty whose range is a skos:Concept.
# noria:networkInterfaceLaserTxOpticalPower is a DatatypeProperty.
# The instances for these are already created as part of the Resource and NetworkInterface declarations.

# Example of a virtual server status observable (though noria:virtualServerStatus is an ObjectProperty)
noria-data:VirtualServer01
    a noria:Resource ;
    rdfs:label "Virtual Server 01"@en ;
    rdfs:comment "A virtual server instance."@en ;
    noria:resourceHostName "vserver01.noria.example.com"^^xsd:string ;
    noria:resourceType noria-data:VirtualMachineType ;
    noria:virtualServerStatus noria-data:OperationalState_Up .

