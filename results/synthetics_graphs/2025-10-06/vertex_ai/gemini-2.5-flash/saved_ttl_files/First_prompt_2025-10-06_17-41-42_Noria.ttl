# This Turtle file describes a new knowledge graph based on the Noria.ttl schema.
# It adheres to RDF, RDFS, OWL vocabularies and TURTLE syntax.
# All values are properly quoted and typed with xsd:type.
# All prefixes are declared at the beginning.
# Entities are created for all OWL classes, linked by ObjectProperties,
# and have rdfs:label, rdfs:comment, and DatatypeProperty literals.

# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .
@prefix time: <http://www.w3.org/2006/time#> .

@prefix bot: <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix org: <http://www.w3.org/ns/org#> .

@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix saref: <http://ontology.tno.nl/saref#> .

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix noria-data: <https://w3id.org/noria/data/> .
@base <https://w3id.org/noria/data/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- SKOS Concepts for controlled vocabularies ---
# These are used as ranges for many ObjectProperties in the Noria schema.
# I'll define a few example concepts for each scheme mentioned in the schema.

# Agent Contact Method
noria-data:PhoneContact
    a skos:Concept ;
    skos:prefLabel "Phone"@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:comment "Preferred contact method via phone."@en .

noria-data:EmailContact
    a skos:Concept ;
    skos:prefLabel "Email"@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:comment "Preferred contact method via email."@en .

# Application Type
noria-data:ServicePlatform
    a skos:Concept ;
    skos:prefLabel "Service Platform"@en ;
    skos:inScheme <kos/application/type> ;
    rdfs:comment "An application acting as a service platform."@en .

noria-data:InfrastructureApp
    a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en ;
    skos:inScheme <kos/application/type> ;
    rdfs:comment "An application managing infrastructure components."@en .

# Application Business Importance
noria-data:CriticalImportance
    a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:comment "Application is critical for business operations."@en .

noria-data:HighImportance
    a skos:Concept ;
    skos:prefLabel "High"@en ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:comment "Application has high business importance."@en .

# Application Module SLA Level
noria-data:SLA_Level_P1
    a skos:Concept ;
    skos:prefLabel "P1 - Critical"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:comment "SLA Level 1, indicating critical service level."@en .

noria-data:SLA_Level_P2
    a skos:Concept ;
    skos:prefLabel "P2 - High"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:comment "SLA Level 2, indicating high service level."@en .

# Application Module Status
noria-data:InProduction
    a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:comment "Application module is currently in production."@en .

noria-data:InDevelopment
    a skos:Concept ;
    skos:prefLabel "In Development"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:comment "Application module is currently under development."@en .

# Service Type
noria-data:CustomerFacingService
    a skos:Concept ;
    skos:prefLabel "Customer Facing Service"@en ;
    skos:inScheme <kos/service/type> ;
    rdfs:comment "A service directly visible and usable by a customer."@en .

noria-data:ResourceFacingService
    a skos:Concept ;
    skos:prefLabel "Resource Facing Service"@en ;
    skos:inScheme <kos/service/type> ;
    rdfs:comment "A service that supports customer-facing services but is not directly visible to customers."@en .

