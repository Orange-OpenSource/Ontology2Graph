# =============================================================================
# Organization related entities
# =============================================================================

noria-data:OrangeCompany
    a org:Organization ;
    rdfs:label "Orange S.A."@en ;
    rdfs:comment "The main organization, Orange S.A."@en ;
    dcterms:identifier "ORANGE_SA_001"^^xsd:string .

noria-data:NOC_Team
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Team"@en ;
    rdfs:comment "The team responsible for network operations."@en ;
    org:unitOf noria-data:OrangeCompany ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:PhoneContact ;
    noria:agentInstructions "For critical issues, call hotline immediately. For non-critical, use ticketing system."^^xsd:string .

noria-data:DevOps_Team
    a org:OrganizationalUnit ;
    rdfs:label "DevOps Application Team"@en ;
    rdfs:comment "The team responsible for application development and operations."@en ;
    org:unitOf noria-data:OrangeCompany ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:EmailContact ;
    noria:agentInstructions "Submit all requests via Jira service desk."^^xsd:string .

noria-data:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee, John Doe."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    org:memberOf noria-data:NOC_Team .

noria-data:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An employee, Jane Smith."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    org:memberOf noria-data:DevOps_Team .

noria-data:JohnDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "The corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe_login"^^xsd:string ;
    observable:accountLogin "jdoe_login"^^xsd:string ;
    observable:accountIdentifier "CU-JD-001"^^xsd:string .

noria-data:JaneSmithCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "The corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith_login"^^xsd:string ;
    observable:accountLogin "jsmith_login"^^xsd:string ;
    observable:accountIdentifier "CU-JS-002"^^xsd:string .

noria-data:JohnDoe foaf:holdsAccount noria-data:JohnDoeCUid .
noria-data:JaneSmith foaf:holdsAccount noria-data:JaneSmithCUid .

# =============================================================================
# Location related entities
# =============================================================================

noria-data:ParisDataCenter
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "PDC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

noria-data:MarseilleOffice
    a bot:Site ;
    rdfs:label "Marseille Office"@en ;
    rdfs:comment "Regional office in Marseille."@en ;
    noria:siteId "MO-02"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Avenue du Prado"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "13008"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Marseille"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Avenue du Prado"^^xsd:string .

noria-data:ServerRoom1_PDC
    a noria:Room ;
    rdfs:label "Server Room 1 (PDC-01)"@en ;
    rdfs:comment "Server room within the Paris Data Center."@en ;
    bot:hasSpace noria-data:ParisDataCenter .

noria-data:NetworkLab_MO
    a noria:Room ;
    rdfs:label "Network Lab (MO-02)"@en ;
    rdfs:comment "Network laboratory within the Marseille Office."@en ;
    bot:hasSpace noria-data:MarseilleOffice .

noria-data:RackA1_ServerRoom1
    a noria:Locus ;
    rdfs:label "Rack A1 in Server Room 1"@en ;
    rdfs:comment "Specific rack location for equipment."@en ;
    bot:containsZone noria-data:ServerRoom1_PDC ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

noria-data:ShelfB2_NetworkLab
    a noria:Locus ;
    rdfs:label "Shelf B2 in Network Lab"@en ;
    rdfs:comment "Specific shelf location for network devices."@en ;
    bot:containsZone noria-data:NetworkLab_MO ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

# =============================================================================
# Structural Elements
# =============================================================================

noria-data:CiscoProductModel
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Product model for Cisco Catalyst 9300 series switches."@en ;
    noria:productManufacturedBy noria-data:CiscoOrganization .

noria-data:DellProductModel
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Product model for Dell PowerEdge R740 servers."@en ;
    noria:productManufacturedBy noria-data:DellOrganization .

noria-data:CiscoOrganization
    a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

noria-data:DellOrganization
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server equipment."@en .

noria-data:Router01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "A core network router in the Paris Data Center."@en ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceHostName "router01.noria.example.com"^^xsd:string ;
    noria:resourceProductModel noria-data:CiscoProductModel ;
    noria:resourceType noria-data:RouterType ;
    noria:resourceSerialNumber "ABC12345DEF"^^xsd:string ;
    noria:resourceUsageState noria-data:InService ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://192.168.1.1/management> ;
    noria:locatedAtLocus noria-data:RackA1_ServerRoom1 ;
    noria:resourceManagedBy noria-data:NOC_Team .

noria-data:Server05
    a noria:Resource ;
    rdfs:label "Application Server 05"@en ;
    rdfs:comment "A physical server hosting applications."@en ;
    noria:resourceLogisticId "LOG-SRV-005"^^xsd:string ;
    noria:resourceHostName "server05.noria.example.com"^^xsd:string ;
    noria:resourceProductModel noria-data:DellProductModel ;
    noria:resourceType noria-data:ServerType ;
    noria:resourceSerialNumber "GHI67890JKL"^^xsd:string ;
    noria:resourceUsageState noria-data:InService ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://10.0.0.5/management> ;
    noria:locatedAtLocus noria-data:RackA1_ServerRoom1 ;
    noria:resourceManagedBy noria-data:DevOps_Team .

noria-data:VirtualMachine01
    a noria:Resource ;
    rdfs:label "Virtual Machine 01"@en ;
    rdfs:comment "A virtual machine running a microservice."@en ;
    noria:resourceLogisticId "LOG-VM-001"^^xsd:string ;
    noria:resourceHostName "vm01.noria.example.com"^^xsd:string ;
    noria:resourceType noria-data:VirtualMachineType ;
    noria:resourceSerialNumber "VM-XYZ-001"^^xsd:string ;
    noria:resourceUsageState noria-data:InService ;
    noria:resourceInstallationDate "2023-06-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://172.16.0.10/management> ;
    noria:resourceManagedBy noria-data:DevOps_Team ;
    noria:clusterController noria-data:VirtualizationHost01 .

noria-data:VirtualizationHost01
    a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical host for virtual machines."@en ;
    noria:resourceHostName "vhost01.noria.example.com"^^xsd:string ;
    noria:resourceType noria-data:ServerType ;
    noria:resourceUsageState noria-data:InService ;
    noria:resourceManagedBy noria-data:DevOps_Team .

noria-data:Router01_GE0_0_1
    a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet0/0/1"@en ;
