    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical issues, call hotline. For non-critical, use ticketing system."^^xsd:string ;
.

<https://w3id.org/noria/data/org/app-support-team>
