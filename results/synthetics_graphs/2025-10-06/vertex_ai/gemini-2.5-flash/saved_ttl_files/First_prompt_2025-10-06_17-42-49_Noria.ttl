<https://w3id.org/noria/data/pep/server-restart-execution>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Server Restart Execution"@en ;
    rdfs:comment "Container for the execution of the server restart procedure."@en ;
    pep:hasProcedure <https://w3id.org/noria/data/operation-plan/server-restart-procedure> ;
    # Example of a member event within this container
    <http://www.w3.org/ns/ldp#member> <https://w3id.org/noria/data/event/server-restart-command-issued> ;
.

<https://w3id.org/noria/data/event/server-restart-command-issued>
    a noria:EventRecord ;
    rdfs:label "Server Restart Command Issued"@en ;
    rdfs:comment "Event recording the command issued to restart Server-PDC-05."@en ;
    noria:loggingTime "2024-07-26T11:05:00Z"^^xsd:dateTime ;
    noria:logText "Command 'systemctl restart apache2' issued on server-pdc-05 by Bob Johnson."^^xsd:string ;
    noria:logOriginatingAgent <https://w3id.org/noria/data/agent/bob-johnson> ;
    pep:hasCommand "systemctl restart apache2"^^xsd:string ;
    pep:hasSimpleResult "Restart command executed successfully."^^xsd:string ;
.

