# --- Dynamic Elements ---

# Event Record
<https://w3id.org/noria/data/event/router-interface-down>
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Router-PDC-01 went down."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/data/resource/router-pdc-01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/data/app/monitoring-system> ;
    noria:logOriginatingAgent <https://w3id.org/noria/data/agent/alice-smith> ; # Assuming Alice configured the monitoring system
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:loggingTime "2024-07-26T10:30:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/major> ;
    noria:alarmProposedRepairAction <https://w3id.org/noria/data/operation-plan/router-interface-troubleshooting> ;
    noria:alarmMonitoredAttribute "interface_status"^^xsd:string ; # Example of a monitored attribute
.

