# Example of a CorrectiveMaintenanceAction (subclass of pep:ProcedureExecution)
<https://w3id.org/noria/data/action/router-interface-reset>
    a noria:CorrectiveMaintenanceAction ;
    rdfs:label "Router Interface Reset Action"@en ;
    rdfs:comment "An action to reset a router interface."@en ;
    noria:actionCorrelatedOperationPlan <https://w3id.org/noria/data/operation-plan/router-interface-troubleshooting> ;
    pep:madeBy <https://w3id.org/noria/data/agent/alice-smith> ;
    pep:hasCommand "interface GigabitEthernet0/0/1; shutdown; no shutdown"^^xsd:string ;
    pep:hasSimpleResult "Interface reset initiated."^^xsd:string ;
.

# Example of a ChangeAction (subclass of pep:ProcedureExecution)
<https://w3id.org/noria/data/action/firmware-upgrade-execution>
    a noria:ChangeAction ;
    rdfs:label "Firmware Upgrade Execution"@en ;
    rdfs:comment "An action representing the execution of a firmware upgrade."@en ;
    noria:actionCorrelatedOperationPlan <https://w3id.org/noria/data/operation-plan/router-firmware-upgrade-plan> ;
    pep:madeBy <https://w3id.org/noria/data/agent/alice-smith> ;
    pep:hasCommand "install software flash:c9300-universalk9.17.06.03.SPA.bin"^^xsd:string ;
    pep:hasSimpleResult "Firmware upgrade started on Router-PDC-01."^^xsd:string ;
.

