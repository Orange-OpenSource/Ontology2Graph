    rdfs:label "Critical"@en ;
    rdfs:comment "Alarm severity: Critical."@en .

# --- Organizational Entities ---
noria:OrangeCompany
    a org:Organization ;
    rdfs:label "Orange S.A."@en ;
    rdfs:comment "The main organization, Orange S.A."@en ;
    dcterms:identifier "ORANGE_SA"^^xsd:string .

noria:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for IT operations."@en ;
    org:unitOf noria:OrangeCompany ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:concept_Email ;
    noria:agentInstructions "Contact via ticketing system for all issues."^^xsd:string .

noria:NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure."@en ;
    org:unitOf noria:ITOperationsDept ;
    noria:agentWorkingHours "24/7 On-call"^^xsd:string ;
    noria:agentPreferredContactMethod noria:concept_Phone ;
    noria:agentInstructions "For critical issues, call the hotline directly."^^xsd:string .

noria:AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for application support."@en ;
    org:unitOf noria:ITOperationsDept ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:concept_Email ;
    noria:agentInstructions "Submit a ticket via the internal portal."^^xsd:string .

noria:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee, leader of the Network Operations Team."@en ;
    foaf:mbox "mailto:john.doe@example.com"^^xsd:anyURI ;
    foaf:phone "tel:+33123456789"^^xsd:string ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:concept_Email ;
    noria:agentInstructions "For urgent matters, send an SMS."^^xsd:string .

noria:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An employee, member of the Application Support Team."@en ;
    foaf:mbox "mailto:jane.smith@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:concept_Email ;
    noria:agentInstructions "Available on internal chat during working hours."^^xsd:string .

noria:JohnDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "CU-JD-001"^^xsd:string .

noria:JaneSmithCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountLogin "jsmith"^^xsd:string ;
    observable:accountIdentifier "CU-JS-002"^^xsd:string .

noria:JohnDoe foaf:holdsAccount noria:JohnDoeCUid .
noria:JaneSmith foaf:holdsAccount noria:JaneSmithCUid .

# --- Location Entities ---
noria:ParisDataCenter
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

noria:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace noria:ParisDataCenter . # Assuming bot:hasSpace can link a Room to a Site

noria:RackL06
    a noria:Locus ;
    rdfs:label "Rack L06"@en ;
    rdfs:comment "Specific location for a server rack in Server Room A."@en ;
    noria:locusLine "L"^^xsd:string ;
    noria:locusRow "06"^^xsd:string ;
    bot:containsZone noria:ServerRoomA . # Assuming bot:containsZone can link a Locus to a Room

# --- Structural Elements ---
noria:WebServer01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "A physical server hosting the WebPortal application."@en ;
    noria:structuralElementDistinguishedName "webserver01.example.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-WS-001"^^xsd:string ;
    noria:resourceHostName "webserver01"^^xsd:string ;
    noria:resourceSerialNumber "SN-WS-001-XYZ"^^xsd:string ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> ;
    noria:resourceType noria:concept_ResourceType_Server ;
    noria:resourceUsageState noria:concept_ResourceLifecycleState_InProduction ;
    noria:locatedAtLocus noria:RackL06 ;
    noria:resourceManagedBy noria:ITOperationsDept ;
    noria:virtualServerStatus noria:concept_ResourceOperationalState_Up .

noria:CiscoRouterModel
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Product model for Cisco Catalyst 9300 series switches."@en ;
    noria:productManufacturedBy noria:CiscoSystems .

noria:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

noria:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "A core network router."@en ;
    noria:structuralElementDistinguishedName "corerouter01.example.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-CR-001"^^xsd:string ;
    noria:resourceHostName "corerouter01"^^xsd:string ;
    noria:resourceSerialNumber "SN-CR-001-ABC"^^xsd:string ;
    noria:resourceInstallationDate "2022-05-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> ;
    noria:resourceType noria:concept_ResourceType_Server ; # Using Server for simplicity, could define a Router type
    noria:resourceUsageState noria:concept_ResourceLifecycleState_InProduction ;
    noria:locatedAtLocus noria:RackL06 ;
    noria:resourceManagedBy noria:NetworkTeam ;
    noria:resourceProductModel noria:CiscoRouterModel .

noria:WebServer01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Web Server 01"@en ;
    rdfs:comment "Network interface for Web Server 01."@en ;
    noria:networkInterfaceDescription "Main network interface for web traffic."^^xsd:string ;
    noria:networkInterfaceOf noria:WebServer01 ;
    noria:networkInterfaceAdministrativeStatus noria:concept_ResourceAdministrativeState_Up ;
    noria:networkInterfaceOperationalStatus noria:concept_ResourceOperationalState_Up ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceType "physical"^^xsd:string .

noria:CoreRouter01_Gig0_0_1
    a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"@en ;
    rdfs:comment "Uplink network interface for Core Router 01."@en ;
    noria:networkInterfaceDescription "Uplink to ISP."^^xsd:string ;
    noria:networkInterfaceOf noria:CoreRouter01 ;
    noria:networkInterfaceAdministrativeStatus noria:concept_ResourceAdministrativeState_Up ;
    noria:networkInterfaceOperationalStatus noria:concept_ResourceOperationalState_Up ;
    noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "0"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int ;
    noria:networkInterfaceType "physical"^^xsd:string .

noria:UplinkToISP
    a noria:NetworkLink ;
    rdfs:label "Uplink to ISP"@en ;
    rdfs:comment "Network link connecting Core Router 01 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-ISP-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-05-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "fiber optic"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria:CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:ISP_Router ; # Assuming an external ISP router
    noria:resourceManagedBy noria:NetworkTeam .

noria:ISP_Router
    a noria:Resource ;
    rdfs:label "ISP Router"@en ;
    rdfs:comment "External ISP router, termination point for UplinkToISP."@en ;
