    noria:resourceHostName "isp-router"^^xsd:string ;
    noria:resourceType noria:concept_ResourceType_Server . # Placeholder type

noria:WebServer01_Eth0 noria:networkInterfaceConnects noria:InternalLAN .
noria:CoreRouter01_Gig0_0_1 noria:networkInterfaceConnects noria:UplinkToISP .

noria:InternalLAN
    a noria:NetworkLink ;
