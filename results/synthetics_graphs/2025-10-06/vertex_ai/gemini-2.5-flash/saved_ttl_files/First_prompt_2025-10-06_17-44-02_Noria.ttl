# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# New Knowledge Graph based on Noria.ttl schema
# =============================================================================

# --- SKOS Concept Schemes and Concepts for property ranges ---
# These are defined to satisfy the owl:intersectionOf (skos:Concept [owl:onProperty skos:inScheme ; owl:hasValue <kos/...] restrictions.

<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

<kos/application/type>
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/business-importance>
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

<kos/application/sla-level>
    a skos:ConceptScheme ;
    rdfs:label "Application Module SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying Service Level Agreement levels for application modules."@en .

<kos/application/status>
    a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

<kos/service/type>
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

<kos/TroubleTicket/severity>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/type>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of trouble tickets."@en .

<kos/TroubleTicket/category>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Criticity/Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the criticity or category of trouble tickets."@en .

<kos/TroubleTicket/priority>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A scheme for classifying the priority of trouble tickets."@en .

<kos/TroubleTicket/origin>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/urgency>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A scheme for classifying the urgency of trouble tickets."@en .

<kos/TroubleTicket/trouble-category>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the nature or technical impact of an incident."@en .

<kos/TroubleTicket/problemResponsibility>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying the responsibility for a problem."@en .

<kos/TroubleTicket/status>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of trouble tickets."@en .

<kos/TroubleTicket/commentType>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the provenance or disclosure rules of a trouble ticket note comment."@en .

<kos/TroubleTicket/operationType>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the operation type of a trouble ticket note."@en .

<kos/ChangeRequest/category>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the nature of change requests."@en .

<kos/ChangeRequest/type>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of change requests based on impact and risk."@en .

<kos/ChangeRequest/cause>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying the cause or reason for change requests."@en .

<kos/ChangeRequest/status>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of change requests."@en .

<kos/ChangeRequest/specification>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    rdfs:comment "A scheme for classifying standard operation plan items for change requests."@en .

<kos/Resource/OperationalState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of resources."@en .

<kos/Resource/AdministrativeState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of resources."@en .

<kos/Resource/type>
    a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of resources."@en .

<kos/Resource/LifecycleState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying the lifecycle state of resources."@en .

<kos/Notification/EventType/stateChange>
    a skos:ConceptScheme ;
    rdfs:label "Notification Event Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of notification events."@en .

<Notification/Severity/PerceivedSeverity>
    a skos:ConceptScheme ;
    rdfs:label "Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the perceived severity of alarms."@en .

# --- SKOS Concepts instances ---
noria:concept_Phone
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method: Phone."@en .

noria:concept_Email
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method: Email."@en .

noria:concept_ApplicationType_WebPortal
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Web Portal"@en ;
    rdfs:comment "Type of application: Web Portal."@en .

noria:concept_BusinessImportance_High
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High"@en ;
    rdfs:comment "High business importance."@en .

noria:concept_SLA_Gold
    a skos:Concept ;
    skos:inScheme <kos/application/sla-level> ;
    rdfs:label "Gold"@en ;
    rdfs:comment "Gold level Service Level Agreement."@en .

noria:concept_AppModuleStatus_InProduction
    a skos:Concept ;
    skos:inScheme <kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application module is currently in production."@en .

noria:concept_ServiceType_CustomerFacing
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "Service directly visible and usable by a customer."@en .

noria:concept_TTSeverity_Major
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Major severity trouble ticket."@en .

noria:concept_TTType_Failure
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Trouble ticket type: Failure."@en .

noria:concept_TTCriticity_CorruptedService
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Corrupted Service"@en ;
    rdfs:comment "Criticity: Corrupted Service."@en .

noria:concept_TTPriority_P1
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "P1"@en ;
    rdfs:comment "Priority 1 trouble ticket."@en .

noria:concept_TTOrigin_Supervision
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision"@en ;
    rdfs:comment "Trouble ticket originated from supervision system."@en .

noria:concept_TTUrgency_Immediate
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Immediate intervention required."@en .

noria:concept_TTTroubleCategory_TotalBreakdown
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Trouble category: Total Breakdown."@en .

noria:concept_TTProblemResponsibility_ManagedBackbone
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Problem responsibility: Managed Backbone Networks."@en .

noria:concept_TTStatus_InProgress
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Trouble ticket status: In Progress."@en .

noria:concept_TTNoteCommentType_Internal
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal"@en ;
    rdfs:comment "Internal comment type for trouble ticket note."@en .

noria:concept_TTNoteOperationType_Diagnosis
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Operation type for trouble ticket note: Diagnosis."@en .

noria:concept_CRCategory_InternalIntervention
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request category: Internal Intervention."@en .

noria:concept_CRType_Standard
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Change request type: Standard Change."@en .

noria:concept_CRCause_SoftwareUpgrade
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change request cause: Software Upgrade."@en .

noria:concept_CRStatus_Approved
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "Change request status: Approved."@en .

noria:concept_CRSpecification_PatchDeployment
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Patch Deployment"@en ;
    rdfs:comment "Change request specification: Patch Deployment."@en .

noria:concept_ResourceOperationalState_Up
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource operational state: Up."@en .

noria:concept_ResourceAdministrativeState_Up
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource administrative state: Up."@en .

noria:concept_ResourceType_Server
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "Type of resource: Server."@en .

noria:concept_ResourceLifecycleState_InProduction
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Resource lifecycle state: In Production."@en .

noria:concept_EventType_StateChange
    a skos:Concept ;
    skos:inScheme <kos/Notification/EventType/stateChange> ;
    rdfs:label "State Change"@en ;
