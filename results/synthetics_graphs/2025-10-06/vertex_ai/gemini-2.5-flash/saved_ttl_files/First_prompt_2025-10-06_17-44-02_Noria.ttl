    noria:applicationModuleHotlineGroup noria:NetworkTeam ; # Example of a hotline group
    noria:applicationModuleSlaLevel noria:concept_SLA_Gold ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleStatus noria:concept_AppModuleStatus_InProduction .

noria:WebServer01 noria:resourceForApplication noria:WebPortalApp .

noria:CustomerFacingService
    a noria:Service ;
    rdfs:label "Customer Web Access Service"@en ;
    rdfs:comment "End-to-end service for customer access to the web portal."@en ;
    noria:functionalElementDistinguishedName "customer-web-access-service"^^xsd:string ;
    noria:serviceType noria:concept_ServiceType_CustomerFacing ;
    seas:subSystemOf noria:WebPortalProdModule . # A service can be composed of application modules

# --- Dynamic Elements (Documentation & Events) ---
noria:ServerDownEvent
    a noria:EventRecord ;
    rdfs:label "Web Server 01 Down Alert"@en ;
    rdfs:comment "An event record indicating that Web Server 01 is down."@en ;
