    rdfs:comment "Trouble ticket opened for the Web Portal production outage."@en ;
    dcterms:identifier "TT-WP-001"^^xsd:string ;
    dcterms:created "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    dcterms:title "Web Portal Production Outage"^^xsd:string ;
    dcterms:description "The corporate web portal is currently inaccessible to users."^^xsd:string ;
    noria:documentExternalId "CUST-INC-54321"^^xsd:string ;
    noria:documentHRef <http://itsm.example.com/ticket/TT-WP-001> ;
    noria:troubleTicketSeverity noria:concept_TTSeverity_Major ;
    noria:troubleTicketType noria:concept_TTType_Failure ;
    noria:troubleTicketCriticity noria:concept_TTCriticity_CorruptedService ;
    noria:troubleTicketPriority noria:concept_TTPriority_P1 ;
    noria:troubleTicketOrigin noria:concept_TTOrigin_Supervision ;
    noria:troubleTicketTrigger noria:ServerDownEvent ;
    noria:troubleTicketUrgency noria:concept_TTUrgency_Immediate ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory noria:concept_TTTroubleCategory_TotalBreakdown ;
    noria:problemCategory noria:concept_TTTroubleCategory_TotalBreakdown ;
    noria:troubleTicketCause "Web server unresponsive due to unknown process crash."^^xsd:string ;
    noria:problemResponsibility noria:concept_TTProblemResponsibility_ManagedBackbone ; # Example, could be AppSupport
    noria:troubleTicketDetectionDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent noria:concept_TTStatus_InProgress ;
    noria:troubleTicketRelatedParty noria:AppSupportTeam ;
    noria:troubleTicketRelatedParty noria:NetworkTeam ;
    noria:troubleTicketRelatedService noria:WebPortalProdModule ;
    noria:troubleTicketRelatedResource noria:WebServer01 ;
    noria:troubleTicketImpacts noria:WebPortalProdModule ;
    noria:troubleTicketImpacts noria:WebServer01 ;
    noria:documentStatusHistory noria:TT_StatusChange_Initialised ;
    noria:documentStatusHistory noria:TT_StatusChange_InProgress .

noria:TT_StatusChange_Initialised
    a noria:EventRecord ;
    rdfs:label "TT-WP-001 Status: Initialised"@en ;
    rdfs:comment "Event record for initial status of TT-WP-001."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "Trouble ticket TT-WP-001 created with status Initialised."^^xsd:string ;
    dcterms:type noria:concept_EventType_StateChange .

noria:TT_StatusChange_InProgress
    a noria:EventRecord ;
    rdfs:label "TT-WP-001 Status: In Progress"@en ;
    rdfs:comment "Event record for status change of TT-WP-001 to In Progress."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Trouble ticket TT-WP-001 status changed to In Progress by Jane Smith."^^xsd:string ;
    noria:logOriginatingAgent noria:JaneSmith ;
    dcterms:type noria:concept_EventType_StateChange .

noria:TroubleTicketNote_WP_001_1
    a noria:TroubleTicketNote ;
    rdfs:label "TT-WP-001 Note 1: Initial Diagnosis"@en ;
    rdfs:comment "First note on Trouble Ticket TT-WP-001, detailing initial diagnosis."@en ;
    dcterms:created "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator noria:JaneSmith ;
    dcterms:description "Initial checks show web server process is not running. Attempting restart."^^xsd:string ;
    noria:troubleTicketNoteCommentType noria:concept_TTNoteCommentType_Internal ;
    noria:troubleTicketNoteOperationType noria:concept_TTNoteOperationType_Diagnosis .

noria:TroubleTicketNote_WP_001_2
    a noria:TroubleTicketNote ;
    rdfs:label "TT-WP-001 Note 2: Restart Attempt"@en ;
    rdfs:comment "Second note on Trouble Ticket TT-WP-001, detailing restart attempt."@en ;
    dcterms:created "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    dcterms:creator noria:JaneSmith ;
    dcterms:description "Restart of web server process failed. Logs indicate segmentation fault. Escalating to L3."^^xsd:string ;
    noria:troubleTicketNoteCommentType noria:concept_TTNoteCommentType_Internal ;
    noria:troubleTicketNoteOperationType noria:concept_TTNoteOperationType_Diagnosis ;
    noria:troubleTicketNoteCorrelatedExecution noria:WebServerRestartAttempt .

noria:WebServerRestartAttempt
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Web Server Restart Attempt Execution"@en ;
    rdfs:comment "Container for events related to the web server restart attempt."@en ;
    dcterms:identifier "PEC-WS-RESTART-001"^^xsd:string .

noria:RestartCommandEvent
    a noria:EventRecord ;
    rdfs:label "Restart Command Issued"@en ;
    rdfs:comment "Event record for the command issued to restart the web server."@en ;
    noria:loggingTime "2024-04-23T10:18:00Z"^^xsd:dateTime ;
    noria:logText "Command 'systemctl restart apache2' issued on webserver01."^^xsd:string ;
    noria:logOriginatingAgent noria:JaneSmith ;
    noria:logOriginatingManagedObject noria:WebServer01 ;
    pep:hasCommand "systemctl restart apache2"^^xsd:string ;
    pep:hasSimpleResult "Restart failed: segmentation fault"^^xsd:string ;
    pep:member noria:WebServerRestartAttempt .

noria:ChangeRequest_WP_001
    a noria:ChangeRequest ;
