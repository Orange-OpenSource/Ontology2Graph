    noria:logText "CRITICAL: Web Server 01 (webserver01.example.com) is unreachable."^^xsd:string ;
    noria:logOriginatingManagedObject noria:WebServer01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:alarmSeverity noria:concept_AlarmSeverity_Critical .

noria:MonitoringSystem
    a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Application responsible for monitoring IT infrastructure."@en ;
    noria:applicationShortIdentifier "CMS"^^xsd:string .

