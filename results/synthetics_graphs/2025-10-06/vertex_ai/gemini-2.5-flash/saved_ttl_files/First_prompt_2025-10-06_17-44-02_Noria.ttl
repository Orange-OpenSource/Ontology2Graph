    noria:networkLinkInstallationDate "2023-01-10T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "ethernet"^^xsd:string ;
    noria:networkLinkTerminationResource noria:WebServer01 ;
    noria:networkLinkTerminationResource noria:CoreRouter01 ;
