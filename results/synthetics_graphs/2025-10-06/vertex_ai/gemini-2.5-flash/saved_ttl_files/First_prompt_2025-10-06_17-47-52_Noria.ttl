    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "The production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf <application/CustomerPortal> ;
    noria:applicationModuleName "CustPortal_Prod"^^xsd:string ;
    noria:applicationModuleIdentifier "CP-PROD-001"^^xsd:string ;
    noria:applicationModuleAdministrationTeam <organizationalUnit/NetworkOperationsCenter> ;
    noria:applicationModuleAdministrationLeader <person/BobJohnson> ;
    noria:applicationModuleSupportTeam <organizationalUnit/NetworkOperationsCenter> ;
    noria:applicationModuleSupportLeader <person/BobJohnson> ;
    noria:applicationModuleSupportGroup <organizationalUnit/NetworkOperationsCenter> ;
    noria:applicationModuleHotlineGroup <organizationalUnit/NetworkOperationsCenter> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-15T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
.

<service/InternetAccessService>
    a noria:Service ;
    rdfs:label "High-Speed Internet Access Service"@en ;
    rdfs:comment "An end-to-end service providing internet connectivity to customers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <applicationModule/CustomerPortal_Prod> ; # Example of linking a service to an application module
    noria:elementManagedBy <organizationalUnit/NetworkOperationsCenter> ;
.

# --- Location related ---

<site/MainDataCenter>
