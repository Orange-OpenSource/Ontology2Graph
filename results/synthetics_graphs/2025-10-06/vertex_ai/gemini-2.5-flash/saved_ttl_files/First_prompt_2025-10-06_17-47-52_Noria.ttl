# This Turtle file describes a new knowledge graph based on the Noria.ttl schema.
# It respects RDF, RDFS, OWL vocabularies and TURTLE syntax.
# All xsd:type values are correctly quoted.
# All prefixes are declared at the beginning.
# Entities are created for all OWL classes, linked by ObjectProperties,
# and have rdfs:label, rdfs:comment, and DatatypeProperty literals.

# --- Basic Prefixes ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management Prefixes ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific Prefixes ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix saref: <http://ontology.tno.nl/saref#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix devopsprod: <http://w3id.org/devops-infra/product#> .

# --- NORIA Prefix and Base URI for instances ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/data/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Organization and Agents ---

<organization/OrangeTelecom>
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company, Orange Telecom."@en ;
    dcterms:identifier "ORG-OT-001"^^xsd:string ;
    org:hasUnit <organizationalUnit/NetworkOperationsCenter> ;
    org:hasMember <person/AliceSmith> ;
.

<organizationalUnit/NetworkOperationsCenter>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "The unit responsible for monitoring and managing the network infrastructure."@en ;
    dcterms:identifier "OU-NOC-001"^^xsd:string ;
    org:unitOf <organization/OrangeTelecom> ;
    org:hasMember <person/BobJohnson> ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical issues, call the hotline immediately. For non-critical, use ticketing system."^^xsd:string ;
.

<person/AliceSmith>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "A key employee at Orange Telecom."@en ;
    foaf:name "Alice Smith"^^xsd:string ;
    foaf:mbox "mailto:alice.smith@example.com"^^xsd:anyURI ;
    foaf:holdsAccount <corporateUserIdentifier/ASmith> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for routine matters."^^xsd:string ;
.

<person/BobJohnson>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Team lead for the Network Operations Center."@en ;
    foaf:name "Bob Johnson"^^xsd:string ;
    foaf:mbox "mailto:bob.johnson@example.com"^^xsd:anyURI ;
    foaf:holdsAccount <corporateUserIdentifier/BJohnson> ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Available on call for urgent network issues."^^xsd:string ;
.

<corporateUserIdentifier/ASmith>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within the organization's IT systems."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "CUid-ASmith-001"^^xsd:string ;
.

<corporateUserIdentifier/BJohnson>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Bob Johnson within the organization's IT systems."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "CUid-BJohnson-001"^^xsd:string ;
.

# --- Applications and Services ---

<application/CustomerPortal>
