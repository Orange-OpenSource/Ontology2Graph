.

# --- Dynamic Elements (Events, Tickets, Changes) ---

<eventRecord/Log_WebServer01_CPU_High>
    a noria:EventRecord ;
    rdfs:label "Log: WebServer01 CPU High Alert"@en ;
    rdfs:comment "An event record indicating high CPU utilization on WebServer01."@en ;
    noria:loggingTime "2024-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on webserver01.example.com exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject <resource/WebServer01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmMonitoredAttribute "CPU_Usage"^^xsd:string ; # This property is an ObjectProperty in schema, but its range is not defined as a class. Assuming it can be a literal for this example.
    # If noria:alarmMonitoredAttribute is intended to link to a class, a new class for "MonitoredAttribute" would be needed.
    # For now, I'll treat it as a literal as per the comment in the schema "This parameter is a set of possibilities specified by the object class definer."
    # Re-reading the schema, it says "defines one or more attributes of the managed object and their corresponding values at the time of the alarm."
    # This implies it should link to a property instance, not a literal. Let's create a dummy StructuralObservable for it.
    noria:alarmMonitoredAttribute <structuralObservable/CPUUsage> ;
.

<structuralObservable/CPUUsage>
    a noria:StructuralObservable ;
    rdfs:label "CPU Usage Observable"@en ;
    rdfs:comment "An observable property representing CPU utilization."@en ;
.

<application/MonitoringSystem>
    a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Application responsible for collecting and analyzing system metrics and logs."@en ;
    noria:applicationShortIdentifier "CMS"^^xsd:string ;
    noria:applicationType <kos/application/type/InfrastructureManagement> ;
    noria:elementManagedBy <organizationalUnit/NetworkOperationsCenter> ;
.

<troubleTicket/TT-2024-001>
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket for WebServer01 CPU Alert"@en ;
    rdfs:comment "Ticket opened due to high CPU on WebServer01 impacting Customer Portal performance."@en ;
    dcterms:identifier "TT-2024-001"^^xsd:string ;
    dcterms:created "2024-01-20T14:35:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-01-20T15:00:00Z"^^xsd:dateTime ;
    dcterms:title "High CPU on WebServer01"^^xsd:string ;
    dcterms:description "WebServer01 experiencing sustained high CPU, affecting Customer Portal responsiveness."^^xsd:string ;
    noria:documentExternalId "CUST-REQ-5544"^^xsd:string ;
    noria:documentHRef "https://ticketing.example.com/TT-2024-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <eventRecord/Log_WebServer01_CPU_High> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Prometheus"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/SoftwareBug> ;
    noria:troubleTicketCause "Misconfigured application causing CPU spike."^^xsd:string ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-01-20T14:25:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-01-20T16:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-01-20T15:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-01-20T17:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <person/BobJohnson> ;
    noria:troubleTicketRelatedService <service/InternetAccessService> ;
    noria:troubleTicketRelatedResource <resource/WebServer01> ;
    noria:troubleTicketImpacts <application/CustomerPortal> ;
    noria:troubleTicketImpacts <resource/WebServer01> ;
    noria:documentStatusHistory <eventRecord/StatusChange_TT-2024-001_InProgress> ;
    noria:troubleTicketFreezeItem <eventRecord/FreezePeriod_TT-2024-001_Maintenance> ;
.

<eventRecord/StatusChange_TT-2024-001_InProgress>
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket TT-2024-001 Status Change to InProgress"@en ;
    rdfs:comment "Log entry for status change of TT-2024-001."@en ;
    noria:loggingTime "2024-01-20T14:40:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-2024-001 status changed to InProgress."^^xsd:string ;
    noria:logOriginatingManagementSystem <application/TicketingSystem> ;
    noria:logOriginatingAgent <person/BobJohnson> ;
.

<eventRecord/FreezePeriod_TT-2024-001_Maintenance>
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket TT-2024-001 Freeze Period for Maintenance"@en ;
