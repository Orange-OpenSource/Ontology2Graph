<troubleTicketNote/TT-2024-001_Note1>
    a noria:TroubleTicketNote ;
    rdfs:label "Note for TT-2024-001: Initial Diagnosis"@en ;
    rdfs:comment "First note on the trouble ticket, detailing initial diagnosis steps."@en ;
    dcterms:created "2024-01-20T14:45:00Z"^^xsd:dateTime ;
    dcterms:creator <person/BobJohnson> ;
    dcterms:description "Initial diagnosis shows high CPU on WebServer01. Suspect application misconfiguration. Escalating to L2 support."^^xsd:string ;
