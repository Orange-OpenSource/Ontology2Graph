    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string ;
.

<room/ServerRoomA>
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A specific server room within the Main Data Center."@en ;
    bot:hasSpace <site/MainDataCenter> ; # Assuming bot:hasSpace can link a room to a site
.

<locus/RackA1_U23>
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location within Server Room A for a server rack unit."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "23"^^xsd:string ;
    bot:containsZone <room/ServerRoomA> ; # Assuming bot:containsZone can link a locus to a room
.

