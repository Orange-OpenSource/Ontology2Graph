    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution <pepExecutionContainer/WebServer01_Diag> ;
.

<pepExecutionContainer/WebServer01_Diag>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution Container for WebServer01 Diagnosis"@en ;
    rdfs:comment "Container for all actions taken during the diagnosis of WebServer01."@en ;
    pep:hasMember <eventRecord/CLI_CheckCPU> ;
.

<eventRecord/CLI_CheckCPU>
    a noria:EventRecord ;
    rdfs:label "CLI Command: Check CPU on WebServer01"@en ;
    rdfs:comment "Log of a CLI command executed to check CPU usage on WebServer01."@en ;
    noria:loggingTime "2024-01-20T14:42:00Z"^^xsd:dateTime ;
    noria:logText "Executed 'top' command on webserver01. Output shows process 'app_service' consuming 85% CPU."^^xsd:string ;
    noria:logOriginatingManagedObject <resource/WebServer01> ;
    noria:logOriginatingAgent <person/BobJohnson> ;
    pep:hasCommand "ssh webserver01 'top -bn1'"^^xsd:string ;
    pep:hasSimpleResult "CPU: 85% app_service"^^xsd:string ;
.

<changeRequest/CR-2024-001>
    a noria:ChangeRequest ;
    rdfs:label "Change Request: Optimize Customer Portal Application"@en ;
    rdfs:comment "Request to optimize the Customer Portal application to reduce CPU usage."@en ;
    dcterms:identifier "CR-2024-001"^^xsd:string ;
    dcterms:created "2024-01-21T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-01-21T10:00:00Z"^^xsd:dateTime ;
    dcterms:description "Application team to review and optimize the 'app_service' component of the Customer Portal to prevent future high CPU incidents."^^xsd:string ;
    noria:documentExternalId "APP-OPT-001"^^xsd:string ;
    noria:documentHRef "https://changemanagement.example.com/CR-2024-001"^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-01-25T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-01-25T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-01-25T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-01-25T03:45:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/StandardChange> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact <application/CustomerPortal> ;
    noria:changeRequestImpact <applicationModule/CustomerPortal_Prod> ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ; # 1 hour 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/AppOptimizationProcedure> ;
    noria:changeRequestInitiatorParty <person/AliceSmith> ;
    noria:changeRequestPilotParty <person/BobJohnson> ;
    noria:changeRequestActorParty <person/AliceSmith> ;
    noria:changeRequestIsRegulated "false"^^xsd:boolean ;
    noria:documentStatusHistory <eventRecord/StatusChange_CR-2024-001_Implemented> ;
.

<eventRecord/StatusChange_CR-2024-001_Implemented>
    a noria:EventRecord ;
    rdfs:label "Change Request CR-2024-001 Status Change to Implemented"@en ;
    rdfs:comment "Log entry for status change of CR-2024-001."@en ;
    noria:loggingTime "2024-01-25T03:45:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-2024-001 status changed to Implemented."^^xsd:string ;
    noria:logOriginatingManagementSystem <application/ChangeManagementSystem> ;
    noria:logOriginatingAgent <person/AliceSmith> ;
.

<application/ChangeManagementSystem>
    a noria:Application ;
    rdfs:label "Change Management System"@en ;
    rdfs:comment "Application used for managing changes in the IT infrastructure."@en ;
    noria:applicationShortIdentifier "CMS"^^xsd:string ;
    noria:applicationType <kos/application/type/ITSM> ;
    noria:elementManagedBy <organization/OrangeTelecom> ;
.

<documentAttachment/CR-2024-001_Plan>
    a noria:DocumentAttachment ;
    rdfs:label "CR-2024-001 Implementation Plan"@en ;
    rdfs:comment "Attachment containing the detailed plan for CR-2024-001."@en ;
    dcterms:title "Implementation Plan for CR-2024-001"^^xsd:string ;
    dcterms:format "application/pdf"^^xsd:string ;
    dcterms:isPartOf <changeRequest/CR-2024-001> ;
.

# --- Procedural Elements ---

<anomalyPattern/HighCPUAnomaly>
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Anomaly Pattern"@en ;
    rdfs:comment "A pattern describing conditions that indicate a high CPU anomaly."@en ;
    folio:hasFailureModeType "Performance Degradation"^^xsd:string ;
.

<operationPlan/AppOptimizationProcedure>
    a noria:OperationPlan ;
    rdfs:label "Application Optimization Procedure"@en ;
    rdfs:comment "A standardized procedure for optimizing application performance."@en ;
    noria:operationPlanPreCondition <actionPreCondition/HighCPUDetected> ;
    noria:operationPlanPostCondition <actionPostCondition/CPUUsageNormalized> ;
    pep:hasInput "Application logs, performance metrics"^^xsd:string ;
    pep:hasOutput "Optimized application configuration"^^xsd:string ;
    BBO:has_activationCondition "High CPU alert triggered"^^xsd:string ;
    BBO:has_completionCondition "CPU usage below 50% for 30 minutes"^^xsd:string ;
.

<actionPreCondition/HighCPUDetected>
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Detected Pre-Condition"@en ;
    rdfs:comment "Condition: CPU utilization on a critical server exceeds 80% for 10 minutes."@en ;
.

<actionPostCondition/CPUUsageNormalized>
    a noria:ActionPostCondition ;
    rdfs:label "CPU Usage Normalized Post-Condition"@en ;
    rdfs:comment "Outcome: CPU utilization on the affected server is below 50% for at least 30 minutes."@en ;
.

<correctiveMaintenanceAction/AppRestart>
    a pep:CorrectiveMaintenanceAction ;
    rdfs:label "Application Restart Action"@en ;
    rdfs:comment "An action to restart the application service."@en ;
    noria:actionCorrelatedOperationPlan <operationPlan/AppRestartProcedure> ;
.

<operationPlan/AppRestartProcedure>
    a noria:OperationPlan ;
    rdfs:label "Application Restart Procedure"@en ;
    rdfs:comment "Standard procedure for restarting an application service."@en ;
.

<changeAction/AppConfigUpdate>
    a pep:ChangeAction ;
    rdfs:label "Application Configuration Update Action"@en ;
    rdfs:comment "An action to update the application configuration."@en ;
    noria:actionCorrelatedOperationPlan <operationPlan/AppConfigUpdateProcedure> ;
.

<operationPlan/AppConfigUpdateProcedure>
    a noria:OperationPlan ;
    rdfs:label "Application Configuration Update Procedure"@en ;
    rdfs:comment "Standard procedure for updating application configuration."@en ;
.

