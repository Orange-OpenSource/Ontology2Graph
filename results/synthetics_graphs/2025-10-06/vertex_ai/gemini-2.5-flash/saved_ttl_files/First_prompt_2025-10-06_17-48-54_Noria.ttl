# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# New Knowledge Graph based on Noria.ttl schema
# =============================================================================

# --- Organizational Entities ---

# Organization: Orange Telecom
<id/organization/orange-telecom>
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company."@en ;
    org:identifier "ORG-001"^^xsd:string ;
    org:hasUnit <id/organizationalunit/noc-team>, <id/organizationalunit/support-l2-team> ;
    .

# Organizational Unit: NOC Team
<id/organizationalunit/noc-team>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Team"@en ;
    rdfs:comment "Team responsible for monitoring and managing network infrastructure."@en ;
    org:unitOf <id/organization/orange-telecom> ;
    org:hasMember <id/person/alice-smith> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "For critical incidents, use direct hotline. For non-critical, open a ticket."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentManagesResource <id/resource/router-001>, <id/resource/server-db-001> ;
    .

# Organizational Unit: Support L2 Team
<id/organizationalunit/support-l2-team>
    a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support Team"@en ;
    rdfs:comment "Team providing advanced technical support for applications and services."@en ;
    org:unitOf <id/organization/orange-telecom> ;
    org:hasMember <id/person/bob-johnson> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Escalate from L1. Use ticketing system for all interactions."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentManagesResource <id/application/crm-system>, <id/applicationmodule/crm-prod-eu> ;
    .

# Person: Alice Smith
<id/person/alice-smith>
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer in the NOC Team."@en ;
    foaf:name "Alice Smith"^^xsd:string ;
    foaf:mbox "mailto:alice.smith@example.com"^^xsd:anyURI ;
    foaf:phone "+33123456789"^^xsd:string ;
    foaf:holdsAccount <id/corporateuseridentifier/asmith> ;
    .

# Person: Bob Johnson
<id/person/bob-johnson>
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Lead in the L2 Support Team."@en ;
    foaf:name "Bob Johnson"^^xsd:string ;
    foaf:mbox "mailto:bob.johnson@example.com"^^xsd:anyURI ;
    foaf:phone "+33987654321"^^xsd:string ;
    foaf:holdsAccount <id/corporateuseridentifier/bjohnson> ;
    .

# Corporate User Identifier: Alice Smith's CUid
<id/corporateuseridentifier/asmith>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within the organization's IT systems."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "CUid-ASMITH-001"^^xsd:string ;
    .

# Corporate User Identifier: Bob Johnson's CUid
<id/corporateuseridentifier/bjohnson>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Bob Johnson within the organization's IT systems."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "CUid-BJOHNSON-001"^^xsd:string ;
    .

# --- Location Entities ---

# Site: Paris Data Center
<id/site/paris-data-center>
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center facility located in Paris."@en ;
    noria:siteId "PDC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix, 75002 Paris, France"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix"^^xsd:string ;
    bot:hasSpace <id/room/server-room-101> ;
    .

# Room: Server Room 101
<id/room/server-room-101>
    a noria:Room ;
    rdfs:label "Server Room 101"@en ;
    rdfs:comment "A dedicated room within the Paris Data Center for housing servers and network equipment."@en ;
    bot:hasSpace <id/locus/rack-a1-shelf3> ;
    .

# Locus: Rack A1, Shelf 3
<id/locus/rack-a1-shelf3>
    a noria:Locus ;
    rdfs:label "Rack A1, Shelf 3"@en ;
    rdfs:comment "Specific location within Server Room 101 where equipment is installed."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "3"^^xsd:string ;
    .

# --- Structural Entities ---

# Product Model: Cisco Catalyst 9300
<id/productmodel/cisco-catalyst-9300>
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Product model for a network switch manufactured by Cisco."@en ;
    noria:productManufacturedBy <id/organization/cisco-systems> ;
    .

# Organization: Cisco Systems
<id/organization/cisco-systems>
    a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en ;
    .

# Product Model: Dell PowerEdge R750
<id/productmodel/dell-poweredge-r750>
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "Product model for a server manufactured by Dell."@en ;
    noria:productManufacturedBy <id/organization/dell-technologies> ;
    .

# Organization: Dell Technologies
<id/organization/dell-technologies>
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en ;
    .

# Resource: Router-001
<id/resource/router-001>
    a noria:Resource ;
    rdfs:label "Router-001"@en ;
    rdfs:comment "Core network router in the Paris Data Center."@en ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceHostName "router-001.example.com"^^xsd:string ;
    noria:resourceProductModel <id/productmodel/cisco-catalyst-9300> ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTR-001-XYZ"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/in-production> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <id/organizationalunit/noc-team> ;
    noria:locatedAtLocus <id/locus/rack-a1-shelf3> ;
    noria:resourceManagementIPAddress <id/networkinterface/router-001-mgmt-ip> ;
    noria:resourceForApplication <id/application/monitoring-platform> ;
    .

# Resource: Server-DB-001
<id/resource/server-db-001>
    a noria:Resource ;
    rdfs:label "Server-DB-001"@en ;
    rdfs:comment "Database server hosting the CRM application."@en ;
    noria:resourceLogisticId "LOG-SRV-DB-001"^^xsd:string ;
    noria:resourceHostName "server-db-001.example.com"^^xsd:string ;
    noria:resourceProductModel <id/productmodel/dell-poweredge-r750> ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-SRV-DB-001-ABC"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/in-production> ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <id/organizationalunit/support-l2-team> ;
    noria:locatedAtLocus <id/locus/rack-a1-shelf3> ;
    noria:resourceManagementIPAddress <id/networkinterface/server-db-001-mgmt-ip> ;
    noria:resourceForApplication <id/application/crm-system> ;
    .

# Network Interface: Router-001 GE0/0/1
<id/networkinterface/router-001-ge0-0-1>
    a noria:NetworkInterface ;
    rdfs:label "Router-001 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Physical interface on Router-001 connecting to Server-DB-001."@en ;
    noria:networkInterfaceDescription "Uplink to Server-DB-001"^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceOf <id/resource/router-001> ;
    noria:networkInterfaceConnects <id/networklink/link-router001-serverdb001> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "0"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int ;
    .

# Network Interface: Server-DB-001 Eth0
<id/networkinterface/server-db-001-eth0>
    a noria:NetworkInterface ;
    rdfs:label "Server-DB-001 Ethernet0"@en ;
    rdfs:comment "Network interface on Server-DB-001 connecting to Router-001."@en ;
    noria:networkInterfaceDescription "Connection to Router-001"^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceOf <id/resource/server-db-001> ;
    noria:networkInterfaceConnects <id/networklink/link-router001-serverdb001> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    .

# Network Interface: Router-001 Management IP
<id/networkinterface/router-001-mgmt-ip>
    a noria:NetworkInterface ;
    rdfs:label "Router-001 Management IP"@en ;
    rdfs:comment "Management IP address for Router-001."@en ;
    observable:ipAddress "192.168.1.1"^^xsd:string ;
    noria:networkInterfaceOf <id/resource/router-001> ;
    .

# Network Interface: Server-DB-001 Management IP
<id/networkinterface/server-db-001-mgmt-ip>
    a noria:NetworkInterface ;
    rdfs:label "Server-DB-001 Management IP"@en ;
    rdfs:comment "Management IP address for Server-DB-001."@en ;
    observable:ipAddress "192.168.1.2"^^xsd:string ;
    noria:networkInterfaceOf <id/resource/server-db-001> ;
    .

# Network Link: Link-Router001-ServerDB001
<id/networklink/link-router001-serverdb001>
    a noria:NetworkLink ;
    rdfs:label "Link between Router-001 and Server-DB-001"@en ;
    rdfs:comment "Direct Ethernet link between Router-001 and Server-DB-001."@en ;
    noria:networkLinkId "NL-001"^^xsd:string ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <id/resource/router-001> ;
    noria:networkLinkTerminationResourceDestination <id/resource/server-db-001> ;
    noria:resourceManagedBy <id/organizationalunit/noc-team> ;
    .

# --- Functional Entities ---

# Application: CRM System
<id/application/crm-system>
    a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:comment "Application for managing customer interactions and data."@en ;
    noria:applicationModelIdentifier "CRM-APP-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CRM"^^xsd:string ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Sales & Marketing"^^xsd:string ;
    noria:elementManagedBy <id/organizationalunit/support-l2-team> ;
    .

# Application: Monitoring Platform
<id/application/monitoring-platform>
    a noria:Application ;
    rdfs:label "Network Monitoring Platform"@en ;
    rdfs:comment "Application for monitoring network devices and services."@en ;
    noria:applicationModelIdentifier "NMP-V1"^^xsd:string ;
    noria:applicationNumericalIdentifier "1002"^^xsd:int ;
    noria:applicationShortIdentifier "NMP"^^xsd:string ;
    noria:applicationType <kos/application/type/infrastructure-management> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Network Monitoring"^^xsd:string ;
    noria:elementManagedBy <id/organizationalunit/noc-team> ;
    .

# Application Module: CRM-Prod-EU
<id/applicationmodule/crm-prod-eu>
    a noria:ApplicationModule ;
    rdfs:label "CRM Production Module (Europe)"@en ;
    rdfs:comment "Production instance of the CRM system serving European customers."@en ;
    noria:applicationModuleOf <id/application/crm-system> ;
    noria:applicationModuleName "CRM_PROD_EU"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-EU"^^xsd:string ;
    noria:applicationModuleAdministrationTeam <id/organizationalunit/support-l2-team> ;
    noria:applicationModuleAdministrationLeader <id/person/bob-johnson> ;
    noria:applicationModuleSupportTeam <id/organizationalunit/support-l2-team> ;
    noria:applicationModuleSupportLeader <id/person/bob-johnson> ;
    noria:applicationModuleSupportGroup <id/organizationalunit/noc-team> ; # Example of cross-team support
    noria:applicationModuleHotlineGroup <id/organizationalunit/noc-team> ;
    noria:applicationModuleSlaLevel <kos/application/sla-level/platinum> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleStatus <kos/application/status/in-production> ;
    .

# Service: Customer Internet Access
<id/service/customer-internet-access>
    a noria:Service ;
    rdfs:label "Customer Internet Access Service"@en ;
    rdfs:comment "End-to-end service providing internet access to customers."@en ;
    noria:serviceType <kos/service/type/customer-facing-service> ;
    seas:subSystemOf <id/application/crm-system> ; # Example: CRM system is part of managing this service
    .

# --- Dynamic and Procedural Entities ---

# Event Record: Interface Down Event
<id/eventrecord/interface-down-event-001>
    a noria:EventRecord ;
    rdfs:label "Router-001 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating that an interface on Router-001 went down."@en ;
    noria:loggingTime "2024-01-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject <id/resource/router-001> ;
    noria:logOriginatingManagementSystem <id/application/monitoring-platform> ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/critical> ;
    noria:alarmProposedRepairAction <id/operationplan/router-interface-troubleshooting> ;
    noria:alarmMonitoredAttribute "interface_status=down"^^xsd:string ;
    .

# Event Record: Login Failure Event
<id/eventrecord/login-failure-event-002>
    a noria:EventRecord ;
    rdfs:label "Failed Login Attempt on Server-DB-001"@en ;
    rdfs:comment "Security event indicating a failed login attempt on the database server."@en ;
    noria:loggingTime "2024-01-20T11:15:30Z"^^xsd:dateTime ;
    noria:logText "Failed password for user 'guest' from 192.168.1.100"^^xsd:string ;
    noria:logOriginatingManagedObject <id/resource/server-db-001> ;
    noria:logOriginatingManagementSystem <id/application/monitoring-platform> ;
    noria:logOriginatingAgent <id/person/unknown-attacker> ; # Example of an unknown agent
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/warning> ;
    .

# Person: Unknown Attacker (example for logOriginatingAgent)
<id/person/unknown-attacker>
    a foaf:Person ;
    rdfs:label "Unknown Attacker"@en ;
    rdfs:comment "Placeholder for an unidentified agent in security logs."@en ;
    foaf:name "Unknown"^^xsd:string ;
    .

# Trouble Ticket: TT-202401-001 (Interface Down)
<id/troubleticket/tt-202401-001>
    a noria:TroubleTicket ;
    rdfs:label "Interface Down on Router-001"@en ;
    rdfs:comment "Trouble ticket opened due to critical interface failure on Router-001 affecting CRM service."@en ;
    dcterms:identifier "TT-202401-001"^^xsd:string ;
    dcterms:created "2024-01-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-01-20T12:30:00Z"^^xsd:dateTime ;
    dcterms:title "Router-001 GE0/0/1 Down"^^xsd:string ;
    dcterms:description "Interface GigabitEthernet0/0/1 on Router-001 went down, impacting connectivity to Server-DB-001 and CRM application."^^xsd:string ;
    noria:documentExternalId "CUST-INC-555"^^xsd:string ;
    noria:documentHRef "https://ticketing.example.com/TT-202401-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/interrupted-service> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/p1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/supervision> ;
    noria:troubleTicketTrigger <id/eventrecord/interface-down-event-001> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/immediate-intervention> ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/total-breakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/network-equipment-failure> ;
    noria:troubleTicketCause "Physical cable fault detected."^^xsd:string ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/managed-backbone-networks> ;
    noria:troubleTicketDetectionDateTime "2024-01-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-01-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-01-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-01-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/in-progress> ;
    noria:troubleTicketRelatedParty <id/person/alice-smith> ;
    noria:troubleTicketRelatedService <id/applicationmodule/crm-prod-eu> ;
    noria:troubleTicketRelatedResource <id/resource/router-001> ;
    noria:troubleTicketImpacts <id/applicationmodule/crm-prod-eu>, <id/resource/router-001> ;
    noria:troubleTicketCharacteristic <id/troubleticketcharacteristic/high-priority-flag> ;
    noria:troubleTicketFreezeItem <id/eventrecord/freeze-event-tt001> ;
    noria:documentStatusHistory <id/eventrecord/status-change-tt001-inprogress> ;
    .

# Trouble Ticket Characteristic (example)
<id/troubleticketcharacteristic/high-priority-flag>
    a skos:Concept ;
    rdfs:label "High Priority Flag"@en ;
    rdfs:comment "A characteristic indicating high priority for the trouble ticket."@en ;
    skos:inScheme <kos/TroubleTicket/characteristic> ;
    .

# Event Record: Status Change for TT-202401-001
<id/eventrecord/status-change-tt001-inprogress>
    a noria:EventRecord ;
    rdfs:label "TT-202401-001 Status Change to InProgress"@en ;
    rdfs:comment "Automated log of trouble ticket status change."@en ;
    noria:loggingTime "2024-01-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-202401-001 status changed from Initialised to InProgress."^^xsd:string ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    .

# Event Record: Freeze Event for TT-202401-001
<id/eventrecord/freeze-event-tt001>
    a noria:EventRecord ;
    rdfs:label "TT-202401-001 Freeze Event"@en ;
