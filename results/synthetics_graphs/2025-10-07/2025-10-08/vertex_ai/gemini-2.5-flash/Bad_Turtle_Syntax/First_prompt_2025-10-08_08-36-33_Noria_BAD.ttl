# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns/> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# --- Synthetic Data and KOS ---
@prefix noria-data: <https://w3id.org/noria/data/> .
@prefix noria-kos: <https://w3id.org/noria/kos/> .

# =============================================================================
# Synthetic Knowledge Graph based on NORIA.ttl schema
# =============================================================================

# --- KOS Concepts Definitions ---
# These are the SKOS concepts used as ranges for various ObjectProperties.
# They are defined here to ensure they exist and can be referenced.

noria-kos:agent-contact-method
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

noria-kos:Email
    a skos:Concept ;
    skos:inScheme noria-kos:agent-contact-method ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via email."@en .

noria-kos:Phone
    a skos:Concept ;
    skos:inScheme noria-kos:agent-contact-method ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via phone."@en .

noria-kos:Chat
    a skos:Concept ;
    skos:inScheme noria-kos:agent-contact-method ;
    rdfs:label "Chat"@en ;
    rdfs:comment "Preferred contact method via instant messaging."@en .

noria-kos:application-type
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

noria-kos:ServicePlatform
    a skos:Concept ;
    skos:inScheme noria-kos:application-type ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "An application acting as a platform for other services."@en .

noria-kos:Infrastructure
    a skos:Concept ;
    skos:inScheme noria-kos:application-type ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application managing core infrastructure components."@en .

noria-kos:BusinessApplication
    a skos:Concept ;
    skos:inScheme noria-kos:application-type ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "An application directly supporting business operations."@en .

noria-kos:application-business-importance
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

noria-kos:CriticalImportance
    a skos:Concept ;
    skos:inScheme noria-kos:application-business-importance ;
    rdfs:label "Critical Importance"@en ;
    rdfs:comment "Application is critical for business operations."@en .

noria-kos:HighImportance
    a skos:Concept ;
    skos:inScheme noria-kos:application-business-importance ;
    rdfs:label "High Importance"@en ;
    rdfs:comment "Application has high importance for business operations."@en .

noria-kos:application-sla-level
    a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying Service Level Agreement levels for applications."@en .

noria-kos:PlatinumSLA
    a skos:Concept ;
    skos:inScheme noria-kos:application-sla-level ;
    rdfs:label "Platinum SLA"@en ;
    rdfs:comment "Highest SLA level, maximum availability and performance."@en .

noria-kos:GoldSLA
    a skos:Concept ;
    skos:inScheme noria-kos:application-sla-level ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "High SLA level, good availability and performance."@en .

noria-kos:application-status
    a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

noria-kos:InProduction
    a skos:Concept ;
    skos:inScheme noria-kos:application-status ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application module is currently live and serving users."@en .

noria-kos:Development
    a skos:Concept ;
    skos:inScheme noria-kos:application-status ;
    rdfs:label "Development"@en ;
    rdfs:comment "Application module is under active development."@en .

noria-kos:service-type
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

noria-kos:CustomerFacingService
    a skos:Concept ;
    skos:inScheme noria-kos:service-type ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by customers."@en .

noria-kos:ResourceFacingService
    a skos:Concept ;
    skos:inScheme noria-kos:service-type ;
    rdfs:label