# =============================================================================
# Procedural Elements (Anomaly Patterns, Operation Plans, Pre/Post Conditions)
# =============================================================================

noria-inst:AnomalyPattern_HighCPU_DB
    a noria:AnomalyPattern ;
    rdfs:label "High CPU on Database Server Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing a high CPU usage anomaly on database servers, often indicating performance issues or inefficient queries."@en ;
    folio:hasCriticality <kos/Notification/Severity/PerceivedSeverity/Critical> .

noria-inst:AnomalyPattern_InterfaceFlap
    a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing a network interface repeatedly changing between up and down states, indicating instability."@en ;
    folio:hasCriticality <kos/Notification/Severity/PerceivedSeverity/Major> .

noria-inst:OperationPlan_DB_Upgrade
    a noria:OperationPlan ;
    rdfs:label "Database Software Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading database software to a new version."@en ;
    noria:operationPlanPreCondition noria-inst:PreCond_DB_Backup ;
    noria:operationPlanPostCondition noria-inst:PostCond_DB_Functional .

noria-inst:OperationPlan_Network_Failover
    a noria:OperationPlan ;
    rdfs:label "Network Link Failover Procedure"@en ;
    rdfs:comment "Procedure to activate redundant network links in case of primary link failure to maintain connectivity."@en ;
    noria:operationPlanPreCondition noria-inst:PreCond_Link_Down ;
    noria:operationPlanPostCondition noria-inst:PostCond_Link_Up_Redundant .

noria-inst:OperationPlan_Firewall_Update
    a noria:OperationPlan ;
    rdfs:label "Firewall Rule Update Procedure"@en ;
    rdfs:comment "Standard procedure for updating firewall rules, including review and deployment steps."@en ;
    noria:operationPlanPreCondition noria-inst:PreCond_Rule_Review ;
    noria:operationPlanPostCondition noria-inst:PostCond_Rule_Applied .

noria-inst:PreCond_DB_Backup
    a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completed"@en ;
    rdfs:comment "Pre-condition: A full backup of the database must be completed and verified before starting the upgrade."@en .

noria-inst:PostCond_DB_Functional
    a noria:ActionPostCondition ;
    rdfs:label "Database Functional and Accessible"@en ;
    rdfs:comment "Post-condition: After upgrade, database must be fully functional, accessible by all dependent applications, and performance validated."@en .

noria-inst:PreCond_Link_Down
    a noria:ActionPreCondition ;
    rdfs:label "Primary Network Link Down"@en ;
    rdfs:comment "Pre-condition: Primary network link must be confirmed as down and unresponsive to initiate failover."@en .

noria-inst:PostCond_Link_Up_Redundant
    a noria:ActionPostCondition ;
    rdfs:label "Redundant Link Operational"@en ;
    rdfs:comment "Post-condition: Redundant network link must be operational, carrying traffic, and primary link failure confirmed."@en .

noria-inst:PreCond_Rule_Review
    a noria:ActionPreCondition ;
    rdfs:label "Firewall Rule Review Completed"@en ;
    rdfs:comment "Pre-condition: New firewall rules must be reviewed and approved by security team before deployment."@en .

noria-inst:PostCond_Rule_Applied
    a noria:ActionPostCondition ;
    rdfs:label "Firewall Rules Applied and Verified"@en ;
    rdfs:comment "Post-condition: New firewall rules must be successfully applied and their functionality verified through testing."@en .

noria-inst:ProcedureExec_Failover
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Failover Procedure Execution"@en ;
    rdfs:comment "Container for events related to the network failover procedure, triggered by a critical link failure."@en ;
    pep:usedProcedure noria-inst:OperationPlan_Network_Failover .

noria-inst:ProcedureExec_DBUpgrade
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Database Upgrade Procedure Execution"@en ;
    rdfs:comment "Container for events related to the database software upgrade procedure."@en ;
    pep:usedProcedure noria-inst:OperationPlan_DB_Upgrade .

noria-inst:CR_20240425_001 noria:actionCorrelatedOperationPlan noria-inst:OperationPlan_DB_Upgrade .
noria-inst:TT_Note_20240420_001_02 noria:troubleTicketNoteCorrelatedExecution noria-inst:ProcedureExec_Failover .
noria-inst:CR_20240426_002 noria:actionCorrelatedOperationPlan noria-inst:OperationPlan_Firewall_Update .

noria-inst:Event_RouterCore1_InterfaceDown noria:alarmProposedRepairAction noria-inst:OperationPlan_Network_Failover .
noria-inst:Event_RouterCore1_InterfaceDown noria:alarmMitigatedBy noria-inst:ProcedureExec_Failover .
noria-inst:Event_CRM_DB_HighCPU noria:alarmProposedRepairAction noria-inst:OperationPlan_DB_Upgrade .
noria-inst:Event_CRM_DB_HighCPU noria:alarmMitigatedBy noria-inst:ProcedureExec_DBUpgrade .
