# Dynamic Elements (Event Records, Trouble Tickets, Change Requests, Documents)
# =============================================================================

noria-inst:Event_RouterCore1_InterfaceDown
    a noria:EventRecord ;
    rdfs:label "Router Core1 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 1 went down, impacting Internet Access Service."@en ;
    noria:logOriginatingManagedObject noria-inst:Router_Core1 ;
    noria:logOriginatingManagementSystem noria-inst:Monitoring_Application ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on core-rtr-01 changed state to down."^^xsd:string ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Critical> .

noria-inst:Event_CRM_DB_HighCPU
    a noria:EventRecord ;
    rdfs:label "CRM DB High CPU Event"@en ;
    rdfs:comment "Log entry indicating high CPU utilization on CRM Database Server, potentially affecting CRM application performance."@en ;
    noria:logOriginatingManagedObject noria-inst:Server_CRM_DB ;
    noria:logOriginatingManagementSystem noria-inst:Monitoring_Application ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on crm-db-01 exceeded 90% for 5 minutes."^^xsd:string ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmMonitoredAttribute [
        rdfs:label "CPU Usage Metric"@en ;
        rdf:value "95%"^^xsd:string ;
        dcterms:type "PerformanceMetric"^^xsd:string
    ] .

noria-inst:Event_Firewall_BlockedAttack
    a noria:EventRecord ;
    rdfs:label "Firewall Blocked Attack Event"@en ;
    rdfs:comment "Security event indicating a blocked attack attempt on the PDC01 perimeter firewall."@en ;
    noria:logOriginatingManagedObject noria-inst:Firewall_PDC01 ;
    noria:logOriginatingManagementSystem noria-inst:Monitoring_Application ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Blocked SYN flood attack from 192.0.2.10 on port 80."^^xsd:string ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Minor> ;
    noria:logOriginatingAgent noria-inst:CharlieBrown .

noria-inst:TT_20240420_001
    a noria:TroubleTicket ;
    rdfs:label "TT-20240420-001: Core Router 1 Interface Down"@en ;
    rdfs:comment "Trouble ticket created due to critical interface down event on Core Router 1, impacting Internet Access Service."@en ;
    noria:documentExternalId "EXT-TT-9876"^^xsd:string ;
    noria:documentHRef "https://ticketing.noria.net/TT-20240420-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity noria-kos:TroubleTicket/severity/Critical ;
    noria:troubleTicketType noria-kos:TroubleTicket/type/Failure ;
    noria:troubleTicketCriticity noria-kos:TroubleTicket/category/InterruptedService ;
    noria:troubleTicketPriority noria-kos:TroubleTicket/priority/P1 ;
    noria:troubleTicketOrigin noria-kos:TroubleTicket/origin/Supervision ;
    noria:troubleTicketTrigger noria-inst:Event_RouterCore1_InterfaceDown ;
    noria:troubleTicketUrgency noria-kos:TroubleTicket/urgency/ImmediateIntervention ;
    noria:troubleTicketSupervisionTool "NMSv2"^^xsd:string ;
    noria:troubleTicketCategory noria-kos:TroubleTicket/trouble-category/TotalBreakdown ;
    noria:problemCategory noria-kos:TroubleTicket/trouble-category/TotalBreakdown ;
    noria:troubleTicketCause "Fiber cut suspected between Core1 and Edge1, confirmed by optical power readings."^^xsd:string ;
    noria:problemResponsibility noria-kos:TroubleTicket/problemResponsibility/InternalNetwork ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent noria-kos:TroubleTicket/status/InProgress ;
    noria:troubleTicketRelatedParty noria-inst:NOC_Team_A, noria-inst:JohnDoe ;
    noria:troubleTicketPartyIntervention noria-inst:AliceJohnson ;
    noria:troubleTicketRelatedResource noria-inst:Router_Core1, noria-inst:Link_Core1_Edge1 ;
    noria:troubleTicketRelatedService noria-inst:InternetAccessService ;
