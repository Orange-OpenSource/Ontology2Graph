    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

noria-kos:agent-contact-method/Email
    a skos:Concept ;
    skos:inScheme noria-kos:org/agent-contact-method ;
    rdfs:label "Email"@en ;
    rdfs:comment "Contact via electronic mail."@en .

noria-kos:agent-contact-method/Phone
    a skos:Concept ;
    skos:inScheme noria-kos:org/agent-contact-method ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Contact via telephone."@en .

noria-kos:agent-contact-method/Chat
    a skos:Concept ;
    skos:inScheme noria-kos:org/agent-contact-method ;
