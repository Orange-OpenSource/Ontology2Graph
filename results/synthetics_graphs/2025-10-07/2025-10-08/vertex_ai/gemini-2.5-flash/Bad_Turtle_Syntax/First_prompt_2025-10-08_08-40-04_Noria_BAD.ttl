# =============================================================================
# Organizational Entities
# =============================================================================

noria-inst:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main telecommunications company."@en ;
    org:hasUnit noria-inst:NetworkOperationsCenter, noria-inst:ApplicationSupportDept, noria-inst:SecurityOperationsCenter .

noria-inst:NetworkOperationsCenter
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "Unit responsible for monitoring and managing the network infrastructure."@en ;
    org:unitOf noria-inst:OrangeCorp ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Phone ;
    noria:agentInstructions "Call hotline for critical network issues, use ticketing system for others."^^xsd:string .

noria-inst:ApplicationSupportDept
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Department"@en ;
    rdfs:comment "Unit responsible for supporting business applications."@en ;
    org:unitOf noria-inst:OrangeCorp ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email ;
    noria:agentInstructions "Email for all requests, critical issues via dedicated channel."^^xsd:string .

noria-inst:SecurityOperationsCenter
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Unit responsible for monitoring and analyzing security events."@en ;
    org:unitOf noria-inst:OrangeCorp ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Chat ;
    noria:agentInstructions "Report all security incidents immediately via chat or phone."^^xsd:string .

noria-inst:NOC_Team_A
    a org:OrganizationalUnit ;
    rdfs:label "NOC Team A"@en ;
    rdfs:comment "First-line support team within the Network Operations Center."@en ;
    org:unitOf noria-inst:NetworkOperationsCenter ;
    noria:agentWorkingHours "08:00-16:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Chat ;
    noria:agentInstructions "Escalate to NOC Team B for complex network issues."^^xsd:string .

noria-inst:NOC_Team_B
    a org:OrganizationalUnit ;
    rdfs:label "NOC Team B"@en ;
    rdfs:comment "Second-line support team within the Network Operations Center."@en ;
    org:unitOf noria-inst:NetworkOperationsCenter ;
    noria:agentWorkingHours "16:00-00:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Phone ;
    noria:agentInstructions "Handles escalated network incidents."^^xsd:string .

noria-inst:AppSupport_Team_CRM
    a org:OrganizationalUnit ;
    rdfs:label "CRM Application Support Team"@en ;
    rdfs:comment "Dedicated team for CRM application support."@en ;
    org:unitOf noria-inst:ApplicationSupportDept ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email ;
    noria:agentInstructions "Refer to CRM documentation for common issues."^^xsd:string .

noria-inst:AppSupport_Team_Billing
    a org:OrganizationalUnit ;
    rdfs:label "Billing Application Support Team"@en ;
    rdfs:comment "Dedicated team for Billing application support."@en ;
    org:unitOf noria-inst:ApplicationSupportDept ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email ;
    noria:agentInstructions "Contact for billing system discrepancies."^^xsd:string .

noria-inst:SOC_Team_ThreatIntel
    a org:OrganizationalUnit ;
    rdfs:label "SOC Threat Intelligence Team"@en ;
    rdfs:comment "Team focused on threat intelligence and analysis."@en ;
    org:unitOf noria-inst:SecurityOperationsCenter ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email ;
    noria:agentInstructions "Provide security alerts and intelligence reports."^^xsd:string .

noria-inst:JohnDoe
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, NOC Team B."@en ;
    noria:agentWorkingHours "16:00-00:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Phone ;
    noria:agentInstructions "Contact for high-level network architecture decisions and critical incidents."^^xsd:string .

noria-inst:JaneSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "CRM Application Manager, App Support Team CRM."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email ;
    noria:agentInstructions "Responsible for CRM application strategy and major incidents."^^xsd:string .

noria-inst:AliceJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "NOC Team A Lead."@en ;
    noria:agentWorkingHours "08:00-16:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Chat ;
    noria:agentInstructions "First point of contact for network alerts and initial troubleshooting."^^xsd:string .

noria-inst:BobWilliams
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Williams"@en ;
    rdfs:comment "Application Support Engineer, App Support Team CRM."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email ;
    noria:agentInstructions "Handles daily CRM support tickets and user requests."^^xsd:string .

noria-inst:CharlieBrown
    a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "SOC Analyst, SOC Threat Intelligence Team."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Chat ;
    noria:agentInstructions "Investigates security alerts and provides threat intelligence."^^xsd:string .

noria-inst:CUid_JohnDoe
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"@xsd:string ;
    observable:accountLogin "jdoe"@xsd:string ;
    observable:accountIdentifier "JD001"^^xsd:string .

noria-inst:CUid_JaneSmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"@xsd:string ;
    observable:accountLogin "jsmith"@xsd:string ;
    observable:accountIdentifier "JS002"^^xsd:string .

noria-inst:CUid_AliceJohnson
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Johnson's Corporate User ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Johnson."@en ;
    foaf:accountName "ajohnson"@xsd:string ;
    observable:accountLogin "ajohnson"@xsd:string ;
    observable:accountIdentifier "AJ003"^^xsd:string .

noria-inst:JohnDoe foaf:holdsAccount noria-inst:CUid_JohnDoe .
noria-inst:JaneSmith foaf:holdsAccount noria-inst:CUid_JaneSmith .
noria-inst:AliceJohnson foaf:holdsAccount noria-inst:CUid_AliceJohnson .

# =============================================================================
# Location Entities
# =============================================================================

noria-inst:ParisDataCenter
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris, France."@en ;
    noria:siteId "PDC01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix, 75002 Paris, France"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

noria-inst:LondonDataCenter
    a bot:Site ;
    rdfs:label "London Data Center"@en ;
    rdfs:comment "Secondary data center located in London, UK."@en ;
    noria:siteId "LDC01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "456 Baker Street, NW1 6XE London, UK"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE"^^xsd:string ;
    noria:sitePrincipalAddressCityName "London"^^xsd:string ;
    noria:sitePrincipalAddressCountry "UK"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Baker Street"^^xsd:string .

noria-inst:ServerRoom_PDC01_A
    a noria:Room ;
    rdfs:label "Server Room A (PDC01)"@en ;
    rdfs:comment "Server room A within the Paris Data Center, hosting core infrastructure."@en ;
    bot:hasSpace noria-inst:Locus_PDC01_A_R1C1, noria-inst:Locus_PDC01_A_R1C2, noria-inst:Locus_PDC01_A_R2C1 ;
    bot:hasElement noria-inst:Router_Core1, noria-inst:Server_CRM_DB, noria-inst:Firewall_PDC01 .

noria-inst:ServerRoom_PDC01_B
    a noria:Room ;
    rdfs:label "Server Room B (PDC01)"@en ;
    rdfs:comment "Server room B within the Paris Data Center, hosting application servers."@en ;
    bot:hasSpace noria-inst:Locus_PDC01_B_R1C1, noria-inst:Locus_PDC01_B_R1C2 ;
    bot:hasElement noria-inst:Server_Billing_App, noria-inst:VirtualMachine_Web1 .

noria-inst:ServerRoom_LDC01_A
    a noria:Room ;
    rdfs:label "Server Room A (LDC01)"@en ;
    rdfs:comment "Server room A within the London Data Center, hosting backup infrastructure."@en ;
    bot:hasSpace noria-inst:Locus_LDC01_A_R1C1 ;
    bot:hasElement noria-inst:Router_Core2, noria-inst:Server_CRM_Backup .

noria-inst:Locus_PDC01_A_R1C1
    a noria:Locus ;
    rdfs:label "Locus R1C1 in Server Room A (PDC01)"@en ;
    rdfs:comment "Specific location for Rack 1, Column 1 in Server Room A of Paris Data Center."@en ;
    noria:locusLine "R1"^^xsd:string ;
    noria:locusRow "C1"^^xsd:string .

noria-inst:Locus_PDC01_A_R1C2
