noria-inst:Event_TT_Freeze_001
    a noria:EventRecord ;
    rdfs:label "TT-20240420-001 Freeze Event"@en ;
    rdfs:comment "Event recording a freeze period for TT-20240420-001 due to external dependency."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Trouble ticket TT-20240420-001 frozen due to external fiber repair team dependency."^^xsd:string .

noria-inst:TT_Note_20240420_001_01
    a noria:TroubleTicketNote ;
    rdfs:label "TT-20240420-001 Note 1: Initial Diagnosis"@en ;
    rdfs:comment "First note on TT-20240420-001 detailing initial diagnosis steps for the interface down issue."@en ;
    noria:troubleTicketNoteCommentType noria-kos:TroubleTicket/commentType/Internal ;
    noria:troubleTicketNoteOperationType noria-kos:TroubleTicket/operationType/Diagnosis ;
    noria:logText "Checked optical power levels on GE0/0/0, Rx power is -30dBm, indicating fiber issue. Initiated physical inspection."^^xsd:string ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:eventRelatedElement noria-inst:Router_Core1 ;
    noria:eventRelatedParty noria-inst:AliceJohnson .

noria-inst:TT_Note_20240420_001_02
    a noria:TroubleTicketNote ;
