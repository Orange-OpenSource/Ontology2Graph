    rdfs:comment "Specific location for Rack 2, Column 1 in Server Room A of Paris Data Center."@en ;
    noria:locusLine "R2"^^xsd:string ;
    noria:locusRow "C1"^^xsd:string .

noria-inst:Locus_PDC01_B_R1C1
    a noria:Locus ;
    rdfs:label "Locus R1C1 in Server Room B (PDC01)"@en ;
    rdfs:comment "Specific location for Rack 1, Column 1 in Server Room B of Paris Data Center."@en ;
    noria:locusLine "R1"^^xsd:string ;
    noria:locusRow "C1"^^xsd:string .

noria-inst:Locus_PDC01_B_R1C2
    a noria:Locus ;
