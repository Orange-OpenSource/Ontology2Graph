# noria:structuralObservableOf (inverse of structuralElementObservable, can be used)
noria-data:NI_WebSrv01_Eth0_Status
    a noria:StructuralObservable ;
    rdfs:label "WebSrv01 Eth0 Operational Status Observable"@en ;
    rdfs:comment "Operational status observable for WebSrv01 Ethernet 0."@en ;
    noria:structuralObservableOf noria-data:NI_WebSrv01_Eth0 .

noria-data:Resource_WebSrv01 noria:structuralElementObservable noria-data:NI_WebSrv01_Eth0_Status .

# noria:actionCorrelatedOperationPlan (needs pep:CorrectiveMaintenanceAction or pep:ChangeAction)
# Let's create a simple pep:ProcedureExecution to represent an action.
noria-data:Action_InterfaceRestart
    a pep:ProcedureExecution ;
    rdfs:label "Action: Restart Interface Ge0/0/0"@en ;
    rdfs:comment "An action representing the execution of restarting a network interface."@en ;
    noria:actionCorrelatedOperationPlan noria-data:OpPlan_RestartInterface ;
    pep:hasInput noria-data:NI_CoreRouter01_Ge0_0_0 ;
    pep:madeBy noria-data:Person_AliceSmith ;
    pep:hasOutput noria-data:Event_RouterUpConfirmation .

noria-data:Event_RouterUpConfirmation
    a noria:EventRecord ;
    rdfs:label "Router Interface Up Confirmation Event"@en ;
    rdfs:comment "Log record confirming a network interface went up after restart."@en ;
    noria:logOriginatingManagedObject noria-data:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria-data:App_MonitoringSystem ;
    noria:logText "Interface GigabitEthernet0/0/0 on cr01.example.com changed state to up."^^xsd:string ;
    noria:loggingTime "2024-04-20T13:35:00Z"^^xsd:dateTime ;
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Warning .

noria-data:ProcExecCont_InterfaceRestart pep:member noria-data:Action_InterfaceRestart . # Link the action to the container

# noria:agentManagesResource (inverse of noria:resourceManagedBy)
noria-data:OrgUnit_NetworkTeam noria:agentManagesResource noria-data:Resource_CoreRouter01 .
noria-data:OrgUnit_AppSupportTeam noria:agentManagesResource noria-data:Resource_WebSrv01 .

