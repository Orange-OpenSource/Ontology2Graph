noria-data:Resource_WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server hosting customer-facing applications."@en ;
    noria:resourceLogisticId "ASSET-WEB-001"^^xsd:string ;
    noria:resourceHostName "websrv01.example.com"^^xsd:string ;
    noria:structuralElementDistinguishedName "websrv01.example.com"^^xsd:string ;
    noria:resourceProductModel noria-data:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType noria-kos:Resource/type/Server ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ"^^xsd:string ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/InUse ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria-data:Locus_RackA1 ;
    noria:resourceManagementIPAddress noria-data:IP_10_0_0_10 ;
    noria:elementManagedBy noria-data:OrgUnit_AppSupportTeam ;
    noria:virtualServerStatus noria-kos:Resource/OperationalState/Running .

