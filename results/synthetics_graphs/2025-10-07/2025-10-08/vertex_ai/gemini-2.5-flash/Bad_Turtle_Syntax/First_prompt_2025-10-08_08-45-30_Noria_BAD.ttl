# =============================================================================
# Agents (foaf:Agent, org:Organization, org:OrganizationalUnit, foaf:Person)
# =============================================================================

noria-data:Org_ITOperations
    a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The main IT operations department responsible for infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency phone line."@en .

noria-data:OrgUnit_NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf noria-data:Org_ITOperations ;
    noria:agentWorkingHours "Mon-Fri, 9:00-17:00"@en ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone ;
    noria:agentInstructions "For network-related incidents, open a ticket and call the team lead."@en .

noria-data:OrgUnit_AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    org:unitOf noria-data:Org_ITOperations ;
    noria:agentWorkingHours "Mon-Fri, 8:30-17:30"@en ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email ;
    noria:agentInstructions "All application issues must be reported via the internal helpdesk portal."@en .

noria-data:Person_AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Team Lead."@en ;
    org:memberOf noria-data:OrgUnit_NetworkTeam ;
    noria:agentWorkingHours "Mon-Fri, 9:00-17:00"@en ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone ;
    noria:agentInstructions "Direct contact for escalations."@en .

noria-data:Person_BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Lead."@en ;
    org:memberOf noria-data:OrgUnit_AppSupportTeam ;
    noria:agentWorkingHours "Mon-Fri, 8:30-17:30"@en ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email ;
    noria:agentInstructions "Contact for critical application issues."@en .

noria-data:Person_CharlieBrown
    a foaf:Person ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "IT Operations Manager."@en ;
    org:memberOf noria-data:Org_ITOperations ;
    noria:agentWorkingHours "Mon-Fri, 9:00-18:00"@en ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email ;
    noria:agentInstructions "Strategic and high-level operational decisions."@en .

# =============================================================================
# Corporate User Identifiers
# =============================================================================

noria-data:CUid_ASmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "AS001"^^xsd:string ;
    foaf:holdsAccount noria-data:Person_AliceSmith .

noria-data:CUid_BJohnson
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "BJ002"^^xsd:string ;
    foaf:holdsAccount noria-data:Person_BobJohnson .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria-data:Site_MainDC
    a bot:Site ;
    rdfs:label "Main Data Center Site"@en ;
    rdfs:comment "Primary data center facility for the organization."@en ;
    noria:siteId "DC01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

noria-data:Site_BranchOffice
    a bot:Site ;
    rdfs:label "Branch Office Site"@en ;
    rdfs:comment "Smaller branch office with local IT infrastructure."@en ;
    noria:siteId "BO01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Business Road"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Gotham"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Business Road"^^xsd:string .

noria-data:Room_ServerRoomDC01
    a noria:Room ;
    rdfs:label "Server Room DC01-A"@en ;
    rdfs:comment "Main server room in Data Center 01."@en ;
    bot:hasSpace noria-data:Site_MainDC .

noria-data:Room_NetworkClosetBO01
    a noria:Room ;
    rdfs:label "Network Closet BO01-1"@en ;
    rdfs:comment "Network equipment closet in Branch Office 01."@en ;
    bot:hasSpace noria-data:Site_BranchOffice .

noria-data:Locus_RackA1
    a noria:Locus ;
    rdfs:label "Rack A1 in Server Room DC01-A"@en ;
    rdfs:comment "Specific location for Rack A1 within Server Room DC01-A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace noria-data:Room_ServerRoomDC01 .

noria-data:Locus_RackB2
    a noria:Locus ;
    rdfs:label "Rack B2 in Server Room DC01-A"@en ;
    rdfs:comment "Specific location for Rack B2 within Server Room DC01-A."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:hasSpace noria-data:Room_ServerRoomDC01 .

noria-data:Locus_WallMountBO01
    a noria:Locus ;
    rdfs:label "Wall Mount BO01-1-SW"@en ;
    rdfs:comment "Wall mount location in Network Closet BO01-1."@en ;
    noria:locusLine "SW"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace noria-data:Room_NetworkClosetBO01 .

