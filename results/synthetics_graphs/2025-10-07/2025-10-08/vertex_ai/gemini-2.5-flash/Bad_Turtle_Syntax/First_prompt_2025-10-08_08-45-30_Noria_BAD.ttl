    noria:structuralElementDistinguishedName "db01.example.com"^^xsd:string ;
    noria:resourceProductModel noria-data:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType noria-kos:Resource/type/Server ;
    noria:resourceSerialNumber "SN-DB-001-ABC"^^xsd:string ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/InUse ;
    noria:resourceInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria-data:Locus_RackA1 ;
