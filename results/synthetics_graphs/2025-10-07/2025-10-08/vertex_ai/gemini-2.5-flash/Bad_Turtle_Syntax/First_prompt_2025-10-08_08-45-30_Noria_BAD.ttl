# =============================================================================
# Event Records
# =============================================================================

noria-data:Event_RouterDown
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log record indicating a network interface went down on Core Router 01."@en ;
    noria:logOriginatingManagedObject noria-data:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria-data:App_MonitoringSystem ;
    noria:logOriginatingAgent noria-data:Person_AliceSmith ; # Alice might have manually shut it down
    noria:logText "Interface GigabitEthernet0/0/0 on cr01.example.com changed state to down."^^xsd:string ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Critical ;
    noria:alarmProposedRepairAction noria-data:OpPlan_RestartInterface .

noria-data:Event_WebSrvHighCPU
    a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert from monitoring system about high CPU utilization on Web Server 01."@en ;
    noria:logOriginatingManagedObject noria-data:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria-data:App_MonitoringSystem ;
    noria:logText "High CPU usage (95%) detected on websrv01.example.com."^^xsd:string ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Warning ;
    noria:alarmMonitoredAttribute [
        a noria:StructuralObservable ;
        rdfs:label "CPU Utilization"@en ;
        rdfs:comment "Observed CPU utilization percentage."@en ;
        noria:structuralElementObservableData "95"^^xsd:int
    ] .

noria-data:Event_DBBackupSuccess
    a noria:EventRecord ;
    rdfs:label "Database Backup Success"@en ;
    rdfs:comment "Log entry confirming successful daily database backup."@en ;
    noria:logOriginatingManagedObject noria-data:Resource_DB01 ;
    noria:logOriginatingManagementSystem noria-data:App_MonitoringSystem ;
    noria:logText "Daily backup of DB01 completed successfully."^^xsd:string ;
    noria:loggingTime "2024-04-20T03:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Warning . # Using warning for informational events as well, as per schema example.

# =============================================================================
# Operation Plans (Procedures)
# =============================================================================

noria-data:OpPlan_RestartInterface
    a noria:OperationPlan ;
    rdfs:label "Network Interface Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a network interface."@en ;
    noria:operationPlanPreCondition noria-data:PreCond_InterfaceDown ;
    noria:operationPlanPostCondition noria-data:PostCond_InterfaceUp .

noria-data:OpPlan_ServerTroubleshooting
    a noria:OperationPlan ;
    rdfs:label "Server High CPU Troubleshooting"@en ;
