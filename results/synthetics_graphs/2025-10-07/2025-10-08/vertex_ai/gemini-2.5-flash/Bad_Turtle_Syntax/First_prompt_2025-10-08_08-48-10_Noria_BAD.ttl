    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer in the IT Operations Team."@en ;
    foaf:name "John Doe"^^xsd:string ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/AgentContactMethod/Email ;
    noria:agentInstructions "Contact for server and virtualization issues."^^xsd:string ;
    noria:agentManagesResource noria:instance/Resource/ServerDB01,
                               noria:instance/Resource/VirtualServer01 ;
    .

