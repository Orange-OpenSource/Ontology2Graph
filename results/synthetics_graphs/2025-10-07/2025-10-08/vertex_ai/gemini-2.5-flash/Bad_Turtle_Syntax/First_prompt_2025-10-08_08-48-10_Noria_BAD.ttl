# =============================================================================
# Synthetic Knowledge Graph Instances
# =============================================================================

# --- Organizational Entities ---

# Organizations
noria:instance/Organization/GlobalNetCorp
    a org:Organization ;
    rdfs:label "GlobalNet Corp"@en ;
    rdfs:comment "A global telecommunications company."@en ;
    org:hasUnit noria:instance/OrganizationalUnit/ITOpsTeam,
                noria:instance/OrganizationalUnit/DevTeam,
                noria:instance/OrganizationalUnit/NOC_Team,
                noria:instance/OrganizationalUnit/SecurityTeam ;
    .

# Organizational Units (Teams)
noria:instance/OrganizationalUnit/ITOpsTeam
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Responsible for the day-to-day operations of IT infrastructure."@en ;
    org:unitOf noria:instance/Organization/GlobalNetCorp ;
    org:hasMember noria:instance/Agent/JohnDoe,
                  noria:instance/Agent/AliceJohnson ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/AgentContactMethod/Email ;
    noria:agentInstructions "For critical issues, use the ticketing system and call the hotline."^^xsd:string ;
    .

noria:instance/OrganizationalUnit/DevTeam
    a org:OrganizationalUnit ;
    rdfs:label "Development Team"@en ;
    rdfs:comment "Responsible for developing and maintaining applications."@en ;
    org:unitOf noria:instance/Organization/GlobalNetCorp ;
    org:hasMember noria:instance/Agent/JaneSmith,
                  noria:instance/Agent/BobWilliams ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/AgentContactMethod/Chat ;
    noria:agentInstructions "Submit all feature requests via JIRA."^^xsd:string ;
    .

noria:instance/OrganizationalUnit/NOC_Team
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Team"@en ;
    rdfs:comment "Monitors network health and responds to incidents 24/7."@en ;
    org:unitOf noria:instance/Organization/GlobalNetCorp ;
    org:hasMember noria:instance/Agent/CharlieBrown,
                  noria:instance/Agent/DianaPrince ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/AgentContactMethod/Phone ;
    noria:agentInstructions "Follow incident response procedures strictly."^^xsd:string ;
    .

noria:instance/OrganizationalUnit/SecurityTeam
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Manages cybersecurity threats and incidents."@en ;
    org:unitOf noria:instance/Organization/GlobalNetCorp ;
    org:hasMember noria:instance/Agent/EveBlack,
                  noria:instance/Agent/FrankWhite ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/AgentContactMethod/SecureEmail ;
    noria:agentInstructions "Report all suspicious activities immediately."^^xsd:string ;
    .

# Agents (Persons)
noria:instance/Agent/JohnDoe
