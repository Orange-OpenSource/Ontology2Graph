noria:instance/ActionPreCondition/RouterUpgradePrecondition
    a noria:ActionPreCondition ;
    rdfs:label "Router Upgrade Pre-condition"@en ;
    rdfs:comment "Condition: Router configuration backed up, maintenance window approved."@en ;
    .

# --- Action Post-Conditions ---
noria:instance/ActionPostCondition/LinkUpPostcondition
    a noria:ActionPostCondition ;
    rdfs:label "Link Up Post-condition"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up', traffic flowing."@en ;
    .

noria:instance/ActionPostCondition/ServerOperationalPostcondition
    a noria:ActionPostCondition ;
    rdfs:label "Server Operational Post-condition"@en ;
    rdfs:comment "Expected outcome: Server is responsive, services running, resource utilization normal."@en ;
    .

noria:instance/ActionPostCondition/RouterUpgradePostcondition
    a noria:ActionPostCondition ;
    rdfs:label "Router Upgrade Post-condition"@en ;
    rdfs:comment "Expected outcome: Router software upgraded, all interfaces up, network connectivity restored."@en ;
    .

