    dcterms:isPartOf noria:instance/TroubleTicket_TT001 ;
    dcterms:title "Router_Interface_Down.png"^^xsd:string ;
    dcterms:description "Screenshot from monitoring system showing interface status."^^xsd:string ;
    dcterms:format "image/png"^^xsd:string ;
