# --- Physical Locations ---

noria:instance/Site_DC1
    a bot:Site ;
    rdfs:label "Main Data Center Site"@en ;
    rdfs:comment "Primary data center facility for critical operations."@en ;
    noria:siteId "DC-MAIN-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

noria:instance/Site_OfficeHQ
    a bot:Site ;
    rdfs:label "Headquarters Office Building"@en ;
    rdfs:comment "Corporate headquarters with administrative and development teams."@en ;
    noria:siteId "HQ-BUILDING-01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Business Blvd"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "20002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Capital City"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Business Blvd"^^xsd:string .

noria:instance/Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the data center."@en ;
    bot:hasSpace noria:instance/Site_DC1 .

noria:instance/Room_NetworkClosetB
    a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in the office building."@en ;
    bot:hasSpace noria:instance/Site_OfficeHQ .

noria:instance/Locus_Rack1_U10
    a noria:Locus ;
    rdfs:label "Rack 1, Unit 10"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    bot:containsZone noria:instance/Room_ServerRoomA ;
    noria:locusLine "Rack1"^^xsd:string ;
    noria:locusRow "U10"^^xsd:string .

noria:instance/Locus_Rack2_U5
    a noria:Locus ;
    rdfs:label "Rack 2, Unit 5"@en ;
    rdfs:comment "Specific location for a network device in Server Room A."@en ;
    bot:containsZone noria:instance/Room_ServerRoomA ;
    noria:locusLine "Rack2"^^xsd:string ;
    noria:locusRow "U5"^^xsd:string .

noria:instance/Locus_Cabinet3_Shelf2
    a noria:Locus ;
    rdfs:label "Cabinet 3, Shelf 2"@en ;
    rdfs:comment "Location for a small switch in Network Closet B."@en ;
    bot:containsZone noria:instance/Room_NetworkClosetB ;
    noria:locusLine "Cabinet3"^^xsd:string ;
    noria:locusRow "Shelf2"^^xsd:string .

# --- Organizations and Agents ---

noria:instance/Org_ITOperations
    a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The department responsible for IT infrastructure and services."@en .

noria:instance/Org_Development
    a org:Organization ;
    rdfs:label "Software Development Department"@en ;
    rdfs:comment "The department responsible for developing applications."@en .

noria:instance/Unit_NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure."@en ;
    org:hasUnit noria:instance/Org_ITOperations .

noria:instance/Unit_AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for applications."@en ;
    org:hasUnit noria:instance/Org_ITOperations .

noria:instance/Unit_WebDevTeam
    a org:OrganizationalUnit ;
    rdfs:label "Web Development Team"@en ;
    rdfs:comment "Team developing web applications."@en ;
    org:hasUnit noria:instance/Org_Development .

noria:instance/Agent_Alice
    a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, responsible for core routers."@en ;
    org:unitMember noria:instance/Unit_NetworkTeam ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent issues, phone for critical."^^xsd:string .

noria:instance/Agent_Bob
    a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Lead, manages critical applications."@en ;
    org:unitMember noria:instance/Unit_AppSupportTeam ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call for P1 incidents."^^xsd:string .

noria:instance/Agent_Charlie
    a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Web Developer, works on the customer portal."@en ;
    org:unitMember noria:instance/Unit_WebDevTeam ;
    noria:agentWorkingHours "10:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for quick questions."^^xsd:string .

noria:instance/CUid_AliceSmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith@company.com"^^xsd:string ;
    observable:accountIdentifier "CUID-AS-001"^^xsd:string .

noria:instance/CUid_BobJohnson
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson@company.com"^^xsd:string ;
    observable:accountIdentifier "CUID-BJ-002"^^xsd:string .

