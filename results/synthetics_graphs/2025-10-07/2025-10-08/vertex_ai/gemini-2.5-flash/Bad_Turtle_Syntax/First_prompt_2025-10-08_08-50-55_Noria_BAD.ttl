# --- Procedural Elements ---

noria:instance/OperationPlan_RouterFirmwareUpgrade
    a noria:OperationPlan ;
    rdfs:label "Standard Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "A documented procedure for upgrading router firmware safely."@en .

noria:instance/OperationPlan_DBPerformanceTuning
    a noria:OperationPlan ;
    rdfs:label "Database Performance Tuning Guide"@en ;
    rdfs:comment "A guide for optimizing database parameters to improve performance."@en .

noria:instance/ActionPreCondition_RouterConnectivityStable
    a noria:ActionPreCondition ;
    rdfs:label "Router Connectivity Stable Pre-Condition"@en ;
    rdfs:comment "Pre-condition: All other network links and devices connected to the router must be stable."@en .

noria:instance/ActionPostCondition_RouterConnectivityRestored
    a noria:ActionPostCondition ;
    rdfs:label "Router Connectivity Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: Router connectivity is fully restored and verified after the operation."@en .

noria:instance/OperationPlan_RouterFirmwareUpgrade
    noria:operationPlanPreCondition noria:instance/ActionPreCondition_RouterConnectivityStable ;
    noria:operationPlanPostCondition noria:instance/ActionPostCondition_RouterConnectivityRestored .

noria:instance/AnomalyPattern_HighCPULowThroughput
    a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Throughput Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential performance bottleneck: high CPU usage combined with unexpectedly low network throughput."@en .

noria:instance/EventRecord_ServerCPUHigh
    noria:alarmProposedRepairAction noria:instance/OperationPlan_DBPerformanceTuning .

noria:instance/TroubleTicketNote_TT001_Note2
    noria:troubleTicketNoteCorrelatedExecution noria:instance/ChangeRequest_CR001 . # Example of correlation

noria:instance/ChangeRequest_CR001
    noria:actionCorrelatedOperationPlan noria:instance/OperationPlan_RouterFirmwareUpgrade .

noria:instance/ChangeRequest_CR002
    noria:actionCorrelatedOperationPlan noria:instance/OperationPlan_DBPerformanceTuning .

