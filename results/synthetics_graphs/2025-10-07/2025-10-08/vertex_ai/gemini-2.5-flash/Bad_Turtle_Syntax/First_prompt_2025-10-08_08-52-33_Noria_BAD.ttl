# --- Procedural Elements (AnomalyPattern, OperationPlan, ActionPreCondition, ActionPostCondition) ---

noria-data:anomalyPattern/HighCPUAnomaly
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing a high CPU utilization anomaly."@en ;
    folio:hasCause noria-data:anomalyPattern/ApplicationBug ;
    folio:hasEffect noria-data:anomalyPattern/ServiceDegradation .

noria-data:anomalyPattern/ApplicationBug
    a noria:AnomalyPattern ;
    rdfs:label "Application Bug Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating a software bug."@en .

noria-data:anomalyPattern/ServiceDegradation
    a noria:AnomalyPattern ;
    rdfs:label "Service Degradation Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating degraded service performance."@en .

noria-data:operationPlan/RestartWebServer
    a noria:OperationPlan ;
    rdfs:label "Restart Web Server Operation Plan"@en ;
    rdfs:comment "Standard operating procedure for restarting a web server."@en ;
    noria:operationPlanPreCondition noria-data:actionPreCondition/ConfirmHighCPU ;
    noria:operationPlanPostCondition noria-data:actionPostCondition/VerifyCPUNormal .

noria-data:operationPlan/CheckFiberLink
    a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Operation Plan"@en ;
    rdfs:comment "Standard operating procedure for diagnosing a fiber link issue."@en ;
    noria:operationPlanPreCondition noria-data:actionPreCondition/LinkDownAlert ;
    noria:operationPlanPostCondition noria-data:actionPostCondition/LinkUpOrFaultIdentified .

noria-data:operationPlan/BackendUpgradePlan
    a noria:OperationPlan ;
    rdfs:label "Backend Upgrade Operation Plan"@en ;
    rdfs:comment "Detailed plan for upgrading the Core Banking Backend module."@en ;
    noria:operationPlanPreCondition noria-data:actionPreCondition/BackupCompleted ;
    noria:operationPlanPostCondition noria-data:actionPostCondition/ServiceFunctionalityVerified .

noria-data:operationPlan/RouterConfigUpdatePlan
    a noria:OperationPlan ;
    rdfs:label "Router Configuration Update Plan"@en ;
    rdfs:comment "Plan for applying configuration changes to network routers."@en ;
    noria:operationPlanPreCondition noria-data:actionPreCondition/ConfigBackup ;
    noria:operationPlanPostCondition noria-data:actionPostCondition/ConnectivityVerified .

noria-data:actionPreCondition/ConfirmHighCPU
    a noria:ActionPreCondition ;
    rdfs:label "Confirm High CPU Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Verify that CPU utilization is indeed high."@en .

noria-data:actionPreCondition/LinkDownAlert
    a noria:ActionPreCondition ;
    rdfs:label "Link Down Alert Pre-Condition"@en ;
    rdfs:comment "Pre-condition: A link down alert has been received."@en .

noria-data:actionPreCondition/BackupCompleted
    a noria:ActionPreCondition ;
    rdfs:label "Backup Completed Pre-Condition"@en ;
    rdfs:comment "Pre-condition: All necessary backups are completed before upgrade."@en .

noria-data:actionPreCondition/ConfigBackup
    a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Configuration backup is performed before changes."@en .

noria-data:actionPostCondition/VerifyCPUNormal
    a noria:ActionPostCondition ;
    rdfs:label "Verify CPU Normal Post-Condition"@en ;
    rdfs:comment "Post-condition: Confirm CPU utilization returns to normal levels."@en .

noria-data:actionPostCondition/LinkUpOrFaultIdentified
    a noria:ActionPostCondition ;
    rdfs:label "Link Up or Fault Identified Post-Condition"@en ;
    rdfs:comment "Post-condition: Link is restored or the root cause of the fault is identified."@en .

noria-data:actionPostCondition/ServiceFunctionalityVerified
    a noria:ActionPostCondition ;
    rdfs:label "Service Functionality Verified Post-Condition"@en ;
    rdfs:comment "Post-condition: All service functionalities are verified after upgrade."@en .

noria-data:actionPostCondition/ConnectivityVerified
    a noria:ActionPostCondition ;
    rdfs:label "Connectivity Verified Post-Condition"@en ;
    rdfs:comment "Post-condition: Network connectivity is verified after configuration changes."@en .

# --- Linking actions to operation plans ---
noria-data:correctiveMaintenanceAction/RestartWebServerAction
    a pep:CorrectiveMaintenanceAction ;
    rdfs:label "Action: Restart Web Server"@en ;
    rdfs:comment "A specific action to restart the web server."@en ;
    noria:actionCorrelatedOperationPlan noria-data:operationPlan/RestartWebServer .

noria-data:changeAction/ApplyBackendUpgrade
    a pep:ChangeAction ;
    rdfs:label "Action: Apply Backend Upgrade"@en ;
    rdfs:comment "A specific action to apply the backend upgrade."@en ;
    noria:actionCorrelatedOperationPlan noria-data:operationPlan/BackendUpgradePlan .

