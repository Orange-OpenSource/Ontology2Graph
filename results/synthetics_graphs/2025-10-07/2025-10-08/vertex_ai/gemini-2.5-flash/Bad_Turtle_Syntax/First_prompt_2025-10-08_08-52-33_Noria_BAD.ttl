# --- SKOS Concepts for various schemes ---
# These are not explicitly defined as classes in the schema, but are used as ranges for ObjectProperties.
# We define them as skos:Concept instances within their respective schemes.

kos:application/type/ServicePlatform
    a skos:Concept ;
    skos:inScheme kos:application/type ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "A platform providing services."@en .

kos:application/type/Infrastructure
    a skos:Concept ;
    skos:inScheme kos:application/type ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application managing core infrastructure components."@en .

kos:application/type/BusinessApplication
    a skos:Concept ;
    skos:inScheme kos:application/type ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "An application directly supporting business operations."@en .

kos:application/business-importance/Critical
    a skos:Concept ;
    skos:inScheme kos:application/business-importance ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for business operations."@en .

kos:application/business-importance/High
    a skos:Concept ;
    skos:inScheme kos:application/business-importance ;
    rdfs:label "High"@en ;
    rdfs:comment "Application has high business importance."@en .

kos:application/business-importance/Medium
    a skos:Concept ;
    skos:inScheme kos:application/business-importance ;
    rdfs:label "Medium"@en ;
    rdfs:comment "Application has medium business importance."@en .

kos:application/business-importance/Low
    a skos:Concept ;
    skos:inScheme kos:application/business-importance ;
    rdfs:label "Low"@en ;
    rdfs:comment "Application has low business importance."@en .

kos:application/sla-level/Gold
    a skos:Concept ;
    skos:inScheme kos:application/sla-level ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement for an application module."@en .

kos:application/sla-level/Silver
    a skos:Concept ;
    skos:inScheme kos:application/sla-level ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Standard Service Level Agreement for an application module."@en .

kos:application/status/InProduction
    a skos:Concept ;
    skos:inScheme kos:application/status ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application module is currently live and operational."@en .

kos:application/status/Staging
    a skos:Concept ;
    skos:inScheme kos:application/status ;
    rdfs:label "Staging"@en ;
    rdfs:comment "Application module is in a testing or pre-production environment."@en .

kos:service/type/CustomerFacingService
    a skos:Concept ;
    skos:inScheme kos:service/type ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by customers."@en .

kos:service/type/ResourceFacingService
    a skos:Concept ;
    skos:inScheme kos:service/type ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that manages underlying resources, not directly exposed to customers."@en .

kos:TroubleTicket/severity/Critical
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/severity ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Highest severity for a trouble ticket, indicating major impact."@en .

kos:TroubleTicket/severity/Major
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/severity ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Major severity for a trouble ticket, indicating significant impact."@en .

kos:TroubleTicket/severity/Minor
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/severity ;
    rdfs:label "Minor Severity"@en ;
    rdfs:comment "Minor severity for a trouble ticket, indicating limited impact."@en .

kos:TroubleTicket/type/Failure
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/type ;
    rdfs:label "Failure Type"@en ;
    rdfs:comment "Trouble ticket type indicating a system failure."@en .

kos:TroubleTicket/type/Assistance
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/type ;
    rdfs:label "Assistance Type"@en ;
    rdfs:comment "Trouble ticket type for user assistance requests."@en .

kos:TroubleTicket/priority/P1
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/priority ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority for a trouble ticket."@en .

kos:TroubleTicket/priority/P2
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/priority ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority for a trouble ticket."@en .

kos:TroubleTicket/origin/Customer
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/origin ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Trouble ticket originated by a customer."@en .

kos:TroubleTicket/origin/Supervision
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/origin ;
    rdfs:label "Supervision Origin"@en ;
    rdfs:comment "Trouble ticket originated by a monitoring system."@en .

kos:TroubleTicket/urgency/ImmediateIntervention
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/urgency ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Urgency level requiring immediate action."@en .

kos:TroubleTicket/trouble-category/TotalBreakdown
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/trouble-category ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Trouble category indicating a complete system failure."@en .

kos:TroubleTicket/problemResponsibility/ManagedBackboneNetworks
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/problemResponsibility ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility for the problem lies with managed backbone networks."@en .

kos:TroubleTicket/commentType/Internal
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/commentType ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "A comment visible only to internal teams."@en .

kos:TroubleTicket/operationType/Diagnosis
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/operationType ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Operation type related to diagnosing an issue."@en .

kos:ChangeRequest/category/InternalIntervention
    a skos:Concept ;
    skos:inScheme kos:ChangeRequest/category ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request category for internal system modifications."@en .

kos:ChangeRequest/type/Standard
    a skos:Concept ;
    skos:inScheme kos:ChangeRequest/type ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A routine, pre-approved change request."@en .

kos:ChangeRequest/cause/Configuration
    a skos:Concept ;
    skos:inScheme kos:ChangeRequest/cause ;
    rdfs:label "Configuration Change Cause"@en ;
    rdfs:comment "Change request caused by a configuration update."@en .

kos:ChangeRequest/status/Completed
    a skos:Concept ;
    skos:inScheme kos:ChangeRequest/status ;
    rdfs:label "Completed Status"@en ;
    rdfs:comment "Change request has been successfully implemented."@en .

kos:Resource/OperationalState/Up
    a skos:Concept ;
    skos:inScheme kos:Resource/OperationalState ;
    rdfs:label "Operational State Up"@en ;
    rdfs:comment "Resource is fully operational."@en .

kos:Resource/OperationalState/Down
    a skos:Concept ;
    skos:inScheme kos:Resource/OperationalState ;
    rdfs:label "Operational State Down"@en ;
    rdfs:comment "Resource is not operational."@en .

kos:Resource/AdministrativeState/Up
    a skos:Concept ;
    skos:inScheme kos:Resource/AdministrativeState ;
    rdfs:label "Administrative State Up"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

kos:Resource/AdministrativeState/Down
    a skos:Concept ;
    skos:inScheme kos:Resource/AdministrativeState ;
    rdfs:label "Administrative State Down"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

kos:Resource/LifecycleState/InProduction
    a skos:Concept ;
    skos:inScheme kos:Resource/LifecycleState ;
    rdfs:label "In Production Lifecycle State"@en ;
    rdfs:comment "Resource is currently used in production."@en .

kos:Resource/type/Server
    a skos:Concept ;
    skos:inScheme kos:Resource/type ;
    rdfs:label "Server Resource Type"@en ;
    rdfs:comment "A computing server resource."@en .

kos:Resource/type/Router
    a skos:Concept ;
    skos:inScheme kos:Resource/type ;
    rdfs:label "Router Resource Type"@en ;
    rdfs:comment "A network router resource."@en .

kos:org/agent-contact-method/Email
    a skos:Concept ;
    skos:inScheme kos:org/agent-contact-method ;
    rdfs:label "Email Contact Method"@en ;
    rdfs:comment "Preferred contact method via email."@en .

kos:org/agent-contact-method/Phone
    a skos:Concept ;
    skos:inScheme kos:org/agent-contact-method ;
    rdfs:label "Phone Contact Method"@en ;
    rdfs:comment "Preferred contact method via phone."@en .

kos:Notification/Severity/PerceivedSeverity/Critical
    a skos:Concept ;
    skos:inScheme kos:Notification/Severity/PerceivedSeverity ;
    rdfs:label "Critical Perceived Severity"@en ;
    rdfs:comment "Perceived severity of an alarm as critical."@en .

kos:Notification/Severity/PerceivedSeverity/Warning
    a skos:Concept ;
    skos:inScheme kos:Notification/Severity/PerceivedSeverity ;
    rdfs:label "Warning Perceived Severity"@en ;
    rdfs:comment "Perceived severity of an alarm as a warning."@en .

# --- Organizational Entities (foaf:Agent, org:Organization, org:OrganizationalUnit) ---

noria-data:agent/JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A synthetic employee, John Doe."@en ;
    foaf:mbox "mailto:john.doe@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email .

noria-data:agent/JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A synthetic employee, Jane Smith."@en ;
    foaf:mbox "mailto:jane.smith@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "8:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Call mobile for urgent issues."^^xsd:string ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Phone .

noria-data:organization/TechCorp
    a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "A fictional technology corporation."@en ;
    org:hasUnit noria-data:organizationalUnit/InfraOps ;
    org:hasUnit noria-data:organizationalUnit/AppDev ;
    org:hasMember noria-data:agent/JohnDoe ;
    org:hasMember noria-data:agent/JaneSmith .

noria-data:organizationalUnit/InfraOps
    a org:OrganizationalUnit ;
    rdfs:label "Infrastructure Operations Team"@en ;
    rdfs:comment "Team responsible for managing IT infrastructure."@en ;
    org:unitOf noria-data:organization/TechCorp ;
    org:hasMember noria-data:agent/JohnDoe ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email .

noria-data:organizationalUnit/AppDev
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining applications."@en ;
    org:unitOf noria-data:organization/TechCorp ;
    org:hasMember noria-data:agent/JaneSmith ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit change requests via portal."^^xsd:string ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Chat .

noria-data:corporateUserIdentifier/jdoe_corp
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "jdoe_corp_id_12345"^^xsd:string ;
    foaf:holdsAccount noria-data:agent/JohnDoe .

noria-data:corporateUserIdentifier/jsmith_corp
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountLogin "jsmith"^^xsd:string ;
    observable:accountIdentifier "jsmith_corp_id_67890"^^xsd:string ;
    foaf:holdsAccount noria-data:agent/JaneSmith .

# --- Location Related Entities (bot:Site, noria:Room, noria:Locus) ---

noria-data:site/DataCenterEast
    a bot:Site ;
    rdfs:label "East Data Center"@en ;
    rdfs:comment "Primary data center located in the eastern region."@en ;
    noria:siteId "DC-EAST-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string ;
    bot:hasSpace noria-data:room/ServerRoomA ;
    bot:hasSpace noria-data:room/NetworkRoomB .

noria-data:room/ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in the East Data Center."@en ;
    bot:hasZone noria-data:locus/RackA1 ;
    bot:hasZone noria-data:locus/RackA2 ;
    bot:hasSpace noria-data:site/DataCenterEast .

noria-data:room/NetworkRoomB
    a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room in the East Data Center."@en ;
    bot:hasZone noria-data:locus/RackB1 ;
    bot:hasZone noria-data:locus/RackB2 ;
    bot:hasSpace noria-data:site/DataCenterEast .

noria-data:locus/RackA1
    a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace noria-data:room/ServerRoomA .

noria-data:locus/RackA2
    a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of database servers in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:hasSpace noria-data:room/ServerRoomA .

noria-data:locus/RackB1
    a noria:Locus ;
    rdfs:label "Rack B1"@en ;
    rdfs:comment "Location of core routers in Network Room B."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace noria-data:room/NetworkRoomB .

noria-data:locus/RackB2
    a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:comment "Location of firewalls and switches in Network Room B."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:hasSpace noria-data:room/NetworkRoomB .

