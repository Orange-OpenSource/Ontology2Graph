# --- Operation Plans ---

<operationplan/router_interface_troubleshoot>
    a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard procedure for diagnosing and resolving router interface issues."@en ;
    pep:hasStep "Check physical connection"^^xsd:string, "Verify interface configuration"^^xsd:string, "Contact ISP if external link"^^xsd:string ;
    noria:operationPlanPreCondition <actionprecondition/interface_down_alert> ;
    noria:operationPlanPostCondition <actionpostcondition/interface_up_service_restored> .

<operationplan/db_performance_check>
    a noria:OperationPlan ;
    rdfs:label "Database Performance Check Procedure"@en ;
    rdfs:comment "Procedure to investigate and optimize database performance issues."@en ;
    pep:hasStep "Analyze slow queries"^^xsd:string, "Check database locks"^^xsd:string, "Review resource utilization"^^xsd:string ;
