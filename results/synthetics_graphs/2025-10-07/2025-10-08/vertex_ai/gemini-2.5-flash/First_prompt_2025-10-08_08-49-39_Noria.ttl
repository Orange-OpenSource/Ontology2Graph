# --- Resources ---

<resource/router_core_01>
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router in the Paris datacenter."@en ;
    noria:resourceLogisticId "LOG-CR-01-PAR"^^xsd:string ;
    noria:resourceHostName "core-router-01.paris.net"^^xsd:string ;
    noria:resourceProductModel <productmodel/cisco_asr9k> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "CISCO-CR01-SN12345"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/network_operations_team> ;
    noria:locatedAtLocus <locus/rack_a1_u1> ;
    noria:resourceManagementIPAddress <ipaddress/10.0.0.1> ;
    noria:clusterController <resource/router_core_02> .

<resource/router_core_02>
    a noria:Resource ;
    rdfs:label "Core Router 02"@en ;
