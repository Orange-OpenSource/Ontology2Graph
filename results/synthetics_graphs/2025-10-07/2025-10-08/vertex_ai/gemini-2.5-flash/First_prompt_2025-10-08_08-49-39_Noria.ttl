    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "CISCO-CR02-SN67890"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/network_operations_team> ;
    noria:locatedAtLocus <locus/rack_a1_u1> ;
    noria:resourceManagementIPAddress <ipaddress/10.0.0.2> .

<resource/app_server_01>
    a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting critical application components."@en ;
    noria:resourceLogisticId "LOG-AS-01-PAR"^^xsd:string ;
    noria:resourceHostName "app-server-01.paris.net"^^xsd:string ;
    noria:resourceProductModel <productmodel/dell_poweredge_r740> ;
