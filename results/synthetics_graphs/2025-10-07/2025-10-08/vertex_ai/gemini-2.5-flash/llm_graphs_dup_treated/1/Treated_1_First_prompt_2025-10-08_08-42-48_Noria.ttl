# Agent manages resource example
<agent/JohnDoe> noria:agentManagesResource <resource/DB_Server_01> .
<agent/JaneSmith> noria:agentManagesResource <resource/Web_Server_01> .
<org/SupportTeam_CRM> noria:agentManagesResource <resource/Core_Router_01> .

# Trouble Ticket Party Intervention example
<tt/CRM_Outage_20240101> noria:troubleTicketPartyIntervention <event/TT_Intervention_Log_Jane> .

<event/TT_Intervention_Log_Jane>
    a noria:EventRecord ;
    rdfs:label "Jane Smith Intervention Log"@en ;
    rdfs:comment "Log of Jane Smith's intervention on the CRM outage ticket."@en ;
    noria:loggingTime "2024-01-01T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingAgent <agent/JaneSmith> ;
    noria:logText "Jane Smith started diagnosis on DB_Server_01."^^xsd:string .

# Trouble Ticket Characteristic example (using a blank node for a specific characteristic instance)
<tt/CRM_Outage_20240101> noria:troubleTicketCharacteristic [
    a skos:Concept ;
    rdfs:label "Customer_extra_node_2 Impact: High_extra_node_2"@en ;
    rdfs:comment "Specific characteristic indicating high customer impact."@en
] .

# Trouble Ticket Freeze Item example
<tt/CRM_Outage_20240101> noria:troubleTicketFreezeItem <event/TT_Freeze_Period_Start> .

<event/TT_Freeze_Period_Start>
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Start"@en ;
    rdfs:comment "Log entry indicating the start of a freeze period for the CRM outage ticket."@en ;
    noria:loggingTime "2024-01-01T10:45:00Z"^^xsd:dateTime ;
    noria:logText "Freeze period started due to external dependency."^^xsd:string .

# Structural Observable example (linking a resource to a property)
<resource/DB_Server_01> noria:structuralElementObservable <property/DB_CPU_Usage> .

<property/DB_CPU_Usage>
    a noria:StructuralObservable ;
    rdfs:label "DB Server_extra_node_2 CPU Usage"@en ;
    rdfs:comment "Observable property for CPU usage of DB Server_extra_node_2 01."@en ;
    noria:structuralObservableOf <resource/DB_Server_01> ;
    noria:structuralElementObservableData "75"^^xsd:int . # Example data, could be linked to a time series.

<resource/Web_Server_01> noria:structuralElementObservable <property/Web_Memory_Usage> .

<property/Web_Memory_Usage>
    a noria:StructuralObservable ;
    rdfs:label "Web Server_extra_node_2 Memory Usage"@en ;
    rdfs:comment "Observable property for Memory usage of Web Server_extra_node_2 01."@en ;
    noria:structuralObservableOf <resource/Web_Server_01> ;
    noria:structuralElementObservableData "60"^^xsd:int .

