# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
<agent/JohnDoe>
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee responsible for IT operations."@en ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_2> .

<agent/JaneSmith>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A team leader for application support."@en ;
    noria:agentWorkingHours "8:30 AM - 4:30 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_2> .

<org/GlobalNetCorp>
    a org:Organization, foaf:Agent ;
    rdfs:label "GlobalNet Corp"@en ;
    rdfs:comment "The main organization managing the IT infrastructure."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Refer to corporate guidelines."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_2> .

<org/AdminTeam_CRM>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "CRM Administration Team"@en ;
    rdfs:comment "Team responsible for administering the CRM application."@en ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Escalate critical issues to Jane Smith."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_2> .

<org/SupportTeam_CRM>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "CRM Support Team"@en ;
    rdfs:comment "Level 2 support team for the CRM application."@en ;
    noria:agentWorkingHours "24/7 On-call"^^xsd:string ;
    noria:agentInstructions "Follow incident management procedures."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_2> .

<org/HotlineTeam_Global>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Global Hotline Team"@en ;
    rdfs:comment "First-line support and hotline team for all services."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Log all calls in the ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_2> .

# --- Corporate User Identifiers ---
<cuid/johndoe_gnc>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe at GlobalNet Corp."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "johndoe_gnc_id"^^xsd:string ;
    foaf:holdsAccount <agent/JohnDoe> .

<cuid/janesmith_gnc>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith at GlobalNet Corp."@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountLogin "jsmith"^^xsd:string ;
    observable:accountIdentifier "janesmith_gnc_id"^^xsd:string ;
    foaf:holdsAccount <agent/JaneSmith> .

# --- Applications ---
<app/CRM_App>
    a noria:Application ;
    rdfs:label "Customer_extra_node_2 Relationship Management Application"@en ;
    rdfs:comment "Core application for managing customer interactions and data."@en ;
    noria:applicationModelIdentifier "CRM-V2.1"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CRM_App"^^xsd:string ;
    noria:applicationType <kos/application/type/CRM> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High_extra_node_2> ;
    noria:applicationFunctionalDomain "Customer_extra_node_2 Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Sales & Marketing"^^xsd:string ;
    noria:elementManagedBy <org/GlobalNetCorp> .

<app/ERP_System>
    a noria:Application ;
    rdfs:label "Enterprise Resource Planning System"@en ;
    rdfs:comment "Integrated management of main business processes."@en ;
    noria:applicationModelIdentifier "ERP-SAP-S4HANA"^^xsd:string ;
    noria:applicationNumericalIdentifier "1002"^^xsd:int ;
    noria:applicationShortIdentifier "ERP_Sys"^^xsd:string ;
    noria:applicationType <kos/application/type/ERP> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High_extra_node_2> ;
    noria:applicationFunctionalDomain "Financial Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Supply Chain"^^xsd:string ;
    noria:elementManagedBy <org/GlobalNetCorp> .

# --- Application Modules ---
<appmodule/CRM_Prod_Module_01>
    a noria:ApplicationModule ;
    rdfs:label "CRM Production Module 01"@en ;
    rdfs:comment "Production instance of the CRM application, serving live customer traffic."@en ;
    noria:applicationModuleOf <app/CRM_App> ;
    noria:applicationModuleName "CRM-V2.1_PROD-01"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-01"^^xsd:string ;
    noria:applicationModuleAdministrationTeam <org/AdminTeam_CRM> ;
    noria:applicationModuleAdministrationLeader <agent/JohnDoe> ;
    noria:applicationModuleSupportTeam <org/SupportTeam_CRM> ;
    noria:applicationModuleSupportLeader <agent/JaneSmith> ;
    noria:applicationModuleSupportGroup <org/HotlineTeam_Global> ;
    noria:applicationModuleHotlineGroup <org/HotlineTeam_Global> ;
    noria:applicationModuleSlaLevel <kos/application/sla-level/Gold_extra_node_2> ;
    noria:applicationModuleSlaLevelDate "2023-01-15T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
    noria:elementManagedBy <org/AdminTeam_CRM> .

<appmodule/CRM_Dev_Module_01>
    a noria:ApplicationModule ;
    rdfs:label "CRM Development_extra_node_2 Module 01"@en ;
    rdfs:comment "Development_extra_node_2 instance of the CRM application for testing and new features."@en ;
    noria:applicationModuleOf <app/CRM_App> ;
    noria:applicationModuleName "CRM-V2.1_DEV-01"^^xsd:string ;
    noria:applicationModuleIdentifier "DEV-01"^^xsd:string ;
    noria:applicationModuleAdministrationTeam <org/AdminTeam_CRM> ;
    noria:applicationModuleAdministrationLeader <agent/JohnDoe> ;
    noria:applicationModuleSupportTeam <org/SupportTeam_CRM> ;
    noria:applicationModuleSupportLeader <agent/JaneSmith> ;
    noria:applicationModuleSlaLevel <kos/application/sla-level/Silver> ;
    noria:applicationModuleSlaLevelDate "2023-03-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "false"^^xsd:boolean ;
    noria:applicationModuleStatus <kos/application/status/Development_extra_node_2> ;
    noria:elementManagedBy <org/AdminTeam_CRM> .

# --- Services ---
<service/CustomerAccessService>
    a noria:Service ;
    rdfs:label "Customer_extra_node_2 Access Service"@en ;
    rdfs:comment "End-to-end service providing customer access to CRM and other portals."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <app/CRM_App> ; # Linking service to application
    noria:elementManagedBy <org/GlobalNetCorp> .

<service/InternalDataProcessing>
    a noria:Service ;
    rdfs:label "Internal_extra_node_2 Data Processing Service"@en ;
    rdfs:comment "Backend service for internal data processing, not directly exposed to customers."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf <app/ERP_System> ; # Linking service to application
    noria:elementManagedBy <org/GlobalNetCorp> .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
<site/DataCenter_Paris>
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string .

<room/ServerRoom_A1>
