    rdfs:label "Server001 Online Event"@en ;
    rdfs:comment "Event record indicating that Server001 came back online."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "INFO: Server webserver001.prod.example.com is UP."^^xsd:string ;
    noria:logOriginatingManagedObject noria:Resource_Server001 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringDashboard ;
    noria:alarmSeverity noria:Concept_PerceivedSeverityMinor ;
    noria:alarmMitigatedBy noria:ProcedureExecutionContainer_ServerDiag .

