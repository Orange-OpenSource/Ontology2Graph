# --- Organizational Entities ---

noria:Person_AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "An employee responsible for IT operations."@en ;
    foaf:name "Alice Smith"^^xsd:string ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria:Concept_EmailContact .

noria:Person_BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "An employee leading the network team."@en ;
    foaf:name "Bob Johnson"^^xsd:string ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Call directly for critical network issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria:Concept_PhoneContact .

noria:OrgUnit_ITOperations
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for daily IT operations."@en ;
    org:unitOf <https://www.orange.com/> ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentManagesResource noria:Resource_Server001, noria:Resource_Router001 .

noria:OrgUnit_NetworkSupport
    a org:OrganizationalUnit ;
    rdfs:label "Network Support Team"@en ;
    rdfs:comment "Team specializing in network infrastructure support."@en ;
    org:unitOf <https://www.orange.com/> ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Escalate to L3 for complex routing problems."^^xsd:string ;
    noria:agentManagesResource noria:Resource_Router001, noria:NetworkLink_WAN_Link_Paris_Lyon .

noria:OrgUnit_AppDevTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining applications."@en ;
    org:unitOf <https://www.orange.com/> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit feature requests via Jira."^^xsd:string ;
    noria:agentManagesResource noria:Application_CRM_System .

noria:CorporateUserIdentifier_Alice
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's CUid"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "CUid-AS-001"^^xsd:string ;
    foaf:holdsAccount noria:Person_AliceSmith .

noria:CorporateUserIdentifier_Bob
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's CUid"@en ;
    rdfs:comment "Corporate User Identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "CUid-BJ-002"^^xsd:string ;
    foaf:holdsAccount noria:Person_BobJohnson .

