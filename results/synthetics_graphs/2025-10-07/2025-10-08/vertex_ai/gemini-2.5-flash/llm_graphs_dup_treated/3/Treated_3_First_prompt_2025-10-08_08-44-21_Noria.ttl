    noria:resourceSerialNumber "SN-WEB-001-XYZ"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:OrgUnit_ITOperations ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType noria:Concept_ResourceTypeServer ;
    noria:resourceUsageState noria:Concept_LifecycleStateInUse ;
