    rdfs:comment "Pre-condition: The target server is currently offline or unresponsive."@en .

noria:ActionPostCondition_ServerOnline
    a noria:ActionPostCondition ;
    rdfs:label "Server Online Post-Condition"@en ;
    rdfs:comment "Post-condition: The server is back online and services are running."@en .

noria:ActionPreCondition_InterfaceFlapping
    a noria:ActionPreCondition ;
