    noria:logOriginatingManagedObject noria-data:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria-data:App_NetworkMonitoring ;
    noria:logOriginatingAgent noria-data:Agent_Charlie ;
    noria:alarmSeverity noria-data:AlarmSeverity_Critical ;
    noria:alarmProposedRepairAction noria-data:OperationPlan_NetworkFailover ;
    noria:alarmMonitoredAttribute noria-data:MonitoredAttribute_InterfaceStatus .

