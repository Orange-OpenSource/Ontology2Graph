# --- Event Records ---
noria-data:Event_CPU_Spike
    a noria:EventRecord ;
    rdfs:label "CPU Spike Alert"@en ;
    rdfs:comment "An alert indicating high CPU utilization on Web Server 01."@en ;
    noria:logText "High CPU usage detected on webserver-01.dc1.orange.com, current: 95%"^^xsd:string ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria-data:Resource_Webserver01 ;
    noria:logOriginatingManagementSystem noria-data:App_NetworkMonitoring ;
    noria:logOriginatingAgent noria-data:Agent_Alice ; # Alice might be the on-call engineer receiving the alert
    noria:alarmSeverity noria-data:AlarmSeverity_Major ;
    noria:alarmProposedRepairAction noria-data:OperationPlan_RebootWebServer ;
    noria:alarmMonitoredAttribute noria-data:MonitoredAttribute_CPUUsage .

