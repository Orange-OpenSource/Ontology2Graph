# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/> .  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/> .  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/> .  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#> .  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix noria-data: <https://w3id.org/noria/data/> .
@base <https://w3id.org/noria/data/> .

# =============================================================================
# Synthetic Knowledge Graph Instances
# =============================================================================

# --- Organizational Units and Agents ---
noria-data:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main corporate entity managing all services and infrastructure."@en ;
    org:hasUnit noria-data:ITOperationsDept, noria-data:NetworkServicesDept, noria-data:CustomerSupportDept .

noria-data:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Responsible for the daily operation and maintenance of IT systems."@en ;
    org:unitOf noria-data:OrangeCorp ;
    org:hasMember noria-data:Agent_Alice, noria-data:Agent_Bob ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. Otherwise, open a ticket."^^xsd:string .

noria-data:NetworkServicesDept
    a org:OrganizationalUnit ;
    rdfs:label "Network Services Department"@en ;
    rdfs:comment "Manages the core network infrastructure and connectivity."@en ;
    org:unitOf noria-data:OrangeCorp ;
    org:hasMember noria-data:Agent_Charlie, noria-data:Agent_Diana ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Phone ;
    noria:agentInstructions "Follow incident response procedures for network outages."^^xsd:string .

noria-data:CustomerSupportDept
    a org:OrganizationalUnit ;
    rdfs:label "Customer Support Department"@en ;
    rdfs:comment "First line of contact for customer inquiries and issues."@en ;
    org:unitOf noria-data:OrangeCorp ;
    org:hasMember noria-data:Agent_Eve ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Chat ;
    noria:agentInstructions "Escalate to L2 support for technical problems."^^xsd:string .

noria-data:Agent_Alice
    a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "IT Operations Engineer."@en ;
    foaf:mbox <mailto:alice.johnson@orange.com> ;
    foaf:holdsAccount noria-data:CUid_AliceJohnson ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:agentInstructions "Contact via internal messaging for non-urgent matters."^^xsd:string ;
    noria:agentManagesResource noria-data:Resource_Webserver01, noria-data:Resource_DBServer01 .

noria-data:Agent_Bob
    a foaf:Agent ;
    rdfs:label "Bob Williams"@en ;
    rdfs:comment "IT Operations Manager."@en ;
    foaf:mbox <mailto:bob.williams@orange.com> ;
    foaf:holdsAccount noria-data:CUid_BobWilliams ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Phone ;
    noria:agentInstructions "Only for escalations."^^xsd:string ;
    noria:agentManagesResource noria-data:Resource_LoadBalancer01 .

noria-data:Agent_Charlie
    a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Network Engineer."@en ;
    foaf:mbox <mailto:charlie.brown@orange.com> ;
    foaf:holdsAccount noria-data:CUid_CharlieBrown ;
    noria:agentWorkingHours "Shift A (Mon-Wed)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Phone ;
    noria:agentInstructions "Available on call for network incidents."^^xsd:string ;
    noria:agentManagesResource noria-data:Resource_CoreRouter01, noria-data:NetworkLink_DC1_DC2 .

noria-data:Agent_Diana
    a foaf:Agent ;
    rdfs:label "Diana Prince"@en ;
    rdfs:comment "Senior Network Architect."@en ;
    foaf:mbox <mailto:diana.prince@orange.com> ;
    foaf:holdsAccount noria-data:CUid_DianaPrince ;
    noria:agentWorkingHours "10:00 am - 7:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:agentInstructions "Strategic network planning and high-level troubleshooting."^^xsd:string ;
    noria:agentManagesResource noria-data:Resource_EdgeRouter01 .

noria-data:Agent_Eve
    a foaf:Agent ;
    rdfs:label "Eve Adams"@en ;
    rdfs:comment "Customer Support Representative."@en ;
    foaf:mbox <mailto:eve.adams@orange.com> ;
    foaf:holdsAccount noria-data:CUid_EveAdams ;
    noria:agentWorkingHours "Shift B (Thu-Sun)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Chat ;
    noria:agentInstructions "Direct customer interaction."^^xsd:string .

noria-data:ContactMethod_Email
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via email."@en .

noria-data:ContactMethod_Phone
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via phone call."@en .

noria-data:ContactMethod_Chat
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Chat"@en ;
    rdfs:comment "Preferred contact method via instant messaging."@en .

