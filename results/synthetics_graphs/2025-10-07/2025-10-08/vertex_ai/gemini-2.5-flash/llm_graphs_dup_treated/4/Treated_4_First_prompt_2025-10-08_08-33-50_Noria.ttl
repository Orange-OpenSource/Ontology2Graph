    noria:resourceHostName "core-router-01.dc1.orange.com"^^xsd:string ;
    noria:resourceSerialNumber "ABC12345DEF"^^xsd:string ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress noria-data:IPAddress_CoreRouter01_Mgmt ;
