# --- Trouble Tickets ---
noria-data:TroubleTicket_NetworkOutage
    a noria:TroubleTicket ;
    rdfs:label "Critical Network Outage - DC1 to DC2 Link Down"@en ;
    rdfs:comment "Trouble ticket opened due to the critical network link failure between data centers."@en ;
    noria:documentExternalId "TT-20240420-001"^^xsd:string ;
    noria:documentHRef "https://ticketing.orange.com/tt/TT-20240420-001"^^xsd:anyURI ;
    noria:troubleTicketCause "Fiber cut suspected between DC1 and DC2."^^xsd:string ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T13:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketSupervisionTool "NMS-APP"^^xsd:string ;
    noria:troubleTicketSeverity noria-data:TroubleTicketSeverity_Blocking ;
    noria:troubleTicketType noria-data:TroubleTicketType_Failure ;
    noria:troubleTicketCriticity noria-data:TroubleTicketCriticity_InterruptedService ;
    noria:troubleTicketPriority noria-data:TroubleTicketPriority_P1 ;
    noria:troubleTicketOrigin noria-data:TroubleTicketOrigin_Supervision ;
    noria:troubleTicketTrigger noria-data:Event_Link_Down ;
    noria:troubleTicketUrgency noria-data:TroubleTicketUrgency_ImmediateIntervention ;
    noria:troubleTicketCategory noria-data:TroubleTicketCategory_TotalBreakdown ;
    noria:problemCategory noria-data:TroubleTicketCategory_TotalBreakdown ;
    noria:problemResponsibility noria-data:ProblemResponsibility_ManagedBackboneNetworks ;
    noria:troubleTicketStatusCurrent noria-data:TroubleTicketStatus_InProgress ;
    noria:troubleTicketRelatedParty noria-data:Agent_Charlie, noria-data:NetworkServicesDept ;
    noria:troubleTicketPartyIntervention noria-data:PartyIntervention_NetworkTeam ;
    noria:troubleTicketRelatedService noria-data:Service_CustomerFacingWeb ;
    noria:troubleTicketRelatedResource noria-data:Resource_CoreRouter01, noria-data:NetworkLink_DC1_DC2 ;
    noria:troubleTicketImpacts noria-data:App_CRM, noria-data:Service_CustomerFacingWeb, noria-data:NetworkLink_DC1_DC2 ;
    noria:documentStatusHistory noria-data:Event_TT_StatusChange_InProgress ;
