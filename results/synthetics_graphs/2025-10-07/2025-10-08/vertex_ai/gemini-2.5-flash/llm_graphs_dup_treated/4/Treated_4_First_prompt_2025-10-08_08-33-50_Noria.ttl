# --- Locations ---
noria-data:Site_DC1
    a bot:Site ;
    rdfs:label "Data Center 1 (DC1)"@en ;
    rdfs:comment "Primary data center location."@en ;
    noria:siteId "DC1-FRA-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Main Street"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Main Street"^^xsd:string ;
    bot:hasSpace noria-data:Room_ServerRoomA, noria-data:Room_NetworkRoomB .

noria-data:Site_DC2
    a bot:Site ;
    rdfs:label "Data Center 2 (DC2)"@en ;
    rdfs:comment "Secondary data center location for disaster recovery."@en ;
    noria:siteId "DC2-LON-02"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "456 Oak Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "SW1A 0AA"^^xsd:string ;
    noria:sitePrincipalAddressCityName "London"^^xsd:string ;
    noria:sitePrincipalAddressCountry "UK"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Oak Avenue"^^xsd:string ;
    bot:hasSpace noria-data:Room_ServerRoomC .

noria-data:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Data Center 1."@en ;
    bot:hasSubSpace noria-data:Locus_RackA1, noria-data:Locus_RackA2 .

noria-data:Room_NetworkRoomB
    a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room in Data Center 1."@en ;
    bot:hasSubSpace noria-data:Locus_RackB1 .

noria-data:Room_ServerRoomC
    a noria:Room ;
    rdfs:label "Server Room C"@en ;
    rdfs:comment "Server room in Data Center 2."@en ;
    bot:hasSubSpace noria-data:Locus_RackC1 .

noria-data:Locus_RackA1
    a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Specific location for servers in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

noria-data:Locus_RackA2
    a noria:Locus ;
    rdfs:label "Rack A2 in Server Room A"@en ;
    rdfs:comment "Specific location for more servers in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

noria-data:Locus_RackB1
    a noria:Locus ;
    rdfs:label "Rack B1 in Network Room B"@en ;
    rdfs:comment "Specific location for network devices in Network Room B."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

noria-data:Locus_RackC1
    a noria:Locus ;
    rdfs:label "Rack C1 in Server Room C"@en ;
    rdfs:comment "Specific location for servers in Server Room C."@en ;
    noria:locusLine "C"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

