# --- Anomaly Patterns ---
noria-data:AnomalyPattern_HighCPU
    a noria:AnomalyPattern ;
    rdfs:label "High_extra_node_0 CPU Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage, potentially leading to performance issues."@en .

noria-data:AnomalyPattern_LinkFlap
    a noria:AnomalyPattern ;
    rdfs:label "Network Link Flapping Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating frequent up/down transitions on a network interface."@en .

# --- Operation Plans ---
noria-data:OperationPlan_RebootWebServer
    a noria:OperationPlan ;
    rdfs:label "Reboot Web Server_extra_node_0 Procedure"@en ;
    rdfs:comment "Standard_extra_node_0 operating procedure for rebooting a web server."@en ;
    noria:operationPlanPreCondition noria-data:ActionPreCondition_WebServerUnresponsive ;
    noria:operationPlanPostCondition noria-data:ActionPostCondition_WebServerRestored .

noria-data:OperationPlan_NetworkFailover
    a noria:OperationPlan ;
    rdfs:label "Network Link Failover Procedure"@en ;
    rdfs:comment "Procedure to activate a redundant network link in case of primary link failure."@en ;
    noria:operationPlanPreCondition noria-data:ActionPreCondition_PrimaryLinkDown ;
    noria:operationPlanPostCondition noria-data:ActionPostCondition_TrafficRerouted .

# --- Action Pre/Post Conditions ---
noria-data:ActionPreCondition_WebServerUnresponsive
    a noria:ActionPreCondition ;
    rdfs:label "Web Server_extra_node_0 Unresponsive Pre-Condition"@en ;
    rdfs:comment "Condition: Web server is not responding to health checks or user requests."@en .

noria-data:ActionPreCondition_PrimaryLinkDown
    a noria:ActionPreCondition ;
    rdfs:label "Primary Network Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: The primary network link is detected as down."@en .

noria-data:ActionPostCondition_WebServerRestored
    a noria:ActionPostCondition ;
    rdfs:label "Web Server_extra_node_0 Restored Post-Condition"@en ;
    rdfs:comment "Outcome: Web server is responsive and serving traffic normally."@en .

noria-data:ActionPostCondition_TrafficRerouted
    a noria:ActionPostCondition ;
    rdfs:label "Traffic Rerouted Post-Condition"@en ;
    rdfs:comment "Outcome: Network traffic is successfully rerouted over the redundant link."@en .

# --- Procedure Executions (representing CorrectiveMaintenanceAction/ChangeAction) ---
noria-data:Action_RebootWebServer
    a pep:ProcedureExecution ;
    rdfs:label "Reboot Web Server_extra_node_0 Action"@en ;
    rdfs:comment "Execution of the web server reboot procedure."@en ;
    noria:actionCorrelatedOperationPlan noria-data:OperationPlan_RebootWebServer ;
    pep:madeBy noria-data:Agent_Alice ;
    pep:hasInput noria-data:ActionPreCondition_WebServerUnresponsive ;
    pep:hasOutput noria-data:ActionPostCondition_WebServerRestored ;
    dcterms:created "2024-04-20T10:30:00Z"^^xsd:dateTime .

noria-data:Action_NetworkFailover
    a pep:ProcedureExecution ;
    rdfs:label "Network Failover Action"@en ;
    rdfs:comment "Execution of the network failover procedure."@en ;
    noria:actionCorrelatedOperationPlan noria-data:OperationPlan_NetworkFailover ;
    pep:madeBy noria-data:Agent_Charlie ;
    pep:hasInput noria-data:ActionPreCondition_PrimaryLinkDown ;
    pep:hasOutput noria-data:ActionPostCondition_TrafficRerouted ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime .

# --- Linking AnomalyPattern to EventRecords ---
noria-data:Event_CPU_Spike
    folio:hasFailureMode noria-data:AnomalyPattern_HighCPU .

noria-data:Event_Link_Down
    folio:hasFailureMode noria-data:AnomalyPattern_LinkFlap .

# --- Linking EventRecords to ProcedureExecutionContainers for alarmMitigatedBy ---
noria-data:Event_Link_Down
    noria:alarmMitigatedBy noria-data:ProcedureExecutionContainer_LinkRestoration .

noria-data:ProcedureExecutionContainer_LinkRestoration
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Link Restoration Execution Container"@en ;
    rdfs:comment "Container for execution records related to restoring the network link."@en .


