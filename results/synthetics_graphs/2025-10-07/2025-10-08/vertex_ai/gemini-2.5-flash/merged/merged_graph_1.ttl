# --- Operation Plans ---
<op/DB_Restart_Procedure>
    a noria:OperationPlan ;
    rdfs:label "Database Restart Procedure"@en ;
    rdfs:comment "Standard_extra_node_2 operating procedure for restarting a database server."@en ;
    noria:operationPlanPreCondition <actionprecondition/DB_Offline_Check> ;
    noria:operationPlanPostCondition <actionpostcondition/DB_Online_Verify> ;
    noria:elementManagedBy <org/AdminTeam_CRM> .

<op/Network_Config_Rollback>
    a noria:OperationPlan ;
    rdfs:label "Network Configuration Rollback Procedure"@en ;
    rdfs:comment "Procedure to revert network configuration changes in case of issues."@en ;
    noria:operationPlanPreCondition <actionprecondition/Network_Impact_Confirmed> ;
    noria:operationPlanPostCondition <actionpostcondition/Network_Restored_Verify> ;
    noria:elementManagedBy <org/SupportTeam_CRM> .

# --- Action Pre-Conditions ---
<actionprecondition/DB_Offline_Check>
    a noria:ActionPreCondition ;
    rdfs:label "Database Offline Check"@en ;
    rdfs:comment "Pre-condition: Verify that the database server is indeed offline or unreachable."@en ;
    pep:hasInput "Ping test to DB server fails."^^xsd:string ;
    BBO:has_activationCondition "DB server status is 'down'."^^xsd:string .

<actionprecondition/Network_Impact_Confirmed>
    a noria:ActionPreCondition ;
    rdfs:label "Network Impact Confirmed"@en ;
    rdfs:comment "Pre-condition: Confirm that network changes have caused a negative impact."@en ;
    pep:hasInput "Network connectivity tests fail after change."^^xsd:string ;
    BBO:has_activationCondition "Service outage confirmed after network change."^^xsd:string .

# --- Action Post-Conditions ---
<actionpostcondition/DB_Online_Verify>
    a noria:ActionPostCondition ;
    rdfs:label "Database Online Verification"@en ;
    rdfs:comment "Post-condition: Verify that the database server is back online and services are restored."@en ;
    pep:hasOutput "DB server responds to pings and application connects successfully."^^xsd:string ;
    BBO:has_completionCondition "DB server status is 'up' and application health checks pass."^^xsd:string .

<actionpostcondition/Network_Restored_Verify>
    a noria:ActionPostCondition ;
    rdfs:label "Network Restored Verification"@en ;
    rdfs:comment "Post-condition: Verify that network connectivity is restored after rollback."@en ;
    pep:hasOutput "Network connectivity tests pass after rollback."^^xsd:string ;
    BBO:has_completionCondition "All affected services are reachable and operational."^^xsd:string .

# --- Additional Object Property Usage ---
<action/DB_Restart_Action>
    a pep:Action ;
    rdfs:label "DB Restart Action"@en ;
    rdfs:comment "An action representing the execution of a DB restart."@en ;
    noria:actionCorrelatedOperationPlan <op/DB_Restart_Procedure> .

<action/Network_Config_Apply_Action>
    a pep:Action ;
    rdfs:label "Network Config Apply Action"@en ;
    rdfs:comment "An action representing the application of network configuration."@en ;
    noria:actionCorrelatedOperationPlan <op/Network_Config_Rollback> . # Example of linking to a rollback plan, could also be a forward plan.

