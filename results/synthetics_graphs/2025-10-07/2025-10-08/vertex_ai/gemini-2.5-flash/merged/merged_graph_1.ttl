    noria:resourceProductModel <productmodel/Cisco_Catalyst_9300> ; # Reusing product model for simplicity
    noria:resourceType <kos/Resource/type/Router_extra_node_2> ; # Using Router_extra_node_2 as a generic network device type
    noria:resourceSerialNumber "SN-FW-001-JKL"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-05-20T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <app/Security_Analytics> ;
    noria:locatedAtLocus <locus/Rack_R2C1> ;
    noria:resourceManagementIPAddress <ipaddress/10.0.0.2> ;
    noria:elementManagedBy <org/NetworkOperations> .

<ipaddress/10.0.0.2>
