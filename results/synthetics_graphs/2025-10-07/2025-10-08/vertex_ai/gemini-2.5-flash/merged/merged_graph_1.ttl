# --- Organizational Units and Agents ---
noria-data:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main corporate entity managing all services and infrastructure."@en ;
    org:hasUnit noria-data:ITOperationsDept, noria-data:NetworkServicesDept, noria-data:CustomerSupportDept .

noria-data:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Responsible for the daily operation and maintenance of IT systems."@en ;
    org:unitOf noria-data:OrangeCorp ;
    org:hasMember noria-data:Agent_Alice, noria-data:Agent_Bob ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. Otherwise, open a ticket."^^xsd:string .

noria-data:NetworkServicesDept
    a org:OrganizationalUnit ;
    rdfs:label "Network Services Department"@en ;
    rdfs:comment "Manages the core network infrastructure and connectivity."@en ;
    org:unitOf noria-data:OrangeCorp ;
    org:hasMember noria-data:Agent_Charlie, noria-data:Agent_Diana ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Phone ;
    noria:agentInstructions "Follow incident response procedures for network outages."^^xsd:string .

noria-data:CustomerSupportDept
    a org:OrganizationalUnit ;
    rdfs:label "Customer_extra_node_0 Support Department"@en ;
    rdfs:comment "First line of contact for customer inquiries and issues."@en ;
    org:unitOf noria-data:OrangeCorp ;
    org:hasMember noria-data:Agent_Eve ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Chat ;
    noria:agentInstructions "Escalate to L2 support for technical problems."^^xsd:string .

noria-data:Agent_Alice
    a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "IT Operations Engineer."@en ;
    foaf:mbox <mailto:alice.johnson@orange.com> ;
    foaf:holdsAccount noria-data:CUid_AliceJohnson ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:agentInstructions "Contact via internal messaging for non-urgent matters."^^xsd:string ;
    noria:agentManagesResource noria-data:Resource_Webserver01, noria-data:Resource_DBServer01 .

noria-data:Agent_Bob
    a foaf:Agent ;
    rdfs:label "Bob Williams"@en ;
    rdfs:comment "IT Operations Manager."@en ;
    foaf:mbox <mailto:bob.williams@orange.com> ;
    foaf:holdsAccount noria-data:CUid_BobWilliams ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Phone ;
    noria:agentInstructions "Only for escalations."^^xsd:string ;
    noria:agentManagesResource noria-data:Resource_LoadBalancer01 .

noria-data:Agent_Charlie
    a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Network Engineer."@en ;
    foaf:mbox <mailto:charlie.brown@orange.com> ;
    foaf:holdsAccount noria-data:CUid_CharlieBrown ;
    noria:agentWorkingHours "Shift A (Mon-Wed)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Phone ;
    noria:agentInstructions "Available on call for network incidents."^^xsd:string ;
    noria:agentManagesResource noria-data:Resource_CoreRouter01, noria-data:NetworkLink_DC1_DC2 .

noria-data:Agent_Diana
    a foaf:Agent ;
    rdfs:label "Diana Prince"@en ;
    rdfs:comment "Senior Network Architect."@en ;
    foaf:mbox <mailto:diana.prince@orange.com> ;
    foaf:holdsAccount noria-data:CUid_DianaPrince ;
