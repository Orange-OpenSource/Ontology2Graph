# --- Generic Agents (Persons and Organizational Units) ---

<agent/john_doe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A synthetic employee, John Doe."@en ;
    foaf:name "John Doe"^^xsd:string ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string .

<agent/jane_smith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A synthetic employee, Jane Smith."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_1> ;
    noria:agentInstructions "Call directly for urgent issues."^^xsd:string .

<org/network_operations_team>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "The team responsible for network infrastructure operations."@en ;
    org:unitOf <org/it_department> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for immediate support."^^xsd:string .

<org/application_support_team>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "The team providing support for critical applications."@en ;
    org:unitOf <org/it_department> ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Submit a ticket via the portal."^^xsd:string .

<org/it_department>
    a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department of the company."@en ;
    foaf:name "Global IT Solutions"^^xsd:string .

# --- Corporate User Identifiers ---

<cuid/jdoe_corp>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountIdentifier "jdoe_corp_id_12345"^^xsd:string ;
    foaf:holdsAccount <agent/john_doe> .

<cuid/jsmith_corp>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountIdentifier "jsmith_corp_id_67890"^^xsd:string ;
    foaf:holdsAccount <agent/jane_smith> .

# --- Locations (Site, Room, Locus) ---

<site/datacenter_paris>
    a bot:Site ;
    rdfs:label "Paris Datacenter"@en ;
    rdfs:comment "Main datacenter located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Republique"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Republique"^^xsd:string .

<site/office_london>
    a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:comment "Regional office in London."@en ;
    noria:siteId "OFF-LDN-01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "45 Park Lane"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "W1K 1PN"^^xsd:string ;
    noria:sitePrincipalAddressCityName "London"^^xsd:string ;
    noria:sitePrincipalAddressCountry "UK"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Park Lane"^^xsd:string .

<room/server_room_a>
    a noria:Room ;
    rdfs:label "Server_extra_node_1 Room A"@en ;
    rdfs:comment "Primary server room in Paris Datacenter."@en ;
    bot:hasSpace <site/datacenter_paris> .

<room/network_closet_b>
    a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in London Office."@en ;
    bot:hasSpace <site/office_london> .

<locus/rack_a1_u1>
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 1"@en ;
    rdfs:comment "Specific location for a server in Server_extra_node_1 Room A."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "U1"^^xsd:string ;
    bot:hasSpace <room/server_room_a> .

<locus/rack_b5_u10>
    a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Specific location for a switch in Network Closet B."@en ;
    noria:locusLine "B5"^^xsd:string ;
    noria:locusRow "U10"^^xsd:string ;
    bot:hasSpace <room/network_closet_b> .

# --- Product Models ---

<productmodel/cisco_asr9k>
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series"@en ;
    rdfs:comment "Product model for Cisco ASR 9000 series routers."@en ;
