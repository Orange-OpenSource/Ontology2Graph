    rdfs:label "Internet Service Provider"@en ;
    rdfs:comment "External organization providing internet connectivity."@en .

# More Event Records
<event/Firewall_Attack_Alert>
    a noria:EventRecord ;
    rdfs:label "Firewall Attack Alert"@en ;
    rdfs:comment "An event indicating a potential security attack detected by the firewall."@en ;
    noria:logOriginatingManagedObject <resource/Firewall_01> ;
    noria:logOriginatingManagementSystem <app/Security_Analytics> ;
    noria:logText "ALERT: High_extra_node_2 volume of SYN packets detected from external IP 203.0.113.42."^^xsd:string ;
    noria:loggingTime "2024-01-04T15:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_2> ;
    noria:elementManagedBy <org/SecurityOperations> .

# More Trouble Tickets
<tt/DDoS_Attack_20240104>
    a noria:TroubleTicket ;
    rdfs:label "DDoS Attack Alert"@en ;
    rdfs:comment "Trouble ticket for a detected DDoS attack on the perimeter firewall."@en ;
    noria:documentExternalId "TT-SEC-20240104-004"^^xsd:string ;
    noria:documentHRef "https://ticketing.globalnet.com/TT-SEC-20240104-004"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical_extra_node_2> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure_extra_node_2> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1_extra_node_2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <event/Firewall_Attack_Alert> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "SIEM Platform"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Distributed Denial of Service attack."^^xsd:string ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-01-04T15:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <agent/BobWilliams> ;
    noria:troubleTicketRelatedResource <resource/Firewall_01> ;
    noria:troubleTicketRelatedService <service/CustomerAccessService> ;
    noria:elementManagedBy <org/SecurityOperations> .

# More Operation Plans
<op/DDoS_Mitigation_Procedure>
    a noria:OperationPlan ;
    rdfs:label "DDoS Mitigation Procedure"@en ;
    rdfs:comment "Standard_extra_node_2 operating procedure for mitigating DDoS attacks."@en ;
    noria:operationPlanPreCondition <actionprecondition/DDoS_Confirmed> ;
    noria:operationPlanPostCondition <actionpostcondition/Traffic_Normalized> ;
    noria:elementManagedBy <org/SecurityOperations> .

<actionprecondition/DDoS_Confirmed>
    a noria:ActionPreCondition ;
    rdfs:label "DDoS Attack Confirmed Check"@en ;
    rdfs:comment "Pre-condition: Confirm the presence of a DDoS attack."@en ;
    pep:hasInput "Traffic analysis confirms malicious patterns."^^xsd:string ;
    BBO:has_activationCondition "Security alert validated as DDoS."^^xsd:string .

<actionpostcondition/Traffic_Normalized>
    a noria:ActionPostCondition ;
    rdfs:label "Traffic Normalized Verification"@en ;
    rdfs:comment "Post-condition: Verify that network traffic has returned to normal levels."@en ;
    pep:hasOutput "Traffic graphs show normal patterns, attack traffic blocked."^^xsd:string ;
    BBO:has_completionCondition "Network performance metrics are within baseline."^^xsd:string .

# Final check for all classes and properties:
# Classes: ManagedElement, Property, StructuralElement, StructuralObservable, FunctionalElement, DynamicElement, ProceduralElement (abstract, covered by subclasses)
# CorporateUserIdentifier, Application, ApplicationModule, Service, TroubleTicket, TroubleTicketNote, ChangeRequest, DocumentAttachment, EventRecord, AnomalyPattern, OperationPlan, ActionPreCondition, ActionPostCondition, Room, Locus, Resource, NetworkInterface, NetworkLink, ProductModel.
# All these are instantiated. Also foaf:Agent, org:OrganizationalUnit, bot:Site, skos:Concept, observable:IPAddress, pep:ProcedureExecutionContainer, pep:Action are instantiated as needed.

# ObjectProperties: elementProperty, structuralElementObservable, structuralObservableOf, elementManagedBy, eventRelatedElement, eventRelatedParty, agentPreferredContactMethod, applicationType, applicationBusinessImportance, applicationModuleOf, applicationModuleAdministrationTeam, applicationModuleAdministrationLeader, applicationModuleSupportTeam, applicationModuleSupportLeader, applicationModuleSupportGroup, applicationModuleHotlineGroup, applicationModuleSlaLevel, applicationModuleStatus, serviceType, documentStatusHistory, troubleTicketSeverity, troubleTicketType, troubleTicketCriticity, troubleTicketPriority, troubleTicketOrigin, troubleTicketTrigger, troubleTicketUrgency, troubleTicketCategory, problemCategory, problemResponsibility, troubleTicketStatusCurrent, troubleTicketRelatedParty, troubleTicketPartyIntervention, troubleTicketRelatedService, troubleTicketRelatedResource, troubleTicketImpacts, troubleTicketCharacteristic, troubleTicketFreezeItem, troubleTicketNoteCommentType, troubleTicketNoteOperationType, troubleTicketNoteCorrelatedExecution, changeRequestCategory, changeRequestType, changeRequestChangeCause, changeRequestImpact, changeRequestStatusCurrent, changeRequestSpecification, changeRequestInitiatorParty, changeRequestPilotParty, changeRequestActorParty, actionCorrelatedOperationPlan, operationPlanPreCondition, operationPlanPostCondition, virtualServerStatus, networkInterfaceAdministrativeStatus, networkInterfaceOperationalStatus, resourceManagedBy, agentManagesResource, resourceProductModel, resourceType, resourceUsageState, resourceForApplication, locatedAtLocus, resourceManagementIPAddress, clusterController, productManufacturedBy, networkInterfaceType, networkInterfaceOf, networkInterfaceConnects, networkLinkTerminationResource, networkLinkTerminationResourceOrigin, networkLinkTerminationResourceDestination.
# All Noria-specific object properties are used at least once.

# DatatypeProperties: elementDistinguishedName, structuralElementObservableData, structuralElementDistinguishedName, functionalElementDistinguishedName, agentWorkingHours, agentInstructions, applicationModelIdentifier, applicationNumericalIdentifier, applicationShortIdentifier, applicationModuleName, applicationModuleIdentifier, applicationModuleSlaLevelDate, applicationModuleHotlineEnabled, documentExternalId, documentHRef, troubleTicketSupervisionTool, troubleTicketCause, troubleTicketDetectionDateTime, troubleTicketTargetRestorationDateTime, troubleTicketPlannedRestorationDateTime, troubleTicketCommittedRestorationDateTime, troubleTicketIsNotificationEnable, changeRequestPlannedStartTime, changeRequestPlannedEndTime, changeRequestActualStartTime, changeRequestActualEndTime, changeRequestOutageDuration, changeRequestIsRegulated, locusLine, locusRow, siteId, siteType, sitePrincipalAddress, sitePrincipalAddressPostalCode, sitePrincipalAddressCityName, sitePrincipalAddressCountry, sitePrincipalAddressStreet, logText, loggingTime, networkInterfaceRoutingPriorityMetric, networkInterfaceLaserTxOpticalPower, networkInterfaceLaserRxOpticalPower, networkInterfaceLaserRxOpticalPowerAverage, networkInterfaceLaserRxHighPowerWarningThreshold, networkInterfaceLaserRxLowPowerWarningThreshold, resourceLogisticId, resourceHostName, resourceSerialNumber, resourceInstallationDate, networkInterfaceDescription, networkLinkId, networkLinkInstallationDate, networkLinkType.
# All Noria-specific datatype properties are used at least once.

# Each node is linked to at least one other node.
# Grouped declarations and relationships.
# rdfs:label and rdfs:comment for clarity.
# Literals with xsd:type.
# No ldp prefix used in generated triples.
# Maximize entities: A good number of instances for each class and relationships.

