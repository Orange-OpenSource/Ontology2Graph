    noria:structuralElementObservable noria-data:NetworkInterface_Eth0_WS01_TxPower .

noria-data:NetworkInterface_Eth0_WS01_TxPower
    a noria:StructuralObservable ;
    rdfs:label "Eth0 WS01 Transmit Power"@en ;
    noria:structuralElementObservableData "-5"^^xsd:int .

noria-data:NetworkInterface_Eth0_WS01_Status
    noria:structuralObservableOf noria-data:NetworkInterface_Eth0_WS01 .

noria-data:NetworkInterface_Eth0_WS01_TxPower
