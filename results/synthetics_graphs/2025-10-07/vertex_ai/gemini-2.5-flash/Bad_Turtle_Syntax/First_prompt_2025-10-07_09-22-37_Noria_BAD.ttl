# --- Organizational Entities ---

noria-data:Person_Alice
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "An employee at TechCorp, responsible for network operations."@en ;
    foaf:name "Alice Smith" ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string .

noria-data:Person_Bob
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "A senior engineer at TechCorp, leading the infrastructure team."@en ;
    foaf:name "Bob Johnson" ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Phone ;
    noria:agentInstructions "Call directly for critical issues."^^xsd:string .

noria-data:OrgUnit_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:hasMember noria-data:Person_Alice ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Phone ;
    noria:agentInstructions "Use ticketing system for all requests, escalate via phone for P1 incidents."^^xsd:string .

noria-data:OrgUnit_AppDev
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining applications."@en ;
    org:hasMember noria-data:Person_Bob ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email ;
    noria:agentInstructions "Submit feature requests via JIRA."^^xsd:string .

noria-data:Org_TechCorp
    a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "The main organization."@en ;
    org:hasUnit noria-data:OrgUnit_NetworkOps, noria-data:OrgUnit_AppDev .

noria-data:CorporateUserIdentifier_AliceSmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "UUID-ASMITH-001"^^xsd:string .

noria-data:CorporateUserIdentifier_BobJohnson
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "UUID-BJOHNSON-002"^^xsd:string .

noria-data:Person_Alice
    foaf:holdsAccount noria-data:CorporateUserIdentifier_AliceSmith .

noria-data:Person_Bob
    foaf:holdsAccount noria-data:CorporateUserIdentifier_BobJohnson .

# --- Location Entities ---

noria-data:Site_DataCenterA
    a bot:Site ;
