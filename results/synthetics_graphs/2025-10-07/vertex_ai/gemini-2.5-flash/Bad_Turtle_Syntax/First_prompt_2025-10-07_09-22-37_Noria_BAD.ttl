    noria:sitePrincipalAddressPostalCode "20002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string .

noria-data:Room_ServerRoom1
    a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "A server room within Data Center A."@en ;
    bot:hasSpace noria-data:Locus_RackA1, noria-data:Locus_RackA2 ;
    bot:hasSubSpace noria-data:Locus_RackA1, noria-data:Locus_RackA2 .

noria-data:Room_NetworkCloset
    a noria:Room ;
    rdfs:label "Network Closet"@en ;
    rdfs:comment "Network equipment closet in Office B."@en ;
    bot:hasSpace noria-data:Locus_RackB1 ;
    bot:hasSubSpace noria-data:Locus_RackB1 .

noria-data:Locus_RackA1
    a noria:Locus ;
    rdfs:label "Rack A1 in Server Room 1"@en ;
    rdfs:comment "Specific location for servers in Server Room 1."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

noria-data:Locus_RackA2
    a noria:Locus ;
    rdfs:label "Rack A2 in Server Room 1"@en ;
    rdfs:comment "Specific location for servers in Server Room 1."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

noria-data:Locus_RackB1
    a noria:Locus ;
    rdfs:label "Rack B1 in Network Closet"@en ;
    rdfs:comment "Specific location for network devices in Network Closet."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

