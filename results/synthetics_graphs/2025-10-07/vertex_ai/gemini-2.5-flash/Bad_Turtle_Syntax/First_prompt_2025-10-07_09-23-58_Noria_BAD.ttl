    a noria:Application ;
    rdfs:label "Customer Web Application"@en ;
    rdfs:comment "Main customer-facing web application."@en ;
    noria:applicationModelIdentifier "CWA-V1"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CWA"^^xsd:string ;
    noria:applicationType noria-kos:application-type/BusinessApp ;
    noria:applicationBusinessImportance noria-kos:app-business-importance/Critical ;
    noria:applicationFunctionalDomain "Market and Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Customer Self-Service"^^xsd:string ;
    noria:elementManagedBy noria-data:OrgUnit_AppDev ;
    noria:resourceForApplication noria-data:Resource_ServerDB1, noria-data:Resource_VirtualServerApp1 .

noria-data:Application_MonitoringSystem
    a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "System for monitoring network health and performance."@en ;
    noria:applicationModelIdentifier "NMS-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier "2001"^^xsd:int ;
    noria:applicationShortIdentifier "NMS"^^xsd:string ;
    noria:applicationType noria-kos:application-type/ServicePlatform ;
    noria:applicationBusinessImportance noria-kos:app-business-importance/High ;
    noria:applicationFunctionalDomain "Resource Development, Management and Operations"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Network Monitoring"^^xsd:string ;
    noria:elementManagedBy noria-data:OrgUnit_NetOps .

