# --- Agents and Organizations ---
noria-data:Agent_AliceSmith
    a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "An agent responsible for IT operations."@en ;
    foaf:name "Alice Smith"^^xsd:string ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email .

noria-data:Agent_BobJohnson
    a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "An agent responsible for network infrastructure."@en ;
    foaf:name "Bob Johnson"^^xsd:string ;
    noria:agentWorkingHours "8:30 AM - 4:30 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Call hotline for critical network issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Phone .

noria-data:OrgUnit_NetOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "The team managing network infrastructure."@en ;
    org:unitOf noria-data:Org_GlobalISP ;
    org:hasMember noria-data:Agent_BobJohnson .

noria-data:OrgUnit_AppDev
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "The team developing and maintaining applications."@en ;
    org:unitOf noria-data:Org_GlobalISP ;
    org:hasMember noria-data:Agent_AliceSmith .

noria-data:Org_GlobalISP
    a org:Organization ;
    rdfs:label "Global ISP Inc."@en ;
    rdfs:comment "A global internet service provider."@en ;
    org:hasUnit noria-data:OrgUnit_NetOps, noria-data:OrgUnit_AppDev .

# --- Corporate User Identifiers ---
noria-data:CUid_AliceSmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountIdentifier "AS12345"^^xsd:string ;
    foaf:holdsAccount noria-data:Agent_AliceSmith .

noria-data:CUid_BobJohnson
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountIdentifier "BJ67890"^^xsd:string ;
    foaf:holdsAccount noria-data:Agent_BobJohnson .

# --- Locations ---
noria-data:Site_DataCenterA
    a bot:Site ;
    rdfs:label "Main Data Center A"@en ;
    rdfs:comment "Primary data center location."@en ;
    noria:siteId "DC-A-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string ;
    wgs84_pos:lat "34.0522"^^xsd:float ;
    wgs84_pos:long "-118.2437"^^xsd:float .

noria-data:Room_ServerRoom1
    a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "Server room within Data Center A."@en ;
    bot:hasSpace noria-data:Site_DataCenterA .

noria-data:Locus_RackA1_U42
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 42"@en ;
    rdfs:comment "Specific location within Server Room 1."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace noria-data:Room_ServerRoom1 .

noria-data:Locus_RackB2_U10
    a noria:Locus ;
    rdfs:label "Rack B2, Unit 10"@en ;
    rdfs:comment "Another specific location within Server Room 1."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:hasSpace noria-data:Room_ServerRoom1 .

