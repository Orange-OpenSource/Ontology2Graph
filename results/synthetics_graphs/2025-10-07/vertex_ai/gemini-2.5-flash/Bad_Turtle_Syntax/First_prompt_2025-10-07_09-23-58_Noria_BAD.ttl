noria-data:IPAddress_ServerDB1_Mgmt
    a observable:IPAddress ;
    observable:ipAddressValue "10.0.0.10"^^xsd:string ;
    rdfs:label "DB Server1 Management IP"@en .

noria-data:Resource_VirtualServerApp1
    a noria:Resource ;
