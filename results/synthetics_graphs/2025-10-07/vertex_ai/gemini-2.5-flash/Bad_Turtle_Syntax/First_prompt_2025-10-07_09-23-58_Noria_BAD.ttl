# --- Resources ---
noria-data:Resource_Router1
    a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "A core network router in Data Center A."@en ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceHostName "router-core-01.dc-a.isp.net"^^xsd:string ;
    noria:resourceSerialNumber "SN123456789"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceType noria-kos:resource-type/Router ;
    noria:resourceUsageState noria-kos:resource-lifecycle-state/InUse ;
    noria:resourceProductModel noria-data:ProductModel_Cisco3850 ;
    noria:resourceManagedBy noria-data:OrgUnit_NetOps ;
    noria:locatedAtLocus noria-data:Locus_RackA1_U42 ;
    noria:resourceManagementIPAddress noria-data:IPAddress_Router1_Mgmt .

noria-data:IPAddress_Router1_Mgmt
    a observable:IPAddress ;
    observable:ipAddressValue "10.0.0.1"^^xsd:string ;
    rdfs:label "Router1 Management IP"@en .

