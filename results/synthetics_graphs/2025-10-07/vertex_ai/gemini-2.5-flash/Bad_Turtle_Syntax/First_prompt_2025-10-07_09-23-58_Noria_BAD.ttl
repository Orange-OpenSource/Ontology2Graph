# --- Event Records ---
noria-data:EventRecord_Router1_LinkDown
    a noria:EventRecord ;
    rdfs:label "Router1 Link Down Event"@en ;
    rdfs:comment "An event indicating a network interface went down on Router1."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject noria-data:Resource_Router1 ;
    noria:logOriginatingManagementSystem noria-data:Application_MonitoringSystem ;
    noria:alarmSeverity noria-kos:notification-severity/Critical .

noria-data:EventRecord_DBServer_HighCPU
    a noria:EventRecord ;
    rdfs:label "DB Server High CPU Warning"@en ;
    rdfs:comment "An event indicating high CPU usage on the database server."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization exceeded 90% for 5 minutes on db-server-01"^^xsd:string ;
    noria:logOriginatingManagedObject noria-data:Resource_ServerDB1 ;
    noria:logOriginatingManagementSystem noria-data:Application_MonitoringSystem ;
    noria:alarmSeverity noria-kos:notification-severity/Warning .

noria-data:EventRecord_UserLoginFailure
    a noria:EventRecord ;
    rdfs:label "User Login Failure Event"@en ;
    rdfs:comment "An event recording a failed login attempt by a user."@en ;
    noria:loggingTime "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:logText "Failed login attempt for user 'intruder' from IP 192.168.1.100"^^xsd:string ;
    noria:logOriginatingManagedObject noria-data:Application_WebApp ;
    noria:logOriginatingManagementSystem noria-data:Application_MonitoringSystem ;
    noria:logOriginatingAgent noria-data:Agent_UnknownAttacker ; # Example of an unknown agent
    noria:alarmSeverity noria-kos:notification-severity/Warning .

noria-data:Agent_UnknownAttacker
    a foaf:Agent ;
    rdfs:label "Unknown Attacker"@en ;
    rdfs:comment "An unknown agent attempting unauthorized access."@en .

# --- Trouble Tickets ---
noria-data:TroubleTicket_TT001
    a noria:TroubleTicket ;
    rdfs:label "TT001 - Core Router Link Down"@en ;
    rdfs:comment "Trouble ticket for critical link failure on Core Router 1."@en ;
    dcterms:identifier "TT001"^^xsd:string ;
    dcterms:created "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CUST-INC-987"^^xsd:string ;
    noria:documentHRef "https://ticketing.example.com/TT001"^^xsd:anyURI ;
    noria:troubleTicketSeverity noria-kos:tt-severity/Critical ;
    noria:troubleTicketType noria-kos:tt-type/Failure ;
    noria:troubleTicketCriticity noria-kos:tt-criticity/InterruptedService ;
    noria:troubleTicketPriority noria-kos:tt-priority/P1 ;
    noria:troubleTicketOrigin noria-kos:tt-origin/Customer ;
    noria:troubleTicketTrigger noria-data:EventRecord_Router1_LinkDown ;
    noria:troubleTicketUrgency noria-kos:tt-urgency/ImmediateIntervention ;
    noria:troubleTicketSupervisionTool "NMS-Tool-X"^^xsd:string ;
    noria:troubleTicketCategory noria-kos:tt-category/TotalBreakdown ;
    noria:problemCategory noria-kos:tt-category/TotalBreakdown ;
    noria:troubleTicketCause "Fiber cut detected on external link."^^xsd:string ;
    noria:problemResponsibility noria-kos:tt-problem-responsibility/ManagedBackbone ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T13:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent noria-kos:tt-status/InProgress ;
    noria:troubleTicketRelatedParty noria-data:Agent_BobJohnson ;
    noria:troubleTicketRelatedService noria-data:Service_CustomerInternetAccess ;
    noria:troubleTicketRelatedResource noria-data:Resource_Router1 ;
    noria:troubleTicketImpacts noria-data:Application_WebApp, noria-data:Service_CustomerInternetAccess, noria-data:Resource_Router1 ;
    noria:troubleTicketCharacteristic noria-data:TTChar_HighImpact ;
    noria:troubleTicketFreezeItem noria-data:EventRecord_TT001_FreezeStart ;
    noria:documentStatusHistory noria-data:EventRecord_TT001_StatusChange1 .

noria-data:TTChar_HighImpact
    a skos:Concept ; # Representing a characteristic as a concept
    rdfs:label "High Impact Incident"@en ;
    rdfs:comment "Characteristic: This incident has a high business impact."@en .

noria-data:EventRecord_TT001_FreezeStart
    a noria:EventRecord ;
    rdfs:label "TT001 Freeze Start"@en ;
    rdfs:comment "Event marking the start of a freeze period for TT001."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Trouble ticket TT001 frozen due to external dependency."^^xsd:string .

noria-data:EventRecord_TT001_StatusChange1
    a noria:EventRecord ;
    rdfs:label "TT001 Status Change to InProgress"@en ;
    rdfs:comment "Event recording status change of TT001."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Status changed from Initialised to InProgress."^^xsd:string .

noria-data:TroubleTicket_TT002
    a noria:TroubleTicket ;
    rdfs:label "TT002 - Web App Performance Degradation"@en ;
    rdfs:comment "Trouble ticket for performance issues on the Customer Web Application."@en ;
    dcterms:identifier "TT002"^^xsd:string ;
    dcterms:created "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:documentHRef "https://ticketing.example.com/TT002"^^xsd:anyURI ;
    noria:troubleTicketSeverity noria-kos:tt-severity/Major ;
    noria:troubleTicketType noria-kos:tt-type/Assistance ;
    noria:troubleTicketOrigin noria-kos:tt-origin/Customer ;
    noria:troubleTicketTrigger noria-data:EventRecord_DBServer_HighCPU ;
    noria:troubleTicketStatusCurrent noria-kos:tt-status/InProgress ;
    noria:troubleTicketRelatedParty noria-data:Agent_AliceSmith ;
    noria:troubleTicketRelatedService noria-data:Application_WebApp ;
    noria:troubleTicketRelatedResource noria-data:Resource_ServerDB1 .

# kos/TroubleTicket/status
noria-kos:tt-status/InProgress
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Trouble Ticket Status: In Progress."@en .

# --- Trouble Ticket Notes ---
noria-data:TroubleTicketNote_TT001_Note1
    a noria:TroubleTicketNote ;
    rdfs:label "TT001 Note 1 - Initial Diagnosis"@en ;
    rdfs:comment "First note on TT001, initial diagnosis."@en ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:creator noria-data:Agent_BobJohnson ;
    dcterms:description "Confirmed link down on GE0/0/1. Initiating fiber check."^^xsd:string ;
    dcterms:isPartOf noria-data:TroubleTicket_TT001 ;
    noria:troubleTicketNoteCommentType noria-kos:tt-comment-type/Internal ;
    noria:troubleTicketNoteOperationType noria-kos:tt-operation-type/Diagnosis .

noria-data:TroubleTicketNote_TT001_Note2
    a noria:TroubleTicketNote ;
    rdfs:label "TT001 Note 2 - Resolution Attempt"@en ;
    rdfs:comment "Second note on TT001, detailing resolution attempt."@en ;
    dcterms:created "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    dcterms:creator noria-data:Agent_BobJohnson ;
    dcterms:description "Re-seated SFP module. Link still down. Escalating to L3."^^xsd:string ;
    dcterms:isPartOf noria-data:TroubleTicket_TT001 ;
    noria:troubleTicketNoteCommentType noria-kos:tt-comment-type/Internal ;
    noria:troubleTicketNoteOperationType noria-kos:tt-operation-type/Diagnosis ;
    noria:troubleTicketNoteCorrelatedExecution noria-data:ProcedureExecutionContainer_SFP_Reseat .

noria-data:ProcedureExecutionContainer_SFP_Reseat
    a pep:ProcedureExecutionContainer ;
    rdfs:label "SFP Reseat Procedure Execution"@en ;
    rdfs:comment "Container for actions related to SFP reseating."@en ;
    pep:hasMember noria-data:EventRecord_SFP_Reseat_Action .

noria-data:EventRecord_SFP_Reseat_Action
    a noria:EventRecord ;
    rdfs:label "SFP Reseat Command Log"@en ;
    rdfs:comment "Log of command executed to reseat SFP."@en ;
    noria:loggingTime "2024-04-20T10:55:00Z"^^xsd:dateTime ;
    noria:logText "Executed 'interface GigabitEthernet0/0/1; shutdown; no shutdown' on Router1."^^xsd:string ;
    noria:logOriginatingManagedObject noria-data:Resource_Router1 ;
    noria:logOriginatingAgent noria-data:Agent_BobJohnson .

