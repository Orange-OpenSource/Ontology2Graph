# --- Network Interfaces ---
noria-data:NetworkInterface_Router1_GE0_0_1
    a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Router1"@en ;
    rdfs:comment "Physical interface on Core Router 1."@en ;
    noria:networkInterfaceDescription "Uplink to ISP backbone"^^xsd:string ;
    noria:networkInterfaceType noria-kos:resource-type/Router ; # Reusing resource type for interface type for simplicity
    noria:networkInterfaceAdministrativeStatus noria-kos:resource-admin-state/Enabled ;
    noria:networkInterfaceOperationalStatus noria-kos:resource-op-state/Up ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-1"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int ;
    noria:networkInterfaceOf noria-data:Resource_Router1 .

noria-data:NetworkInterface_ServerDB1_Eth0
    a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on DB Server 1"@en ;
    rdfs:comment "Network interface for database server."@en ;
    noria:networkInterfaceDescription "Primary network interface"^^xsd:string ;
    noria:networkInterfaceType noria-kos:resource-type/Server ; # Reusing resource type for interface type for simplicity
    noria:networkInterfaceAdministrativeStatus noria-kos:resource-admin-state/Enabled ;
    noria:networkInterfaceOperationalStatus noria-kos:resource-op-state/Up ;
    noria:networkInterfaceOf noria-data:Resource_ServerDB1 .

