# --- Anomaly Patterns ---
noria-data:AnomalyPattern_HighCPU_LowThroughput
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Low Throughput Anomaly"@en ;
    rdfs:comment "Anomaly pattern: High CPU usage combined with low network throughput, indicating a potential bottleneck or misconfiguration."@en ;
    folio:hasCause noria-data:ActionPreCondition_HighCPU_LowThroughput .

# --- Operation Plans ---
noria-data:OperationPlan_RouterOSUpgrade
    a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems."@en ;
    noria:operationPlanPreCondition noria-data:ActionPreCondition_RouterOSUpgrade ;
    noria:operationPlanPostCondition noria-data:ActionPostCondition_RouterOSUpgrade .

noria-data:OperationPlan_TroubleshootLink
    a noria:OperationPlan ;
    rdfs:label "Troubleshoot Network Link Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving network link issues."@en ;
    noria:operationPlanPreCondition noria-data:ActionPreCondition_LinkDown ;
    noria:operationPlanPostCondition noria-data:ActionPostCondition_LinkUp .

# --- Action Pre/Post Conditions ---
noria-data:ActionPreCondition_RouterOSUpgrade
    a noria:ActionPreCondition ;
    rdfs:label "Router OS Upgrade Pre-Condition"@en ;
    rdfs:comment "Pre-conditions for router OS upgrade: backup complete, maintenance window approved."@en .

noria-data:ActionPostCondition_RouterOSUpgrade
    a noria:ActionPostCondition ;
    rdfs:label "Router OS Upgrade Post-Condition"@en ;
    rdfs:comment "Post-conditions for router OS upgrade: OS version verified, network connectivity restored."@en .

noria-data:ActionPreCondition_LinkDown
    a noria:ActionPreCondition ;
    rdfs:label "Network Link Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition for troubleshooting: network interface operational status is 'down'."@en .

noria-data:ActionPostCondition_LinkUp
    a noria:ActionPostCondition ;
    rdfs:label "Network Link Up Post-Condition"@en ;
    rdfs:comment "Post-condition for troubleshooting: network interface operational status is 'up'."@en .

noria-data:ActionPreCondition_HighCPU_LowThroughput
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Low Throughput Pre-Condition"@en ;
    rdfs:comment "Pre-condition for anomaly: CPU usage > 90% and network throughput < 10% of capacity."@en .

# --- Linking Operations to Procedures ---
noria-data:CorrectiveMaintenanceAction_TT001_L3Escalation
    a pep:CorrectiveMaintenanceAction ;
    rdfs:label "TT001 L3 Escalation Action"@en ;
    rdfs:comment "Action to escalate TT001 to L3 support."@en ;
    noria:actionCorrelatedOperationPlan noria-data:OperationPlan_TroubleshootLink .

noria-data:ChangeAction_CR001_ExecuteUpgrade
    a pep:ChangeAction ;
    rdfs:label "CR001 Execute Upgrade Action"@en ;
    rdfs:comment "Action to execute the OS upgrade for CR001."@en ;
    noria:actionCorrelatedOperationPlan noria-data:OperationPlan_RouterOSUpgrade .

