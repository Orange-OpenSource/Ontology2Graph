noria-data:EventRecord_CR001_StatusChange1
    a noria:EventRecord ;
    rdfs:label "CR001 Status Change to Approved"@en ;
    rdfs:comment "Event recording status change of CR001."@en ;
    noria:loggingTime "2024-04-18T16:00:00Z"^^xsd:dateTime ;
