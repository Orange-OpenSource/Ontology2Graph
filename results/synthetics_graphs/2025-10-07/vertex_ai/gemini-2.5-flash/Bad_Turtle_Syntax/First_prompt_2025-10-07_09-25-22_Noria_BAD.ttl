# --- Procedural Elements (Anomaly Patterns, Operation Plans, Pre/Post Conditions) ---

noria:AnomalyPattern_HighCPUUsage
    a noria:AnomalyPattern ;
    rdfs:label "Anomaly Pattern: High CPU Usage"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage on a critical resource."@en ;
    folio:hasConsequence "Performance degradation, service outage"^^xsd:string .

noria:AnomalyPattern_NetworkLoopDetected
    a noria:AnomalyPattern ;
    rdfs:label "Anomaly Pattern: Network Loop Detected"@en ;
    rdfs:comment "Pattern indicating a network loop, often leading to broadcast storms."@en ;
    folio:hasConsequence "Network instability, packet loss"^^xsd:string .

noria:OperationPlan_RouterRestart
    a noria:OperationPlan ;
    rdfs:label "Operation Plan: Router Restart"@en ;
    rdfs:comment "Standard operating procedure for restarting a network router."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterPingable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterUp .

noria:OperationPlan_AppRollback
    a noria:OperationPlan ;
    rdfs:label "Operation Plan: Application Rollback"@en ;
    rdfs:comment "Procedure to revert an application to a previous stable version."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_AppHealthy ;
    noria:operationPlanPostCondition noria:ActionPostCondition_AppRestored .

noria:ActionPreCondition_RouterPingable
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Router Pingable"@en ;
    rdfs:comment "Condition: The router must be reachable via ICMP before proceeding."@en .

noria:ActionPreCondition_AppHealthy
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Application Health Check Passed"@en ;
    rdfs:comment "Condition: Application health checks must pass before rollback."@en .

noria:ActionPostCondition_RouterUp
    a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Router Interfaces Up"@en ;
    rdfs:comment "Expected outcome: All critical router interfaces are operational."@en .

noria:ActionPostCondition_AppRestored
    a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Application Functionality Restored"@en ;
    rdfs:comment "Expected outcome: Application is fully functional and responsive."@en .

# --- Linking Dynamic and Procedural Elements ---

noria:EventRecord_RouterDown
    noria:alarmMitigatedBy noria:TroubleTicket_001 . # The TT is the container for mitigation actions

noria:EventRecord_ConfigChange
    noria:actionCorrelatedOperationPlan noria:OperationPlan_FirewallUpdate ; # Assuming a specific OpPlan for firewall updates
    noria:alarmMitigatedBy noria:ChangeRequest_001 .

noria:OperationPlan_FirewallUpdate
    a noria:OperationPlan ;
    rdfs:label "Operation Plan: Firewall Rule Update"@en ;
    rdfs:comment "Specific procedure for updating firewall rules."@en .

noria:TroubleTicket_001
    noria:documentStatusHistory noria:EventRecord_RouterDown . # Example of status history

noria:ChangeRequest_001
    noria:documentStatusHistory noria:EventRecord_ConfigChange . # Example of status history

