# Organizations and Agents
noria-inst:Org/ITOperations
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The main IT operations department responsible for infrastructure."@en ;
    org:unitOf noria-inst:Org/GlobalCorp .

noria-inst:Org/NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf noria-inst:Org/ITOperations ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:contactMethod/Email ;
    noria:agentInstructions "Contact via ticketing system for all issues."^^xsd:string .

noria-inst:Org/AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    org:unitOf noria-inst:Org/ITOperations ;
    noria:agentWorkingHours "24/7 On-call"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:contactMethod/Phone ;
    noria:agentInstructions "For critical issues, call hotline immediately."^^xsd:string .

noria-inst:Org/GlobalCorp
    a org:Organization ;
    rdfs:label "GlobalCorp Inc."@en ;
    rdfs:comment "A global technology corporation."@en .

noria-inst:Person/AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@globalcorp.com> ;
    org:memberOf noria-inst:Org/NetworkTeam ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:contactMethod/Email ;
    noria:agentInstructions "Email for non-urgent matters, direct call for emergencies."^^xsd:string .

noria-inst:Person/BobJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Manager."@en ;
    foaf:mbox <mailto:bob.johnson@globalcorp.com> ;
    org:memberOf noria-inst:Org/AppSupportTeam ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:contactMethod/Phone ;
    noria:agentInstructions "Always available for critical application issues."^^xsd:string .

noria-inst:Person/CharlieBrown
    a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "IT Security Analyst."@en ;
    foaf:mbox <mailto:charlie.brown@globalcorp.com> ;
    org:memberOf noria-inst:Org/ITOperations ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:contactMethod/Email ;
    noria:agentInstructions "Report security incidents via dedicated portal."^^xsd:string .

noria-inst:UserAccount/ASmithCorpID
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith"@xsd:string ;
    observable:accountLogin "asmith"@xsd:string ;
    observable:accountIdentifier "AS0012345"@xsd:string ;
    foaf:holdsAccount noria-inst:Person/AliceSmith .

noria-inst:UserAccount/BJohnsonCorpID
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"@xsd:string ;
    observable:accountLogin "bjohnson"@xsd:string ;
    observable:accountIdentifier "BJ0067890"@xsd:string ;
    foaf:holdsAccount noria-inst:Person/BobJohnson .

# Locations
noria-inst:Site/DataCenterA
    a bot:Site ;
    rdfs:label "Main Data Center A"@en ;
    rdfs:comment "Primary data center facility for GlobalCorp."@en ;
    noria:siteId "DC-A-01"^^xsd:string ;
