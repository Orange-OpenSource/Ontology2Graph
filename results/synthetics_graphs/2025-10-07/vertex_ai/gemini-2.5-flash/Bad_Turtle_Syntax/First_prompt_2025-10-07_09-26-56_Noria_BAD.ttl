# SKOS Concept Schemes and Concepts for various controlled vocabularies
noria-inst:kos/application/type
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

noria-inst:appType/ServicePlatform
    a skos:Concept ;
    skos:inScheme noria-inst:kos/application/type ;
