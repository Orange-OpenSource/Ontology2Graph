ex:Event_RouterCPUHigh
    a noria:EventRecord ;
    rdfs:label "Router CPU High Alert"@en ;
    rdfs:comment "Event record for high CPU utilization on Router01."@en ;
    noria:loggingTime "2024-03-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on router-core-01.example.com exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject ex:Resource_Router01 ;
    noria:logOriginatingManagementSystem ex:App_NetworkMgmt ;
    noria:alarmSeverity ex:PerceivedCritical ;
    noria:alarmProposedRepairAction ex:OP_RouterRestart ;
    noria:alarmMitigatedBy ex:PEC_RouterRestart_TT100 ;
    noria:alarmProbableCause ex:HighCPUProbableCause .

