# --- foaf:Agent and org:OrganizationalUnit instances ---

ex:Agent_JohnDoe
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee responsible for network operations."@en ;
    foaf:name "John Doe"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent issues."^^xsd:string ;
    noria:agentPreferredContactMethod ex:EmailContact ;
    noria:agentManagesResource ex:Resource_Router01 .

ex:Agent_JaneSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An employee leading the application support team."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Call hotline for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod ex:PhoneContact ;
    noria:agentManagesResource ex:Resource_Server01 .

ex:Agent_AliceBrown
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Brown"@en ;
    rdfs:comment "A network engineer."@en ;
    foaf:name "Alice Brown"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Email for routine tasks."^^xsd:string ;
    noria:agentPreferredContactMethod ex:EmailContact .

ex:OrgUnit_NetworkOps
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf ex:Org_GlobalIT ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod ex:PhoneContact ;
    noria:agentManagesResource ex:Resource_Router01, ex:Resource_Switch01, ex:NL_Router01_Switch01, ex:NL_Router01_WAN, ex:NL_Switch01_Server01 .

ex:OrgUnit_AppSupport
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Level 2 support for critical applications."@en ;
    org:unitOf ex:Org_GlobalIT ;
    noria:agentWorkingHours "8:00-18:00 Mon-Sat"^^xsd:string ;
    noria:agentInstructions "Escalate via internal tool."^^xsd:string ;
    noria:agentPreferredContactMethod ex:EmailContact ;
    noria:agentManagesResource ex:Resource_Server01, ex:Resource_Controller01 .

ex:OrgUnit_Hotline
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Hotline Team"@en ;
    rdfs:comment "First line support for all IT issues."@en ;
    org:unitOf ex:Org_GlobalIT ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Direct calls only."^^xsd:string ;
    noria:agentPreferredContactMethod ex:PhoneContact .

ex:Org_GlobalIT
    a org:Organization, foaf:Agent ;
    rdfs:label "Global IT Solutions Inc."@en ;
    rdfs:comment "The main IT organization."@en ;
    foaf:name "Global IT Solutions Inc."^^xsd:string .

ex:Org_Cisco
    a org:Organization, foaf:Agent ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

ex:Org_HP
