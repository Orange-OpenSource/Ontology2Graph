# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# --- Synthetic Graph Specific ---
@prefix ex: <https://w3id.org/noria/example/> .
@prefix kos: <https://w3id.org/noria/kos/> . # Re-declaring kos for clarity, as it's used in the schema for concept schemes.

# =============================================================================
# Synthetic Knowledge Graph
# =============================================================================

# --- SKOS Concepts for ObjectProperty Ranges ---

kos:org/agent-contact-method
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

ex:EmailContact
    a skos:Concept ;
    skos:inScheme kos:org/agent-contact-method ;
    rdfs:label "Email Contact"@en ;
    rdfs:comment "Preferred contact method is email."@en .

ex:PhoneContact
    a skos:Concept ;
    skos:inScheme kos:org/agent-contact-method ;
    rdfs:label "Phone Contact"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

kos:application/type
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

ex:WebApplication
    a skos:Concept ;
    skos:inScheme kos:application/type ;
    rdfs:label "Web Application"@en ;
    rdfs:comment "An application accessible via a web browser."@en .

ex:DatabaseApplication
    a skos:Concept ;
    skos:inScheme kos:application/type ;
    rdfs:label "Database Application"@en ;
    rdfs:comment "An application primarily interacting with a database."@en .

ex:MonitoringApplication
    a skos:Concept ;
    skos:inScheme kos:application/type ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "An application used for system monitoring."@en .

kos:application/business-importance
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

ex:CriticalImportance
    a skos:Concept ;
    skos:inScheme kos:application/business-importance ;
    rdfs:label "Critical Importance"@en ;
    rdfs:comment "Application is critical for business operations."@en .

ex:HighImportance
    a skos:Concept ;
    skos:inScheme kos:application/business-importance ;
    rdfs:label "High Importance"@en ;
    rdfs:comment "Application has high business importance."@en .

kos:application/sla-level
    a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying Service Level Agreement levels for applications."@en .

ex:SLA_P1
    a skos:Concept ;
    skos:inScheme kos:application/sla-level ;
    rdfs:label "SLA Priority 1"@en ;
    rdfs:comment "Highest SLA level, requiring immediate attention."@en .

ex:SLA_P2
    a skos:Concept ;
    skos:inScheme kos:application/sla-level ;
    rdfs:label "SLA Priority 2"@en ;
    rdfs:comment "High SLA level, requiring prompt attention."@en .

kos:application/status
    a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of applications."@en .

ex:InProduction
    a skos:Concept ;
    skos:inScheme kos:application/status ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application is currently in production."@en .

ex:Development
    a skos:Concept ;
    skos:inScheme kos:application/status ;
    rdfs:label "Development"@en ;
    rdfs:comment "Application is in development phase."@en .

kos:service/type
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

ex:CustomerFacingService
    a skos:Concept ;
    skos:inScheme kos:service/type ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by customers."@en .

ex:ResourceFacingService
    a skos:Concept ;
    skos:inScheme kos:service/type ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that manages underlying resources."@en .

