ex:CR_2024_001
    a noria:ChangeRequest ;
    rdfs:label "Router Firmware Upgrade"@en ;
    rdfs:comment "Change request for upgrading firmware on Core Router 01."@en ;
    noria:documentExternalId "EXT-CR-001"^^xsd:string ;
