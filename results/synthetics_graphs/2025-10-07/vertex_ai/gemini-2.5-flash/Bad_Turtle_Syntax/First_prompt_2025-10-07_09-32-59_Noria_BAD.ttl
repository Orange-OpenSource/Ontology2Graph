    noria:changeRequestPlannedStartTime "2024-04-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-01T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-01T03:45:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory ex:InternalIntervention ;
    noria:changeRequestType ex:StandardChange ;
    noria:changeRequestChangeCause ex:SoftwareUpgrade ;
    noria:changeRequestImpact ex:Resource_Router01, ex:Service_CustomerConnectivity ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ;
    noria:changeRequestStatusCurrent ex:CR_Implemented ;
    noria:changeRequestSpecification ex:StandardOperationPlan ;
    noria:changeRequestInitiatorParty ex:Agent_JohnDoe ;
