# foaf:Agent (Persons)
<agent/john_doe>
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee responsible for network operations."@en ;
    foaf:name "John Doe"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string .

<agent/jane_smith>
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An employee leading the application support team."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_1> ;
    noria:agentInstructions "Call directly for critical application issues."^^xsd:string .

<agent/alice_williams>
    a foaf:Agent ;
    rdfs:label "Alice Williams"@en ;
    rdfs:comment "A senior network engineer."@en ;
    foaf:name "Alice Williams"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Email_extra_node_1 for routine changes, phone for emergencies."^^xsd:string .

<agent/bob_johnson>
    a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "A software developer and application owner."@en ;
    foaf:name "Bob Johnson"^^xsd:string ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Submit tickets via JIRA, then email."^^xsd:string .

<agent/charlie_brown>
    a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "A junior network technician."@en ;
    foaf:name "Charlie Brown"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_1> ;
    noria:agentInstructions "Escalate to senior staff for complex issues."^^xsd:string .

# org:OrganizationalUnit (Teams)
<orgunit/network_ops_team>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for 24/7 network infrastructure monitoring and maintenance."@en ;
    org:unitOf <org/it_department> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_1> ;
    noria:agentInstructions "Use emergency hotline for critical network incidents."^^xsd:string ;
    org:hasMember <agent/john_doe> , <agent/alice_williams> , <agent/charlie_brown> .

<orgunit/app_support_team>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing level 2 support for critical business applications."@en ;
    org:unitOf <org/it_department> ;
    noria:agentWorkingHours "8:00-20:00 Mon-Sun"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Open a ticket in the ITSM system first."^^xsd:string ;
    org:hasMember <agent/jane_smith> .

<orgunit/devops_team_alpha>
    a org:OrganizationalUnit ;
    rdfs:label "DevOps Team Alpha"@en ;
    rdfs:comment "Team responsible for development and operations of core services."@en ;
    org:unitOf <org/it_department> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Contact via internal chat for urgent development issues."^^xsd:string ;
    org:hasMember <agent/bob_johnson> .

# org:Organization (Departments/Companies)
<org/it_department>
    a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department."@en ;
    org:hasUnit <orgunit/network_ops_team> , <orgunit/app_support_team> , <orgunit/devops_team_alpha> .

<org/manufacturer_cisco>
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "A leading manufacturer of networking hardware."@en .

<org/manufacturer_dell>
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "A multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

