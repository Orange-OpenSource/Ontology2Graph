# pep:Procedure (for alarmProposedRepairAction)
<procedure/restart_service>
    a pep:Procedure ;
    rdfs:label "Restart Application Service"@en ;
    rdfs:comment "Procedure to restart a failed application service."@en .

<procedure/check_network_connectivity>
    a pep:Procedure ;
    rdfs:label "Check Network Connectivity"@en ;
    rdfs:comment "Procedure to diagnose network connectivity issues."@en .

# pep:ProcedureExecutionContainer (for troubleTicketNoteCorrelatedExecution and alarmMitigatedBy)
<pep/execution_container_001>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution Container for TT-2024-001"@en ;
    rdfs:comment "Container for actions related to Trouble Ticket TT-2024-001."@en ;
    noria:actionCorrelatedOperationPlan <operationplan/router_reboot> .

<pep/execution_container_002>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution Container for CR-2024-001"@en ;
    rdfs:comment "Container for actions related to Change Request CR-2024-001."@en ;
    noria:actionCorrelatedOperationPlan <operationplan/app_patch_deployment> .

# noria:EventRecord
<eventrecord/router_interface_down>
    a noria:EventRecord ;
    rdfs:label "Router_extra_node_1 Interface Down Event"@en ;
    rdfs:comment "An event indicating a network interface on Router_extra_node_1-01 went down."@en ;
    noria:logOriginatingManagedObject <resource/router_01> ;
    noria:logOriginatingManagementSystem <application/core_network_infra> ;
    noria:logOriginatingAgent <agent/john_doe> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"^^xsd:string ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_1> ;
    noria:alarmProposedRepairAction <procedure/check_network_connectivity> ;
    noria:alarmMonitoredAttribute <kos/Resource/OperationalState/Down> ;
    noria:alarmMitigatedBy <pep/execution_container_001> ;
    dcterms:relation <anomalypattern/link_flapping> .

<eventrecord/app_service_restart>
    a noria:EventRecord ;
    rdfs:label "Application Service Restart Event"@en ;
    rdfs:comment "An event indicating a restart of the CRM production module service."@en ;
    noria:logOriginatingManagedObject <application/crm_system> ;
    noria:logOriginatingManagementSystem <applicationmodule/crm_prod_module> ;
    noria:logOriginatingAgent <agent/jane_smith> ;
    noria:logText "CRM_PROD_MODULE_01 service restarted successfully."^^xsd:string ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmProposedRepairAction <procedure/restart_service> ;
    dcterms:relation <anomalypattern/high_cpu_usage> .

<eventrecord/config_change_router_02>
    a noria:EventRecord ;
    rdfs:label "Router_extra_node_1-02 Configuration Change Event"@en ;
    rdfs:comment "An event recording a configuration change on Router_extra_node_1-02."@en ;
    noria:logOriginatingManagedObject <resource/router_02> ;
    noria:logOriginatingManagementSystem <application/core_network_infra> ;
    noria:logOriginatingAgent <agent/alice_williams> ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by alice_williams (192.168.1.10)"^^xsd:string ;
    noria:loggingTime "2024-04-19T15:45:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

<eventrecord/server_cpu_spike>
    a noria:EventRecord ;
    rdfs:label "Server_extra_node_1 CPU Spike Alert"@en ;
    rdfs:comment "An alert indicating a sudden spike in CPU usage on Server_extra_node_1-01."@en ;
    noria:logOriginatingManagedObject <resource/server_01> ;
    noria:logOriginatingManagementSystem <application/crm_system> ;
    noria:logText "CPU usage on app-srv-01 exceeded 90% for 5 minutes."^^xsd:string ;
    noria:loggingTime "2024-04-21T11:20:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_1> ;
