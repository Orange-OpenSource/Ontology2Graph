    noria:agentWorkingHours "08:30-16:30 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_2> ;
    noria:agentInstructions "Call directly for network emergencies."^^xsd:string ;
.

