foaf:Person_AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"^^xsd:string ;
    rdfs:comment "An employee, Alice Smith, working in the IT department."^^xsd:string ;
    foaf:name "Alice Smith"^^xsd:string ;
    foaf:mbox "mailto:alice.smith@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_2> ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
.

