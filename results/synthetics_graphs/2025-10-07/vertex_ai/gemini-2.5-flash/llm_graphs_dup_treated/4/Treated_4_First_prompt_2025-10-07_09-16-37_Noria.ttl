# --- foaf:Agent and org:OrganizationalUnit instances ---

<agent/JohnDoe>
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee responsible for IT operations."@en ;
    foaf:mbox "mailto:john.doe@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string .

<agent/JaneSmith>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A senior engineer and team lead."@en ;
    foaf:mbox "mailto:jane.smith@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_0> ;
    noria:agentInstructions "Call directly for critical issues."^^xsd:string .

<org/ITOperationsTeam>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for daily IT operations."@en ;
    org:unitOf <org/GlobalITDepartment> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_0> ;
    noria:agentInstructions "Use ticketing system for all requests, call hotline for P1_extra_node_0/P2."^^xsd:string .

<org/NetworkSupportTeam>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Support Team"@en ;
    rdfs:comment "Team specializing in network infrastructure support."@en ;
    org:unitOf <org/ITOperationsTeam> ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> ;
    noria:agentInstructions "Submit network-related tickets to this team."^^xsd:string .

<org/GlobalITDepartment>
    a org:Organization, foaf:Agent ;
    rdfs:label "Global IT Department"@en ;
    rdfs:comment "The overarching IT organization."@en .

<org/AcmeCorp>
    a org:Organization, foaf:Agent ;
    rdfs:label "Acme Corp"@en ;
    rdfs:comment "A fictional manufacturer of IT equipment."@en .

# --- bot:Site, noria:Room, noria:Locus instances ---

<site/DataCenterParis>
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

<site/OfficeLondon>
    a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:comment "Corporate office building in London."@en ;
    noria:siteId "OFF-LDN-01"^^xsd:string ;
    noria:siteType "building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Baker Street"^^xsd:string ;
    noria:sitePrincipalAddressCityName "London"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE"^^xsd:string ;
    noria:sitePrincipalAddressCountry "UK"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Baker Street"^^xsd:string .

<room/ServerRoomA>
    a noria:Room ;
    rdfs:label "Server_extra_node_0 Room A"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace <locus/RackA1L1>, <locus/RackA2L1> ;
    bot:hasElement <resource/Server001>, <resource/Router001> .

<room/NetworkClosetB>
    a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "A network closet in the London Office."@en ;
    bot:hasSpace <locus/RackB1L1> ;
    bot:hasElement <resource/Switch001> .

<locus/RackA1L1>
    a noria:Locus ;
    rdfs:label "Rack A1, Locus 1"@en ;
    rdfs:comment "Specific location for equipment in Server_extra_node_0 Room A."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

<locus/RackA2L1>
    a noria:Locus ;
    rdfs:label "Rack A2, Locus 1"@en ;
    rdfs:comment "Specific location for equipment in Server_extra_node_0 Room A."@en ;
    noria:locusLine "A2"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

<locus/RackB1L1>
    a noria:Locus ;
    rdfs:label "Rack B1, Locus 1"@en ;
    rdfs:comment "Specific location for equipment in Network Closet B."@en ;
    noria:locusLine "B1"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

