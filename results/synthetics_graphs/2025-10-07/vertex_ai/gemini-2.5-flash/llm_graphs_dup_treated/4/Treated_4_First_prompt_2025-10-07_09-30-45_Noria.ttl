# --- Agents and Organizations ---

<agent/JohnDoe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A synthetic employee, manager of IT Operations."@en ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<agent/JaneSmith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A synthetic employee, lead of Network Operations."@en ;
    noria:agentWorkingHours "8:30 AM - 4:30 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Always use the ticketing system first."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<agent/AliceJohnson>
    a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "A synthetic employee, application support specialist."@en ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Escalate to L2 support for complex application issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<org/ITOperations>
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Manages the day-to-day operations of IT infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentInstructions "Follow escalation matrix for critical incidents."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<org/NetworkTeam>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Responsible for network infrastructure management."@en ;
    noria:agentWorkingHours "8:00 AM - 6:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit a change request for any network configuration changes."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<org/AppSupportTeam>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Provides technical support for business applications."@en ;
    noria:agentWorkingHours "8:00 AM - 8:00 PM (Mon-Sat)"^^xsd:string ;
    noria:agentInstructions "Prioritize tickets based on business impact."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<org/AcmeCorp>
    a org:Organization ;
    rdfs:label "Acme Corporation"@en ;
    rdfs:comment "A fictional technology company, also acting as a manufacturer for synthetic data."@en ;
    noria:agentWorkingHours "General business hours"^^xsd:string ;
    noria:agentInstructions "Refer to corporate guidelines."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

