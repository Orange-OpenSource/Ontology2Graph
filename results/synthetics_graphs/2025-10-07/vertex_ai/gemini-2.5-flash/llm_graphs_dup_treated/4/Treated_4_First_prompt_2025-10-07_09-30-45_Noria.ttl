# --- Anomaly Patterns ---

<anomalypattern/High_CPU_Low_Traffic>
    a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Traffic Anomaly"@en ;
    rdfs:comment "Anomaly pattern: high CPU usage on a server with unexpectedly low network traffic, indicating a potential runaway process or internal loop."@en .

<anomalypattern/Link_Flap_High_Error>
    a noria:AnomalyPattern ;
    rdfs:label "Link Flap with High Error Rate Anomaly"@en ;
    rdfs:comment "Anomaly pattern: network interface repeatedly going up/down accompanied by a high error rate, suggesting physical layer issues or faulty transceiver."@en .

<anomalypattern/Disk_Full_No_Growth_Alert>
    a noria:AnomalyPattern ;
    rdfs:label "Disk Full with No Recent Growth Anomaly"@en ;
    rdfs:comment "Anomaly pattern: disk space reported as full, but no significant data growth observed recently, suggesting a monitoring error or stale data."@en .

# --- Operation Plans ---

<operationplan/Router_Software_Upgrade_Procedure>
    a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router software."@en ;
    noria:operationPlanPreCondition <actionprecondition/Router_Backup_Complete> ;
    noria:operationPlanPostCondition <actionpostcondition/Router_Operational_After_Upgrade> .

<operationplan/Server_Process_Restart_Procedure>
    a noria:OperationPlan ;
    rdfs:label "Server Process Restart Procedure"@en ;
    rdfs:comment "Procedure to identify and restart runaway processes on a server."@en ;
    noria:operationPlanPreCondition <actionprecondition/Server_Monitoring_Active> ;
    noria:operationPlanPostCondition <actionpostcondition/Server_CPU_Normal_After_Restart> .

<operationplan/DB_Index_Optimization_Procedure>
    a noria:OperationPlan ;
    rdfs:label "Database Index Optimization Procedure"@en ;
    rdfs:comment "Procedure for routine database index optimization."@en ;
    noria:operationPlanPreCondition <actionprecondition/DB_Backup_Complete> ;
    noria:operationPlanPostCondition <actionpostcondition/DB_Performance_Improved> .

# --- Action Pre-Conditions ---

<actionprecondition/Router_Backup_Complete>
    a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Complete"@en ;
    rdfs:comment "Pre-condition: Ensure a full configuration backup of the router is completed before proceeding with upgrade."@en .

<actionprecondition/Server_Monitoring_Active>
    a noria:ActionPreCondition ;
    rdfs:label "Server Monitoring Active"@en ;
    rdfs:comment "Pre-condition: Verify that server monitoring is active and alerts are configured before performing process restart."@en .

<actionprecondition/DB_Backup_Complete>
    a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete"@en ;
    rdfs:comment "Pre-condition: Ensure a full backup of the database is completed before performing index optimization."@en .

# --- Action Post-Conditions ---

<actionpostcondition/Router_Operational_After_Upgrade>
    a noria:ActionPostCondition ;
    rdfs:label "Router Operational After Upgrade"@en ;
    rdfs:comment "Post-condition: Verify router is fully operational, all interfaces are up, and routing protocols are stable after software upgrade."@en .

<actionpostcondition/Server_CPU_Normal_After_Restart>
    a noria:ActionPostCondition ;
    rdfs:label "Server CPU Normal After Restart"@en ;
    rdfs:comment "Post-condition: Confirm CPU utilization returns to normal levels after restarting the application process."@en .

<actionpostcondition/DB_Performance_Improved>
    a noria:ActionPostCondition ;
    rdfs:label "Database Performance Improved"@en ;
    rdfs:comment "Post-condition: Verify database query performance has improved after index optimization."@en .

# --- Linking Operation Plans to Actions (via Event Records or Change Requests) ---

<changerequest/CR-20240425-001>
    noria:actionCorrelatedOperationPlan <operationplan/Router_Software_Upgrade_Procedure> .

<troubleticketnote/TT-20240420-002-Note-01>
    noria:troubleTicketNoteCorrelatedExecution <operationplan/Server_Process_Restart_Procedure> .

<changerequest/CR-20240501-002>
    noria:actionCorrelatedOperationPlan <operationplan/DB_Index_Optimization_Procedure> .

<eventrecord/Router_Link_Down_001>
    noria:alarmProposedRepairAction <operationplan/Router_Software_Upgrade_Procedure> .

<eventrecord/Server_CPU_High_001>
    noria:alarmProposedRepairAction <operationplan/Server_Process_Restart_Procedure> .

