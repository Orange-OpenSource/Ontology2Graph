noria-kos:troubleticket-priority
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A scheme for classifying the priority of trouble tickets."@en .

noria-kos:tt-priority-p1
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-priority ;
