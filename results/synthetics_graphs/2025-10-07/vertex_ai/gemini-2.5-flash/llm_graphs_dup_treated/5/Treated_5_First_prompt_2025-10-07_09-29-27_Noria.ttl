# =============================================================================
# Knowledge Organization System (KOS) Concepts
# =============================================================================

noria-kos:agent-contact-method
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

noria-kos:contact-method-email
    a skos:Concept ;
    skos:inScheme noria-kos:agent-contact-method ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via email."@en .

noria-kos:contact-method-phone
    a skos:Concept ;
    skos:inScheme noria-kos:agent-contact-method ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via phone."@en .

noria-kos:contact-method-chat
    a skos:Concept ;
    skos:inScheme noria-kos:agent-contact-method ;
    rdfs:label "Chat"@en ;
    rdfs:comment "Preferred contact method via instant messaging."@en .

noria-kos:application-type
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

noria-kos:app-type-web
    a skos:Concept ;
    skos:inScheme noria-kos:application-type ;
    rdfs:label "Web Application"@en ;
    rdfs:comment "An application accessible via a web browser."@en .

noria-kos:app-type-database
    a skos:Concept ;
    skos:inScheme noria-kos:application-type ;
    rdfs:label "Database System"@en ;
    rdfs:comment "An application primarily for data storage and retrieval."@en .

noria-kos:app-type-monitoring
    a skos:Concept ;
    skos:inScheme noria-kos:application-type ;
    rdfs:label "Monitoring System"@en ;
    rdfs:comment "An application used for system surveillance and alerting."@en .

noria-kos:application-business-importance
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

noria-kos:biz-importance-critical
    a skos:Concept ;
    skos:inScheme noria-kos:application-business-importance ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for core business operations."@en .

noria-kos:biz-importance-high
    a skos:Concept ;
    skos:inScheme noria-kos:application-business-importance ;
    rdfs:label "High"@en ;
    rdfs:comment "Application is highly important for business operations."@en .

noria-kos:biz-importance-medium
    a skos:Concept ;
    skos:inScheme noria-kos:application-business-importance ;
    rdfs:label "Medium"@en ;
    rdfs:comment "Application has moderate business importance."@en .

noria-kos:application-sla-level
    a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying Service Level Agreement levels for application modules."@en .

noria-kos:sla-level-platinum
    a skos:Concept ;
    skos:inScheme noria-kos:application-sla-level ;
    rdfs:label "Platinum SLA"@en ;
    rdfs:comment "Highest Service Level Agreement, maximum availability."@en .

noria-kos:sla-level-gold
    a skos:Concept ;
    skos:inScheme noria-kos:application-sla-level ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "High Service Level Agreement, good availability."@en .

noria-kos:application-status
    a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

noria-kos:app-status-production
    a skos:Concept ;
    skos:inScheme noria-kos:application-status ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application module is live and serving users."@en .

noria-kos:app-status-development
    a skos:Concept ;
    skos:inScheme noria-kos:application-status ;
    rdfs:label "In Development"@en ;
    rdfs:comment "Application module is under active development."@en .

noria-kos:service-type
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

noria-kos:service-type-customer-facing
    a skos:Concept ;
    skos:inScheme noria-kos:service-type ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by customers."@en .

noria-kos:service-type-resource-facing
    a skos:Concept ;
    skos:inScheme noria-kos:service-type ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations."@en .

noria-kos:troubleticket-severity
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .

noria-kos:tt-severity-critical
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-severity ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Highest severity, immediate business impact."@en .

noria-kos:tt-severity-major
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-severity ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant business impact, requires urgent attention."@en .

noria-kos:troubleticket-type
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of trouble tickets."@en .

noria-kos:tt-type-failure
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-type ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Ticket related to a system or service failure."@en .

noria-kos:tt-type-assistance
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-type ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Ticket requesting user assistance."@en .

noria-kos:troubleticket-criticity
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Criticity Scheme"@en ;
    rdfs:comment "A scheme for classifying the criticity of trouble tickets from customer impact."@en .

noria-kos:tt-criticity-interrupted
    a skos:Concept ;
