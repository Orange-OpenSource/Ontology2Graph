    rdfs:comment "Highest priority, requires immediate action."@en .

noria-kos:tt-priority-p2
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-priority ;
    rdfs:label "P2 - High"@en ;
    rdfs:comment "High priority, needs prompt resolution."@en .

noria-kos:troubleticket-origin
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

noria-kos:tt-origin-customer
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-origin ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Ticket initiated by a customer."@en .

noria-kos:tt-origin-supervision
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-origin ;
    rdfs:label "Supervision System"@en ;
    rdfs:comment "Ticket initiated by an automated monitoring system."@en .

noria-kos:troubleticket-urgency
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A scheme for classifying the urgency of trouble tickets."@en .

noria-kos:tt-urgency-immediate
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-urgency ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action to prevent further damage or restore service."@en .

noria-kos:tt-urgency-deferred
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-urgency ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Can be addressed during scheduled maintenance or lower priority."@en .

noria-kos:troubleticket-trouble-category
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the technical impact or nature of the incident."@en .

noria-kos:tt-category-network-outage
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-trouble-category ;
    rdfs:label "Network Outage"@en ;
    rdfs:comment "Complete loss of network connectivity."@en .

noria-kos:tt-category-server-failure
    a skos:Concept ;
    skos:inScheme noria-kos:troubleticket-trouble-category ;
    rdfs:label "Server Failure"@en ;
