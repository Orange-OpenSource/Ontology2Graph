    a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network interface."@en ;
    noria:operationPlanPreCondition noria-data:PreConditionInterfaceDown ;
    noria:operationPlanPostCondition noria-data:PostConditionInterfaceUp .

noria-data:PreConditionInterfaceDown
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Interface is Down"@en ;
    rdfs:comment "The network interface must be in a 'down' operational state."@en .

noria-data:PostConditionInterfaceUp
    a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Interface is Up"@en ;
    rdfs:comment "The network interface must return to an 'up' operational state."@en .

noria-data:AnomalyPatternHighCPU
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Usage Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage, potentially leading to performance degradation."@en ;
    folio:hasFailureMode noria-data:PerformanceDegradationFM .

noria-data:PerformanceDegradationFM
    a folio:FailureMode ;
    rdfs:label "Performance Degradation Failure Mode"@en ;
    rdfs:comment "A failure mode where system performance is below acceptable thresholds."@en .

# =============================================================================
# Procedure Execution and related
# =============================================================================

noria-data:InterfaceCheckExecution
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Interface Check Execution"@en ;
    rdfs:comment "Container for events related to checking the CoreRouter01 interface."@en ;
    dcterms:member noria-data:EventRecord001 . # Example of ldp:member, though ldp prefix is avoided, dcterms:member is used.

noria-data:RestartInterfaceAction
    a pep:ProcedureExecution ;
    rdfs:label "Restart Interface Action"@en ;
    rdfs:comment "An action to restart the network interface."@en ;
    noria:actionCorrelatedOperationPlan noria-data:RestartInterfaceProcedure ;
    pep:usedProcedure noria-data:RestartInterfaceProcedure ;
    pep:madeBy noria-data:JohnDoe ;
    dcterms:created "2024-04-10T10:35:00Z"^^xsd:dateTime ;
    pep:hasSimpleResult "Interface restart command issued successfully."^^xsd:string .

noria-data:TroubleTicket001
    noria:troubleTicketPartyIntervention noria-data:RestartInterfaceAction .

# =============================================================================
# Additional KOS Concepts for Statuses (not explicitly defined in schema but implied by ranges)
# =============================================================================

noria-kos:tt-status
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of trouble tickets."@en .

noria-kos:tt-status-inprogress
    a skos:Concept ;
    skos:inScheme noria-kos:tt-status ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Trouble ticket is currently being worked on."@en .

noria-kos:tt-status-resolved
    a skos:Concept ;
    skos:inScheme noria-kos:tt-status ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "Trouble ticket has been resolved."@en .

noria-kos:cr-status
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of change requests."@en .

noria-kos:cr-status-scheduled
    a skos:Concept ;
    skos:inScheme noria-kos:cr-status ;
    rdfs:label "Scheduled"@en ;
    rdfs:comment "Change request is approved and scheduled for execution."@en .

noria-kos:cr-status-completed
    a skos:Concept ;
    skos:inScheme noria-kos:cr-status ;
    rdfs:label "Completed"@en ;
    rdfs:comment "Change request has been successfully executed."@en .

# =============================================================================
# Example of a custom characteristic (range for noria:troubleTicketCharacteristic)
# =============================================================================

noria-data:CharacteristicHighImpact
    a noria:Property ; # Using noria:Property as a generic base
    rdfs:label "High Impact Characteristic"@en ;
    rdfs:comment "A characteristic indicating a high business impact."@en ;
    dcterms:description "This incident affects a critical customer-facing service."^^xsd:string .

# =============================================================================
# Additional Event Records for documentStatusHistory and troubleTicketFreezeItem
# =============================================================================

noria-data:EventRecord004
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Event"@en ;
    rdfs:comment "Event indicating TT-20240410-001 was frozen due to external dependency."@en ;
    noria:loggingTime "2024-04-10T10:45:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240410-001 status changed to Frozen. Reason: Awaiting ISP action."^^xsd:string ;
    noria:logOriginatingManagementSystem noria-data:MonitoringDashboardApp ;
    dcterms:type noria-kos:tt-status-frozen . # Assuming a 'frozen' status concept

noria-data:EventRecord005
    a noria:EventRecord ;
    rdfs:label "Change Request Status Update Event"@en ;
    rdfs:comment "Event indicating CR-20240415-001 status changed to Completed."@en ;
    noria:loggingTime "2024-04-15T03:45:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-20240415-001 status changed to Completed. OS upgrade successful."^^xsd:string ;
    noria:logOriginatingManagementSystem noria-data:MonitoringDashboardApp ;
    dcterms:type noria-kos:cr-status-completed .

noria-kos:tt-status-frozen
    a skos:Concept ;
    skos:inScheme noria-kos:tt-status ;
    rdfs:label "Frozen"@en ;
    rdfs:comment "Trouble ticket resolution is paused due to external factors."@en .
