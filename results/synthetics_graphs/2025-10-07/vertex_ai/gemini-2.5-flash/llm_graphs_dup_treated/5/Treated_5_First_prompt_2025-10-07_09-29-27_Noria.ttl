noria-kos:res-type-router
    a skos:Concept ;
    skos:inScheme noria-kos:resource-type ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router."@en .

noria-kos:res-type-switch
    a skos:Concept ;
    skos:inScheme noria-kos:resource-type ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network switch."@en .

noria-kos:resource-lifecycle-state
    a skos:ConceptScheme ;
