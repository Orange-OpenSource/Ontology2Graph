noria-kos:cr-category-internal
    a skos:Concept ;
    skos:inScheme noria-kos:changerequest-category ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change initiated and executed by internal teams."@en .

noria-kos:cr-category-customer
    a skos:Concept ;
    skos:inScheme noria-kos:changerequest-category ;
    rdfs:label "Customer Requested Change"@en ;
    rdfs:comment "Change requested by a customer."@en .

noria-kos:changerequest-type
    a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the impact and risk level of change requests."@en .

noria-kos:cr-type-standard
    a skos:Concept ;
    skos:inScheme noria-kos:changerequest-type ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Pre-approved, low-risk, routine change."@en .

noria-kos:cr-type-major
    a skos:Concept ;
    skos:inScheme noria-kos:changerequest-type ;
    rdfs:label "Major Change"@en ;
    rdfs:comment "High-risk, significant impact change."@en .

noria-kos:changerequest-cause
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying the reason for change requests."@en .

noria-kos:cr-cause-upgrade
    a skos:Concept ;
    skos:inScheme noria-kos:changerequest-cause ;
    rdfs:label "Software Upgrade"@en ;
