Line : foaf:topic_interest <application/crm_system> .
Line : <agent/alice_williams> noria:agentManagesResource <resource/router_02> ;
Line : foaf:topic_interest <resource/router_02> .
Line : <agent/bob_johnson> noria:agentManagesResource <applicationmodule/crm_dev_module> ;
Line : foaf:topic_interest <applicationmodule/crm_dev_module> .
Line : 
Line : # Linking loci to elements they contain (bot:hasElement is inverse of noria:locatedAtLocus)
Line : <locus/rack_a1_u1> bot:hasElement <resource/router_01> .
Line : <locus/rack_a1_u2> bot:hasElement <resource/server_01> .
Line : <locus/rack_a2_u1> bot:hasElement <resource/router_02> .
Line : <locus/rack_b1_u1> bot:hasElement <resource/switch_01> .
Line : 
