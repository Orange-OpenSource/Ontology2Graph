Line : # --- Anomaly Patterns ---
Line : 
Line : <anomalypattern/High_CPU_Low_Traffic>
Line : a noria:AnomalyPattern ;
Line : rdfs:label "High CPU, Low Traffic Anomaly"@en ;
Line : rdfs:comment "Anomaly pattern: high CPU usage on a server with unexpectedly low network traffic, indicating a potential runaway process or internal loop."@en .
Line : 
Line : <anomalypattern/Link_Flap_High_Error>
Line : a noria:AnomalyPattern ;
Line : rdfs:label "Link Flap with High Error Rate Anomaly"@en ;
Line : rdfs:comment "Anomaly pattern: network interface repeatedly going up/down accompanied by a high error rate, suggesting physical layer issues or faulty transceiver."@en .
Line : 
Line : <anomalypattern/Disk_Full_No_Growth_Alert>
Line : a noria:AnomalyPattern ;
Line : rdfs:label "Disk Full with No Recent Growth Anomaly"@en ;
Line : rdfs:comment "Anomaly pattern: disk space reported as full, but no significant data growth observed recently, suggesting a monitoring error or stale data."@en .
Line : 
Line : # --- Operation Plans ---
Line : 
Line : <operationplan/Router_Software_Upgrade_Procedure>
Line : a noria:OperationPlan ;
Line : rdfs:label "Router Software Upgrade Procedure"@en ;
Line : rdfs:comment "Standard operating procedure for upgrading router software."@en ;
Line : noria:operationPlanPreCondition <actionprecondition/Router_Backup_Complete> ;
Line : noria:operationPlanPostCondition <actionpostcondition/Router_Operational_After_Upgrade> .
Line : 
Line : <operationplan/Server_Process_Restart_Procedure>
Line : a noria:OperationPlan ;
Line : rdfs:label "Server Process Restart Procedure"@en ;
Line : rdfs:comment "Procedure to identify and restart runaway processes on a server."@en ;
Line : noria:operationPlanPreCondition <actionprecondition/Server_Monitoring_Active> ;
Line : noria:operationPlanPostCondition <actionpostcondition/Server_CPU_Normal_After_Restart> .
Line : 
Line : <operationplan/DB_Index_Optimization_Procedure>
Line : a noria:OperationPlan ;
Line : rdfs:label "Database Index Optimization Procedure"@en ;
Line : rdfs:comment "Procedure for routine database index optimization."@en ;
Line : noria:operationPlanPreCondition <actionprecondition/DB_Backup_Complete> ;
Line : noria:operationPlanPostCondition <actionpostcondition/DB_Performance_Improved> .
Line : 
Line : # --- Action Pre-Conditions ---
Line : 
Line : <actionprecondition/Router_Backup_Complete>
Line : a noria:ActionPreCondition ;
Line : rdfs:label "Router Configuration Backup Complete"@en ;
Line : rdfs:comment "Pre-condition: Ensure a full configuration backup of the router is completed before proceeding with upgrade."@en .
Line : 
Line : <actionprecondition/Server_Monitoring_Active>
Line : a noria:ActionPreCondition ;
Line : rdfs:label "Server Monitoring Active"@en ;
Line : rdfs:comment "Pre-condition: Verify that server monitoring is active and alerts are configured before performing process restart."@en .
Line : 
Line : <actionprecondition/DB_Backup_Complete>
Line : a noria:ActionPreCondition ;
Line : rdfs:label "Database Backup Complete"@en ;
Line : rdfs:comment "Pre-condition: Ensure a full backup of the database is completed before performing index optimization."@en .
Line : 
Line : # --- Action Post-Conditions ---
Line : 
Line : <actionpostcondition/Router_Operational_After_Upgrade>
Line : a noria:ActionPostCondition ;
Line : rdfs:label "Router Operational After Upgrade"@en ;
Line : rdfs:comment "Post-condition: Verify router is fully operational, all interfaces are up, and routing protocols are stable after software upgrade."@en .
Line : 
Line : <actionpostcondition/Server_CPU_Normal_After_Restart>
Line : a noria:ActionPostCondition ;
Line : rdfs:label "Server CPU Normal After Restart"@en ;
Line : rdfs:comment "Post-condition: Confirm CPU utilization returns to normal levels after restarting the application process."@en .
Line : 
Line : <actionpostcondition/DB_Performance_Improved>
Line : a noria:ActionPostCondition ;
Line : rdfs:label "Database Performance Improved"@en ;
Line : rdfs:comment "Post-condition: Verify database query performance has improved after index optimization."@en .
Line : 
