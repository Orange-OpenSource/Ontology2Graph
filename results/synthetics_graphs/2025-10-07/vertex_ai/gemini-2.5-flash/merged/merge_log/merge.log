Line : <application/core_network_infra> seas:subSystemOf <service/internal_api_gateway> .
Line : 
Line : # Linking event records to anomaly patterns (dcterms:relation)
Line : <eventrecord/router_interface_down> dcterms:relation <anomalypattern/link_flapping> .
Line : <eventrecord/server_cpu_spike> dcterms:relation <anomalypattern/high_cpu_usage> .
Line : 
Line : # Linking trouble tickets to operation plans (dcterms:relation)
Line : <troubleticket/tt_2024_001> dcterms:relation <operationplan/router_reboot> .
Line : <troubleticket/tt_2024_002> dcterms:relation <operationplan/app_patch_deployment> .
Line : 
Line : # Linking change requests to operation plans (dcterms:relation)
Line : <changerequest/cr_2024_001> dcterms:relation <operationplan/router_reboot> .
Line : <changerequest/cr_2024_002> dcterms:relation <operationplan/app_patch_deployment> .
