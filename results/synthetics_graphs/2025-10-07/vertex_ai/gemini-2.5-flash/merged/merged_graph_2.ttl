noria-data:RestartInterfaceProcedure
    a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network interface."@en ;
    noria:operationPlanPreCondition noria-data:PreConditionInterfaceDown ;
    noria:operationPlanPostCondition noria-data:PostConditionInterfaceUp .

noria-data:PreConditionInterfaceDown
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Interface is Down"@en ;
    rdfs:comment "The network interface must be in a 'down' operational state."@en .

noria-data:PostConditionInterfaceUp
