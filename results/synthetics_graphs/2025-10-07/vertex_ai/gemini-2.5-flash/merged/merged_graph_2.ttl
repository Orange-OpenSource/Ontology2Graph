# =============================================================================
# Procedural Elements (Anomaly Patterns, Operation Plans, Action Pre/Post Conditions)
# =============================================================================

# noria:AnomalyPattern
<anomalypattern/high_cpu_usage>
    a noria:AnomalyPattern ;
    rdfs:label "High_extra_node_1 CPU Usage Anomaly"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage on a critical resource."@en ;
    folio:hasCriticality <Notification/Severity/PerceivedSeverity/Warning_extra_node_1> .

<anomalypattern/link_flapping>
    a noria:AnomalyPattern ;
    rdfs:label "Network Link Flapping Anomaly"@en ;
    rdfs:comment "Pattern indicating frequent up/down transitions on a network link."@en ;
    folio:hasCritical_extra_node_1ity <Notification/Severity/PerceivedSeverity/Critical_extra_node_1> .

# noria:ActionPreCondition
<actionprecondition/network_reachable>
    a noria:ActionPreCondition ;
    rdfs:label "Network Reachability Confirmed"@en ;
    rdfs:comment "Pre-condition: Target network device is reachable via management interface."@en .

<actionprecondition/maintenance_window>
    a noria:ActionPreCondition ;
    rdfs:label "Maintenance_extra_node_1 Window Active"@en ;
    rdfs:comment "Pre-condition: The change is being executed within an approved maintenance window."@en .

# noria:ActionPostCondition
<actionpostcondition/service_restored>
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored"@en ;
    rdfs:comment "Post-condition: Affected service is fully operational and accessible."@en .

<actionpostcondition/cpu_normal>
    a noria:ActionPostCondition ;
    rdfs:label "CPU Usage Normal"@en ;
    rdfs:comment "Post-condition: CPU usage on the resource has returned to normal levels."@en .

# noria:OperationPlan
<operationplan/router_reboot>
    a noria:OperationPlan ;
    rdfs:label "Router_extra_node_1 Reboot Procedure"@en ;
    rdfs:comment "Standard_extra_node_1 operating procedure for rebooting a network router."@en ;
    noria:operationPlanPreCondition <actionprecondition/network_reachable> ;
    noria:operationPlanPostCondition <actionpostcondition/service_restored> .

<operationplan/app_patch_deployment>
    a noria:OperationPlan ;
    rdfs:label "Application Patch Deployment Plan"@en ;
    rdfs:comment "Plan for deploying security patches to application servers."@en ;
    noria:operationPlanPreCondition <actionprecondition/maintenance_window> ;
    noria:operationPlanPostCondition <actionpostcondition/service_restored> .

# =============================================================================
# Additional ObjectProperty links to ensure all nodes are connected
# =============================================================================

# Linking agents to resources they manage (noria:agentManagesResource is inverse of noria:resourceManagedBy)
<agent/john_doe> noria:agentManagesResource <resource/router_01> , <networklink/dc_core_link_01> ;
    foaf:topic_interest <resource/router_01> .
<agent/jane_smith> noria:agentManagesResource <application/crm_system> , <applicationmodule/crm_prod_module> ;
    foaf:topic_interest <application/crm_system> .
<agent/alice_williams> noria:agentManagesResource <resource/router_02> ;
    foaf:topic_interest <resource/router_02> .
<agent/bob_johnson> noria:agentManagesResource <applicationmodule/crm_dev_module> ;
    foaf:topic_interest <applicationmodule/crm_dev_module> .

# Linking loci to elements they contain (bot:hasElement is inverse of noria:locatedAtLocus)
<locus/rack_a1_u1> bot:hasElement <resource/router_01> .
<locus/rack_a1_u2> bot:hasElement <resource/server_01> .
<locus/rack_a2_u1> bot:hasElement <resource/router_02> .
<locus/rack_b1_u1> bot:hasElement <resource/switch_01> .

# Linking rooms to zones they contain (bot:containsZone is inverse of bot:hasSpace)
<room/server_room_a> bot:containsZone <locus/rack_a1_u1> , <locus/rack_a1_u2> , <locus/rack_a2_u1> .
<room/network_closet_b> bot:containsZone <locus/rack_b1_u1> , <locus/rack_b1_u2> .

# Linking application modules to services (seas:subSystemOf)
<applicationmodule/crm_prod_module> seas:subSystemOf <service/customer_facing_web_service> .
<application/core_network_infra> seas:subSystemOf <service/internal_api_gateway> .

# Linking event records to anomaly patterns (dcterms:relation)
<eventrecord/router_interface_down> dcterms:relation <anomalypattern/link_flapping> .
<eventrecord/server_cpu_spike> dcterms:relation <anomalypattern/high_cpu_usage> .

# Linking trouble tickets to operation plans (dcterms:relation)
<troubleticket/tt_2024_001> dcterms:relation <operationplan/router_reboot> .
<troubleticket/tt_2024_002> dcterms:relation <operationplan/app_patch_deployment> .

# Linking change requests to operation plans (dcterms:relation)
<changerequest/cr_2024_001> dcterms:relation <operationplan/router_reboot> .
<changerequest/cr_2024_002> dcterms:relation <operationplan/app_patch_deployment> .

