    rdfs:label "High CPU Usage Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage, potentially leading to performance degradation."@en ;
    folio:hasFailureMode noria-data:PerformanceDegradationFM .

noria-data:PerformanceDegradationFM
    a folio:FailureMode ;
    rdfs:label "Performance Degradation Failure Mode"@en ;
    rdfs:comment "A failure mode where system performance is below acceptable thresholds."@en .

