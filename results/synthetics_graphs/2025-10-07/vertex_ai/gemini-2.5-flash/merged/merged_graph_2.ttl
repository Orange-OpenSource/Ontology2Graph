# Organizational Entities
# =============================================================================

noria-data:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main corporate entity."@en ;
    dcterms:identifier "ORANGE-HQ-001"^^xsd:string .

noria-data:ITOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for IT infrastructure and operations."@en ;
    org:unitOf noria-data:OrangeCorp ;
    dcterms:identifier "IT-OPS-001"^^xsd:string .

noria-data:NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure."@en ;
    org:unitOf noria-data:ITOperationsDept ;
    dcterms:identifier "NET-OPS-001"^^xsd:string ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "For critical network issues, use the dedicated hotline. For non-critical, open a ticket."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:contact-method-phone .

noria-data:AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    org:unitOf noria-data:ITOperationsDept ;
    dcterms:identifier "APP-SUP-001"^^xsd:string ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentInstructions "All application issues must be reported via the ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:contact-method-email .

noria-data:JohnDoe
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Network Engineer and Team Lead."@en ;
    org:memberOf noria-data:NetworkTeam ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:contact-method-chat .

noria-data:JaneSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    org:memberOf noria-data:AppSupportTeam ;
    noria:agentWorkingHours "10:00 am - 7:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Email is preferred for all non-critical communications."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:contact-method-email .

noria-data:JohnDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "jdoe@orange.com"^^xsd:string ;
    foaf:holdsAccount noria-data:JohnDoe .

noria-data:JaneSmithCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountLogin "jsmith"^^xsd:string ;
    observable:accountIdentifier "jsmith@orange.com"^^xsd:string ;
    foaf:holdsAccount noria-data:JaneSmith .

