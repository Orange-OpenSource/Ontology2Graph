<kos/application/type>
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"^^xsd:string ;
    rdfs:comment "A scheme for classifying types of applications."^^xsd:string .

<kos/application/type/WebBased>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Web-Based Application"^^xsd:string ;
    rdfs:comment "An application accessible via a web browser."^^xsd:string .

<kos/application/type/Database>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Database Application"^^xsd:string ;
    rdfs:comment "An application primarily managing data storage and retrieval."^^xsd:string .

