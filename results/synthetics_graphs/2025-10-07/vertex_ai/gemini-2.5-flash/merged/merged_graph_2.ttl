# --- noria:AnomalyPattern instances ---

<anomalypattern/HighCPUDegradation>
    a noria:AnomalyPattern ;
    rdfs:label "High_extra_node_0 CPU Degradation Pattern"@en ;
    rdfs:comment "Pattern indicating a sustained high CPU usage leading to performance degradation."@en ;
    folio:hasConsequence "Service performance degradation"^^xsd:string ;
    folio:hasCause "Application misconfiguration or resource exhaustion"^^xsd:string .

<anomalypattern/NetworkLatencySpike>
    a noria:AnomalyPattern ;
    rdfs:label "Network Latency Spike Pattern"@en ;
    rdfs:comment "Pattern indicating sudden and significant increases in network latency."@en ;
    folio:hasConsequence "Application unresponsiveness, connection timeouts"^^xsd:string ;
    folio:hasCause "Network congestion, faulty hardware, routing issues"^^xsd:string .

# --- noria:OperationPlan instances ---

<operationplan/RouterTroubleshooting>
    a noria:OperationPlan ;
    rdfs:label "Router_extra_node_0 Troubleshooting Procedure"@en ;
    rdfs:comment "Standard_extra_node_0 operating procedure for troubleshooting router issues."@en ;
    pep:hasStep "Check interface status"^^xsd:string ;
    pep:hasStep "Verify routing table"^^xsd:string ;
    noria:operationPlanPreCondition <actionprecondition/RouterConnectivityCheck> ;
    noria:operationPlanPostCondition <actionpostcondition/RouterConnectivityRestored> .

<operationplan/FirmwareUpgradeProcedure>
    a noria:OperationPlan ;
    rdfs:label "Firmware Upgrade Procedure"@en ;
    rdfs:comment "Procedure for upgrading router firmware."@en ;
    pep:hasStep "Backup configuration"^^xsd:string ;
    pep:hasStep "Upload new firmware"^^xsd:string ;
    pep:hasStep "Reboot device"^^xsd:string ;
    noria:operationPlanPreCondition <actionprecondition/FirmwareUpgradeReadiness> ;
    noria:operationPlanPostCondition <actionpostcondition/FirmwareUpgradeSuccess> .

<operationplan/DatabasePatchingProcedure>
    a noria:OperationPlan ;
    rdfs:label "Database Patching Procedure"@en ;
    rdfs:comment "Standard_extra_node_0 operating procedure for applying database patches."@en ;
    pep:hasStep "Stop database service"^^xsd:string ;
    pep:hasStep "Apply patches"^^xsd:string ;
    pep:hasStep "Start database service"^^xsd:string ;
    noria:operationPlanPreCondition <actionprecondition/DatabaseBackupVerification> ;
    noria:operationPlanPostCondition <actionpostcondition/DatabaseServiceRestored> .

<operationplan/WebAppRestartProcedure>
    a noria:OperationPlan ;
    rdfs:label "Web Application Restart Procedure"@en ;
    rdfs:comment "Procedure for gracefully restarting the web application."@en ;
    pep:hasStep "Drain connections from load balancer"^^xsd:string ;
    pep:hasStep "Stop application service"^^xsd:string ;
    pep:hasStep "Start application service"^^xsd:string ;
    pep:hasStep "Verify application health"^^xsd:string ;
    noria:operationPlanPreCondition <actionprecondition/ApplicationHealthCheck> ;
    noria:operationPlanPostCondition <actionpostcondition/ApplicationServiceRestored> .

# --- noria:ActionPreCondition instances ---

<actionprecondition/RouterConnectivityCheck>
    a noria:ActionPreCondition ;
    rdfs:label "Router_extra_node_0 Connectivity Check"@en ;
    rdfs:comment "Pre-condition: Verify basic network connectivity to the router."@en .

<actionprecondition/FirmwareUpgradeReadiness>
    a noria:ActionPreCondition ;
    rdfs:label "Firmware Upgrade Readiness Check"@en ;
    rdfs:comment "Pre-condition: Ensure device is backed up and maintenance window is active."@en .

<actionprecondition/DatabaseBackupVerification>
    a noria:ActionPreCondition ;
    rdfs:label "Database Backup Verification"@en ;
    rdfs:comment "Pre-condition: Verify a recent, successful database backup exists."@en .

<actionprecondition/ApplicationHealthCheck>
    a noria:ActionPreCondition ;
    rdfs:label "Application Health Check"@en ;
    rdfs:comment "Pre-condition: Verify current application health status before intervention."@en .

# --- noria:ActionPostCondition instances ---

<actionpostcondition/RouterConnectivityRestored>
    a noria:ActionPostCondition ;
    rdfs:label "Router_extra_node_0 Connectivity Restored"@en ;
    rdfs:comment "Post-condition: Confirm full network connectivity to and through the router."@en .

<actionpostcondition/FirmwareUpgradeSuccess>
    a noria:ActionPostCondition ;
    rdfs:label "Firmware Upgrade Success"@en ;
    rdfs:comment "Post-condition: Verify new firmware version and device operational status."@en .

<actionpostcondition/DatabaseServiceRestored>
    a noria:ActionPostCondition ;
    rdfs:label "Database Service Restored"@en ;
    rdfs:comment "Post-condition: Confirm database service is running and accessible."@en .

<actionpostcondition/ApplicationServiceRestored>
    a noria:ActionPostCondition ;
    rdfs:label "Application Service Restored"@en ;
    rdfs:comment "Post-condition: Confirm application service is fully operational and responsive."@en .

# --- Interconnections to ensure all nodes are linked ---

<org/ITOperationsTeam>
    noria:agentManagesResource <resource/Server001>, <resource/DatabaseServer001>, <resource/LoadBalancer001> ;
    foaf:holdsAccount <cuid/JohnDoeCUID>, <cuid/JaneSmithCUID> .

<org/NetworkSupportTeam>
    noria:agentManagesResource <resource/Router001>, <resource/Switch001>, <networklink/WANLinkParisLondon>, <networklink/LANLinkServer001>, <networklink/LANLinkDatabase001>, <networklink/LANLinkLoadBalancer001> .

<application/WebAppFrontend>
    noria:elementManagedBy <org/ITOperationsTeam> ;
    noria:resourceForApplication <resource/LoadBalancer001> .

<application/DatabaseBackend>
    noria:elementManagedBy <org/ITOperationsTeam> .

<service/CustomerPortalService>
    seas:subSystemOf <applicationmodule/DatabaseBackendProd> ;
    seas:subSystemOf <applicationmodule/WebAppFrontendProd> .

<service/InternalMonitoringService>
    seas:subSystemOf <applicationmodule/WebAppFrontendProd> ;
    seas:subSystemOf <applicationmodule/DatabaseBackendProd> .

<agent/JohnDoe_extra_node_0>
    foaf:holdsAccount <cuid/JohnDoeCUID> ;
    noria:agentManagesResource <resource/Server001> .

<agent/JaneSmith_extra_node_0>
    foaf:holdsAccount <cuid/JaneSmithCUID> ;
    noria:agentManagesResource <resource/DatabaseServer001> .

<eventrecord/RouterDownAlarm>
    noria:alarmMitigatedBy <changerequest/CR001> .

<eventrecord/DatabaseConnectionError>
    noria:alarmMitigatedBy <troubleticket/TT003> .

<troubleticket/TT001>
    dcterms:hasPart <documentattachment/RouterFirmwareReleaseNotes> .

<changerequest/CR001>
    dcterms:hasPart <documentattachment/RouterFirmwareReleaseNotes> .

<changerequest/CR003>
    dcterms:hasPart <documentattachment/WebAppConfigGuide> ;
    noria:actionCorrelatedOperationPlan <operationplan/WebAppRestartProcedure> .

<eventrecord/LoadBalancerHealthCheckFailure>
    noria:alarmProposedRepairAction <operationplan/WebAppRestartProcedure> .

<applicationmodule/WebAppFrontendProd>
    noria:elementProperty <anomalypattern/HighCPUDegradation> .

<networklink/WANLinkParisLondon>
    noria:elementProperty <anomalypattern/NetworkLatencySpike> .

<troubleticket/TT004>
    noria:troubleTicketPartyIntervention <agent/JohnDoe_extra_node_0> ;
    noria:troubleTicketPartyIntervention <org/ITOperationsTeam> .

<resource/Server001>
    noria:clusterController <resource/LoadBalancer001> .

<resource/DatabaseServer001>
    noria:clusterController <resource/Server001> . # Example: Server001 acts as a controller for DB server in some setup.

<application/WebAppFrontend>
    noria:elementProperty <anomalypattern/HighCPUDegradation> .

<application/DatabaseBackend>
    noria:elementProperty <anomalypattern/NetworkLatencySpike> .

<operationplan/RouterTroubleshooting>
    noria:actionCorrelatedOperationPlan <changerequest/CR001> . # A CR might trigger a troubleshooting OP.

<operationplan/DatabasePatchingProcedure>
    noria:actionCorrelatedOperationPlan <changerequest/CR002> .

<operationplan/WebAppRestartProcedure>
    noria:actionCorrelatedOperationPlan <changerequest/CR003> .



