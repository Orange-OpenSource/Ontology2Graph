# Placeholder for observable:IPAddress as it's an ObjectProperty in noria schema but DatatypeProperty in UCO.
# I'll define it as a class to satisfy the ObjectProperty range.
observable:IPAddress
    a owl:Class ;
    rdfs:label "IP Address" ;
    rdfs:comment "Represents an IP address, as an instance for object property ranges." .

# --- Core Entities ---

# foaf:Agent and org:OrganizationalUnit
:Agent_Alice
    a foaf:Agent ;
    rdfs:label "Alice Smith" ;
    rdfs:comment "A synthetic agent, an employee in the organization." ;
    foaf:name "Alice Smith"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

:Agent_Bob
    a foaf:Agent ;
    rdfs:label "Bob Johnson" ;
    rdfs:comment "A synthetic agent, a team leader." ;
    foaf:name "Bob Johnson"^^xsd:string ;
    noria:agentWorkingHours "08:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Call hotline for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

:OrgUnit_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Organizational unit responsible for network infrastructure." ;
    org:unitOf :Org_GlobalTech ;
    noria:agentWorkingHours "24/7 Shift"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string .

:OrgUnit_AppSupport
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team" ;
    rdfs:comment "Organizational unit responsible for application support." ;
    org:unitOf :Org_GlobalTech ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Email for general inquiries, phone for emergencies."^^xsd:string .

:Org_GlobalTech
    a org:Organization ;
    rdfs:label "GlobalTech Corp" ;
    rdfs:comment "The main organization." .

# noria:CorporateUserIdentifier
:CUid_Alice
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice's Corporate User ID" ;
    rdfs:comment "Corporate user identifier for Alice Smith." ;
    foaf:accountName "asmith"^^xsd:string ;
    foaf:holdsAccount :Agent_Alice .

# bot:Site, noria:Room, noria:Locus
:Site_DataCenterA
    a bot:Site ;
    rdfs:label "Primary Data Center A" ;
    rdfs:comment "Main data center facility." ;
    noria:siteId "DC-A-001"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "USA"^^xsd:string .

:Room_ServerRoom1
    a noria:Room ;
    rdfs:label "Server Room 1" ;
    rdfs:comment "A server room within Data Center A." ;
    bot:hasSpace :Site_DataCenterA .

:Locus_RackA1_U1
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 1" ;
    rdfs:comment "Specific location within Server Room 1." ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "U1"^^xsd:string ;
    bot:containsZone :Room_ServerRoom1 .

# noria:ProductModel
:ProductModel_Cisco3850
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 3850" ;
    rdfs:comment "Product model for a network switch." ;
    noria:productManufacturedBy :Org_Cisco .

:Org_Cisco
    a org:Organization ;
    rdfs:label "Cisco Systems" ;
    rdfs:comment "Manufacturer of network equipment." .

:ProductModel_DellPowerEdge
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740" ;
    rdfs:comment "Product model for a server." ;
    noria:productManufacturedBy :Org_Dell .

:Org_Dell
    a org:Organization ;
    rdfs:label "Dell Technologies" ;
    rdfs:comment "Manufacturer of server equipment." .

# noria:Resource
:Resource_Router1
    a noria:Resource ;
    rdfs:label "Core Router R1" ;
    rdfs:comment "A core network router in Data Center A." ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceHostName "router-core-01.dca.globaltech.com"^^xsd:string ;
    noria:resourceSerialNumber "SN123456789"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :OrgUnit_NetworkOps ;
    noria:resourceProductModel :ProductModel_Cisco3850 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/in-production> ;
    noria:locatedAtLocus :Locus_RackA1_U1 ;
    noria:resourceManagementIPAddress :IP_10_0_0_1 .

:IP_10_0_0_1
    a observable:IPAddress ;
    rdfs:label "Management IP for Router1" ;
    observable:ipAddress "10.0.0.1"^^xsd:string .

:Resource_ServerWeb1
    a noria:Resource ;
    rdfs:label "Web Server S1" ;
    rdfs:comment "A web application server." ;
    noria:resourceLogisticId "LOG-WEB-001"^^xsd:string ;
    noria:resourceHostName "web-app-01.dca.globaltech.com"^^xsd:string ;
    noria:resourceSerialNumber "SN987654321"^^xsd:string ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :OrgUnit_AppSupport ;
    noria:resourceProductModel :ProductModel_DellPowerEdge ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/in-production> ;
    noria:locatedAtLocus :Locus_RackA1_U1 ;
    noria:resourceManagementIPAddress :IP_10_0_0_2 .

:IP_10_0_0_2
    a observable:IPAddress ;
    rdfs:label "Management IP for ServerWeb1" ;
    observable:ipAddress "10.0.0.2"^^xsd:string .

# noria:NetworkInterface
:NetworkInterface_R1_Eth0
    a noria:NetworkInterface ;
    rdfs:label "Router1 Ethernet0/0" ;
    rdfs:comment "Ethernet interface on Core Router R1." ;
    noria:networkInterfaceDescription "Uplink to ISP"^^xsd:string ;
    noria:networkInterfaceType <kos/networkInterfaceType/physical> ;
    noria:networkInterfaceOf :Resource_Router1 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-8"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-7"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-15"^^xsd:int .

:NetworkInterface_S1_Eth0
    a noria:NetworkInterface ;
    rdfs:label "ServerWeb1 Ethernet0" ;
    rdfs:comment "Ethernet interface on Web Server S1." ;
    noria:networkInterfaceDescription "Connection to internal network"^^xsd:string ;
    noria:networkInterfaceType <kos/networkInterfaceType/physical> ;
    noria:networkInterfaceOf :Resource_ServerWeb1 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric "0"^^xsd:int .

# noria:NetworkLink
:NetworkLink_R1_S1
    a noria:NetworkLink ;
    rdfs:label "Link between Router1 and ServerWeb1" ;
    rdfs:comment "A direct network link for internal traffic." ;
    noria:networkLinkId "NL-R1-S1-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin :Resource_Router1 ;
    noria:networkLinkTerminationResourceDestination :Resource_ServerWeb1 ;
    noria:networkInterfaceConnects :NetworkInterface_R1_Eth0 ;
    noria:networkInterfaceConnects :NetworkInterface_S1_Eth0 .

# noria:Application
:Application_WebApp
    a noria:Application ;
    rdfs:label "Customer Portal Application" ;
    rdfs:comment "The main customer-facing web application." ;
    noria:applicationModelIdentifier "CP-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CPORTAL"^^xsd:string ;
    noria:applicationType <kos/application/type/web-service> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Online Services"^^xsd:string ;
    noria:elementManagedBy :OrgUnit_AppSupport ;
    noria:resourceForApplication :Resource_ServerWeb1 .

:Application_Monitoring
    a noria:Application ;
    rdfs:label "Network Monitoring System" ;
    rdfs:comment "Application for monitoring network health." ;
    noria:applicationModelIdentifier "NMS-V3"^^xsd:string ;
