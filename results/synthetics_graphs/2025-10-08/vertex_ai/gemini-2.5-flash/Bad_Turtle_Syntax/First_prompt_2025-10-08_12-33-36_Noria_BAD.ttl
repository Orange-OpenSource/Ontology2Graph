noria:GeneratedKnowledgeGraph
  a owl:Ontology ;
  dcterms:title "Synthetic NORIA Knowledge Graph"@en ;
  dcterms:description "A synthetic knowledge graph generated based on the NORIA ontology schema, maximizing entity count and property usage within token limits."@en ;
  dcterms:creator "AI Assistant" ;
  dcterms:issued "2024-05-15"^^xsd:date ;
  owl:versionInfo "1.0" .

# Helper functions for generating synthetic data
# (These are conceptual and would be implemented in a script generating this output)
# generate_uri(class_name, index) -> noria:ClassName_001
# random_datetime_str() -> "2023-10-26T10:30:00Z"^^xsd:dateTime
# random_ip_address() -> "192.168.1.1"
# random_duration() -> "PT1H30M"

# --- Base Entities for Linking ---

