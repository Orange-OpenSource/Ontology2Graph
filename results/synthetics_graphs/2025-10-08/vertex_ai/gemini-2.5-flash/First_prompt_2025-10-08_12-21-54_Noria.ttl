    rdfs:comment "Notification indicates critical perceived severity."@en .

# -----------------------------------------------------------------------------
# Organizational Entities (foaf:Agent, org:OrganizationalUnit)
# -----------------------------------------------------------------------------

noria:OrgUnitA
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "The primary team responsible for network operations."@en ;
    org:unitOf <https://www.orange.com/> ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Contact via dedicated ticketing system for P1/P2 issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:OrgUnitB
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for critical business applications."@en ;
    org:unitOf <https://www.orange.com/> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Email for non-urgent issues, phone for urgent."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:PersonA
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Engineer at NOC."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "tel:+1-555-123-4567"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Available for critical escalations."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:PersonB
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "tel:+1-555-987-6543"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for quick queries."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:CUid1
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountIdentifier "AS-001"^^xsd:string ;
    foaf:holdsAccount noria:PersonA .

noria:CUid2
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountIdentifier "BJ-002"^^xsd:string ;
    foaf:holdsAccount noria:PersonB .

# -----------------------------------------------------------------------------
# Location Entities (bot:Site, noria:Room, noria:Locus)
# -----------------------------------------------------------------------------

noria:SiteDC1
    a bot:Site ;
    rdfs:label "Main Data Center Site"@en ;
    rdfs:comment "Primary data center location."@en ;
    noria:siteId "DC-MAIN-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Techville"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

noria:RoomA101
    a noria:Room ;
    rdfs:label "Server Room A101"@en ;
    rdfs:comment "A server room within the main data center."@en ;
    bot:hasSpace noria:SiteDC1 .

noria:LocusR1C5
    a noria:Locus ;
    rdfs:label "Rack 1, Column 5 Locus"@en ;
    rdfs:comment "Specific location for a rack in Server Room A101."@en ;
    noria:locusLine "R1"^^xsd:string ;
    noria:locusRow "C5"^^xsd:string ;
    bot:containsZone noria:RoomA101 .

# -----------------------------------------------------------------------------
# Structural Elements (noria:Resource, noria:NetworkInterface, noria:NetworkLink, noria:ProductModel)
# -----------------------------------------------------------------------------

noria:ProductModelRouterX
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9000 Series"@en ;
    rdfs:comment "Product model for high-performance network routers."@en ;
    noria:productManufacturedBy noria:CiscoOrg .

noria:CiscoOrg
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

noria:ProductModelServerY
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "Product model for enterprise servers."@en ;
    noria:productManufacturedBy noria:DellOrg .

noria:DellOrg
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

noria:ResourceRouter1
    a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Primary router for the data center network."@en ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceHostName "router-core-01"^^xsd:string ;
    noria:resourceProductModel noria:ProductModelRouterX ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-12345"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:OrgUnitA ;
    noria:locatedAtLocus noria:LocusR1C5 ;
    noria:resourceManagementIPAddress noria:IPAddressRouter1 .

noria:IPAddressRouter1
    a noria:IPAddress ;
    rdfs:label "Management IP for Router 1"@en ;
    rdfs:comment "IP address used for managing Core Router 1."@en ;
    observable:ipAddress "10.0.0.1"^^xsd:string .

noria:ResourceServerDB1
    a noria:Resource ;
    rdfs:label "Database Server 1"@en ;
    rdfs:comment "Server hosting the main application database."@en ;
    noria:resourceLogisticId "LOG-DB-001"^^xsd:string ;
    noria:resourceHostName "db-server-01"^^xsd:string ;
    noria:resourceProductModel noria:ProductModelServerY ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-SRV-67890"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2022-02-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:OrgUnitB ;
    noria:resourceForApplication noria:AppCRM ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterfaceR1G001
    a noria:NetworkInterface ;
    rdfs:label "Router1 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Network interface on Core Router 1."@en ;
    noria:networkInterfaceDescription "Uplink to distribution switch."^^xsd:string ;
    noria:networkInterfaceType noria:PhysicalInterfaceType ;
    noria:networkInterfaceOf noria:ResourceRouter1 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-8"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-7"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-15"^^xsd:int .

noria:PhysicalInterfaceType
    a skos:Concept ;
    rdfs:label "Physical Interface Type"@en ;
    rdfs:comment "Represents a physical network interface."@en .

noria:NetworkLinkDCUplink
    a noria:NetworkLink ;
    rdfs:label "Data Center Uplink Link"@en ;
    rdfs:comment "High-speed link connecting the data center to the core network."@en ;
    noria:networkLinkId "NL-DC-UPLINK-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria:ResourceRouter1 ;
    noria:networkLinkTerminationResourceDestination noria:ResourceCoreSwitch ;
    noria:networkInterfaceConnects noria:NetworkInterfaceR1G001 .

noria:ResourceCoreSwitch
    a noria:Resource ;
    rdfs:label "Core Switch 1"@en ;
    rdfs:comment "Core switch in the data center."@en ;
    noria:resourceHostName "switch-core-01"^^xsd:string ;
    noria:resourceManagedBy noria:OrgUnitA .

# -----------------------------------------------------------------------------
# Functional Elements (noria:Application, noria:ApplicationModule, noria:Service)
# -----------------------------------------------------------------------------

noria:AppCRM
    a noria:Application ;
    rdfs:label "Customer Relationship Management"@en ;
    rdfs:comment "Application for managing customer interactions."@en ;
    noria:applicationModelIdentifier "CRM-APP-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CRM"^^xsd:string ;
    noria:applicationType <kos/application/type/BusinessApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Market and Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Customer Support"^^xsd:string ;
    noria:elementManagedBy noria:OrgUnitB .

noria:AppModuleCRMProd
    a noria:ApplicationModule ;
    rdfs:label "CRM Production Module"@en ;
    rdfs:comment "Production instance of the CRM application."@en ;
    noria:applicationModuleOf noria:AppCRM ;
    noria:applicationModuleName "CRM_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-001"^^xsd:string ;
    noria:applicationModuleRelatedParty noria:OrgUnitB ;
    noria:applicationModuleAdministrationTeam noria:OrgUnitB ;
    noria:applicationModuleAdministrationLeader noria:PersonB ;
    noria:applicationModuleSupportTeam noria:OrgUnitB ;
