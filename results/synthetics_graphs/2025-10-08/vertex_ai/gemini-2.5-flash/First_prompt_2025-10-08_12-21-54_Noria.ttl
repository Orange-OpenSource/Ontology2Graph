# Synthetic Knowledge Graph based on NORIA Ontology

# -----------------------------------------------------------------------------
# SKOS Concepts for controlled vocabularies
# -----------------------------------------------------------------------------

<kos/application/type>
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/type/ServicePlatform>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "An application acting as a service platform."@en .

<kos/application/type/Infrastructure>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application managing core infrastructure."@en .

<kos/application/type/BusinessApplication>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "An application supporting business operations."@en .

<kos/application/business-importance>
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

<kos/application/business-importance/Critical>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for business operations."@en .

<kos/application/business-importance/High>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High"@en ;
    rdfs:comment "Application has high business importance."@en .

<kos/application/sla-level>
    a skos:ConceptScheme ;
    rdfs:label "SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying Service Level Agreement levels."@en .

<kos/application/sla-level/Gold>
    a skos:Concept ;
    skos:inScheme <kos/application/sla-level> ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "Highest Service Level Agreement."@en .

<kos/application/status>
    a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of applications."@en .

<kos/application/status/InProduction>
    a skos:Concept ;
    skos:inScheme <kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application is currently in production."@en .

<kos/service/type>
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "Service directly visible and usable by customers."@en .

<kos/TroubleTicket/severity>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying trouble ticket severity."@en .

<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Critical impact on service."@en .

<kos/TroubleTicket/type>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of trouble tickets."@en .

<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure Ticket"@en ;
    rdfs:comment "Ticket reporting a system failure."@en .

<kos/TroubleTicket/category>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme"@en ;
    rdfs:comment "A scheme for classifying trouble ticket categories."@en .

<kos/TroubleTicket/category/ServiceInterruption>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Service Interruption"@en ;
    rdfs:comment "Category for service interruption issues."@en .

<kos/TroubleTicket/priority>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A scheme for classifying trouble ticket priorities."@en .

<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority ticket."@en .

<kos/TroubleTicket/origin>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Ticket originated by a customer."@en .

<kos/TroubleTicket/urgency>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A scheme for classifying trouble ticket urgency."@en .

<kos/TroubleTicket/urgency/Immediate>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action."@en .

<kos/TroubleTicket/trouble-category>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the nature of the incident."@en .

<kos/TroubleTicket/trouble-category/TotalBreakdown>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Complete system failure."@en .

<kos/TroubleTicket/problemResponsibility>
    a skos:ConceptScheme ;
    rdfs:label "Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying problem responsibility."@en .

<kos/TroubleTicket/problemResponsibility/ManagedNetwork>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Network"@en ;
    rdfs:comment "Responsibility lies with the managed network team."@en .

<kos/TroubleTicket/status>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying trouble ticket statuses."@en .

<kos/TroubleTicket/status/InProgress>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Ticket is currently being worked on."@en .

<kos/TroubleTicket/commentType>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying comment types on trouble tickets."@en .

<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment for internal use only."@en .

<kos/TroubleTicket/operationType>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying operation types on trouble tickets."@en .

<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Operation related to diagnosing the problem."@en .

<kos/ChangeRequest/category>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A scheme for classifying change request categories."@en .

<kos/ChangeRequest/category/SoftwareUpgrade>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Category for software upgrade requests."@en .

<kos/ChangeRequest/type>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying change request types."@en .

<kos/ChangeRequest/type/Standard>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Standard, pre-approved change."@en .

<kos/ChangeRequest/cause>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying change request causes."@en .

<kos/ChangeRequest/cause/ConfigurationChange>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change due to configuration update."@en .

<kos/ChangeRequest/status>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying change request statuses."@en .

<kos/ChangeRequest/status/Executing>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Executing Change"@en ;
    rdfs:comment "Change request is currently being executed."@en .

<kos/ChangeRequest/specification>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    rdfs:comment "A scheme for classifying change request specifications."@en .

<kos/ChangeRequest/specification/StandardProcedureA>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Standard Procedure A"@en ;
    rdfs:comment "Refers to Standard Operating Procedure A."@en .

<kos/Resource/OperationalState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of resources."@en .

<kos/Resource/OperationalState/Up>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is operational."@en .

<kos/Resource/AdministrativeState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of resources."@en .

<kos/Resource/AdministrativeState/Enabled>
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Enabled"@en ;
