    rdfs:comment "A scheme for classifying the lifecycle state of resources."@en .

<kos/Resource/LifecycleState/Production>
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Production"@en ;
    rdfs:comment "Resource is in production use."@en .

<kos/Resource/type>
    a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of resources."@en .

<kos/Resource/type/Router>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router device."@en .

<kos/Resource/type/Server>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A server machine."@en .

<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
