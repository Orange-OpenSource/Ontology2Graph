# Synthetic Knowledge Graph based on NORIA Ontology

# --- SKOS Concepts for controlled vocabularies ---

<kos/application/type/ServicePlatform>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "A platform providing a specific service."@en .

<kos/application/type/Infrastructure>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Infrastructure"@en ;
    rdfs:comment "Core infrastructure component."@en .

<kos/application/business-importance/Critical>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for business operations."@en .

<kos/application/business-importance/High>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "High"@en ;
    rdfs:comment "Application has high business importance."@en .

<kos/application/sla-level/Gold>
