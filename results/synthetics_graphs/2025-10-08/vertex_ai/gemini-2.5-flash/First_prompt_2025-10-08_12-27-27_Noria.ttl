# --- Resources ---

<Resource/Router01>
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary router in Data Center A."@en ;
    noria:elementDistinguishedName "router-dca-01"^^xsd:string ;
    noria:structuralElementDistinguishedName "router-dca-01"^^xsd:string ;
    noria:resourceLogisticId "LOG-DCA-R01"^^xsd:string ;
    noria:resourceHostName "router01.dca.example.com"^^xsd:string ;
    noria:resourceSerialNumber "SN-RTR-001-XYZ"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <OrgUnit/NetworkOperations> ;
    noria:resourceProductModel <ProductModel/Cisco3850> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:locatedAtLocus <Locus/RackA1> ;
    noria:resourceManagementIPAddress "10.0.0.1"^^xsd:string ;
    noria:resourceForApplication <Application/NetworkCore> .

<Resource/Server05>
    a noria:Resource ;
    rdfs:label "Application Server 05"@en ;
    rdfs:comment "Server hosting critical application components."@en ;
    noria:elementDistinguishedName "appserver-05"^^xsd:string ;
    noria:structuralElementDistinguishedName "appserver-05"^^xsd:string ;
    noria:resourceLogisticId "LOG-DCA-S05"^^xsd:string ;
    noria:resourceHostName "appserver05.dca.example.com"^^xsd:string ;
    noria:resourceSerialNumber "SN-SRV-005-ABC"^^xsd:string ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <OrgUnit/ApplicationSupport> ;
    noria:resourceProductModel <ProductModel/HPProLiantDL380> ;
    noria:resourceType <kos/Resource/type/Server> ;
