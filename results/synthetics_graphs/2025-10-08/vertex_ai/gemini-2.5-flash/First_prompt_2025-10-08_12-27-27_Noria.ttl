# --- Agents and Organizations ---

<Agent/JohnDoe>
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A synthetic employee, IT Manager."@en ;
    foaf:mbox "mailto:john.doe@example.com"^^xsd:anyURI ;
    foaf:phone "+1-555-123-4567"^^xsd:string ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<Agent/JaneSmith>
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A synthetic employee, Network Engineer."@en ;
    foaf:mbox "mailto:jane.smith@example.com"^^xsd:anyURI ;
    foaf:phone "+1-555-987-6543"^^xsd:string ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<OrgUnit/NetworkOperations>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure."@en ;
    org:unitOf <Org/ExampleCorp> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "Escalate critical network alarms to this team."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<OrgUnit/ApplicationSupport>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for application modules."@en ;
    org:unitOf <Org/ExampleCorp> ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Sat)"^^xsd:string ;
    noria:agentInstructions "Check application logs before contacting."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<Org/ExampleCorp>
    a org:Organization ;
    rdfs:label "Example Corporation"@en ;
    rdfs:comment "A fictional company."@en ;
    org:hasUnit <OrgUnit/NetworkOperations> , <OrgUnit/ApplicationSupport> .

<Org/CiscoSystems>
    a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

<Org/HPE>
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

# --- Corporate User Identifiers ---

<CUid/johndoe_it>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "johndoe_it"^^xsd:string ;
    observable:accountIdentifier "JD001"^^xsd:string ;
    observable:accountLogin "johndoe_it"^^xsd:string ;
    foaf:holdsAccount <Agent/JohnDoe> .

<CUid/janesmith_net>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "janesmith_net"^^xsd:string ;
    observable:accountIdentifier "JS002"^^xsd:string ;
    observable:accountLogin "janesmith_net"^^xsd:string ;
    foaf:holdsAccount <Agent/JaneSmith> .

# --- Locations ---

<Site/DataCenterA>
    a bot:Site ;
    rdfs:label "Primary Data Center A"@en ;
    rdfs:comment "Main data center facility."@en ;
    noria:siteId "DCA01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "USA"^^xsd:string ;
    wgs84_pos:lat "34.0522"^^xsd:decimal ;
    wgs84_pos:long "-118.2437"^^xsd:decimal .

<Site/OfficeB>
    a bot:Site ;
    rdfs:label "Regional Office B"@en ;
    rdfs:comment "Regional office building."@en ;
    noria:siteId "ROB02"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Business Road"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Business Road"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Gotham"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "20002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "USA"^^xsd:string .

<Room/ServerRoom1>
    a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "Main server room in Data Center A."@en ;
    bot:hasSpace <Site/DataCenterA> .

<Room/NetworkCloset2>
    a noria:Room ;
    rdfs:label "Network Closet 2"@en ;
    rdfs:comment "Network equipment closet in Office B."@en ;
    bot:hasSpace <Site/OfficeB> .

<Locus/RackA1>
    a noria:Locus ;
    rdfs:label "Rack A1 Locus"@en ;
    rdfs:comment "Location of Rack A1 in Server Room 1."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:containsZone <Room/ServerRoom1> .

<Locus/RackB5>
    a noria:Locus ;
    rdfs:label "Rack B5 Locus"@en ;
    rdfs:comment "Location of Rack B5 in Network Closet 2."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "5"^^xsd:string ;
    bot:containsZone <Room/NetworkCloset2> .

