    noria:changeRequestChangeCause <kos/ChangeRequest/cause/ConfigurationChange> ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkMaintenance> ;
    noria:changeRequestInitiatorParty <Agent/JohnDoe> ;
    noria:changeRequestPilotParty <Agent/JohnDoe> ;
    noria:changeRequestActorParty <Agent/JohnDoe> ;
    noria:changeRequestIsRegulated "true"^^xsd:boolean ;
    noria:changeRequestImpact <Resource/Server05> ;
    noria:changeRequestImpact <ApplicationModule/CRM_Prod> ;
    noria:changeRequestImpact <Service/CustomerFacingCRM> .

# --- Document Attachments ---

<DocumentAttachment/Diagram001>
    a noria:DocumentAttachment ;
    rdfs:label "Network Diagram DCA"@en ;
    rdfs:comment "Network topology diagram for Data Center A."@en ;
    dcterms:isPartOf <TroubleTicket/TT001> ;
    dcterms:isPartOf <ChangeRequest/CR001> ;
    dcterms:format "image/png"^^xsd:string ;
    dcterms:identifier "DCA-NET-DIAG-V1.2"^^xsd:string .

# --- Procedural Elements ---

<OperationPlan/InterfaceTroubleshooting>
    a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    noria:elementDistinguishedName "OP-NET-IF-TROUBLE"^^xsd:string ;
    noria:operationPlanPreCondition <ActionPreCondition/InterfaceDown> ;
    noria:operationPlanPostCondition <ActionPostCondition/InterfaceUp> ;
    noria:elementManagedBy <OrgUnit/NetworkOperations> .

<OperationPlan/DBOptimization>
    a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing slow database queries."@en ;
    noria:elementDistinguishedName "OP-DB-QUERY-OPT"^^xsd:string ;
    noria:operationPlanPreCondition <ActionPreCondition/HighCPU> ;
    noria:operationPlanPostCondition <ActionPostCondition/LowCPU> ;
    noria:elementManagedBy <OrgUnit/ApplicationSupport> .

<ActionPreCondition/InterfaceDown>
    a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Pre-condition: a network interface reports an 'administratively down' or 'operationally down' status."@en .

<ActionPreCondition/HighCPU>
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Utilization"@en ;
    rdfs:comment "Pre-condition: a server's CPU utilization exceeds a predefined threshold."@en .

<ActionPostCondition/InterfaceUp>
    a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Post-condition: the network interface is restored to an 'up' operational state."@en .

<ActionPostCondition/LowCPU>
    a noria:ActionPostCondition ;
    rdfs:label "CPU Utilization Normalized"@en ;
    rdfs:comment "Post-condition: the server's CPU utilization returns to normal levels."@en .

<AnomalyPattern/RepeatedInterfaceFlap>
    a noria:AnomalyPattern ;
    rdfs:label "Repeated Interface Flap Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating an interface repeatedly goes up and down within a short period."@en ;
    folio:hasCause "Faulty transceiver or cable"^^xsd:string ;
    folio:hasEffect "Intermittent network connectivity"^^xsd:string ;
    noria:elementManagedBy <OrgUnit/NetworkOperations> .

# Linking EventRecord to OperationPlan via actionCorrelatedOperationPlan
<EventRecord/Log001>
    noria:actionCorrelatedOperationPlan <OperationPlan/InterfaceTroubleshooting> .

<EventRecord/Log003>
    noria:actionCorrelatedOperationPlan <OperationPlan/InterfaceTroubleshooting> .
