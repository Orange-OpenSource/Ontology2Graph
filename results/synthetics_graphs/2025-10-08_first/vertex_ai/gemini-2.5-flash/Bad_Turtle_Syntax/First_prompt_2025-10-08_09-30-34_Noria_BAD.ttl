    noria:networkInterfaceAdministrativeStatus noria-kos:AdminState_Enabled ;
    noria:networkInterfaceOperationalStatus noria-kos:OpState_Up ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
