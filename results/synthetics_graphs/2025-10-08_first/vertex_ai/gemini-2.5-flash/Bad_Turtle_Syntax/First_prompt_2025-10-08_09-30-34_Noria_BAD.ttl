    noria:resourceInstallationDate "2022-02-20T11:30:00Z"^^xsd:dateTime ;
    noria:elementDistinguishedName "router-edge-02"^^xsd:string ;
    noria:structuralElementDistinguishedName "router-edge-02"^^xsd:string ;
    noria:resourceProductModel noria-inst:ProductModel_JuniperMX ;
    noria:resourceType noria-kos:ResourceType_Router ;
    noria:resourceUsageState noria-kos:LifecycleState_Production ;
    noria:resourceManagedBy noria-inst:Agent_JaneSmith ;
    noria:locatedAtLocus noria-inst:Locus_Rack1A ;
    noria:resourceManagementIPAddress noria-inst:IPAddress_Router02_Mgmt .

noria-inst:Resource_Server01
    a noria:Resource ;
