# --- Resources ---

noria-inst:Resource_Router01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router for the network."@en ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceHostName "router-core-01"^^xsd:string ;
    noria:resourceSerialNumber "SN-RTR-001-XYZ"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:elementDistinguishedName "router-core-01"^^xsd:string ;
    noria:structuralElementDistinguishedName "router-core-01"^^xsd:string ;
    noria:resourceProductModel noria-inst:ProductModel_Cisco3850 ;
    noria:resourceType noria-kos:ResourceType_Router ;
    noria:resourceUsageState noria-kos:LifecycleState_Production ;
    noria:resourceManagedBy noria-inst:Agent_JaneSmith ;
    noria:locatedAtLocus noria-inst:Locus_Rack1A ;
    noria:resourceManagementIPAddress noria-inst:IPAddress_Router01_Mgmt ;
    noria:structuralElementObservableData "85.5"^^xsd:float . # Example of structuralElementObservableData

noria-inst:Resource_Router02
    a noria:Resource ;
    rdfs:label "Edge Router 02"@en ;
