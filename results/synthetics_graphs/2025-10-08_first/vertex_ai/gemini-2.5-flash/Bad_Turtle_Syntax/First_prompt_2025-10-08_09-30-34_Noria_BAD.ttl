# --- General Agents and Organizations ---

noria-inst:Org_ITDept
    a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department responsible for infrastructure."@en ;
    noria:elementDistinguishedName "IT-DEPT-GLOBAL"^^xsd:string .

noria-inst:Org_Cisco
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en ;
    noria:elementDistinguishedName "Cisco"^^xsd:string .

noria-inst:Org_Dell
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en ;
    noria:elementDistinguishedName "Dell"^^xsd:string .

noria-inst:OrgUnit_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Organizational unit responsible for network operations."@en ;
    org:unitOf noria-inst:Org_ITDept ;
    noria:elementDistinguishedName "NET-OPS-UNIT"^^xsd:string .

noria-inst:OrgUnit_AppDev
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Unit"@en ;
    rdfs:comment "Organizational unit responsible for application development."@en ;
    org:unitOf noria-inst:Org_ITDept ;
    noria:elementDistinguishedName "APP-DEV-UNIT"^^xsd:string .

noria-inst:OrgUnit_SecurityOps
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Organizational unit responsible for cybersecurity operations."@en ;
    org:unitOf noria-inst:Org_ITDept ;
    noria:elementDistinguishedName "SOC-UNIT"^^xsd:string .

noria-inst:Agent_JohnDoe
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A key agent in the IT department."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:ContactMethod_Email ;
    noria:elementDistinguishedName "john.doe"^^xsd:string .

noria-inst:Agent_JaneSmith
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A senior network engineer."@en ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Call hotline for critical network issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:ContactMethod_Phone ;
    noria:elementDistinguishedName "jane.smith"^^xsd:string .

noria-inst:Agent_AliceBrown
    a foaf:Agent ;
    rdfs:label "Alice Brown"@en ;
    rdfs:comment "Application support lead."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:ContactMethod_Email ;
    noria:elementDistinguishedName "alice.brown"^^xsd:string .

noria-inst:Agent_BobWhite
    a foaf:Agent ;
    rdfs:label "Bob White"@en ;
    rdfs:comment "Security analyst."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Alert via internal chat for urgent security events."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:ContactMethod_Email ;
    noria:elementDistinguishedName "bob.white"^^xsd:string .

# --- Corporate User Identifiers ---

noria-inst:CUid_JohnDoe
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's CUid"@en ;
    rdfs:comment "Corporate User Identifier for John Doe."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "CU-JD-001"^^xsd:string ;
    noria:elementDistinguishedName "CU-JD-001"^^xsd:string .

noria-inst:CUid_JaneSmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's CUid"@en ;
    rdfs:comment "Corporate User Identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountLogin "jsmith"^^xsd:string ;
    observable:accountIdentifier "CU-JS-002"^^xsd:string ;
    noria:elementDistinguishedName "CU-JS-002"^^xsd:string .

noria-inst:Agent_JohnDoe foaf:holdsAccount noria-inst:CUid_JohnDoe .
noria-inst:Agent_JaneSmith foaf:holdsAccount noria-inst:CUid_JaneSmith .

# --- Locations ---

noria-inst:Site_HQ
    a bot:Site ;
    rdfs:label "Headquarters Building"@en ;
    rdfs:comment "Main corporate headquarters building."@en ;
    noria:siteId "SITE-HQ-01"^^xsd:string ;
    noria:siteType "building"^^xsd:string ;
    noria:sitePrincipalAddress "123 Main Street"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "New York"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Main Street"^^xsd:string ;
    noria:elementDistinguishedName "SITE-HQ-01"^^xsd:string .

noria-inst:Site_DRC
    a bot:Site ;
    rdfs:label "Disaster Recovery Center"@en ;
    rdfs:comment "Secondary data center for disaster recovery."@en ;
    noria:siteId "SITE-DRC-02"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "456 Backup Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Beverly Hills"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Backup Avenue"^^xsd:string ;
    noria:elementDistinguishedName "SITE-DRC-02"^^xsd:string .

noria-inst:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room in the HQ building."@en ;
    bot:hasSpace noria-inst:Locus_Rack1A ;
    bot:hasSpace noria-inst:Locus_Rack2B ;
    bot:hasBuilding noria-inst:Site_HQ ;
    noria:elementDistinguishedName "HQ-SR-A"^^xsd:string .

noria-inst:Room_ServerRoomB
    a noria:Room ;
    rdfs:label "Server Room B"@en ;
    rdfs:comment "Secondary server room in the HQ building."@en ;
    bot:hasSpace noria-inst:Locus_Rack3C ;
    bot:hasBuilding noria-inst:Site_HQ ;
    noria:elementDistinguishedName "HQ-SR-B"^^xsd:string .

noria-inst:Locus_Rack1A
    a noria:Locus ;
    rdfs:label "Rack 1A Locus"@en ;
    rdfs:comment "Specific location for Rack 1A in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    noria:elementDistinguishedName "HQ-SR-A-R1A"^^xsd:string .

noria-inst:Locus_Rack2B
    a noria:Locus ;
    rdfs:label "Rack 2B Locus"@en ;
    rdfs:comment "Specific location for Rack 2B in Server Room A."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    noria:elementDistinguishedName "HQ-SR-A-R2B"^^xsd:string .

noria-inst:Locus_Rack3C
    a noria:Locus ;
    rdfs:label "Rack 3C Locus"@en ;
    rdfs:comment "Specific location for Rack 3C in Server Room B."@en ;
    noria:locusLine "C"^^xsd:string ;
    noria:locusRow "3"^^xsd:string ;
    noria:elementDistinguishedName "HQ-SR-B-R3C"^^xsd:string .

