# --- Network Links ---

noria-inst:NetLink_ISP_Uplink
    a noria:NetworkLink ;
    rdfs:label "ISP Uplink Link"@en ;
    rdfs:comment "Network link connecting Router01 to the ISP."@en ;
    noria:networkLinkId "NL-ISP-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:elementDistinguishedName "NL-ISP-001"^^xsd:string ;
    noria:structuralElementDistinguishedName "NL-ISP-001"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria-inst:Resource_Router01 ;
    noria:networkLinkTerminationResourceDestination noria-inst:Resource_ISP_Gateway ;
    noria:resourceManagedBy noria-inst:Agent_JaneSmith .

noria-inst:NetLink_Internal_LAN
    a noria:NetworkLink ;
    rdfs:label "Internal LAN Link"@en ;
    rdfs:comment "Network link connecting Router01 to internal servers."@en ;
    noria:networkLinkId "NL-LAN-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:elementDistinguishedName "NL-LAN-001"^^xsd:string ;
    noria:structuralElementDistinguishedName "NL-LAN-001"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria-inst:Resource_Router01 ;
    noria:networkLinkTerminationResourceDestination noria-inst:Resource_Server01 ;
    noria:resourceManagedBy noria-inst:Agent_JaneSmith .

noria-inst:NetLink_DMZ_Connection
    a noria:NetworkLink ;
    rdfs:label "DMZ Connection Link"@en ;
    rdfs:comment "Network link connecting Router02 to the DMZ."@en ;
    noria:networkLinkId "NL-DMZ-002"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-02-20T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:elementDistinguishedName "NL-DMZ-002"^^xsd:string ;
    noria:structuralElementDistinguishedName "NL-DMZ-002"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria-inst:Resource_Router02 ;
    noria:networkLinkTerminationResourceDestination noria-inst:Resource_Server01 ; # Example: Server01 is in DMZ
    noria:resourceManagedBy noria-inst:Agent_JaneSmith .

noria-inst:NetInt_Router01_Eth0 noria:networkInterfaceConnects noria-inst:NetLink_ISP_Uplink .
noria-inst:NetInt_Router01_Eth1 noria:networkInterfaceConnects noria-inst:NetLink_Internal_LAN .
noria-inst:NetInt_Router02_Eth0 noria:networkInterfaceConnects noria-inst:NetLink_DMZ_Connection .
noria-inst:NetInt_Server01_Eth0 noria:networkInterfaceConnects noria-inst:NetLink_Internal_LAN .
noria-inst:NetInt_Server02_Eth0 noria:networkInterfaceConnects noria-inst:NetLink_Internal_LAN . # Assuming DB server is also on internal LAN

