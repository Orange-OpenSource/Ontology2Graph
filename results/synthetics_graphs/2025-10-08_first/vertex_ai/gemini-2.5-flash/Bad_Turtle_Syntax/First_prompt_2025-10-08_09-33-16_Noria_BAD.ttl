# Network Links
<networklink/rtr001_isp_a>
    a noria:NetworkLink ;
    rdfs:label "Router 001 to ISP A Link"@en ;
    rdfs:comment "Network link connecting Core Router 001 to ISP A."@en ;
    noria:networkLinkId "NL-RTR001-ISPA"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin <resource/router_001> ;
    noria:networkLinkTerminationResource <resource/router_001> ; # Represents the external endpoint
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:networkInterfaceConnects <networkinterface/rtr001_ge000> .

<networklink/rtr001_sw001>
    a noria:NetworkLink ;
    rdfs:label "Router 001 to Switch 001 Link"@en ;
    rdfs:comment "Internal network link between Core Router 001 and Distribution Switch 001."@en ;
    noria:networkLinkId "NL-RTR001-SW001"^^xsd:string ;
