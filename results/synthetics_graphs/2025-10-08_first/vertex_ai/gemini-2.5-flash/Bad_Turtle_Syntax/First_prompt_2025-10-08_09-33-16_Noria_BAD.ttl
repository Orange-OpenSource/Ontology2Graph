    noria:networkLinkInstallationDate "2022-05-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:networkInterfaceConnects <networkinterface/rtr001_ge001> ;
    noria:networkInterfaceConnects <networkinterface/sw001_ge000> .

<networklink/sw001_fw001>
    a noria:NetworkLink ;
    rdfs:label "Switch 001 to Firewall 001 Link"@en ;
    rdfs:comment "Internal network link between Distribution Switch 001 and Perimeter Firewall 001."@en ;
