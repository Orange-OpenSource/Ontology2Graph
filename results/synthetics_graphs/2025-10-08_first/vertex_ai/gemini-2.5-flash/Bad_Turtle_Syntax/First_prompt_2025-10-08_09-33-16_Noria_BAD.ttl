# Synthetic Knowledge Graph based on NORIA Ontology

# KOS Concepts (Knowledge Organization System)
# These are concepts used as ranges for various ObjectProperties in the NORIA schema.
# We define a few instances for each relevant KOS scheme.

<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method: Email."@en .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method: Phone."@en .

