    rdfs:comment "Pattern indicating sustained high CPU utilization on a server."@en ;
    folio:hasFailureModeType "Performance Degradation"^^xsd:string ;
    folio:hasFailureModeDescription "CPU usage consistently above threshold."^^xsd:string .

<anomalypattern/unauthorized_access>
    a noria:AnomalyPattern ;
    rdfs:label "Unauthorized Access Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating attempts to access systems without proper authorization."@en ;
    folio:hasFailureModeType "Security Breach Attempt"^^xsd:string ;
    folio:hasFailureModeDescription "Multiple failed login attempts or port scans from external IPs."^^xsd:string .

# Operation Plans
<operationplan/restart_interface>
    a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Operation Plan"@en ;
    rdfs:comment "Standard operating procedure to restart a network interface."@en ;
    folio:hasControlMethodType "Corrective Action"^^xsd:string ;
    pep:hasStep "Login to device"^^xsd:string ;
    pep:hasStep "Execute 'shutdown' command"^^xsd:string ;
    pep:hasStep "Wait 10 seconds"^^xsd:string ;
    pep:hasStep "Execute 'no shutdown' command"^^xsd:string ;
    noria:operationPlanPreCondition <actionprecondition/interface_down_or_flapping> ;
    noria:operationPlanPostCondition <actionpostcondition/interface_up_and_stable> .

<operationplan/scale_web_servers>
    a noria:OperationPlan ;
    rdfs:label "Scale Web Servers Operation Plan"@en ;
    rdfs:comment "Procedure to scale out web server instances in response to high load."@en ;
    folio:hasControlMethodType "Preventative Action"^^xsd:string ;
    pep:hasStep "Provision new web server instance"^^xsd:string ;
    pep:hasStep "Add to load balancer pool"^^xsd:string ;
    noria:operationPlanPreCondition <actionprecondition/high_cpu_load> ;
    noria:operationPlanPostCondition <actionpostcondition/cpu_load_normalized> .

<operationplan/firewall_rule_update>
    a noria:OperationPlan ;
    rdfs:label "Firewall Rule Update Operation Plan"@en ;
    rdfs:comment "Procedure to update firewall rules to block specific IPs or traffic patterns."@en ;
    folio:hasControlMethodType "Corrective Action"^^xsd:string ;
    pep:hasStep "Identify malicious IP"^^xsd:string ;
    pep:hasStep "Create deny rule"^^xsd:string ;
    pep:hasStep "Apply rule to firewall"^^xsd:string ;
    noria:operationPlanPreCondition <actionprecondition/unauthorized_traffic> ;
    noria:operationPlanPostCondition <actionpostcondition/traffic_blocked> .

# Action Pre-Conditions
<actionprecondition/interface_down_or_flapping>
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down or Flapping Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Network interface is in a down state or flapping."@en ;
    dcterms:description "Check if network interface operational status is 'down' or if there are frequent 'up/down' events."^^xsd:string .

<actionprecondition/high_cpu_load>
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Load Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Server CPU utilization is consistently high."@en ;
    dcterms:description "Verify CPU usage metrics are above 80% for more than 15 minutes."^^xsd:string .

<actionprecondition/unauthorized_traffic>
    a noria:ActionPreCondition ;
    rdfs:label "Unauthorized Traffic Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Detection of unauthorized or malicious network traffic."@en ;
    dcterms:description "SIEM alerts or firewall logs indicate suspicious activity from external sources."^^xsd:string .

# Action Post-Conditions
<actionpostcondition/interface_up_and_stable>
    a noria:ActionPostCondition ;
    rdfs:label "Interface Up and Stable Post-Condition"@en ;
    rdfs:comment "Post-condition: Network interface is up and stable."@en ;
    dcterms:description "Confirm network interface operational status is 'up' and no state changes for 5 minutes."^^xsd:string .

<actionpostcondition/cpu_load_normalized>
    a noria:ActionPostCondition ;
    rdfs:label "CPU Load Normalized Post-Condition"@en ;
    rdfs:comment "Post-condition: Server CPU utilization has returned to normal levels."@en ;
    dcterms:description "Verify CPU usage metrics are below 50% for at least 10 minutes."^^xsd:string .

<actionpostcondition/traffic_blocked>
    a noria:ActionPostCondition ;
    rdfs:label "Traffic Blocked Post-Condition"@en ;
    rdfs:comment "Post-condition: Malicious network traffic is successfully blocked."@en ;
    dcterms:description "Verify firewall logs show successful blocking of the identified malicious IP."^^xsd:string .

# Generic Actions (pep:Action) linked to Operation Plans
<action/interface_restart_action>
    a pep:Action ;
    rdfs:label "Interface Restart Action Instance"@en ;
    rdfs:comment "An instance of an action to restart a network interface."@en ;
    noria:actionCorrelatedOperationPlan <operationplan/restart_interface> .

<action/firewall_block_action>
    a pep:Action ;
    rdfs:label "Firewall Block Action Instance"@en ;
    rdfs:comment "An instance of an action to block an IP on the firewall."@en ;
    noria:actionCorrelatedOperationPlan <operationplan/firewall_rule_update> .

# Additional links for alarmMitigatedBy
<eventrecord/log_rtr001_linkdown>
    noria:alarmMitigatedBy <troubleticket/tt_20231026_001> .

<eventrecord/log_fw001_attack>
    noria:alarmMitigatedBy <changerequest/cr_20231028_003> .

