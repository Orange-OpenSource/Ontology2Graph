    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:networkInterfaceConnects <networkinterface/fw001_eth1> ; # Assuming another interface on firewall
    noria:networkInterfaceConnects <networkinterface/rtr002_ge000> .

<networklink/web01_db01>
