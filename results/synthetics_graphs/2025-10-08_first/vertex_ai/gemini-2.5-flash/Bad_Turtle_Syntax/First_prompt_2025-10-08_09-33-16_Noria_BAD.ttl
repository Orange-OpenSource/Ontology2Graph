<agent/network_support_team>
    noria:agentManagesResource <resource/router_001> ;
    noria:agentManagesResource <resource/router_002> ;
    noria:agentManagesResource <resource/switch_001> ;
    noria:agentManagesResource <resource/router_003> .

<agent/it_operations_team>
    noria:agentManagesResource <resource/server_web_01> ;
    noria:agentManagesResource <resource/server_db_01> ;
    noria:agentManagesResource <resource/virtual_server_001> .

<agent/security_team>
    noria:agentManagesResource <resource/firewall_001> .

<agent/development_team>
    noria:agentManagesResource <resource/dev_server_01> .
