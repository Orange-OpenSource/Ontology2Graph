    rdfs:label "Network Closet 1"@en ;
    rdfs:comment "Network closet within the West Office Building."@en ;
    bot:hasSpace <site/office_west> .

<room/dev_lab>
    a noria:Room ;
    rdfs:label "Development Lab"@en ;
    rdfs:comment "Development and testing lab in the West Office Building."@en ;
    bot:hasSpace <site/office_west> .

# Loci
<locus/rack_a1_u1>
