# Agents (Persons and Teams)
<agent/john_doe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A synthetic employee, John Doe, IT Operations Specialist."@en ;
    foaf:name "John Doe"^^xsd:string ;
    foaf:mbox "mailto:john.doe@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string .

<agent/jane_smith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A synthetic employee, Jane Smith, Network Engineer."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    foaf:mbox "mailto:jane.smith@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "10:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call directly for urgent issues."^^xsd:string .

<agent/alice_brown>
    a foaf:Person ;
    rdfs:label "Alice Brown"@en ;
    rdfs:comment "A synthetic employee, Alice Brown, Security Analyst."@en ;
    foaf:name "Alice Brown"^^xsd:string ;
    foaf:mbox "mailto:alice.brown@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for incident reports."^^xsd:string .

<agent/bob_white>
    a foaf:Person ;
    rdfs:label "Bob White"@en ;
    rdfs:comment "A synthetic employee, Bob White, Software Developer."@en ;
    foaf:name "Bob White"^^xsd:string ;
    foaf:mbox "mailto:bob.white@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use internal chat for quick questions."^^xsd:string .

<agent/it_operations_team>
    a foaf:Group ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "A synthetic IT Operations Team, responsible for system uptime."@en ;
    foaf:name "IT Operations"^^xsd:string ;
    noria:agentWorkingHours "24/7 On-call"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string .

<agent/network_support_team>
    a foaf:Group ;
    rdfs:label "Network Support Team"@en ;
    rdfs:comment "A synthetic Network Support Team, handling network infrastructure."@en ;
    foaf:name "Network Support"^^xsd:string ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for routine inquiries, phone for emergencies."^^xsd:string .

<agent/security_team>
    a foaf:Group ;
    rdfs:label "Security Team"@en ;
    rdfs:comment "A synthetic Security Team, managing cybersecurity."@en ;
    foaf:name "Security Operations"^^xsd:string ;
    noria:agentWorkingHours "24/7 Monitoring"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report security incidents via dedicated channel."^^xsd:string .

<agent/development_team>
    a foaf:Group ;
    rdfs:label "Development Team"@en ;
    rdfs:comment "A synthetic Development Team, building and maintaining applications."@en ;
    foaf:name "Software Development"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use project management tool for feature requests."^^xsd:string .

# Organizations
<org/example_corp>
    a org:Organization ;
    rdfs:label "Example Corp"@en ;
    rdfs:comment "A synthetic corporate entity, parent organization."@en ;
    org:legalName "Example Corporation"^^xsd:string ;
    org:identifier "ECORP-001"^^xsd:string .

# Organizational Units
<orgunit/datacenter_ops>
    a org:OrganizationalUnit ;
    rdfs:label "Data Center Operations"@en ;
    rdfs:comment "Organizational unit responsible for data center operations."@en ;
    org:unitOf <org/example_corp> ;
    org:hasMember <agent/john_doe> ;
    org:hasMember <agent/it_operations_team> .

<orgunit/network_engineering>
    a org:OrganizationalUnit ;
    rdfs:label "Network Engineering"@en ;
    rdfs:comment "Organizational unit responsible for network engineering."@en ;
    org:unitOf <org/example_corp> ;
    org:hasMember <agent/jane_smith> ;
    org:hasMember <agent/network_support_team> .

<orgunit/security_operations>
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations"@en ;
    rdfs:comment "Organizational unit responsible for cybersecurity operations."@en ;
    org:unitOf <org/example_corp> ;
    org:hasMember <agent/alice_brown> ;
    org:hasMember <agent/security_team> .

<orgunit/software_development>
    a org:OrganizationalUnit ;
    rdfs:label "Software Development"@en ;
    rdfs:comment "Organizational unit responsible for software development."@en ;
    org:unitOf <org/example_corp> ;
    org:hasMember <agent/bob_white> ;
    org:hasMember <agent/development_team> .

