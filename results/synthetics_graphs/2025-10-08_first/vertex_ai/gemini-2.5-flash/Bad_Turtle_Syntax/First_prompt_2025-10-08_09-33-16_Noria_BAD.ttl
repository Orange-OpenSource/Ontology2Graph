    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:networkInterfaceConnects <networkinterface/sw001_ge000> ; # Assuming another interface on switch
    noria:networkInterfaceConnects <networkinterface/fw001_eth1> .

<networklink/fw001_rtr002>
    a noria:NetworkLink ;
    rdfs:label "Firewall 001 to Router 002 Link"@en ;
    rdfs:comment "Network link between Perimeter Firewall 001 and Edge Router 002."@en ;
