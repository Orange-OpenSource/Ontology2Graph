# =============================================================================
# Synthetic Knowledge Graph
# =============================================================================

noria-inst:knowledge-graph-01
    a owl:Ontology ;
    dcterms:title "Synthetic NORIA Knowledge Graph"@en ;
    dcterms:description "A synthetic knowledge graph generated based on the NORIA ontology schema."@en ;
    dcterms:creator "AI Assistant"@en ;
    dcterms:issued "2024-07-30T10:00:00Z"^^xsd:dateTime ;
    owl:versionInfo "1.0" ;
    rdfs:comment "This graph is generated to demonstrate the NORIA schema usage and contains fictional data."@en .

