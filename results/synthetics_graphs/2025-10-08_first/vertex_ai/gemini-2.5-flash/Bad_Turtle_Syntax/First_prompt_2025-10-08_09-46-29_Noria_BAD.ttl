# --- Event Records ---
ex:EventRecordRouterDown
    a noria:EventRecord ;
    rdfs:label "Router-01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Router-01."@en ;
    noria:loggingTime "2023-10-26T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject ex:ResourceRouter01 ;
    noria:logOriginatingManagementSystem ex:ApplicationAuthService ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

ex:EventRecordServerCPUHigh
