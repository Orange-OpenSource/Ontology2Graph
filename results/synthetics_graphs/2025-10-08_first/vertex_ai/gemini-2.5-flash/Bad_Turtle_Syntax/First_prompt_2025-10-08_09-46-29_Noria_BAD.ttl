    rdfs:label "Server-01 CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Server-01."@en ;
    noria:loggingTime "2023-10-26T10:10:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on appserver01.example.com exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject ex:ResourceServer01 ;
    noria:logOriginatingManagementSystem ex:ApplicationWebApp ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmProposedRepairAction ex:OperationPlanRestartService ;
    noria:alarmMonitoredAttribute ex:Server01CPULoad .

