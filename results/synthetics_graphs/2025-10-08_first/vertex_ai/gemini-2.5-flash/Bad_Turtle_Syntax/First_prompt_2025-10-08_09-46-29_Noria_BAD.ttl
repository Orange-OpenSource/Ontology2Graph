# --- Custom classes for schema inconsistencies ---
# As noria:resourceManagementIPAddress is an ObjectProperty but its subproperty observable:ipAddress is a DatatypeProperty.
# To resolve this, we introduce a class ex:IPAddress and a DatatypeProperty ex:hasIPValue.
ex:IPAddress
    a owl:Class ;
    rdfs:label "IP Address Entity"@en ;
    rdfs:comment "Represents an IP address as an entity, to be used as a range for ObjectProperties like noria:resourceManagementIPAddress."@en .

ex:hasIPValue
    a owl:DatatypeProperty ;
    rdfs:label "has IP Value"@en ;
    rdfs:comment "The actual string value of an IP address."@en ;
    rdfs:domain ex:IPAddress ;
    rdfs:range xsd:string .

# --- Core Organizational and Location Entities ---

ex:OrgA
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "A major telecommunications company."@en ;
    noria:elementDistinguishedName "OrangeTelecom"^^xsd:string .

ex:OrgUnitIT
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for IT infrastructure operations."@en ;
    org:unitOf ex:OrgA ;
    noria:elementDistinguishedName "ITOpsDept"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for L1 issues."^^xsd:string ;
    noria:agentPreferredContactMethod kos:agent-contact-method/Email .

ex:OrgUnitNetwork
    a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Team responsible for network design and maintenance."@en ;
    org:unitOf ex:OrgA ;
    noria:elementDistinguishedName "NetEngTeam"^^xsd:string ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentInstructions "Emergency calls only for P1 incidents."^^xsd:string ;
    noria:agentPreferredContactMethod kos:agent-contact-method/Phone .

ex:AgentJohnDoe
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee in the IT Operations Department."@en ;
    noria:elementDistinguishedName "johndoe"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod kos:agent-contact-method/Email .

ex:AgentJaneSmith
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A network engineer."@en ;
    noria:elementDistinguishedName "janesmith"^^xsd:string ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Use internal chat for quick questions."^^xsd:string ;
    noria:agentPreferredContactMethod kos:agent-contact-method/Phone .

ex:SiteParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "PARIS-DC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

ex:SiteLyonOffice
    a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "LYON-OFFICE-01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
