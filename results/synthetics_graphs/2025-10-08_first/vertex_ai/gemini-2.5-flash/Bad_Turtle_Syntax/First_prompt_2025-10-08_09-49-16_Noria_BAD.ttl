# --- KOS Concepts Declaration ---

noria-kos:agent-contact-method
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

noria-kos:agent-contact-method/Email
    a skos:Concept ;
    skos:inScheme noria-kos:agent-contact-method ;
    rdfs:label "Email"@en ;
    rdfs:comment "Contact via email."@en .

noria-kos:agent-contact-method/Phone
    a skos:Concept ;
    skos:inScheme noria-kos:agent-contact-method ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Contact via phone."@en .

