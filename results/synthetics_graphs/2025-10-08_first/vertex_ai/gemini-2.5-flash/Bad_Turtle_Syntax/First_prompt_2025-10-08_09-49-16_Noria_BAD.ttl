# --- Organizations and Agents ---

noria-data:Org_GlobalCorp
    a org:Organization ;
    rdfs:label "GlobalCorp Inc."@en ;
    rdfs:comment "A multinational technology corporation."@en ;
    org:hasUnit noria-data:OrgUnit_ITOperations ;
    org:hasUnit noria-data:OrgUnit_NetworkServices ;
    org:hasUnit noria-data:OrgUnit_SecurityOps .

noria-data:OrgUnit_ITOperations
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Manages daily IT infrastructure operations."@en ;
    org:unitOf noria-data:Org_GlobalCorp ;
    org:hasMember noria-data:Person_Alice ;
    org:hasMember noria-data:Person_Bob ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentInstructions "Contact via ticketing system for all issues."@en ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email .

noria-data:OrgUnit_NetworkServices
    a org:OrganizationalUnit ;
    rdfs:label "Network Services Team"@en ;
    rdfs:comment "Responsible for network infrastructure design and maintenance."@en ;
    org:unitOf noria-data:Org_GlobalCorp ;
    org:hasMember noria-data:Person_Charlie ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentInstructions "For critical network issues, use emergency hotline."@en ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Phone .

noria-data:OrgUnit_SecurityOps
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    org:unitOf noria-data:Org_GlobalCorp ;
    org:hasMember noria-data:Person_Diana ;
    noria:agentWorkingHours "24/7 Shift-based"@en ;
    noria:agentInstructions "All security alerts must be escalated immediately."@en ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Chat .

noria-data:Person_Alice
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "IT Operations Engineer."@en ;
    foaf:mbox <mailto:alice.smith@globalcorp.com> ;
    foaf:holdsAccount noria-data:CUid_ASmith ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentInstructions "Primary contact for server issues."@en ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email .

noria-data:Person_Bob
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior IT Operations Engineer."@en ;
    foaf:mbox <mailto:bob.johnson@globalcorp.com> ;
    foaf:holdsAccount noria-data:CUid_BJohnson ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentInstructions "Escalation point for critical IT issues."@en ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Phone .

noria-data:Person_Charlie
    a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Network Architect."@en ;
    foaf:mbox <mailto:charlie.brown@globalcorp.com> ;
    foaf:holdsAccount noria-data:CUid_CBrown ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentInstructions "Specialist for WAN routing."@en ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email .

noria-data:Person_Diana
    a foaf:Person, foaf:Agent ;
    rdfs:label "Diana Prince"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:diana.prince@globalcorp.com> ;
    foaf:holdsAccount noria-data:CUid_DPrince ;
