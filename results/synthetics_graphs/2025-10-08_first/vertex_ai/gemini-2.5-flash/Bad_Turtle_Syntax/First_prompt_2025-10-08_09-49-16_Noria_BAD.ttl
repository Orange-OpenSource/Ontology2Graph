    noria:siteType "corporate campus"@en ;
    noria:sitePrincipalAddress "123 Main Street"@en ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "New York"@en ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
