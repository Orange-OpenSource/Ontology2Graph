noria-data:OpPlan_RouterPatching
    a noria:OperationPlan ;
    rdfs:label "Router OS Patching Procedure"@en ;
    rdfs:comment "Standard procedure for applying OS patches to network routers."@en ;
    pep:hasInput noria-data:ActionPreCond_RouterNeedsPatch ;
    pep:hasOutput noria-data:ActionPostCond_RouterPatched .

# --- Action Pre/Post Conditions ---

noria-data:ActionPreCond_DBServiceDown
    a noria:ActionPreCondition ;
    rdfs:label "Database Service Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Database service is not running or unresponsive."@en .

noria-data:ActionPostCond_DBServiceUp
    a noria:ActionPostCondition ;
    rdfs:label "Database Service Up Post-Condition"@en ;
    rdfs:comment "Post-condition: Database service is running and accessible."@en .

noria-data:ActionPreCond_InterfaceFlapping
    a noria:ActionPreCondition ;
    rdfs:label "Interface Flapping Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Network interface is intermittently going up and down."@en .

noria-data:ActionPostCond_InterfaceStable
    a noria:ActionPostCondition ;
    rdfs:label "Interface Stable Post-Condition"@en ;
    rdfs:comment "Post-condition: Network interface is stable and operational."@en .

noria-data:ActionPreCond_RouterNeedsPatch
    a noria:ActionPreCondition ;
    rdfs:label "Router Needs Patch Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Router OS has identified vulnerabilities requiring a patch."@en .

noria-data:ActionPostCond_RouterPatched
    a noria:ActionPostCondition ;
    rdfs:label "Router Patched Post-Condition"@en ;
    rdfs:comment "Post-condition: Router OS is updated with the latest security patches."@en .

