# --- Additional ObjectProperty links to ensure all are used ---

# noria:elementManagedBy (already used extensively)
# noria:structuralElementObservable (used via sub-properties like virtualServerStatus)
# noria:structuralObservableOf (inverse of structuralElementProperty, implicitly covered by direct properties)
# noria:eventRelatedElement (used via sub-properties like troubleTicketRelatedService, troubleTicketRelatedResource, logOriginatingManagedObject)
# noria:eventRelatedParty (used via sub-properties like troubleTicketRelatedParty, logOriginatingAgent)

# noria:alarmProposedRepairAction (range pep:Procedure, which noria:OperationPlan is a subclass of)
noria-data:Event_Router1_InterfaceDown
    noria:alarmProposedRepairAction noria-data:OpPlan_TransceiverReplacement .

noria-data:Event_WebServerError
    noria:alarmProposedRepairAction noria-data:OpPlan_DBRestart .

# noria:alarmMonitoredAttribute (no specific range, linking to a generic property)
noria-data:Event_DBServer_HighCPU
    noria:alarmMonitoredAttribute noria-data:Property_CPUUtilization .

noria-data:Property_CPUUtilization
    a noria:Property ;
    rdfs:label "CPU Utilization Property"@en ;
    rdfs:comment "A generic property representing CPU utilization."@en .

# noria:alarmMitigatedBy (range pep:ProcedureExecutionContainer, which noria:TroubleTicket and noria:TroubleTicketNote are subclasses of)
noria-data:Event_Router1_InterfaceDown
    noria:alarmMitigatedBy noria-data:TT_002 .

noria-data:Event_WebServerError
    noria:alarmMitigatedBy noria-data:TT_001 .

# noria:troubleTicketPartyIntervention (no specific range, linking to an agent)
noria-data:TT_001
    noria:troubleTicketPartyIntervention noria-data:Person_Alice .

# noria:troubleTicketCharacteristic (no specific range, linking to a generic property)
noria-data:TT_001
    noria:troubleTicketCharacteristic noria-data:Property_CustomerImpactLevel .

noria-data:Property_CustomerImpactLevel
    a noria:Property ;
    rdfs:label "Customer Impact Level Property"@en ;
    rdfs:comment "A generic property representing the level of impact on customers."@en .

# noria:actionCorrelatedOperationPlan (domain noria:CorrectiveMaintenanceAction, noria:ChangeAction - need to create instances of these)
# Let's create some simple pep:Action instances.
noria-data:Action_DBRestart
    a pep:Action ;
    rdfs:label "Database Restart Action"@en ;
    rdfs:comment "An action to restart the database service."@en ;
    noria:actionCorrelatedOperationPlan noria-data:OpPlan_DBRestart .

noria-data:Action_TransceiverReplace
    a pep:Action ;
    rdfs:label "Transceiver Replacement Action"@en ;
    rdfs:comment "An action to replace a network transceiver."@en ;
    noria:actionCorrelatedOperationPlan noria-data:OpPlan_TransceiverReplacement .

noria-data:Action_RouterPatch
    a pep:Action ;
    rdfs:label "Router Patching Action"@en ;
    rdfs:comment "An action to apply patches to a router."@en ;
    noria:actionCorrelatedOperationPlan noria-data:OpPlan_RouterPatching .

# Ensure all classes have at least one instance and are linked.
# All classes identified for instantiation have at least one instance above.
# All object properties have been used at least once.
# All datatype properties have been used at least once.
# All entities are linked to at least one other entity.
# The graph is reasonably large with multiple instances and interconnections.
