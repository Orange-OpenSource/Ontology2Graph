# --- Document Attachments ---

noria-data:Doc_RouterUpgradePlan
    a noria:DocumentAttachment ;
    rdfs:label "Router Upgrade Plan Document"@en ;
    rdfs:comment "Attachment for CR-001: detailed plan for router OS upgrade."@en ;
    dcterms:isPartOf noria-data:CR_001_RouterOSUpgrade ;
    dcterms:title "Router_OS_Upgrade_Plan_v1.0.pdf"^^xsd:string ;
    dcterms:format "application/pdf"^^xsd:string .

noria-data:Doc_ServerLog
    a noria:DocumentAttachment ;
    rdfs:label "Server Log Excerpt"@en ;
    rdfs:comment "Attachment for TT-002: relevant server log excerpt."@en ;
    dcterms:isPartOf noria-data:TT_002_CRM_Perf ;
    dcterms:title "app-srv-par-01_logs_20240420.txt"^^xsd:string ;
    dcterms:format "text/plain"^^xsd:string .

noria-data:Doc_SecurityReport
    a noria:DocumentAttachment ;
    rdfs:label "Security Incident Report"@en ;
    rdfs:comment "Attachment for TT-003: detailed security incident report."@en ;
    dcterms:isPartOf noria-data:TT_003_SecurityAlert ;
    dcterms:title "Security_Incident_Report_DB_Login_Anomaly.pdf"^^xsd:string ;
    dcterms:format "application/pdf"^^xsd:string .

# --- Anomaly Patterns ---

noria-data:AnomalyPattern_HighCPULoad
    a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Anomaly"@en ;
    rdfs:comment "Anomaly pattern for sustained high CPU utilization on critical servers."@en ;
    folio:hasConsequence "Application performance degradation"^^xsd:string ;
    folio:hasCause "Misconfigured application or resource exhaustion"^^xsd:string .

noria-data:AnomalyPattern_LinkFlap
    a noria:AnomalyPattern ;
    rdfs:label "Network Link Flapping Anomaly"@en ;
    rdfs:comment "Anomaly pattern for frequent up/down transitions on a network link."@en ;
    folio:hasConsequence "Network instability, service interruptions"^^xsd:string ;
    folio:hasCause "Faulty cable or transceiver, or port misconfiguration"^^xsd:string .

noria-data:AnomalyPattern_UnauthorizedAccess
    a noria:AnomalyPattern ;
    rdfs:label "Unauthorized Access Attempt Anomaly"@en ;
    rdfs:comment "Anomaly pattern for multiple failed login attempts or suspicious access patterns."@en ;
    folio:hasConsequence "Data breach, system compromise"^^xsd:string ;
    folio:hasCause "Brute-force attack or compromised credentials"^^xsd:string .

# --- Operation Plans ---

noria-data:OperationPlan_RestartInterface
    a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a network interface."@en ;
    noria:operationPlanPreCondition noria-data:PreCond_InterfaceDown ;
    noria:operationPlanPostCondition noria-data:PostCond_InterfaceUp .

noria-data:OperationPlan_DiagnoseCPU
    a noria:OperationPlan ;
    rdfs:label "Diagnose High CPU Procedure"@en ;
    rdfs:comment "Procedure to diagnose the cause of high CPU utilization."@en ;
    noria:operationPlanPreCondition noria-data:PreCond_HighCPU ;
    noria:operationPlanPostCondition noria-data:PostCond_CPUResolved .

noria-data:OperationPlan_RouterOSUpgrade
    a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for upgrading router operating systems."@en ;
    noria:operationPlanPreCondition noria-data:PreCond_BackupComplete ;
    noria:operationPlanPostCondition noria-data:PostCond_OSUpgradeSuccess .

noria-data:OperationPlan_SecurityIncidentResponse
    a noria:OperationPlan ;
    rdfs:label "Security Incident Response Plan"@en ;
    rdfs:comment "Plan for responding to security incidents like unauthorized access."@en ;
    noria:operationPlanPreCondition noria-data:PreCond_SecurityAlert ;
    noria:operationPlanPostCondition noria-data:PostCond_IncidentContained .

# --- Action Pre/Post Conditions ---

noria-data:PreCond_InterfaceDown
    a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Pre-condition: The network interface's operational status is 'down'."@en .

noria-data:PostCond_InterfaceUp
    a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Post-condition: The network interface's operational status is 'up' and stable."@en .

noria-data:PreCond_HighCPU
    a noria:ActionPreCondition ;
    rdfs:label "Server CPU Load High"@en ;
    rdfs:comment "Pre-condition: Server CPU utilization exceeds threshold."@en .

noria-data:PostCond_CPUResolved
    a noria:ActionPostCondition ;
    rdfs:label "Server CPU Load Normal"@en ;
    rdfs:comment "Post-condition: Server CPU utilization returns to normal levels."@en .

noria-data:PreCond_BackupComplete
    a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup Complete"@en ;
    rdfs:comment "Pre-condition: Configuration backup of the device is complete."@en .

noria-data:PostCond_OSUpgradeSuccess
    a noria:ActionPostCondition ;
    rdfs:label "OS Upgrade Successful"@en ;
    rdfs:comment "Post-condition: Router OS upgrade completed successfully and device is operational."@en .

noria-data:PreCond_SecurityAlert
    a noria:ActionPreCondition ;
    rdfs:label "Security Alert Triggered"@en ;
    rdfs:comment "Pre-condition: A security alert indicating potential compromise has been triggered."@en .

noria-data:PostCond_IncidentContained
    a noria:ActionPostCondition ;
    rdfs:label "Security Incident Contained"@en ;
    rdfs:comment "Post-condition: The security incident has been successfully contained and mitigated."@en .

# Link EventRecords to OperationPlans (as actions)
noria-data:Event_RouterDown_01 noria:alarmProposedRepairAction noria-data:OperationPlan_RestartInterface .
noria-data:Event_ServerHighCPU_01 noria:alarmProposedRepairAction noria-data:OperationPlan_DiagnoseCPU .
noria-data:Event_LoginFailure_01 noria:alarmProposedRepairAction noria-data:OperationPlan_SecurityIncidentResponse .

# Link ChangeRequest to OperationPlan (as procedures)
noria-data:CR_001_RouterOSUpgrade pep:hasProcedure noria-data:OperationPlan_RouterOSUpgrade .
noria-data:CR_002_ServerPatching pep:hasProcedure noria-data:OperationPlan_DiagnoseCPU . # Reusing for patching context

# Link alarms to mitigation (TroubleTicket or ChangeRequest as ProcedureExecutionContainer)
noria-data:Event_RouterDown_01 noria:alarmMitigatedBy noria-data:TT_001_InternetOutage .
noria-data:Event_ServerHighCPU_01 noria:alarmMitigatedBy noria-data:TT_002_CRM_Perf .
noria-data:Event_LoginFailure_01 noria:alarmMitigatedBy noria-data:TT_003_SecurityAlert .

# Ensure agentManagesResource is used
noria-data:OU_NetworkOps noria:agentManagesResource noria-data:Resource_Router01_Paris, noria-data:Resource_Router02_London, noria-data:Resource_Switch01_London, noria-data:Resource_Switch02_Paris .
noria-data:OU_AppDev noria:agentManagesResource noria-data:Resource_Server01_Paris, noria-data:Resource_Server02_Paris .
noria-data:OU_SecurityOps noria:agentManagesResource noria-data:Resource_Firewall01_Paris .
noria-data:OU_DataCenterOps noria:agentManagesResource noria-data:Resource_Server03_NYC, noria-data:Resource_LB01_NYC .
