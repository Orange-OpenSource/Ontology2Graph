# --- Organizations, Organizational Units, and Agents (Persons) ---

noria-data:Org_GlobalTelco
    a org:Organization ;
    rdfs:label "GlobalTelco Inc."@en ;
    rdfs:comment "A major telecommunications company."@en ;
    org:hasUnit noria-data:OU_NetworkOps, noria-data:OU_AppDev, noria-data:OU_SecurityOps .

noria-data:Org_TechSolutions
    a org:Organization ;
    rdfs:label "TechSolutions Ltd."@en ;
    rdfs:comment "A technology consulting and service provider."@en ;
    org:hasUnit noria-data:OU_CustomerSupport, noria-data:OU_InfrastructureMgmt .

noria-data:Org_CloudCorp
    a org:Organization ;
    rdfs:label "CloudCorp Innovations"@en ;
    rdfs:comment "A leading cloud service provider."@en ;
    org:hasUnit noria-data:OU_DataCenterOps .

noria-data:OU_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Department"@en ;
    rdfs:comment "Manages the core network infrastructure for GlobalTelco."@en ;
    org:unitOf noria-data:Org_GlobalTelco ;
    noria:agentWorkingHours "Mon-Fri, 9:00-17:00 CET"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:agentInstructions "For critical issues, use emergency hotline."^^xsd:string .

noria-data:OU_AppDev
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Develops and maintains internal applications for GlobalTelco."@en ;
    org:unitOf noria-data:Org_GlobalTelco ;
    noria:agentWorkingHours "Mon-Fri, 9:00-18:00 CET"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Chat ;
    noria:agentInstructions "Submit tickets via JIRA for new features."^^xsd:string .

noria-data:OU_SecurityOps
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Monitors and responds to security incidents for GlobalTelco."@en ;
    org:unitOf noria-data:Org_GlobalTelco ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Phone ;
    noria:agentInstructions "Immediate escalation for all security alerts."^^xsd:string .

noria-data:OU_CustomerSupport
    a org:OrganizationalUnit ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "Provides first-line support to TechSolutions clients."@en ;
    org:unitOf noria-data:Org_TechSolutions ;
    noria:agentWorkingHours "Mon-Sat, 8:00-20:00 EST"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:agentInstructions "Refer to knowledge base for common issues."^^xsd:string .

noria-data:OU_InfrastructureMgmt
    a org:OrganizationalUnit ;
    rdfs:label "Infrastructure Management"@en ;
    rdfs:comment "Manages IT infrastructure for TechSolutions."@en ;
    org:unitOf noria-data:Org_TechSolutions ;
    noria:agentWorkingHours "Mon-Fri, 9:00-17:00 EST"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Chat ;
    noria:agentInstructions "Use internal ticketing system for requests."^^xsd:string .

noria-data:OU_DataCenterOps
    a org:OrganizationalUnit ;
    rdfs:label "Data Center Operations"@en ;
    rdfs:comment "Manages physical and virtual infrastructure in CloudCorp data centers."@en ;
    org:unitOf noria-data:Org_CloudCorp ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Phone ;
    noria:agentInstructions "Follow strict change management protocols."^^xsd:string .

noria-data:Person_Alice
    a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, Team Lead for Network Operations."@en ;
    org:memberOf noria-data:OU_NetworkOps ;
    noria:agentWorkingHours "Mon-Fri, 9:00-17:00 CET"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Phone ;
    noria:agentInstructions "Call directly for P1 incidents."^^xsd:string .

noria-data:Person_Bob
    a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Software Developer in Application Development."@en ;
    org:memberOf noria-data:OU_AppDev ;
    noria:agentWorkingHours "Mon-Fri, 10:00-19:00 CET"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:agentInstructions "Email for all non-urgent requests."^^xsd:string .

noria-data:Person_Charlie
    a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "IT Support Specialist in Network Operations."@en ;
    org:memberOf noria-data:OU_NetworkOps ;
    noria:agentWorkingHours "Mon-Fri, 8:00-16:00 CET"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Chat ;
    noria:agentInstructions "First point of contact for all network issues."^^xsd:string .

noria-data:Person_David
    a foaf:Agent ;
    rdfs:label "David Lee"@en ;
    rdfs:comment "Security Analyst in Security Operations Center."@en ;
    org:memberOf noria-data:OU_SecurityOps ;
    noria:agentWorkingHours "Mon-Fri, 9:00-17:00 CET"^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:agentInstructions "Report suspicious activities via security portal."^^xsd:string .

noria-data:Person_Eve
    a foaf:Agent ;
