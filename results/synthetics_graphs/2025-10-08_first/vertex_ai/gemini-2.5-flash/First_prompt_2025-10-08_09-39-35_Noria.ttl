# --- Event Records ---

noria-data:Event_RouterDown_01
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event (Router01)"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Router01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/0, changed state to down."^^xsd:string ;
    noria:logOriginatingManagedObject noria-data:Resource_Router01_Paris ;
    noria:logOriginatingManagementSystem noria-data:App_Monitoring ;
    noria:alarmSeverity noria-data:AlarmSeverity_Critical ;
    noria:alarmProposedRepairAction noria-data:OperationPlan_RestartInterface .

