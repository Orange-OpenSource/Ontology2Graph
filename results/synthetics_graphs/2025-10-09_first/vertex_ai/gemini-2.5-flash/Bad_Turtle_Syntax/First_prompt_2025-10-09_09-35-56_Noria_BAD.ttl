# noria:Application
<noria/application/CRMSystem>
    a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:comment "Core application for managing customer interactions."@en ;
    noria:applicationModelIdentifier "CRM-V2.1"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CRM"^^xsd:string ;
    noria:applicationType <kos/application/type/ServicePlatform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Market and Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Customer Support Management"^^xsd:string ;
    noria:elementManagedBy <org/ApplicationDevTeam> .

<noria/application/NetworkMonitoring>
