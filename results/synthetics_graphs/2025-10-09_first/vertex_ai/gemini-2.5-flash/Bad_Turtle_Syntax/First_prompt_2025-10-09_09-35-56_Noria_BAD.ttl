    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T13:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketRelatedParty <foaf/BobJohnson> ;
    noria:troubleTicketRelatedService <noria/service/CustomerInternetAccess> ;
    noria:troubleTicketRelatedResource <noria/resource/Router1> ;
    noria:troubleTicketImpacts <noria/service/CustomerInternetAccess> , <noria/resource/Router1> .

