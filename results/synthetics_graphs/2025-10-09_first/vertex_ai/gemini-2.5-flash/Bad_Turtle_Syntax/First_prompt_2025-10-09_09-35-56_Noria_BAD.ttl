    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "Application for real-time network performance monitoring."@en ;
    noria:applicationModelIdentifier "NMS-PRO-V3.0"^^xsd:string ;
    noria:applicationNumericalIdentifier "1002"^^xsd:int ;
    noria:applicationShortIdentifier "NMS"^^xsd:string ;
