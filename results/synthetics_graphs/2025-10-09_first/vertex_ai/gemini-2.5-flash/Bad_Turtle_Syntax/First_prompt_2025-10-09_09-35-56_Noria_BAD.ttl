# noria:EventRecord (used as trigger for TroubleTicket)
<noria/event/LogRouter1Down>
    a noria:EventRecord ;
    rdfs:label "Router1 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Router1."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject <noria/resource/Router1> ;
    noria:logOriginatingManagementSystem <noria/application/NetworkMonitoring> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<noria/event/AppCrashLog>
    a noria:EventRecord ;
    rdfs:label "CRM Application Crash Log"@en ;
    rdfs:comment "Log entry indicating a crash in the CRM application."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logText "Application CRMProd encountered a critical error and restarted."^^xsd:string ;
    noria:logOriginatingManagedObject <noria/application/CRMSystem> ;
    noria:logOriginatingManagementSystem <noria/application/NetworkMonitoring> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent <foaf/CharlieBrown> .

# noria:TroubleTicket
