# Synthetic Knowledge Graph based on NORIA Ontology

# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .
@prefix time: <http://www.w3.org/2006/time#> .

@prefix bot: <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix org: <http://www.w3.org/ns/org#> .

@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix saref: <http://ontology.tno.nl/saref#>.

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (Knowledge Organization Systems)
# =============================================================================

# Agent Contact Method
<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via email."@en .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via phone."@en .

# Application Type
<kos/application/type/ServicePlatform>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "An application acting as a service platform."@en .

<kos/application/type/Infrastructure>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application managing core infrastructure."@en .

# Application Business Importance
<kos/application/business-importance/High>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Importance"@en ;
    rdfs:comment "Application with high business impact."@en .

<kos/application/business-importance/Medium>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Importance"@en ;
    rdfs:comment "Application with medium business impact."@en .

# Application SLA Level
<https://w3id.org/noria/kos/application/sla-level/Gold>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement tier."@en .

<https://w3id.org/noria/kos/application/sla-level/Silver>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Standard Service Level Agreement tier."@en .

# Application Status
<https://w3id.org/noria/kos/application/status/InProduction>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application module is currently live and operational."@en .

<https://w3id.org/noria/kos/application/status/Maintenance>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Under Maintenance"@en ;
    rdfs:comment "Application module is currently undergoing maintenance."@en .

# Service Type
<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by customers."@en .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations."@en .

# TroubleTicket Severity
<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Highest severity, immediate impact on critical services."@en .

<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Significant impact on services, but not critical."@en .

