# =============================================================================
# Synthetic Knowledge Graph Instances
# =============================================================================

# --- Organizations and Agents ---

noria:Org_ITOperations
    a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The central department responsible for IT infrastructure and services."@en ;
    org:hasUnit noria:OrgUnit_NetworkTeam, noria:OrgUnit_AppSupportTeam .

noria:OrgUnit_NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, direct phone for critical network outages."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    org:unitOf noria:Org_ITOperations .

noria:OrgUnit_AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    noria:agentWorkingHours "8:30 AM - 6:00 PM (Mon-Sat)"^^xsd:string ;
    noria:agentInstructions "Use internal chat for urgent app issues, email for general inquiries."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    org:unitOf noria:Org_ITOperations .

noria:Person_AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer Lead."@en ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Escalate to Alice for P1 network incidents."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    org:memberOf noria:OrgUnit_NetworkTeam .

noria:Person_BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Specialist."@en ;
    noria:agentWorkingHours "8:30 AM - 6:00 PM (Mon-Sat)"^^xsd:string ;
    noria:agentInstructions "Bob is the primary contact for CRM application issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    org:memberOf noria:OrgUnit_AppSupportTeam .

noria:Person_JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "External user attempting to access CRM."@en .

noria:CUid_AliceSmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith's corporate account."@en ;
    foaf:accountName "asmith"@xsd:string ;
    foaf:holdsAccount noria:Person_AliceSmith .

noria:CUid_BobJohnson
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Bob Johnson's corporate account."@en ;
    foaf:accountName "bjohnson"@xsd:string ;
    foaf:holdsAccount noria:Person_BobJohnson .

# --- Locations ---

noria:Site_MainDataCenter
    a bot:Site ;
    rdfs:label "Main Data Center Site"@en ;
    rdfs:comment "Primary data center facility."@en ;
    noria:siteId "DC01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Techville"^^xsd:string ;
    noria:sitePrincipalAddressCountry "USA"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

noria:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Server room within the main data center."@en ;
    bot:hasSpace noria:Locus_RackA1 .

noria:Locus_RackA1
    a noria:Locus ;
    rdfs:label "Rack A1 Locus"@en ;
    rdfs:comment "Specific location for Rack A1 in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

noria:Room_NetworkRoomB
    a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room within the main data center."@en ;
    bot:hasSpace noria:Locus_RackB5 .

noria:Locus_RackB5
    a noria:Locus ;
    rdfs:label "Rack B5 Locus"@en ;
    rdfs:comment "Specific location for Rack B5 in Network Room B."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "5"^^xsd:string .

noria:Site_DRSite
    a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary site for disaster recovery."@en ;
    noria:siteId "DR01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "456 Backup Road"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90211"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Recoverytown"^^xsd:string ;
    noria:sitePrincipalAddressCountry "USA"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Backup Road"^^xsd:string .

noria:Room_DRServerRoom
    a noria:Room ;
    rdfs:label "DR Server Room"@en ;
    rdfs:comment "Server room in the disaster recovery site."@en ;
    bot:hasSpace noria:Locus_DRRackC1 .

noria:Locus_DRRackC1
    a noria:Locus ;
    rdfs:label "DR Rack C1 Locus"@en ;
    rdfs:comment "Specific location for Rack C1 in DR Server Room."@en ;
    noria:locusLine "C"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

# --- Applications and Services ---

noria:App_CRM
    a noria:Application ;
    rdfs:label "Customer Relationship Management (CRM) Application"@en ;
    rdfs:comment "Core application for managing customer interactions."@en ;
    noria:applicationModelIdentifier "CRM-PROD-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CRM-P"^^xsd:string ;
    noria:applicationFunctionalDomain "Market and Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Customer Support Operations"^^xsd:string ;
    noria:applicationType <kos/application/type/ServicePlatform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> .

noria:App_Monitoring
    a noria:Application ;
    rdfs:label "Network Monitoring System (NMS) Application"@en ;
    rdfs:comment "Application for monitoring network devices and services."@en ;
    noria:applicationModelIdentifier "NMS-V3"^^xsd:string ;
    noria:applicationNumericalIdentifier "2002"^^xsd:int ;
    noria:applicationShortIdentifier "NMS"^^xsd:string ;
    noria:applicationFunctionalDomain "Service Development, Management and Operations"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Network Performance Management"^^xsd:string ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Medium> .

noria:App_Billing
    a noria:Application ;
    rdfs:label "Billing System Application"@en ;
    rdfs:comment "Application for customer billing and invoicing."@en ;
    noria:applicationModelIdentifier "BILL-V1"^^xsd:string ;
    noria:applicationNumericalIdentifier "3003"^^xsd:int ;
    noria:applicationShortIdentifier "BILL"^^xsd:string ;
    noria:applicationFunctionalDomain "Revenue Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Invoice Generation"^^xsd:string ;
    noria:applicationType <kos/application/type/ServicePlatform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> .

noria:AppModule_CRM_Prod
    a noria:ApplicationModule ;
    rdfs:label "CRM Production Module"@en ;
    rdfs:comment "Production instance of the CRM application."@en ;
    noria:applicationModuleOf noria:App_CRM ;
    noria:applicationModuleName "CRM-PROD-V2_Instance01"^^xsd:string ;
    noria:applicationModuleIdentifier "Instance01"^^xsd:string ;
    noria:applicationModuleAdministrationTeam noria:OrgUnit_AppSupportTeam ;
    noria:applicationModuleAdministrationLeader noria:Person_BobJohnson ;
    noria:applicationModuleSupportTeam noria:OrgUnit_AppSupportTeam ;
    noria:applicationModuleSupportLeader noria:Person_BobJohnson ;
