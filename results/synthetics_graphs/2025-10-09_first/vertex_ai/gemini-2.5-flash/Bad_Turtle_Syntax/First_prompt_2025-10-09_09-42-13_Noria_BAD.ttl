# --- Procedural Elements ---

noria:OpPlan_RestartInterface
    a noria:OperationPlan ;
    rdfs:label "Operation Plan: Restart Network Interface"@en ;
    rdfs:comment "Standard procedure for restarting a network interface."@en ;
    noria:operationPlanPreCondition noria:PreCond_InterfaceDown ;
    noria:operationPlanPostCondition noria:PostCond_InterfaceUp .

noria:OpPlan_DiagnoseHighCPU
    a noria:OperationPlan ;
    rdfs:label "Operation Plan: Diagnose High CPU"@en ;
    rdfs:comment "Procedure to diagnose high CPU utilization on a server."@en ;
    noria:operationPlanPreCondition noria:PreCond_HighCPUAlert ;
    noria:operationPlanPostCondition noria:PostCond_CPUUtilNormal .

noria:OpPlan_DBCleanup
    a noria:OperationPlan ;
    rdfs:label "Operation Plan: Database Disk Cleanup"@en ;
    rdfs:comment "Standard procedure for cleaning up disk space on database servers."@en ;
    noria:operationPlanPreCondition noria:PreCond_DiskFull ;
    noria:operationPlanPostCondition noria:PostCond_DiskSpaceNormal .

noria:PreCond_InterfaceDown
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Network Interface is Down"@en ;
    rdfs:comment "Condition that the target network interface must be in a 'down' state."@en .

noria:PostCond_InterfaceUp
    a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: the network interface is in an 'up' state."@en .

noria:PreCond_HighCPUAlert
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: High CPU Alert Triggered"@en ;
    rdfs:comment "Condition that a high CPU alert has been triggered for a server."@en .

noria:PostCond_CPUUtilNormal
    a noria:ActionPostCondition ;
    rdfs:label "Post-condition: CPU Utilization Normal"@en ;
    rdfs:comment "Expected outcome: CPU utilization returns to normal levels."@en .

noria:PreCond_DiskFull
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Disk Space Critical"@en ;
    rdfs:comment "Condition that disk space is critically low on a server."@en .

noria:PostCond_DiskSpaceNormal
    a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Disk Space Normal"@en ;
    rdfs:comment "Expected outcome: disk space utilization returns to normal levels."@en .

noria:PEC_InterfaceTroubleshoot
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution Container: Interface Troubleshooting"@en ;
    rdfs:comment "Container for actions taken during network interface troubleshooting."@en ;
    dcterms:member noria:PE_InterfaceRestartAttempt .

noria:PE_InterfaceRestartAttempt
    a pep:ProcedureExecution ;
    rdfs:label "Procedure Execution: Interface Restart Attempt"@en ;
    rdfs:comment "An attempt to restart the network interface on Core Router 01."@en ;
    noria:actionCorrelatedOperationPlan noria:OpPlan_RestartInterface ;
    pep:madeBy noria:Person_AliceSmith ;
    pep:hasCommand "interface GigabitEthernet0/0/1; shutdown; no shutdown"^^xsd:string ;
    pep:hasSimpleResult "Interface restarted successfully."^^xsd:string ;
    dcterms:created "2023-10-26T10:12:00Z"^^xsd:dateTime .

noria:PEC_AppServerDiagnosis
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution Container: App Server Diagnosis"@en ;
    rdfs:comment "Container for actions taken to diagnose high CPU on App Server 01."@en ;
    dcterms:member noria:PE_CheckProcesses .

noria:PE_CheckProcesses
    a pep:ProcedureExecution ;
    rdfs:label "Procedure Execution: Check Processes"@en ;
    rdfs:comment "Checking running processes on Application Server 01."@en ;
    noria:actionCorrelatedOperationPlan noria:OpPlan_DiagnoseHighCPU ;
    pep:madeBy noria:Person_BobJohnson ;
    pep:hasCommand "ssh appserver01 'top -b -n 1'"^^xsd:string ;
    pep:hasSimpleResult "High CPU by Java process for CRM."^^xsd:string ;
    dcterms:created "2023-10-26T10:18:00Z"^^xsd:dateTime .

noria:PEC_DBCleanup
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution Container: DB Cleanup"@en ;
    rdfs:comment "Container for actions taken to clean up disk space on DB Server 01."@en ;
    dcterms:member noria:PE_ExecuteCleanupScript .

noria:PE_ExecuteCleanupScript
    a pep:ProcedureExecution ;
    rdfs:label "Procedure Execution: Execute Cleanup Script"@en ;
    rdfs:comment "Executing a script to remove old database logs."@en ;
    noria:actionCorrelatedOperationPlan noria:OpPlan_DBCleanup ;
    pep:madeBy noria:Person_BobJohnson ;
    pep:hasCommand "ssh dbserver01 '/opt/scripts/cleanup_db_logs.sh'"^^xsd:string ;
    pep:hasSimpleResult "Disk space reduced to 60%."^^xsd:string ;
    dcterms:created "2023-10-27T15:00:00Z"^^xsd:dateTime .

# --- Anomaly Patterns and Monitored Attributes ---

noria:AnomalyPattern_NetworkCongestion
    a noria:AnomalyPattern ;
    rdfs:label "Network Congestion Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating network congestion, characterized by high latency and packet loss."@en ;
    folio:hasCause noria:Event_CR01_InterfaceDown .

noria:AnomalyPattern_AppPerformanceDegradation
    a noria:AnomalyPattern ;
    rdfs:label "Application Performance Degradation Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating slow application response times and high resource usage."@en ;
    folio:hasCause noria:Event_AppServer_HighCPU .

noria:MonitoredAttr_CPUUsage
    a owl:Thing ;
    rdfs:label "CPU Usage Attribute"@en ;
    rdfs:comment "Represents the monitored CPU usage attribute."@en ;
    noria:structuralElementObservableData "95%"^^xsd:string .

noria:Obs_InterfaceStatus
    a noria:StructuralObservable ;
    rdfs:label "Interface Operational Status Observable"@en ;
    rdfs:comment "An observable property representing the operational status of a network interface."@en ;
    noria:structuralObservableOf noria:NI_CR01_GE001 .

