# --- Organizations and Agents ---

<org/OrangeTelecom_extra_node_3>
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "A leading telecommunications company."@en ;
    org:hasUnit <org/NetworkOperations_extra_node_3>, <org/ApplicationSupport_extra_node_3> .

<org/NetworkOperations_extra_node_3>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:memberOf <org/OrangeTelecom_extra_node_3> ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentInstructions "Contact via dedicated ticketing system for critical issues."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_3> .

<org/ApplicationSupport_extra_node_3>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    org:memberOf <org/OrangeTelecom_extra_node_3> ;
    noria:agentWorkingHours "Mon-Fri 9:00-18:00 CET"@en ;
    noria:agentInstructions "Submit a ticket via the internal portal for all requests."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_3> .

<foaf/person/john.doe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Network Engineer Lead."@en ;
    foaf:mbox <mailto:john.doe@example.com_extra_node_3> ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00 CET"@en ;
    noria:agentInstructions "Escalate to John for critical network incidents."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_3> .

<foaf/person/jane.smith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:jane.smith@example.com_extra_node_3> ;
    noria:agentWorkingHours "Mon-Fri 9:30-18:30 CET"@en ;
    noria:agentInstructions "Jane is the primary contact for CRM application issues."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_3> .

<noria/cuid/johndoe_corp>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "johndoe_corp"^^xsd:string ;
    observable:accountLogin "johndoe_corp"^^xsd:string ;
    observable:accountIdentifier "JD001"^^xsd:string ;
    foaf:holdsAccount <foaf/person/john.doe> .

<noria/cuid/janesmith_corp>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "janesmith_corp"^^xsd:string ;
    observable:accountLogin "janesmith_corp"^^xsd:string ;
    observable:accountIdentifier "JS002"^^xsd:string ;
    foaf:holdsAccount <foaf/person/jane.smith> .

# --- Locations ---

<bot/site/ParisDataCenter>
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center facility in Paris."@en ;
    noria:siteId "PDC01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    wgs84_pos:lat "48.867"^^xsd:float ;
    wgs84_pos:long "2.333"^^xsd:float .

<bot/site/LyonOffice>
    a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "LRO01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "69007"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Lyon"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    wgs84_pos:lat "45.749"^^xsd:float ;
    wgs84_pos:long "4.846"^^xsd:float .

<noria/room/ServerRoomA_extra_node_3>
    a noria:Room ;
    rdfs:label "Server_extra_node_3 Room A"@en ;
    rdfs:comment "Primary server room in Paris Data Center."@en ;
    bot:hasSpace <noria/locus/RackA1_extra_node_3>, <noria/locus/RackA2_extra_node_3> ;
    bot:hasElement <noria/resource/RouterCore01> .

<noria/room/NetworkClosetB_extra_node_3>
    a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace <noria/locus/CabinetB1> ;
    bot:hasElement <noria/resource/SwitchEdge01> .

<noria/locus/RackA1_extra_node_3>
    a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical servers in Server_extra_node_3 Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasElement <noria/resource/ServerWeb01>, <noria/resource/ServerDB01> .

<noria/locus/RackA2_extra_node_3>
    a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of backup servers in Server_extra_node_3 Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:hasElement <noria/resource/ServerBackup01> .

<noria/locus/CabinetB1>
    a noria:Locus ;
    rdfs:label "Cabinet B1"@en ;
    rdfs:comment "Location of edge network equipment in Network Closet B."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasElement <noria/resource/FirewallEdge01> .

