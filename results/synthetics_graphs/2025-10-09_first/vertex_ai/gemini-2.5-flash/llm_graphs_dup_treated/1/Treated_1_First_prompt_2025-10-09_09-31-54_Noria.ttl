# Network Interfaces
<noria/NetworkInterface_R1_Eth0>
    a noria:NetworkInterface ;
    rdfs:label "Router1 Ethernet0/0"@en ;
    rdfs:comment "Interface connecting Router1 to Database_extra_node_6 Server_extra_node_6 and Access Switch."@en ;
    noria:networkInterfaceDescription "Uplink to DB-PROD-01 and Access-SW-01"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceOf <noria/Resource_Router1> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled_extra_node_6> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_6> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-7"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-6"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

<noria/NetworkInterface_R1_Eth1>
    a noria:NetworkInterface ;
