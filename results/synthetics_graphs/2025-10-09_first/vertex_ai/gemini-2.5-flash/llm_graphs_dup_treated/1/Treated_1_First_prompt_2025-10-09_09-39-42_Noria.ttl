    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_5> ;
    noria:alarmProposedRepairAction <noria/OperationPlan/RouterOSUpgradeProcedure> ;
    noria:elementManagedBy <org/NetworkOperationsTeam> .

<noria/EventRecord/Log-DB-Conn-Error-20240102-001>
