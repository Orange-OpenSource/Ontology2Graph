    noria:logOriginatingManagedObject <noria/Resource/CoreRouter01_extra_node_5> ;
    noria:logOriginatingManagementSystem <noria/Application/NetworkMonitoring> ;
    noria:logOriginatingAgent <foaf/Agent/AliceSmith_extra_node_5> ;
    noria:logText "CPU utilization on CoreRouter01_extra_node_5 exceeded 90% for 5 minutes."^^xsd:string ;
