@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Organization Systems (KOS) Concepts
# =============================================================================

<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents, such as email or phone."@en .

<kos/org/agent-contact-method/Email_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Email_extra_node_1"@en ;
    skos:altLabel "Electronic Mail"@en ;
    skos:definition "Preferred contact method via electronic mail."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/Phone_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Phone_extra_node_1"@en ;
    skos:altLabel "Telephone"@en ;
    skos:definition "Preferred contact method via telephone call."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/application/type>
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications, e.g., Web Frontend, Database_extra_node_1, API Gateway."@en .

<kos/application/type/WebFrontend>
    a skos:Concept ;
    skos:prefLabel "Web Frontend"@en ;
    skos:definition "An application type representing the user-facing part of a web application."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/Database_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Database_extra_node_1"@en ;
    skos:definition "An application type representing a data storage and retrieval system."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/APIGateway>
    a skos:Concept ;
    skos:prefLabel "API Gateway"@en ;
    skos:definition "An application type acting as a single entry point for microservices."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/business-importance>
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying business importance of applications for risk assessment."@en .

<kos/application/business-importance/Critical_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Critical_extra_node_1"@en ;
    skos:definition "Application is critical to core business operations; downtime has severe impact."@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/business-importance/High_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "High_extra_node_1"@en ;
    skos:definition "Application is important for business operations; downtime has significant impact."@en ;
    skos:inScheme <kos/application/business-importance> .

<https://w3id.org/noria/kos/application/sla-level>
    a skos:ConceptScheme ;
    rdfs:label "Application Module SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying Service Level Agreement (SLA) levels for application modules."@en .

<https://w3id.org/noria/kos/application/sla-level/Gold_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Gold_extra_node_1"@en ;
    skos:definition "Highest SLA level, indicating maximum availability and performance guarantees."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<https://w3id.org/noria/kos/application/sla-level/Silver_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Silver_extra_node_1"@en ;
    skos:definition "Medium_extra_node_1 SLA level, indicating good availability and performance guarantees."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<https://w3id.org/noria/kos/application/status>
    a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    rdfs:comment "A scheme for classifying operational statuses of application modules, e.g., In Production, Development_extra_node_1."@en .

<https://w3id.org/noria/kos/application/status/InProduction_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:definition "The application module is currently live and serving users."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/status/Development_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Development_extra_node_1"@en ;
    skos:definition "The application module is under active development and not yet in production."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<kos/service/type>
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services, such as Customer_extra_node_1 Facing or Resource Facing."@en .

<kos/service/type/CustomerFacingService_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Customer_extra_node_1 Facing Service"@en ;
    skos:definition "A service directly consumed by external customers."@en ;
    skos:inScheme <kos/service/type> .

<kos/service/type/ResourceFacingService_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Resource Facing Service"@en ;
    skos:definition "A service that supports other services or internal operations, not directly exposed to customers."@en ;
    skos:inScheme <kos/service/type> .

<kos/TroubleTicket/severity>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying severity levels of trouble tickets, e.g., Major_extra_node_1, Minor."@en .

<kos/TroubleTicket/severity/Major_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Major_extra_node_1"@en ;
    skos:definition "A trouble ticket indicating a significant impact on service or operations."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Minor>
    a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:definition "A trouble ticket indicating a limited impact on service or operations."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/type>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of trouble tickets, e.g., Failure_extra_node_1, Assistance_extra_node_1."@en .

<kos/TroubleTicket/type/Failure_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Failure_extra_node_1"@en ;
    skos:definition "A trouble ticket reporting a system or service failure."@en ;
    skos:inScheme <kos/TroubleTicket/type> .

<kos/TroubleTicket/type/Assistance_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Assistance_extra_node_1"@en ;
    skos:definition "A trouble ticket requesting assistance or support."@en ;
    skos:inScheme <kos/TroubleTicket/type> .

<kos/TroubleTicket/category>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Criticity Scheme"@en ;
    rdfs:comment "A scheme for classifying criticity of trouble tickets from a customer impact perspective."@en .

<kos/TroubleTicket/category/InterruptedService_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Interrupted Service"@en ;
    skos:definition "Criticity indicating a complete interruption of service."@en ;
    skos:inScheme <kos/TroubleTicket/category> .

<kos/TroubleTicket/category/CorruptedService_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Corrupted Service"@en ;
    skos:definition "Criticity indicating data corruption or incorrect service behavior."@en ;
    skos:inScheme <kos/TroubleTicket/category> .

<kos/TroubleTicket/priority>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A scheme for classifying priority levels of trouble tickets, e.g., P1_extra_node_1, P2_extra_node_1."@en .

<kos/TroubleTicket/priority/P1_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "P1_extra_node_1"@en ;
    skos:definition "Highest priority, requiring immediate attention and resolution."@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/priority/P2_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "P2_extra_node_1"@en ;
    skos:definition "High_extra_node_1 priority, requiring prompt attention."@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/origin>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying origins of trouble tickets, e.g., Customer_extra_node_1, Supervision_extra_node_1."@en .

<kos/TroubleTicket/origin/Customer_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Customer_extra_node_1"@en ;
    skos:definition "Trouble ticket originated by a customer report."@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/origin/Supervision_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Supervision_extra_node_1"@en ;
    skos:definition "Trouble ticket originated by an automated monitoring system."@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/urgency>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A scheme for classifying urgency levels of trouble tickets, e.g., Immediate_extra_node_1 Intervention."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Immediate_extra_node_1 Intervention"@en ;
    skos:definition "Requires immediate action due to severe impact."@en ;
    skos:inScheme <kos/TroubleTicket/urgency> .

<kos/TroubleTicket/urgency/DeferredIntervention_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Deferred Intervention"@en ;
    skos:definition "Intervention can be scheduled for a later time."@en ;
    skos:inScheme <kos/TroubleTicket/urgency> .

<kos/TroubleTicket/trouble-category>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category Scheme"@en ;
    rdfs:comment "A scheme for classifying technical impact or nature of trouble tickets."@en .

<kos/TroubleTicket/trouble-category/TotalBreakdown_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Total Breakdown"@en ;
    skos:definition "Indicates a complete failure of a system or component."@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/trouble-category/DowngradingEquipment_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Downgrading Equipment"@en ;
    skos:definition "Indicates reduced performance or capacity of equipment."@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/problemResponsibility>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying responsibility areas for problems identified in trouble tickets."@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Managed Backbone Networks"@en ;
    skos:definition "Responsibility lies with the team managing backbone network infrastructure."@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

<kos/TroubleTicket/problemResponsibility/Customer_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Customer_extra_node_1"@en ;
    skos:definition "Responsibility lies with the customer."@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

<kos/TroubleTicket/commentType>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying comment provenance types for trouble ticket notes."@en .

<kos/TroubleTicket/commentType/Internal_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Internal_extra_node_1"@en ;
    skos:definition "Comment is for internal team use only."@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

<kos/TroubleTicket/commentType/Customer_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Customer_extra_node_1"@en ;
    skos:definition "Comment is visible to the customer."@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

<kos/TroubleTicket/operationType>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying operation types for trouble ticket notes."@en .

<kos/TroubleTicket/operationType/Diagnosis_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Diagnosis_extra_node_1"@en ;
    skos:definition "Note describes diagnostic steps taken."@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

<kos/TroubleTicket/operationType/Resolution_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Resolution_extra_node_1"@en ;
    skos:definition "Note describes actions taken for resolution."@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

<kos/ChangeRequest/category>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A scheme for classifying categories of change requests, e.g., Internal_extra_node_1 Intervention."@en .

<kos/ChangeRequest/category/InternalIntervention_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Internal_extra_node_1 Intervention"@en ;
    skos:definition "Change request for internal operational changes."@en ;
    skos:inScheme <kos/ChangeRequest/category> .

<kos/ChangeRequest/category/CustomerIntervention>
    a skos:Concept ;
    skos:prefLabel "Customer_extra_node_1 Intervention"@en ;
    skos:definition "Change request requiring customer involvement."@en ;
    skos:inScheme <kos/ChangeRequest/category> .

<kos/ChangeRequest/type>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of change requests based on impact and risk."@en .

<kos/ChangeRequest/type/Standard_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Standard_extra_node_1"@en ;
    skos:definition "A routine change with low risk and predefined procedure."@en ;
    skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/type/Emergency_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Emergency_extra_node_1"@en ;
    skos:definition "An urgent change required to resolve an incident or prevent a major disruption."@en ;
    skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/cause>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying causes or reasons for change requests."@en .

<kos/ChangeRequest/cause/Configuration_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Configuration_extra_node_1"@en ;
    skos:definition "Change requested due to configuration update or modification."@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

<kos/ChangeRequest/cause/SoftwareUpgrade_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Software Upgrade"@en ;
    skos:definition "Change requested for software version upgrade."@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

<kos/ChangeRequest/status>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying statuses of change requests, e.g., Approved_extra_node_1, Implemented_extra_node_1."@en .

<kos/ChangeRequest/status/Approved_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Approved_extra_node_1"@en ;
    skos:definition "Change request has been approved and is ready for scheduling."@en ;
    skos:inScheme <kos/ChangeRequest/status> .

<kos/ChangeRequest/status/Implemented_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Implemented_extra_node_1"@en ;
    skos:definition "Change request has been successfully implemented."@en ;
    skos:inScheme <kos/ChangeRequest/status> .

<kos/ChangeRequest/specification>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    rdfs:comment "A scheme for classifying specifications for change requests, e.g., Software Upgrade."@en .

<kos/ChangeRequest/specification/SoftwareUpgrade_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Software Upgrade"@en ;
    skos:definition "Specification for a software upgrade procedure."@en ;
    skos:inScheme <kos/ChangeRequest/specification> .

<kos/ChangeRequest/specification/HardwareReplacement>
    a skos:Concept ;
    skos:prefLabel "Hardware Replacement"@en ;
    skos:definition "Specification for a hardware replacement procedure."@en ;
    skos:inScheme <kos/ChangeRequest/specification> .

<Notification/Severity/PerceivedSeverity>
    a skos:ConceptScheme ;
    rdfs:label "Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying perceived severity of alarms, as per ITU-T X.733."@en .

<Notification/Severity/PerceivedSeverity/Critical_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Critical_extra_node_1"@en ;
    skos:definition "Alarm severity indicating a critical condition requiring immediate action."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Major_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Major_extra_node_1"@en ;
    skos:definition "Alarm severity indicating a major service affecting condition."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Minor>
    a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:definition "Alarm severity indicating a minor service affecting condition."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<kos/Resource/OperationalState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying operational states of resources, e.g., Up_extra_node_1, Down_extra_node_1."@en .

<kos/Resource/OperationalState/Up_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Up_extra_node_1"@en ;
    skos:definition "Resource is fully operational."@en ;
    skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/OperationalState/Down_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Down_extra_node_1"@en ;
    skos:definition "Resource is not operational."@en ;
    skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/AdministrativeState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying administrative states of resources, e.g., Enabled_extra_node_1, Disabled."@en .

<kos/Resource/AdministrativeState/Enabled_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Enabled_extra_node_1"@en ;
    skos:definition "Resource is administratively enabled."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

<kos/Resource/AdministrativeState/Disabled>
    a skos:Concept ;
    skos:prefLabel "Disabled"@en ;
    skos:definition "Resource is administratively disabled."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

<kos/Resource/type>
    a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of resources, e.g., Server_extra_node_1, Router_extra_node_1."@en .

<kos/Resource/type/Server_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Server_extra_node_1"@en ;
    skos:definition "A computing resource providing services."@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Router_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Router_extra_node_1"@en ;
    skos:definition "A network device that forwards data packets between computer networks."@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Switch_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Switch_extra_node_1"@en ;
    skos:definition "A network device that connects devices in a computer network."@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/LifecycleState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying lifecycle states of resources, e.g., In Use, Decommissioned."@en .

<kos/Resource/LifecycleState/InUse_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "In Use"@en ;
    skos:definition "Resource is actively being used in production."@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

<kos/Resource/LifecycleState/Maintenance_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Maintenance_extra_node_1"@en ;
    skos:definition "Resource is currently undergoing maintenance."@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

# =============================================================================
# Organization and People Entities
# =============================================================================

noria:Org_ITOperations
    a org:Organization ;
    rdfs:label "IT Operations Inc."@en ;
    rdfs:comment "The main IT operations organization_extra_node_1 responsible for managing infrastructure and applications."@en ;
    org:hasUnit noria:Unit_NetworkOps, noria:Unit_AppSupport, noria:Unit_SecurityOps ;
    org:identifier "ORG-IT-OPS-001"^^xsd:string ;
.

noria:Unit_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "A team within IT Operations responsible for network infrastructure."@en ;
    org:unitOf noria:Org_ITOperations ;
    org:member noria:Person_AliceSmith, noria:Person_BobJohnson, noria:Person_EveGreen ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "For critical network issues, call the on-call engineer. For routine requests, use ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_1> ;
.

noria:Unit_AppSupport
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "A team within IT Operations responsible for application support and maintenance."@en ;
    org:unitOf noria:Org_ITOperations ;
    org:member noria:Person_CharlieBrown, noria:Person_DianaPrince ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "All application issues must be reported via the application ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
.

noria:Unit_SecurityOps
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:unitOf noria:Org_ITOperations ;
    org:member noria:Person_FrankWhite ;
    noria:agentWorkingHours "24/7 Shift"^^xsd:string ;
    noria:agentInstructions "Contact SOC immediately for any suspected security breach."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_1> ;
.

