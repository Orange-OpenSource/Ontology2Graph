# =============================================================================
# foaf:Agent and org:OrganizationalUnit instances
# =============================================================================

<instance/Agent/AdminTeamA>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Admin Team Alpha"@en ;
    rdfs:comment "The primary administration team for critical applications."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_4> ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string .

<instance/Agent/SupportTeamB>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Support Team Beta"@en ;
    rdfs:comment "Level 2 support team for network infrastructure."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_4> ;
    noria:agentInstructions "Always call the hotline for immediate support."^^xsd:string .

<instance/Agent/JohnDoe>
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead administrator for Application A."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_4> ;
    noria:agentInstructions "Email_extra_node_4 for all requests."^^xsd:string .

<instance/Agent/JaneSmith>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network engineer responsible for Router_extra_node_4 1."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_4> ;
    noria:agentInstructions "Call during working hours for network issues."^^xsd:string .

<instance/Agent/CustomerService>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Customer_extra_node_4 Service Department"@en ;
    rdfs:comment "First line of contact for all customer inquiries."@en ;
    noria:agentWorkingHours "08:00-20:00 (Mon-Sun)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_4> ;
    noria:agentInstructions "Direct customers to the appropriate support channel."^^xsd:string .

