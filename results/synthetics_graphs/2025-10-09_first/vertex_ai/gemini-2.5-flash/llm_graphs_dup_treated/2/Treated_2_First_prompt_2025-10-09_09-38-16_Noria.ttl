<instance/CorporateUserIdentifier/JDoe001>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe001"^^xsd:string ;
    observable:accountLogin "jdoe001"^^xsd:string ;
    observable:accountIdentifier "CID-JD001"^^xsd:string ;
    foaf:holdsAccount <instance/Agent/JohnDoe> .

<instance/CorporateUserIdentifier/JSmith002>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith002"^^xsd:string ;
    observable:accountLogin "jsmith002"^^xsd:string ;
    observable:accountIdentifier "CID-JS002"^^xsd:string ;
    foaf:holdsAccount <instance/Agent/JaneSmith> .

