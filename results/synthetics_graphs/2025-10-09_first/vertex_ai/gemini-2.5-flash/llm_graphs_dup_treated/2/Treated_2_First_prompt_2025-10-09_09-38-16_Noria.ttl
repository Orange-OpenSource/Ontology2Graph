    noria:resourceProductModel <instance/ProductModel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/Server_extra_node_4> ;
    noria:resourceSerialNumber "SN-DELL-R740-001"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse_extra_node_4> ;
