<instance/Resource/Server001>
    a noria:Resource ;
    rdfs:label "Application Server_extra_node_4 001"@en ;
    rdfs:comment "Primary server for the WebApp application."@en ;
    noria:resourceLogisticId "AS-001-LOG"^^xsd:string ;
