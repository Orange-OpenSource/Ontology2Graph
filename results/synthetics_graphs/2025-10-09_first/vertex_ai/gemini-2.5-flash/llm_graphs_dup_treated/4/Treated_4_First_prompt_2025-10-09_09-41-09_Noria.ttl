# --- Organization related entities ---

<agent/AliceSmith>
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "A key contact person for network operations."@en ;
    foaf:name "Alice Smith" ;
    foaf:mbox "mailto:alice.smith@example.com" ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<agent/BobJohnson>
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead engineer for application support."@en ;
    foaf:name "Bob Johnson" ;
    foaf:mbox "mailto:bob.johnson@example.com" ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Call directly for critical application issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<org/NetworkOperations>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf <org/ITDepartment> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "Follow incident management procedures for all issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

<org/ApplicationSupport>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting critical business applications."@en ;
    org:unitOf <org/ITDepartment> ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Sat)"^^xsd:string ;
    noria:agentInstructions "Escalate to L3 for complex software bugs."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<org/ITDepartment>
    a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department of the company."@en ;
    org:hasUnit <org/NetworkOperations>, <org/ApplicationSupport> .

<cuid/ASmith001>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith."@en ;
    foaf:accountName "asmith001"^^xsd:string ;
    observable:accountLogin "asmith001"^^xsd:string ;
    observable:accountIdentifier "CUID-AS001"^^xsd:string .

<cuid/BJohnson002>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson002"^^xsd:string ;
    observable:accountLogin "bjohnson002"^^xsd:string ;
    observable:accountIdentifier "CUID-BJ002"^^xsd:string .

# --- Location related entities ---

<site/MainDataCenter>
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility."@en ;
    noria:siteId "DC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Techville"^^xsd:string ;
    noria:sitePrincipalAddressCountry "USA"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

<room/ServerRoomA>
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Room A within the Main Data Center, housing critical servers."@en ;
    bot:hasSpace <locus/RackA1>, <locus/RackA2> ;
    bot:hasBuilding <site/MainDataCenter> .

<locus/RackA1>
    a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Rack A1 within Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasZone <room/ServerRoomA> .

<locus/RackA2>
    a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of network devices in Rack A2 within Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:hasZone <room/ServerRoomA> .

