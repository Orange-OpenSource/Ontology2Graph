# --- Location related (bot:Site, noria:Room, noria:Locus) ---
<site/DataCenter-NYC>
    a bot:Site ;
    rdfs:label "NYC Data Center"@en ;
    rdfs:comment "Primary data center location for TechCorp."@en ;
    noria:siteId "NYC-DC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "New York"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

<room/ServerRoom-A1>
    a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "Main server room in NYC Data Center."@en ;
    bot:hasSpace <locus/Rack-A1-R01>, <locus/Rack-A1-R02> ;
    bot:hasBuilding <site/DataCenter-NYC> .

<locus/Rack-A1-R01>
    a noria:Locus ;
    rdfs:label "Rack A1-R01"@en ;
    rdfs:comment "Location of servers in Rack 01, Row A1."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "01"^^xsd:string ;
    bot:hasSpace <room/ServerRoom-A1> .

<locus/Rack-A1-R02>
    a noria:Locus ;
    rdfs:label "Rack A1-R02"@en ;
    rdfs:comment "Location of network equipment in Rack 02, Row A1."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "02"^^xsd:string ;
    bot:hasSpace <room/ServerRoom-A1> .

