    noria:logText "CPU utilization on appserver-01 exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject <resource/AppServer-01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent <agent/AliceSmith> . # Example of an agent triggering an event (e.g., manual check)

