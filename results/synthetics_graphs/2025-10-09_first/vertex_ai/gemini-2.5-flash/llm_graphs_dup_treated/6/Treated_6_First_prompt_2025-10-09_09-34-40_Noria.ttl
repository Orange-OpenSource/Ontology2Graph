# --- Anomaly Patterns ---
<anomalypattern/HighCPULoad>
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "Sustained High CPU Load"@en ;
    rdfs:comment "Anomaly pattern indicating a system is under sustained high CPU load, potentially leading to performance degradation or outage."@en ;
    folio:hasCause "Inefficient application code or unexpected traffic surge."^^xsd:string .

<anomalypattern/NetworkInterfaceFlap>
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "Network Interface Flapping"@en ;
    rdfs:comment "Anomaly pattern indicating a network interface repeatedly changes between up and down states, suggesting physical layer issues or misconfiguration."@en ;
    folio:hasCause "Faulty cable, transceiver, or port, or routing protocol instability."^^xsd:string .

# --- Operation Plans ---
<operationplan/FailoverProcedure>
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Network Uplink Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over to a secondary network uplink in case of primary link failure."@en ;
    noria:operationPlanPreCondition <actionprecondition/PrimaryUplinkDown> ;
    noria:operationPlanPostCondition <actionpostcondition/SecondaryUplinkActive> ;
    noria:actionCorrelatedOperationPlan <operationplan/FailoverProcedure> . # Self-referential for demonstration

<operationplan/AppRestartProcedure>
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Application Module Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting an application module."@en ;
    noria:operationPlanPreCondition <actionprecondition/HighCPULoadDetected> ;
    noria:operationPlanPostCondition <actionpostcondition/CPULoadNormalized> .

# --- Action Pre-Conditions ---
<actionprecondition/PrimaryUplinkDown>
    a noria:ActionPreCondition ;
    rdfs:label "Primary Uplink Down"@en ;
    rdfs:comment "Condition: The primary network uplink is detected as being down."@en .

<actionprecondition/HighCPULoadDetected>
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Load Detected"@en ;
    rdfs:comment "Condition: Sustained high CPU load is detected on an application server."@en .

# --- Action Post-Conditions ---
<actionpostcondition/SecondaryUplinkActive>
    a noria:ActionPostCondition ;
    rdfs:label "Secondary Uplink Active"@en ;
    rdfs:comment "Outcome: The secondary network uplink is successfully activated and carrying traffic."@en .

<actionpostcondition/CPULoadNormalized>
    a noria:ActionPostCondition ;
    rdfs:label "CPU Load Normalized"@en ;
    rdfs:comment "Outcome: CPU utilization on the application server has returned to normal levels."@en .

# --- Procedure Execution Containers (for correlating actions) ---
<pep/FailoverProcedureExecution>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Failover Procedure for TT-2024-001"@en ;
    rdfs:comment "Container for events related to the network uplink failover procedure."@en ;
    pep:usedProcedure <operationplan/FailoverProcedure> ;
    dcterms:relation <troubleticket/TT-2024-001> .

<pep/AppRestartProcedureExecution>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of App Restart Procedure for TT-2024-002"@en ;
    rdfs:comment "Container for events related to the application module restart procedure."@en ;
    pep:usedProcedure <operationplan/AppRestartProcedure> ;
    dcterms:relation <troubleticket/TT-2024-002> .

# --- Additional links to ensure all ObjectProperties are used ---
<org/NetworkOperations> noria:agentManagesResource <resource/Router-Edge-01>, <resource/LoadBalancer-01> .
<org/ApplicationSupport> noria:agentManagesResource <resource/AppServer-01>, <resource/DBServer-01> .

<troubleticket/TT-2024-001> noria:troubleTicketPartyIntervention <org/NetworkOperations> .
<troubleticket/TT-2024-002> noria:troubleTicketPartyIntervention <org/ApplicationSupport> .

<noria:alarmMonitoredAttribute>
    rdfs:label "alarmMonitoredAttribute" ;
    rdfs:comment "Example of a monitored attribute for an alarm."@en ;
    rdfs:domain noria:EventRecord ;
    rdfs:range noria:Property . # As per schema, range is not restricted to a specific class.

<property/CPUUtilization>
    a noria:Property ;
    rdfs:label "CPU Utilization Property"@en ;
    rdfs:comment "A property representing CPU utilization."@en .

<eventrecord/Log-AppServer-HighCPU> noria:alarmMonitoredAttribute <property/CPUUtilization> .

<eventrecord/Log-Router-InterfaceDown> noria:alarmProposedRepairAction <operationplan/FailoverProcedure> .
<eventrecord/Log-AppServer-HighCPU> noria:alarmProposedRepairAction <operationplan/AppRestartProcedure> .

<eventrecord/Log-Router-InterfaceDown> noria:alarmMitigatedBy <pep/FailoverProcedureExecution> .
<eventrecord/Log-AppServer-HighCPU> noria:alarmMitigatedBy <pep/AppRestartProcedureExecution> .

# --- Final entity to ensure no truncation ---
<noria/FinalEntity>
    a owl:Thing ;
    rdfs:label "Final Entity Marker"@en ;
    rdfs:comment "This entity marks the end of the synthetic knowledge graph."@en .
