# --- Agents (foaf:Agent, org:Organization, org:OrganizationalUnit) ---
<agent/AliceSmith>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "A key employee responsible for network operations."@en ;
    foaf:name "Alice Smith" ;
    foaf:mbox "mailto:alice.smith@techcorp.com" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string .

<agent/BobJohnson>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead of the Application Support Team."@en ;
    foaf:name "Bob Johnson" ;
    foaf:mbox "mailto:bob.johnson@techcorp.com" ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call directly for critical application issues."^^xsd:string .

<org/TechCorp>
    a org:Organization, foaf:Agent ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "The main organization managing the IT infrastructure."@en ;
    org:hasUnit <org/NetworkOperations>, <org/ApplicationSupport> ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Refer to internal documentation for contact protocols."^^xsd:string .

<org/NetworkOperations>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf <org/TechCorp> ;
    org:member <agent/AliceSmith> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use ticketing system for all requests, call hotline for emergencies."^^xsd:string .

<org/ApplicationSupport>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    org:unitOf <org/TechCorp> ;
    org:member <agent/BobJohnson> ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the portal for all issues."^^xsd:string .

<org/VendorX>
    a org:Organization, foaf:Agent ;
    rdfs:label "Vendor X Solutions"@en ;
    rdfs:comment "Third-party vendor for network equipment."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via dedicated support portal."^^xsd:string .

