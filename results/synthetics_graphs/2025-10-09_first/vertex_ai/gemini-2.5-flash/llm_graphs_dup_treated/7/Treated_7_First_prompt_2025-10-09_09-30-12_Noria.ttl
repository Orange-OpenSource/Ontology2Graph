    noria:logOriginatingManagementSystem noria:App_Beta ; # Assuming Beta is also a monitoring tool
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on core-rtr01.example.com changed state to down."^^xsd:string ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_0> ;
    noria:alarmMonitoredAttribute "interface_status=down"^^xsd:string .

noria:EventRec_UserLoginFailed
    a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security event: multiple failed login attempts for a user."@en ;
    noria:logOriginatingManagedObject noria:App_Alpha ;
    noria:logOriginatingManagementSystem noria:App_Alpha ;
    noria:logOriginatingAgent noria:Agent_Charlie ; # Could be a malicious actor or a user
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "User 'jdoe' failed to log in 5 times from IP 203.0.113.45."^^xsd:string ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

