    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead administrator for critical applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> ;
