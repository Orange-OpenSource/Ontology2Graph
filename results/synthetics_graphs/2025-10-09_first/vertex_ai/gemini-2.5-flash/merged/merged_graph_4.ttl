<eventrecord/Log-Router_extra_node_2-InterfaceDown>
    a noria:EventRecord, log:Event, observable:EventRecord, pep:ProcedureExecution, BBO:DocumentResource ;
    rdfs:label "Router_extra_node_2 Interface Down_extra_node_2 Log"@en ;
    rdfs:comment "Log entry indicating a network interface went down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject <resource/Router_extra_node_2-Edge-01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_2> .

