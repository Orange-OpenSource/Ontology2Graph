    a noria:ActionPreCondition ;
    rdfs:label "Web Server_extra_node_0 Down_extra_node_0 Pre-Condition"@en ;
    rdfs:comment "Condition: Web server is not responding to health checks."@en .

noria:PostCond_WebServerUp
    a noria:ActionPostCondition ;
    rdfs:label "Web Server_extra_node_0 Up_extra_node_0 Post-Condition"@en ;
    rdfs:comment "Outcome: Web server is responding to health checks and serving traffic."@en .

noria:AnomalyPattern_HighCPUUsage
