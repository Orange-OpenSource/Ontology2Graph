# EventRecord
<noria/EventRecord/Log-Router-CPU-High-20240101-001>
    a noria:EventRecord ;
    rdfs:label "Router CPU High Alert"@en ;
    rdfs:comment "Log entry indicating high CPU usage on CoreRouter01."@en ;
    noria:logOriginatingManagedObject <noria/Resource/CoreRouter01> ;
    noria:logOriginatingManagementSystem <noria/Application/NetworkMonitoring> ;
    noria:logOriginatingAgent <foaf/Agent/AliceSmith> ;
    noria:logText "CPU utilization on CoreRouter01 exceeded 90% for 5 minutes."^^xsd:string ;
    noria:loggingTime "2024-01-01T07:55:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmProposedRepairAction <noria/OperationPlan/RouterOSUpgradeProcedure> ;
    noria:elementManagedBy <org/NetworkOperationsTeam> .

<noria/EventRecord/Log-DB-Conn-Error-20240102-001>
    a noria:EventRecord ;
    rdfs:label "Database Connection Error Log"@en ;
    rdfs:comment "Log entry from CRM application indicating database connection issues."@en ;
    noria:logOriginatingManagedObject <noria/ApplicationModule/CRMProd> ;
    noria:logOriginatingManagementSystem <noria/Application/CRMSystem> ;
    noria:logOriginatingAgent <foaf/Agent/BobJohnson> ;
    noria:logText "Failed to acquire connection from data source: Connection refused."^^xsd:string ;
    noria:loggingTime "2024-01-02T09:25:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <noria/OperationPlan/DBRestartProcedure> ;
    noria:elementManagedBy <org/ApplicationSupportTeam> .

# Linking TroubleTicket to EventRecord
<noria/TroubleTicket/TT-20240101-001>
    noria:troubleTicketTrigger <noria/EventRecord/Log-Router-CPU-High-20240101-001> .

<noria/TroubleTicket/TT-20240102-002>
    noria:troubleTicketTrigger <noria/EventRecord/Log-DB-Conn-Error-20240102-001> .

