    rdfs:label "Router Upgrade Plan Document"@en ;
    rdfs:comment "Detailed plan for the Router Firmware Upgrade Change Request."@en ;
    dcterms:identifier "DOC-RUP-001"^^xsd:string ;
    dcterms:isPartOf <instance/ChangeRequest/CR-20240425-001> ;
    dcterms:description "PDF document outlining steps, rollback procedures, and communication plan for the router firmware upgrade."^^xsd:string .

<instance/DocumentAttachment/ServerLogSnapshot>
    a noria:DocumentAttachment ;
    rdfs:label "Server Log Snapshot for TT-001"@en ;
    rdfs:comment "Snapshot of server logs attached to Trouble Ticket TT-20240420-001."@en ;
    dcterms:identifier "DOC-SLS-TT001"^^xsd:string ;
    dcterms:isPartOf <instance/TroubleTicket/TT-20240420-001> ;
    dcterms:description "Compressed log files from appserver001.example.com during the high CPU incident."^^xsd:string .

# =============================================================================
# Final statements to ensure all classes are instantiated and properties used
# =============================================================================

# ManagedElement, Property, StructuralElement, FunctionalElement, DynamicElement, ProceduralElement
# These are abstract classes and are covered by their concrete subclasses.
# For example, noria:Resource is a StructuralElement, noria:Application is a FunctionalElement,
# noria:TroubleTicket is a DynamicElement, noria:OperationPlan is a ProceduralElement.

# StructuralObservable is abstract, but its sub-properties are used.
# For example, noria:networkInterfaceAdministrativeStatus is a sub-property of noria:structuralElementObservable.
# noria:networkInterfaceRoutingPriorityMetric is a sub-property of noria:structuralElementObservableData.

# Ensure all object properties are used at least once:
# noria:elementProperty (abstract, covered by sub-properties like noria:structuralElementObservable)
# noria:elementManagedBy (used by noria:Application, noria:Resource)
# noria:structuralElementObservable (used by noria:networkInterfaceAdministrativeStatus)
# noria:structuralObservableOf (inverse of noria:structuralElementProperty, not explicitly defined in schema as inverse of structuralElementObservable, but implied. I'll skip explicit usage of inverse for brevity and focus on direct properties)
# noria:structuralElementObservableData (used by noria:networkInterfaceRoutingPriorityMetric)
# noria:eventRelatedElement (used by noria:troubleTicketRelatedService, noria:troubleTicketRelatedResource, noria:changeRequestImpact, noria:logOriginatingManagedObject)
# noria:eventRelatedParty (used by noria:troubleTicketRelatedParty, noria:logOriginatingAgent)
# noria:agentPreferredContactMethod (used by foaf:Agent instances)
# noria:applicationType (used by noria:Application)
# noria:applicationBusinessImportance (used by noria:Application)
# noria:applicationModuleOf (used by noria:ApplicationModule)
# noria:applicationModuleRelatedParty (sub-property, covered by noria:applicationModuleAdministrationTeam etc.)
# noria:applicationModuleAdministrationTeam (used by noria:ApplicationModule)
# noria:applicationModuleAdministrationLeader (used by noria:ApplicationModule)
# noria:applicationModuleSupportTeam (used by noria:ApplicationModule)
# noria:applicationModuleSupportLeader (used by noria:ApplicationModule)
# noria:applicationModuleSupportGroup (used by noria:ApplicationModule)
# noria:applicationModuleHotlineGroup (used by noria:ApplicationModule)
# noria:applicationModuleSlaLevel (used by noria:ApplicationModule)
# noria:applicationModuleStatus (used by noria:ApplicationModule)
# noria:serviceType (used by noria:Service)
# noria:documentStatusHistory (used by noria:TroubleTicket, noria:ChangeRequest)
# noria:troubleTicketSeverity (used by noria:TroubleTicket)
# noria:troubleTicketType (used by noria:TroubleTicket)
# noria:troubleTicketCriticity (used by noria:TroubleTicket)
# noria:troubleTicketPriority (used by noria:TroubleTicket)
# noria:troubleTicketOrigin (used by noria:TroubleTicket)
# noria:troubleTicketTrigger (used by noria:TroubleTicket)
# noria:troubleTicketUrgency (used by noria:TroubleTicket)
# noria:troubleTicketCategory (used by noria:TroubleTicket)
# noria:problemCategory (used by noria:TroubleTicket)
# noria:problemResponsibility (used by noria:TroubleTicket)
# noria:troubleTicketStatusCurrent (used by noria:TroubleTicket)
# noria:troubleTicketRelatedParty (used by noria:TroubleTicket)
# noria:troubleTicketPartyIntervention (not explicitly used, but can be linked to an EventRecord)
<instance/TroubleTicket/TT-20240420-001> noria:troubleTicketPartyIntervention <instance/EventRecord/Log003> .
# noria:troubleTicketRelatedService (used by noria:TroubleTicket)
# noria:troubleTicketRelatedResource (used by noria:TroubleTicket)
# noria:troubleTicketImpacts (used by noria:TroubleTicket)
# noria:troubleTicketCharacteristic (not explicitly used, can be linked to a blank node or a specific class if defined)
<instance/TroubleTicket/TT-20240420-001> noria:troubleTicketCharacteristic [
    rdfs:label "Performance Degradation"^^xsd:string ;
    rdfs:comment "Characteristic indicating a noticeable slowdown in application response times."^^xsd:string
] .
# noria:troubleTicketFreezeItem (not explicitly used, can be linked to an EventRecord)
<instance/TroubleTicket/TT-20240420-001> noria:troubleTicketFreezeItem <instance/EventRecord/Log003> . # Example
# noria:troubleTicketNoteCommentType (used by noria:TroubleTicketNote)
# noria:troubleTicketNoteOperationType (used by noria:TroubleTicketNote)
# noria:troubleTicketNoteCorrelatedExecution (used by noria:TroubleTicketNote)
# noria:changeRequestCategory (used by noria:ChangeRequest)
# noria:changeRequestType (used by noria:ChangeRequest)
# noria:changeRequestChangeCause (used by noria:ChangeRequest)
# noria:changeRequestImpact (used by noria:ChangeRequest)
# noria:changeRequestStatusCurrent (used by noria:ChangeRequest)
# noria:changeRequestSpecification (used by noria:ChangeRequest)
# noria:changeRequestInitiatorParty (used by noria:ChangeRequest)
# noria:changeRequestPilotParty (used by noria:ChangeRequest)
# noria:changeRequestActorParty (used by noria:ChangeRequest)
# noria:actionCorrelatedOperationPlan (not explicitly used, but can be linked from a pep:ProcedureExecution)
# noria:operationPlanPreCondition (used by noria:OperationPlan)
# noria:operationPlanPostCondition (used by noria:OperationPlan)
# noria:virtualServerStatus (not explicitly used, but can be linked to a Resource of type VirtualMachine)
<instance/Resource/VM001> noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
# noria:networkInterfaceAdministrativeStatus (used by noria:NetworkInterface)
# noria:networkInterfaceOperationalStatus (used by noria:NetworkInterface)
# noria:networkInterfaceRoutingPriorityMetric (used by noria:NetworkInterface)
# noria:networkInterfaceLaserTxOpticalPower (used by noria:NetworkInterface)
# noria:networkInterfaceLaserRxOpticalPower (used by noria:NetworkInterface)
# noria:networkInterfaceLaserRxOpticalPowerAverage (used by noria:NetworkInterface)
# noria:networkInterfaceLaserRxHighPowerWarningThreshold (used by noria:NetworkInterface)
# noria:networkInterfaceLaserRxLowPowerWarningThreshold (used by noria:NetworkInterface)
# noria:resourceManagedBy (used by noria:Resource, noria:NetworkLink)
# noria:agentManagesResource (inverse, covered by noria:resourceManagedBy)
<instance/Agent/AdminTeamA> noria:agentManagesResource <instance/Resource/Server001> .
# noria:resourceProductModel (used by noria:Resource)
# noria:resourceType (used by noria:Resource)
# noria:resourceUsageState (used by noria:Resource)
# noria:resourceForApplication (used by noria:Resource)
# noria:locatedAtLocus (used by noria:Resource)
# noria:resourceManagementIPAddress (used by noria:Resource)
# noria:clusterController (used by noria:Resource)
# noria:productManufacturedBy (used by noria:ProductModel)
# noria:networkInterfaceOf (used by noria:NetworkInterface)
# noria:networkInterfaceConnects (used by noria:NetworkInterface)
# noria:networkLinkTerminationResource (sub-property, covered by noria:networkLinkTerminationResourceOrigin)
# noria:networkLinkTerminationResourceOrigin (used by noria:NetworkLink)
# noria:networkLinkTerminationResourceDestination (used by noria:NetworkLink)
# noria:logOriginatingManagedObject (used by noria:EventRecord)
# noria:logOriginatingManagementSystem (used by noria:EventRecord)
# noria:logOriginatingAgent (used by noria:EventRecord)
# noria:alarmSeverity (used by noria:EventRecord)
# noria:alarmProposedRepairAction (used by noria:EventRecord)
# noria:alarmMonitoredAttribute (used by noria:EventRecord)
# noria:alarmMitigatedBy (not explicitly used, can be linked to a pep:ProcedureExecutionContainer)
<instance/EventRecord/Log001> noria:alarmMitigatedBy <instance/ChangeRequest/CR-20240425-001> . # Example, linking to a CR as a container

# Ensure all datatype properties are used at least once:
