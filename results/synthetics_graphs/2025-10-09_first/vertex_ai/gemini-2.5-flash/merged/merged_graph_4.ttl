# Agents (Organizations, Organizational Units, Persons)
<org/OrgA>
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "A major telecommunications company."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentInstructions "Contact via official channels only."@en .

<org/TeamAlpha>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Alpha"@en ;
    rdfs:comment "Team responsible for core network infrastructure."@en ;
    org:unitOf <org/OrgA> ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical issues, call the hotline. For routine, use ticketing system."@en .

<org/TeamBeta>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team Beta"@en ;
    rdfs:comment "Team responsible for critical business applications."@en ;
    org:unitOf <org/OrgA> ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for non-urgent requests. Use ticketing system for incidents."@en .

<foaf/Person1>
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, Team Alpha."@en ;
    org:memberOf <org/TeamAlpha> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<foaf/Person2>
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Developer, Team Beta."@en ;
    org:memberOf <org/TeamBeta> ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<noria/CUid_ASmith>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "AS-12345"^^xsd:string ;
    foaf:holdsAccount <foaf/Person1> .

<noria/CUid_BJohnson>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "BJ-67890"^^xsd:string ;
    foaf:holdsAccount <foaf/Person2> .

# Locations
<bot/Site_HQ>
    a bot:Site ;
    rdfs:label "Headquarters Data Center"@en ;
    rdfs:comment "Main data center for core services."@en ;
    noria:siteId "DC-HQ-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Main Street"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "New York"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Main Street"^^xsd:string .

<noria/Room_ServerRoom1>
    a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "Primary server room in HQ Data Center."@en ;
    bot:hasSpace <bot/Site_HQ> .

<noria/Locus_RackA1>
    a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of network equipment in Server Room 1."@en ;
