# OperationPlan
<noria/OperationPlan/RouterOSUpgradeProcedure>
    a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems."@en ;
    folio:hasStep "Backup configuration"^^xsd:string ;
    folio:hasStep "Download new OS image"^^xsd:string ;
    folio:hasStep "Install OS image"^^xsd:string ;
    folio:hasStep "Verify operation"^^xsd:string ;
    noria:elementManagedBy <org/NetworkOperationsTeam> .

<noria/OperationPlan/DBRestartProcedure>
    a noria:OperationPlan ;
    rdfs:label "Database Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting the CRM database."@en ;
    folio:hasStep "Notify users"^^xsd:string ;
    folio:hasStep "Stop application services"^^xsd:string ;
    folio:hasStep "Stop database service"^^xsd:string ;
    folio:hasStep "Start database service"^^xsd:string ;
    folio:hasStep "Start application services"^^xsd:string ;
    folio:hasStep "Verify functionality"^^xsd:string ;
    noria:elementManagedBy <org/ApplicationSupportTeam> .

# ActionPreCondition
<noria/ActionPreCondition/NetworkConnectivityOK>
    a noria:ActionPreCondition ;
    rdfs:label "Network Connectivity OK"@en ;
    rdfs:comment "Pre-condition: Basic network connectivity must be stable before proceeding."@en ;
    noria:elementManagedBy <org/NetworkOperationsTeam> .

# ActionPostCondition
<noria/ActionPostCondition/ServiceRestored>
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored"@en ;
    rdfs:comment "Post-condition: Affected service is fully operational and accessible."@en ;
    noria:elementManagedBy <org/ApplicationSupportTeam> .

# Linking OperationPlan with Pre/Post Conditions
<noria/OperationPlan/RouterOSUpgradeProcedure>
    noria:operationPlanPreCondition <noria/ActionPreCondition/NetworkConnectivityOK> ;
    noria:operationPlanPostCondition <noria/ActionPostCondition/ServiceRestored> .

<noria/OperationPlan/DBRestartProcedure>
    noria:operationPlanPreCondition <noria/ActionPreCondition/NetworkConnectivityOK> ;
    noria:operationPlanPostCondition <noria/ActionPostCondition/ServiceRestored> .

