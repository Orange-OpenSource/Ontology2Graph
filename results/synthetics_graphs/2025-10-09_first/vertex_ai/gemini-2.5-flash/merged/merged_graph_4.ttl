# --- External Entities ---

<org/OrangeTelecom>
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "A major telecommunications company."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via official support channels."^^xsd:string .

<org/NetworkOperationsTeam>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf <org/OrangeTelecom> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical issues, call the hotline immediately."^^xsd:string .

<org/ApplicationSupportTeam>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting critical business applications."@en ;
    org:unitOf <org/OrangeTelecom> ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket for non-urgent requests."^^xsd:string .

