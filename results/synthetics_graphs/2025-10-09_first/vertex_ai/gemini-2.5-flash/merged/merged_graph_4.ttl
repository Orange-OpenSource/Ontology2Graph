    rdfs:label "High_extra_node_0 CPU Usage Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating sustained high CPU usage on a server."@en ;
    folio:hasCause "Excessive load or runaway process"^^xsd:string .

noria:OpPlan_NetworkTroubleshooting
    a noria:OperationPlan ;
    rdfs:label "Network Troubleshooting Guide"@en ;
    rdfs:comment "Procedure for diagnosing network connectivity issues."@en ;
    noria:operationPlanPreCondition noria:PreCond_NetworkUnreachable ;
    noria:operationPlanPostCondition noria:PostCond_NetworkRestored .

noria:PreCond_NetworkUnreachable
    a noria:ActionPreCondition ;
    rdfs:label "Network Unreachable Pre-Condition"@en ;
    rdfs:comment "Condition: A network resource is unreachable."@en .

noria:PostCond_NetworkRestored
    a noria:ActionPostCondition ;
    rdfs:label "Network Restored Post-Condition"@en ;
    rdfs:comment "Outcome: Network connectivity to the resource is restored."@en .

# --- Event Records ---

noria:EventRec_WebSrv01_CPUAlert
    a noria:EventRecord ;
    rdfs:label "WebSrv01 High_extra_node_0 CPU Alert"@en ;
    rdfs:comment "Alert generated due to high CPU usage on WebSrv01."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_Alpha ; # Monitoring tool for App Alpha
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on websrv01.example.com exceeded 90% for 5 minutes."^^xsd:string ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_0> ;
    noria:alarmProposedRepairAction noria:OpPlan_RestartWebServer .

noria:EventRec_RouterCore01_LinkDown
    a noria:EventRecord ;
    rdfs:label "CoreRouter01 Link Down_extra_node_0 Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Core Router_extra_node_0 01."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_Beta ; # Assuming Beta is also a monitoring tool
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on core-rtr01.example.com changed state to down."^^xsd:string ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_0> ;
    noria:alarmMonitoredAttribute "interface_status=down"^^xsd:string .

noria:EventRec_UserLoginFailed
    a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security event: multiple failed login attempts for a user."@en ;
    noria:logOriginatingManagedObject noria:App_Alpha ;
    noria:logOriginatingManagementSystem noria:App_Alpha ;
    noria:logOriginatingAgent noria:Agent_Charlie ; # Could be a malicious actor or a user
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "User 'jdoe' failed to log in 5 times from IP 203.0.113.45."^^xsd:string ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_0> .

