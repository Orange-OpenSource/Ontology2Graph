# =============================================================================
# foaf:Agent and org:OrganizationalUnit instances
# =============================================================================

<instance/Agent/AdminTeamA>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Admin Team Alpha"@en ;
    rdfs:comment "The primary administration team for critical applications."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string .

<instance/Agent/SupportTeamB>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Support Team Beta"@en ;
    rdfs:comment "Level 2 support team for network infrastructure."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call the hotline for immediate support."^^xsd:string .

<instance/Agent/JohnDoe>
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead administrator for Application A."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for all requests."^^xsd:string .

<instance/Agent/JaneSmith>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network engineer responsible for Router 1."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call during working hours for network issues."^^xsd:string .

<instance/Agent/CustomerService>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Customer Service Department"@en ;
    rdfs:comment "First line of contact for all customer inquiries."@en ;
    noria:agentWorkingHours "08:00-20:00 (Mon-Sun)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Direct customers to the appropriate support channel."^^xsd:string .

# =============================================================================
# noria:CorporateUserIdentifier instances
# =============================================================================

<instance/CorporateUserIdentifier/JDoe001>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe001"^^xsd:string ;
    observable:accountLogin "jdoe001"^^xsd:string ;
    observable:accountIdentifier "CID-JD001"^^xsd:string ;
    foaf:holdsAccount <instance/Agent/JohnDoe> .

<instance/CorporateUserIdentifier/JSmith002>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith002"^^xsd:string ;
    observable:accountLogin "jsmith002"^^xsd:string ;
    observable:accountIdentifier "CID-JS002"^^xsd:string ;
    foaf:holdsAccount <instance/Agent/JaneSmith> .

# =============================================================================
# noria:ProductModel instances
# =============================================================================

<instance/ProductModel/Cisco3850>
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 3850"@en ;
    rdfs:comment "Product model for Cisco Catalyst 3850 series switches."@en ;
    noria:productManufacturedBy <https://www.cisco.com/organization> .

<instance/ProductModel/DellPowerEdgeR740>
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Product model for Dell PowerEdge R740 servers."@en ;
    noria:productManufacturedBy <https://www.dell.com/organization> .

<instance/ProductModel/JuniperMX204>
    a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Product model for Juniper MX204 universal routing platform."@en ;
    noria:productManufacturedBy <https://www.juniper.net/organization> .

<https://www.cisco.com/organization>
    a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en ;
    rdfs:comment "Manufacturer of network hardware."@en .

<https://www.dell.com/organization>
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

<https://www.juniper.net/organization>
    a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking products."@en .

# =============================================================================
# noria:Room and noria:Locus instances
# =============================================================================

<instance/Room/ServerRoomA>
    a noria:Room ;
    rdfs:label "Server Room Alpha"@en ;
    rdfs:comment "Main server room in the primary data center."@en ;
    bot:hasSpace <instance/Locus/RackA1> .

<instance/Room/NetworkClosetB>
    a noria:Room ;
    rdfs:label "Network Closet Beta"@en ;
    rdfs:comment "Network equipment closet on the second floor."@en ;
    bot:hasSpace <instance/Locus/RackB2> .

<instance/Locus/RackA1>
    a noria:Locus ;
    rdfs:label "Rack A1 in Server Room Alpha"@en ;
    rdfs:comment "Location of critical servers."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

<instance/Locus/RackB2>
    a noria:Locus ;
    rdfs:label "Rack B2 in Network Closet Beta"@en ;
    rdfs:comment "Location of network switches."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

<instance/Site/MainDataCenter>
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility."@en ;
    noria:siteId "DC-MAIN-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Techville"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string ;
    bot:hasSpace <instance/Room/ServerRoomA> .

# =============================================================================
# noria:Resource instances
# =============================================================================

<instance/Resource/Server001>
    a noria:Resource ;
    rdfs:label "Application Server 001"@en ;
    rdfs:comment "Primary server for the WebApp application."@en ;
    noria:resourceLogisticId "AS-001-LOG"^^xsd:string ;
    noria:resourceHostName "appserver001.example.com"^^xsd:string ;
    noria:resourceProductModel <instance/ProductModel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DELL-R740-001"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <instance/Agent/AdminTeamA> ;
    noria:locatedAtLocus <instance/Locus/RackA1> ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

<instance/Resource/Router001>
    a noria:Resource ;
    rdfs:label "Core Router 001"@en ;
    rdfs:comment "Main router for the corporate network."@en ;
    noria:resourceLogisticId "CR-001-LOG"^^xsd:string ;
    noria:resourceHostName "router001.example.com"^^xsd:string ;
    noria:resourceProductModel <instance/ProductModel/JuniperMX204> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-JUNIPER-MX204-001"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <instance/Agent/SupportTeamB> ;
    noria:locatedAtLocus <instance/Locus/RackA1> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

<instance/Resource/VM001>
    a noria:Resource ;
    rdfs:label "Virtual Machine 001"@en ;
    rdfs:comment "Virtual machine hosting a database service."@en ;
    noria:resourceLogisticId "VM-001-LOG"^^xsd:string ;
    noria:resourceHostName "dbvm001.example.com"^^xsd:string ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "SN-VM-001"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <instance/Agent/AdminTeamA> ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.5> ;
    noria:clusterController <instance/Resource/Hypervisor01> .

<instance/Resource/Hypervisor01>
    a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines."@en ;
    noria:resourceHostName "hypervisor01.example.com"^^xsd:string ;
