# --- Operation Plans, Pre/Post Conditions, Anomaly Patterns ---

<noria/operationplan/CheckFiberLink>
    a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Procedure to diagnose and verify fiber optic link status."@en ;
    noria:operationPlanPreCondition <noria/actionprecondition/LinkDownAlert> ;
    noria:operationPlanPostCondition <noria/actionpostcondition/LinkStatusConfirmed> ;
    noria:elementManagedBy <org/NetworkOperations> .

<noria/actionprecondition/LinkDownAlert>
    a noria:ActionPreCondition ;
    rdfs:label "Network Link Down_extra_node_3 Alert"@en ;
    rdfs:comment "Pre-condition: An alert indicating a network link is down."@en .

<noria/actionpostcondition/LinkStatusConfirmed>
    a noria:ActionPostCondition ;
    rdfs:label "Network Link Status Confirmed"@en ;
    rdfs:comment "Post-condition: The operational status of the network link has been confirmed (up or down) and cause identified."@en .

<noria/operationplan/RestartWebServer>
    a noria:OperationPlan ;
    rdfs:label "Restart Web Server_extra_node_3 Procedure"@en ;
    rdfs:comment "Standard_extra_node_3 operating procedure for restarting a web server."@en ;
    noria:operationPlanPreCondition <noria/actionprecondition/HighCPUAlert> ;
    noria:operationPlanPostCondition <noria/actionpostcondition/CPUBackToNormal> ;
    noria:elementManagedBy <org/ApplicationSupport> .

<noria/actionprecondition/HighCPUAlert>
    a noria:ActionPreCondition ;
    rdfs:label "High_extra_node_3 CPU Utilization Alert"@en ;
    rdfs:comment "Pre-condition: An alert indicating high CPU utilization on a web server."@en .

<noria/actionpostcondition/CPUBackToNormal>
    a noria:ActionPostCondition ;
    rdfs:label "CPU Utilization Back to Normal"@en ;
    rdfs:comment "Post-condition: CPU utilization on the web server has returned to normal levels."@en .

<noria/anomalypattern/FiberCutAnomaly>
    a noria:AnomalyPattern ;
    rdfs:label "Fiber Cut Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a fiber optic cable cut, characterized by multiple link down events and loss of connectivity."@en ;
    folio:hasCritical_extra_node_3ity <Notification/Severity/PerceivedSeverity/Critical_extra_node_3> .

<noria/anomalypattern/AppPerformanceDegradation>
    a noria:AnomalyPattern ;
    rdfs:label "Application Performance Degradation Anomaly"@en ;
    rdfs:comment "Pattern indicating application performance degradation, characterized by high CPU/memory, slow response times, and increased error rates."@en ;
    folio:hasCriticality <Notification/Severity/PerceivedSeverity/Major_extra_node_3> .

