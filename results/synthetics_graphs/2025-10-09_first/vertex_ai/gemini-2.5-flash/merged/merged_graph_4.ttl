<org/ApplicationSupport> noria:agentManagesResource <resource/AppServer-01>, <resource/DBServer-01> .

<troubleticket/TT-2024-001> noria:troubleTicketPartyIntervention <org/NetworkOperations> .
<troubleticket/TT-2024-002> noria:troubleTicketPartyIntervention <org/ApplicationSupport> .

<noria:alarmMonitoredAttribute>
    rdfs:label "alarmMonitoredAttribute" ;
    rdfs:comment "Example of a monitored attribute for an alarm."@en ;
    rdfs:domain noria:EventRecord ;
    rdfs:range noria:Property . # As per schema, range is not restricted to a specific class.

<property/CPUUtilization>
    a noria:Property ;
    rdfs:label "CPU Utilization Property"@en ;
    rdfs:comment "A property representing CPU utilization."@en .

<eventrecord/Log-AppServer-HighCPU> noria:alarmMonitoredAttribute <property/CPUUtilization> .

<eventrecord/Log-Router_extra_node_2-InterfaceDown> noria:alarmProposedRepairAction <operationplan/FailoverProcedure> .
<eventrecord/Log-AppServer-HighCPU> noria:alarmProposedRepairAction <operationplan/AppRestartProcedure> .

<eventrecord/Log-Router_extra_node_2-InterfaceDown> noria:alarmMitigatedBy <pep/FailoverProcedureExecution> .
<eventrecord/Log-AppServer-HighCPU> noria:alarmMitigatedBy <pep/AppRestartProcedureExecution> .

