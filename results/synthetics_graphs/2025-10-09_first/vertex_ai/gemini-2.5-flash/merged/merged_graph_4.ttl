# Service
<noria/Service/InternetAccess>
    a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <noria/Application/NetworkMonitoring> ; # Example of linking to an application
    noria:elementManagedBy <org/NetworkOperationsTeam> .

<noria/Service/VPNService>
    a noria:Service ;
    rdfs:label "Remote VPN Access Service"@en ;
    rdfs:comment "Enables secure remote access to internal network resources."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf <noria/ApplicationModule/NMSDev> ; # Example of linking to an application module
    noria:elementManagedBy <org/NetworkOperationsTeam> .

# TroubleTicket
<noria/TroubleTicket/TT-20240101-001>
    a noria:TroubleTicket ;
    rdfs:label "Internet Outage in DC01"@en ;
    rdfs:comment "Critical internet outage affecting Main Data Center."@en ;
    noria:documentExternalId "EXT-INC-98765"^^xsd:string ;
    noria:documentHRef "https://ticketing.example.com/TT-20240101-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
