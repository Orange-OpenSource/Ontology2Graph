# Anomaly Patterns
<noria/AnomalyPattern_HighLatency>
    a noria:AnomalyPattern ;
    rdfs:label "High Latency Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating unusually high network latency, potentially due to congestion or hardware failure."@en ;
    folio:hasCause "Network Congestion"^^xsd:string ;
    folio:hasEffect "Degraded Service Performance"^^xsd:string ;
    noria:elementManagedBy <org/TeamAlpha> .

<noria/AnomalyPattern_AuthFailureSpike>
    a noria:AnomalyPattern ;
    rdfs:label "Authentication Failure Spike Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a sudden increase in authentication failures, possibly a brute-force attack."@en ;
    folio:hasCause "Brute-force Attack"^^xsd:string ;
    folio:hasEffect "Security Breach Attempt"^^xsd:string ;
    noria:elementManagedBy <org/TeamBeta> .

<noria/AnomalyPattern_DiskFull>
    a noria:AnomalyPattern ;
    rdfs:label "Disk Full Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a server disk is nearing full capacity, leading to potential service disruption."@en ;
    folio:hasCause "Log File Accumulation"^^xsd:string ;
    folio:hasEffect "Service Interruption"^^xsd:string ;
    noria:elementManagedBy <org/TeamBeta> .

# Linking EventRecords to TroubleTickets and ChangeRequests
<noria/TroubleTicket_TT001>
    noria:documentStatusHistory <noria/EventRecord_RouterDown> .

<noria/ChangeRequest_CR001>
    noria:documentStatusHistory <noria/EventRecord_ConfigChange> .

<noria/TroubleTicket_TT003>
    noria:documentStatusHistory <noria/EventRecord_WebServerError> .

# Linking TroubleTicketNote to correlated execution (using a dummy ProcedureExecutionContainer)
<pep/ProcedureExecutionContainer_TT001_Note1_Exec>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution Container for TT001 Note 1"@en ;
    rdfs:comment "Represents the actions taken during the initial diagnosis of TT001."@en ;
    pep:hasProcedure <noria/OperationPlan_RouterRestart> ;
    pep:member <noria/EventRecord_RouterDown> .

<noria/TroubleTicketNote_TT001_Note1>
    noria:troubleTicketNoteCorrelatedExecution <pep/ProcedureExecutionContainer_TT001_Note1_Exec> .

# Linking ChangeRequest to OperationPlan
<noria/ChangeRequest_CR001>
    noria:actionCorrelatedOperationPlan <noria/OperationPlan_RouterRestart> .

<noria/ChangeRequest_CR002>
    noria:actionCorrelatedOperationPlan <noria/OperationPlan_DBPatch> .

<noria/ChangeRequest_CR003>
    noria:actionCorrelatedOperationPlan <noria/OperationPlan_DBPatch> .

# Linking Agents to Resources they manage (inverse of resourceManagedBy)
<org/TeamAlpha>
    noria:agentManagesResource <noria/Resource_Router1> ;
    noria:agentManagesResource <noria/NetworkLink_R1_DB> ;
    noria:agentManagesResource <noria/NetworkLink_R1_LB> ;
    noria:agentManagesResource <noria/Resource_Switch1> ;
    noria:agentManagesResource <noria/NetworkLink_R1_SW1> .

<org/TeamBeta>
    noria:agentManagesResource <noria/Resource_ServerDB> ;
    noria:agentManagesResource <noria/Resource_LoadBalancer> ;
    noria:agentManagesResource <noria/Resource_VirtualServer> .

# Additional complex relationships
<noria/TroubleTicketCharacteristic_PerformanceDegradation>
    a noria:Property ;
    rdfs:label "Performance Degradation Characteristic"@en ;
    rdfs:comment "Characteristic indicating a general slowdown or reduced efficiency."@en .

<noria/TroubleTicket_TT001>
    noria:troubleTicketCharacteristic <noria/TroubleTicketCharacteristic_PerformanceDegradation> .

<noria/TroubleTicketPartyIntervention_TT001_TeamAlpha_Initial>
    a noria:EventRecord ;
    rdfs:label "TT001 Team Alpha Initial Intervention"@en ;
    rdfs:comment "Log of Team Alpha's initial response to TT001."@en ;
    noria:loggingTime "2024-04-10T10:12:00Z"^^xsd:dateTime ;
    noria:logText "Team Alpha acknowledged TT001 and started diagnosis."^^xsd:string ;
    noria:logOriginatingAgent <org/TeamAlpha> ;
    noria:eventRelatedElement <noria/TroubleTicket_TT001> .

<noria/TroubleTicket_TT001>
    noria:troubleTicketPartyIntervention <noria/TroubleTicketPartyIntervention_TT001_TeamAlpha_Initial> .

<noria/EventRecord_TT001_FreezeStart>
    a noria:EventRecord ;
    rdfs:label "TT001 Freeze Start Event"@en ;
    rdfs:comment "Event marking the start of a freeze period for TT001."@en ;
    noria:loggingTime "2024-04-10T11:30:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT001 frozen due to external dependency."^^xsd:string ;
    noria:elementManagedBy <org/TeamAlpha> .

<noria/EventRecord_TT001_FreezeEnd>
    a noria:EventRecord ;
    rdfs:label "TT001 Freeze End Event"@en ;
    rdfs:comment "Event marking the end of a freeze period for TT001."@en ;
    noria:loggingTime "2024-04-10T11:50:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT001 unfrozen, external dependency resolved."^^xsd:string ;
    noria:elementManagedBy <org/TeamAlpha> .

<noria/TroubleTicket_TT001>
    noria:troubleTicketFreezeItem <noria/EventRecord_TT001_FreezeStart> ;
    noria:troubleTicketFreezeItem <noria/EventRecord_TT001_FreezeEnd> .

<noria/Property_InterfaceStatus>
    a noria:Property ;
    rdfs:label "Interface Status Property"@en ;
    rdfs:comment "A property representing the operational status of a network interface."@en .

<noria/EventRecord_RouterDown>
    noria:alarmMonitoredAttribute <noria/Property_InterfaceStatus> .

<pep/ProcedureExecutionContainer_TT001_Resolution>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Resolution Actions for TT001"@en ;
    rdfs:comment "Container for all actions taken to resolve Trouble Ticket TT001."@en ;
    pep:hasProcedure <noria/OperationPlan_RouterRestart> ;
    pep:member <noria/EventRecord_TT001_FreezeEnd> .

<noria/EventRecord_RouterDown>
    noria:alarmMitigatedBy <pep/ProcedureExecutionContainer_TT001_Resolution> .


# =============================================================================
# Knowledge Organization Systems (KOS) Concepts
# =============================================================================

<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents, such as email or phone."@en .

<kos/org/agent-contact-method/Email_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Email_extra_node_1"@en ;
    skos:altLabel "Electronic Mail"@en ;
    skos:definition "Preferred contact method via electronic mail."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/Phone_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Phone_extra_node_1"@en ;
    skos:altLabel "Telephone"@en ;
    skos:definition "Preferred contact method via telephone call."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/application/type>
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications, e.g., Web Frontend, Database_extra_node_1, API Gateway."@en .

<kos/application/type/WebFrontend>
    a skos:Concept ;
    skos:prefLabel "Web Frontend"@en ;
    skos:definition "An application type representing the user-facing part of a web application."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/Database_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Database_extra_node_1"@en ;
    skos:definition "An application type representing a data storage and retrieval system."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/APIGateway>
    a skos:Concept ;
    skos:prefLabel "API Gateway"@en ;
    skos:definition "An application type acting as a single entry point for microservices."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/business-importance>
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying business importance of applications for risk assessment."@en .

<kos/application/business-importance/Critical_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Critical_extra_node_1"@en ;
    skos:definition "Application is critical to core business operations; downtime has severe impact."@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/business-importance/High_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "High_extra_node_1"@en ;
    skos:definition "Application is important for business operations; downtime has significant impact."@en ;
    skos:inScheme <kos/application/business-importance> .

<https://w3id.org/noria/kos/application/sla-level>
    a skos:ConceptScheme ;
    rdfs:label "Application Module SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying Service Level Agreement (SLA) levels for application modules."@en .

<https://w3id.org/noria/kos/application/sla-level/Gold_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "Gold_extra_node_1"@en ;
    skos:definition "Highest SLA level, indicating maximum availability and performance guarantees."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<https://w3id.org/noria/kos/application/sla-level/Silver>
    a skos:Concept ;
    skos:prefLabel "Silver"@en ;
    skos:definition "Medium_extra_node_1 SLA level, indicating good availability and performance guarantees."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<https://w3id.org/noria/kos/application/status>
    a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    rdfs:comment "A scheme for classifying operational statuses of application modules, e.g., In Production, Development_extra_node_1."@en .

<https://w3id.org/noria/kos/application/status/InProduction_extra_node_1>
    a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:definition "The application module is currently live and serving users."@en ;
