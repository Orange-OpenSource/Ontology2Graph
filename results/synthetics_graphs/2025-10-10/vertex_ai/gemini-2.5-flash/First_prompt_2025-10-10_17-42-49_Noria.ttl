# Application Types
noria-inst:AppType_WebPortal
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Web Portal Application Type"@en ;
    rdfs:comment "A web-based application providing a user interface."@en .

noria-inst:AppType_Database
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Database Application Type"@en ;
    rdfs:comment "An application primarily managing data storage and retrieval."@en .

noria-inst:AppType_Monitoring
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Monitoring Application Type"@en ;
    rdfs:comment "An application used for system and network monitoring."@en .

