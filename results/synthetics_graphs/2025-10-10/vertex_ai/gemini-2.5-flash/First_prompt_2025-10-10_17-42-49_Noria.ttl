    noria:troubleTicketCriticity noria-inst:TTCriticity_InterruptedService ;
    noria:troubleTicketPriority noria-inst:TTPriority_P1 ;
    noria:troubleTicketOrigin noria-inst:TTOrigin_Customer ;
    noria:troubleTicketTrigger noria-inst:Event_RouterCPUHigh ;
    noria:troubleTicketUrgency noria-inst:TTUrgency_Immediate ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory noria-inst:TTCriticity_InterruptedService ;
    noria:problemCategory noria-inst:TTCriticity_InterruptedService ;
    noria:troubleTicketCause "High CPU on core router impacting portal connectivity."^^xsd:string ;
    noria:problemResponsibility noria-inst:TTResp_ManagedNetwork ;
    noria:troubleTicketDetectionDateTime "2024-03-20T10:07:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-20T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-03-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent noria-inst:TTStatus_InProgress ;
    noria:troubleTicketRelatedParty noria-inst:AppSupportTeam ;
    noria:troubleTicketRelatedParty noria-inst:NetworkOperationsTeam ;
    noria:troubleTicketRelatedService noria-inst:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria-inst:Router_Core01 ;
    noria:troubleTicketImpacts noria-inst:App_CustomerPortal ;
    noria:troubleTicketImpacts noria-inst:Server_Web01 ;
