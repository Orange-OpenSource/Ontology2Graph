# =============================================================================
# Procedural Elements (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition, noria:AnomalyPattern)
# =============================================================================

noria-inst:OpPlan_RouterReboot
    a noria:OperationPlan ;
    rdfs:label "Router Reboot Procedure"@en ;
    rdfs:comment "Standard operating procedure for rebooting a network router."@en ;
    noria:operationPlanPreCondition noria-inst:PreCond_TrafficLow ;
    noria:operationPlanPostCondition noria-inst:PostCond_RouterUp .

noria-inst:PreCond_TrafficLow
    a noria:ActionPreCondition ;
    rdfs:label "Low Traffic Condition"@en ;
    rdfs:comment "Condition: Network traffic must be below 10% of capacity."@en .

noria-inst:PostCond_RouterUp
    a noria:ActionPostCondition ;
    rdfs:label "Router Operational Post-Reboot"@en ;
    rdfs:comment "Expected outcome: Router is fully operational and all interfaces are up."@en .

noria-inst:AnomalyPattern_HighCPU
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization on a critical resource."@en ;
    folio:hasFailureMode "Sustained High CPU"^^xsd:string .

noria-inst:OpPlan_DBMaintenance
    a noria:OperationPlan ;
    rdfs:label "Database Maintenance Procedure"@en ;
    rdfs:comment "Scheduled procedure for database optimization and backup."@en ;
    noria:operationPlanPreCondition noria-inst:PreCond_BackupComplete ;
    noria:operationPlanPostCondition noria-inst:PostCond_DBOptimized .

noria-inst:PreCond_BackupComplete
    a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete"@en ;
    rdfs:comment "Condition: Full database backup must be completed before maintenance."@en .

noria-inst:PostCond_DBOptimized
    a noria:ActionPostCondition ;
    rdfs:label "Database Optimized"@en ;
    rdfs:comment "Expected outcome: Database performance metrics are within optimal range."@en .

