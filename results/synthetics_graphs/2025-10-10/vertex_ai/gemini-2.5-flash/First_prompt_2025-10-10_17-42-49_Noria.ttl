noria-inst:TTNote_20240320_001_01
    a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note"@en ;
    rdfs:comment "First note on TT_20240320_001: Initial diagnosis points to network congestion."@en ;
    noria:troubleTicketNoteCommentType noria-inst:TTNoteCommentType_Internal ;
    noria:troubleTicketNoteOperationType noria-inst:TTNoteOpType_Diagnosis ;
    dcterms:created "2024-03-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:creator noria-inst:BobJohnson ;
    dcterms:description "Observed high CPU on core router. Investigating traffic patterns."^^xsd:string ;
    dcterms:isPartOf noria-inst:TT_20240320_001 ;
    noria:eventRelatedParty noria-inst:BobJohnson .

noria-inst:TTNote_20240320_001_02
    a noria:TroubleTicketNote ;
    rdfs:label "Resolution Action Note"@en ;
    rdfs:comment "Second note on TT_20240320_001: Applied temporary traffic shaping."@en ;
    noria:troubleTicketNoteCommentType noria-inst:TTNoteCommentType_Internal ;
    noria:troubleTicketNoteOperationType noria-inst:TTNoteOpType_Intervention ;
    dcterms:created "2024-03-20T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator noria-inst:AliceSmith ;
    dcterms:description "Implemented temporary QoS policy on Core01 to prioritize portal traffic. CPU dropped to 60%."^^xsd:string ;
    dcterms:isPartOf noria-inst:TT_20240320_001 ;
    noria:eventRelatedParty noria-inst:AliceSmith ;
    noria:troubleTicketNoteCorrelatedExecution noria-inst:ProcExecCont_TrafficShape .

