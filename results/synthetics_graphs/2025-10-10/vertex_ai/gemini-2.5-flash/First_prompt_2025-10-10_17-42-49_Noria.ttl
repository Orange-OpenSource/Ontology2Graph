# Dynamic Elements (noria:EventRecord, noria:TroubleTicket, noria:TroubleTicketNote, noria:ChangeRequest, noria:DocumentAttachment)
# =============================================================================

noria-inst:Event_RouterCPUHigh
    a noria:EventRecord ;
    rdfs:label "Router CPU High Event"@en ;
    rdfs:comment "Event indicating high CPU usage on Core Router 01."@en ;
    noria:loggingTime "2024-03-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on core01.dc-par.example.com exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject noria-inst:Router_Core01 ;
    noria:logOriginatingManagementSystem noria-inst:App_MonitoringSystem ;
    noria:alarmSeverity noria-inst:AlarmSeverity_Critical ;
    noria:alarmProposedRepairAction noria-inst:OpPlan_RouterReboot .

noria-inst:Event_InterfaceDown
    a noria:EventRecord ;
    rdfs:label "Interface Down Event"@en ;
    rdfs:comment "Event indicating that an interface on Edge Router 01 went down."@en ;
    noria:loggingTime "2024-03-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet 0/0/0 on edge01.dc-par.example.com changed state to down."^^xsd:string ;
    noria:logOriginatingManagedObject noria-inst:Router_Edge01 ;
    noria:logOriginatingManagementSystem noria-inst:App_MonitoringSystem ;
    noria:alarmSeverity noria-inst:AlarmSeverity_Critical ;
    noria:logOriginatingAgent noria-inst:AliceSmith . # Example of an agent causing an event (e.g., manual shutdown)

noria-inst:Event_LoginFailure
    a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Event indicating multiple failed login attempts on Web Server 01."@en ;
    noria:loggingTime "2024-03-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Multiple failed login attempts detected for user 'admin' on web01.example.com from IP 192.168.1.100."^^xsd:string ;
    noria:logOriginatingManagedObject noria-inst:Server_Web01 ;
    noria:logOriginatingManagementSystem noria-inst:SecurityTeam ;
    noria:alarmSeverity noria-inst:AlarmSeverity_Warning .

noria-inst:TT_20240320_001
    a noria:TroubleTicket ;
    rdfs:label "Customer Portal Unresponsive"@en ;
    rdfs:comment "Customer reported that the Customer Portal is unresponsive."@en ;
    noria:documentExternalId "CUST-P-12345"^^xsd:string ;
    noria:documentHRef "https://ticketing.example.com/TT_20240320_001"^^xsd:anyURI ;
    noria:troubleTicketSeverity noria-inst:TTSeverity_Critical ;
