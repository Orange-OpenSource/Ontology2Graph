# =============================================================================
# Organizational Entities (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

noria-inst:AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "A network engineer responsible for core infrastructure."@en ;
    foaf:mbox "mailto:alice.smith@example.com"^^xsd:anyURI ;
    foaf:phone "+1-555-123-4567"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:AgentContact_Email ;
    noria:agentInstructions "Contact via email for non-urgent issues, phone for critical alerts."^^xsd:string .

noria-inst:BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "An application support specialist."@en ;
    foaf:mbox "mailto:bob.johnson@example.com"^^xsd:anyURI ;
    foaf:phone "+1-555-987-6543"^^xsd:string ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:AgentContact_Phone ;
    noria:agentInstructions "Always call for immediate application issues."^^xsd:string .

noria-inst:CharlieBrown
    a foaf:Person ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "A database administrator."@en ;
    foaf:mbox "mailto:charlie.brown@example.com"^^xsd:anyURI ;
    foaf:phone "+1-555-111-2222"^^xsd:string ;
    noria:agentWorkingHours "10:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:AgentContact_Email ;
    noria:agentInstructions "Email for all requests, will respond within 2 hours."^^xsd:string .

noria-inst:NetworkOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:AgentContact_Phone ;
    noria:agentInstructions "Use ticketing system for all requests, call hotline for P1/P2 incidents."^^xsd:string ;
    org:hasMember noria-inst:AliceSmith .

noria-inst:AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "08:00-20:00 (Mon-Sun)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:AgentContact_Email ;
    noria:agentInstructions "Submit tickets via portal, expect response within 1 hour."^^xsd:string ;
    org:hasMember noria-inst:BobJohnson .

noria-inst:DBATeam
    a org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all database systems."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:AgentContact_Email ;
    noria:agentInstructions "All database change requests must go through the CR process."^^xsd:string ;
    org:hasMember noria-inst:CharlieBrown .

noria-inst:SecurityTeam
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and response."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:AgentContact_Phone ;
    noria:agentInstructions "Report all security incidents immediately via dedicated hotline."^^xsd:string .

noria-inst:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountIdentifier "U12345"^^xsd:string ;
    foaf:holdsAccount noria-inst:AliceSmith .

# =============================================================================
# Location Entities (noria:Room, noria:Locus, bot:Site)
# =============================================================================

noria-inst:DataCenter_Paris
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

noria-inst:ServerRoom_A1
    a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "Server room within the Paris Data Center."@en ;
    bot:hasSpace noria-inst:DataCenter_Paris .

noria-inst:Locus_A1_R1_C5
    a noria:Locus ;
    rdfs:label "Locus A1-R1-C5"@en ;
    rdfs:comment "Specific location in Server Room A1, Rack 1, Slot 5."@en ;
    noria:locusLine "R1"^^xsd:string ;
    noria:locusRow "C5"^^xsd:string ;
    bot:containsZone noria-inst:ServerRoom_A1 .

noria-inst:DataCenter_Lyon
    a bot:Site ;
    rdfs:label "Lyon Data Center"@en ;
    rdfs:comment "Secondary data center located in Lyon."@en ;
    noria:siteId "DC-LYN-02"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "69007"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Lyon"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès"^^xsd:string .

noria-inst:ServerRoom_B2
    a noria:Room ;
    rdfs:label "Server Room B2"@en ;
    rdfs:comment "Server room within the Lyon Data Center."@en ;
    bot:hasSpace noria-inst:DataCenter_Lyon .

noria-inst:Locus_B2_R3_C10
    a noria:Locus ;
    rdfs:label "Locus B2-R3-C10"@en ;
    rdfs:comment "Specific location in Server Room B2, Rack 3, Slot 10."@en ;
    noria:locusLine "R3"^^xsd:string ;
    noria:locusRow "C10"^^xsd:string ;
    bot:containsZone noria-inst:ServerRoom_B2 .

