@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix ob: <http://ontology.tno.nl/saref#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.com/Network1> a noria:ManagedElement, seas:System ;
  rdfs:label "Main Corporate Network"@en ;
  rdfs:comment "The primary corporate network infrastructure connecting all data centers and offices."@en ;
  noria:elementManagedBy <https://example.com/Org/ITSupport> ;
  noria:locatedAtLocus <https://example.com/Locus/OfficeFloor> ;
  noria:resourceManagedBy <https://example.com/Org/NetworkAdmin> ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Network> ;
  noria:resourceSerialNumber "NET-001"^^xsd:string ;
  noria:resourceLogisticId "LOG-12345"^^xsd:string ;
  noria:resourceHostName "core-network-01"^^xsd:string ;
  noria:resourceProductModel <https://example.com/ProductModel/NetModelX> ;
  noria:locatedAtLocus <https://example.com/Locus/ServerRoom> .

<https://example.com/Resource/Router1> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Router 1"@en ;
  rdfs:comment "Core router responsible for main data traffic routing."@en ;
  noria:resourceSerialNumber "R-0001"^^xsd:string ;
  noria:resourceLogisticId "LOG-54321"^^xsd:string ;
  noria:resourceHostName "router-01"^^xsd:string ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:resourceProductModel <https://example.com/ProductModel/RouterModelY> ;
  noria:locatedAtLocus <https://example.com/Locus/ServerRoom> ;
  noria:resourceManagementIPAddress "192.168.0.1"^^xsd:string ;
  noria:clusterController <https://example.com/Resource/ClusterController> ;
  noria:resourceManagedBy <https://example.com/Org/NetworkAdmin> .

<https://example.com/Resource/Switch1> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Switch 1"@en ;
  rdfs:comment "Aggregation switch for data center 1."@en ;
  noria:resourceSerialNumber "SW-1001"^^xsd:string ;
  noria:resourceLogisticId "LOG-67890"^^xsd:string ;
  noria:resourceHostName "switch-01"^^xsd:string ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
  noria:resourceProductModel <https://example.com/ProductModel/SwitchModelZ> ;
  noria:locatedAtLocus <https://example.com/Locus/DataCenter1> ;
  noria:resourceManagementIPAddress "192.168.0.2"^^xsd:string ;
  noria:agentManagesResource <https://example.com/Org/NetworkSupportTeam> .

<https://example.com/Resource/Firewall1> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Firewall 1"@en ;
  rdfs:comment "Firewall protecting the main data center perimeter."@en ;
  noria:resourceSerialNumber "FW-2001"^^xsd:string ;
  noria:resourceLogisticId "LOG-11223"^^xsd:string ;
  noria:resourceHostName "firewall-01"^^xsd:string ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
  noria:resourceProductModel <https://example.com/ProductModel/FirewallModelA> ;
  noria:locatedAtLocus <https://example.com/Locus/DataCenterPerimeter> ;
  noria:resourceManagementIPAddress "192.168.0.3"^^xsd:string ;
  noria:agentManagesResource <https://example.com/Org/SecurityTeam> .

<https://example.com/NetworkLink/WANLink> a noria:NetworkLink ;
  rdfs:label "WAN Link"@en ;
  rdfs:comment "Optical fiber link connecting data centers in Paris and Papeete."@en ;
  noria:networkLinkId "LINK-001"^^xsd:string ;
  noria:networkLinkType "Optical Fiber"^^xsd:string ;
  noria:networkLinkInstallationDate "2020-05-15T10:00:00Z"^^xsd:dateTime ;
  noria:networkLinkTerminationResourceOrigin <https://example.com/Resource/Router1> ;
  noria:networkLinkTerminationResourceDestination <https://example.com/Resource/Router2> .

<https://example.com/Resource/Router2> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Router 2"@en ;
  rdfs:comment "Backup router for main data center."@en ;
  noria:resourceSerialNumber "R-0002"^^xsd:string ;
  noria:resourceLogisticId "LOG-54322"^^xsd:string ;
  noria:resourceHostName "router-02"^^xsd:string ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
  noria:resourceProductModel <https://example.com/ProductModel/RouterModelY> ;
  noria:locatedAtLocus <https://example.com/Locus/ServerRoom> .

<https://example.com/Resource/Server1> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Server 1"@en ;
  rdfs:comment "Primary application server."@en ;
  noria:resourceSerialNumber "SV-3001"^^xsd:string ;
  noria:resourceLogisticId "LOG-44556"^^xsd:string ;
  noria:resourceHostName "app-server-01"^^xsd:string ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceProductModel <https://example.com/ProductModel/ServerModelQ> ;
  noria:locatedAtLocus <https://example.com/Locus/DataCenter1> .

<https://example.com/Resource/Server2> a noria:Resource, seas:CommunicationDevice ;
  rdfs:label "Server 2"@en ;
  rdfs:comment "Backup application server."@en ;
  noria:resourceSerialNumber "SV-3002"^^xsd:string ;
  noria:resourceLogisticId "LOG-44557"^^xsd:string ;
  noria:resourceHostName "app-server-02"^^xsd:string ;
  noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
  noria:resourceProductModel <https://example.com/ProductModel/ServerModelQ> ;
  noria:locatedAtLocus <https://example.com/Locus/DataCenter1> .

<https://example.com/Org/ITSupport> a org:OrganizationalUnit ;
  rdfs:label "IT Support Team"@en ;
  rdfs:comment "Internal IT support team responsible for network infrastructure."@en .

<https://example.com/Org/NetworkAdmin> a org:OrganizationalUnit ;
  rdfs:label "Network Administration"@en ;
  rdfs:comment "Team responsible for network resource management."@en .

<https://example.com/Org/SecurityTeam> a org:OrganizationalUnit ;
  rdfs:label "Security Team"@en ;
  rdfs:comment "Team responsible for security infrastructure and policies."@en .

<https://example.com/Org/NetworkSupportTeam> a org:OrganizationalUnit ;
  rdfs:label "Network Support Team"@en ;
  rdfs:comment "Support team managing network devices and links."@en .

<https://example.com/Locus/OfficeFloor> a noria:Locus ;
  rdfs:label "Office Floor"@en ;
  rdfs:comment "Main office floor where core network equipment is located."@en .

<https://example.com/Locus/DataCenter1> a noria:Locus ;
  rdfs:label "Data Center 1"@en ;
  rdfs:comment "Primary data center in Paris."@en .

<https://example.com/Locus/DataCenterPerimeter> a noria:Locus ;
  rdfs:label "Data Center Perimeter"@en ;
  rdfs:comment "Perimeter security zone of the data center."@en .

<https://example.com/ProductModel/NetModelX> a noria:ProductModel ;
  rdfs:label "NetModelX"@en ;
  rdfs:comment "High-performance network model for core routers."@en .

<https://example.com/ProductModel/RouterModelY> a noria:ProductModel ;
  rdfs:label "RouterModelY"@en ;
  rdfs:comment "Enterprise-grade router model Y."@en .

<https://example.com/ProductModel/SwitchModelZ> a noria:ProductModel ;
  rdfs:label "SwitchModelZ"@en ;
  rdfs:comment "Data center switch model Z."@en .

<https://example.com/ProductModel/FirewallModelA> a noria:ProductModel ;
  rdfs:label "FirewallModelA"@en ;
  rdfs:comment "Next-gen firewall model A."@en .

<https://example.com/ProductModel/ServerModelQ> a noria:ProductModel ;
  rdfs:label "ServerModelQ"@en ;
  rdfs:comment "Application server model Q."@en .

