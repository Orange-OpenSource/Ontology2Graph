# Action Pre/Post Conditions
<https://w3id.org/noria/actionprecondition/ServerRestartPreCheck>
    a noria:ActionPreCondition ;
    rdfs:label "Server Restart Pre-Condition"@en ;
    rdfs:comment "Verify no active user sessions and data backups are complete."@en .

<https://w3id.org/noria/actionpostcondition/ServerRestartPostCheck>
    a noria:ActionPostCondition ;
    rdfs:label "Server Restart Post-Condition"@en ;
    rdfs:comment "Verify all services are running and accessible after restart."@en .

<https://w3id.org/noria/actionprecondition/NetworkFailoverPreCheck>
    a noria:ActionPreCondition ;
    rdfs:label "Network Failover Pre-Condition"@en ;
    rdfs:comment "Confirm primary link failure and secondary link readiness."@en .

<https://w3id.org/noria/actionpostcondition/NetworkFailoverPostCheck>
    a noria:ActionPostCondition ;
    rdfs:label "Network Failover Post-Condition"@en ;
    rdfs:comment "Verify traffic is flowing through the secondary link and primary is down."@en .

