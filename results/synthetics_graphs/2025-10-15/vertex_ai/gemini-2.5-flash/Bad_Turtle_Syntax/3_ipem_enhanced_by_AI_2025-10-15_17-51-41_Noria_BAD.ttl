# =============================================================================
# Additional links to ensure all ObjectProperties are used
# =============================================================================

# Using noria:structuralObservableOf (inverse of noria:structuralElementProperty)
# noria:structuralElementObservable is a subproperty of noria:elementProperty
# noria:virtualServerStatus is a subproperty of noria:structuralElementObservable
# So, noria:virtualServerStatus is a noria:structuralElementProperty.
# The inverse noria:structuralObservableOf would link the observable (skos:Concept) back to the element (Resource).
noria:OpState_Up
    noria:structuralObservableOf noria:Resource_Server_001 ;
.

# Using noria:actionCorrelatedOperationPlan
# Domain: noria:CorrectiveMaintenanceAction, noria:ChangeAction (subclasses of pep:ProcedureExecution)
# Range: noria:OperationPlan
noria:EventRecord_RouterCPUAlarm_001 # EventRecord is a pep:ProcedureExecution
    noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterRestart ;
.

noria:EventRecord_AppLog_LoginFailure_001 # EventRecord is a pep:ProcedureExecution
    noria:actionCorrelatedOperationPlan noria:OperationPlan_AppDeploy ;
.

# Ensure foaf:holdsAccount is used for CorporateUserIdentifier
noria:Person_JohnDoe
    foaf:holdsAccount noria:CorporateUserIdentifier_JohnDoe ;
.

noria:Person_JaneSmith
    foaf:holdsAccount noria:CorporateUserIdentifier_JaneSmith ;
.

# Dummy instance for generic pep:Procedure
noria:GenericProcedure_Troubleshooting
    a pep:Procedure ;
    rdfs:label "Generic Troubleshooting Procedure"@en ;
    rdfs:comment "A general procedure for diagnosing issues."@en ;
.

# Link to generic procedure
noria:alarmProposedRepairAction noria:GenericProcedure_Troubleshooting ;

# Dummy instance for generic characteristic
noria:GenericCharacteristic_PerformanceIssue
    a rdfs:Resource ; # No specific class for noria:troubleTicketCharacteristic, so using rdfs:Resource
    rdfs:label "Performance Issue Characteristic"@en ;
    rdfs:comment "A generic characteristic indicating a performance problem."@en ;
.

noria:troubleTicketCharacteristic noria:GenericCharacteristic_PerformanceIssue ;

# Dummy instance for generic monitored attribute
noria:GenericMonitoredAttribute_NetworkLatency
    a rdfs:Resource ; # No specific class for noria:alarmMonitoredAttribute, so using rdfs:Resource
    rdfs:label "Network Latency Metric"@en ;
    rdfs:comment "A generic attribute representing network latency."@en ;
.

noria:alarmMonitoredAttribute noria:GenericMonitoredAttribute_NetworkLatency ;

# Ensure all classes have at least one instance, even abstract ones if they are not covered by concrete subclasses.
# ManagedElement, Property, StructuralElement, StructuralObservable, FunctionalElement, DynamicElement, ProceduralElement
# These are abstract and covered by their concrete subclasses already instantiated.
# For example, noria:Resource is a StructuralElement, noria:Application is a FunctionalElement, noria:TroubleTicket is a DynamicElement.
# noria:ProductModel is a StructuralProperty (subclass of noria:Property).
# skos:Concept instances are used as ranges for properties that are subclasses of noria:StructuralObservable.
# So, all abstract classes are covered by their concrete instances or by instances of their sub-properties' ranges.
