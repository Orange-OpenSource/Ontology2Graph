noria:EventRecord_RouterCPUAlarm_001
    a noria:EventRecord, BBO:DocumentResource, pep:ProcedureExecution, observable:EventRecord, log:Event ;
    rdfs:label "Router CPU High Alarm"@en ;
    rdfs:comment "Event record for high CPU usage on Core Router R1."@en ;
    noria:loggingTime "2023-10-26T14:35:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on router-core-01 exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject noria:Resource_Router_001 ;
    noria:logOriginatingManagementSystem noria:Application_NetworkMgmt_001 ;
    noria:logOriginatingAgent noria:Team_NetworkOps ;
    noria:alarmSeverity noria:AlarmSeverity_Critical ;
    noria:alarmProposedRepairAction noria:OperationPlan_RouterRestart ;
    noria:alarmMonitoredAttribute noria:Resource_Router_001 ; # Linking to the resource itself as the monitored attribute
    noria:alarmMitigatedBy noria:ProcedureExecutionContainer_RouterFix_001 ;
.

noria:EventRecord_AppLog_LoginFailure_001
    a noria:EventRecord, BBO:DocumentResource, pep:ProcedureExecution, observable:EventRecord, log:Event ;
    rdfs:label "Application Login Failure Log"@en ;
