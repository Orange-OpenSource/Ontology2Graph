noria:Person_JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee in the IT department."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email ;
.

noria:Person_JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A senior network engineer."@en ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Call directly for critical network issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Phone ;
.

noria:Org_ITServices
    a org:Organization ;
    rdfs:label "IT Services Department"@en ;
    rdfs:comment "The main IT services organization."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email ;
.

noria:Team_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "Escalate P1 issues to on-call engineer."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Phone ;
    noria:agentManagesResource noria:Resource_Router_001, noria:NetworkLink_WAN_001 ;
.

noria:Team_AppDev
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for application development and maintenance."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit bug reports via JIRA."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email ;
    noria:agentManagesResource noria:Application_CRM_001 ;
.

noria:Site_MainDataCenter
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility."@en ;
    noria:siteId "DC01"^^xsd:string ;
