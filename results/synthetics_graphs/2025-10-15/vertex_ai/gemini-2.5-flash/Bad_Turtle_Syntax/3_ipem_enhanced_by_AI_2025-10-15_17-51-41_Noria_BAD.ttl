noria:OperationPlan_RouterRestart
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Router Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network router."@en ;
    noria:operationPlanPreCondition noria:PreCondition_NetworkImpactLow ;
    noria:operationPlanPostCondition noria:PostCondition_RouterOnline ;
.

noria:OperationPlan_AppDeploy
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Application Deployment Procedure"@en ;
    rdfs:comment "Procedure for deploying new versions of applications."@en ;
    noria:operationPlanPreCondition noria:PreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:PostCondition_AppFunctional ;
.

noria:PreCondition_NetworkImpactLow
    a noria:ActionPreCondition ;
    rdfs:label "Low Network Impact Expected"@en ;
    rdfs:comment "Pre-condition: Network impact of the operation is expected to be low."@en ;
.

noria:PreCondition_MaintenanceWindow
    a noria:ActionPreCondition ;
    rdfs:label "Scheduled Maintenance Window"@en ;
    rdfs:comment "Pre-condition: Operation must occur within a scheduled maintenance window."@en ;
.

noria:PostCondition_RouterOnline
    a noria:ActionPostCondition ;
    rdfs:label "Router Online and Functional"@en ;
    rdfs:comment "Post-condition: Router is expected to be online and fully functional."@en ;
.

noria:PostCondition_AppFunctional
    a noria:ActionPostCondition ;
    rdfs:label "Application Fully Functional"@en ;
    rdfs:comment "Post-condition: Application is expected to be fully functional after deployment."@en ;
.

noria:AnomalyPattern_HighCPU
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "High CPU Usage Anomaly"@en ;
    rdfs:comment "Pattern indicating abnormally high CPU usage on a resource."@en ;
.

