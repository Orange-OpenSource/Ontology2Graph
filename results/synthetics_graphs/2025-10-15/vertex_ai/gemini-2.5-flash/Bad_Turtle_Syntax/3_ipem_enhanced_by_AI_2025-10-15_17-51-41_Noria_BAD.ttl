noria:NetworkInterface_R1_Eth0
    a noria:NetworkInterface, seas:CommunicationConnectionPoint, observable:NetworkInterface ;
    rdfs:label "Router R1 Ethernet 0/0"@en ;
    rdfs:comment "Ethernet interface on Core Router R1."@en ;
    noria:networkInterfaceDescription "Uplink to ISP"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
