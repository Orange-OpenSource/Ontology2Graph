noria:Resource_Router_001
    a noria:Resource, seas:System, seas:CommunicationDevice, bot:Element, observable:Device, log:Host ;
    rdfs:label "Core Router R1"@en ;
    rdfs:comment "Main router for the data center network."@en ;
    noria:resourceLogisticId "ASSET-RTR-001"^^xsd:string ;
    noria:resourceHostName "router-core-01.example.com"^^xsd:string ;
    noria:resourceSerialNumber "SN123456789"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:resourceProductModel noria:ProductModel_Cisco3850 ;
    noria:resourceType noria:ResourceType_Router ;
    noria:resourceUsageState noria:LifecycleState_Production ;
    noria:resourceForApplication noria:Application_NetworkMgmt_001 ;
    noria:locatedAtLocus noria:Locus_RackB_DC01 ;
    noria:resourceManagementIPAddress noria:IPAddress_192_168_1_1 ;
    noria:clusterController noria:Resource_Controller_001 ;
    noria:virtualServerStatus noria:OpState_Up ;
.

