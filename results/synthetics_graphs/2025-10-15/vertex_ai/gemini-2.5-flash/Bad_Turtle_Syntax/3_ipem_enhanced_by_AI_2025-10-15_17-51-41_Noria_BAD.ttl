    noria:logText "User 'johndoe' failed to log in to CRM_PROD_INSTANCE from IP 192.168.1.100."^^xsd:string ;
    noria:logOriginatingManagedObject noria:Application_CRM_001 ;
    noria:logOriginatingManagementSystem noria:Application_CRM_001 ; # Application itself can be the management system
    noria:logOriginatingAgent noria:Person_JohnDoe ;
    noria:alarmSeverity noria:AlarmSeverity_Warning ;
.

noria:ProcedureExecutionContainer_RouterFix_001
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Router Fix Execution Container"@en ;
    rdfs:comment "Container for actions taken to fix router CPU issue."@en ;
