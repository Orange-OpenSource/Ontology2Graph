# Implicitly defined classes from the schema's property domains/ranges
noria:ProceduralObject
    a owl:Class ;
    rdfs:label "Procedural Object" ;
    rdfs:comment "An abstract class for objects related to procedures, serving as a superclass for AnomalyPattern, OperationPlan, ActionPreCondition, and ActionPostCondition. It is a subclass of noria:ProceduralElement." ;
    rdfs:subClassOf noria:ProceduralElement ;
.

noria:StructuralProperty
    a owl:Class ;
    rdfs:label "Structural Property" ;
    rdfs:comment "An abstract class for properties of structural elements, serving as a superclass for ProductModel. It is a subclass of noria:Property." ;
    rdfs:subClassOf noria:Property ;
.

noria:Characteristic
    a owl:Class ;
    rdfs:label "Characteristic" ;
    rdfs:comment "A generic characteristic for entities like TroubleTickets, allowing for flexible property descriptions." ;
    rdfs:subClassOf noria:Property ;
.

noria:CorrectiveMaintenanceAction
    a owl:Class ;
    rdfs:label "Corrective Maintenance Action" ;
    rdfs:comment "An action taken to correct a fault or issue, often in response to a TroubleTicket. It is a subclass of noria:DynamicElement and pep:ProcedureExecution." ;
    rdfs:subClassOf noria:DynamicElement, pep:ProcedureExecution ;
.

noria:ChangeAction
    a owl:Class ;
    rdfs:label "Change Action" ;
    rdfs:comment "An action taken as part of a change request, detailing specific steps or operations. It is a subclass of noria:DynamicElement and pep:ProcedureExecution." ;
    rdfs:subClassOf noria:DynamicElement, pep:ProcedureExecution ;
.

observable:IPAddress
    a owl:Class ;
    rdfs:label "IP Address" ;
    rdfs:comment "Represents an IP address, used for management interfaces of resources. It is a subclass of observable:Address." ;
    rdfs:subClassOf observable:Address ;
.

