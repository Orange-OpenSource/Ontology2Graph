# Instances for foaf:Agent and org:Organization/OrganizationalUnit
<agent/JohnDoe>
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe" ;
    rdfs:comment "A fictional employee, acting as an agent within the organization." ;
    foaf:name "John Doe"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters, use emergency line for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

<agent/JaneSmith>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Another fictional employee, acting as an agent, specializing in network support." ;
    foaf:name "Jane Smith"^^xsd:string ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Call directly for critical network issues, otherwise use ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

<org/ITOperations>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "The department responsible for overall IT infrastructure and application operations." ;
    org:unitOf <org/NoriaCorp> ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "All requests must go through the central ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

<org/NetworkTeam>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Engineering Team" ;
    rdfs:comment "A specialized team within IT Operations focusing on network infrastructure management." ;
    org:unitOf <org/ITOperations> ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Escalate via John Doe for urgent network issues during business hours."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

<org/NoriaCorp>
    a org:Organization, foaf:Agent ;
    rdfs:label "Noria Corporation" ;
    rdfs:comment "The main organization that owns and operates the described IT infrastructure." ;
    noria:agentWorkingHours "Global coverage"^^xsd:string ;
    noria:agentInstructions "Refer to corporate policy for all operational procedures."^^xsd:string ;
.

<org/CiscoSystems>
    a org:Organization, foaf:Agent ;
    rdfs:label "Cisco Systems" ;
    rdfs:comment "A major manufacturer of networking hardware and software." ;
.

<org/DellTechnologies>
    a org:Organization, foaf:Agent ;
    rdfs:label "Dell Technologies" ;
    rdfs:comment "A major manufacturer of computer hardware, including servers." ;
.

# Instances for bot:Site, noria:Room, noria:Locus
