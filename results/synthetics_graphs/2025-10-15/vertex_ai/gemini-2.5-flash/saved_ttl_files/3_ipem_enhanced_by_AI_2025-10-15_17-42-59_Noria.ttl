.

<operationPlan/SoftwareUpgrade>
    a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Plan" ;
    rdfs:comment "A detailed plan outlining the steps for upgrading router software, including pre-checks and post-checks." ;
    noria:elementDistinguishedName "op-router-upgrade"^^xsd:string ;
    pep:hasInput <actionPreCondition/BackupComplete> ;
    pep:hasOutput <actionPostCondition/UpgradeSuccessful> ;
    noria:operationPlanPreCondition <actionPreCondition/BackupComplete> ;
    noria:operationPlanPostCondition <actionPostCondition/UpgradeSuccessful> ;
.

# Instances for noria:ActionPreCondition
<actionPreCondition/InterfaceDown>
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Pre-Condition" ;
    rdfs:comment "A pre-condition stating that the network interface must be in a 'down' state before proceeding with an operation." ;
    noria:elementDistinguishedName "precond-interface-down"^^xsd:string ;
.

<actionPreCondition/BackupComplete>
    a noria:ActionPreCondition ;
    rdfs:label "Backup Complete Pre-Condition" ;
    rdfs:comment "A pre-condition requiring a full configuration backup to be completed before a major change." ;
    noria:elementDistinguishedName "precond-backup-complete"^^xsd:string ;
.

# Instances for noria:ActionPostCondition
<actionPostCondition/InterfaceUp>
    a noria:ActionPostCondition ;
    rdfs:label "Interface Up Post-Condition" ;
    rdfs:comment "A post-condition expecting the network interface to be in an 'up' state after an operation." ;
    noria:elementDistinguishedName "postcond-interface-up"^^xsd:string ;
.

<actionPostCondition/UpgradeSuccessful>
    a noria:ActionPostCondition ;
    rdfs:label "Upgrade Successful Post-Condition" ;
    rdfs:comment "A post-condition confirming that a software upgrade has completed without errors." ;
    noria:elementDistinguishedName "postcond-upgrade-successful"^^xsd:string ;
.

# Instances for noria:StructuralObservable
<structuralObservable/InterfaceStatus>
    a noria:StructuralObservable ;
    rdfs:label "Network Interface Status Observable" ;
    rdfs:comment "An observable property representing the current operational status of a network interface." ;
    noria:elementDistinguishedName "obs-interface-status"^^xsd:string ;
    noria:structuralElementObservable <networkInterface/Router01-Eth0> ;
.

# Instances for noria:CorrectiveMaintenanceAction and noria:ChangeAction
<correctiveMaintenanceAction/FiberCheck>
    a noria:CorrectiveMaintenanceAction ;
    rdfs:label "Fiber Optic Cable Check" ;
    rdfs:comment "A corrective action involving a physical inspection and testing of a fiber optic cable." ;
    noria:elementDistinguishedName "cma-fiber-check"^^xsd:string ;
    noria:actionCorrelatedOperationPlan <operationPlan/RestartInterface> ;
    noria:eventRelatedElement <networkLink/ISP-Uplink> ;
    noria:eventRelatedParty <agent/JohnDoe> ;
.

<changeAction/RouterConfigUpdate>
    a noria:ChangeAction ;
    rdfs:label "Router Configuration Update" ;
    rdfs:comment "A specific action taken to update the configuration of a router as part of a larger change request." ;
    noria:elementDistinguishedName "ca-router-config-update"^^xsd:string ;
    noria:actionCorrelatedOperationPlan <operationPlan/SoftwareUpgrade> ;
    noria:eventRelatedElement <resource/Router01> ;
    noria:eventRelatedParty <agent/JaneSmith> ;
.

# Explicitly state inverse relationships or other links to ensure full coverage of ObjectProperties
<org/NetworkTeam>
    noria:agentManagesResource <resource/Router01>, <networkLink/ISP-Uplink> ;
.

<org/ITOperations>
    noria:agentManagesResource <resource/Server01>, <resource/ClusterController01> ;
.

<agent/JohnDoe>
    foaf:holdsAccount <cuid/JohnDoeCUID> ;
.
