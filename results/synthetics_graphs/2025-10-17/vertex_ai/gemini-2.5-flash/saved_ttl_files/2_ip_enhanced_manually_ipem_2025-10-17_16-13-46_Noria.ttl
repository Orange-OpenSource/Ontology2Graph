    noria:elementManagedBy org:OrganizationalUnit_SecurityTeam .

noria:ActionPreCondition_LinkDown
    a noria:ActionPreCondition ;
    rdfs:label "Network Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: a critical network link is reported as down."@en ;
    noria:elementManagedBy org:OrganizationalUnit_NetworkOps .

noria:ActionPostCondition_LinkUp
    a noria:ActionPostCondition ;
    rdfs:label "Network Link Up Post-Condition"@en ;
    rdfs:comment "Expected outcome: the critical network link is restored and operational."@en ;
    noria:elementManagedBy org:OrganizationalUnit_NetworkOps .

noria:ActionPreCondition_HighCPU
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Usage Pre-Condition"@en ;
    rdfs:comment "Condition: CPU utilization on a critical server exceeds threshold."@en ;
    noria:elementManagedBy org:OrganizationalUnit_DBA .

noria:ActionPostCondition_LowCPU
    a noria:ActionPostCondition ;
    rdfs:label "Low CPU Usage Post-Condition"@en ;
    rdfs:comment "Expected outcome: CPU utilization on the server returns to normal levels."@en ;
    noria:elementManagedBy org:OrganizationalUnit_DBA .

noria:ActionPreCondition_NewFeatureRequest
    a noria:ActionPreCondition ;
    rdfs:label "New Feature Firewall Request Pre-Condition"@en ;
    rdfs:comment "Condition: A new application feature requires specific firewall access."@en ;
    noria:elementManagedBy org:OrganizationalUnit_SecurityTeam .

noria:ActionPostCondition_TrafficFlows
    a noria:ActionPostCondition ;
    rdfs:label "New Feature Traffic Flows Post-Condition"@en ;
    rdfs:comment "Expected outcome: Network traffic for the new feature flows correctly through the firewall."@en ;
    noria:elementManagedBy org:OrganizationalUnit_SecurityTeam .

noria:AnomalyPattern_RepeatedLinkFlap
    a noria:AnomalyPattern ;
    rdfs:label "Repeated Link Flap Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a recurring issue with a network link frequently changing state."@en ;
    folio:hasCause "Faulty Transceiver"^^xsd:string ;
    folio:hasEffect "Intermittent Network Outage"^^xsd:string ;
    noria:elementManagedBy org:OrganizationalUnit_NetworkOps .

noria:AnomalyPattern_DBDeadlock
    a noria:AnomalyPattern ;
    rdfs:label "Database Deadlock Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating frequent database deadlocks affecting application stability."@en ;
    folio:hasCause "Inefficient Query Design"^^xsd:string ;
    folio:hasEffect "Application Freezes"^^xsd:string ;
    noria:elementManagedBy org:OrganizationalUnit_DBA .

# --- Linking EventRecords to ProcedureExecutionContainer (TroubleTicket/ChangeRequest/TroubleTicketNote) ---

noria:TroubleTicket_TT001 pep:hasMember noria:EventRecord_RouterDown .
noria:TroubleTicket_TT002 pep:hasMember noria:EventRecord_DBHighCPU .
noria:TroubleTicket_TT003 pep:hasMember noria:EventRecord_FirewallBlocked .
noria:TroubleTicketNote_TT001_Note1 pep:hasMember noria:EventRecord_RouterDown .
noria:TroubleTicketNote_TT002_Note1 pep:hasMember noria:EventRecord_DBHighCPU .

# --- Linking ChangeRequests to EventRecords (for status history) ---
noria:ChangeRequest_CR001 noria:documentStatusHistory noria:EventRecord_ConfigChange .

# --- Linking actions to OperationPlans ---
# Creating specific instances of pep:CorrectiveMaintenanceAction and pep:ChangeAction as EventRecord is a pep:ProcedureExecution.

pep:CorrectiveMaintenanceAction_FiberCheck
    a pep:CorrectiveMaintenanceAction ;
    rdfs:label "Fiber Check Action for Router Outage"@en ;
    rdfs:comment "An action taken to check the fiber optic link after a router interface went down."@en ;
    pep:hasProcedure noria:OperationPlan_CheckFiber ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_CheckFiber ;
    pep:hasInput noria:ActionPreCondition_LinkDown ;
    pep:hasOutput noria:ActionPostCondition_LinkUp ;
    pep:hasMember noria:EventRecord_RouterDown ;
    noria:elementManagedBy org:OrganizationalUnit_NetworkOps .

pep:ChangeAction_DBIndexOptimize
    a pep:ChangeAction ;
    rdfs:label "Database Index Optimization Action"@en ;
    rdfs:comment "An action taken to optimize database indexes."@en ;
    pep:hasProcedure noria:OperationPlan_DBOptimization ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_DBOptimization ;
    pep:hasInput noria:ActionPreCondition_HighCPU ;
    pep:hasOutput noria:ActionPostCondition_LowCPU ;
    pep:hasMember noria:EventRecord_DBHighCPU ;
    noria:elementManagedBy org:OrganizationalUnit_DBA .

pep:ChangeAction_FirewallRuleUpdate
    a pep:ChangeAction ;
    rdfs:label "Firewall Rule Update Action"@en ;
    rdfs:comment "An action taken to update firewall rules as per CR003."@en ;
    pep:hasProcedure noria:OperationPlan_FirewallUpdate ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_FirewallUpdate ;
    pep:hasInput noria:ActionPreCondition_NewFeatureRequest ;
    pep:hasOutput noria:ActionPostCondition_TrafficFlows ;
    pep:hasMember noria:EventRecord_FirewallBlocked ; # This event might be a result of the old rule blocking, or a test of the new rule
    noria:elementManagedBy org:OrganizationalUnit_SecurityTeam .

# --- Generic StructuralObservable instance ---
noria:StructuralObservable_NetworkStatus
    a noria:StructuralObservable ;
    rdfs:label "Network Interface Status Observable"@en ;
    rdfs:comment "An observable property representing the status of a network interface."@en .

noria:NetworkInterface_CR01_Ge000 noria:structuralElementObservable noria:StructuralObservable_NetworkStatus .
noria:NetworkInterface_WS01_Eth0 noria:structuralElementObservable noria:StructuralObservable_NetworkStatus .

