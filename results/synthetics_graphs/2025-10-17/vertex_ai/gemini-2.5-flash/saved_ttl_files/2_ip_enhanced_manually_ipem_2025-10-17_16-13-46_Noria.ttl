# --- Instances of foaf:Agent (Person and OrganizationalUnit) ---

foaf:Person_JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A senior network engineer."@en ;
    foaf:mbox "mailto:john.doe@example.com"^^xsd:anyURI ;
    foaf:phone "+33123456789"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Person_JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead application developer."@en ;
    foaf:mbox "mailto:jane.smith@example.com"^^xsd:anyURI ;
    foaf:phone "+33698765432"^^xsd:string ;
    noria:agentWorkingHours "10:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Person_AliceJohnson
    a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Junior network administrator."@en ;
    foaf:mbox "mailto:alice.johnson@example.com"^^xsd:anyURI ;
    foaf:phone "+33711223344"^^xsd:string ;
    noria:agentWorkingHours "8:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Escalate to John Doe for complex issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Person_BobWilliams
    a foaf:Person ;
    rdfs:label "Bob Williams"@en ;
    rdfs:comment "Database administrator."@en ;
    foaf:mbox "mailto:bob.williams@example.com"^^xsd:anyURI ;
    foaf:phone "+33655443322"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Monitor database performance dashboards."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:OrganizationalUnit_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:hasMember foaf:Person_JohnDoe, foaf:Person_AliceJohnson ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentInstructions "Follow incident management procedure for escalation."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:OrganizationalUnit_AppDev
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core applications."@en ;
    org:hasMember foaf:Person_JaneSmith ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit change requests via JIRA."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrganizationalUnit_SecurityTeam
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "All security alerts must be escalated immediately."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:OrganizationalUnit_DBA
    a org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database management and optimization."@en ;
    org:hasMember foaf:Person_BobWilliams ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Perform routine maintenance during off-peak hours."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

# --- Instances of noria:CorporateUserIdentifier ---
noria:CorporateUserIdentifier_JDoe
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe_netops"^^xsd:string ;
    observable:accountIdentifier "CU-JD-001"^^xsd:string ;
    observable:accountLogin "jdoe"^^xsd:string .

noria:CorporateUserIdentifier_JSmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith_appdev"^^xsd:string ;
    observable:accountIdentifier "CU-JS-002"^^xsd:string ;
    observable:accountLogin "jsmith"^^xsd:string .

noria:CorporateUserIdentifier_AJohnson
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Johnson."@en ;
    foaf:accountName "ajohnson_netops"^^xsd:string ;
    observable:accountIdentifier "CU-AJ-003"^^xsd:string ;
    observable:accountLogin "ajohnson"^^xsd:string .

foaf:Person_JohnDoe foaf:holdsAccount noria:CorporateUserIdentifier_JDoe .
foaf:Person_JaneSmith foaf:holdsAccount noria:CorporateUserIdentifier_JSmith .
foaf:Person_AliceJohnson foaf:holdsAccount noria:CorporateUserIdentifier_AJohnson .

# --- Instances of bot:Site, noria:Room, noria:Locus ---

bot:Site_ParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

bot:Site_LyonOffice
    a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office in Lyon with a small server room."@en ;
    noria:siteId "OFF-LYN-01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "69007"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Lyon"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès"^^xsd:string .

noria:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room in Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Room_NetworkCloset1
    a noria:Room ;
    rdfs:label "Network Closet 1"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace bot:Site_LyonOffice .

noria:Locus_RackA1
    a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Specific rack location for critical servers."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Locus_RackB5
    a noria:Locus ;
    rdfs:label "Rack B5 in Server Room A"@en ;
    rdfs:comment "Rack location for database servers."@en ;
