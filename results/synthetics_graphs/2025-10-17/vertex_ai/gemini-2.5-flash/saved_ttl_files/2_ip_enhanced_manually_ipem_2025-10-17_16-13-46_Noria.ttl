# Synthetic Knowledge Graph based on NORIA.ttl schema

# --- SKOS Concepts (for ranges of ObjectProperties) ---
# These concepts are used to classify various properties within the Noria ontology.

<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying methods to contact an agent."@en .

<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:prefLabel "Email"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:prefLabel "Phone"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

