# --- Operation Plans (noria:OperationPlan) ---

<https://w3id.org/noria/operationplan/RouterOSUpgradeProcedure>
    a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems."@en ;
    skos:example "Steps include backup configuration, download new image, install, reboot, verify."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/RouterBackupComplete> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/RouterOSVerified> .

<https://w3id.org/noria/operationplan/DBIndexOptimizationProcedure>
    a noria:OperationPlan ;
    rdfs:label "Database Index Optimization Procedure"@en ;
    rdfs:comment "Procedure for optimizing database indexes for improved performance."@en ;
    skos:example "Steps include analyze tables, rebuild indexes, monitor performance."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/DBPerformanceBaseline> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/DBPerformanceImproved> .

<https://w3id.org/noria/operationplan/WANLinkTroubleshootingProcedure>
    a noria:OperationPlan ;
    rdfs:label "WAN Link Troubleshooting Procedure"@en ;
    rdfs:comment "Standard procedure for diagnosing and resolving WAN link issues."@en ;
    skos:example "Steps include checking physical layer, verifying configurations, contacting ISP."@en .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---

<https://w3id.org/noria/actionprecondition/RouterBackupComplete>
    a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Complete"@en ;
    rdfs:comment "Ensures a full backup of the router configuration is completed before any OS upgrade."@en .

<https://w3id.org/noria/actionpostcondition/RouterOSVerified>
    a noria:ActionPostCondition ;
    rdfs:label "Router OS Version Verified"@en ;
    rdfs:comment "Verifies that the router is running the new OS version and all services are operational."@en .

<https://w3id.org/noria/actionprecondition/DBPerformanceBaseline>
    a noria:ActionPreCondition ;
    rdfs:label "Database Performance Baseline Established"@en ;
    rdfs:comment "Ensures current database performance metrics are recorded before optimization."@en .

<https://w3id.org/noria/actionpostcondition/DBPerformanceImproved>
    a noria:ActionPostCondition ;
    rdfs:label "Database Performance Improved"@en ;
    rdfs:comment "Confirms that database query performance has improved after index optimization."@en .

# --- Anomaly Patterns (noria:AnomalyPattern) ---

<https://w3id.org/noria/anomalypattern/HighCPUNetworkLatency>
    a noria:AnomalyPattern ;
    rdfs:label "High CPU and Network Latency Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential network bottleneck or resource exhaustion when both CPU usage is high and network latency increases."@en ;
    skos:example "If (CPU > 90% on Router) AND (Latency > 100ms on connected link), then Network Bottleneck."@en .

