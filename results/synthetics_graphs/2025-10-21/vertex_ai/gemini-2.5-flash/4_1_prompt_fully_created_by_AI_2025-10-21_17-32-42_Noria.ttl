# --- Agents (foaf:Agent, org:OrganizationalUnit) ---

<https://w3id.org/noria/agent/ITOperationsTeam>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:label "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for the day-to-day operation and maintenance of IT infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the emergency hotline. Otherwise, open a ticket."@en .

<https://w3id.org/noria/agent/NetworkAdminTeam>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:label "Équipe Administration Réseau"@fr ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via internal ticketing system for non-critical requests."@en .

