# Example of noria:troubleTicketNoteCorrelatedExecution
# Let's assume a procedure execution container for the web service restart
<https://w3id.org/noria/pep/WebSvcRestart_TTN1> a pep:ProcedureExecutionContainer ;
    rdfs:label "Web Service Restart Execution for TTN_WebPortalOutage_001_Note1"@en ;
    rdfs:comment "Container for the execution of the web service restart action."@en .
noria:TTN_WebPortalOutage_001_Note1 noria:troubleTicketNoteCorrelatedExecution <https://w3id.org/noria/pep/WebSvcRestart_TTN1> .

# Example of alarmMitigatedBy
# Let's assume the failover procedure execution mitigated the link down alarm
<https://w3id.org/noria/pep/WANFailoverExecution_TT2> a pep:ProcedureExecutionContainer ;
    rdfs:label "WAN Failover Execution for TT-CR-002"@en ;
    rdfs:comment "Container for the execution of the WAN link failover procedure."@en .
