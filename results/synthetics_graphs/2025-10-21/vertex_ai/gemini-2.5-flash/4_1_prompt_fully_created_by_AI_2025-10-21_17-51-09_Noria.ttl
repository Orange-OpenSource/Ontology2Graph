# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OP_ServerReboot a noria:OperationPlan ;
    rdfs:label "Standard Server Reboot Procedure"@en ;
    rdfs:comment "Procedure for safely rebooting a production server."@en .

noria:OP_NetworkFailover a noria:OperationPlan ;
    rdfs:label "Network Link Failover Protocol"@en ;
    rdfs:comment "Protocol for activating a redundant network link in case of primary link failure."@en .

noria:OP_DBBackup a noria:OperationPlan ;
    rdfs:label "Database Backup Procedure"@en ;
    rdfs:comment "Routine procedure for backing up the customer database."@en .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:APC_ServerPingable a noria:ActionPreCondition ;
    rdfs:label "Server Pingable Pre-Condition"@en ;
    rdfs:comment "Condition: The server must be reachable via ICMP (ping) before proceeding."@en .

noria:APC_TrafficLow a noria:ActionPreCondition ;
    rdfs:label "Low Network Traffic Pre-Condition"@en ;
    rdfs:comment "Condition: Network traffic on the affected link must be below a certain threshold."@en .

noria:APOC_ServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Outcome: The affected service is fully operational and accessible."@en .

noria:APOC_NewConfigActive a noria:ActionPostCondition ;
    rdfs:label "New Configuration Active Post-Condition"@en ;
    rdfs:comment "Outcome: The new configuration has been successfully applied and is active."@en .

noria:OP_ServerReboot noria:operationPlanPreCondition noria:APC_ServerPingable ;
    noria:operationPlanPostCondition noria:APOC_ServiceRestored .

noria:OP_NetworkFailover noria:operationPlanPreCondition noria:APC_TrafficLow ;
    noria:operationPlanPostCondition noria:APOC_ServiceRestored .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:Event_CPUHigh_WebServer01 a noria:EventRecord ;
    rdfs:label "CPU High Alert on Web Server 01"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2023-10-26T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_LinkDown_CR01_Gi0_0_1 a noria:EventRecord ;
    rdfs:label "Link Down Alert on Core Router 01 Interface"@en ;
    rdfs:comment "Network interface Gi0/0/1 on Core Router 01 went down."@en ;
    noria:loggingTime "2023-10-26T10:15:30Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1 on cr01.dc.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_ConfigChange_FW01 a noria:EventRecord ;
    rdfs:label "Configuration Change on Firewall 01"@en ;
    rdfs:comment "Log entry for a configuration change applied to Firewall 01."@en ;
    noria:loggingTime "2023-10-26T09:45:10Z"^^xsd:dateTime ;
    noria:logText "Configuration updated by Alice Smith: added new NAT rule for application X."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_PerimeterSecurity ;
    noria:logOriginatingAgent foaf:AliceSmith ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_DBError_DB01 a noria:EventRecord ;
    rdfs:label "Database Connection Error on DB Server 01"@en ;
    rdfs:comment "Error log indicating issues with database connections."@en ;
    noria:loggingTime "2023-10-26T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Failed to establish connection to database 'customer_db' from application server."@en ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_LoginFailure_VMHost01 a noria:EventRecord ;
    rdfs:label "Failed Login Attempt on VM Host 01"@en ;
    rdfs:comment "Security event: multiple failed login attempts detected on VM Host 01."@en ;
    noria:loggingTime "2023-10-26T09:30:00Z"^^xsd:dateTime ;
    noria:logText "Multiple failed login attempts for user 'root' from IP 10.0.0.5."@en ;
    noria:logOriginatingManagedObject noria:Resource_VMHost01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:Event_DNSResolutionFailure a noria:EventRecord ;
    rdfs:label "DNS Resolution Failure Alert"@en ;
    rdfs:comment "Alert indicating that DNS resolution for external domains is failing."@en ;
    noria:loggingTime "2023-10-26T10:20:00Z"^^xsd:dateTime ;
    noria:logText "External DNS resolution failed for example.com from internal network."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNSServer01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TT_WebPortalOutage_001 a noria:TroubleTicket ;
    rdfs:label "Corporate Web Portal Outage Incident"@en ;
