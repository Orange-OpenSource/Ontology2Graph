# Add a new trouble ticket related to storage
noria:TT_StoragePerformance_005 a noria:TroubleTicket ;
    rdfs:label "Storage Array Performance Degradation"@en ;
    rdfs:comment "Slow I/O operations reported on the primary storage array, impacting multiple services."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/PerformanceDegradation> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Storage Monitoring" ;
    noria:troubleTicketCategory <kos/TroubleTicket/category/PerformanceDegradation> ;
    noria:troubleTicketCause "High disk latency on storage array due to heavy load."@en ;
    noria:problemCategory <kos/TroubleTicket/category/PerformanceDegradation> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2023-10-27T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2023-10-27T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:InfrastructureTeam ;
    noria:troubleTicketRelatedResource noria:Resource_StorageArray01 ;
    noria:troubleTicketImpacts noria:Application_CustomerDatabase, noria:Service_CustomerDataManagement ;
    noria:documentHRef <https://itsm.example.com/ticket/TT-SAN-005> .

