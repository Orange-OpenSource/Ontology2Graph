# =============================================================================
# Anomaly Patterns (noria:AnomalyPattern)
# =============================================================================

noria:AP_HighCPU_WebPortal a noria:AnomalyPattern ;
    rdfs:label "High CPU on Web Portal Servers Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential issue with web portal performance due to excessive CPU usage."@en ;
    skos:example "Triggered when CPU > 90% for 5 minutes on any server associated with Corporate Web Portal."@en .

noria:AP_WANLinkFailure a noria:AnomalyPattern ;
    rdfs:label "WAN Link Failure Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a critical failure of a primary WAN link."@en ;
    skos:example "Triggered when a network interface connected to a primary WAN link goes down."@en .

noria:AP_DBConnectionErrors a noria:AnomalyPattern ;
    rdfs:label "Database Connection Errors Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a high rate of failed database connections."@en ;
    skos:example "Triggered when database logs show more than 10 connection errors per minute."@en .

