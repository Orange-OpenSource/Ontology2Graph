    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "LOG-WEB-001" ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-WEB-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-01T11:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_DC01_RackA1 ;
    noria:resourceManagementIPAddress "192.168.20.10" .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Corporate Database Server 01"@en ;
    rdfs:comment "Hosts the primary customer database."@en ;
    noria:resourceManagedBy org:DatabaseTeam ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "LOG-DB-001" ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DB-001-DEF" ;
