noria:Resource_VMHost01 a noria:Resource ;
    rdfs:label "Virtual Machine Host 01"@en ;
    rdfs:comment "ESXi host running multiple virtual machines."@en ;
    noria:resourceManagedBy org:InfrastructureTeam ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceLogisticId "LOG-VMH-001" ;
