# Link Agents to resources they manage (inverse of resourceManagedBy)
org:NetworkOperationsTeam noria:agentManagesResource noria:Resource_DNSServer01, noria:Resource_CoreRouter01, noria:Resource_LoadBalancer01, noria:Resource_BranchRouter01 .
org:ApplicationSupportTeam noria:agentManagesResource noria:Resource_WebServer01, noria:Resource_VirtualWebServer01 .
org:DatabaseTeam noria:agentManagesResource noria:Resource_DBServer01, noria:Resource_VirtualDBServer01 .
org:SecurityTeam noria:agentManagesResource noria:Resource_Firewall01 .
org:InfrastructureTeam noria:agentManagesResource noria:Resource_VMHost01 .

# Link Applications to resources they use (resourceForApplication)
noria:Resource_DNSServer01 noria:resourceForApplication noria:Application_DNSService .
noria:Resource_WebServer01 noria:resourceForApplication noria:Application_CorporateWebPortal .
noria:Resource_DBServer01 noria:resourceForApplication noria:Application_CustomerDatabase .
noria:Resource_Firewall01 noria:resourceForApplication noria:Application_PerimeterSecurity .
noria:Resource_LoadBalancer01 noria:resourceForApplication noria:Application_CorporateWebPortal .
noria:Resource_VirtualWebServer01 noria:resourceForApplication noria:Application_CorporateWebPortal .
noria:Resource_VirtualDBServer01 noria:resourceForApplication noria:Application_CustomerDatabase .

