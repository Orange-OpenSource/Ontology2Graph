# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (used for ranges of properties)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application"@en .
<kos/application/type/business-application> a skos:Concept ; rdfs:label "Business Application"@en .
<kos/application/type/monitoring-system> a skos:Concept ; rdfs:label "Monitoring System"@en .
<kos/application/type/database-system> a skos:Concept ; rdfs:label "Database System"@en .
<kos/application/type/security-system> a skos:Concept ; rdfs:label "Security System"@en .

<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low Business Importance"@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; rdfs:label "En Production"@fr .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; rdfs:label "Maintenance"@en .

<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en .
<kos/TroubleTicket/severity/Warning> a skos:Concept ; rdfs:label "Warning Severity"@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance"@en .
<kos/TroubleTicket/type/Maintenance> a skos:Concept ; rdfs:label "Maintenance"@en .

<kos/TroubleTicket/category/TotalBreakdown> a skos:Concept ; rdfs:label "Total Breakdown"@en .
<kos/TroubleTicket/category/IsolatedCustomerSite> a skos:Concept ; rdfs:label "Isolated Customer Site"@en .
<kos/TroubleTicket/category/PerformanceDegradation> a skos:Concept ; rdfs:label "Performance Degradation"@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en .
<kos/TroubleTicket/priority/P3> a skos:Concept ; rdfs:label "Priority 3"@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Origin"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision System Origin"@en .
<kos/TroubleTicket/origin/Internal> a skos:Concept ; rdfs:label "Internal Origin"@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention"@en .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention"@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; rdfs:label "Managed Backbone Networks"@en .
<kos/TroubleTicket/problemResponsibility/ApplicationHostingServices> a skos:Concept ; rdfs:label "Application Hosting Services"@en .
<kos/TroubleTicket/problemResponsibility/Customer> a skos:Concept ; rdfs:label "Customer Responsibility"@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en .
<kos/TroubleTicket/status/Initialised> a skos:Concept ; rdfs:label "Initialised"@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment"@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation"@en .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; rdfs:label "Tests and Measurements Operation"@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention"@en .
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency Change"@en .

<kos/ChangeRequest/cause/Configuration> a skos:Concept ; rdfs:label "Configuration Change Cause"@en .
<kos/ChangeRequest/cause/NetworkExtension> a skos:Concept ; rdfs:label "Network Extension Change Cause"@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved Status"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented Status"@en .
<kos/ChangeRequest/status/Scheduled> a skos:Concept ; rdfs:label "Scheduled Status"@en .

<kos/ChangeRequest/specification/StandardProcedure> a skos:Concept ; rdfs:label "Standard Procedure Specification"@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning Perceived Severity"@en .

<kos/Resource/type/server> a skos:Concept ; rdfs:label "Server Resource Type"@en .
<kos/Resource/type/router> a skos:Concept ; rdfs:label "Router Resource Type"@en .
<kos/Resource/type/firewall> a skos:Concept ; rdfs:label "Firewall Resource Type"@en .
<kos/Resource/type/load-balancer> a skos:Concept ; rdfs:label "Load Balancer Resource Type"@en .
<kos/Resource/type/virtual-machine> a skos:Concept ; rdfs:label "Virtual Machine Resource Type"@en .
<kos/Resource/type/storage-array> a skos:Concept ; rdfs:label "Storage Array Resource Type"@en .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ; rdfs:label "In Production Lifecycle State"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned Lifecycle State"@en .
<kos/Resource/LifecycleState/Maintenance> a skos:Concept ; rdfs:label "Maintenance Lifecycle State"@en .

<kos/Resource/OperationalState/up> a skos:Concept ; rdfs:label "Operational State Up"@en .
<kos/Resource/OperationalState/down> a skos:Concept ; rdfs:label "Operational State Down"@en .

<kos/Resource/AdministrativeState/up> a skos:Concept ; rdfs:label "Administrative State Up"@en .
<kos/Resource/AdministrativeState/down> a skos:Concept ; rdfs:label "Administrative State Down"@en .

<kos/org/agent-contact-method/email> a skos:Concept ; rdfs:label "Email Contact Method"@en .
<kos/org/agent-contact-method/phone> a skos:Concept ; rdfs:label "Phone Contact Method"@en .
<kos/org/agent-contact-method/chat> a skos:Concept ; rdfs:label "Chat Contact Method"@en .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, noria:CorporateUserIdentifier)
# =============================================================================

# Organizational Units (Teams)
org:NetworkOperationsTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing and maintaining network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical network issues, call the hotline immediately. For non-critical, use ticketing system."@en .

org:ApplicationSupportTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit tickets via the internal portal for all application-related issues."@en .

org:SecurityTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Alert via SIEM for high-severity security events."@en .

org:DatabaseTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing and maintaining all corporate databases."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Use the dedicated DB support portal for all requests."@en .

org:CustomerServiceTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Customer Service Center"@en ;
    rdfs:comment "First-line support for customer inquiries and issues."@en ;
    noria:agentWorkingHours "7:00 am - 10:00 pm (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Escalate unresolved customer issues to relevant L2 teams."@en .

org:ChangeManagementTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Change Management Board"@en ;
    rdfs:comment "Team responsible for approving and coordinating IT changes."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "All change requests must be submitted through the CR system at least 7 days in advance."@en .

org:InfrastructureTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Infrastructure Management Team"@en ;
    rdfs:comment "Team responsible for physical and virtual infrastructure."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact for server provisioning, virtualization, and hardware issues."@en .

# Individual Agents
foaf:AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, member of Network Operations Team."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:member org:NetworkOperationsTeam .

foaf:BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead Application Support Specialist."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:member org:ApplicationSupportTeam .

foaf:CharlieBrown a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Database Administrator."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    foaf:member org:DatabaseTeam .

# Corporate User Identifiers
noria:CUid_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith's corporate account."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount foaf:AliceSmith .

noria:CUid_BJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Unique identifier for Bob Johnson's corporate account."@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount foaf:BobJohnson .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy <https://www.dell.com/> .

noria:ProductModel_Cisco9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade stackable access switch."@en ;
    noria:productManufacturedBy <https://www.cisco.com/> .

noria:ProductModel_JuniperMX204 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Compact, high-density universal routing platform."@en ;
    noria:productManufacturedBy <https://www.juniper.net/> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com/> .

noria:ProductModel_PaloAltoFW a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy <https://www.paloaltonetworks.com/> .

noria:ProductModel_F5BigIP a noria:ProductModel ;
    rdfs:label "F5 BIG-IP iSeries i2800"@en ;
    rdfs:comment "Application delivery controller and load balancer."@en ;
    noria:productManufacturedBy <https://www.f5.com/> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

# Sites
bot:MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for core IT services."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

bot:BranchOfficeA a bot:Site ;
    rdfs:label "Branch Office A"@en ;
    rdfs:comment "Regional office with local IT infrastructure."@en ;
    noria:siteId "BOA01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Business Street" ;
    noria:sitePrincipalAddressCityName "Smallville" ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "US" .

# Rooms
noria:ServerRoom1 a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace bot:MainDataCenter .

noria:NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in Branch Office A."@en ;
    bot:hasSpace bot:BranchOfficeA .

# Loci
noria:Locus_DC01_RackA1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room 1"@en ;
    rdfs:comment "Specific rack location for servers in Server Room 1."@en ;
    bot:containsZone noria:ServerRoom1 ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_DC01_RackB2 a noria:Locus ;
    rdfs:label "Rack B2 in Server Room 1"@en ;
    rdfs:comment "Specific rack location for network devices in Server Room 1."@en ;
    bot:containsZone noria:ServerRoom1 ;
    noria:locusLine "B" ;
    noria:locusRow "2" .

noria:Locus_BOA01_RackC3 a noria:Locus ;
    rdfs:label "Rack C3 in Network Closet B"@en ;
    rdfs:comment "Rack for local network equipment in Network Closet B."@en ;
    bot:containsZone noria:NetworkClosetB ;
    noria:locusLine "C" ;
    noria:locusRow "3" .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNSServer01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network services."@en ;
    noria:resourceManagedBy org:NetworkOperationsTeam ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_DC01_RackA1 ;
    noria:resourceManagementIPAddress "192.168.10.10" .

noria:Resource_WebServer01 a noria:Resource ;
    rdfs:label "Corporate Web Server 01"@en ;
