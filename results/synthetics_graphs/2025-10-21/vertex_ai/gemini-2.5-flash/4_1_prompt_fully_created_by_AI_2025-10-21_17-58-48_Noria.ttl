# --- Services (noria:Service) ---
noria:Service_CustomerInternetAccess a noria:Service ;
    rdfs:label "Customer Internet Access Service"@en ;
    rdfs:comment "Provides internet access to customers via branch offices and the corporate network."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_WebApp ;
    seas:subSystemOf noria:Application_SecurityGateway ;
    seas:subSystemOf noria:Resource_CoreRouter1 ;
    seas:subSystemOf noria:Resource_BranchRouterX ;
    seas:subSystemOf noria:Resource_Firewall01 ;
    seas:subSystemOf noria:Resource_EdgeRouter01 .

noria:Service_InternalDatabaseAccess a noria:Service ;
    rdfs:label "Internal Database Access Service"@en ;
    rdfs:comment "Provides secure and high-performance access to internal databases for applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Application_WebApp ;
    seas:subSystemOf noria:Resource_DBServer01 ;
    seas:subSystemOf noria:Resource_AppServer01 .

noria:Service_DRReplication a noria:Service ;
    rdfs:label "Disaster Recovery Replication Service"@en ;
    rdfs:comment "Ensures continuous data replication to the disaster recovery site for business continuity."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Application_BackupSystem ;
    seas:subSystemOf noria:Resource_CoreRouter1 ;
    seas:subSystemOf <http://dr-site-router> ;
    seas:subSystemOf noria:Resource_DBServer01 .

noria:Service_LogCollection a noria:Service ;
    rdfs:label "Centralized Log Collection Service"@en ;
    rdfs:comment "Collects and stores logs from all network devices and servers for auditing and troubleshooting."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Application_LogManagement ;
    seas:subSystemOf noria:Resource_CoreRouter1 ;
    seas:subSystemOf noria:Resource_AppServer01 ;
    seas:subSystemOf noria:Resource_DBServer01 ;
    seas:subSystemOf noria:Resource_Firewall01 .

# --- Event Records (noria:EventRecord) ---
noria:EventRecord_RouterDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Core Router 1, impacting WAN connectivity."@en ;
    noria:loggingTime "2024-03-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface Ethernet0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_AppError a noria:EventRecord ;
    rdfs:label "Application Error Log"@en ;
    rdfs:comment "Error log from Corporate Web Application indicating a database connection issue due to high load."@en ;
    noria:loggingTime "2024-03-20T10:06:30Z"^^xsd:dateTime ;
    noria:logText "ERROR: Database connection failed for user 'webapp_user' - Connection timed out"@en ;
    noria:logOriginatingManagedObject noria:Application_WebApp ;
    noria:logOriginatingManagementSystem noria:Application_LogManagement ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_SecurityAlert a noria:EventRecord ;
    rdfs:label "Security Alert - Brute Force Attempt"@en ;
    rdfs:comment "Alert from security gateway detecting multiple failed login attempts on a public-facing service."@en ;
    noria:loggingTime "2024-03-20T09:55:00Z"^^xsd:dateTime ;
    noria:logText "ALERT: Brute force attempt detected on SSH port from 1.2.3.4"@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_SecurityGateway ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logOriginatingAgent <http://example.com/attacker-ip-1.2.3.4> .

<http://example.com/attacker-ip-1.2.3.4> a foaf:Agent ;
    rdfs:label "Unknown Attacker IP 1.2.3.4"@en ;
    rdfs:comment "Represents an external entity initiating a security event, identified by IP address."@en .

noria:EventRecord_InterfaceUp a noria:EventRecord ;
    rdfs:label "Router Interface Up Event"@en ;
    rdfs:comment "Log entry indicating a network interface went up on Core Router 1, clearing a previous alarm."@en ;
    noria:loggingTime "2024-03-20T10:20:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface Ethernet0/1, changed state to up"@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Cleared> .

noria:EventRecord_FirewallBlocked a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Event"@en ;
    rdfs:comment "Log entry from firewall indicating blocked malicious traffic from a known threat source."@en ;
    noria:loggingTime "2024-03-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "BLOCKED: Malicious traffic from 5.6.7.8 to 10.0.0.10 on port 8080"@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_SecurityGateway ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_DBBackupSuccess a noria:EventRecord ;
    rdfs:label "Database Backup Success"@en ;
    rdfs:comment "Log entry indicating successful daily database backup for DBServer01."@en ;
    noria:loggingTime "2024-03-20T03:00:00Z"^^xsd:dateTime ;
    noria:logText "INFO: Full database backup completed successfully for db01.dca.example.com."@en ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_BackupSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Cleared> .

noria:EventRecord_HighCPU a noria:EventRecord ;
    rdfs:label "High CPU Usage Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Application Server 01, potentially affecting performance."@en ;
    noria:loggingTime "2024-03-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "ALERT: CPU usage on appserv01 exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_BackupFailure a noria:EventRecord ;
    rdfs:label "Backup Job Failure"@en ;
    rdfs:comment "Alert indicating that the daily backup job for a critical application failed."@en ;
    noria:loggingTime "2024-03-21T04:15:00Z"^^xsd:dateTime ;
    noria:logText "ERROR: Backup job 'WebApp_Daily_Backup' failed with error code 123. Disk space full."@en ;
    noria:logOriginatingManagedObject noria:Resource_BackupServer01 ;
    noria:logOriginatingManagementSystem noria:Application_BackupSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DiskFull a noria:EventRecord ;
    rdfs:label "Disk Space Full Alert"@en ;
    rdfs:comment "Alert indicating that a disk partition on the backup server is critically full."@en ;
    noria:loggingTime "2024-03-21T04:10:00Z"^^xsd:dateTime ;
    noria:logText "ALERT: Disk /backup_vol on backupsrv01 is 98% full."@en ;
    noria:logOriginatingManagedObject noria:Resource_BackupServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_LoginSuccess a noria:EventRecord ;
    rdfs:label "Successful Admin Login"@en ;
    rdfs:comment "Audit log entry for a successful administrative login to Core Router 1."@en ;
    noria:loggingTime "2024-03-20T10:18:00Z"^^xsd:dateTime ;
    noria:logText "INFO: User 'admin' logged in successfully from 10.0.0.50 to cr01.dca.example.com."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter1 ;
    noria:logOriginatingManagementSystem noria:Application_LogManagement ;
    noria:logOriginatingAgent <http://example.com/internal-ip-10.0.0.50> ; # Another example of an agent
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Cleared> .

<http://example.com/internal-ip-10.0.0.50> a foaf:Agent ;
    rdfs:label "Internal IP 10.0.0.50"@en ;
    rdfs:comment "Represents an internal workstation or jump host."@en .

noria:EventRecord_RouterUpgradeStart a noria:EventRecord ;
    rdfs:label "Router Upgrade Started Event"@en ;
    rdfs:comment "Log entry indicating the start of the software upgrade on Core Router 1."@en ;
    noria:loggingTime "2024-03-25T02:00:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Software upgrade initiated on cr01.dca.example.com"@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_NetworkTeam ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade .

noria:EventRecord_RouterUpgradeEnd a noria:EventRecord ;
    rdfs:label "Router Upgrade Completed Event"@en ;
    rdfs:comment "Log entry indicating the completion of the software upgrade on Core Router 1."@en ;
    noria:loggingTime "2024-03-25T03:55:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Software upgrade completed on cr01.dca.example.com. System rebooted."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_NetworkTeam ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade .

# --- Trouble Tickets (noria:TroubleTicket) ---
noria:TroubleTicket_MajorOutage a noria:TroubleTicket ;
    rdfs:label "Major Service Outage"@en ;
    rdfs:comment "A major incident affecting multiple critical services, including customer internet access and internal database access."@en ;
    dcterms:created "2024-03-20T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-03-20T12:00:00Z"^^xsd:dateTime ;
    noria:documentExternalId "TT-MAJ-20240320-000" ;
    noria:documentHRef "https://ticketing.example.com/TT-MAJ-20240320-000" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/Immediate> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkTeam ;
    noria:troubleTicketRelatedParty foaf:Agent_AppSupportTeam ;
    noria:troubleTicketRelatedService noria:Service_CustomerInternetAccess ;
    noria:troubleTicketRelatedService noria:Service_InternalDatabaseAccess ;
    noria:troubleTicketImpacts noria:Service_CustomerInternetAccess ;
    noria:troubleTicketImpacts noria:Service_InternalDatabaseAccess .

noria:TroubleTicket_WANOutage a noria:TroubleTicket ;
    rdfs:label "WAN Link Outage to Branch Office X"@en ;
    rdfs:comment "Critical incident reported due to WAN link failure affecting Branch Office X, child of a major outage."@en ;
    dcterms:created "2024-03-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-03-20T10:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "TT-WAN-20240320-001" ;
    noria:documentHRef "https://ticketing.example.com/TT-WAN-20240320-001" ;
