# --- Operation Plans (noria:OperationPlan) ---
noria:OperationPlan_RouterRestart a noria:OperationPlan ;
    rdfs:label "Standard Router Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting a core network router, including pre-checks and post-verifications."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterReachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterUpAndRunning .

noria:OperationPlan_DBConnectionTroubleshoot a noria:OperationPlan ;
    rdfs:label "Database Connection Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving database connectivity issues, including checking logs and network paths."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_AppErrorLogs ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBConnectionRestored .

noria:OperationPlan_BackupTroubleshoot a noria:OperationPlan ;
    rdfs:label "Backup System Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving failures in the enterprise backup system."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_BackupLogs ;
    noria:operationPlanPostCondition noria:ActionPostCondition_BackupSuccess .

noria:OperationPlan_DiskCleanup a noria:OperationPlan ;
    rdfs:label "Server Disk Cleanup Procedure"@en ;
    rdfs:comment "Standard operating procedure for freeing up disk space on servers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DiskUsageHigh ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DiskSpaceFree .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:ActionPreCondition_RouterReachable a noria:ActionPreCondition ;
    rdfs:label "Router Reachable Pre-Condition"@en ;
    rdfs:comment "Verify router is reachable via management IP and ping before initiating restart."@en .

noria:ActionPostCondition_RouterUpAndRunning a noria:ActionPostCondition ;
    rdfs:label "Router Up and Running Post-Condition"@en ;
    rdfs:comment "Confirm router is fully operational, all critical interfaces are up, and routing protocols are converged after restart."@en .

noria:ActionPreCondition_AppErrorLogs a noria:ActionPreCondition ;
    rdfs:label "Application Error Logs Pre-Condition"@en ;
    rdfs:comment "Check application logs for specific database connection errors and timestamps."@en .

noria:ActionPostCondition_DBConnectionRestored a noria:ActionPostCondition ;
    rdfs:label "Database Connection Restored Post-Condition"@en ;
    rdfs:comment "Verify application can successfully connect to the database, and no new connection errors are reported in logs."@en .

noria:ActionPreCondition_BackupLogs a noria:ActionPreCondition ;
    rdfs:label "Backup Logs Review Pre-Condition"@en ;
    rdfs:comment "Review backup system logs for specific failure messages and error codes."@en .

noria:ActionPostCondition_BackupSuccess a noria:ActionPostCondition ;
    rdfs:label "Backup Success Post-Condition"@en ;
    rdfs:comment "Verify that the backup job completes successfully after intervention."@en .

noria:ActionPreCondition_DiskUsageHigh a noria:ActionPreCondition ;
    rdfs:label "High Disk Usage Pre-Condition"@en ;
    rdfs:comment "Confirm that disk usage on the target server is above a critical threshold."@en .

noria:ActionPostCondition_DiskSpaceFree a noria:ActionPostCondition ;
    rdfs:label "Sufficient Disk Space Post-Condition"@en ;
    rdfs:comment "Verify that sufficient disk space has been freed and is below warning thresholds."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Data Center Network Diagram"@en ;
    rdfs:comment "PDF document showing the logical and physical network topology of Data Center A."@en ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "DC-NET-DIAG-V2.3" ;
    dcterms:isPartOf noria:TroubleTicket_WANOutage ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade .

noria:DocumentAttachment_DBMigrationPlan a noria:DocumentAttachment ;
    rdfs:label "Database Migration Plan"@en ;
    rdfs:comment "Detailed plan for migrating the database to a new cluster, including rollback procedures."@en ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:identifier "DB-MIG-PLAN-V1.0" ;
    dcterms:isPartOf noria:ChangeRequest_DBMigration .

# =============================================================================
# Cross-linking and Density Enhancement
# =============================================================================

# Link Event Records to Trouble Tickets and Change Requests
noria:EventRecord_InterfaceUp noria:alarmMitigatedBy noria:TroubleTicket_WANOutage .
noria:EventRecord_FirewallBlocked noria:alarmMitigatedBy noria:TroubleTicket_SecurityIncident .
noria:EventRecord_DBBackupSuccess noria:alarmMitigatedBy noria:TroubleTicket_BackupFailure . # A successful backup after a failure might clear the ticket.

# Update TroubleTicket status history
noria:TroubleTicket_WANOutage noria:documentStatusHistory noria:EventRecord_RouterDown .
noria:TroubleTicket_WANOutage noria:documentStatusHistory noria:EventRecord_InterfaceUp .
noria:TroubleTicket_DBConnIssue noria:documentStatusHistory noria:EventRecord_AppError .
noria:TroubleTicket_DBConnIssue noria:documentStatusHistory noria:EventRecord_HighCPU .
noria:TroubleTicket_SecurityIncident noria:documentStatusHistory noria:EventRecord_SecurityAlert .
noria:TroubleTicket_SecurityIncident noria:documentStatusHistory noria:EventRecord_FirewallBlocked .
noria:TroubleTicket_BackupFailure noria:documentStatusHistory noria:EventRecord_BackupFailure .
noria:TroubleTicket_BackupFailure noria:documentStatusHistory noria:EventRecord_DiskFull .
noria:TroubleTicket_DiskSpaceAlert noria:documentStatusHistory noria:EventRecord_DiskFull .

# Update ChangeRequest status history
noria:ChangeRequest_RouterUpgrade noria:documentStatusHistory noria:EventRecord_RouterUpgradeStart .
noria:ChangeRequest_RouterUpgrade noria:documentStatusHistory noria:EventRecord_RouterUpgradeEnd .

# Connect Applications to Resources they use
noria:Application_WebApp noria:resourceForApplication noria:Resource_AppServer01, noria:Resource_DBServer01, noria:Resource_VirtualMachine01, noria:Resource_LoadBalancer01 .
noria:Application_MonitoringSystem noria:resourceForApplication noria:Resource_AppServer01, noria:Resource_DBServer01, noria:Resource_CoreRouter1, noria:Resource_Firewall01 .
noria:Application_SecurityGateway noria:resourceForApplication noria:Resource_Firewall01, noria:Resource_EdgeRouter01 .
noria:Application_BackupSystem noria:resourceForApplication noria:Resource_BackupServer01 .
noria:Application_LogManagement noria:resourceForApplication noria:Resource_BackupServer01 . # Logs might be stored on backup server or a dedicated log server.

# Connect Application Modules to Resources they use (more specific than Application)
