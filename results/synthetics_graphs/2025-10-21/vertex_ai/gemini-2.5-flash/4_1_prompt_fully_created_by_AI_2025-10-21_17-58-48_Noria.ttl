# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# SKOS Concept Schemes and Concepts (used for property ranges)
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ; rdfs:label "Application Types"@en .
<kos/application/type/infrastructure> a skos:Concept ; skos:inScheme <kos/application/type> ; rdfs:label "Infrastructure Application"@en ; rdfs:comment "An application providing foundational IT services."@en .
<kos/application/type/business> a skos:Concept ; skos:inScheme <kos/application/type> ; rdfs:label "Business Application"@en ; rdfs:comment "An application directly supporting business operations."@en .
<kos/application/type/monitoring> a skos:Concept ; skos:inScheme <kos/application/type> ; rdfs:label "Monitoring Application"@en ; rdfs:comment "An application used for observing system performance and health."@en .
<kos/application/type/database> a skos:Concept ; skos:inScheme <kos/application/type> ; rdfs:label "Database Application"@en ; rdfs:comment "An application primarily managing data storage and retrieval."@en .
<kos/application/type/security> a skos:Concept ; skos:inScheme <kos/application/type> ; rdfs:label "Security Application"@en ; rdfs:comment "An application focused on protecting IT assets and data."@en .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ; rdfs:label "Application Business Importance"@en .
<kos/application/business-importance/high> a skos:Concept ; skos:inScheme <kos/application/business-importance> ; rdfs:label "High Business Importance"@en ; rdfs:comment "Critical for business operations, significant impact if unavailable."@en .
<kos/application/business-importance/medium> a skos:Concept ; skos:inScheme <kos/application/business-importance> ; rdfs:label "Medium Business Importance"@en ; rdfs:comment "Important for business, moderate impact if unavailable."@en .
<kos/application/business-importance/low> a skos:Concept ; skos:inScheme <kos/application/business-importance> ; rdfs:label "Low Business Importance"@en ; rdfs:comment "Non-critical for immediate business operations, minor impact if unavailable."@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ; rdfs:label "Application Module Status"@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/status> ; rdfs:label "In Production"@en ; rdfs:comment "The application module is actively serving users."@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/status> ; rdfs:label "Development"@en ; rdfs:comment "The application module is under active development."@en .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/status> ; rdfs:label "Maintenance"@en ; rdfs:comment "The application module is undergoing maintenance or testing."@en .

# TroubleTicket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Severity"@en .
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; rdfs:label "Critical"@en ; rdfs:comment "Service completely unavailable or severely degraded, major business impact."@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; rdfs:label "Major"@en ; rdfs:comment "Significant service degradation or partial unavailability, moderate business impact."@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; rdfs:label "Minor"@en ; rdfs:comment "Minor service impact, workaround available, low business impact."@en .
<kos/TroubleTicket/severity/Warning> a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; rdfs:label "Warning"@en ; rdfs:comment "Potential issue detected, no immediate service impact, proactive action required."@en .

# TroubleTicket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Type"@en .
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; rdfs:label "Failure"@en ; rdfs:comment "Indicates a system or service failure."@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; rdfs:label "Assistance"@en ; rdfs:comment "Request for help or support."@en .
<kos/TroubleTicket/type/Maintenance> a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; rdfs:label "Maintenance"@en ; rdfs:comment "Related to scheduled or unscheduled maintenance activities."@en .

# TroubleTicket Criticity / Category
<kos/TroubleTicket/category> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Category"@en .
<kos/TroubleTicket/category/InterruptedService> a skos:Concept ; skos:inScheme <kos/TroubleTicket/category> ; rdfs:label "Interrupted Service"@en ; rdfs:comment "Service is completely down or inaccessible."@en .
<kos/TroubleTicket/category/CorruptedService> a skos:Concept ; skos:inScheme <kos/TroubleTicket/category> ; rdfs:label "Corrupted Service"@en ; rdfs:comment "Service is available but data or functionality is compromised."@en .
<kos/TroubleTicket/category/PerformanceDegradation> a skos:Concept ; skos:inScheme <kos/TroubleTicket/category> ; rdfs:label "Performance Degradation"@en ; rdfs:comment "Service is slow or performing below expected levels."@en .

# TroubleTicket Priority
<kos/TroubleTicket/priority> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Priority"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:inScheme <kos/TroubleTicket/priority> ; rdfs:label "Priority 1"@en ; rdfs:comment "Highest priority, immediate action required."@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:inScheme <kos/TroubleTicket/priority> ; rdfs:label "Priority 2"@en ; rdfs:comment "High priority, urgent action required."@en .
<kos/TroubleTicket/priority/P3> a skos:Concept ; skos:inScheme <kos/TroubleTicket/priority> ; rdfs:label "Priority 3"@en ; rdfs:comment "Medium priority, action required within defined timeframe."@en .
<kos/TroubleTicket/priority/P4> a skos:Concept ; skos:inScheme <kos/TroubleTicket/priority> ; rdfs:label "Priority 4"@en ; rdfs:comment "Low priority, routine action."@en .

# TroubleTicket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Origin"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:inScheme <kos/TroubleTicket/origin> ; rdfs:label "Customer"@en ; rdfs:comment "Ticket initiated by an external customer."@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:inScheme <kos/TroubleTicket/origin> ; rdfs:label "Supervision System"@en ; rdfs:comment "Ticket automatically generated by a monitoring system."@en .
<kos/TroubleTicket/origin/Internal> a skos:Concept ; skos:inScheme <kos/TroubleTicket/origin> ; rdfs:label "Internal User"@en ; rdfs:comment "Ticket initiated by an internal employee."@en .

# TroubleTicket Urgency
<kos/TroubleTicket/urgency> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Urgency"@en .
<kos/TroubleTicket/urgency/Immediate> a skos:Concept ; skos:inScheme <kos/TroubleTicket/urgency> ; rdfs:label "Immediate Intervention"@en ; rdfs:comment "Requires immediate attention and action."@en .
<kos/TroubleTicket/urgency/Deferred> a skos:Concept ; skos:inScheme <kos/TroubleTicket/urgency> ; rdfs:label "Deferred Intervention"@en ; rdfs:comment "Can be addressed at a later scheduled time."@en .

# TroubleTicket Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ; rdfs:label "Problem Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ; skos:inScheme <kos/TroubleTicket/problemResponsibility> ; rdfs:label "Network Team"@en ; rdfs:comment "Responsibility lies with the network operations team."@en .
<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ; skos:inScheme <kos/TroubleTicket/problemResponsibility> ; rdfs:label "Application Team"@en ; rdfs:comment "Responsibility lies with the application support team."@en .
<kos/TroubleTicket/problemResponsibility/Vendor> a skos:Concept ; skos:inScheme <kos/TroubleTicket/problemResponsibility> ; rdfs:label "Vendor"@en ; rdfs:comment "Responsibility lies with an external vendor or supplier."@en .

# TroubleTicket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Status"@en .
<kos/TroubleTicket/status/Initialised> a skos:Concept ; skos:inScheme <kos/TroubleTicket/status> ; rdfs:label "Initialised"@en ; rdfs:comment "Ticket has been created."@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:inScheme <kos/TroubleTicket/status> ; rdfs:label "In Progress"@en ; rdfs:comment "Work is actively being done on the ticket."@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:inScheme <kos/TroubleTicket/status> ; rdfs:label "Resolved"@en ; rdfs:comment "The issue has been fixed."@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; skos:inScheme <kos/TroubleTicket/status> ; rdfs:label "Closed"@en ; rdfs:comment "The ticket has been closed after verification."@en .

# TroubleTicket Note Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Note Comment Type"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:inScheme <kos/TroubleTicket/commentType> ; rdfs:label "Internal Comment"@en ; rdfs:comment "Comment visible only to internal teams."@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:inScheme <kos/TroubleTicket/commentType> ; rdfs:label "Customer Visible Comment"@en ; rdfs:comment "Comment visible to the customer."@en .

# TroubleTicket Note Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Note Operation Type"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:inScheme <kos/TroubleTicket/operationType> ; rdfs:label "Diagnosis Operation"@en ; rdfs:comment "Note related to diagnostic steps."@en .
<kos/TroubleTicket/operationType/Intervention> a skos:Concept ; skos:inScheme <kos/TroubleTicket/operationType> ; rdfs:label "Intervention Operation"@en ; rdfs:comment "Note related to actions taken to resolve the issue."@en .

# ChangeRequest Category
<kos/ChangeRequest/category> a skos:ConceptScheme ; rdfs:label "Change Request Category"@en .
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; skos:inScheme <kos/ChangeRequest/category> ; rdfs:label "Internal Intervention"@en ; rdfs:comment "Change performed by internal teams."@en .
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; skos:inScheme <kos/ChangeRequest/category> ; rdfs:label "Software Upgrade"@en ; rdfs:comment "Change involving software version updates."@en .
<kos/ChangeRequest/category/HardwareReplacement> a skos:Concept ; skos:inScheme <kos/ChangeRequest/category> ; rdfs:label "Hardware Replacement"@en ; rdfs:comment "Change involving replacement of physical hardware."@en .

# ChangeRequest Type
<kos/ChangeRequest/type> a skos:ConceptScheme ; rdfs:label "Change Request Type"@en .
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:inScheme <kos/ChangeRequest/type> ; rdfs:label "Standard Change"@en ; rdfs:comment "Pre-approved, low-risk change."@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:inScheme <kos/ChangeRequest/type> ; rdfs:label "Emergency Change"@en ; rdfs:comment "Urgent change required to restore service or prevent major impact."@en .
<kos/ChangeRequest/type/Normal> a skos:Concept ; skos:inScheme <kos/ChangeRequest/type> ; rdfs:label "Normal Change"@en ; rdfs:comment "Requires assessment and authorization, but not urgent."@en .

# ChangeRequest Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ; rdfs:label "Change Request Cause"@en .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; skos:inScheme <kos/ChangeRequest/cause> ; rdfs:label "Configuration Change"@en ; rdfs:comment "Change due to modification of system configuration."@en .
<kos/ChangeRequest/cause/NetworkExtension> a skos:Concept ; skos:inScheme <kos/ChangeRequest/cause> ; rdfs:label "Network Extension"@en ; rdfs:comment "Change due to expansion of network infrastructure."@en .
<kos/ChangeRequest/cause/SecurityPatch> a skos:Concept ; skos:inScheme <kos/ChangeRequest/cause> ; rdfs:label "Security Patch"@en ; rdfs:comment "Change to apply security updates."@en .

# ChangeRequest Status
<kos/ChangeRequest/status> a skos:ConceptScheme ; rdfs:label "Change Request Status"@en .
<kos/ChangeRequest/status/Planned> a skos:Concept ; skos:inScheme <kos/ChangeRequest/status> ; rdfs:label "Planned"@en ; rdfs:comment "Change is scheduled for future execution."@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; skos:inScheme <kos/ChangeRequest/status> ; rdfs:label "Implemented"@en ; rdfs:comment "Change has been successfully executed."@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:inScheme <kos/ChangeRequest/status> ; rdfs:label "Approved"@en ; rdfs:comment "Change has been approved for execution."@en .
<kos/ChangeRequest/status/Failed> a skos:Concept ; skos:inScheme <kos/ChangeRequest/status> ; rdfs:label "Failed"@en ; rdfs:comment "Change execution failed."@en .

# ChangeRequest Specification
<kos/ChangeRequest/specification> a skos:ConceptScheme ; rdfs:label "Change Request Specification"@en .
<kos/ChangeRequest/specification/StandardProcedureA> a skos:Concept ; skos:inScheme <kos/ChangeRequest/specification> ; rdfs:label "Standard Procedure A"@en ; rdfs:comment "Refers to a documented standard operating procedure A."@en .
<kos/ChangeRequest/specification/StandardProcedureB> a skos:Concept ; skos:inScheme <kos/ChangeRequest/specification> ; rdfs:label "Standard Procedure B"@en ; rdfs:comment "Refers to a documented standard operating procedure B."@en .

# Resource Type
<kos/Resource/type> a skos:ConceptScheme ; rdfs:label "Resource Type"@en .
<kos/Resource/type/Server> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Server"@en ; rdfs:comment "A computer program or a device that provides functionality for other programs or devices."@en .
<kos/Resource/type/Router> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Router"@en ; rdfs:comment "A networking device that forwards data packets between computer networks."@en .
<kos/Resource/type/Switch> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Switch"@en ; rdfs:comment "A networking device that connects devices on a computer network by using packet switching to receive, process, and forward data to the destination device."@en .
<kos/Resource/type/Firewall> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Firewall"@en ; rdfs:comment "A network security system that monitors and controls incoming and outgoing network traffic."@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Virtual Machine"@en ; rdfs:comment "An emulation of a computer system."@en .
<kos/Resource/type/LoadBalancer> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Load Balancer"@en ; rdfs:comment "A device that distributes network traffic across multiple servers."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ; rdfs:label "Resource Lifecycle State"@en .
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; rdfs:label "In Production"@en ; rdfs:comment "The resource is actively used in the production environment."@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; rdfs:label "Decommissioned"@en ; rdfs:comment "The resource has been removed from service."@en .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; rdfs:label "Staging"@en ; rdfs:comment "The resource is in a pre-production testing environment."@en .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ; rdfs:label "Resource Operational State"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; rdfs:label "Up"@en ; rdfs:comment "The resource is currently operational."@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; rdfs:label "Down"@en ; rdfs:comment "The resource is currently not operational."@en .
<kos/Resource/OperationalState/Degraded> a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; rdfs:label "Degraded"@en ; rdfs:comment "The resource is operational but with reduced performance or functionality."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ; rdfs:label "Resource Administrative State"@en .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; skos:inScheme <kos/Resource/AdministrativeState> ; rdfs:label "Up"@en ; rdfs:comment "The resource is administratively enabled."@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; skos:inScheme <kos/Resource/AdministrativeState> ; rdfs:label "Down"@en ; rdfs:comment "The resource is administratively disabled."@en .

# Service Type
<kos/service/type> a skos:ConceptScheme ; rdfs:label "Service Type"@en .
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:inScheme <kos/service/type> ; rdfs:label "Customer Facing Service"@en ; rdfs:comment "A service directly consumed by customers."@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:inScheme <kos/service/type> ; rdfs:label "Resource Facing Service"@en ; rdfs:comment "A service that supports other services or internal operations."@en .

# Notification Severity / Perceived Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ; rdfs:label "Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Critical"@en ; rdfs:comment "Highest severity, immediate and severe impact."@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Major"@en ; rdfs:comment "Significant severity, considerable impact."@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Minor"@en ; rdfs:comment "Low severity, limited impact."@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Warning"@en ; rdfs:comment "Potential issue, no immediate impact but requires attention."@en .
<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Indeterminate"@en ; rdfs:comment "Severity cannot be determined."@en .
<Notification/Severity/PerceivedSeverity/Cleared> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Cleared"@en ; rdfs:comment "Previous alarm condition has been resolved."@en .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ; rdfs:label "Agent Contact Method"@en .
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:inScheme <kos/org/agent-contact-method> ; rdfs:label "Email"@en ; rdfs:comment "Preferred contact via email."@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:inScheme <kos/org/agent-contact-method> ; rdfs:label "Phone"@en ; rdfs:comment "Preferred contact via phone call."@en .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; skos:inScheme <kos/org/agent-contact-method> ; rdfs:label "Ticketing System"@en ; rdfs:comment "Preferred contact via the ticketing system."@en .

# SLA Level
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA Level"@en ; rdfs:comment "Highest Service Level Agreement tier."@en .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; rdfs:label "Silver SLA Level"@en ; rdfs:comment "Mid-tier Service Level Agreement."@en .
<https://w3id.org/noria/kos/application/sla-level/Bronze> a skos:Concept ; rdfs:label "Bronze SLA Level"@en ; rdfs:comment "Basic Service Level Agreement tier."@en .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
foaf:Agent_NetworkTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Call emergency line for critical issues. Use ticketing system for standard requests."@en .

foaf:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the internal portal for all issues."@en .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email security-alert@example.com for urgent security matters. Use ticketing system for non-critical reports."@en .

foaf:Agent_DBA_JohnDoe a foaf:Agent ;
    rdfs:label "Database Administrator John Doe"@en ;
    rdfs:comment "Individual responsible for database management and optimization."@en ;
    noria:agentWorkingHours "8:00-16:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for database-related queries."@en .

foaf:Agent_CustomerService a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Service Department"@en ;
    rdfs:comment "First line support for customer inquiries and issues."@en ;
    noria:agentWorkingHours "8:00-20:00 Mon-Sun"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Direct customer calls to this department."@en .

foaf:Agent_SysAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "System Administration Team"@en ;
    rdfs:comment "Team managing operating systems and server hardware."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Open a ticket for server provisioning or maintenance requests."@en .

foaf:Agent_DevOpsEngineer_Alice a foaf:Agent ;
    rdfs:label "DevOps Engineer Alice Smith"@en ;
    rdfs:comment "Individual responsible for CI/CD pipelines and infrastructure automation."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_ExternalVendor a foaf:Agent, org:Organization ;
    rdfs:label "External Network Provider"@en ;
    rdfs:comment "Third-party vendor providing WAN connectivity services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use dedicated hotline for service outages."@en .

# --- Corporate User Identifiers ---
