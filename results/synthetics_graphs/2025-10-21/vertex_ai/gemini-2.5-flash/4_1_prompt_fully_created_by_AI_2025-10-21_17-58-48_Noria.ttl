# --- Network Links (noria:NetworkLink) ---
noria:NetworkLink_DC_Internal_CR1_AppSrv1 a noria:NetworkLink ;
    rdfs:label "Data Center Internal Link (CR1-AppSrv1)"@en ;
    rdfs:comment "High-speed link within Data Center A, connecting core router to application server 01."@en ;
    noria:networkLinkId "NL-DCI-001" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_AppServer01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR1_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_AppSrv1_Eth0 .

