    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Failed> .

# Adding a trouble ticket for the failed migration
noria:TroubleTicket_MigrationFailure a noria:TroubleTicket ;
    rdfs:label "Web Portal Migration Failure Incident"@en ;
    rdfs:comment "Incident caused by the failure of the planned web portal server migration."@en ;
    dcterms:identifier "TT-20240420-005" ;
    dcterms:created "2024-04-20T01:40:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Internal> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_AppSupportL2, foaf:Agent_NetworkOpsTeam ;
    noria:troubleTicketRelatedService noria:Application_WebPortal ;
    noria:troubleTicketRelatedResource noria:Resource_WebSrv01, noria:Resource_VMHost01 ;
    noria:troubleTicketTrigger noria:EventRecord_AppMigrationFailure ;
    noria:documentHRef <http://itsm.example.com/ticket/TT-20240420-005> .

noria:TroubleTicket_MigrationFailure noria:troubleTicketCause "Network configuration mismatch during VM migration."@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ConfigurationError> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> .

# Adding a trouble ticket note for the migration failure
noria:TroubleTicketNote_MigrationRollback a noria:TroubleTicketNote ;
    rdfs:label "Migration Rollback Note"@en ;
    rdfs:comment "Details of the rollback procedure after migration failure."@en ;
    dcterms:created "2024-04-20T02:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_AppSupportL2 ;
    dcterms:description "Initiated rollback to previous configuration. Web portal service restored on original physical server. Root cause analysis to follow."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/CorrectiveAction> ;
    dcterms:isPartOf noria:TroubleTicket_MigrationFailure .

# Adding a document attachment for the migration plan
noria:DocumentAttachment_MigrationPlan a noria:DocumentAttachment ;
    rdfs:label "Web Portal Migration Plan"@en ;
    rdfs:comment "Detailed plan for migrating the corporate web portal."@en ;
    dcterms:identifier "MigrationPlan_CorpWeb_v1.0.docx" ;
    dcterms:created "2024-03-28T10:00:00Z"^^xsd:dateTime ;
    dcterms:description "Document outlining all steps, dependencies, and rollback procedures for the migration."@en ;
    dcterms:isPartOf noria:ChangeRequest_AppMigration .

