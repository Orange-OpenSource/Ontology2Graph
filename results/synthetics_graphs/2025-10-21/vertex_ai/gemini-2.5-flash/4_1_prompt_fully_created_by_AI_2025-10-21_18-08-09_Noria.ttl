    dcterms:created "2024-04-10T09:01:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Unidentified software crash on DNS01."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-10T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-10T09:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-10T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_DNSAdminTeam, foaf:Agent_JohnDoe ;
    noria:troubleTicketRelatedService noria:Application_CorpDNS ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:Application_CorpDNS, noria:Resource_DNS01 ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:documentHRef <http://itsm.example.com/ticket/TT-20240410-001> .

noria:TroubleTicket_WebPortalSlow a noria:TroubleTicket ;
    rdfs:label "Web Portal Slow Performance"@en, "Performance Lente Portail Web"@fr ;
    rdfs:comment "Users reporting slow loading times for the corporate web portal."@en ;
    dcterms:identifier "TT-20240410-002" ;
    dcterms:created "2024-04-10T10:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "APM Tool" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/PerformanceDegradation> ;
    noria:troubleTicketCause "High CPU on web server, possibly due to increased traffic."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-10T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedParty foaf:Agent_AppSupportL2 ;
    noria:troubleTicketRelatedService noria:Application_WebPortal ;
    noria:troubleTicketRelatedResource noria:Resource_WebSrv01 ;
    noria:troubleTicketImpacts noria:Application_WebPortal, noria:Resource_WebSrv01 ;
