# Adding a change request for a new application deployment
noria:ChangeRequest_NewAppDeployment a noria:ChangeRequest ;
    rdfs:label "New Application Deployment: Project Alpha"@en ;
    rdfs:comment "Deployment of a new internal application, Project Alpha, including new servers and network configuration."@en ;
    dcterms:identifier "CR-20240501-004" ;
    dcterms:created "2024-04-15T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T17:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ;
    noria:changeRequestImpact noria:Resource_VMHost01, noria:Resource_CoreRouter1, noria:Application_MonitoringSystem ; # Impacting existing infrastructure
    noria:changeRequestOutageDuration "PT0H"^^xsd:duration ; # No expected outage for existing services
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent_AppSupportL2 ;
    noria:changeRequestPilotParty foaf:Agent_NetworkOpsTeam ;
    noria:documentHRef <http://itsm.example.com/change/CR-20240501-004> .

