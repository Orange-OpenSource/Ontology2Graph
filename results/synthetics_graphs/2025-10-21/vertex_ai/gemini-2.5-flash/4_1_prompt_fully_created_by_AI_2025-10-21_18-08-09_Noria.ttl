    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ; # Assuming RackA1 is a logical representation that can span sites for DR purposes, or I need another Locus. Let's create one for DR.
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> ;
    noria:resourceForApplication noria:Application_CorpDNS .

noria:Locus_DRRack1 a noria:Locus ;
