# Adding more agents and linking them
foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Team"@en, "Équipe Opérations Sécurité"@fr ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "Respond to SIEM alerts immediately. Coordinate with Network Ops for network-related security incidents."@en ;
    noria:agentManagesResource noria:Resource_Firewall01 .

org:OrganizationalUnit_SecurityOps a org:OrganizationalUnit ;
    rdfs:label "Security Operations Unit"@en ;
    rdfs:comment "Organizational unit for security operations."@en ;
    org:member foaf:Agent_SecurityTeam .

noria:ApplicationModule_MonitoringSystem_Prod noria:applicationModuleSupportGroup org:OrganizationalUnit_SecurityOps . # Security team uses monitoring system

