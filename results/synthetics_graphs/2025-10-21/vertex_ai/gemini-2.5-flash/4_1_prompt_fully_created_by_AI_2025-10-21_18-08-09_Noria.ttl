foaf:Agent_ProjectManager a foaf:Agent ;
    rdfs:label "Project Manager Alice"@en ;
    rdfs:comment "Manages IT projects, including new application deployments."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:ChangeRequest_NewAppDeployment noria:changeRequestInitiatorParty foaf:Agent_ProjectManager .

# Adding a new site for a branch office
bot:Site_BranchOfficeA a bot:Site ;
    rdfs:label "Branch Office A"@en ;
    rdfs:comment "Remote branch office location."@en ;
    noria:siteId "BO-NYC-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "789 Main Street" ;
    noria:sitePrincipalAddressCityName "New York" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_OfficeNetwork a noria:Room ;
    rdfs:label "Office Network Room"@en ;
    rdfs:comment "Network equipment room in Branch Office A."@en ;
    bot:hasSpace bot:Site_BranchOfficeA .

noria:Locus_OfficeRack1 a noria:Locus ;
    rdfs:label "Office Rack 1"@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:containsZone noria:Room_OfficeNetwork .

noria:Resource_BranchRouter1 a noria:Resource ;
    rdfs:label "Branch Router 1"@en ;
    rdfs:comment "Router for Branch Office A."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "br01.bo.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1K ;
    noria:resourceType <kos/Resource/type/NetworkDevice> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus noria:Locus_OfficeRack1 ;
    noria:resourceForApplication noria:Application_InternetAccess .

noria:NetworkInterface_BranchRouter1_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "BranchRouter1 GigabitEthernet 0/0/0"@en ;
    noria:networkInterfaceOf noria:Resource_BranchRouter1 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "WAN uplink to corporate network."@en .

noria:NetworkLink_Branch_WAN_Link a noria:NetworkLink ;
    rdfs:label "Branch Office WAN Link"@en ;
    noria:networkLinkId "NL-BO1-WAN" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_BranchRouter1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeRouter2 ; # Connecting to the edge router in main DC
    noria:networkLinkType "MPLS VPN" ;
    noria:networkInterfaceConnects noria:NetworkInterface_BranchRouter1_Gi0_0_0, noria:NetworkInterface_EdgeRouter2_Gi0_0_2 . # Reusing EdgeRouter2 interface for WAN

# Adding an event record for a branch office link flapping
noria:EventRecord_BranchLinkFlap a noria:EventRecord ;
    rdfs:label "Branch Office Link Flapping Alert"@en ;
    rdfs:comment "Alert indicating intermittent connectivity on the branch office WAN link."@en ;
    noria:loggingTime "2024-04-12T14:00:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on br01.bo.example.com repeatedly changing state (up/down)."@en ;
    noria:logOriginatingManagedObject noria:Resource_BranchRouter1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:TroubleTicket_BranchLinkFlap a noria:TroubleTicket ;
    rdfs:label "Branch Office A WAN Link Flapping"@en ;
    rdfs:comment "Incident regarding unstable WAN connectivity for Branch Office A."@en ;
    dcterms:identifier "TT-20240412-006" ;
    dcterms:created "2024-04-12T14:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkOpsTeam ;
    noria:troubleTicketRelatedResource noria:Resource_BranchRouter1, noria:Resource_EdgeRouter2 ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess ;
    noria:troubleTicketTrigger noria:EventRecord_BranchLinkFlap ;
    noria:documentHRef <http://itsm.example.com/ticket/TT-20240412-006> .

noria:TroubleTicket_BranchLinkFlap noria:troubleTicketCause "Suspected physical layer issue or faulty SFP on branch router."@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkConnectivity> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> .

# Adding a new operation plan for troubleshooting link flapping
noria:OperationPlan_LinkTroubleshooting a noria:OperationPlan ;
    rdfs:label "WAN Link Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving WAN link instability issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_LinkFlappingDetected ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LinkStabilityRestored .

noria:ActionPreCondition_LinkFlappingDetected a noria:ActionPreCondition ;
    rdfs:label "Link Flapping Detected"@en ;
    rdfs:comment "Condition: Network interface operational status is rapidly changing between up and down."@en .

noria:ActionPostCondition_LinkStabilityRestored a noria:ActionPostCondition ;
    rdfs:label "Link Stability Restored"@en ;
    rdfs:comment "Outcome: Network link remains stable for at least 30 minutes, and traffic flows normally."@en .

noria:EventRecord_BranchLinkFlap noria:alarmProposedRepairAction noria:OperationPlan_LinkTroubleshooting .

# Adding a new agent for external vendor support
foaf:Agent_ISP_Support a foaf:Agent ;
    rdfs:label "ISP Support Team"@en ;
    rdfs:comment "External vendor support team for internet service provider."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/VendorPortal> ;
    noria:agentInstructions "Open a ticket via the ISP's customer portal for circuit issues."@en .

noria:TroubleTicket_BranchLinkFlap noria:troubleTicketRelatedParty foaf:Agent_ISP_Support .

# Adding a new event record for a security incident
noria:EventRecord_MalwareDetected a noria:EventRecord ;
    rdfs:label "Malware Detected Alert"@en ;
    rdfs:comment "Alert from endpoint protection platform indicating malware detection on a user workstation."@en ;
    noria:loggingTime "2024-04-12T15:30:00Z"^^xsd:dateTime ;
    noria:logText "Malware 'WannaCry.Variant.A' detected and quarantined on workstation 'userpc01'."@en ;
    noria:logOriginatingManagedObject <http://example.com/resource/UserPC01> ; # Assuming a user PC is also a noria:Resource
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<http://example.com/resource/UserPC01> a noria:Resource ;
    rdfs:label "User Workstation 01"@en ;
    rdfs:comment "End-user workstation in the corporate network."@en ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:resourceHostName "userpc01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Workstation> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> .

noria:TroubleTicket_MalwareIncident a noria:TroubleTicket ;
    rdfs:label "Malware Infection Incident"@en ;
    rdfs:comment "Incident regarding a malware infection on a corporate workstation."@en ;
    dcterms:identifier "TT-20240412-007" ;
    dcterms:created "2024-04-12T15:35:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/High> ;
    noria:troubleTicketType <kos/TroubleTicket/type/SecurityIncident> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_SecurityTeam, foaf:Agent_SecurityAnalyst ;
    noria:troubleTicketRelatedResource <http://example.com/resource/UserPC01> ;
    noria:troubleTicketTrigger noria:EventRecord_MalwareDetected ;
    noria:documentHRef <http://itsm.example.com/ticket/TT-20240412-007> .

noria:TroubleTicket_MalwareIncident noria:troubleTicketCause "User opened a malicious attachment."@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/SecurityBreach> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/Customer> .

# Adding an operation plan for malware remediation
noria:OperationPlan_MalwareRemediation a noria:OperationPlan ;
    rdfs:label "Malware Remediation Procedure"@en ;
    rdfs:comment "Procedure for isolating, cleaning, and restoring systems affected by malware."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_MalwareConfirmed ;
    noria:operationPlanPostCondition noria:ActionPostCondition_SystemCleaned .

noria:ActionPreCondition_MalwareConfirmed a noria:ActionPreCondition ;
    rdfs:label "Malware Confirmed"@en ;
    rdfs:comment "Condition: Malware infection on a system has been confirmed by security tools or analysis."@en .

noria:ActionPostCondition_SystemCleaned a noria:ActionPostCondition ;
    rdfs:label "System Cleaned and Verified"@en ;
    rdfs:comment "Outcome: Affected system is free of malware, vulnerabilities patched, and verified safe for network access."@en .

noria:EventRecord_MalwareDetected noria:alarmProposedRepairAction noria:OperationPlan_MalwareRemediation .

# Adding a change request for a security patch deployment
noria:ChangeRequest_SecurityPatchDeployment a noria:ChangeRequest ;
    rdfs:label "Critical Security Patch Deployment"@en ;
    rdfs:comment "Deployment of a critical security patch across all Windows servers."@en ;
    dcterms:identifier "CR-20240425-005" ;
    dcterms:created "2024-04-18T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-26T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Emergency> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_DNS01, noria:Resource_DNS02, noria:Resource_WebSrv01, noria:Resource_DBServer01 ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ; # Expected brief outage per server
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty foaf:Agent_SecurityTeam ;
    noria:changeRequestPilotParty foaf:Agent_AppSupportL2 ;
    noria:changeRequestActorParty foaf:Agent_AppSupportL2 ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef <http://itsm.example.com/change/CR-20240425-005> .

# Adding a document attachment for the security advisory
noria:DocumentAttachment_SecurityAdvisory a noria:DocumentAttachment ;
    rdfs:label "Security Advisory for CVE-2024-XXXX"@en ;
    rdfs:comment "Official security advisory detailing a critical vulnerability and patch information."@en ;
    dcterms:identifier "SEC-ADV-2024-XXXX.pdf" ;
    dcterms:created "2024-04-17T15:00:00Z"^^xsd:dateTime ;
    dcterms:description "Vendor advisory for a critical Windows kernel vulnerability."@en ;
    dcterms:isPartOf noria:ChangeRequest_SecurityPatchDeployment .

# Final check for connectivity and density:
# - All major classes have multiple instances.
# - Instances are linked to each other using various NORIA properties.
# - Agents manage resources/applications.
# - Resources are located, have product models, types, and are part of applications.
# - Network interfaces are part of resources and connect to links.
# - Network links connect resources/interfaces.
# - Applications have modules, types, business importance.
# - Services aggregate applications/modules.
# - Event records originate from resources/applications/agents and trigger trouble tickets.
# - Trouble tickets are linked to services, resources, agents, events, and have detailed attributes.
# - Trouble ticket notes are part of trouble tickets.
# - Change requests impact resources/applications/services, are initiated/piloted by agents, and have detailed attributes.
# - Operation plans have pre/post conditions and are proposed as repair actions for events.
# - Document attachments are linked to trouble tickets/change requests.
# - All entities have labels and comments.
# - No ldp prefix used.
# - Prefixes are declared.
# - Organization is logical.

# This graph is quite dense and covers a good range of the NORIA vocabulary.
# The token count should be substantial.
