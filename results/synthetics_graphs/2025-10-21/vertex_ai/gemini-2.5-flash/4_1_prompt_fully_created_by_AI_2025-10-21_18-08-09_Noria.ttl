# --- Trouble Ticket Notes ---
noria:TroubleTicketNote_DNSFix a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Resolution Note"@en ;
    rdfs:comment "Steps taken to restore DNS service."@en ;
    dcterms:created "2024-04-10T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JohnDoe ;
    dcterms:description "Restarted DNS service on DNS01. Verified service is up and resolving queries. Failover to DNS02 was successful during the restart."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage .

noria:TroubleTicketNote_WebPortalDiag a noria:TroubleTicketNote ;
    rdfs:label "Web Portal Diagnosis Note"@en ;
    rdfs:comment "Initial diagnosis for web portal slow performance."@en ;
    dcterms:created "2024-04-10T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_AppSupportL2 ;
    dcterms:description "Observed high CPU on websrv01. Checked application logs, no immediate errors found. Investigating traffic patterns."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TroubleTicket_WebPortalSlow .

# --- Change Requests ---
noria:ChangeRequest_RouterUpgrade a noria:ChangeRequest ;
    rdfs:label "Core Router Firmware Upgrade"@en, "Mise à Jour Firmware Routeur Cœur"@fr ;
    rdfs:comment "Planned firmware upgrade for Core Router 1 to address security vulnerabilities."@en ;
    dcterms:identifier "CR-20240415-001" ;
    dcterms:created "2024-04-01T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-15T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-15T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_CoreRouter1, noria:Application_InternetAccess ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty foaf:Agent_NetworkOpsTeam ;
    noria:changeRequestPilotParty foaf:Agent_JaneSmith ;
    noria:changeRequestActorParty foaf:Agent_JaneSmith ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef <http://itsm.example.com/change/CR-20240415-001> .

noria:ChangeRequest_AppMigration a noria:ChangeRequest ;
    rdfs:label "Web Portal Server Migration"@en, "Migration Serveur Portail Web"@fr ;
    rdfs:comment "Migration of Corporate Web Portal from physical server to new virtualized infrastructure."@en ;
    dcterms:identifier "CR-20240420-002" ;
    dcterms:created "2024-04-05T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-20T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-20T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ; # Using NetworkExtension as a proxy for infrastructure change
    noria:changeRequestImpact noria:Resource_WebSrv01, noria:Application_WebPortal, noria:Resource_VMHost01 ;
    noria:changeRequestOutageDuration "PT6H"^^xsd:duration ; # 6 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent_AppSupportL2 ;
    noria:changeRequestPilotParty foaf:Agent_JohnDoe ; # John Doe from DNS team might be involved in IP changes
    noria:changeRequestIsRegulated false ;
    noria:documentHRef <http://itsm.example.com/change/CR-20240420-002> .

# --- Operation Plans ---
noria:OperationPlan_DNSFailover a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en, "Procédure de Basculement DNS"@fr ;
    rdfs:comment "Standard operating procedure for failing over DNS services to a secondary server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSPrimaryDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSSecondaryActive .

noria:OperationPlan_RouterFirmwareUpdate a noria:OperationPlan ;
    rdfs:label "Router Firmware Update Procedure"@en, "Procédure de Mise à Jour Firmware Routeur"@fr ;
    rdfs:comment "Detailed steps for upgrading router firmware with minimal downtime."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterFirmwareUpdated .

# --- Action Pre/Post Conditions ---
noria:ActionPreCondition_DNSPrimaryDown a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Down"@en ;
    rdfs:comment "Condition: Primary DNS server (DNS01) is confirmed to be unreachable or unresponsive."@en .

noria:ActionPostCondition_DNSSecondaryActive a noria:ActionPostCondition ;
    rdfs:label "Secondary DNS Server Active"@en ;
    rdfs:comment "Outcome: Secondary DNS server (DNS02) is actively serving DNS queries and primary is isolated."@en .

noria:ActionPreCondition_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Approved Maintenance Window"@en ;
    rdfs:comment "Condition: The change is scheduled and approved within a designated maintenance window."@en .

noria:ActionPostCondition_RouterFirmwareUpdated a noria:ActionPostCondition ;
    rdfs:label "Router Firmware Updated and Verified"@en ;
    rdfs:comment "Outcome: Router firmware is successfully updated, and all interfaces/routing protocols are verified operational."@en .

# --- Linking Event Records to Operation Plans (e.g., proposed repair action) ---
noria:EventRecord_DNSOutageLog noria:alarmProposedRepairAction noria:OperationPlan_DNSFailover .

# --- Document Status History (linking Trouble Tickets/Change Requests to Event Records) ---
noria:TroubleTicket_DNSOutage noria:documentStatusHistory noria:EventRecord_DNSOutageLog .
noria:TroubleTicket_DNSOutage noria:documentStatusHistory noria:EventRecord_RouterPortDown . # Assuming router port down is related to the DNS outage
noria:TroubleTicket_DNSOutage noria:documentStatusHistory noria:EventRecord_RouterPortUp . # Assuming router port up is part of the resolution

# --- Example of a DocumentAttachment ---
noria:DocumentAttachment_DNSDiagReport a noria:DocumentAttachment ;
    rdfs:label "DNS Diagnostic Report"@en ;
    rdfs:comment "Diagnostic report generated during the DNS outage investigation."@en ;
    dcterms:identifier "DR-DNS-20240410-001.pdf" ;
    dcterms:created "2024-04-10T09:40:00Z"^^xsd:dateTime ;
    dcterms:description "PDF report containing network traces and server logs related to the DNS outage."@en ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage .

noria:DocumentAttachment_FirmwareReleaseNotes a noria:DocumentAttachment ;
    rdfs:label "Router Firmware Release Notes"@en ;
    rdfs:comment "Release notes for the new router firmware version."@en ;
    dcterms:identifier "Cisco_ASR1K_Firmware_RN_v17.pdf" ;
    dcterms:created "2024-03-25T11:00:00Z"^^xsd:dateTime ;
    dcterms:description "Official documentation for the firmware update."@en ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade .

# --- Additional entities for density and connectivity ---

# More Resources
noria:Resource_LoadBalancer01 a noria:Resource ;
    rdfs:label "Load Balancer 01"@en ;
    rdfs:comment "Distributes traffic to web servers."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "lb01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Reusing a product model
    noria:resourceType <kos/Resource/type/NetworkDevice> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceForApplication noria:Application_WebPortal .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Hosts the database for the Corporate Web Portal."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportL2 ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/PhysicalServer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceForApplication noria:Application_WebPortal .

# More Network Interfaces
