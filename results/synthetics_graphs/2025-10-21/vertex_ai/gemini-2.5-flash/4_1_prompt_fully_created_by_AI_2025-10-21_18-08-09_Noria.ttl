# Adding a corrective action for the DB connection issue
noria:OperationPlan_DBRestart a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Procedure for restarting the database service on DBServer01."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBConnectionError ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBServiceRunning .

noria:ActionPreCondition_DBConnectionError a noria:ActionPreCondition ;
    rdfs:label "Database Connection Error Detected"@en ;
    rdfs:comment "Condition: Database connection errors are actively being reported by applications."@en .

noria:ActionPostCondition_DBServiceRunning a noria:ActionPostCondition ;
    rdfs:label "Database Service Running and Accessible"@en ;
    rdfs:comment "Outcome: Database service is confirmed to be running and accessible from application servers."@en .

noria:EventRecord_DBConnectionError noria:alarmProposedRepairAction noria:OperationPlan_DBRestart .

# Adding a specific agent for security incidents
foaf:Agent_SecurityAnalyst a foaf:Agent ;
    rdfs:label "Security Analyst John Doe"@en ;
    rdfs:comment "Individual security analyst responsible for investigating security alerts."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Escalate suspicious activity to Security Operations Team lead."@en .

