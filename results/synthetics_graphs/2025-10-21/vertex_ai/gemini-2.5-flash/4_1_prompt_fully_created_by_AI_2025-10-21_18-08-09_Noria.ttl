    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_DBServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0"@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# More Network Links
noria:NetworkLink_LB_WebSrv_Link a noria:NetworkLink ;
    rdfs:label "Load Balancer to Web Server Link"@en ;
    noria:networkLinkId "NL-LB1-WS1" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_LoadBalancer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_WebSrv01 ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects noria:NetworkInterface_LoadBalancer01_Eth0, noria:NetworkInterface_WebSrv01_Eth0 . # Assuming WebSrv01 has an Eth0

noria:NetworkInterface_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkLink_WebSrv_DB_Link a noria:NetworkLink ;
    rdfs:label "Web Server to DB Server Link"@en ;
    noria:networkLinkId "NL-WS1-DB1" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DBServer01 ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects noria:NetworkInterface_WebSrv01_Eth1, noria:NetworkInterface_DBServer01_Eth0 . # Assuming WebSrv01 has an Eth1

noria:NetworkInterface_WebSrv01_Eth1 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 1"@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

