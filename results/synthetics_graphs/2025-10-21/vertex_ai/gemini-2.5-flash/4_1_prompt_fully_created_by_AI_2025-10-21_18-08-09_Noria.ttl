# --- Event Records ---
noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Outage Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logText "DNS server dns01.corp.example.com unreachable on port 53."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_RouterPortDown a noria:EventRecord ;
    rdfs:label "Router Port Down Alert"@en ;
    rdfs:comment "Alert indicating a network interface on Core Router 1 went down."@en ;
    noria:loggingTime "2024-04-10T09:05:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/2 on cr01.dc.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_WebSrvHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on websrv01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_DNSConfigChange a noria:EventRecord ;
    rdfs:label "DNS Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on DNS01."@en ;
    noria:loggingTime "2024-04-09T15:30:00Z"^^xsd:dateTime ;
    noria:logText "Configuration updated by jdoe: added new A record for newapp.corp.example.com."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem . # Assuming monitoring system logs config changes.

noria:EventRecord_RouterPortUp a noria:EventRecord ;
    rdfs:label "Router Port Up Log"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 1 came back up."@en ;
    noria:loggingTime "2024-04-10T09:15:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/2 on cr01.dc.example.com changed state to up."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Clear> .

# --- Trouble Tickets ---
