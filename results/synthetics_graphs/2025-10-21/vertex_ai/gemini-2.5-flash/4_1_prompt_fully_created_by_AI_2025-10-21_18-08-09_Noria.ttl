    dcterms:created "2024-04-11T08:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_AppSupportL2 ;
    noria:troubleTicketRelatedResource noria:Resource_DBServer01 ;
    noria:troubleTicketTrigger noria:EventRecord_DBDiskFull ;
    noria:documentHRef <http://itsm.example.com/ticket/TT-20240411-003> .

# More Change Requests
noria:ChangeRequest_FirewallPolicyUpdate a noria:ChangeRequest ;
    rdfs:label "Firewall Policy Update"@en ;
    rdfs:comment "Update firewall policy to allow new application traffic."@en ;
    dcterms:identifier "CR-20240418-003" ;
    dcterms:created "2024-04-10T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-18T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-18T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource_Firewall01, noria:Application_InternalCRM ;
    noria:changeRequestOutageDuration "PT0H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty foaf:Agent_NetworkOpsTeam ;
    noria:documentHRef <http://itsm.example.com/change/CR-20240418-003> .

# More Operation Plans
noria:OperationPlan_DiskCleanup a noria:OperationPlan ;
    rdfs:label "Database Disk Cleanup Procedure"@en ;
    rdfs:comment "Procedure for safely cleaning up disk space on database servers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBBackupComplete ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DiskSpaceFreed .

noria:ActionPreCondition_DBBackupComplete a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete"@en ;
    rdfs:comment "Condition: A full backup of the database has been successfully completed."@en .

noria:ActionPostCondition_DiskSpaceFreed a noria:ActionPostCondition ;
    rdfs:label "Sufficient Disk Space Freed"@en ;
    rdfs:comment "Outcome: At least 20% of disk space has been freed on the database server."@en .

noria:TroubleTicket_DBDiskFull noria:troubleTicketCause "Database logs consuming excessive disk space."@en ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-11T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-11T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Zabbix" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ResourceExhaustion> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ApplicationHostingServices> .

noria:EventRecord_DBDiskFull noria:alarmProposedRepairAction noria:OperationPlan_DiskCleanup .

