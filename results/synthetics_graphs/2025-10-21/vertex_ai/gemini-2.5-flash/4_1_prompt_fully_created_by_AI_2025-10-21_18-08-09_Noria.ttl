# More Event Records
noria:EventRecord_DBDiskFull a noria:EventRecord ;
    rdfs:label "Database Disk Full Alert"@en ;
    rdfs:comment "Alert indicating database server disk space is critically low."@en ;
    noria:loggingTime "2024-04-11T08:00:00Z"^^xsd:dateTime ;
    noria:logText "Disk usage on /var/lib/mysql on db01.corp.example.com is 95%."@en ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_FirewallBlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en ;
    rdfs:comment "Alert indicating unusual traffic blocked by the firewall."@en ;
    noria:loggingTime "2024-04-11T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Blocked connection attempt from 1.2.3.4 to internal host 192.168.1.20 on port 8080. Policy violation."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# More Trouble Tickets
noria:TroubleTicket_DBDiskFull a noria:TroubleTicket ;
    rdfs:label "Database Disk Full Incident"@en ;
    rdfs:comment "Incident regarding critical disk space on the database server."@en ;
