    noria:networkLinkInstallationDate "2023-03-10T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkInterfaceConnects noria:NetworkInterface/CoreRouter01-Gi0-0-0 ;
    noria:networkInterfaceConnects noria:NetworkInterface/EmailServer01-Eth0 .

