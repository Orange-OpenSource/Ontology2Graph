# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, noria:CorporateUserIdentifier)
# =============================================================================

noria:Agent/NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical issues, call the hotline. For non-critical, use ticketing system."@en .

noria:Agent/AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2 support for business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
