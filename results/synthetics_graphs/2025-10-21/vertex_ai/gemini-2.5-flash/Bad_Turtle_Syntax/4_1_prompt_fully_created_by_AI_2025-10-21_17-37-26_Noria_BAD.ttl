    noria:operationPlanPreCondition noria:OperationPlan/DBUpgradeProcedure .

noria:ActionPostCondition/DBUpgradeSuccessful a noria:ActionPostCondition ;
    rdfs:label "Database Upgrade Successful"@en ;
    rdfs:comment "Post-condition: Database version updated, all services connected, and performance metrics within baseline."@en ;
    noria:operationPlanPostCondition noria:OperationPlan/DBUpgradeProcedure .

