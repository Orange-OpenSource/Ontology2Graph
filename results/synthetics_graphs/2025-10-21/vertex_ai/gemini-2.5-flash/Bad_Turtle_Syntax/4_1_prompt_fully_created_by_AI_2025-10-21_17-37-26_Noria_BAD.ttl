noria:ActionPostCondition/InterfaceUpAndStable a noria:ActionPostCondition ;
    rdfs:label "Interface Up and Stable"@en ;
    rdfs:comment "Post-condition: Interface status is 'up', traffic flows normally, and no flapping observed for 15 minutes."@en ;
    noria:operationPlanPostCondition noria:OperationPlan/RouterInterfaceTroubleshooting .

noria:ActionPreCondition/DBBackupCompleted a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completed"@en ;
