    noria:loggingTime "2024-04-22T02:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan/IsolateServerProcedure .

noria:OperationPlan/IsolateServerProcedure a noria:OperationPlan ;
    rdfs:label "Isolate Server Procedure"@en ;
    rdfs:comment "Procedure to isolate a compromised server from the network."@en .

noria:OperationPlan/IsolateServerProcedure noria:operationPlanPreCondition noria:ActionPreCondition/CompromiseConfirmed .
noria:OperationPlan/IsolateServerProcedure noria:operationPlanPostCondition noria:ActionPostCondition/ServerIsolated .

noria:ActionPreCondition/CompromiseConfirmed a noria:ActionPreCondition ;
    rdfs:label "Compromise Confirmed"@en ;
    rdfs:comment "Pre-condition: Evidence of unauthorized access or malicious activity on the server."@en .

noria:ActionPostCondition/ServerIsolated a noria:ActionPostCondition ;
    rdfs:label "Server Isolated"@en ;
    rdfs:comment "Post-condition: Server is no longer reachable from the network, and threat is contained."@en .

noria:TroubleTicket/TT-20240422-004 noria:troubleTicketTrigger noria:EventRecord/Log-SIEM-BruteForce .

