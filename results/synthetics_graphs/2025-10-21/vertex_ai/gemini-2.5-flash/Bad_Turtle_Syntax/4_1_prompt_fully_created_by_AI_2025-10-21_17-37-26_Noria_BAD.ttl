# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord/Log-CoreRouter-InterfaceDown a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on CoreRouter01 went down."@en ;
    noria:logOriginatingManagedObject noria:Resource/CoreRouter01-Paris ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringPlatform ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord/Log-AppServer-HighCPU a noria:EventRecord ;
    rdfs:label "App Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on AppServer01."@en ;
    noria:logOriginatingManagedObject noria:Resource/AppServer01-Paris ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringPlatform ;
    noria:logText "CPU utilization on appserver01.paris.example.com exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord/Log-Firewall-BlockedTraffic a noria:EventRecord ;
