# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent001 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:comment "First line support team for network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline for critical issues, use ticketing system for non-critical."@en .

foaf:Agent002 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Team responsible for critical business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Open a ticket via the internal portal."@en .

foaf:Agent003 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team managing physical and virtual server infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for routine requests, critical issues via NOC."@en .

foaf:Agent004 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC) Team"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate notification for security incidents."@en .

foaf:Agent005 a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> .

foaf:Agent006 a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> .

foaf:Agent007 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

foaf:Agent008 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cloud Infrastructure Team"@en ;
    rdfs:comment "Team managing public and private cloud resources."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

