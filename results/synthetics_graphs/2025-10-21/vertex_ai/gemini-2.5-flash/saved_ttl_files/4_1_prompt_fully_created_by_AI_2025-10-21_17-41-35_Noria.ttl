# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord001 a noria:EventRecord ;
    rdfs:label "Interface Down Alert CR-PAR-01"@en ;
    rdfs:comment "Alert indicating that GigabitEthernet0/0/1 on CR-PAR-01 went down."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application002 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord002 a noria:EventRecord ;
    rdfs:label "High CPU Usage APP-SRV-01"@en ;
    rdfs:comment "Warning for sustained high CPU usage on Application Server 1."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU_UTILIZATION_HIGH: CPU usage on app-srv-01 exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource002 ;
    noria:logOriginatingManagementSystem noria:Application002 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord003 a noria:EventRecord ;
    rdfs:label "Database Connection Error DB-SRV-01"@en ;
    rdfs:comment "Log entry indicating multiple failed database connections."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "DB_CONN_ERROR: Failed to connect to database from app-srv-01. Max connections reached."@en ;
    noria:logOriginatingManagedObject noria:Resource003 ;
    noria:logOriginatingManagementSystem noria:Application001 ; # ERP system itself logging
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord004 a noria:EventRecord ;
    rdfs:label "Firewall Policy Change FW-PAR-01"@en ;
    rdfs:comment "Informational log about a firewall policy modification."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logText "POLICY_CHANGE: Rule 'Allow_SSH_Admin' modified by Alice Smith."@en ;
    noria:logOriginatingManagedObject noria:Resource004 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logOriginatingAgent foaf:Agent005 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord005 a noria:EventRecord ;
    rdfs:label "VM-WEB-01 Disk Full Alert"@en ;
    rdfs:comment "Alert indicating that the disk on VM-WEB-01 is nearly full."@en ;
    noria:loggingTime "2024-04-20T09:45:00Z"^^xsd:dateTime ;
    noria:logText "DISK_FULL_WARNING: /dev/sda1 on vm-web-01 at 95% capacity."@en ;
    noria:logOriginatingManagedObject noria:Resource006 ;
    noria:logOriginatingManagementSystem noria:Application002 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord006 a noria:EventRecord ;
    rdfs:label "SAN Volume Offline Alert"@en ;
    rdfs:comment "Critical alert: a volume on the Storage Array is offline."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "STORAGE_VOLUME_OFFLINE: Volume 'ERP_DATA_VOL' on san-par-01 is offline."@en ;
    noria:logOriginatingManagedObject noria:Resource007 ;
    noria:logOriginatingManagementSystem noria:Application002 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

