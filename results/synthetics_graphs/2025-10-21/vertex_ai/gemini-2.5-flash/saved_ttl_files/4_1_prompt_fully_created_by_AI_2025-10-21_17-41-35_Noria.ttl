# =============================================================================
# Operational Procedures (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:OperationPlan001 a noria:OperationPlan ;
    rdfs:label "Router Interface Replacement Procedure"@en ;
    rdfs:comment "Standard operating procedure for replacing a faulty router interface card."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition001 ;
    noria:operationPlanPostCondition noria:ActionPostCondition001 ;
    noria:actionCorrelatedOperationPlan noria:ChangeRequest001 .

noria:ActionPreCondition001 a noria:ActionPreCondition ;
    rdfs:label "Interface Replacement Pre-Check"@en ;
    rdfs:comment "Verify redundant path is active, backup configuration, and physical access to the device."@en .

noria:ActionPostCondition001 a noria:ActionPostCondition ;
    rdfs:label "Interface Replacement Post-Check"@en ;
    rdfs:comment "Verify interface status is 'up', traffic flow restored, and no new alarms generated."@en .

noria:OperationPlan002 a noria:OperationPlan ;
    rdfs:label "Database Performance Tuning Procedure"@en ;
    rdfs:comment "Procedure for optimizing database performance, including index rebuilds and query analysis."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition002 ;
    noria:operationPlanPostCondition noria:ActionPostCondition002 ;
    noria:actionCorrelatedOperationPlan noria:ChangeRequest002 .

noria:ActionPreCondition002 a noria:ActionPreCondition ;
    rdfs:label "Database Tuning Pre-Check"@en ;
    rdfs:comment "Ensure database backup is recent, application downtime window is approved, and performance metrics baseline is captured."@en .

noria:ActionPostCondition002 a noria:ActionPostCondition ;
    rdfs:label "Database Tuning Post-Check"@en ;
    rdfs:comment "Verify application functionality, check database performance metrics for improvement, and confirm no errors in logs."@en .

noria:OperationPlan003 a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard procedure for upgrading router operating system firmware."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition003 ;
    noria:operationPlanPostCondition noria:ActionPostCondition003 ;
    noria:actionCorrelatedOperationPlan noria:ChangeRequest003 .

noria:ActionPreCondition003 a noria:ActionPreCondition ;
    rdfs:label "Firmware Upgrade Pre-Check"@en ;
    rdfs:comment "Verify current firmware version, download new image, backup configuration, and ensure power stability."@en .

noria:ActionPostCondition003 a noria:ActionPostCondition ;
    rdfs:label "Firmware Upgrade Post-Check"@en ;
    rdfs:comment "Verify new firmware version, check device uptime, confirm all interfaces are up, and test connectivity."@en .

