# --- Additional Interconnections for Density ---

# Link agents to resources they manage
foaf:Agent001 noria:agentManagesResource noria:Resource003, noria:Resource004, noria:Resource008 .
foaf:Agent002 noria:agentManagesResource noria:Resource001, noria:Resource007 .
foaf:Agent004 noria:agentManagesResource noria:Resource002 .
foaf:Agent005 noria:agentManagesResource noria:Resource005 .
org:OrgUnit003 noria:agentManagesResource noria:Resource006 .

# Link applications to resources
noria:Resource001 noria:resourceForApplication noria:Application001 .
noria:Resource002 noria:resourceForApplication noria:Application001 .
noria:Resource006 noria:resourceForApplication noria:Application002 .
noria:Resource008 noria:resourceForApplication noria:Application003 .
noria:Resource005 noria:resourceForApplication noria:Application004 .

# Link EventRecords to TroubleTickets and ChangeRequests
noria:TroubleTicket001 noria:documentStatusHistory noria:EventRecord001, noria:EventRecord002 .
noria:TroubleTicket002 noria:documentStatusHistory noria:EventRecord003 .
noria:TroubleTicket004 noria:documentStatusHistory noria:EventRecord004 .
noria:ChangeRequest001 noria:documentStatusHistory noria:EventRecord007 . # Example: Monitoring server restart might be related to a change request on monitoring system itself.

# Link TroubleTicketNotes to EventRecords (as correlated executions)
noria:TroubleTicketNote004 noria:troubleTicketNoteCorrelatedExecution noria:EventRecord004 .

# Link ChangeRequest to EventRecords (as correlated executions)
noria:ChangeRequest001 noria:changeRequestImpact noria:Resource003 .
noria:ChangeRequest002 noria:changeRequestImpact noria:Resource006 .
noria:ChangeRequest003 noria:changeRequestImpact noria:ApplicationModule001 .

# Example of alarm mitigation
noria:EventRecord003 noria:alarmMitigatedBy noria:TroubleTicket002 . # The TT itself acts as a container for mitigation actions.
noria:EventRecord004 noria:alarmMitigatedBy noria:TroubleTicket004 .

# Example of a resource being a cluster controller for another resource (if applicable)
# Assuming Resource006 (VM Host) is controlled by a virtual center (another resource)
noria:Resource006 noria:clusterController noria:Resource009 .

