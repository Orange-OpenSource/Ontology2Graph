    rdfs:label "Virtual Center Server"@en ;
    rdfs:comment "Centralized management server for VMware environment."@en ;
    noria:resourceHostName "vcenter01.example.com" ;
    noria:resourceType <kos/Resource/type/management-server> ;
    noria:resourceManagedBy org:OrgUnit003 .

# Example of a resource having a virtual server status
noria:Resource001 noria:virtualServerStatus <kos/Resource/OperationalState/running> .
noria:Resource002 noria:virtualServerStatus <kos/Resource/OperationalState/running> .

# Example of network interface optical power (if applicable)
noria:NetworkInterface003 noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-1"^^xsd:int ;
