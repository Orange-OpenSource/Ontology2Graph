    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "45.748"^^xsd:float ;
    wgs84_pos:long "4.847"^^xsd:float .

noria:Room001 a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace bot:Site001 .

noria:Room002 a noria:Room ;
    rdfs:label "Network Core Room B2"@en ;
    rdfs:comment "Network core equipment room in Paris Data Center."@en ;
    bot:hasSpace bot:Site001 .

noria:Room003 a noria:Room ;
    rdfs:label "DR Server Room C1"@en ;
    rdfs:comment "Disaster recovery server room in Lyon Data Center."@en ;
    bot:hasSpace bot:Site002 .

noria:Locus001 a noria:Locus ;
    rdfs:label "Rack A1-01"@en ;
    rdfs:comment "First rack in Server Room A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "01" ;
