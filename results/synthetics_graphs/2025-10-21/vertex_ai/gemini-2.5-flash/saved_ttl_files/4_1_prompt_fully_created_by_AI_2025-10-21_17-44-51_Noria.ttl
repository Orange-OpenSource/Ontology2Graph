# --- Operation Plans (noria:OperationPlan) ---

noria:OperationPlan001 a noria:OperationPlan ;
    rdfs:label "Core Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and restoring a down core router interface."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition001 ;
    noria:operationPlanPostCondition noria:ActionPostCondition001 .

noria:OperationPlan002 a noria:OperationPlan ;
    rdfs:label "Web Server CPU Spike Resolution"@en ;
    rdfs:comment "Procedure to identify and resolve high CPU utilization on web servers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition002 ;
    noria:operationPlanPostCondition noria:ActionPostCondition002 .

noria:OperationPlan003 a noria:OperationPlan ;
    rdfs:label "Firewall IP Block Procedure"@en ;
    rdfs:comment "Procedure for blocking malicious IP addresses at the perimeter firewall."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition003 ;
    noria:operationPlanPostCondition noria:ActionPostCondition003 .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---

noria:ActionPreCondition001 a noria:ActionPreCondition ;
    rdfs:label "Interface Down Confirmed"@en ;
    rdfs:comment "Pre-condition: Network interface status is 'down' and no administrative shutdown is active."@en .

noria:ActionPostCondition001 a noria:ActionPostCondition ;
    rdfs:label "Interface Operational"@en ;
    rdfs:comment "Post-condition: Network interface status is 'up' and traffic is flowing."@en .

noria:ActionPreCondition002 a noria:ActionPreCondition ;
    rdfs:label "High CPU Alert Active"@en ;
    rdfs:comment "Pre-condition: CPU utilization on target server is consistently above 90%."@en .

noria:ActionPostCondition002 a noria:ActionPostCondition ;
    rdfs:label "CPU Utilization Normalized"@en ;
    rdfs:comment "Post-condition: CPU utilization on target server is below 70% for at least 15 minutes."@en .

noria:ActionPreCondition003 a noria:ActionPreCondition ;
    rdfs:label "Malicious IP Identified"@en ;
    rdfs:comment "Pre-condition: A source IP address has been identified as originating malicious traffic."@en .

noria:ActionPostCondition003 a noria:ActionPostCondition ;
    rdfs:label "IP Blocked and Alerts Ceased"@en ;
    rdfs:comment "Post-condition: The malicious IP address is blocked, and related security alerts have stopped."@en .

