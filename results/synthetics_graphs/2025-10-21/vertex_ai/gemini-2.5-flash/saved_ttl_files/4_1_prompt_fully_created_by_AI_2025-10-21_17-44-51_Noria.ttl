noria:Locus002 a noria:Locus ;
    rdfs:label "Rack A1-02"@en ;
    rdfs:comment "Second rack in Server Room A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "02" ;
    bot:containsZone noria:Room001 .

noria:Locus003 a noria:Locus ;
    rdfs:label "Rack B2-05"@en ;
