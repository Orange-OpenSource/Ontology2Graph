    noria:locusLine "B2" ;
    noria:locusRow "05" ;
    bot:containsZone noria:Room002 .

noria:Locus004 a noria:Locus ;
    rdfs:label "Rack C1-03"@en ;
    rdfs:comment "Third rack in DR Server Room C1."@en ;
    noria:locusLine "C1" ;
    noria:locusRow "03" ;
    bot:containsZone noria:Room003 .

