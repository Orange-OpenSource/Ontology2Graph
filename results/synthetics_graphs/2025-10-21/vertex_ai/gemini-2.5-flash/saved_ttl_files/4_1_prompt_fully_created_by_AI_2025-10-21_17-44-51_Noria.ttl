    rdfs:label "Trouble Ticket 001 Frozen"@en ;
    rdfs:comment "Trouble Ticket 001 was frozen due to dependency on external vendor."@en ;
    noria:loggingTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
