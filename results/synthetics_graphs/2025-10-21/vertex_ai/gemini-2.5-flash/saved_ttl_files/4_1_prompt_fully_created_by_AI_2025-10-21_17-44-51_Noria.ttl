noria:ApplicationModule004 noria:applicationModuleSupportLeader foaf:Agent006 .

noria:ApplicationModule005 noria:applicationModuleAdministrationLeader foaf:Agent005 .
noria:ApplicationModule005 noria:applicationModuleSupportLeader foaf:Agent005 .

# Example of an EventRecord being mitigated by a ProcedureExecutionContainer (e.g., a TroubleTicket)
noria:EventRecord001 noria:alarmMitigatedBy noria:TroubleTicket001 .
noria:EventRecord002 noria:alarmMitigatedBy noria:TroubleTicket001 .
noria:EventRecord005 noria:alarmMitigatedBy noria:TroubleTicket003 .
noria:EventRecord006 noria:alarmMitigatedBy noria:TroubleTicket001 . # Load balancer issue contributes to portal degradation

# Example of an EventRecord proposing a repair action
noria:EventRecord003 noria:alarmProposedRepairAction noria:OperationPlan001 .
noria:EventRecord001 noria:alarmProposedRepairAction noria:OperationPlan002 .
noria:EventRecord004 noria:alarmProposedRepairAction noria:OperationPlan003 .

# Example of a TroubleTicket having a freeze item (represented by an EventRecord)
noria:TroubleTicket001 noria:troubleTicketFreezeItem noria:EventRecord008 .

