    noria:logText "INTERFACE_DOWN: xe-0/0/0 on cr01.par.example.com changed state to down" ;
    noria:logOriginatingManagedObject noria:Resource003 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord004 a noria:EventRecord ;
    rdfs:label "Firewall Policy Violation"@en ;
    rdfs:comment "Attempted unauthorized access detected by Firewall 01."@en ;
    noria:loggingTime "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:logText "FW_VIOLATION: Source IP 192.168.1.10 attempted access to restricted port 22" ;
    noria:logOriginatingManagedObject noria:Resource005 ;
    noria:logOriginatingManagementSystem noria:Application004 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent foaf:Agent005 .

noria:EventRecord005 a noria:EventRecord ;
    rdfs:label "VM Host Disk Usage High"@en ;
    rdfs:comment "Disk usage on vmhost01.prod.example.com reached 98%."@en ;
    noria:loggingTime "2024-04-23T10:25:00Z"^^xsd:dateTime ;
