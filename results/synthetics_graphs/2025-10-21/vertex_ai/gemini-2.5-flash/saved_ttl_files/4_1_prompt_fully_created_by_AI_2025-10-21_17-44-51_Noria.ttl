noria:TroubleTicketNote001 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT001"@en ;
    rdfs:comment "Identified high CPU on web01 and corresponding database connection timeouts. Investigating database server logs."@en ;
