    noria:logOriginatingManagedObject noria:Resource006 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord006 a noria:EventRecord ;
    rdfs:label "Load Balancer Backend Down"@en ;
    rdfs:comment "Health check failed for a backend server on Load Balancer 01."@en ;
    noria:loggingTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:logText "LB_BACKEND_DOWN: Backend server web02.prod.example.com failed health check" ;
    noria:logOriginatingManagedObject noria:Resource007 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord007 a noria:EventRecord ;
    rdfs:label "Monitoring Server Service Restart"@en ;
    rdfs:comment "Prometheus service restarted on monitor01.example.com."@en ;
    noria:loggingTime "2024-04-23T10:35:00Z"^^xsd:dateTime ;
