# --- Agents (foaf:Agent, org:OrganizationalUnit) ---

foaf:Agent001 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:comment "Primary team responsible for 24/7 network monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Contact via dedicated hotline for critical issues. Use ticketing system for non-urgent matters."@en .

foaf:Agent002 a foaf:Agent ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team managing physical and virtual server infrastructure."@en ;
    noria:agentWorkingHours "8:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit tickets via internal portal. For emergencies, call the on-call engineer."@en .

foaf:Agent003 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Support team for critical business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "All issues must be logged in the ITSM system."@en .

foaf:Agent004 a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database systems and performance."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "Prioritize issues based on severity. Critical issues require immediate phone notification after ticket creation."@en .

foaf:Agent005 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC) Team"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Report all security incidents immediately via phone and follow up with a security incident ticket."@en .

foaf:Agent006 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer, NOC Team."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

foaf:Agent007 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Architect, App Support Team A."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

org:OrgUnit001 a org:OrganizationalUnit ;
    rdfs:label "Infrastructure Operations Department"@en ;
    rdfs:comment "Department overseeing all IT infrastructure."@en .

org:OrgUnit002 a org:OrganizationalUnit ;
    rdfs:label "Core Network Team"@en ;
    rdfs:comment "Team responsible for the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

org:OrgUnit003 a org:OrganizationalUnit ;
