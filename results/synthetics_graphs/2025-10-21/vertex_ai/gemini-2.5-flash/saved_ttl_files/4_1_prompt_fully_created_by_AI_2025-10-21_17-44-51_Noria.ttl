# Example of a ChangeRequest being regulated
noria:ChangeRequest001 noria:changeRequestIsRegulated "true"^^xsd:boolean .
noria:ChangeRequest002 noria:changeRequestIsRegulated "false"^^xsd:boolean .

# Example of a TroubleTicket having characteristic (not explicitly defined as a class, but can be a blank node or literal)
noria:TroubleTicket001 noria:troubleTicketCharacteristic "Customer Impact: High" .
noria:TroubleTicket001 noria:troubleTicketCharacteristic "Root Cause Analysis: Pending" .

# Example of a TroubleTicketPartyIntervention (can be a blank node or a specific class if defined)
noria:TroubleTicket001 noria:troubleTicketPartyIntervention [
    a noria:TroubleTicketNote ;
    rdfs:label "Handover to DB Team"@en ;
    dcterms:created "2024-04-23T10:40:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent003 ;
    rdfs:comment "Issue escalated to Database Administration Team for further investigation."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis>
] .

noria:TroubleTicket002 noria:troubleTicketPartyIntervention [
    a noria:TroubleTicketNote ;
    rdfs:label "Handover to Core Network L3"@en ;
    dcterms:created "2024-04-23T10:50:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent001 ;
    rdfs:comment "Issue escalated to Core Network L3 team for physical layer troubleshooting."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis>
] .

# Ensure all entities are connected.
# All Resources are locatedAtLocus and resourceManagedBy.
# All NetworkInterfaces are networkInterfaceOf a Resource and networkInterfaceConnects a NetworkLink.
# All NetworkLinks have termination resources and are managed by an agent.
# All Applications have resourceManagedBy and resourceForApplication links.
# All ApplicationModules are applicationModuleOf an Application and have related parties.
# All Services are subSystemOf ApplicationModules/Resources/NetworkLinks.
# All EventRecords have originating objects/systems/agents and are linked to TroubleTickets.
# All TroubleTickets are linked to services/resources, parties, and event records.
# All ChangeRequests are linked to impacts, parties, and potentially event records.
# All Notes are partOf a TroubleTicket and have a creator.
# All ProductModels are manufacturedBy an organization.
# All Locations are linked to sites/rooms.
# All OperationPlans have pre/post conditions.
# All Pre/Post Conditions are linked to OperationPlans.
# All DocumentAttachments are partOf a TroubleTicket/ChangeRequest.

# This graph is dense and interconnected, covering various aspects of IT infrastructure,
# application management, and incident/change processes using the NORIA vocabulary.
