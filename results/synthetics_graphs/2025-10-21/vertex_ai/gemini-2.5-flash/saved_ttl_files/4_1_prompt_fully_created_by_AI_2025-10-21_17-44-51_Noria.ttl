    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/InwardCustomerComments> ;
    dcterms:isPartOf noria:TroubleTicket001 .

