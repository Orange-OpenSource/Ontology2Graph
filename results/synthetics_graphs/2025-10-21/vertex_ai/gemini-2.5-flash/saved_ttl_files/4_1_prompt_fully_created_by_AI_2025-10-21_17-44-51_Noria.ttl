# --- Event Records (noria:EventRecord) ---

noria:EventRecord001 a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alert"@en ;
    rdfs:comment "CPU utilization on web01.prod.example.com exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU_HIGH: web01.prod.example.com CPU usage 95%"@en ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord002 a noria:EventRecord ;
    rdfs:label "Database Connection Error"@en ;
    rdfs:comment "Multiple connection errors reported by the application to db01.prod.example.com."@en ;
    noria:loggingTime "2024-04-23T10:10:30Z"^^xsd:dateTime ;
    noria:logText "DB_CONN_FAIL: Application failed to connect to db01.prod.example.com" ;
    noria:logOriginatingManagedObject noria:Resource002 ;
    noria:logOriginatingManagementSystem noria:Application001 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord003 a noria:EventRecord ;
    rdfs:label "Core Router Interface Down"@en ;
    rdfs:comment "Interface xe-0/0/0 on cr01.par.example.com went down."@en ;
