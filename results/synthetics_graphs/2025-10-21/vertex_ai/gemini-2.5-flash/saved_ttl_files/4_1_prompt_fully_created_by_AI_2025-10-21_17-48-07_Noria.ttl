    noria:logOriginatingManagedObject noria:Resource_AppServer03 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CPU utilization on appserver03 exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-04-20T11:15:30Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_VDB01_DiskFull a noria:EventRecord ;
    rdfs:label "Virtual DB Server 01 Disk Full Alert"@en ;
