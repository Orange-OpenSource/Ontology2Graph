# --- Operation Plans and Conditions ---

noria:OperationPlan_RouterFirmwareUpgrade a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware, including pre-checks and post-checks."@en ;
    skos:example "Steps include: backup configuration, download firmware, install, reboot, verify connectivity."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterConnectivityCheck ;
    noria:operationPlanPreCondition noria:ActionPreCondition_ConfigurationBackup ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterConnectivityRestored ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FirmwareVersionVerified .

noria:OperationPlan_VMDiskExpansion a noria:OperationPlan ;
    rdfs:label "Virtual Machine Disk Expansion Procedure"@en ;
    rdfs:comment "Procedure for safely expanding virtual machine disk space."@en ;
    skos:example "Steps include: snapshot VM, expand disk in hypervisor, extend filesystem in OS, verify."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_VMBackup ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DiskSpaceMonitoring ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DiskSpaceIncreased ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ApplicationFunctionalityVerified .

noria:ActionPreCondition_RouterConnectivityCheck a noria:ActionPreCondition ;
    rdfs:label "Router Connectivity Check"@en ;
    rdfs:comment "Verify network connectivity to the router before starting any maintenance."@en ;
    skos:example "Ping management IP, check BGP neighbor status."@en .

noria:ActionPreCondition_ConfigurationBackup a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup"@en ;
    rdfs:comment "Ensure a recent backup of the router configuration is available."@en ;
    skos:example "Save running configuration to TFTP server."@en .

noria:ActionPostCondition_RouterConnectivityRestored a noria:ActionPostCondition ;
    rdfs:label "Router Connectivity Restored"@en ;
    rdfs:comment "Confirm that the router is fully operational and reachable after maintenance."@en ;
    skos:example "All interfaces up, routing protocols converged, traffic flowing."@en .

noria:ActionPostCondition_FirmwareVersionVerified a noria:ActionPostCondition ;
    rdfs:label "Firmware Version Verified"@en ;
    rdfs:comment "Verify that the new firmware version is correctly installed."@en ;
    skos:example "Check 'show version' output."@en .

noria:ActionPreCondition_VMBackup a noria:ActionPreCondition ;
    rdfs:label "Virtual Machine Snapshot/Backup"@en ;
    rdfs:comment "Ensure a recent snapshot or backup of the VM is taken before disk expansion."@en ;
    skos:example "Create a snapshot via vCenter."@en .

noria:ActionPreCondition_DiskSpaceMonitoring a noria:ActionPreCondition ;
    rdfs:label "Disk Space Monitoring"@en ;
    rdfs:comment "Verify current disk space usage and monitoring status."@en ;
    skos:example "Check Zabbix alerts for disk usage."@en .

noria:ActionPostCondition_DiskSpaceIncreased a noria:ActionPostCondition ;
    rdfs:label "Disk Space Increased"@en ;
    rdfs:comment "Confirm that the disk space has been successfully increased and is reported correctly by the OS."@en ;
    skos:example "Run 'df -h' command."@en .

noria:ActionPostCondition_ApplicationFunctionalityVerified a noria:ActionPostCondition ;
    rdfs:label "Application Functionality Verified"@en ;
    rdfs:comment "Verify that the application running on the VM is functioning correctly after disk expansion."@en ;
    skos:example "Perform a test transaction on the Customer Portal."@en .

