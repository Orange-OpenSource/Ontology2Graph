    noria:logText "Disk usage on /data partition of vdb01 is 98%."@en ;
    noria:loggingTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_FW01_LoginAttempt a noria:EventRecord ;
    rdfs:label "Firewall 01 Failed Login Attempt"@en ;
    rdfs:comment "Security log entry for multiple failed login attempts on Firewall 01."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_SecurityServices ;
    noria:logText "Multiple failed login attempts detected from IP 192.168.5.10 on fw01."@en ;
    noria:loggingTime "2024-04-20T13:45:10Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent foaf:Agent_CharlieBrown . # Assuming Charlie Brown is monitoring this.

noria:EventRecord_CR01_InterfaceUp a noria:EventRecord ;
    rdfs:label "Core Router 01 Interface Up Event"@en ;
