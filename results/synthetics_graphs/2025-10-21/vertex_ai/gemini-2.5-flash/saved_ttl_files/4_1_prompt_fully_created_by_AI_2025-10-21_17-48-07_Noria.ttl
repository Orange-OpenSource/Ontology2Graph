# --- Network Links ---

noria:NetworkLink_Uplink_CR01_ISP a noria:NetworkLink ;
    rdfs:label "Core Router 01 Uplink to ISP"@en ;
    rdfs:comment "High-capacity fiber link connecting Core Router 01 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-CR01-ISP-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01 ; # Simplified: assuming firewall is next hop to ISP
    noria:networkLinkInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "fiber-optic"@en ;
    noria:resourceManagedBy org:NetworkOpsDept ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_GE0_0_0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_FW01_GE0_0_0 .

noria:NetworkLink_CR01_AppServers a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Application Servers Link"@en ;
    rdfs:comment "Internal network link connecting Core Router 01 to the application server segment."@en ;
    noria:networkLinkId "NL-CR01-APPS-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_AppServer03 ; # Simplified: direct link to one server
    noria:networkLinkInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "ethernet"@en ;
    noria:resourceManagedBy org:NetworkOpsDept ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_GE0_0_1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_AS03_ETH0 .

noria:NetworkLink_AppServer_DBServer a noria:NetworkLink ;
    rdfs:label "Application Server to Database Server Link"@en ;
    rdfs:comment "Internal network link between application server and virtual database server."@en ;
    noria:networkLinkId "NL-APPS-DB-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_AppServer03 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_VirtualDB01 ;
    noria:networkLinkInstallationDate "2022-06-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "virtual-ethernet"@en ;
    noria:resourceManagedBy org:AppSupportL2Team ;
    noria:networkInterfaceConnects noria:NetworkInterface_AS03_ETH0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_VDB01_ETH0 .

