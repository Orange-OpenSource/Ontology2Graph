# =============================================================================
# Network Components
# =============================================================================

noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en .

noria:NI_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for WebSrv01 server."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Ethernet interface connected to application LAN."@en .

noria:NI_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DB01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DB01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DB01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Ethernet interface connected to database LAN."@en .

noria:NI_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 Gi0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to Server Room A."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Uplink to Server Room A distribution switch."@en .

noria:NI_RouterCore01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 Gi0/0/2"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to Firewall DMZ."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Link to DMZ Firewall."@en .

noria:NI_FirewallDMZ01_Eth0_0 a noria:NetworkInterface ;
    rdfs:label "DMZ Firewall 01 Eth0/0"@en ;
    rdfs:comment "External interface of DMZ Firewall."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "External interface connected to corporate core network."@en .

noria:NI_FirewallDMZ01_Eth0_1 a noria:NetworkInterface ;
    rdfs:label "DMZ Firewall 01 Eth0/1"@en ;
    rdfs:comment "Internal interface of DMZ Firewall."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Internal interface connected to DMZ servers."@en .

noria:NI_Storage01_FC0 a noria:NetworkInterface ;
    rdfs:label "Storage01 Fibre Channel 0"@en ;
    rdfs:comment "Fibre Channel interface for Storage01."@en ;
    noria:networkInterfaceOf noria:Resource_Storage01 ;
    noria:networkInterfaceType "fibre-channel" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Fibre Channel link to SAN switch."@en .

noria:NI_VirtualMachine_Web01_Eth0 a noria:NetworkInterface ;
    rdfs:label "VM Web 01 Ethernet 0"@en ;
    rdfs:comment "Virtual network interface for VM Web 01."@en ;
    noria:networkInterfaceOf noria:Resource_VirtualMachine_Web01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Virtual Ethernet interface connected to virtual switch."@en .

noria:NL_CoreRouter_ServerRoomA a noria:NetworkLink ;
    rdfs:label "Core Router to Server Room A Link"@en ;
    rdfs:comment "High-speed link between core router and server room distribution switch."@en ;
    noria:networkLinkId "NL-CR-SRA-001" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2021-11-01T12:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gi0_0_1 ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResource noria:Resource_DNS01 . # Simplified, in reality it would connect to a switch, then to DNS01.

noria:NL_CoreRouter_DMZFW a noria:NetworkLink ;
    rdfs:label "Core Router to DMZ Firewall Link"@en ;
    rdfs:comment "Link between core router and DMZ firewall."@en ;
    noria:networkLinkId "NL-CR-DMZFW-001" ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:networkLinkInstallationDate "2022-08-01T17:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gi0_0_2 ;
    noria:networkInterfaceConnects noria:NI_FirewallDMZ01_Eth0_0 ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResource noria:Resource_FirewallDMZ01 .

noria:NL_DMZFW_WebSrv a noria:NetworkLink ;
    rdfs:label "DMZ Firewall to Web Server Link"@en ;
    rdfs:comment "Link from DMZ firewall to web server."@en ;
    noria:networkLinkId "NL-DMZFW-WEB-001" ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:networkLinkInstallationDate "2023-01-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_FirewallDMZ01_Eth0_1 ;
    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0 ;
    noria:networkLinkTerminationResource noria:Resource_FirewallDMZ01 ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv01 .

noria:NL_WebSrv_DB01 a noria:NetworkLink ;
    rdfs:label "Web Server to DB Server Link"@en ;
    rdfs:comment "Internal link between web server and database server."@en ;
    noria:networkLinkId "NL-WEB-DB-001" ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:networkLinkInstallationDate "2023-01-20T15:15:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0 ; # Assuming same interface for simplicity, in reality it would be different subnets/interfaces
    noria:networkInterfaceConnects noria:NI_DB01_Eth0 ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResource noria:Resource_DB01 .

noria:NL_Storage_DB01 a noria:NetworkLink ;
    rdfs:label "Storage to DB Server Link"@en ;
    rdfs:comment "Fibre Channel link between storage array and database server."@en ;
    noria:networkLinkId "NL-STO-DB-001" ;
    noria:networkLinkType "Fibre Channel 8Gbps" ;
    noria:networkLinkInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_Storage01_FC0 ;
    noria:networkInterfaceConnects noria:NI_DB01_Eth0 ; # Simplified, would be a FC HBA on DB01
    noria:networkLinkTerminationResource noria:Resource_Storage01 ;
    noria:networkLinkTerminationResource noria:Resource_DB01 .

