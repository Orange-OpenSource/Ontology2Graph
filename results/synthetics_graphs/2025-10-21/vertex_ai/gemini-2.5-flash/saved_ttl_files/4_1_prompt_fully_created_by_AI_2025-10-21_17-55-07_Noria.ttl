    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication noria:App_CorporatePortal ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress "10.0.1.50" .

noria:NI_LoadBalancer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Load Balancer 01 Eth0"@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "External interface for incoming web traffic."@en .

noria:NI_LoadBalancer01_Eth1 a noria:NetworkInterface ;
