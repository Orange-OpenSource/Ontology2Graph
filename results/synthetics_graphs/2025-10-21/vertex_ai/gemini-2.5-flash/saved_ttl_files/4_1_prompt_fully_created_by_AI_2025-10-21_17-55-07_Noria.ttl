# =============================================================================
# Procedural Elements
# =============================================================================

noria:OP_WebSrv_Restart a noria:OperationPlan ;
    rdfs:label "Web Server Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the web server service."@en ;
    skos:example "ssh to server, sudo systemctl restart apache2"@en ;
    noria:operationPlanPreCondition noria:APC_WebSrv_Accessible ;
    noria:operationPlanPostCondition noria:APOC_WebSrv_Running .

noria:APC_WebSrv_Accessible a noria:ActionPreCondition ;
    rdfs:label "Web Server Accessible"@en ;
    rdfs:comment "Pre-condition: Web server is reachable via SSH and ping."@en .

noria:APOC_WebSrv_Running a noria:ActionPostCondition ;
    rdfs:label "Web Server Service Running"@en ;
    rdfs:comment "Post-condition: Web server service is active and listening on port 80/443."@en .

noria:OP_Fiber_Cleaning a noria:OperationPlan ;
    rdfs:label "Fiber Optic Cleaning Procedure"@en ;
    rdfs:comment "Procedure for inspecting and cleaning fiber optic connectors."@en ;
    skos:example "Use fiber inspection scope, clean with lint-free wipes and alcohol."@en ;
    noria:operationPlanPreCondition noria:APC_Fiber_Degraded ;
    noria:operationPlanPostCondition noria:APOC_Fiber_Optimal .

noria:APC_Fiber_Degraded a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Degraded"@en ;
    rdfs:comment "Pre-condition: Optical power levels are outside acceptable thresholds."@en .

noria:APOC_Fiber_Optimal a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Optimal"@en ;
    rdfs:comment "Post-condition: Optical power levels are within acceptable thresholds."@en .

noria:OP_DB_IndexCreation a noria:OperationPlan ;
    rdfs:label "Database Index Creation Procedure"@en ;
    rdfs:comment "Procedure for creating a new index on a database table to improve query performance."@en ;
    skos:example "SQL command: CREATE INDEX idx_column ON table (column);"@en ;
    noria:operationPlanPreCondition noria:APC_DB_HighLoad ;
    noria:operationPlanPostCondition noria:APOC_DB_LoadReduced .

noria:APC_DB_HighLoad a noria:ActionPreCondition ;
    rdfs:label "Database High Load"@en ;
    rdfs:comment "Pre-condition: Database server CPU or I/O utilization is consistently high."@en .

noria:APOC_DB_LoadReduced a noria:ActionPostCondition ;
    rdfs:label "Database Load Reduced"@en ;
    rdfs:comment "Post-condition: Database server CPU and I/O utilization has returned to normal levels."@en .

# Linking operations to actions (example for CR_WebSrv_Upgrade)
noria:CR_WebSrv_Upgrade
    noria:changeRequestImpact noria:OP_WebSrv_Restart . # A change request might involve executing an operation plan.

noria:TT_WebSrv01_Outage
    noria:troubleTicketCharacteristic noria:OP_WebSrv_Restart . # A trouble ticket might reference an operation plan used.

noria:Event_WebSrv01_Restarted
    pep:usedProcedure noria:OP_WebSrv_Restart . # An event record can be the result of a procedure execution.

noria:Event_NL_OpticalDegradation
    noria:alarmProposedRepairAction noria:OP_Fiber_Cleaning . # An alarm might suggest a repair action.

noria:Event_DB01_HighLoad
    noria:alarmProposedRepairAction noria:OP_DB_IndexCreation . # An alarm might suggest a repair action.

# Example of document status history for a TroubleTicket
noria:Event_TT_WebSrv01_StatusChange_InProgress a noria:EventRecord ;
    rdfs:label "Trouble Ticket WebSrv01 Status Change to InProgress"@en ;
