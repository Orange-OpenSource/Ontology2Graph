    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketImpacts noria:NL_CoreRouter_ServerRoomA ;
    noria:troubleTicketImpacts noria:NI_RouterCore01_Gi0_0_1 .

noria:TTNote_OpticalLink_Troubleshooting a noria:TroubleTicketNote ;
    rdfs:label "Optical Link Troubleshooting"@en ;
