    noria:logText "WARNING: Interface Gi0/0/1 on core-rtr01.corp.example.com Rx power -1.5 dBm (threshold -2.0 dBm)."@en ;
    noria:logOriginatingManagedObject noria:NI_RouterCore01_Gi0_0_1 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:networkInterfaceLaserRxOpticalPower -1 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 .

