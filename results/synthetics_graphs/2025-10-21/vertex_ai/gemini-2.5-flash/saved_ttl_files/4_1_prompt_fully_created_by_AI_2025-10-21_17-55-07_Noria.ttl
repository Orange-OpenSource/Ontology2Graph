# =============================================================================
# Agents (Teams, Persons, Organizations)
# =============================================================================

noria:Agent_DNSAdminTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'Administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution of related incidents."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for L1, then email for L2/L3 issues."@en .

noria:Agent_NetworkOpsTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, call the hotline. For non-critical, use the ticketing system."@en .

noria:Agent_AppSupportTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing L2/L3 support for critical business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All requests must go through the central IT ticketing system."@en .

noria:Agent_SecurityTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center"@en, "Centre Opérations Sécurité"@fr ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "Automated alerts are preferred. For manual escalation, use secure communication channels."@en .

noria:Agent_DBA_Team a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en, "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Manages and maintains all corporate database systems."@en ;
    noria:agentWorkingHours "08:30-17:30 Mon-Fri, on-call for critical issues"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket for all requests. Critical issues can be escalated via phone after ticket creation."@en .

noria:Agent_JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Agent_JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+33198765432" ;
    noria:agentWorkingHours "09:30-18:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

noria:Agent_CustomerSupport a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Customer Support Center"@en, "Centre de Support Client"@fr ;
    rdfs:comment "First line of contact for customer issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server for data centers."@en ;
    noria:productManufacturedBy noria:Org_Dell .

