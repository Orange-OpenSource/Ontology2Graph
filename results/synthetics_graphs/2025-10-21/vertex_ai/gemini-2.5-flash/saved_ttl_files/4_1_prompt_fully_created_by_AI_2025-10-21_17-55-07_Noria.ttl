    noria:troubleTicketDetectionDateTime "2024-04-24T08:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-24T16:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketImpacts noria:Resource_Storage01 ;
    noria:troubleTicketImpacts noria:Resource_DB01 .

noria:CR_Disk_Replacement a noria:ChangeRequest ;
    rdfs:label "Storage Disk Replacement"@en ;
    rdfs:comment "Replace failed disk in Storage01 array."@en ;
    dcterms:created "2024-04-24T08:30:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-24T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-24T11:00:00Z"^^xsd:dateTime ;
