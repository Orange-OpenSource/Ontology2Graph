    noria:troubleTicketTrigger noria:Event_NL_OpticalDegradation ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "NMS System"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:troubleTicketDetectionDateTime "2024-04-21T11:30:00Z"^^xsd:dateTime ;
