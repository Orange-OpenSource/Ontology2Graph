# Security Incident Scenario
noria:Event_Firewall_Attack a noria:EventRecord ;
    rdfs:label "Firewall Attack Alert"@en ;
    rdfs:comment "Alert indicating a high volume of suspicious traffic detected by the DMZ Firewall."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logText "ALERT: High volume of SYN floods detected from external IP 203.0.113.42 targeting DMZ."@en ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:TT_Security_Incident a noria:TroubleTicket ;
    rdfs:label "DMZ Firewall Security Incident"@en ;
    rdfs:comment "Security incident reported due to suspected DDoS attack on DMZ firewall."@en ;
    dcterms:created "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/SecurityIncident> ;
    noria:troubleTicketRelatedService noria:AppMod_CIA_Prod ;
    noria:troubleTicketRelatedParty noria:Agent_SecurityTeam ;
    noria:troubleTicketDescription "External attack detected on DMZ firewall, potential impact on public-facing services."@en ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:Event_Firewall_Attack ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Palo Alto Panorama"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/SecurityBreach> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketImpacts noria:Resource_FirewallDMZ01 ;
    noria:troubleTicketImpacts noria:App_CorporateInternetAccess .

noria:TTNote_Security_Mitigation a noria:TroubleTicketNote ;
    rdfs:label "Security Incident Mitigation"@en ;
    rdfs:comment "Applied temporary firewall rules to block source IP. Traffic normalized."@en ;
    dcterms:created "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_SecurityTeam ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TT_Security_Incident .

noria:Event_Firewall_BlockApplied a noria:EventRecord ;
    rdfs:label "Firewall Rule Applied Log"@en ;
    rdfs:comment "Log entry confirming new firewall rule to block malicious IP."@en ;
    noria:loggingTime "2024-04-23T10:25:00Z"^^xsd:dateTime ;
    noria:logText "Rule 'block_203.0.113.42' added to DMZ policy."@en ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ01 ;
    noria:logOriginatingAgent noria:Agent_SecurityTeam ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:CR_Firewall_PolicyUpdate a noria:ChangeRequest ;
    rdfs:label "Firewall Policy Update for DDoS Protection"@en ;
    rdfs:comment "Permanent update to firewall policy to enhance DDoS protection mechanisms."@en ;
    dcterms:created "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-05T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-05T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource_FirewallDMZ01 ;
    noria:changeRequestOutageDuration "PT0S"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty noria:Agent_SecurityTeam ;
    noria:changeRequestPilotParty noria:Agent_SecurityTeam ;
    noria:changeRequestActorParty noria:Agent_SecurityTeam ;
    noria:changeRequestIsRegulated true ;
    dcterms:relation noria:TT_Security_Incident .

