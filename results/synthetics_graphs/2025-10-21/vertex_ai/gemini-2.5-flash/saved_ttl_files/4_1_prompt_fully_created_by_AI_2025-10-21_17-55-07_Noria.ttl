# Scenario 1: Web Application Incident
noria:Event_WebSrv01_Down a noria:EventRecord ;
    rdfs:label "Web Server 01 Down Alert"@en ;
    rdfs:comment "Automated alert indicating Web Server 01 is unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host web01.corp.example.com is DOWN!"@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:TT_WebSrv01_Outage a noria:TroubleTicket ;
    rdfs:label "Web Server 01 Outage Incident"@en ;
    rdfs:comment "Incident reported due to Web Server 01 being down, affecting Corporate Web Portal."@en ;
    dcterms:created "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketRelatedService noria:AppMod_CWP_Prod ;
    noria:troubleTicketRelatedParty noria:Agent_AppSupportTeam ;
    noria:troubleTicketRelatedParty noria:Agent_CustomerSupport ;
    noria:troubleTicketDescription "Web server vm-web01.corp.example.com is not responding, users cannot access the corporate portal."@en ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:Event_WebSrv01_Down ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketImpacts noria:Resource_WebSrv01 ;
    noria:troubleTicketImpacts noria:App_CorporatePortal .

noria:TTNote_WebSrv01_RestartAttempt a noria:TroubleTicketNote ;
    rdfs:label "Restart Attempt on WebSrv01"@en ;
    rdfs:comment "Attempted to restart the web server service, no change."@en ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JaneSmith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TT_WebSrv01_Outage .

noria:Event_WebSrv01_Restarted a noria:EventRecord ;
    rdfs:label "Web Server 01 Service Restarted"@en ;
    rdfs:comment "Log entry indicating successful restart of web server service."@en ;
    noria:loggingTime "2024-04-20T09:20:00Z"^^xsd:dateTime ;
    noria:logText "Service 'apache2' restarted successfully."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingAgent noria:Agent_JaneSmith ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem .

noria:TTNote_WebSrv01_RootCauseFound a noria:TroubleTicketNote ;
    rdfs:label "Root Cause Identified for WebSrv01"@en ;
    rdfs:comment "Identified root cause as high CPU utilization due to misconfigured caching."@en ;
    dcterms:created "2024-04-20T09:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JaneSmith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TT_WebSrv01_Outage .

noria:TT_WebSrv01_Resolved a noria:TroubleTicket ;
    rdfs:label "Web Server 01 Outage Resolved"@en ;
    rdfs:comment "Incident resolved by adjusting caching configuration. Permanent fix requires software upgrade."@en ;
    dcterms:created "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketRelatedService noria:AppMod_CWP_Prod ;
    noria:troubleTicketRelatedParty noria:Agent_AppSupportTeam ;
    noria:troubleTicketDescription "Temporary fix applied. Portal is accessible. Creating CR for permanent solution."@en ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Internal> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/NoIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/WorkingBackup> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketCause "Misconfigured application caching leading to high CPU."@en ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/SoftwareIssue> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ApplicationDevelopment> ;
    dcterms:isPartOf noria:TT_WebSrv01_Outage . # This is a follow-up ticket or a state change, linking to the original.

noria:CR_WebSrv_Upgrade a noria:ChangeRequest ;
    rdfs:label "Web Portal Software Upgrade"@en ;
    rdfs:comment "Upgrade web portal software to address caching performance issues permanently."@en ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:AppMod_CWP_Prod ;
    noria:changeRequestImpact noria:Resource_WebSrv01 ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty noria:Agent_JaneSmith ;
    noria:changeRequestPilotParty noria:Agent_JaneSmith ;
    noria:changeRequestActorParty noria:Agent_AppSupportTeam ;
    noria:changeRequestIsRegulated false ;
    dcterms:relation noria:TT_WebSrv01_Outage . # Link CR to the TT that prompted it.

# Scenario 2: Network Link Degradation
noria:Event_NL_OpticalDegradation a noria:EventRecord ;
    rdfs:label "Optical Link Degradation Alert"@en ;
    rdfs:comment "Alert indicating high Rx optical power on a network interface, potentially causing signal distortion."@en ;
