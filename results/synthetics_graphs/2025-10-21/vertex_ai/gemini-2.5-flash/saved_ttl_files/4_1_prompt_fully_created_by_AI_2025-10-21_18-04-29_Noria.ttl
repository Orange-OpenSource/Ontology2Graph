noria:OP_ReplacePSU a noria:OperationPlan ;
    rdfs:label "Router PSU Replacement Procedure"@en ;
    rdfs:comment "Standard operating procedure for replacing a power supply unit in a network router."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterPSUFailure ;
    noria:operationPlanPostCondition noria:PostCond_RouterOperational .

noria:PreCond_RouterPSUFailure a noria:ActionPreCondition ;
    rdfs:label "Router PSU Failure Detected"@en ;
    rdfs:comment "Pre-condition: Monitoring system reports power supply failure or router is unresponsive due to power issue."@en .

noria:PostCond_RouterOperational a noria:ActionPostCondition ;
    rdfs:label "Router Operational After PSU Replacement"@en ;
    rdfs:comment "Post-condition: Router is powered on, all interfaces are up, and network connectivity is restored."@en .

noria:OP_DBIndexOptimize a noria:OperationPlan ;
    rdfs:label "Database Index Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing slow database queries by adding or modifying indexes."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBHighLoad ;
    noria:operationPlanPostCondition noria:PostCond_DBPerformanceRestored .

noria:PreCond_DBHighLoad a noria:ActionPreCondition ;
    rdfs:label "High Database Load Detected"@en ;
    rdfs:comment "Pre-condition: Database server CPU/IO utilization is consistently high, and application performance is degraded."@en .

noria:PostCond_DBPerformanceRestored a noria:ActionPostCondition ;
    rdfs:label "Database Performance Restored"@en ;
    rdfs:comment "Post-condition: Database server resource utilization returns to normal levels, and application response times are within SLA."@en .

# =============================================================================
# Procedure Executions (from PEP)
# =============================================================================

noria:PE_CR1_PSU_Replace a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of PSU Replacement for CR1"@en ;
    rdfs:comment "Record of the physical replacement of the power supply unit on Core Router 1."@en ;
    dcterms:created "2023-10-26T10:30:00Z"^^xsd:dateTime ;
    pep:usedProcedure noria:OP_ReplacePSU ;
    pep:hasInput noria:PreCond_RouterPSUFailure ;
    pep:hasOutput noria:PostCond_RouterOperational ;
    prov:wasAssociatedWith noria:Team_NetOps .

noria:PE_DB_IndexOptimize a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Database Index Optimization"@en ;
    rdfs:comment "Record of the database index optimization performed on DB Server 1."@en ;
    dcterms:created "2023-10-26T11:30:00Z"^^xsd:dateTime ;
    pep:usedProcedure noria:OP_DBIndexOptimize ;
    pep:hasInput noria:PreCond_DBHighLoad ;
    pep:hasOutput noria:PostCond_DBPerformanceRestored ;
    prov:wasAssociatedWith noria:Agent_Bob .

