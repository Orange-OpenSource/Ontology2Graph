# Linking a Trouble Ticket to a Change Request (e.g., a rollback)
noria:TroubleTicket_FW1_ConfigError dcterms:relation noria:ChangeRequest_FW1_RuleUpdate . # This TT might have been caused by the CR.

# Linking a Service to its underlying Application Modules
noria:Service_CriticalBusinessApps seas:subSystemOf noria:AppMod_CRM_Prod, noria:AppMod_ERP_Prod .
noria:Service_CorporateConnectivity seas:subSystemOf noria:AppMod_Intranet_Prod, noria:AppMod_Internet_GW_Prod .

# More detailed EventRecord for a security alert
noria:Event_DDoS_Attack a noria:EventRecord ;
    rdfs:label "DDoS Attack Detected"@en ;
    rdfs:comment "High volume of traffic detected targeting the corporate internet access gateway, indicative of a DDoS attack."@en ;
    dcterms:identifier "EVT-20231026-009" ;
    noria:loggingTime "2023-10-26T18:00:00Z"^^xsd:dateTime ;
    noria:logText "Anomaly detected: Ingress traffic on INET_GW_PROD exceeded 10Gbps. Baseline 1Gbps."@en ;
    noria:logOriginatingManagedObject noria:AppMod_Internet_GW_Prod ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logOriginatingAgent noria:Team_SecOps .

noria:TroubleTicket_DDoS_Mitigation a noria:TroubleTicket ;
    rdfs:label "DDoS Attack Mitigation"@en ;
    rdfs:comment "Incident to mitigate an ongoing Distributed Denial of Service attack."@en ;
    dcterms:identifier "TT-20231026-005" ;
    dcterms:created "2023-10-26T18:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/SecurityIncident> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketRelatedParty noria:Team_SecOps, noria:Team_NetOps ;
    noria:troubleTicketRelatedService noria:Service_CorporateConnectivity ;
    noria:troubleTicketRelatedResource noria:Resource_Firewall1, noria:Resource_CoreRouter1 ;
    noria:troubleTicketTrigger noria:Event_DDoS_Attack ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> .

# Example of a procedural element for security
noria:OP_DDoSMitigation a noria:OperationPlan ;
    rdfs:label "DDoS Mitigation Playbook"@en ;
    rdfs:comment "Standard operating procedure for detecting and mitigating DDoS attacks."@en ;
    noria:operationPlanPreCondition noria:PreCond_DDoSDetected ;
    noria:operationPlanPostCondition noria:PostCond_DDoSMitigated .

noria:PreCond_DDoSDetected a noria:ActionPreCondition ;
    rdfs:label "DDoS Attack Detected"@en ;
    rdfs:comment "Pre-condition: High traffic anomaly and multiple connection failures detected on internet-facing infrastructure."@en .

noria:PostCond_DDoSMitigated a noria:ActionPostCondition ;
    rdfs:label "DDoS Attack Mitigated"@en ;
    rdfs:comment "Post-condition: Ingress traffic returns to normal, service availability restored, and attack source blocked."@en .

noria:TroubleTicket_DDoS_Mitigation dcterms:relation noria:OP_DDoSMitigation . # The TT is being handled by this OP.

# Final check for connectivity and density:
# - All major entities (Resource, Application, TT, CR, Event, Agent, Location) are created.
# - Resources are linked to ProductModels, Locations, Applications, and managed by Agents.
# - Network Interfaces are linked to Resources and Network Links.
# - Applications are linked to Application Modules.
# - Application Modules have various related parties and status.
# - Services group Applications/Application Modules.
# - Trouble Tickets are linked to Services, Applications, Resources, Agents, and triggered by EventRecords.
# - Trouble Ticket Notes are linked to Trouble Tickets and Agents.
# - Event Records are linked to originating objects (Resource/Application), management systems, and agents.
# - Change Requests are linked to impacted entities (Resource/Application/Service), agents, and have planned/actual dates.
# - Document Attachments are linked to Trouble Tickets/Change Requests.
# - Operation Plans, Pre/Post Conditions are defined and linked to each other and to Procedure Executions.
# - Procedure Executions are linked to Operation Plans and Agents.
# - Many cross-references between different types of entities (e.g., TT to CR, Event to TT, Agent to Resource/App).
# - All properties used are from the NORIA vocabulary.
# - No `ldp` prefix used.
# - Labels and comments are provided.
# - Organization is logical.

# This graph is dense and interconnected, covering various aspects of IT operations and incident management.
