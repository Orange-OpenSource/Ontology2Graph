noria:Team_SecOps noria:agentManagesResource noria:Resource_Firewall1 .
noria:Team_CloudOps noria:agentManagesResource noria:Resource_VirtualHost1 .

# Resources contributing to applications
noria:Resource_CoreRouter1 noria:resourceForApplication noria:App_MonitoringSystem .
noria:Resource_DBServer1 noria:resourceForApplication noria:App_MonitoringSystem .
noria:Resource_WebSrv01 noria:resourceForApplication noria:App_MonitoringSystem .
noria:Resource_Firewall1 noria:resourceForApplication noria:App_MonitoringSystem .
noria:Resource_EdgeRouter1 noria:resourceForApplication noria:App_MonitoringSystem .
noria:Resource_StorageArray1 noria:resourceForApplication noria:App_MonitoringSystem .
noria:Resource_VirtualHost1 noria:resourceForApplication noria:App_MonitoringSystem .

# Application modules related parties
noria:AppMod_Intranet_Prod noria:applicationModuleSupportLeader noria:Agent_Alice .
noria:AppMod_CRM_Prod noria:applicationModuleSupportLeader noria:Agent_Bob .
noria:AppMod_Internet_GW_Prod noria:applicationModuleSupportLeader noria:Agent_Charlie .
noria:AppMod_Cloud_Dev noria:applicationModuleSupportLeader noria:Agent_Eve .

# Trouble ticket status history (using EventRecords)
noria:TroubleTicket_CR1_Outage noria:documentStatusHistory noria:Event_CR1_Down, noria:Event_CR1_Up .
noria:TroubleTicket_FW1_ConfigError noria:documentStatusHistory noria:Event_FW1_ConfigChange, noria:Event_FW1_AccessDenied .

# Change request related parties
noria:ChangeRequest_FW1_RuleUpdate noria:changeRequestRelatedParty noria:Agent_Charlie, noria:Team_SecOps .
noria:ChangeRequest_DB_Upgrade noria:changeRequestRelatedParty noria:Agent_Bob, noria:Team_DBA .

# Event records related to procedure executions
noria:Event_CR1_Up pep:wasOutputOf noria:PE_CR1_PSU_Replace .
noria:Event_CRM_HighLatency pep:wasInputFor noria:PE_DB_IndexOptimize .
noria:Event_DB_HighCPU pep:wasInputFor noria:PE_DB_IndexOptimize .

# Additional network interface observables
noria:NI_CR1_Eth0_0_1 noria:networkInterfaceLaserRxOpticalPower -10 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -5 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -20 .

noria:NI_ER1_Eth0_0_1 noria:networkInterfaceLaserRxOpticalPowerAverage -8 .

# Virtual server status (for virtual machines)
noria:Resource_VM_CRM_App noria:virtualServerStatus <kos/Resource/OperationalState/up> .
noria:Resource_VM_ERP_App noria:virtualServerStatus <kos/Resource/OperationalState/up> .

# Example of a security event
noria:Event_SuspiciousLogin a noria:EventRecord ;
    rdfs:label "Suspicious Login Attempt"@en ;
    rdfs:comment "Multiple failed login attempts detected on a critical server from an unusual IP address."@en ;
    dcterms:identifier "EVT-20231026-007" ;
    noria:loggingTime "2023-10-26T16:00:00Z"^^xsd:dateTime ;
    noria:logText "Failed login for user 'admin' from IP 192.168.5.10 (5 attempts)."@en ;
    noria:logOriginatingManagedObject noria:Resource_DBServer1 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent noria:Agent_Charlie . # Charlie might be investigating or logging this.

# Example of a Change Request leading to an EventRecord
noria:ChangeRequest_FW1_RuleUpdate noria:documentStatusHistory noria:Event_FW1_ConfigChange .

# Example of a Trouble Ticket related to a security event
noria:TroubleTicket_SuspiciousActivity a noria:TroubleTicket ;
    rdfs:label "Suspicious Activity on DB Server"@en ;
    rdfs:comment "Investigation into suspicious login attempts on the primary database server."@en ;
    dcterms:identifier "TT-20231026-004" ;
    dcterms:created "2023-10-26T16:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/SecurityIncident> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketRelatedParty noria:Team_SecOps, noria:Agent_Charlie ;
    noria:troubleTicketRelatedResource noria:Resource_DBServer1 ;
    noria:troubleTicketTrigger noria:Event_SuspiciousLogin ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> .

# Example of an Anomaly Pattern
noria:AnomalyPattern_HighCPU_SlowApp a noria:AnomalyPattern ;
    rdfs:label "High CPU & Slow Application Pattern"@en ;
    rdfs:comment "This pattern indicates a potential performance bottleneck when a database server experiences high CPU usage concurrently with application latency."@en ;
    folio:hasCause noria:PreCond_DBHighLoad ;
    folio:hasEffect noria:PostCond_DBPerformanceRestored . # Post-condition can be seen as the desired state after resolving the anomaly.

# Linking an Operation Plan to an Anomaly Pattern
noria:OP_DBIndexOptimize seas:solves noria:AnomalyPattern_HighCPU_SlowApp .

# Further linking of agents to resources and applications
noria:Agent_Alice foaf:topic_interest noria:Resource_CoreRouter1, noria:App_InternetAccess .
noria:Agent_Bob foaf:topic_interest noria:Resource_DBServer1, noria:App_CRM, noria:App_ERP .
noria:Agent_Charlie foaf:topic_interest noria:Resource_Firewall1, noria:App_MonitoringSystem .
noria:Agent_Eve foaf:topic_interest noria:Resource_VirtualHost1, noria:App_CloudPlatform .

