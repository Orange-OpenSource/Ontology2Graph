# =============================================================================
# Network Links
# =============================================================================

noria:NL_CR1_FW1 a noria:NetworkLink ;
    rdfs:label "Link CR1-FW1"@en ;
    rdfs:comment "High-speed link between Core Router 1 and Perimeter Firewall 1."@en ;
    noria:networkLinkId "NL-CR1-FW1-001" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2020-02-10T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall1 ;
    noria:networkInterfaceConnects noria:NI_CR1_Eth0_0_2, noria:NI_FW1_Eth1_1 .

noria:NL_WAN_PAR_LYN a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-Lyon"@en ;
    rdfs:comment "Dedicated WAN link connecting Paris DC to Lyon Office."@en ;
    noria:networkLinkId "NL-WAN-PAR-LYN-001" ;
    noria:networkLinkType "MPLS VPN 1Gbps" ;
    noria:networkLinkInstallationDate "2021-08-25T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeRouter1 ;
    noria:networkInterfaceConnects noria:NI_CR1_Eth0_0_1, noria:NI_ER1_Eth0_0_1 .

noria:NL_Internal_DC a noria:NetworkLink ;
    rdfs:label "Internal DC Network"@en ;
    rdfs:comment "Internal network segment within the Paris Data Center."@en ;
    noria:networkLinkId "NL-INT-DC-001" ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkLinkInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter1, noria:Resource_DBServer1, noria:Resource_WebSrv01, noria:Resource_StorageArray1, noria:Resource_VirtualHost1 ;
