# =============================================================================
# Network Interfaces
# =============================================================================

noria:NI_CR1_Eth0_0_1 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 1 to the internal network."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NI_CR1_Eth0_0_2 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 1 to the perimeter firewall."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

noria:NI_FW1_Eth1_1 a noria:NetworkInterface ;
    rdfs:label "ethernet1/1"@en ;
    rdfs:comment "Interface connecting Firewall 1 to Core Router 1 (internal side)."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_FW1_Eth1_2 a noria:NetworkInterface ;
    rdfs:label "ethernet1/2"@en ;
    rdfs:comment "Interface connecting Firewall 1 to the Internet uplink."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_ER1_Eth0_0_1 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/1"@en ;
    rdfs:comment "Interface connecting Edge Router Lyon to the corporate WAN."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouter1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -7 .

noria:NI_ER1_Eth0_0_2 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/2"@en ;
    rdfs:comment "Interface connecting Edge Router Lyon to the local office LAN."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouter1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_DB1_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Main network interface for Database Server 1."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer1 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_WebSrv1_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Main network interface for Web Server 1."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_VM_CRM_Eth0 a noria:NetworkInterface ;
