noria:AppMod_CRM_Prod noria:applicationModuleSupportGroup noria:Team_HelpDesk ;
    noria:applicationModuleHotlineGroup noria:Team_AppDev .

noria:AppMod_Internet_GW_Prod noria:applicationModuleSupportGroup noria:Team_NetOps ;
    noria:applicationModuleHotlineGroup noria:Team_SecOps .

