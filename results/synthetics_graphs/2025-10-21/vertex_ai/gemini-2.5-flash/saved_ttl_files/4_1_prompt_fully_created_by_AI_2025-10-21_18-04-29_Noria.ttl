@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix devopsprod: <http://w3id.org/devops-infra/product#> .

# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

# Organizational Units (Teams)
noria:Team_NetOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical incidents, call the on-call engineer directly. For non-critical, use ticketing system."@en .

noria:Team_AppDev a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit all requests via Jira Service Desk."@en .

noria:Team_SecOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team monitoring and responding to security threats."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/soc-platform> ;
    noria:agentInstructions "Alerts are automatically routed to the SIEM. For manual escalation, use the dedicated secure channel."@en .

noria:Team_DBA a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "Open a ticket for all database-related issues or requests."@en .

noria:Team_HelpDesk a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Help Desk"@en ;
    rdfs:comment "First-line support for all IT-related issues."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Users should call the help desk for immediate assistance."@en .

noria:Team_CloudOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Manages cloud infrastructure and services."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Use the internal chat for quick queries, ticketing system for formal requests."@en .

# Individual Agents
noria:Agent_Alice a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

noria:Agent_Bob a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Database Administrator."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> .

noria:Agent_Charlie a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    foaf:phone "+1-555-111-2222" ;
    noria:agentWorkingHours "24/7 Shift"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/soc-platform> .

noria:Agent_Eve a foaf:Person, foaf:Agent ;
    rdfs:label "Eve Davis"@en ;
    rdfs:comment "Cloud Architect."@en ;
    foaf:mbox <mailto:eve.davis@example.com> ;
    foaf:phone "+1-555-333-4444" ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server for data centers."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series Switch"@en ;
    rdfs:comment "Data center switch for high-density deployments."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_PaloAltoFW a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220 Firewall"@en ;
    rdfs:comment "Next-generation firewall for enterprise security."@en ;
    noria:productManufacturedBy noria:Org_PaloAlto .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor for virtualized environments."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:ProductModel_NetAppFAS a noria:ProductModel ;
    rdfs:label "NetApp FAS8200 Storage System"@en ;
    rdfs:comment "Unified storage system for enterprise data management."@en ;
    noria:productManufacturedBy noria:Org_NetApp .

noria:ProductModel_HPProLiantDL380 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10 Server"@en ;
    rdfs:comment "Versatile 2U rack server for various workloads."@en ;
    noria:productManufacturedBy noria:Org_HP .

# Manufacturers (org:Organization)
noria:Org_Dell a org:Organization, foaf:Agent ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:Org_Cisco a org:Organization, foaf:Agent ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

noria:Org_PaloAlto a org:Organization, foaf:Agent ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "American multinational cybersecurity company."@en .

noria:Org_VMware a org:Organization, foaf:Agent ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

noria:Org_NetApp a org:Organization, foaf:Agent ;
    rdfs:label "NetApp"@en ;
    rdfs:comment "Hybrid cloud data services and data management company."@en .

noria:Org_HP a org:Organization, foaf:Agent ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "American multinational enterprise information technology company."@en .

# =============================================================================
# Locations (noria:Room, noria:Locus, bot:Site)
# =============================================================================

noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center for European operations."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_LyonOffice a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office with local IT infrastructure."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    bot:hasElement noria:Resource_CoreRouter1, noria:Resource_DBServer1 ;
    seas:subSystemOf noria:Site_ParisDC .

noria:Room_NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace noria:Locus_RackB1 ;
    bot:hasElement noria:Resource_EdgeRouter1 ;
    seas:subSystemOf noria:Site_LyonOffice .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasElement noria:Resource_CoreRouter1, noria:Resource_DBServer1 ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasElement noria:Resource_WebSrv01, noria:Resource_Firewall1 ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_RackB1 a noria:Locus ;
    rdfs:label "Rack B1"@en ;
    rdfs:comment "Single rack in Network Closet B."@en ;
    noria:locusLine "B" ;
    noria:locusRow "1" ;
    bot:hasElement noria:Resource_EdgeRouter1 ;
    seas:subSystemOf noria:Room_NetworkClosetB .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_CoreRouter1 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Main router for the data center network."@en ;
    noria:resourceManagedBy noria:Team_NetOps ;
    noria:resourceLogisticId "CR1-DC-PAR-01" ;
    noria:resourceHostName "cr01.par.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "ABC12345DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_CorpIntranet, noria:App_InternetAccess ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://10.0.0.1> .

