@prefix prov: <http://www.w3.org/ns/prov#> .
@base <https://w3id.org/noria/data/> .

# =============================================================================
# KOS Concepts (minimal definitions for demonstration)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure"@en .
<kos/application/type/service-platform> a skos:Concept ; skos:prefLabel "Service Platform"@en .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring System"@en .
<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High"@en .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium"@en .
<kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en .
<kos/application/status/Staging> a skos:Concept ; skos:prefLabel "Staging"@en .
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en .
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:prefLabel "Failure"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:prefLabel "Assistance"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved"@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; skos:prefLabel "Closed"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:prefLabel "Customer Comment"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis"@en .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; skos:prefLabel "Resolution"@en .
<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server"@en .
<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine"@en .
<kos/Resource/LifecycleState/InUse> a skos:Concept ; skos:prefLabel "In Use"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:prefLabel "Decommissioned"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Up"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down"@en .
<kos/Resource/AdministrativeState/up> a skos:Concept ; skos:prefLabel "Up"@en .
<kos/Resource/AdministrativeState/down> a skos:Concept ; skos:prefLabel "Down"@en .
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en .
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; skos:prefLabel "Software Upgrade"@en .
<kos/ChangeRequest/category/ConfigurationChange> a skos:Concept ; skos:prefLabel "Configuration Change"@en .
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:prefLabel "Emergency Change"@en .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; skos:prefLabel "Configuration Change"@en .
<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ; skos:prefLabel "Preventative Maintenance"@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:prefLabel "Approved"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; skos:prefLabel "Implemented"@en .
<kos/ChangeRequest/status/Scheduled> a skos:Concept ; skos:prefLabel "Scheduled"@en .
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en .
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone"@en .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; skos:prefLabel "Ticketing System"@en .

# =============================================================================
# Agents (Teams and Individuals)
# =============================================================================

:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and support."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues."@en .

:Agent_NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical issues, call the hotline directly."@en .

:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Level 2 support for critical business applications."@en ;
    noria:agentWorkingHours "08:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate via ticketing system, then phone for urgent matters."@en .

:Agent_VirtualizationTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Virtualization Team"@en, "Équipe Virtualisation"@fr ;
    rdfs:comment "Team managing virtual infrastructure."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en .

:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead Engineer for DNS Infrastructure."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentManagesResource :Resource_DNS01, :Resource_VM_Web01 .

:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentManagesResource :Resource_Router01, :NetworkLink_WAN_ParisLyon .

:Agent_CustomerService a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Service"@en, "Service Client"@fr ;
    rdfs:comment "First point of contact for customer issues."@en .

# =============================================================================
# Locations
# =============================================================================

:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace :Locus_RackA1, :Locus_RackA2 ;
    bot:hasBuilding :Site_ParisDC .

:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en, "Baie A1"@fr ;
    rdfs:comment "Location for critical infrastructure servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace :Resource_DNS01, :Resource_WebSrv01 .

:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en, "Baie A2"@fr ;
    rdfs:comment "Location for application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasSpace :Resource_AppSrv01 .

:Site_LyonOffice a bot:Site ;
    rdfs:label "Lyon Office"@en, "Bureau de Lyon"@fr ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

:Room_NetworkRoom a noria:Room ;
    rdfs:label "Network Room"@en, "Salle Réseau"@fr ;
    rdfs:comment "Network equipment room in Lyon Office."@en ;
    bot:hasSpace :Locus_RouterRack ;
    bot:hasBuilding :Site_LyonOffice .

:Locus_RouterRack a noria:Locus ;
    rdfs:label "Router Rack"@en, "Baie Routeurs"@fr ;
    rdfs:comment "Rack containing network routers."@en ;
    noria:locusLine "R" ;
    noria:locusRow "1" ;
    bot:hasSpace :Resource_Router01 .

# =============================================================================
# Product Models
# =============================================================================

:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing."@en ;
    noria:productManufacturedBy :Org_Dell .

:ProductModel_CiscoASR1K a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Enterprise-grade router for WAN aggregation."@en ;
    noria:productManufacturedBy :Org_Cisco .

:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy :Org_VMware .

:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en .

:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en .

:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en .

# =============================================================================
# Resources
# =============================================================================

:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network in Paris DC."@en ;
    noria:resourceManagedBy :Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
    noria:resourceForApplication :Application_CorpDNS .

:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en, "Serveur Web 01"@fr ;
    rdfs:comment "Web server hosting the main corporate website."@en ;
    noria:resourceManagedBy :Agent_AppSupportTeam ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.20" ;
    noria:resourceForApplication :Application_CorpWebsite .

:Resource_AppSrv01 a noria:Resource ;
    rdfs:label "Application Server 01"@en, "Serveur Applicatif 01"@fr ;
    rdfs:comment "Server for critical business application backend."@en ;
    noria:resourceManagedBy :Agent_AppSupportTeam ;
    noria:resourceHostName "app01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-APP-01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.30" ;
    noria:resourceForApplication :Application_CRM .

:Resource_Router01 a noria:Resource ;
    rdfs:label "Edge Router Lyon"@en, "Routeur de Bordure Lyon"@fr ;
    rdfs:comment "Main router for Lyon office, connecting to WAN."@en ;
    noria:resourceManagedBy :Agent_NetworkOpsTeam ;
    noria:resourceHostName "lyon-rtr01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_CiscoASR1K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-11-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RouterRack ;
    noria:resourceManagementIPAddress "192.168.1.1" ;
    noria:resourceForApplication :Application_CorpWAN .

:Resource_VM_Web01 a noria:Resource ;
    rdfs:label "Virtual Web Server 01"@en, "Serveur Web Virtuel 01"@fr ;
    rdfs:comment "Virtual machine hosting a secondary web service."@en ;
    noria:resourceManagedBy :Agent_VirtualizationTeam ;
    noria:resourceHostName "vm-web01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-20T16:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.40" ;
    noria:resourceForApplication :Application_CorpWebsite ;
    noria:clusterController :Resource_Hypervisor01 . # Assuming a hypervisor resource

:Resource_Hypervisor01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en, "Hôte Hyperviseur 01"@fr ;
    rdfs:comment "Physical host running virtual machines."@en ;
    noria:resourceManagedBy :Agent_VirtualizationTeam ;
    noria:resourceHostName "hypervisor01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-HYP-01-JKL" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-08-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.50" .

# =============================================================================
# Network Interfaces
# =============================================================================

:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en, "DNS01 Ethernet 0"@fr ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf :Resource_DNS01 ;
    noria:networkInterfaceDescription "Management interface" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

:NetworkInterface_Router01_Gig0_0_0 a noria:NetworkInterface ;
    rdfs:label "Router01 Gig0/0/0"@en, "Routeur01 Gig0/0/0"@fr ;
    rdfs:comment "WAN uplink interface for Router01."@en ;
    noria:networkInterfaceOf :Resource_Router01 ;
    noria:networkInterfaceDescription "Uplink to WAN provider" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -8 .

:NetworkInterface_Router01_Gig0_0_1 a noria:NetworkInterface ;
    rdfs:label "Router01 Gig0/0/1"@en, "Routeur01 Gig0/0/1"@fr ;
    rdfs:comment "LAN interface for Router01, connecting to local network."@en ;
    noria:networkInterfaceOf :Resource_Router01 ;
    noria:networkInterfaceDescription "LAN segment for Lyon office" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

:NetworkInterface_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en, "WebSrv01 Ethernet 0"@fr ;
    rdfs:comment "Network interface for WebSrv01."@en ;
    noria:networkInterfaceOf :Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Web traffic interface" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links
# =============================================================================

:NetworkLink_WAN_ParisLyon a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-Lyon"@en, "Lien WAN Paris-Lyon"@fr ;
    rdfs:comment "Dedicated WAN link between Paris Data Center and Lyon Office."@en ;
    noria:networkLinkId "WAN-PL-001" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2021-10-20T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_NetworkOpsTeam ;
    noria:networkLinkTerminationResourceOrigin :Resource_Router01 ; # Simplified, typically connects to another router in Paris
    noria:networkLinkTerminationResourceDestination :Resource_Router01 ; # This is not ideal, should be two distinct resources
    noria:networkInterfaceConnects :NetworkInterface_Router01_Gig0_0_0 .

:NetworkLink_LAN_ParisDC_RackA1 a noria:NetworkLink ;
    rdfs:label "LAN Link Paris DC Rack A1"@en, "Lien LAN Paris DC Baie A1"@fr ;
    rdfs:comment "Internal LAN link within Rack A1 in Paris DC."@en ;
    noria:networkLinkId "LAN-PDC-RA1-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-10T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_NetworkOpsTeam ;
    noria:networkLinkTerminationResource :Resource_DNS01, :Resource_WebSrv01 ;
    noria:networkInterfaceConnects :NetworkInterface_DNS01_Eth0, :NetworkInterface_WebSrv01_Eth0 .

# =============================================================================
# Applications
# =============================================================================

:Application_CorpDNS a noria:Application ;
    rdfs:label "Corporate DNS Service"@en, "Service DNS d'Entreprise"@fr ;
    rdfs:comment "Critical service for internal and external name resolution."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "CORP-DNS" ;
    noria:applicationShortIdentifier "CDNS" ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Name Resolution" .

:Application_CorpWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en, "Site Web d'Entreprise"@fr ;
    rdfs:comment "Public-facing website for corporate information."@en ;
    noria:applicationType <kos/application/type/service-platform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationModelIdentifier "CORP-WEB" ;
    noria:applicationShortIdentifier "CWEB" ;
    noria:applicationFunctionalDomain "Marketing and Communication" .

:Application_CRM a noria:Application ;
    rdfs:label "Customer Relationship Management"@en, "Gestion Relation Client"@fr ;
    rdfs:comment "Internal application for managing customer interactions."@en ;
    noria:applicationType <kos/application/type/service-platform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "CRM-APP" ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationFunctionalDomain "Customer Management" .

:Application_CorpWAN a noria:Application ;
    rdfs:label "Corporate WAN Infrastructure"@en, "Infrastructure WAN d'Entreprise"@fr ;
    rdfs:comment "Provides connectivity between corporate sites."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "CORP-WAN" ;
    noria:applicationShortIdentifier "CWAN" ;
    noria:applicationFunctionalDomain "Network Connectivity" .

:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en, "Système de Supervision Central"@fr ;
    rdfs:comment "Collects and analyzes logs and metrics from all IT infrastructure."@en ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "MON-SYS" ;
    noria:applicationShortIdentifier "MON" .

# =============================================================================
# Application Modules
# =============================================================================

:ApplicationModule_CorpDNS_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en, "Module DNS d'Entreprise Production"@fr ;
    rdfs:comment "Production instance of the Corporate DNS Service."@en ;
    noria:applicationModuleOf :Application_CorpDNS ;
    noria:applicationModuleName "CORP-DNS_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ; # Assuming this concept exists
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam :Agent_DNSAdminTeam ;
    noria:applicationModuleSupportTeam :Agent_DNSAdminTeam .

:ApplicationModule_CorpWebsite_Staging a noria:ApplicationModule ;
    rdfs:label "Corporate Website Staging Module"@en, "Module Site Web Staging"@fr ;
    rdfs:comment "Staging environment for the Corporate Website."@en ;
    noria:applicationModuleOf :Application_CorpWebsite ;
    noria:applicationModuleName "CORP-WEB_STAGING" ;
    noria:applicationModuleIdentifier "STAGING" ;
    noria:applicationModuleStatus <kos/application/status/Staging> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleAdministrationTeam :Agent_AppSupportTeam .

:ApplicationModule_CRM_Prod a noria:ApplicationModule ;
    rdfs:label "CRM Production Module"@en, "Module CRM Production"@fr ;
    rdfs:comment "Production instance of the CRM application."@en ;
    noria:applicationModuleOf :Application_CRM ;
    noria:applicationModuleName "CRM-APP_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam :Agent_AppSupportTeam ;
    noria:applicationModuleSupportTeam :Agent_AppSupportTeam .

# =============================================================================
# Services
# =============================================================================

:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en, "Service Accès Internet Entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet access to all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> .

:Service_InterSiteConnectivity a noria:Service ;
    rdfs:label "Inter-Site Connectivity Service"@en, "Service Connectivité Inter-Sites"@fr ;
    rdfs:comment "Provides network connectivity between different corporate locations."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> .

# =============================================================================
# Event Records
# =============================================================================

:EventRecord_DNS_Down a noria:EventRecord ;
    rdfs:label "DNS Server Down Alert"@en, "Alerte Serveur DNS Hors Service"@fr ;
    rdfs:comment "Automated alert indicating primary DNS server is unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:logOriginatingManagedObject :Resource_DNS01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_Interface_Down a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en, "Alerte Interface Routeur Hors Service"@fr ;
    rdfs:comment "Alert for a critical network interface going down on Router01."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "LINK-3-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down" ;
    noria:logOriginatingManagedObject :Resource_Router01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_WebSrv_HighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Warning"@en, "Avertissement CPU Élevé Serveur Web"@fr ;
    rdfs:comment "Warning for sustained high CPU usage on WebSrv01."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU utilization on web01.corp.example.com is 95% for 10 minutes" ;
    noria:logOriginatingManagedObject :Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:EventRecord_User_LoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en, "Tentative de Connexion Échouée"@fr ;
    rdfs:comment "Log entry for a failed login attempt by a user."@en ;
    noria:loggingTime "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    noria:logText "Failed login for user 'jdoe' from IP 192.168.1.100" ;
    noria:logOriginatingManagedObject :Resource_AppSrv01 ;
    noria:logOriginatingAgent :Agent_JohnDoe ; # Assuming John Doe tried to log in
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

# =============================================================================
# Trouble Tickets
# =============================================================================

:TroubleTicket_DNSOutage_001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "Primary DNS server unreachable, impacting all corporate services."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketRelatedService :Application_CorpDNS ;
    noria:troubleTicketRelatedResource :Resource_DNS01 ;
    noria:troubleTicketRelatedParty :Agent_DNSAdminTeam, :Agent_JohnDoe ;
    noria:troubleTicketDescription "DNS server dns01.corp.example.com is not responding to queries. Services relying on DNS are affected."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :EventRecord_DNS_Down ;
    noria:documentHRef "https://ticketing.example.com/TT-DNS-001" ;
    noria:troubleTicketCause "Unknown, suspected network connectivity issue or server crash."@en .

:TroubleTicket_WANLinkDown_002 a noria:TroubleTicket ;
    rdfs:label "WAN Link Down Lyon Office"@en, "Lien WAN Bureau Lyon Hors Service"@fr ;
    rdfs:comment "WAN link to Lyon office is down, isolating the site."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketRelatedService :Application_CorpWAN, :Service_InterSiteConnectivity ;
    noria:troubleTicketRelatedResource :Resource_Router01, :NetworkLink_WAN_ParisLyon ;
    noria:troubleTicketRelatedParty :Agent_NetworkOpsTeam, :Agent_JaneSmith ;
    noria:troubleTicketDescription "The primary WAN link connecting Lyon office to Paris DC is down. Lyon users have no network access."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :EventRecord_Interface_Down ;
    noria:documentHRef "https://ticketing.example.com/TT-WAN-002" .

:TroubleTicket_WebPerformance_003 a noria:TroubleTicket ;
    rdfs:label "Corporate Website Performance Degradation"@en, "Dégradation Performance Site Web Entreprise"@fr ;
    rdfs:comment "Users report slow loading times for the corporate website."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketRelatedService :Application_CorpWebsite ;
    noria:troubleTicketRelatedResource :Resource_WebSrv01 ;
    noria:troubleTicketRelatedParty :Agent_AppSupportTeam, :Agent_CustomerService ;
    noria:troubleTicketDescription "Website is slow, high CPU on web server detected."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger :EventRecord_WebSrv_HighCPU ;
    noria:documentHRef "https://ticketing.example.com/TT-WEB-003" .

