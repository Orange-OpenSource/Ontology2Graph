:TroubleTicketNote_WAN_002_Note1 a noria:TroubleTicketNote ;
    rdfs:label "WAN Link Down Initial Check"@en, "Vérification Initiale Lien WAN Hors Service"@fr ;
    rdfs:comment "Confirmed physical link down on Gig0/0/0. Contacting ISP for line status."@en ;
    dcterms:isPartOf :TroubleTicket_WANLinkDown_002 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_JaneSmith .

