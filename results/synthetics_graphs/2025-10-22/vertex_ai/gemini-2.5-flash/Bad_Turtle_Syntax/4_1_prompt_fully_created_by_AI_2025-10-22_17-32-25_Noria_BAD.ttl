:TroubleTicketNote_DNS_001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Initial Diagnosis"@en, "Diagnostic Initial Panne DNS"@fr ;
    rdfs:comment "Initial checks confirm DNS service is not running on dns01. Attempting to restart service."@en ;
