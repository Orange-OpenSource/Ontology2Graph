@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# =============================================================================
# KOS Concepts (Controlled Vocabularies)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure"@en .
<kos/application/type/service-platform> a skos:Concept ; rdfs:label "Service Platform"@en .
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High"@en .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium"@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; rdfs:label "Maintenance"@en .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold"@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major"@en .
<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "P1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "P2"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision"@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis"@en .
<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ; rdfs:label "Total Breakdown"@en .
<kos/TroubleTicket/problemResponsibility/ManagedBackbone> a skos:Concept ; rdfs:label "Managed Backbone Networks"@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard"@en .
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention"@en .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented"@en .

<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server"@en .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine"@en .
<kos/Resource/LifecycleState/InUse> a skos:Concept ; rdfs:label "In Use"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned"@en .
<kos/Resource/AdministrativeState/up> a skos:Concept ; rdfs:label "Up"@en .
<kos/Resource/AdministrativeState/down> a skos:Concept ; rdfs:label "Down"@en .
<kos/Resource/OperationalState/up> a skos:Concept ; rdfs:label "Up"@en .
<kos/Resource/OperationalState/down> a skos:Concept ; rdfs:label "Down"@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning"@en .
<kos/Notification/EventType/stateChange> a skos:Concept ; rdfs:label "State Change"@en .
<kos/Notification/EventType/alarm> a skos:Concept ; rdfs:label "Alarm"@en .

<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone"@en .

<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email to dns-support@example.com for all issues."@en .

:Agent_NOC a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline +1-800-NOC-ALERT for critical issues."@en .

:Agent_InfraTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Infrastructure Team"@en ;
    rdfs:comment "Team managing physical and virtual server infrastructure."@en ;
    noria:agentWorkingHours "08:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit change requests via ITSM portal."@en .

:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead engineer for DNS services."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

:Site_DC1 a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate services."@en ;
    noria:siteId "DC1" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within DC1."@en ;
    bot:hasSpace :Locus_RackA1, :Locus_RackA2 ;
    bot:hasSubSpace :Site_DC1 . # Using bot:hasSubSpace to link Room to Site

:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing."@en ;
    noria:productManufacturedBy :Org_Dell .

:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Cisco data center switch series."@en ;
    noria:productManufacturedBy :Org_Cisco .

:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of Dell PowerEdge servers."@en .

:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in DC1."@en ;
    noria:resourceManagedBy :Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RackA1 ;
    noria:resourceManagementIPAddress observable:IPv4Address_192_168_1_10 ;
    noria:resourceForApplication :Application_CorpInternetAccess .

:Resource_RouterCore1 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Main router for internal network traffic in DC1."@en ;
    noria:resourceManagedBy :Agent_NOC ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTRC1-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RackA2 ;
    noria:resourceManagementIPAddress observable:IPv4Address_10_0_0_1 ;
    noria:resourceForApplication :Application_CorpInternetAccess .

:Resource_VMWeb01 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy :Agent_InfraTeam ;
    noria:resourceHostName "webvm01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication :Application_CorpWebsite .

observable:IPv4Address_192_168_1_10 a observable:IPv4Address ;
    rdfs:label "192.168.1.10"@en ;
    observable:ipAddressValue "192.168.1.10" .

observable:IPv4Address_10_0_0_1 a observable:IPv4Address ;
    rdfs:label "10.0.0.1"@en ;
    observable:ipAddressValue "10.0.0.1" .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

:NetIF_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on DNS01"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf :Resource_DNS01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceType "physical" .

:NetIF_RouterCore1_Gig0_0_1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on RouterCore1"@en ;
    rdfs:comment "Uplink interface from RouterCore1 to external network."@en ;
    noria:networkInterfaceOf :Resource_RouterCore1 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -7 ;
    noria:networkInterfaceType "physical" .

:NetIF_RouterCore1_Gig0_0_2 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/2 on RouterCore1"@en ;
    rdfs:comment "Interface from RouterCore1 to internal network."@en ;
    noria:networkInterfaceOf :Resource_RouterCore1 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 ;
    noria:networkInterfaceType "physical" .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

:NetLink_DNS01_Core1 a noria:NetworkLink ;
    rdfs:label "Link between DNS01 and RouterCore1"@en ;
    rdfs:comment "Internal network link connecting DNS01 to the core router."@en ;
    noria:networkLinkId "NL-DNS01-CORE1" ;
    noria:networkLinkTerminationResource :Resource_DNS01, :Resource_RouterCore1 ;
    noria:networkLinkTerminationResourceOrigin :Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination :Resource_RouterCore1 ;
    noria:networkLinkInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy :Agent_NOC ;
    noria:networkInterfaceConnects :NetIF_DNS01_Eth0, :NetIF_RouterCore1_Gig0_0_2 .

:NetLink_Core1_External a noria:NetworkLink ;
    rdfs:label "Uplink from RouterCore1 to ISP"@en ;
    rdfs:comment "External network link connecting RouterCore1 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-CORE1-ISP" ;
    noria:networkLinkTerminationResource :Resource_RouterCore1 ;
    noria:networkLinkInstallationDate "2021-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" ;
    noria:resourceManagedBy :Agent_NOC ;
    noria:networkInterfaceConnects :NetIF_RouterCore1_Gig0_0_1 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

:Application_CorpInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet access for all corporate users and services."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "DNS Resolution" .

:Application_CorpWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "Public-facing website for the company."@en ;
    noria:applicationType <kos/application/type/service-platform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Marketing" ;
    noria:applicationFunctionalSubDomain "Web Presence" .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

:AppModule_DNSProd a noria:ApplicationModule ;
    rdfs:label "DNS Production Module"@en ;
    rdfs:comment "Production instance of the DNS service."@en ;
    noria:applicationModuleOf :Application_CorpInternetAccess ;
    noria:applicationModuleName "DNS_PROD" ;
    noria:applicationModuleIdentifier "DNS-PROD-001" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleAdministrationTeam :Agent_DNSAdminTeam ;
    noria:applicationModuleSupportTeam :Agent_NOC ;
    noria:applicationModuleAdministrationLeader :Agent_JohnDoe ;
    noria:applicationModuleHotlineEnabled true .

:AppModule_WebProd a noria:ApplicationModule ;
    rdfs:label "Web Production Module"@en ;
    rdfs:comment "Production instance of the corporate website."@en ;
    noria:applicationModuleOf :Application_CorpWebsite ;
    noria:applicationModuleName "WEB_PROD" ;
    noria:applicationModuleIdentifier "WEB-PROD-001" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleAdministrationTeam :Agent_InfraTeam ;
    noria:applicationModuleSupportTeam :Agent_InfraTeam .

# =============================================================================
# Services (noria:Service)
# =============================================================================

:Service_EnterpriseConnectivity a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing network connectivity across the enterprise."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :AppModule_DNSProd, :AppModule_WebProd . # Linking ApplicationModules to Service

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

:Event_DNSOutageAlarm a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Alarm"@en ;
    rdfs:comment "Alarm triggered when DNS01 server became unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%"@en ;
    noria:logOriginatingManagedObject :Resource_DNS01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/alarm> .

:Event_InterfaceDownLog a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on RouterCore1 went down."@en ;
    noria:loggingTime "2024-04-10T08:59:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject :Resource_RouterCore1 ;
    noria:logOriginatingManagementSystem :Application_SyslogServer ;
    dcterms:type <kos/Notification/EventType/stateChange> .

:Event_DNSAdminLogin a noria:EventRecord ;
    rdfs:label "DNS Admin Login Event"@en ;
    rdfs:comment "Login event by DNS Admin Team to investigate DNS outage."@en ;
    noria:loggingTime "2024-04-10T09:15:00Z"^^xsd:dateTime ;
    noria:logText "User 'jdoe' logged in from 192.168.1.50 to dns01.corp.example.com"@en ;
    noria:logOriginatingManagedObject :Resource_DNS01 ;
    noria:logOriginatingAgent :Agent_JohnDoe ;
    noria:logOriginatingManagementSystem :Application_AuthServer .

:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "Application responsible for monitoring network devices."@en ;
    noria:applicationType <kos/application/type/infrastructure> .

:Application_SyslogServer a noria:Application ;
    rdfs:label "Central Syslog Server"@en ;
    rdfs:comment "Application collecting logs from various network devices."@en ;
    noria:applicationType <kos/application/type/infrastructure> .

:Application_AuthServer a noria:Application ;
    rdfs:label "Authentication Server"@en ;
    rdfs:comment "Server managing user authentication for IT systems."@en ;
    noria:applicationType <kos/application/type/service-platform> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "Critical DNS Server Outage"@en ;
    rdfs:comment "DNS01 server unreachable, impacting corporate internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketRelatedService :AppModule_DNSProd ;
    noria:troubleTicketRelatedResource :Resource_DNS01 ;
    noria:troubleTicketRelatedParty :Agent_NOC, :Agent_DNSAdminTeam ;
    noria:troubleTicketCause "Suspected network interface failure on DNS01."@en ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTrigger :Event_DNSOutageAlarm ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring" ;
    noria:documentHRef "https://itsm.example.com/tt/DNSOutage-20240410"^^xsd:anyURI ;
    noria:documentStatusHistory :Event_TT_StatusChange_InProgress .

:Event_TT_StatusChange_InProgress a noria:EventRecord ;
    rdfs:label "Trouble Ticket Status Change to In Progress"@en ;
    noria:loggingTime "2024-04-10T09:05:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket DNSOutage-20240410 status changed to InProgress."@en ;
    noria:logOriginatingManagementSystem :Application_ITSMSystem ;
    dcterms:type <kos/Notification/EventType/stateChange> .

:Application_ITSMSystem a noria:Application ;
    rdfs:label "IT Service Management System"@en ;
    rdfs:comment "System for managing incidents, problems, and changes."@en ;
    noria:applicationType <kos/application/type/service-platform> .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

:TTNote_DNSDiag1 a noria:TroubleTicketNote ;
    rdfs:label "Initial DNS Diagnosis Note"@en ;
    rdfs:comment "NOC confirmed DNS server unreachable. PING and SSH failed. Escalated to DNS Admin Team."@en ;
    dcterms:created "2024-04-10T09:10:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_NOC ;
    dcterms:isPartOf :TroubleTicket_DNSOutage ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

:TTNote_DNSDiag2 a noria:TroubleTicketNote ;
    rdfs:label "DNS Admin Investigation Note"@en ;
    rdfs:comment "John Doe from DNS Admin Team is investigating. Suspect network card issue on DNS01. Will attempt remote restart."@en ;
    dcterms:created "2024-04-10T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_JohnDoe ;
    dcterms:isPartOf :TroubleTicket_DNSOutage ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution :ProcExecContainer_DNSDiag .

:ProcExecContainer_DNSDiag a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS Diagnosis Procedure Execution"@en ;
    rdfs:comment "Container for actions taken during DNS diagnosis."@en ;
    pep:hasMember :Event_DNSAdminLogin .

# =============================================================================
# Change Requests (noria:ChangeRequest)
# =============================================================================

:ChangeRequest_DNSNICUpgrade a noria:ChangeRequest ;
    rdfs:label "DNS01 Network Interface Upgrade"@en ;
    rdfs:comment "Upgrade network interface card on DNS01 to improve reliability and performance."@en ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ; # Using SoftwareUpgrade as a placeholder for hardware upgrade, as no specific hardware upgrade cause is defined.
    noria:changeRequestImpact :Resource_DNS01, :NetIF_DNS01_Eth0 ;
    noria:changeRequestInitiatorParty :Agent_JohnDoe ;
    noria:changeRequestPilotParty :Agent_InfraTeam ;
    noria:changeRequestActorParty :Agent_InfraTeam ;
    noria:changeRequestPlannedStartTime "2024-04-20T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-20T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:documentHRef "https://itsm.example.com/cr/DNSNICUpgrade-20240415"^^xsd:anyURI ;
    noria:documentStatusHistory :Event_CR_StatusChange_Approved .

:Event_CR_StatusChange_Approved a noria:EventRecord ;
    rdfs:label "Change Request Status Change to Approved"@en ;
    noria:loggingTime "2024-04-15T15:00:00Z"^^xsd:dateTime ;
    noria:logText "Change Request DNSNICUpgrade-20240415 status changed to Approved."@en ;
    noria:logOriginatingManagementSystem :Application_ITSMSystem ;
    dcterms:type <kos/Notification/EventType/stateChange> .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

:OperationPlan_NICUpgrade a noria:OperationPlan ;
    rdfs:label "Network Interface Card Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading network interface cards on servers."@en ;
    noria:operationPlanPreCondition :PreCond_ServerMaintenanceWindow ;
    noria:operationPlanPostCondition :PostCond_NICFunctional .

:PreCond_ServerMaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Server Maintenance Window"@en ;
    rdfs:comment "Ensure the server is within an approved maintenance window to minimize service disruption."@en .

:PostCond_NICFunctional a noria:ActionPostCondition ;
    rdfs:label "New NIC Functional"@en ;
    rdfs:comment "Verify the new network interface card is installed, configured, and fully operational."@en .

# =============================================================================
# Connecting Change Request to Operation Plan
# =============================================================================

:ChangeAction_DNSNICUpgradeExecution a pep:ChangeAction ;
    rdfs:label "Execution of DNS NIC Upgrade"@en ;
    rdfs:comment "The actual execution of the NIC upgrade for DNS01."@en ;
    noria:actionCorrelatedOperationPlan :OperationPlan_NICUpgrade ;
    pep:hasInput :ChangeRequest_DNSNICUpgrade .

# Example of a resolved trouble ticket
:TroubleTicket_DNSOutage_Resolved a noria:TroubleTicket ;
    rdfs:label "Critical DNS Server Outage (Resolved)"@en ;
    rdfs:comment "DNS01 server unreachable, impacting corporate internet access. Resolved after NIC replacement."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketRelatedService :AppModule_DNSProd ;
    noria:troubleTicketRelatedResource :Resource_DNS01 ;
    noria:troubleTicketRelatedParty :Agent_NOC, :Agent_DNSAdminTeam ;
    noria:troubleTicketCause "Faulty network interface card."@en ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketDetectionDateTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-10T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-10T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-10T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackbone> ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring" ;
    noria:documentHRef "https://itsm.example.com/tt/DNSOutage-20240410-Resolved"^^xsd:anyURI ;
    noria:documentStatusHistory :Event_TT_StatusChange_Resolved ;
    noria:troubleTicketImpacts :Application_CorpInternetAccess, :Resource_DNS01 ;
    noria:troubleTicketIsNotificationEnable true .

:Event_TT_StatusChange_Resolved a noria:EventRecord ;
    rdfs:label "Trouble Ticket Status Change to Resolved"@en ;
    noria:loggingTime "2024-04-10T11:30:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket DNSOutage-20240410 status changed to Resolved. NIC replaced, service restored."@en ;
    noria:logOriginatingManagementSystem :Application_ITSMSystem ;
