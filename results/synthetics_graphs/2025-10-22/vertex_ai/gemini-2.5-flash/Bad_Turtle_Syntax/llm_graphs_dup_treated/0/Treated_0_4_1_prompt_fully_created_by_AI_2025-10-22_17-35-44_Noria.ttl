noria:Service_EnterpriseConnectivity_extra_node_3 a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing network connectivity for all corporate operations."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService_extra_node_3> ;
    seas:subSystemOf noria:ApplicationModule_CIA_Prod_extra_node_3 ; # Example of linking an AppModule to a Service
    seas:subSystemOf noria:ApplicationModule_DNS_Prod_extra_node_3 .

noria:Service_PublicWebPresence_extra_node_3 a noria:Service ;
    rdfs:label "Public Web Presence Service"@en ;
    rdfs:comment "Service ensuring the availability and performance of the corporate public website."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService_extra_node_3> ;
    seas:subSystemOf noria:ApplicationModule_WebPortal_Prod_extra_node_3 .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog_extra_node_3 a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_3 Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01_extra_node_3 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_3> .

noria:EventRecord_InterfaceDown_extra_node_3 a noria:EventRecord ;
    rdfs:label "Router_extra_node_3 Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical_extra_node_3 network interface on Core Router_extra_node_3 1 went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "ALERT: Interface Gi0/0/1 on router-core-01.corp.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1_extra_node_3 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_3> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckFiberLink_extra_node_3 .

noria:EventRecord_ConfigChange_extra_node_3 a noria:EventRecord ;
    rdfs:label "Router_extra_node_3 Configuration_extra_node_3 Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router_extra_node_3 1."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logText "INFO: Configuration_extra_node_3 changed by Jane Smith from console. Interface Gi0/0/1 shutdown."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1_extra_node_3 ;
    noria:logOriginatingAgent foaf:Agent_JaneSmith_extra_node_3 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational_extra_node_3> .

noria:EventRecord_VMCPUHigh_extra_node_3 a noria:EventRecord ;
    rdfs:label "VM CPU Usage High Alert"@en ;
    rdfs:comment "Alert for high_extra_node_3 CPU utilization on Web Server_extra_node_3 VM 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU usage on webvm01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_VMWeb01_extra_node_3 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_3> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket_DNSOutage_extra_node_3 a noria:TroubleTicket ;
    rdfs:label "DNS Server_extra_node_3 Outage Incident"@en ;
    rdfs:comment "Critical_extra_node_3 incident: Corporate DNS server is unreachable, impacting all services."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical_extra_node_3> ;
