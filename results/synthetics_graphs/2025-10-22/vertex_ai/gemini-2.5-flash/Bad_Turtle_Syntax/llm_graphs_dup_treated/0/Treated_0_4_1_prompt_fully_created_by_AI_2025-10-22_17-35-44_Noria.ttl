noria:Application_MonitoringSystem_extra_node_3 a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "System for collecting and analyzing logs and metrics from IT infrastructure_extra_node_3."@en ;
    noria:applicationType <kos/application/type/management-tool_extra_node_3> ;
