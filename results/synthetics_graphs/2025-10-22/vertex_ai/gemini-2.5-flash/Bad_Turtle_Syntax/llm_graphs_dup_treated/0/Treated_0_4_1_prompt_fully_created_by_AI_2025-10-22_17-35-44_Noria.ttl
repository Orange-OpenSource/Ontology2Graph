    noria:applicationFunctionalDomain "Core IT Services"@en ;
    noria:applicationFunctionalSubDomain "Identity and Naming Services"@en ;
    noria:applicationShortIdentifier "DNS" .

noria:Application_WebPortal_extra_node_3 a noria:Application ;
