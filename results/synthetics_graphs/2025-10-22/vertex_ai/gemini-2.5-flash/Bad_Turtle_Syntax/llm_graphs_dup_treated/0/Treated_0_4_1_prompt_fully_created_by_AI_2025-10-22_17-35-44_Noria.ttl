@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

foaf:Agent_DNSAdminTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_3> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical_extra_node_3 issues, use emergency hotline."@en .

foaf:Agent_NetworkOpsTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure_extra_node_3 and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_3> ;
    noria:agentInstructions "Immediate escalation for network outages. Use dedicated incident management platform."@en .

foaf:Agent_AppSupportTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2 support for critical_extra_node_3 business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system_extra_node_3> .

foaf:Agent_JohnDoe_extra_node_3 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for DNS Services."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_3> .

foaf:Agent_JaneSmith_extra_node_3 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network Engineer responsible for core routing."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_3> .

org:OrgUnit_ITOperations_extra_node_3 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Overall department for IT infrastructure_extra_node_3 and application operations."@en .

org:OrgUnit_SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_DataCenterA_extra_node_3 a bot:Site ;
    rdfs:label "Main Data Center A"@en ;
    noria:siteId "DC-A-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoom1_extra_node_3 a noria:Room ;
    rdfs:label "Server_extra_node_3 Room 1"@en ;
    rdfs:comment "Primary server room in Data Center A."@en ;
    bot:hasSpace noria:Locus_RackA1_extra_node_3 .

noria:Locus_RackA1_extra_node_3 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of core network and DNS servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_RackA2_extra_node_3 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740_extra_node_3 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us_extra_node_3> .

noria:ProductModel_CiscoASR1000_extra_node_3 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router_extra_node_3"@en ;
    rdfs:comment "Enterprise-class aggregation services router."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel_VMwareESXi_extra_node_3 a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com> .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01_extra_node_3 a noria:Resource ;
    rdfs:label "Corporate DNS Server_extra_node_3 01"@en ;
    rdfs:comment "Primary DNS server for internal and external resolution."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam_extra_node_3 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_3 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_3 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_10_extra_node_3 .

noria:Resource_RouterCore1_extra_node_3 a noria:Resource ;
    rdfs:label "Core Router_extra_node_3 1"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam_extra_node_3 ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000_extra_node_3 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTRC01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_3 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_1_extra_node_3 .

noria:Resource_AppServer01_extra_node_3 a noria:Resource ;
    rdfs:label "Application Server_extra_node_3 01"@en ;
    rdfs:comment "Server_extra_node_3 hosting critical_extra_node_3 business applications."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam_extra_node_3 ;
    noria:resourceHostName "appserver01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_3 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-APPS01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2022-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2_extra_node_3 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_20_extra_node_3 .

noria:Resource_VirtualHost01_extra_node_3 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server running multiple virtual machines."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam_extra_node_3 ;
    noria:resourceHostName "vhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_3 ;
    noria:resourceType <kos/Resource/type/hypervisor_extra_node_3> ;
    noria:resourceSerialNumber "SN-VHOST01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2023-02-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2_extra_node_3 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_30_extra_node_3 .

noria:Resource_VMWeb01_extra_node_3 a noria:Resource ;
    rdfs:label "Web Server_extra_node_3 VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam_extra_node_3 ;
    noria:resourceHostName "webvm01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi_extra_node_3 ; # The hypervisor_extra_node_3 model, not the VM itself
    noria:resourceType <kos/Resource/type/virtual-machine_extra_node_3> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2023-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_VirtualHost01_extra_node_3 ;
    noria:resourceManagementIPAddress observable:IPAddress_172_16_0_10_extra_node_3 .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface for DNS server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01_extra_node_3 ;
    noria:networkInterfaceDescription "Primary network interface for management and service traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_3> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_3> .

noria:NetworkInterface_RouterCore1_Gi0_0_0_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "router-core-01-Gi0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface connecting to internal network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1_extra_node_3 ;
    noria:networkInterfaceDescription "Internal_extra_node_3 LAN uplink."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_3> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_3> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterCore1_Gi0_0_1_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "router-core-01-Gi0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface connecting to external network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1_extra_node_3 ;
    noria:networkInterfaceDescription "External WAN uplink."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_3> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_3> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkInterface_AppServer01_Eth0_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "appserver01-eth0"@en ;
    rdfs:comment "Ethernet interface for Application Server_extra_node_3 01."@en ;
    noria:networkInterfaceOf noria:Resource_AppServer01_extra_node_3 ;
    noria:networkInterfaceDescription "Primary network interface for application traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_3> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_3> .

noria:NetworkInterface_VMWeb01_Eth0_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "webvm01-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Web Server_extra_node_3 VM 01."@en ;
    noria:networkInterfaceOf noria:Resource_VMWeb01_extra_node_3 ;
    noria:networkInterfaceDescription "Virtual network interface for web traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_3> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_3> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_LAN_Core_DNS_extra_node_3 a noria:NetworkLink ;
    rdfs:label "LAN Link Core-DNS"@en ;
    rdfs:comment "Internal_extra_node_3 LAN link between Core Router_extra_node_3 1 and DNS Server_extra_node_3 01."@en ;
    noria:networkLinkId "NL-LAN-001" ;
    noria:networkLinkType "Ethernet 10Gbps"@en ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore1_Gi0_0_0_extra_node_3 ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0_extra_node_3 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore1_extra_node_3 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DNS01_extra_node_3 .

noria:NetworkLink_WAN_External_extra_node_3 a noria:NetworkLink ;
    rdfs:label "WAN Link External"@en ;
    rdfs:comment "External WAN link from Core Router_extra_node_3 1 to ISP."@en ;
    noria:networkLinkId "NL-WAN-001" ;
    noria:networkLinkType "Fiber Optic 100Gbps"@en ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore1_Gi0_0_1_extra_node_3 ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore1_extra_node_3 ; # Assuming the other end is external and not modeled
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam_extra_node_3 .

noria:NetworkLink_LAN_App_VM_extra_node_3 a noria:NetworkLink ;
    rdfs:label "LAN Link App-VM"@en ;
    rdfs:comment "Internal_extra_node_3 LAN link between Application Server_extra_node_3 01 and Web Server_extra_node_3 VM 01 (via Virtual Host)."@en ;
    noria:networkLinkId "NL-LAN-002" ;
    noria:networkLinkType "Virtual Ethernet"@en ;
    noria:networkLinkInstallationDate "2023-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_AppServer01_Eth0_extra_node_3 ;
    noria:networkInterfaceConnects noria:NetworkInterface_VMWeb01_Eth0_extra_node_3 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_AppServer01_extra_node_3 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_VMWeb01_extra_node_3 .

