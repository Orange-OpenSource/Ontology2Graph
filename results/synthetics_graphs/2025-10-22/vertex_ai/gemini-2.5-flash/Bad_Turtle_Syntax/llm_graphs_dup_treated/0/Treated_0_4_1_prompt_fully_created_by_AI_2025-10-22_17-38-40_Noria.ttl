# =============================================================================

noria:NetworkLink_ISP_Uplink1_extra_node_2 a noria:NetworkLink ;
    rdfs:label "ISP Uplink 1"@en ;
    rdfs:comment "Physical link connecting RouterEdge01 to the Internet Service Provider."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam_extra_node_2 ;
