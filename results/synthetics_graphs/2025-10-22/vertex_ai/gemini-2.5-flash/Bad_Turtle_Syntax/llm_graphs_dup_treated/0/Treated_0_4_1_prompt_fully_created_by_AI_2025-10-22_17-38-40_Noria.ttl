noria:ProductModel_DellR740_extra_node_2 a noria:ProductModel ;
    rdfs:label "Dell_extra_node_2 PowerEdge R740"@en ;
    rdfs:comment "Dell_extra_node_2 server_extra_node_2 model used for various services."@en ;
    noria:productManufacturedBy <https://www.dell.com/org/Dell_extra_node_2> . # Assuming Dell_extra_node_2 is an org:Organization

noria:ProductModel_CiscoASR1000_extra_node_2 a noria:ProductModel ;
