# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01_extra_node_2 a noria:Resource ;
    rdfs:label "Corporate DNS Server_extra_node_2 01"@en ;
    rdfs:comment "Primary DNS server_extra_node_2 for corporate network, critical_extra_node_2 for internet access."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam_extra_node_2 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_2 ;
    noria:resourceType <kos/Resource/type/Server_extra_node_2> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack1A_extra_node_2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10_extra_node_2> .

noria:Resource_RouterEdge01_extra_node_2 a noria:Resource ;
    rdfs:label "Edge Router_extra_node_2 01"@en ;
    rdfs:comment "Main router_extra_node_2 connecting the corporate network to the internet."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam_extra_node_2 ;
    noria:resourceHostName "router_extra_node_2-edge01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000_extra_node_2 ;
    noria:resourceType <kos/Resource/type/Router_extra_node_2> ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack2B_extra_node_2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1_extra_node_2> .

noria:Resource_VMWeb01_extra_node_2 a noria:Resource ;
    rdfs:label "Web Application VM 01"@en ;
    rdfs:comment "Virtual machine hosting a critical_extra_node_2 web application."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam_extra_node_2 ;
    noria:resourceHostName "web01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi_extra_node_2 ; # The hypervisor_extra_node_2 model, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine_extra_node_2> ;
    noria:resourceSerialNumber "VM-WEB01-123" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:resourceInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack1A_extra_node_2 ; # Located on a physical server_extra_node_2 in this rack
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.10_extra_node_2> .

noria:Resource_ClusterController01_extra_node_2 a noria:Resource ;
    rdfs:label "Virtualization Cluster Controller 01"@en ;
    rdfs:comment "Controller for the virtualization cluster."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam_extra_node_2 ;
    noria:resourceHostName "vcenter01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server_extra_node_2> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:locatedAtLocus noria:Locus_Rack1A_extra_node_2 .

noria:Resource_VMWeb02_extra_node_2 a noria:Resource ;
    rdfs:label "Web Application VM 02"@en ;
    rdfs:comment "Secondary virtual machine hosting a critical_extra_node_2 web application, part of a cluster."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam_extra_node_2 ;
    noria:resourceHostName "web02.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi_extra_node_2 ;
    noria:resourceType <kos/Resource/type/VirtualMachine_extra_node_2> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:locatedAtLocus noria:Locus_Rack1A_extra_node_2 ;
    noria:clusterController noria:Resource_ClusterController01_extra_node_2 .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0_extra_node_2 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server_extra_node_2."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01_extra_node_2 ;
    noria:networkInterfaceDescription "Management and DNS traffic interface."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_2> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_2> .

noria:NetworkInterface_RouterEdge01_Gig0_0_0_extra_node_2 a noria:NetworkInterface ;
    rdfs:label "RouterEdge01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface to ISP for RouterEdge01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterEdge01_extra_node_2 ;
    noria:networkInterfaceDescription "ISP Uplink 1"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_2> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_2> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterEdge01_Gig0_0_1_extra_node_2 a noria:NetworkInterface ;
    rdfs:label "RouterEdge01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Internal_extra_node_2 network interface for RouterEdge01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterEdge01_extra_node_2 ;
    noria:networkInterfaceDescription "Internal_extra_node_2 LAN connection"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_2> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_2> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

