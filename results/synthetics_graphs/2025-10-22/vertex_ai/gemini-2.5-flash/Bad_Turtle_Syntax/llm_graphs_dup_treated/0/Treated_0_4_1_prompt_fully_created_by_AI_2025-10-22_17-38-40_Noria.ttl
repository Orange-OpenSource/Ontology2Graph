    rdfs:comment "Cisco router_extra_node_2 model for edge routing."@en ;
    noria:productManufacturedBy <https://www.cisco.com_extra_node_2/org/Cisco> . # Assuming Cisco is an org:Organization

noria:ProductModel_VMwareESXi_extra_node_2 a noria:ProductModel ;
