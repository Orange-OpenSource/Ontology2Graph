noria:Application_CorpInternetAccess_extra_node_2 a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet access for all corporate users and services."@en ;
    noria:applicationType <kos/application/type/infrastructure_extra_node_2> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high_extra_node_2> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Gateway Management" ;
    noria:applicationShortIdentifier "CIA" .

noria:Application_MonitoringSystem_extra_node_2 a noria:Application ;
