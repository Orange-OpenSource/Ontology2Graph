noria:OperationPlan_DNSUpgradeProcedure_extra_node_2 a noria:OperationPlan ;
    rdfs:label "DNS Server_extra_node_2 Upgrade Procedure"@en ;
    rdfs:comment "Standard_extra_node_2 operating procedure for upgrading DNS server_extra_node_2 software."@en ;
