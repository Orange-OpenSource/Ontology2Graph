bot:Site_DataCenterA a bot:Site ;
    rdfs:label "Main Data Center A"@en ;
    rdfs:comment "Primary data center facility."@en ;
    noria:siteId "DC-A-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoom1_extra_node_5 a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "Main server room within Data Center A."@en ;
    bot:hasSpace bot:Site_DataCenterA .

noria:Locus_RackA1_extra_node_5 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Specific rack location in Server Room 1."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoom1_extra_node_5 .

noria:Locus_RackA2_extra_node_5 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Specific rack location in Server Room 1."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasSpace noria:Room_ServerRoom1_extra_node_5 .

