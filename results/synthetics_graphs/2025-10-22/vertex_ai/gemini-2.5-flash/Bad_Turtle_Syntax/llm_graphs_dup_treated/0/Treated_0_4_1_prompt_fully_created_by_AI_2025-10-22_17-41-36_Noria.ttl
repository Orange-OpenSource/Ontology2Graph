noria:OperationPlan_CheckFiberLink_extra_node_5 a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Standard_extra_node_5 operating procedure to diagnose and troubleshoot fiber optic link issues."@en ;
    skos:example "1. Verify physical connection. 2. Check optical power levels. 3. Contact ISP if issue persists."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_LinkDown_extra_node_5 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LinkRestored_extra_node_5 .

noria:ActionPreCondition_LinkDown_extra_node_5 a noria:ActionPreCondition ;
    rdfs:label "Network Link Down Pre-Condition"@en ;
    rdfs:comment "Condition where a network link's operational status is 'down'."@en .

noria:ActionPostCondition_LinkRestored_extra_node_5 a noria:ActionPostCondition ;
    rdfs:label "Network Link Restored Post-Condition"@en ;
    rdfs:comment "Expected outcome: network link's operational status is 'up_extra_node_5' and traffic flows."@en .

noria:OperationPlan_DNSFailover_extra_node_5 a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Procedure to activate secondary DNS server in case of primary DNS failure."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable_extra_node_5 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSFunctional_extra_node_5 .

noria:ActionPreCondition_DNSUnreachable_extra_node_5 a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unreachable Pre-Condition"@en ;
    rdfs:comment "Condition where primary DNS server is not responding to queries."@en .

noria:ActionPostCondition_DNSFunctional_extra_node_5 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Functional Post-Condition"@en ;
    rdfs:comment "Expected outcome: DNS resolution is restored via secondary server."@en .

