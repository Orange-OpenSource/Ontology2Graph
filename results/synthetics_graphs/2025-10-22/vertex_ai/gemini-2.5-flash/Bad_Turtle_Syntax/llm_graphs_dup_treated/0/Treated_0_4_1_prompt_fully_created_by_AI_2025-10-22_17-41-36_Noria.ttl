# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

foaf:Agent_DNSAdminTeam_extra_node_5 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_5> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

foaf:Agent_NetworkOpsTeam_extra_node_5 a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure_extra_node_5."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Immediate phone call for any network outage. Use ticketing for routine changes."@en .

foaf:Agent_AppSupportL2_extra_node_5 a foaf:Agent ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support for critical business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing> ;
    noria:agentInstructions "Escalate from L1 via ticketing system. Direct contact only for P1_extra_node_5 incidents."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 Security Monitoring"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alert_system_extra_node_5> ;
    noria:agentInstructions "Automated alerts for critical security events. Manual review for suspicious activities."@en .

foaf:Agent_JohnDoe_extra_node_5 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual IT administrator."@en .

org:OrgUnit_ITInfrastructure_extra_node_5 a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en ;
    rdfs:comment "Department overseeing all IT infrastructure_extra_node_5 components."@en .

org:OrgUnit_AppDev_extra_node_5 a org:OrganizationalUnit ;
    rdfs:label "Application Development Unit"@en ;
    rdfs:comment "Unit responsible for developing and maintaining business applications."@en .

