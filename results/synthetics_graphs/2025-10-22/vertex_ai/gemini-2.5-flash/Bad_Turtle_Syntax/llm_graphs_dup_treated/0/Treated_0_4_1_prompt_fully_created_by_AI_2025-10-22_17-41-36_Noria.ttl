noria:EventRecord_DNSOutageLog_extra_node_5 a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: DNS server dns01.corp.example.com is unreachable via ping."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01_extra_node_5 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_5 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_5> .

noria:EventRecord_InterfaceDown_extra_node_5 a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical network interface went down."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "INTERFACE_STATUS: GigabitEthernet0/0/1 on router-core-01 changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1_extra_node_5 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_5 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_5> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckFiberLink_extra_node_5 .

noria:EventRecord_ConfigChange_extra_node_5 a noria:EventRecord ;
    rdfs:label "Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on a router."@en ;
    noria:loggingTime "2024-04-19T14:15:30Z"^^xsd:dateTime ;
    noria:logText "CONFIG_CHANGE: User_extra_node_5 'jdoe' applied configuration 'no shutdown interface Gi0/0/1'."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1_extra_node_5 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe_extra_node_5 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_5 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational_extra_node_5> .

