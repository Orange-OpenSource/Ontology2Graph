    rdfs:comment "Primary network interface for Web Server 03."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer03_extra_node_7 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up_extra_node_7> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up_extra_node_7> ;
    noria:networkInterfaceType "physical" .

noria:NI_DB01_Eth0_extra_node_7 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Primary network interface for DB Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01_extra_node_7 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up_extra_node_7> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up_extra_node_7> ;
    noria:networkInterfaceType "physical" .

noria:NI_LB01_PortA_extra_node_7 a noria:NetworkInterface ;
    rdfs:label "Port A"@en ;
    rdfs:comment "Frontend interface for Load Balancer 01."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01_extra_node_7 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up_extra_node_7> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up_extra_node_7> ;
    noria:networkInterfaceType "physical" .

noria:NI_LB01_PortB_extra_node_7 a noria:NetworkInterface ;
    rdfs:label "Port B"@en ;
    rdfs:comment "Backend interface for Load Balancer 01 connecting to web servers."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01_extra_node_7 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up_extra_node_7> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up_extra_node_7> ;
    noria:networkInterfaceType "physical" .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NL_CR01_Internet_extra_node_7 a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Internet Link"@en ;
    rdfs:comment "High-speed fiber link connecting the data center to the internet backbone."@en ;
    noria:networkLinkId "NL-CR01-INT-001" ;
    noria:networkInterfaceConnects noria:NI_CR01_Eth0_extra_node_7 ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter01_extra_node_7 ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime .

noria:NL_CR01_LB01_extra_node_7 a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Load Balancer 01 Link"@en ;
    rdfs:comment "Internal_extra_node_7 link between core router and load balancer."@en ;
    noria:networkLinkId "NL-CR01-LB01-001" ;
    noria:networkInterfaceConnects noria:NI_CR01_Eth1_extra_node_7, noria:NI_LB01_PortA_extra_node_7 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01_extra_node_7 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_LoadBalancer01_extra_node_7 ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2021-08-01T16:00:00Z"^^xsd:dateTime .

noria:NL_LB01_WS03_extra_node_7 a noria:NetworkLink ;
    rdfs:label "Load Balancer 01 to Web Server 03 Link"@en ;
    rdfs:comment "Link from load balancer to web server."@en ;
    noria:networkLinkId "NL-LB01-WS03-001" ;
    noria:networkInterfaceConnects noria:NI_LB01_PortB_extra_node_7, noria:NI_WS03_Eth0_extra_node_7 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_LoadBalancer01_extra_node_7 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_WebServer03_extra_node_7 ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime .

noria:NL_WS03_DB01_extra_node_7 a noria:NetworkLink ;
    rdfs:label "Web Server 03 to DB Server 01 Link"@en ;
    rdfs:comment "Internal_extra_node_7 link between web server and database server."@en ;
    noria:networkLinkId "NL-WS03-DB01-001" ;
    noria:networkInterfaceConnects noria:NI_WS03_Eth0_extra_node_7, noria:NI_DB01_Eth0_extra_node_7 ; # Assuming WS03_Eth0 connects to both LB and DB for simplicity, or another interface
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebServer03_extra_node_7 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DBServer01_extra_node_7 ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime .

