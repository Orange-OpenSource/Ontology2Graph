# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_CoreRouter01_extra_node_7 a noria:Resource ;
    rdfs:label "Core Router 01"@en, "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for inter-VLAN routing and external connectivity."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps_extra_node_7 ;
    noria:resourceHostName "cr01.parisdc.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K_extra_node_7 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_7> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Cabinet3_extra_node_7 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_1_extra_node_7 .

noria:Resource_WebServer03_extra_node_7 a noria:Resource ;
    rdfs:label "Web Server 03"@en, "Serveur Web 03"@fr ;
