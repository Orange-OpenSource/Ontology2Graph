    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up_extra_node_7> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up_extra_node_7> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceType "physical" .

noria:NI_CR01_Eth1_extra_node_7 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface for Core Router 01 connecting to Web Server 03."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01_extra_node_7 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up_extra_node_7> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up_extra_node_7> ;
    noria:networkInterfaceType "physical" .

