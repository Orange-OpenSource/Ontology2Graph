    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_7> ;
    noria:resourceInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12U_extra_node_7 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_1_3_extra_node_7 ;
    noria:resourceForApplication noria:App_CustomerPortal_extra_node_7 .

noria:Resource_DBServer01_extra_node_7 a noria:Resource ;
    rdfs:label "Database Server 01"@en, "Serveur Base de Données 01"@fr ;
    rdfs:comment "Primary database server for the internal CRM application."@en ;
    noria:resourceManagedBy noria:Agent_JohnDoe_extra_node_7 ;
    noria:resourceHostName "db01.crm.example.com" ;
    noria:resourceProductModel noria:ProductModel_HPProLiantDL380_extra_node_7 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_7> ;
    noria:resourceInstallationDate "2021-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack15U_extra_node_7 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_2_1_extra_node_7 ;
    noria:resourceForApplication noria:App_InternalCRM_extra_node_7 .

noria:Resource_VirtualHost01_extra_node_7 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en, "Hôte de Virtualisation 01"@fr ;
    rdfs:comment "Physical server running VMware ESXi for virtual machines."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps_extra_node_7 ;
    noria:resourceHostName "vh01.parisdc.example.com" ;
    noria:resourceProductModel noria:ProductModel_HPProLiantDL380_extra_node_7 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Hypervisor> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_7> ;
