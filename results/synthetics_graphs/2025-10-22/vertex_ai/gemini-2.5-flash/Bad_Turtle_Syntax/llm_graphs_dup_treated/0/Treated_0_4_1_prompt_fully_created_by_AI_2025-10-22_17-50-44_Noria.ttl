# --- Event Records (noria:EventRecord) ---
noria:EventRecord_HighCPUWeb01_extra_node_0 a noria:EventRecord ;
    rdfs:label "High CPU Alert Web01"@en ;
    rdfs:comment "Alert indicating high_extra_node_0 CPU utilization on web01.ecommerce.example.com."@en ;
    noria:loggingTime "2024-04-20T14:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on web01.ecommerce.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01_extra_node_0 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_0 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_0> .

noria:EventRecord_NetworkInterfaceDown_extra_node_0 a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert Router01"@en ;
    rdfs:comment "Alert indicating a network interface went down on Core Router_extra_node_0 01."@en ;
    noria:loggingTime "2024-04-20T14:10:00Z"^^xsd:dateTime ;
    noria:logText "Interface Gi0/1 on router01.dc.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01_extra_node_0 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_0 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_0> .

noria:EventRecord_TTStatusChangeInProgress_extra_node_0 a noria:EventRecord ;
