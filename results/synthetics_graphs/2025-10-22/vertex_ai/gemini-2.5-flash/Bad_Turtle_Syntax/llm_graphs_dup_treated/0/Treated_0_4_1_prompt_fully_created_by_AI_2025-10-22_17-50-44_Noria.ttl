    rdfs:label "E-commerce Platform Slowdown Incident_extra_node_0"@en ;
    rdfs:comment "Customers reporting slow response times on the E-commerce platform."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical_extra_node_0> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Incident_extra_node_0> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1_extra_node_0> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved_extra_node_0> ;
    noria:troubleTicketRelatedService noria:ApplicationModule_EcommerceProd_extra_node_0 ;
    noria:troubleTicketRelatedResource noria:Resource_WebServer01_extra_node_0 ;
