# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
foaf:Agent_DevOpsTeam_extra_node_0 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DevOps Team"@en ;
    rdfs:label "Équipe DevOps"@fr ;
    rdfs:comment "Team responsible for the E-commerce platform's development and operations."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> ;
    noria:agentInstructions "Contact via ticketing_extra_node_0 system for P1_extra_node_0/P2_extra_node_0 incidents."@en .

foaf:Agent_NetworkAdminTeam_extra_node_0 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Admin Team"@en ;
    rdfs:label "Équipe Administration Réseau"@fr ;
    rdfs:comment "Team responsible for managing network infrastructure_extra_node_0."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_0> ;
    noria:agentInstructions "Call hotline for critical_extra_node_0 network issues."@en .

foaf:Agent_JohnDoe_extra_node_0 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for the E-commerce Platform."@en ;
    foaf:mbox <mailto:john.doe@example.com_extra_node_0> .

foaf:Agent_JaneSmith_extra_node_0 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox <mailto:jane.smith@example.com_extra_node_0> .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
bot:Site_ParisDC_extra_node_0 a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "PAR-DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA_extra_node_0 a noria:Room ;
    rdfs:label "Server_extra_node_0 Room A"@en ;
    rdfs:comment "Primary server_extra_node_0 room within Paris Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1_extra_node_0 .

noria:Locus_RackA1_extra_node_0 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical_extra_node_0 web servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_RackA2_extra_node_0 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of database servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

