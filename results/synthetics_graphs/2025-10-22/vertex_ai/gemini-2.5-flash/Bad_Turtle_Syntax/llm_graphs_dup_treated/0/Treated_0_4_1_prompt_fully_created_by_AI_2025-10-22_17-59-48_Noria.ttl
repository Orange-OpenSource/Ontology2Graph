# =============================================================================
# Agents (foaf:Agent & org:OrganizationalUnit)
# =============================================================================

<agent/DNSAdminTeam_extra_node_1> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server_extra_node_1 management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Contact via ticketing system for non-critical_extra_node_1 issues, direct call for critical_extra_node_1 outages."@en .

<agent/NOCSupportTeam_extra_node_1> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "NOC Support Team"@en ;
    rdfs:comment "Network Operations Center team, 24/7 monitoring_extra_node_1 and first-level incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_1> ;
    noria:agentInstructions "Always call the hotline for any network-related incident."@en .

<agent/NetworkOpsTeam_extra_node_1> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team for network infrastructure_extra_node_1 changes and complex troubleshooting."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_1> ;
    noria:agentInstructions "Submit a Change Request for any planned intervention."@en .

<agent/JohnDoe_extra_node_1> a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the DNS Admin Team."@en ;
    foaf:mbox <mailto:john.doe@example.com_extra_node_1> ;
    foaf:phone_extra_node_1 "+1-555-123-4567" .

<agent/JaneSmith_extra_node_1> a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the NOC Support Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com_extra_node_1> ;
    foaf:phone_extra_node_1 "+1-555-987-6543" .

