<changerequest/CR-20240120-001_extra_node_1> a noria:ChangeRequest ;
    rdfs:label "Replace Faulty Fiber Optic Link to ISP"@en ;
    rdfs:comment "Emergency_extra_node_1 change request to replace the fiber optic link connected to CR01 GigE 0/0/1 due to physical damage."@en ;
