<actionpostcondition/VerifyLinkRestored_extra_node_1> a noria:ActionPostCondition ;
    rdfs:label "Verify Link Restored"@en ;
    rdfs:comment "Confirm that the new link is operational and traffic is flowing."@en .

<changerequest/CR-20240120-001_extra_node_1> pep:usedProcedure <operationplan/FiberReplacementProcedure_extra_node_1> .

