    rdfs:comment "Procedure to restart the DNS service on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSServiceNotResponding ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSServiceRunning .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition_LinkDown a noria:ActionPreCondition ;
    rdfs:label "Network Link is Down"@en ;
    rdfs:comment "Condition: A network link's operational status is 'down'."@en .

noria:ActionPostCondition_LinkStatusConfirmed a noria:ActionPostCondition ;
    rdfs:label "Network Link Status Confirmed"@en ;
    rdfs:comment "Outcome: The cause of the link status (up_extra_node_3/down) has been identified and confirmed."@en .

noria:ActionPreCondition_DNSServiceNotResponding a noria:ActionPreCondition ;
    rdfs:label "DNS Service Not Responding"@en ;
    rdfs:comment "Condition: DNS queries to the server are failing."@en .

noria:ActionPostCondition_DNSServiceRunning a noria:ActionPostCondition ;
    rdfs:label "DNS Service Running"@en ;
    rdfs:comment "Outcome: DNS service process is running and responding to queries."@en .

