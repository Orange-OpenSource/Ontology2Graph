@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

# =============================================================================
# KOS Concepts (Knowledge Organization System)
# These are used as ranges for various properties and must be defined.
# =============================================================================

<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application providing core infrastructure services."@en .

<kos/application/type/business> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "An application supporting specific business processes."@en .

<kos/application/type/monitoring> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "An application used for monitoring IT systems."@en .

<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

<kos/application/business-importance/high> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en .

<kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction_extra_node_2> a skos:Concept ;
    skos:inScheme <kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:label "En Production"@fr .

<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ;
    skos:inScheme <kos/application/status> ;
    rdfs:label "In Maintenance"@en ;
    rdfs:label "En Maintenance"@fr .

<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical_extra_node_2> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical_extra_node_2 Severity"@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor Severity"@en .

<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of trouble tickets."@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en .

<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System"@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Report"@en .

<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of comments in trouble ticket notes."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en .

<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of operation described in trouble ticket notes."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation"@en .

<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of change requests."@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en .

<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying the cause of change requests."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en .

<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of IT resources."@en .

<kos/Resource/type/Server> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en .

<kos/Resource/type/Router> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en .

<kos/Resource/type/VirtualMachine> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Virtual Machine"@en .

<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying the lifecycle state of resources."@en .

<kos/Resource/LifecycleState/InProduction_extra_node_2> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Production"@en .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Decommissioned"@en .

<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of resources."@en .

<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en .

<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of resources."@en .

<kos/Resource/AdministrativeState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Up"@en .

<kos/Resource/AdministrativeState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Down"@en .

<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the perceived severity of notifications."@en .

<Notification/Severity/PerceivedSeverity/Critical_extra_node_2> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical_extra_node_2"@en .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Major"@en .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning"@en .

<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

noria:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'Administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

noria:Agent_NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for network infrastructure operations and changes."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call the NOC for network-related incidents."@en .

noria:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket for all application issues."@en .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the DNS Admin Team."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Network Operations Team."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace noria:Locus_Rack1A ;
    bot:hasSpace noria:Locus_Rack2B ;
    seas:subSystemOf noria:Site_MainDC .

noria:Locus_Rack1A a noria:Locus ;
    rdfs:label "Rack 1A"@en ;
    rdfs:comment "Location of critical servers in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_Rack2B a noria:Locus ;
    rdfs:label "Rack 2B"@en ;
    rdfs:comment "Location of network equipment in Server Room A."@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" ;
    seas:subSystemOf noria:Room_ServerRoomA .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various services."@en ;
    noria:productManufacturedBy <https://www.dell.com/org/Dell> . # Assuming Dell is an org:Organization

noria:ProductModel_CiscoASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Cisco router model for edge routing."@en ;
    noria:productManufacturedBy <https://www.cisco.com/org/Cisco> . # Assuming Cisco is an org:Organization

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy <https://www.vmware.com/org/VMware> . # Assuming VMware is an org:Organization

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, critical for internet access."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack1A ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_RouterEdge01 a noria:Resource ;
    rdfs:label "Edge Router 01"@en ;
    rdfs:comment "Main router connecting the corporate network to the internet."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-edge01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack2B ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_VMWeb01 a noria:Resource ;
    rdfs:label "Web Application VM 01"@en ;
    rdfs:comment "Virtual machine hosting a critical web application."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "web01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-WEB01-123" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:resourceInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack1A ; # Located on a physical server in this rack
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.10> .

noria:Resource_ClusterController01 a noria:Resource ;
    rdfs:label "Virtualization Cluster Controller 01"@en ;
    rdfs:comment "Controller for the virtualization cluster."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:resourceHostName "vcenter01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:locatedAtLocus noria:Locus_Rack1A .

noria:Resource_VMWeb02 a noria:Resource ;
    rdfs:label "Web Application VM 02"@en ;
    rdfs:comment "Secondary virtual machine hosting a critical web application, part of a cluster."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "web02.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:locatedAtLocus noria:Locus_Rack1A ;
    noria:clusterController noria:Resource_ClusterController01 .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Management and DNS traffic interface."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_RouterEdge01_Gig0_0_0 a noria:NetworkInterface ;
    rdfs:label "RouterEdge01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface to ISP for RouterEdge01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterEdge01 ;
    noria:networkInterfaceDescription "ISP Uplink 1"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterEdge01_Gig0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterEdge01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Internal network interface for RouterEdge01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterEdge01 ;
    noria:networkInterfaceDescription "Internal LAN connection"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_ISP_Uplink1 a noria:NetworkLink ;
    rdfs:label "ISP Uplink 1"@en ;
    rdfs:comment "Physical link connecting RouterEdge01 to the Internet Service Provider."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:networkLinkId "NL-ISP-001" ;
    noria:networkLinkTerminationResource noria:Resource_RouterEdge01 ;
    noria:networkLinkInstallationDate "2021-03-20T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" .

noria:NetworkLink_Internal_LAN_DC01 a noria:NetworkLink ;
    rdfs:label "Internal LAN DC01"@en ;
    rdfs:comment "Internal network link within Data Center 01."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:networkLinkId "NL-LAN-DC01" ;
    noria:networkLinkTerminationResource noria:Resource_RouterEdge01 ;
    noria:networkLinkTerminationResource noria:Resource_DNS01 ;
    noria:networkLinkInstallationDate "2022-01-10T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" .

noria:NetworkInterface_RouterEdge01_Gig0_0_0 noria:networkInterfaceConnects noria:NetworkLink_ISP_Uplink1 .
noria:NetworkInterface_RouterEdge01_Gig0_0_1 noria:networkInterfaceConnects noria:NetworkLink_Internal_LAN_DC01 .
noria:NetworkInterface_DNS01_Eth0 noria:networkInterfaceConnects noria:NetworkLink_Internal_LAN_DC01 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application_CorpInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet access for all corporate users and services."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Gateway Management" ;
    noria:applicationShortIdentifier "CIA" .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "System responsible for collecting and analyzing logs and metrics from IT infrastructure."@en ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationShortIdentifier "CMS" .

noria:Application_WebAppPortal a noria:Application ;
    rdfs:label "Customer Web Portal"@en ;
    rdfs:comment "Public-facing web application for customer interactions."@en ;
    noria:applicationType <kos/application/type/business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationShortIdentifier "CWP" .

# Link resources to applications
noria:Resource_DNS01 noria:resourceForApplication noria:Application_CorpInternetAccess .
noria:Resource_RouterEdge01 noria:resourceForApplication noria:Application_CorpInternetAccess .
noria:Resource_VMWeb01 noria:resourceForApplication noria:Application_WebAppPortal .
noria:Resource_VMWeb02 noria:resourceForApplication noria:Application_WebAppPortal .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

noria:ApplicationModule_CIA_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate Internet Access Production Module"@en ;
    rdfs:comment "Production instance of the Corporate Internet Access application."@en ;
    noria:applicationModuleOf noria:Application_CorpInternetAccess ;
    noria:applicationModuleName "CIA_Prod" ;
    noria:applicationModuleIdentifier "CIA-PROD-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction_extra_node_2> ;
    noria:applicationModuleAdministrationTeam noria:Agent_NetworkOpsTeam ;
    noria:applicationModuleSupportTeam noria:Agent_NetworkOpsTeam ;
    noria:applicationModuleAdministrationLeader noria:Agent_JaneSmith ;
    noria:applicationModuleHotlineEnabled true .

noria:ApplicationModule_CWP_Prod a noria:ApplicationModule ;
    rdfs:label "Customer Web Portal Production Module"@en ;
    rdfs:comment "Production instance of the Customer Web Portal application."@en ;
    noria:applicationModuleOf noria:Application_WebAppPortal ;
    noria:applicationModuleName "CWP_Prod" ;
    noria:applicationModuleIdentifier "CWP-PROD-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction_extra_node_2> ;
    noria:applicationModuleAdministrationTeam noria:Agent_AppSupportTeam ;
    noria:applicationModuleSupportTeam noria:Agent_AppSupportTeam ;
    noria:applicationModuleHotlineEnabled false .

# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service_EnterpriseConnectivity a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing network connectivity for the enterprise."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> .

noria:Service_WebHosting a noria:Service ;
    rdfs:label "Web Hosting Service"@en ;
    rdfs:comment "Service providing infrastructure for hosting web applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> .

# Link Application Modules to Services (using seas:subSystemOf as per NORIA guidance)
noria:ApplicationModule_CIA_Prod seas:subSystemOf noria:Service_EnterpriseConnectivity .
noria:ApplicationModule_CWP_Prod seas:subSystemOf noria:Service_WebHosting .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_2> .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical interface on the edge router went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on router-edge01.corp.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterEdge01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_VMWeb01HighCPU a noria:EventRecord ;
    rdfs:label "VMWeb01 High CPU Warning"@en ;
    rdfs:comment "Warning log for high CPU utilization on VMWeb01."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: VM web01.app.example.com CPU usage exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_VMWeb01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket_DNSOutage001 a noria:TroubleTicket ;
    rdfs:label "Critical_extra_node_2 DNS Server Outage"@en ;
    rdfs:comment "Primary DNS server is unreachable, impacting corporate internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical_extra_node_2> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application_CorpInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty noria:Agent_DNSAdminTeam ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:01:00Z"^^xsd:dateTime ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketCause "Unknown at detection, suspected network connectivity issue."@en ;
    noria:documentExternalId "TT-20240420-001" ;
    noria:documentHRef "http://ticketing.example.com/TT-20240420-001" .

noria:TroubleTicket_WebAppPerformance001 a noria:TroubleTicket ;
    rdfs:label "Web Portal Slow Performance"@en ;
    rdfs:comment "Customers reporting slow loading times for the web portal."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application_WebAppPortal ;
    noria:troubleTicketRelatedResource noria:Resource_VMWeb01 ;
    noria:troubleTicketRelatedParty noria:Agent_AppSupportTeam ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketCause "High CPU on VMWeb01, investigating root cause."@en ;
    noria:documentExternalId "TT-20240420-002" ;
    noria:documentHRef "http://ticketing.example.com/TT-20240420-002" .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote_DNSFixAttempt a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Initial Diagnosis and Action"@en ;
    rdfs:comment "Initial diagnosis points to a network link issue. Temporarily rerouted DNS traffic via secondary link. Service partially restored."@en ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage001 ; # Using dcterms:isPartOf as per schema alignment
    dcterms:created "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote_WebAppScaling a noria:TroubleTicketNote ;
    rdfs:label "Web Portal Scaling Action"@en ;
    rdfs:comment "Increased CPU and RAM for VMWeb01. Performance improved, but still monitoring."@en ;
    dcterms:isPartOf noria:TroubleTicket_WebAppPerformance001 ;
    dcterms:created "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_AppSupportTeam ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

# =============================================================================
# Change Requests (noria:ChangeRequest)
# =============================================================================

noria:ChangeRequest_DNSUpgrade001 a noria:ChangeRequest ;
    rdfs:label "DNS Server Software Upgrade"@en ;
    rdfs:comment "Upgrade DNS server software to latest stable version to address known vulnerabilities and improve performance."@en ;
    noria:changeRequestPlannedStartTime "2024-05-10T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-10T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_DNS01 ;
    noria:changeRequestImpact noria:Application_CorpInternetAccess ;
    noria:changeRequestInitiatorParty noria:Agent_DNSAdminTeam ;
    noria:changeRequestPilotParty noria:Agent_JohnDoe ;
    noria:changeRequestActorParty noria:Agent_NetworkOpsTeam ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:documentExternalId "CR-20240510-001" ;
    noria:documentHRef "http://changemgmt.example.com/CR-20240510-001" .

noria:ChangeRequest_RouterFirmwareUpdate a noria:ChangeRequest ;
    rdfs:label "Edge Router Firmware Update"@en ;
    rdfs:comment "Apply critical firmware update to Edge Router 01 to enhance security and stability."@en ;
    noria:changeRequestPlannedStartTime "2024-05-15T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-15T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_RouterEdge01 ;
    noria:changeRequestImpact noria:Application_CorpInternetAccess ;
    noria:changeRequestInitiatorParty noria:Agent_NetworkOpsTeam ;
    noria:changeRequestPilotParty noria:Agent_JaneSmith ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ; # 1 hour 30 minutes
    noria:documentExternalId "CR-20240515-002" ;
    noria:documentHRef "http://changemgmt.example.com/CR-20240515-002" .

# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan_DNSUpgradeProcedure a noria:OperationPlan ;
    rdfs:label "DNS Server Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading DNS server software."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSBackup ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSServiceRestored .

noria:ActionPreCondition_DNSBackup a noria:ActionPreCondition ;
    rdfs:label "DNS Configuration Backup Completed"@en ;
    rdfs:comment "Ensure a full backup of DNS configuration and data is completed before starting the upgrade."@en .

noria:ActionPostCondition_DNSServiceRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Fully Restored and Verified"@en ;
    rdfs:comment "Verify DNS resolution is fully functional and stable after the upgrade."@en .

# Link Change Request to Operation Plan
noria:ChangeRequest_DNSUpgrade001 pep:usedProcedure noria:OperationPlan_DNSUpgradeProcedure .

# Example of a corrective maintenance action (implicitly linked via pep:ProcedureExecutionContainer)
# A TroubleTicket is a pep:ProcedureExecutionContainer.
# An EventRecord is a pep:ProcedureExecution.
# So, an EventRecord can be a member of a TroubleTicket's execution container.
noria:TroubleTicket_DNSOutage001 pep:member noria:EventRecord_DNSOutageLog .
noria:TroubleTicket_WebAppPerformance001 pep:member noria:EventRecord_VMWeb01HighCPU .

# Example of document status history
noria:EventRecord_TT_DNSOutage001_StatusChange_Resolved a noria:EventRecord ;
    rdfs:label "DNS Outage Ticket Status Change to Resolved"@en ;
    noria:loggingTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240420-001 status changed to Resolved."@en ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent noria:Agent_JohnDoe .

noria:TroubleTicket_DNSOutage001 noria:documentStatusHistory noria:EventRecord_TT_DNSOutage001_StatusChange_Resolved .

