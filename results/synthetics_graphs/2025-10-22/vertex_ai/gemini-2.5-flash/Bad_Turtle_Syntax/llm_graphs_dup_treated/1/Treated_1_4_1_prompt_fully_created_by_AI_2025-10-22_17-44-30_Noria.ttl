noria:ApplicationModule_CRM_Dev a noria:ApplicationModule ;
    rdfs:label "CRM System Development Module"@en ;
    rdfs:label "Module de Développement Système CRM"@fr ;
    rdfs:comment "Development instance of the CRM System application."@en ;
    noria:applicationModuleOf noria:Application_CRMSystem ;
    noria:applicationModuleName "CRM_DEV" ;
    noria:applicationModuleIdentifier "DEV-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
