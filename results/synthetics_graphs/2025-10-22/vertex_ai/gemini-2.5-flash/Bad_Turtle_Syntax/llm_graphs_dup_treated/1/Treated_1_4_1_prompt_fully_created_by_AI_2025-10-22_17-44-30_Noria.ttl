    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam noria:Agent_NetworkOps ;
    noria:applicationModuleSupportTeam noria:Agent_NetworkOps ;
    noria:applicationModuleAdministrationLeader noria:Agent_JaneSmith .

noria:ApplicationModule_CRM_Prod a noria:ApplicationModule ;
    rdfs:label "CRM System Production Module"@en ;
    rdfs:label "Module de Production Système CRM"@fr ;
    rdfs:comment "Production instance of the CRM System application."@en ;
    noria:applicationModuleOf noria:Application_CRMSystem ;
    noria:applicationModuleName "CRM_PROD" ;
    noria:applicationModuleIdentifier "PROD-02" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction_extra_node_4> ;
