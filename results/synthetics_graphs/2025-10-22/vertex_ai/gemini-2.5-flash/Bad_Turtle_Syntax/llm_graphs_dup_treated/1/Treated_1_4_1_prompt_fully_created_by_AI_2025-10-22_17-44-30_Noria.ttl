# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_RestartInterface a noria:OperationPlan ;
    rdfs:label "Network Interface Restart Procedure"@en ;
    rdfs:label "Procédure de Redémarrage d'Interface Réseau"@fr ;
    rdfs:comment "Standard operating procedure for restarting a network interface on a router."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:OperationPlan_DNSCheck a noria:OperationPlan ;
    rdfs:label "DNS Service Health Check"@en ;
    rdfs:comment "Procedure to verify the operational status and responsiveness of DNS services."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSResponding .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: The network interface reports an operational status of 'down'."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface reports an operational status of 'up_extra_node_4' and traffic flows."@en .

noria:ActionPreCondition_DNSUnreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS queries fail or timeout for the specified server."@en .

noria:ActionPostCondition_DNSResponding a noria:ActionPostCondition ;
    rdfs:label "DNS Service Responding"@en ;
    rdfs:comment "Expected outcome: DNS queries to the server are successful and timely."@en .

