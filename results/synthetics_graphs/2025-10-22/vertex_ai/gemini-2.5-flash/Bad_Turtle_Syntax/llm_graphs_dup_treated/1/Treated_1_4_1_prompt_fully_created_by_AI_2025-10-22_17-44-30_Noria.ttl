    rdfs:label "Resolution Attempt Note for TT001"@en ;
    rdfs:comment "Restarted network interface on Core Router 01. DNS service restored."@en ;
    dcterms:created "2024-04-20T09:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JaneSmith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
