@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix time: <http://www.w3.org/2006/time#> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person)
# =============================================================================

noria:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and support."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

noria:Agent_NetworkOps a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:label "Centre d'Opérations Réseau"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

noria:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team A"@en ;
    rdfs:label "Équipe de Développement Applicatif A"@fr ;
    rdfs:comment "Team responsible for developing and maintaining critical business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en .

noria:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cyber Security Operations"@en ;
    rdfs:label "Opérations de Cybersécurité"@fr ;
    rdfs:comment "Team dedicated to monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en .

noria:Agent_JohnDoe a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:label "Jean Dupont"@fr ;
    rdfs:comment "Lead administrator for DNS services."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

noria:Agent_JaneSmith a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:label "Jeanne Martin"@fr ;
    rdfs:comment "Network engineer responsible for core routing."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria:Site_DataCenterParis a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center location for corporate services."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack1A .

noria:Locus_Rack1A a noria:Locus ;
    rdfs:label "Rack 1A"@en ;
    rdfs:label "Baie 1A"@fr ;
    rdfs:comment "Specific rack location for critical infrastructure."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_Rack2B a noria:Locus ;
    rdfs:label "Rack 2B"@en ;
    rdfs:label "Baie 2B"@fr ;
    rdfs:comment "Rack location for application servers."@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> .

noria:ProductModel_CiscoASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series"@en ;
    rdfs:comment "Carrier-grade aggregation services router."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> .

<http://www.dell.com/organization> a org:Organization ;
    rdfs:label "Dell Technologies"@en .

<http://www.cisco.com/organization> a org:Organization ;
    rdfs:label "Cisco Systems"@en .

<http://www.vmware.com/organization> a org:Organization ;
    rdfs:label "VMware Inc."@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, physical host."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_4> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack1A ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for the corporate backbone network."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_4> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack1A ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_AppServerVM01 a noria:Resource ;
    rdfs:label "Application Server VM 01"@en ;
    rdfs:label "VM Serveur Applicatif 01"@fr ;
    rdfs:comment "Virtual machine hosting a critical business application."@en ;
    noria:resourceManagedBy noria:Agent_AppDevTeam ;
    noria:resourceHostName "appvm01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself, but it's a valid link.
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_4> ;
    noria:resourceInstallationDate "2023-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.10> .

noria:Resource_LoadBalancer01 a noria:Resource ;
    rdfs:label "Load Balancer 01"@en ;
    rdfs:label "Équilibreur de Charge 01"@fr ;
    rdfs:comment "Hardware load balancer for web services."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "lb01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/load-balancer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_4> ;
    noria:locatedAtLocus noria:Locus_Rack2B ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.50> .

noria:Resource_ClusterController01 a noria:Resource ;
    rdfs:label "Virtualization Cluster Controller 01"@en ;
    rdfs:comment "Controller for the virtualization cluster."@en ;
    noria:resourceManagedBy noria:Agent_AppDevTeam ;
    noria:resourceHostName "vcenter01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/management-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_4> ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.5> .

noria:Resource_HypervisorHost01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical host running virtual machines."@en ;
    noria:resourceManagedBy noria:Agent_AppDevTeam ;
    noria:resourceHostName "hypervisor01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_4> ;
    noria:clusterController noria:Resource_ClusterController01 ;
    noria:locatedAtLocus noria:Locus_Rack2B .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_4> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_4> ;
    noria:networkInterfaceType "physical" .

noria:NetworkInterface_RouterCore01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_4> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_4> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceType "physical" .

noria:NetworkInterface_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Downlink interface for Core Router 01 to internal network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_4> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_4> ;
    noria:networkInterfaceRoutingPriorityMetric 10 ;
    noria:networkInterfaceType "physical" .

noria:NetworkInterface_AppServerVM01_Eth0 a noria:NetworkInterface ;
    rdfs:label "AppServerVM01 Ethernet 0"@en ;
    rdfs:comment "Virtual network interface for Application Server VM 01."@en ;
    noria:networkInterfaceOf noria:Resource_AppServerVM01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_4> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_4> ;
    noria:networkInterfaceType "virtual" .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_CoreToInternet a noria:NetworkLink ;
    rdfs:label "Core Router to Internet Uplink"@en ;
    rdfs:comment "High-speed fiber link connecting Core Router 01 to the internet gateway."@en ;
    noria:networkLinkId "NL-001-WAN" ;
    noria:networkLinkType "fiber optic" ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_LoadBalancer01 ; # Simplified, could be an external router
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Gi0_0_0 .

noria:NetworkLink_DNS01ToCore a noria:NetworkLink ;
    rdfs:label "DNS01 to Core Network Link"@en ;
    rdfs:comment "Ethernet link connecting DNS01 to the internal core network."@en ;
    noria:networkLinkId "NL-002-LAN" ;
    noria:networkLinkType "ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkTerminationResource noria:Resource_DNS01 ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Gi0_0_1 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application_CorpInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:label "Accès Internet d'entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Gateway Management" ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" .

noria:Application_CRMSystem a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:label "Système de Gestion de la Relation Client"@fr ;
    rdfs:comment "Critical_extra_node_4 application for managing customer interactions."@en ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Management" ;
    noria:applicationFunctionalSubDomain "Sales & Support" ;
    noria:applicationModelIdentifier "CRM-APP" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "CRM" .

noria:Application_MonitoringPlatform a noria:Application ;
    rdfs:label "IT Monitoring Platform"@en ;
    rdfs:label "Plateforme de Supervision IT"@fr ;
    rdfs:comment "Centralized platform for monitoring IT infrastructure and applications."@en ;
    noria:applicationType <kos/application/type/management-tool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Performance & Availability Monitoring" ;
    noria:applicationModelIdentifier "MON-PLAT" ;
    noria:applicationNumericalIdentifier 3001 ;
    noria:applicationShortIdentifier "MON" .

# Link resources to applications
noria:Resource_DNS01 noria:resourceForApplication noria:Application_CorpInternetAccess .
noria:Resource_RouterCore01 noria:resourceForApplication noria:Application_CorpInternetAccess .
noria:Resource_AppServerVM01 noria:resourceForApplication noria:Application_CRMSystem .
noria:Resource_LoadBalancer01 noria:resourceForApplication noria:Application_CRMSystem .
noria:Resource_HypervisorHost01 noria:resourceForApplication noria:Application_CRMSystem .

# =============================================================================
# Application Modules (noria:ApplicationModule)
