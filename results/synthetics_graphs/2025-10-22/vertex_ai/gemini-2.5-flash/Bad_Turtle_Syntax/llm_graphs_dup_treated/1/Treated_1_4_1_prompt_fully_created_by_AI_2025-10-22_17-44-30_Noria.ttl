# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service_EnterpriseConnectivity a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:label "Service de Connectivité d'Entreprise"@fr ;
    rdfs:comment "End-to-end service providing network connectivity to all corporate sites and users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> .

noria:Service_CustomerPortal a noria:Service ;
    rdfs:label "Customer Portal Service"@en ;
    rdfs:label "Service Portail Client"@fr ;
    rdfs:comment "Service exposing CRM functionalities to external customers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> .

# Link Application Modules to Services (using seas:subSystemOf as per NORIA doc)
noria:ApplicationModule_CIA_Prod seas:subSystemOf noria:Service_EnterpriseConnectivity .
noria:ApplicationModule_CRM_Prod seas:subSystemOf noria:Service_CustomerPortal .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_4> .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical router interface went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "LINKPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_4> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartInterface .

noria:EventRecord_LoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security event: multiple failed login attempts on appvm01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "AUTH_FAILED: User 'attacker' failed to login 5 times from 1.2.3.4 on appvm01."@en ;
    noria:logOriginatingManagedObject noria:Resource_AppServerVM01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logOriginatingAgent <http://example.com/external/attacker> ; # Example of external agent
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<http://example.com/external/attacker> a foaf:Agent ;
    rdfs:label "External Attacker"@en ;
    rdfs:comment "Hypothetical external entity attempting unauthorized access."@en .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket_DNSOutage_TT001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident de Panne Serveur DNS"@fr ;
    rdfs:comment "DNS server unreachable causing internet access issues for corporate users."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical_extra_node_4> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedService noria:Application_CorpInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty noria:Agent_DNSAdminTeam ;
    noria:troubleTicketRelatedParty noria:Agent_NetworkOps ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketCause "Unidentified network connectivity issue to DNS server."@en ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring" ;
    noria:documentExternalId "INC-2024-04-20-001" ;
    noria:documentHRef <http://ticketing.example.com/INC-2024-04-20-001> .

noria:TroubleTicket_CRMFailure_TT002 a noria:TroubleTicket ;
    rdfs:label "CRM Application Performance Degradation"@en ;
    rdfs:label "Dégradation des Performances Application CRM"@fr ;
    rdfs:comment "Users report slow response times and occasional timeouts on the CRM system."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/User> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Open> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedService noria:Application_CRMSystem ;
    noria:troubleTicketRelatedParty noria:Agent_AppDevTeam ;
    noria:troubleTicketImpacts noria:Resource_AppServerVM01 ;
    noria:troubleTicketImpacts noria:Resource_LoadBalancer01 ;
    noria:documentExternalId "INC-2024-04-20-002" .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote_TT001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for TT001"@en ;
    rdfs:comment "Initial checks show no local network issues on DNS server. Suspect upstream network or firewall."@en ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JohnDoe ;
