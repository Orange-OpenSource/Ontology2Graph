# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OP_RouterFirmwareUpdate a noria:OperationPlan ;
    rdfs:label "Router Firmware Update Procedure"@en, "Procédure Mise à Jour Firmware Routeur"@fr ;
    rdfs:comment "Step-by-step guide for safely upgrading router firmware."@en ;
    noria:operationPlanPreCondition noria:PreCond_BackupConfig ;
    noria:operationPlanPostCondition noria:PostCond_ConnectivityRestored .

noria:OP_DBBackupProcedure a noria:OperationPlan ;
    rdfs:label "Database Backup Procedure"@en, "Procédure Sauvegarde Base de Données"@fr ;
    rdfs:comment "Routine procedure for backing up critical databases."@en ;
    noria:operationPlanPreCondition noria:PreCond_SufficientStorage ;
    noria:operationPlanPostCondition noria:PostCond_BackupVerified .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:PreCond_BackupConfig a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup Completed"@en ;
    rdfs:comment "Ensure a full backup of the device configuration is completed before proceeding."@en .

noria:PostCond_ConnectivityRestored a noria:ActionPostCondition ;
    rdfs:label "Network Connectivity Restored"@en ;
    rdfs:comment "Verify all network interfaces are up and traffic is flowing as expected."@en .

noria:PreCond_SufficientStorage a noria:ActionPreCondition ;
    rdfs:label "Sufficient Storage Available"@en ;
    rdfs:comment "Confirm adequate storage space is available for the backup operation."@en .

noria:PostCond_BackupVerified a noria:ActionPostCondition ;
    rdfs:label "Backup Integrity Verified"@en ;
    rdfs:comment "Validate the integrity and completeness of the generated backup files."@en .

