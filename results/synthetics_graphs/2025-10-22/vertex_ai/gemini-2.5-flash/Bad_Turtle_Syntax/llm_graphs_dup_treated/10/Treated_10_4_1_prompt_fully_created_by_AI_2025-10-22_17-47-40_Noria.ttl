@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix devopsprod: <http://w3id.org/devops-infra/product#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual IT engineer responsible for network infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via internal ticketing system for non-urgent issues."@en .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Lead developer for the Customer Portal application."@en ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call directly for critical application incidents."@en .

noria:Team_NetworkOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for managing the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Open a P1 ticket for any network outage."@en ;
    noria:agentManagesResource noria:Resource_CoreRouter01, noria:Resource_LoadBalancer01 .

noria:Team_AppSupport a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing level 2 support for business applications."@en ;
    noria:agentWorkingHours "8:00-20:00 Mon-Sun"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate to L3 for issues not resolved within 4 hours."@en .

noria:Team_Security a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center"@en, "Centre Opérations Sécurité"@fr ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report all suspicious activities immediately."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:Org_HP a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données Paris"@fr ;
    rdfs:comment "Primary data center location for critical infrastructure."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" ;
    bot:hasSpace noria:Room_ServerRoomA, noria:Room_NetworkRoomB .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Room hosting application servers and storage."@en ;
    bot:hasSpace noria:Locus_Rack12U, noria:Locus_Rack15U .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Room hosting core network devices."@en ;
    bot:hasSpace noria:Locus_Cabinet3, noria:Locus_Cabinet4 .

noria:Locus_Rack12U a noria:Locus ;
    rdfs:label "Rack 12U"@en, "Baie 12U"@fr ;
    rdfs:comment "Specific rack location within Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "12" .

noria:Locus_Rack15U a noria:Locus ;
    rdfs:label "Rack 15U"@en, "Baie 15U"@fr ;
    rdfs:comment "Specific rack location within Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "15" .

noria:Locus_Cabinet3 a noria:Locus ;
    rdfs:label "Cabinet 3"@en, "Armoire 3"@fr ;
    rdfs:comment "Specific cabinet location within Network Room B."@en ;
    noria:locusLine "B" ;
    noria:locusRow "3" .

noria:Locus_Cabinet4 a noria:Locus ;
    rdfs:label "Cabinet 4"@en, "Armoire 4"@fr ;
    rdfs:comment "Specific cabinet location within Network Room B."@en ;
    noria:locusLine "B" ;
    noria:locusRow "4" .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch series."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_HPProLiantDL380 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Versatile rack server for various workloads."@en ;
    noria:productManufacturedBy noria:Org_HP .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor."@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en, "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for inter-VLAN routing and external connectivity."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:resourceHostName "cr01.parisdc.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Cabinet3 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_1 .

noria:Resource_WebServer03 a noria:Resource ;
    rdfs:label "Web Server 03"@en, "Serveur Web 03"@fr ;
    rdfs:comment "Application server hosting the customer portal frontend."@en ;
    noria:resourceManagedBy noria:Agent_JohnDoe ;
    noria:resourceHostName "ws03.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_HPProLiantDL380 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12U ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_1_3 ;
    noria:resourceForApplication noria:App_CustomerPortal .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en, "Serveur Base de Données 01"@fr ;
    rdfs:comment "Primary database server for the internal CRM application."@en ;
    noria:resourceManagedBy noria:Agent_JohnDoe ;
    noria:resourceHostName "db01.crm.example.com" ;
    noria:resourceProductModel noria:ProductModel_HPProLiantDL380 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack15U ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_2_1 ;
    noria:resourceForApplication noria:App_InternalCRM .

noria:Resource_VirtualHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en, "Hôte de Virtualisation 01"@fr ;
    rdfs:comment "Physical server running VMware ESXi for virtual machines."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:resourceHostName "vh01.parisdc.example.com" ;
    noria:resourceProductModel noria:ProductModel_HPProLiantDL380 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Hypervisor> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-11-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12U ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_10 .

noria:Resource_LoadBalancer01 a noria:Resource ;
    rdfs:label "Load Balancer 01"@en, "Équilibreur de Charge 01"@fr ;
    rdfs:comment "Distributes traffic to web servers for the customer portal."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:resourceHostName "lb01.parisdc.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Example, could be a dedicated appliance
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/LoadBalancer> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-01T16:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Cabinet4 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_5 ;
    noria:resourceForApplication noria:App_CustomerPortal .

observable:IPAddress_10_0_0_1 a observable:IPAddress ;
    rdfs:label "10.0.0.1"@en ;
    rdfs:comment "Management IP for Core Router 01."@en .

observable:IPAddress_10_0_1_3 a observable:IPAddress ;
    rdfs:label "10.0.1.3"@en ;
    rdfs:comment "Management IP for Web Server 03."@en .

observable:IPAddress_10_0_2_1 a observable:IPAddress ;
    rdfs:label "10.0.2.1"@en ;
    rdfs:comment "Management IP for DB Server 01."@en .

observable:IPAddress_10_0_0_10 a observable:IPAddress ;
    rdfs:label "10.0.0.10"@en ;
    rdfs:comment "Management IP for Virtualization Host 01."@en .

observable:IPAddress_10_0_0_5 a observable:IPAddress ;
    rdfs:label "10.0.0.5"@en ;
    rdfs:comment "Management IP for Load Balancer 01."@en .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NI_CR01_Eth0 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface for Core Router 01 to the internet."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceType "physical" .

noria:NI_CR01_Eth1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface for Core Router 01 connecting to Web Server 03."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" .

noria:NI_WS03_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Primary network interface for Web Server 03."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer03 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" .

noria:NI_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Primary network interface for DB Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" .

noria:NI_LB01_PortA a noria:NetworkInterface ;
    rdfs:label "Port A"@en ;
    rdfs:comment "Frontend interface for Load Balancer 01."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" .

noria:NI_LB01_PortB a noria:NetworkInterface ;
    rdfs:label "Port B"@en ;
    rdfs:comment "Backend interface for Load Balancer 01 connecting to web servers."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NL_CR01_Internet a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Internet Link"@en ;
    rdfs:comment "High-speed fiber link connecting the data center to the internet backbone."@en ;
    noria:networkLinkId "NL-CR01-INT-001" ;
    noria:networkInterfaceConnects noria:NI_CR01_Eth0 ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter01 ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime .

noria:NL_CR01_LB01 a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Load Balancer 01 Link"@en ;
    rdfs:comment "Internal link between core router and load balancer."@en ;
    noria:networkLinkId "NL-CR01-LB01-001" ;
    noria:networkInterfaceConnects noria:NI_CR01_Eth1, noria:NI_LB01_PortA ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_LoadBalancer01 ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2021-08-01T16:00:00Z"^^xsd:dateTime .

noria:NL_LB01_WS03 a noria:NetworkLink ;
    rdfs:label "Load Balancer 01 to Web Server 03 Link"@en ;
    rdfs:comment "Link from load balancer to web server."@en ;
    noria:networkLinkId "NL-LB01-WS03-001" ;
    noria:networkInterfaceConnects noria:NI_LB01_PortB, noria:NI_WS03_Eth0 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_LoadBalancer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_WebServer03 ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime .

noria:NL_WS03_DB01 a noria:NetworkLink ;
    rdfs:label "Web Server 03 to DB Server 01 Link"@en ;
    rdfs:comment "Internal link between web server and database server."@en ;
    noria:networkLinkId "NL-WS03-DB01-001" ;
    noria:networkInterfaceConnects noria:NI_WS03_Eth0, noria:NI_DB01_Eth0 ; # Assuming WS03_Eth0 connects to both LB and DB for simplicity, or another interface
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebServer03 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DBServer01 ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:App_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal"@en, "Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Online Self-Service"@en .

noria:App_InternalCRM a noria:Application ;
    rdfs:label "Internal CRM"@en, "CRM Interne"@fr ;
    rdfs:comment "Application used by internal teams for customer management."@en ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/internal-business> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Sales and Marketing"@en ;
    noria:applicationFunctionalSubDomain "Customer Data Management"@en .

noria:App_MonitoringSystem a noria:Application ;
    rdfs:label "Monitoring System"@en, "Système de Supervision"@fr ;
    rdfs:comment "Centralized system for collecting and analyzing infrastructure metrics and logs."@en ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Performance and Fault Management"@en .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

noria:AppMod_CustomerPortal_Prod a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en, "Module Production Portail Client"@fr ;
    rdfs:comment "Production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf noria:App_CustomerPortal ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam noria:Team_AppSupport ;
    noria:applicationModuleSupportTeam noria:Team_AppSupport ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:AppMod_InternalCRM_Dev a noria:ApplicationModule ;
    rdfs:label "Internal CRM Development Module"@en, "Module Développement CRM Interne"@fr ;
    rdfs:comment "Development instance of the Internal CRM application."@en ;
    noria:applicationModuleOf noria:App_InternalCRM ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleAdministrationTeam noria:Team_AppSupport ;
    noria:applicationModuleSupportTeam noria:Team_AppSupport ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleSlaLevelDate "2023-03-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false .

# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service_ECommerce a noria:Service ;
    rdfs:label "E-Commerce Service"@en, "Service E-Commerce"@fr ;
    rdfs:comment "End-to-end service for online product sales, relying on Customer Portal."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CustomerPortal_Prod . # Linking service to application module

noria:Service_VPNAccess a noria:Service ;
    rdfs:label "Corporate VPN Access"@en, "Accès VPN Entreprise"@fr ;
    rdfs:comment "Service providing secure remote access to internal resources."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Resource_CoreRouter01 . # Linking service to a resource

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:Event_RouterDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2023-10-26T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_LoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security event indicating multiple failed login attempts on Web Server 03."@en ;
    noria:loggingTime "2023-10-26T10:15:30Z"^^xsd:dateTime ;
    noria:logText "Authentication failure for user 'admin' from IP 192.168.1.100 (5 attempts)"@en ;
    noria:logOriginatingManagedObject noria:Resource_WebServer03 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logOriginatingAgent noria:Team_Security ; # Security team might be the 'agent' detecting/logging it
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_DiskFull a noria:EventRecord ;
    rdfs:label "Disk Space Low Alert"@en ;
    rdfs:comment "Alert indicating low disk space on DB Server 01."@en ;
    noria:loggingTime "2023-10-26T09:45:00Z"^^xsd:dateTime ;
    noria:logText "Disk usage on /var/log is 95% on db01.crm.example.com"@en ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Minor> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TT_RouterIssue a noria:TroubleTicket ;
    rdfs:label "Core Router 01 Interface Down"@en, "Interface Routeur Cœur 01 Hors Service"@fr ;
    rdfs:comment "Critical incident: GigabitEthernet0/0/0 on Core Router 01 is down, impacting internet connectivity."@en ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Service_ECommerce ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRouter01 ;
    noria:troubleTicketRelatedParty noria:Team_NetworkOps ;
    noria:troubleTicketTrigger noria:Event_RouterDown ;
