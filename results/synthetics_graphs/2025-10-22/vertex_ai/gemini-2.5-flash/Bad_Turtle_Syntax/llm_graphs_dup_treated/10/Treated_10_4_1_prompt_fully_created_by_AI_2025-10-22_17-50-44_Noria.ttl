@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

# --- KOS Concepts (defined inline for demonstration) ---
<kos/application/type/web-application> a skos:Concept ; rdfs:label "Web Application"@en .
<kos/application/type/database-service> a skos:Concept ; rdfs:label "Database Service"@en .
<kos/application/type/monitoring-system> a skos:Concept ; rdfs:label "Monitoring System"@en .
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High"@en .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium"@en .
<kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en .
<kos/application/status/Staging> a skos:Concept ; rdfs:label "Staging"@en .
<kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold"@en .
<kos/application/sla-level/Silver> a skos:Concept ; rdfs:label "Silver"@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major"@en .
<kos/TroubleTicket/type/Incident> a skos:Concept ; rdfs:label "Incident"@en .
<kos/TroubleTicket/type/Problem> a skos:Concept ; rdfs:label "Problem"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis"@en .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; rdfs:label "Resolution"@en .

<kos/ChangeRequest/category/InfrastructureUpgrade> a skos:Concept ; rdfs:label "Infrastructure Upgrade"@en .
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented"@en .
<kos/ChangeRequest/cause/CapacityPlanning> a skos:Concept ; rdfs:label "Capacity Planning"@en .

<kos/Resource/type/WebServer> a skos:Concept ; rdfs:label "Web Server"@en .
<kos/Resource/type/DatabaseServer> a skos:Concept ; rdfs:label "Database Server"@en .
<kos/Resource/type/NetworkRouter> a skos:Concept ; rdfs:label "Network Router"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine"@en .
<kos/Resource/LifecycleState/InUse> a skos:Concept ; rdfs:label "In Use"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned"@en .
<kos/Resource/AdministrativeState/up> a skos:Concept ; rdfs:label "Up"@en .
<kos/Resource/AdministrativeState/down> a skos:Concept ; rdfs:label "Down"@en .
<kos/Resource/OperationalState/up> a skos:Concept ; rdfs:label "Up"@en .
<kos/Resource/OperationalState/down> a skos:Concept ; rdfs:label "Down"@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning"@en .

# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
foaf:Agent_DevOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DevOps Team"@en ;
    rdfs:label "Équipe DevOps"@fr ;
    rdfs:comment "Team responsible for the E-commerce platform's development and operations."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for P1/P2 incidents."@en .

foaf:Agent_NetworkAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Admin Team"@en ;
    rdfs:label "Équipe Administration Réseau"@fr ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline for critical network issues."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for the E-commerce Platform."@en ;
    foaf:mbox <mailto:john.doe@example.com> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox <mailto:jane.smith@example.com> .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
bot:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "PAR-DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room within Paris Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1 .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical web servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of database servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

# --- Product Models (noria:ProductModel) ---
noria:ProductModel_HPProLiantDL380 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Standard server model for web applications."@en ;
    noria:productManufacturedBy <https://www.hpe.com/> .

noria:ProductModel_CiscoCatalyst9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch."@en ;
    noria:productManufacturedBy <https://www.cisco.com/> .

# --- Resources (noria:Resource) ---
noria:Resource_WebServer01 a noria:Resource ;
    rdfs:label "E-commerce Web Server 01"@en ;
    rdfs:comment "First web server hosting the E-commerce platform."@en ;
    noria:resourceManagedBy foaf:Agent_DevOpsTeam ;
    noria:resourceHostName "web01.ecommerce.example.com" ;
    noria:resourceProductModel noria:ProductModel_HPProLiantDL380 ;
    noria:resourceType <kos/Resource/type/WebServer> ;
    noria:resourceSerialNumber "SN-WEB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> ;
    noria:resourceForApplication noria:Application_EcommercePlatform .

noria:Resource_WebServer02 a noria:Resource ;
    rdfs:label "E-commerce Web Server 02"@en ;
    rdfs:comment "Second web server hosting the E-commerce platform."@en ;
    noria:resourceManagedBy foaf:Agent_DevOpsTeam ;
    noria:resourceHostName "web02.ecommerce.example.com" ;
    noria:resourceProductModel noria:ProductModel_HPProLiantDL380 ;
    noria:resourceType <kos/Resource/type/WebServer> ;
    noria:resourceSerialNumber "SN-WEB-002" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.11> ;
    noria:resourceForApplication noria:Application_EcommercePlatform .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "E-commerce Database Server 01"@en ;
    rdfs:comment "Primary database server for the E-commerce platform."@en ;
    noria:resourceManagedBy foaf:Agent_DevOpsTeam ;
    noria:resourceHostName "db01.ecommerce.example.com" ;
    noria:resourceProductModel noria:ProductModel_HPProLiantDL380 ;
    noria:resourceType <kos/Resource/type/DatabaseServer> ;
    noria:resourceSerialNumber "SN-DB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-02-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> ;
    noria:resourceForApplication noria:Application_EcommercePlatform .

noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router DC01"@en ;
    rdfs:comment "Main router for the Paris Data Center."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkAdminTeam ;
    noria:resourceHostName "router01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoCatalyst9300 ;
    noria:resourceType <kos/Resource/type/NetworkRouter> ;
    noria:resourceSerialNumber "SN-RTR-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

# --- Network Interfaces (noria:NetworkInterface) ---
noria:NetworkInterface_Web01Eth0 a noria:NetworkInterface ;
    rdfs:label "web01.ecommerce.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer01 ;
    noria:networkInterfaceDescription "Uplink to core switch" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_DB01Eth0 a noria:NetworkInterface ;
    rdfs:label "db01.ecommerce.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface for DB Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceDescription "Uplink to core switch" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_Router01Gi0_1 a noria:NetworkInterface ;
    rdfs:label "router01.dc.example.com:Gi0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/1 on Core Router 01, connected to web servers."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Connection to Web Server VLAN" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_Router01Gi0_2 a noria:NetworkInterface ;
    rdfs:label "router01.dc.example.com:Gi0/2"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/2 on Core Router 01, connected to database servers."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Connection to Database Server VLAN" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

# --- Network Links (noria:NetworkLink) ---
noria:NetworkLink_Web01ToRouter a noria:NetworkLink ;
    rdfs:label "Link Web01-Router01"@en ;
    rdfs:comment "Network link between Web Server 01 and Core Router 01."@en ;
    noria:networkLinkId "NL-WEB01-RTR01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ;
    noria:resourceManagedBy foaf:Agent_NetworkAdminTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_Web01Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_Router01Gi0_1 .

noria:NetworkLink_DB01ToRouter a noria:NetworkLink ;
    rdfs:label "Link DB01-Router01"@en ;
    rdfs:comment "Network link between DB Server 01 and Core Router 01."@en ;
    noria:networkLinkId "NL-DB01-RTR01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-02-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DBServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ;
    noria:resourceManagedBy foaf:Agent_NetworkAdminTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_DB01Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_Router01Gi0_2 .

# --- Applications (noria:Application) ---
noria:Application_EcommercePlatform a noria:Application ;
    rdfs:label "E-commerce Platform"@en ;
    rdfs:label "Plateforme E-commerce"@fr ;
    rdfs:comment "Online retail application for customer purchases."@en ;
    noria:applicationType <kos/application/type/web-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Sales and Marketing"@en ;
    noria:applicationFunctionalSubDomain "Online Storefront"@en ;
    noria:applicationModelIdentifier "ECOMM-V2" ;
    noria:applicationShortIdentifier "ECOMM" .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Infrastructure Monitoring System"@en ;
    rdfs:comment "System for collecting and analyzing metrics and logs from IT infrastructure."@en ;
    noria:applicationType <kos/application/type/monitoring-system> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationShortIdentifier "MONSYS" .

# --- Application Modules (noria:ApplicationModule) ---
noria:ApplicationModule_EcommerceProd a noria:ApplicationModule ;
    rdfs:label "E-commerce Production Module"@en ;
    rdfs:comment "Production instance of the E-commerce Platform."@en ;
    noria:applicationModuleOf noria:Application_EcommercePlatform ;
    noria:applicationModuleName "ECOMM_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam foaf:Agent_DevOpsTeam ;
    noria:applicationModuleSupportTeam foaf:Agent_DevOpsTeam ;
    noria:applicationModuleAdministrationLeader foaf:Agent_JohnDoe .

noria:ApplicationModule_EcommerceStaging a noria:ApplicationModule ;
    rdfs:label "E-commerce Staging Module"@en ;
    rdfs:comment "Staging instance of the E-commerce Platform for testing."@en ;
    noria:applicationModuleOf noria:Application_EcommercePlatform ;
    noria:applicationModuleName "ECOMM_STAGING" ;
    noria:applicationModuleIdentifier "STAGING" ;
    noria:applicationModuleStatus <kos/application/status/Staging> ;
    noria:applicationModuleSlaLevel <kos/application/sla-level/Silver> ;
    noria:applicationModuleHotlineEnabled false .

# --- Services (noria:Service) ---
noria:Service_CustomerFacingEcommerce a noria:Service ;
    rdfs:label "Customer-Facing E-commerce Service"@en ;
    rdfs:comment "The end-to-end service provided to customers for online shopping."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> .

# --- Event Records (noria:EventRecord) ---
noria:EventRecord_HighCPUWeb01 a noria:EventRecord ;
    rdfs:label "High CPU Alert Web01"@en ;
    rdfs:comment "Alert indicating high CPU utilization on web01.ecommerce.example.com."@en ;
    noria:loggingTime "2024-04-20T14:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on web01.ecommerce.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_NetworkInterfaceDown a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert Router01"@en ;
    rdfs:comment "Alert indicating a network interface went down on Core Router 01."@en ;
    noria:loggingTime "2024-04-20T14:10:00Z"^^xsd:dateTime ;
    noria:logText "Interface Gi0/1 on router01.dc.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_TTStatusChangeInProgress a noria:EventRecord ;
    rdfs:label "Trouble Ticket TT-20240420-001 Status Change to InProgress"@en ;
    rdfs:comment "System log for status change of TT-20240420-001."@en ;
    noria:loggingTime "2024-04-20T14:15:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240420-001 status changed to InProgress."@en ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem .

noria:EventRecord_TTStatusChangeResolved a noria:EventRecord ;
    rdfs:label "Trouble Ticket TT-20240420-001 Status Change to Resolved"@en ;
    rdfs:comment "System log for status change of TT-20240420-001."@en ;
    noria:loggingTime "2024-04-20T16:30:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240420-001 status changed to Resolved."@en ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem .

# --- Trouble Tickets (noria:TroubleTicket) ---
noria:TroubleTicket_EcommerceSlowdown a noria:TroubleTicket ;
    rdfs:label "E-commerce Platform Slowdown Incident"@en ;
    rdfs:comment "Customers reporting slow response times on the E-commerce platform."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Incident> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketRelatedService noria:ApplicationModule_EcommerceProd ;
    noria:troubleTicketRelatedResource noria:Resource_WebServer01 ;
    noria:troubleTicketRelatedParty foaf:Agent_DevOpsTeam ;
    noria:troubleTicketTrigger noria:EventRecord_HighCPUWeb01 ;
    noria:troubleTicketCause "High CPU utilization on web server due to unexpected traffic surge."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T14:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T16:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T16:15:00Z"^^xsd:dateTime ;
    noria:documentHRef <http://ticketing.example.com/TT-20240420-001> ;
    noria:documentStatusHistory noria:EventRecord_TTStatusChangeInProgress, noria:EventRecord_TTStatusChangeResolved .

noria:TroubleTicket_NetworkOutageDC a noria:TroubleTicket ;
    rdfs:label "Data Center Network Outage"@en ;
    rdfs:comment "Major network outage affecting multiple services in the Paris DC."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Incident> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Closed> ;
    noria:troubleTicketRelatedService noria:Service_CustomerFacingEcommerce ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRouter01 ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkAdminTeam ;
    noria:troubleTicketTrigger noria:EventRecord_NetworkInterfaceDown ;
    noria:troubleTicketCause "Fiber cut affecting core router uplink."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T14:10:00Z"^^xsd:dateTime ;
    noria:documentHRef <http://ticketing.example.com/TT-20240420-002> .

# --- Trouble Ticket Notes (noria:TroubleTicketNote) ---
noria:TroubleTicketNote_TT001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "TT-20240420-001 Note 1"@en ;
    rdfs:comment "Initial diagnosis: High CPU on web01. Scaling up web servers is recommended."@en ;
    dcterms:isPartOf noria:TroubleTicket_EcommerceSlowdown ; # Using dcterms:isPartOf as per schema comment
    dcterms:created "2024-04-20T14:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote_TT001_Note2 a noria:TroubleTicketNote ;
    rdfs:label "TT-20240420-001 Note 2"@en ;
    rdfs:comment "Resolution: New web server added to load balancer. Traffic distributed, CPU normalized."@en ;
    dcterms:isPartOf noria:TroubleTicket_EcommerceSlowdown ;
    dcterms:created "2024-04-20T16:20:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> .

# --- Change Requests (noria:ChangeRequest) ---
noria:ChangeRequest_ScaleWebServers a noria:ChangeRequest ;
    rdfs:label "Scale E-commerce Web Servers"@en ;
    rdfs:comment "Add a new web server to the E-commerce platform to handle increased load."@en ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InfrastructureUpgrade> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestImpact noria:ApplicationModule_EcommerceProd, noria:Resource_WebServer01 ;
    noria:changeRequestInitiatorParty foaf:Agent_JohnDoe ;
    noria:changeRequestPilotParty foaf:Agent_DevOpsTeam ;
    noria:changeRequestActorParty foaf:Agent_DevOpsTeam ;
    noria:changeRequestPlannedStartTime "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-20T16:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-20T15:10:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-20T16:15:00Z"^^xsd:dateTime ;
    noria:changeRequestOutageDuration "PT0H5M"^^xsd:duration ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/CapacityPlanning> ;
    noria:documentHRef <http://changemanagement.example.com/CR-20240420-001> .

# --- Operation Plans (noria:OperationPlan) ---
noria:OperationPlan_WebServerScaling a noria:OperationPlan ;
    rdfs:label "Web Server Scaling Procedure"@en ;
    rdfs:comment "Standard operating procedure for adding new web servers to the E-commerce cluster."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_AvailableVM ;
    noria:operationPlanPostCondition noria:ActionPostCondition_TrafficDistributed .

# --- Action Pre/Post Conditions ---
noria:ActionPreCondition_AvailableVM a noria:ActionPreCondition ;
    rdfs:label "Available VM Resource"@en ;
    rdfs:comment "Pre-condition: A virtual machine resource is available and configured for web server role."@en .

noria:ActionPostCondition_TrafficDistributed a noria:ActionPostCondition ;
    rdfs:label "Traffic Distributed and CPU Normalized"@en ;
    rdfs:comment "Post-condition: Traffic is successfully distributed to the new server, and CPU utilization on existing servers is normalized."@en .

# --- Additional connections for density ---
foaf:Agent_DevOpsTeam noria:agentManagesResource noria:Resource_WebServer01, noria:Resource_WebServer02, noria:Resource_DBServer01 .
foaf:Agent_NetworkAdminTeam noria:agentManagesResource noria:Resource_CoreRouter01 .

noria:Application_EcommercePlatform noria:elementManagedBy foaf:Agent_DevOpsTeam .
noria:Application_MonitoringSystem noria:elementManagedBy foaf:Agent_NetworkAdminTeam .

noria:ChangeRequest_ScaleWebServers pep:usedProcedure noria:OperationPlan_WebServerScaling .
noria:EventRecord_HighCPUWeb01 noria:alarmMitigatedBy noria:ChangeRequest_ScaleWebServers .
