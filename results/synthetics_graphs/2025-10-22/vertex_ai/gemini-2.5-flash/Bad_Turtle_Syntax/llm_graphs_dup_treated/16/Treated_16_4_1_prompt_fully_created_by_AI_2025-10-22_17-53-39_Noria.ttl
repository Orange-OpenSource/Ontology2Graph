noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "End-to-end service providing internet access to corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppModule_CorporateDNS_Prod ; # Linking application module to service
    seas:subSystemOf noria:AppModule_CorporateWebsite_Prod . # Linking application module to service

noria:Service_InternalNetwork a noria:Service ;
