noria:OperationPlan_DNSFailover a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over DNS services to a secondary server."@en ;
    noria:operationPlanPreCondition noria:PreCond_DNSPrimaryDown ;
    noria:operationPlanPostCondition noria:PostCond_DNSServiceRestored .

noria:OperationPlan_RouterInterfaceTroubleshoot a noria:OperationPlan ;
