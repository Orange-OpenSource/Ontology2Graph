@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concept Schemes and Concepts
# =============================================================================

# Application Type
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for application types."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application providing core infrastructure services."@en .

<kos/application/type/business> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "An application supporting specific business processes."@en .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A controlled vocabulary for application business importance."@en .

<kos/application/business-importance/high> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for business operations."@en .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application is important but not critical for immediate business operations."@en .

# Application Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for application module status."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently in a production state."@en .

<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Maintenance"@en ;
    rdfs:comment "The application module is currently undergoing maintenance."@en .

# TroubleTicket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket severity levels."@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Service is completely down or severely impacted."@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant service degradation or partial outage."@en .

# TroubleTicket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket types."@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Indicates a system or service failure."@en .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Request for user assistance or support."@en .

# TroubleTicket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket origins."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System"@en ;
    rdfs:comment "Ticket originated from an automated monitoring system."@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Report"@en ;
    rdfs:comment "Ticket reported by a customer."@en .

# TroubleTicket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket current status."@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue described in the trouble ticket has been resolved."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for resource lifecycle states."@en .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The resource is actively used in production."@en .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "The resource has been removed from service."@en .

# Resource Type
<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for resource types."@en .

<kos/Resource/type/Server> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computing server resource."@en .

<kos/Resource/type/Router> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router resource."@en .

<kos/Resource/type/VirtualMachine> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Virtual Machine"@en ;
    rdfs:comment "A virtualized computing resource."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for resource administrative states."@en .

<kos/Resource/AdministrativeState/up> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "The resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/down> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "The resource is administratively disabled."@en .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for resource operational states."@en .

<kos/Resource/OperationalState/up> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "The resource is currently operational."@en .

<kos/Resource/OperationalState/down> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "The resource is currently not operational."@en .

# Service Type
<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for service types."@en .

<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by customers."@en .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service supporting other services or internal operations."@en .

# Change Request Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for change request types."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk."@en .

<kos/ChangeRequest/type/Emergency> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Emergency Change"@en ;
    rdfs:comment "An urgent change required to resolve an incident."@en .

# Change Request Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A controlled vocabulary for change request causes."@en .

<kos/ChangeRequest/cause/Configuration> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change due to configuration update."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change due to software version upgrade."@en .

# Change Request Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for change request statuses."@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "The change request has been approved."@en .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "The change request has been implemented."@en .

# Notification Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for notification perceived severity levels."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "A critical notification indicating severe impact."@en .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning"@en ;
    rdfs:comment "A warning notification indicating potential issues."@en .

# TroubleTicket Note Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket note comment types."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team use."@en .

# TroubleTicket Note Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket note operation types."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Note related to diagnostic steps."@en .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

noria:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentInstructions "Contact via ticketing system for P1/P2 issues."@en .

noria:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentInstructions "Use emergency hotline for critical network outages."@en .

noria:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2 support for business applications."@en ;
    noria:agentWorkingHours "8:30-18:00 Mon-Fri"@en .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en .

noria:OrgUnit_ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department of the organization."@en .

noria:OrgUnit_NOC a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "24/7 monitoring and first-line support for network infrastructure."@en ;
    org:member noria:Agent_NetworkOpsTeam .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room in Main Data Center."@en ;
    bot:hasSpace noria:Site_MainDC . # Assuming bot:hasSpace can link a room to a site.

noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "23" ;
    bot:hasSpace noria:Room_ServerRoomA . # Assuming bot:hasSpace can link a locus to a room.

noria:Locus_RackB2_U10 a noria:Locus ;
    rdfs:label "Rack B2, Unit 10"@en ;
    rdfs:comment "Specific location for a router in Server Room A."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "10" ;
    bot:hasSpace noria:Room_ServerRoomA .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various services."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of Dell PowerEdge servers."@en .

noria:ProductModel_CiscoASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series"@en ;
    rdfs:comment "High-end router series from Cisco."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of Cisco networking equipment."@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_10 .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate backbone network."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-05-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB2_U10 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_1 .

noria:Resource_VMWeb01 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-10T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:IPAddress_172_16_0_10 .

observable:IPAddress_192_168_1_10 a observable:IPAddress ;
    rdfs:label "192.168.1.10"@en ;
    observable:ipAddressValue "192.168.1.10" .

observable:IPAddress_10_0_0_1 a observable:IPAddress ;
    rdfs:label "10.0.0.1"@en ;
    observable:ipAddressValue "10.0.0.1" .

observable:IPAddress_172_16_0_10 a observable:IPAddress ;
    rdfs:label "172.16.0.10"@en ;
    observable:ipAddressValue "172.16.0.10" .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetIF_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Primary network interface for DNS services."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetIF_RouterCore01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "router-core01-Gi0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface connecting to internal network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to internal corporate network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetIF_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "router-core01-Gi0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface connecting to external network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to external internet provider."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 200 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetIF_VMWeb01_Eth0 a noria:NetworkInterface ;
    rdfs:label "web01-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Web Server VM 01."@en ;
    noria:networkInterfaceOf noria:Resource_VMWeb01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetLink_DNS01_CoreNet a noria:NetworkLink ;
    rdfs:label "DNS01 to Core Network Link"@en ;
    rdfs:comment "Link between DNS01 server and the core network."@en ;
    noria:networkLinkId "NL-DNS01-CORE" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:networkLinkTerminationResource noria:Resource_DNS01 ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ;
    noria:networkInterfaceConnects noria:NetIF_DNS01_Eth0 ;
    noria:networkInterfaceConnects noria:NetIF_RouterCore01_Gi0_0_0 .

noria:NetLink_Core01_ISP a noria:NetworkLink ;
    rdfs:label "Core Router 01 to ISP Link"@en ;
    rdfs:comment "Uplink from Core Router 01 to Internet Service Provider."@en ;
    noria:networkLinkId "NL-CORE01-ISP" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-05-20T15:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkInterfaceConnects noria:NetIF_RouterCore01_Gi0_0_1 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application_CorporateDNS a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:comment "Provides DNS resolution for all internal corporate services."@en ;
    noria:applicationModelIdentifier "CORP-DNS" ;
    noria:applicationShortIdentifier "CDNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "DNS Resolution" ;
    noria:resourceForApplication noria:Resource_DNS01 .

noria:Application_CorporateWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "Public-facing website for the corporation."@en ;
    noria:applicationModelIdentifier "CORP-WEB" ;
    noria:applicationShortIdentifier "CWEB" ;
    noria:applicationType <kos/application/type/business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Marketing & Communications" ;
    noria:applicationFunctionalSubDomain "Public Presence" ;
    noria:resourceForApplication noria:Resource_VMWeb01 .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

noria:AppModule_CorporateDNS_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en ;
    rdfs:comment "The production instance of the Corporate DNS service."@en ;
    noria:applicationModuleOf noria:Application_CorporateDNS ;
    noria:applicationModuleName "CORP-DNS_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam noria:OrgUnit_ITDepartment ;
    noria:applicationModuleSupportTeam noria:Agent_DNSAdminTeam ;
    noria:applicationModuleSupportLeader noria:Agent_JohnDoe ;
    noria:applicationModuleHotlineEnabled true .

noria:AppModule_CorporateWebsite_Prod a noria:ApplicationModule ;
