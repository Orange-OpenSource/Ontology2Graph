# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:PreCond_DNSPrimaryDown a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Down"@en ;
    rdfs:comment "Condition: Primary DNS server is not responding to queries."@en .

noria:PostCond_DNSServiceRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS queries are successfully resolved by the secondary server."@en .

noria:PreCond_InterfaceOperationalDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Operational Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en .

noria:PostCond_InterfaceOperationalUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Operational Up"@en ;
    rdfs:comment "Outcome: The network interface's operational status is 'up'."@en .

