    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:documentStatusHistory noria:Event_DNS01_Down .

noria:TroubleTicket_InternetAccessDegradation a noria:TroubleTicket ;
    rdfs:label "Internet Access Degradation"@en ;
