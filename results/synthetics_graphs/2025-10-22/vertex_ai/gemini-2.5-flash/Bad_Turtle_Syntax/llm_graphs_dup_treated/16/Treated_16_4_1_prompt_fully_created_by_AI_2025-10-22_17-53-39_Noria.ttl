    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_RouterCore01 ;
    noria:troubleTicketRelatedParty noria:Agent_NetworkOpsTeam ;
    noria:troubleTicketTrigger noria:Event_RouterCore01_InterfaceDown ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketCause "Suspected fiber cut on ISP uplink."@en ;
    noria:documentExternalId "CUST-INC-2024-001" ;
    noria:documentHRef "https://ticketing.example.com/ticket/CUST-INC-2024-001" .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote_DNSDiag1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Diagnosis Note 1"@en ;
    rdfs:comment "Initial diagnosis: confirmed DNS service is not responding on dns01.corp.example.com. Checked network connectivity, appears fine."@en ;
