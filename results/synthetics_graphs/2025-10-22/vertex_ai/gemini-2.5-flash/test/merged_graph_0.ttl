noria:NetworkInterface_DNS01_Eth0_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface for DNS server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01_extra_node_3 ;
    noria:networkInterfaceDescription "Primary network interface for management and service traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_3> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_3> .

noria:NetworkInterface_RouterCore1_Gi0_0_0_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "router-core-01-Gi0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface connecting to internal network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1_extra_node_3 ;
    noria:networkInterfaceDescription "Internal_extra_node_3 LAN uplink."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_3> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_3> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterCore1_Gi0_0_1_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "router-core-01-Gi0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface connecting to external network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1_extra_node_3 ;
    noria:networkInterfaceDescription "External WAN uplink."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_3> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_3> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkInterface_AppServer01_Eth0_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "appserver01-eth0"@en ;
    rdfs:comment "Ethernet interface for Application Server_extra_node_3 01."@en ;
    noria:networkInterfaceOf noria:Resource_AppServer01_extra_node_3 ;
    noria:networkInterfaceDescription "Primary network interface for application traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_3> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_3> .

noria:NetworkInterface_VMWeb01_Eth0_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "webvm01-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Web Server_extra_node_3 VM 01."@en ;
    noria:networkInterfaceOf noria:Resource_VMWeb01_extra_node_3 ;
    noria:networkInterfaceDescription "Virtual network interface for web traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_3> ;
