noria:OperationPlan_RestartInterface_extra_node_4 a noria:OperationPlan ;
    rdfs:label "Network Interface Restart Procedure"@en ;
    rdfs:label "Procédure de Redémarrage d'Interface Réseau"@fr ;
    rdfs:comment "Standard_extra_node_4 operating procedure for restarting a network interface on a router."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown_extra_node_4 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp_extra_node_4 .

noria:OperationPlan_DNSCheck_extra_node_4 a noria:OperationPlan ;
    rdfs:label "DNS Service Health Check"@en ;
    rdfs:comment "Procedure to verify the operational status and responsiveness of DNS services."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable_extra_node_4 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSResponding_extra_node_4 .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition_InterfaceDown_extra_node_4 a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: The network interface reports an operational status of 'down'."@en .

noria:ActionPostCondition_InterfaceUp_extra_node_4 a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up_extra_node_4"@en ;
    rdfs:comment "Expected outcome: The network interface reports an operational status of 'up_extra_node_4' and traffic flows."@en .

noria:ActionPreCondition_DNSUnreachable_extra_node_4 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS queries fail or timeout for the specified server."@en .

noria:ActionPostCondition_DNSResponding_extra_node_4 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Responding"@en ;
    rdfs:comment "Expected outcome: DNS queries to the server are successful and timely."@en .

