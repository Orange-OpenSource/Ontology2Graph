# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog_extra_node_4 a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01_extra_node_4 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform_extra_node_4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_4> .

noria:EventRecord_InterfaceDown_extra_node_4 a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical router interface went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "LINKPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01_extra_node_4 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform_extra_node_4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_4> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartInterface_extra_node_4 .

noria:EventRecord_LoginFailure_extra_node_4 a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security event: multiple failed login attempts on appvm01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "AUTH_FAILED: User_extra_node_4 'attacker_extra_node_4' failed to login 5 times from 1.2.3.4 on appvm01."@en ;
    noria:logOriginatingManagedObject noria:Resource_AppServerVM01_extra_node_4 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform_extra_node_4 ;
    noria:logOriginatingAgent <http://example.com/external/attacker_extra_node_4> ; # Example of external agent
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_4> .

<http://example.com/external/attacker_extra_node_4> a foaf:Agent ;
    rdfs:label "External Attacker"@en ;
    rdfs:comment "Hypothetical external entity attempting unauthorized access."@en .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket_DNSOutage_TT001_extra_node_4 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
