noria:TroubleTicketNote_TT001_Note2_extra_node_4 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Attempt Note for TT001"@en ;
    rdfs:comment "Restarted network interface on Core Router 01. DNS service restored."@en ;
    dcterms:created "2024-04-20T09:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JaneSmith_extra_node_4 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_4> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements_extra_node_4> ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage_TT001_extra_node_4 ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_InterfaceDown_extra_node_4 . # This event might be a consequence of the action, or related to it.

# Update TT status based on notes
noria:TroubleTicket_DNSOutage_TT001_extra_node_4 noria:documentStatusHistory noria:EventRecord_DNSOutageLog_extra_node_4 . # Initial event
noria:TroubleTicket_DNSOutage_TT001_extra_node_4 noria:documentStatusHistory noria:EventRecord_TT001_StatusChange_InProgress_extra_node_4 .

