    noria:productManufacturedBy <https://www.vmware.com> .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01_extra_node_3 a noria:Resource ;
    rdfs:label "Corporate DNS Server_extra_node_3 01"@en ;
    rdfs:comment "Primary DNS server for internal and external resolution."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam_extra_node_3 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_3 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_3 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_10_extra_node_3 .

noria:Resource_RouterCore1_extra_node_3 a noria:Resource ;
    rdfs:label "Core Router_extra_node_3 1"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam_extra_node_3 ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000_extra_node_3 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTRC01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_3 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_1_extra_node_3 .

noria:Resource_AppServer01_extra_node_3 a noria:Resource ;
    rdfs:label "Application Server_extra_node_3 01"@en ;
    rdfs:comment "Server_extra_node_3 hosting critical_extra_node_3 business applications."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam_extra_node_3 ;
    noria:resourceHostName "appserver01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_3 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-APPS01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2022-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2_extra_node_3 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_20_extra_node_3 .

noria:Resource_VirtualHost01_extra_node_3 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server running multiple virtual machines."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam_extra_node_3 ;
    noria:resourceHostName "vhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_3 ;
    noria:resourceType <kos/Resource/type/hypervisor_extra_node_3> ;
    noria:resourceSerialNumber "SN-VHOST01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2023-02-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2_extra_node_3 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_30_extra_node_3 .

noria:Resource_VMWeb01_extra_node_3 a noria:Resource ;
    rdfs:label "Web Server_extra_node_3 VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam_extra_node_3 ;
    noria:resourceHostName "webvm01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi_extra_node_3 ; # The hypervisor_extra_node_3 model, not the VM itself
    noria:resourceType <kos/Resource/type/virtual-machine_extra_node_3> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2023-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_VirtualHost01_extra_node_3 ;
    noria:resourceManagementIPAddress observable:IPAddress_172_16_0_10_extra_node_3 .

