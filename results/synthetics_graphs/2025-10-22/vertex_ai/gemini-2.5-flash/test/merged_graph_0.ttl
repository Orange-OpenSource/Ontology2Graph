    rdfs:label "Initial Diagnosis_extra_node_4 Note for TT001"@en ;
    rdfs:comment "Initial checks show no local network issues on DNS server. Suspect upstream network or firewall."@en ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JohnDoe_extra_node_4 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_4> ;
