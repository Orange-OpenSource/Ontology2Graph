# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog_extra_node_3 a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_3 Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01_extra_node_3 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_3> .

noria:EventRecord_InterfaceDown_extra_node_3 a noria:EventRecord ;
    rdfs:label "Router_extra_node_3 Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical_extra_node_3 network interface on Core Router_extra_node_3 1 went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "ALERT: Interface Gi0/0/1 on router-core-01.corp.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1_extra_node_3 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_3> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckFiberLink_extra_node_3 .

noria:EventRecord_ConfigChange_extra_node_3 a noria:EventRecord ;
    rdfs:label "Router_extra_node_3 Configuration_extra_node_3 Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router_extra_node_3 1."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logText "INFO: Configuration_extra_node_3 changed by Jane Smith from console. Interface Gi0/0/1 shutdown."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1_extra_node_3 ;
    noria:logOriginatingAgent foaf:Agent_JaneSmith_extra_node_3 ;
