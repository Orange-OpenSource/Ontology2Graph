    noria:logText "Trouble Ticket TT-20240420-001 status changed to Resolved."@en ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_2 ;
    noria:logOriginatingAgent noria:Agent_JohnDoe_extra_node_2 .

noria:TroubleTicket_DNSOutage001_extra_node_2 noria:documentStatusHistory noria:EventRecord_TT_DNSOutage001_StatusChange_Resolved_extra_node_2 .



