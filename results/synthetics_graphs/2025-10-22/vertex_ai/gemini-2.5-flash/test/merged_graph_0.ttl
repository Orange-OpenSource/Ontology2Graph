# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

foaf:Agent_DNSAdminTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_3> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical_extra_node_3 issues, use emergency hotline."@en .

foaf:Agent_NetworkOpsTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure_extra_node_3 and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_3> ;
    noria:agentInstructions "Immediate escalation for network outages. Use dedicated incident management platform."@en .

foaf:Agent_AppSupportTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2 support for critical_extra_node_3 business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system_extra_node_3> .

foaf:Agent_JohnDoe_extra_node_3 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for DNS Services."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_3> .

foaf:Agent_JaneSmith_extra_node_3 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network Engineer responsible for core routing."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_3> .

org:OrgUnit_ITOperations_extra_node_3 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Overall department for IT infrastructure_extra_node_3 and application operations."@en .

org:OrgUnit_SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_DataCenterA_extra_node_3 a bot:Site ;
    rdfs:label "Main Data Center A"@en ;
    noria:siteId "DC-A-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoom1_extra_node_3 a noria:Room ;
    rdfs:label "Server_extra_node_3 Room 1"@en ;
    rdfs:comment "Primary server room in Data Center A."@en ;
    bot:hasSpace noria:Locus_RackA1_extra_node_3 .

noria:Locus_RackA1_extra_node_3 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of core network and DNS servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_RackA2_extra_node_3 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

