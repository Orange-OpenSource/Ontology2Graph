# Example of a corrective maintenance action (implicitly linked via pep:ProcedureExecutionContainer)
# A TroubleTicket is a pep:ProcedureExecutionContainer.
# An EventRecord is a pep:ProcedureExecution.
# So, an EventRecord can be a member of a TroubleTicket's execution container.
noria:TroubleTicket_DNSOutage001_extra_node_2 pep:member noria:EventRecord_DNSOutageLog_extra_node_2 .
noria:TroubleTicket_WebAppPerformance001_extra_node_2 pep:member noria:EventRecord_VMWeb01HighCPU_extra_node_2 .

# Example of document status history
noria:EventRecord_TT_DNSOutage001_StatusChange_Resolved_extra_node_2 a noria:EventRecord ;
    rdfs:label "DNS Outage Ticket Status Change to Resolved"@en ;
