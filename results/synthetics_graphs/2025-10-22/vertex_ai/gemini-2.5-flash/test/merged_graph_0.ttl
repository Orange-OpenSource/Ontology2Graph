# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_LAN_Core_DNS_extra_node_3 a noria:NetworkLink ;
    rdfs:label "LAN Link Core-DNS"@en ;
    rdfs:comment "Internal_extra_node_3 LAN link between Core Router_extra_node_3 1 and DNS Server_extra_node_3 01."@en ;
    noria:networkLinkId "NL-LAN-001" ;
    noria:networkLinkType "Ethernet 10Gbps"@en ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore1_Gi0_0_0_extra_node_3 ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0_extra_node_3 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore1_extra_node_3 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DNS01_extra_node_3 .

noria:NetworkLink_WAN_External_extra_node_3 a noria:NetworkLink ;
    rdfs:label "WAN Link External"@en ;
    rdfs:comment "External WAN link from Core Router_extra_node_3 1 to ISP."@en ;
    noria:networkLinkId "NL-WAN-001" ;
    noria:networkLinkType "Fiber Optic 100Gbps"@en ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore1_Gi0_0_1_extra_node_3 ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore1_extra_node_3 ; # Assuming the other end is external and not modeled
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam_extra_node_3 .

noria:NetworkLink_LAN_App_VM_extra_node_3 a noria:NetworkLink ;
    rdfs:label "LAN Link App-VM"@en ;
    rdfs:comment "Internal_extra_node_3 LAN link between Application Server_extra_node_3 01 and Web Server_extra_node_3 VM 01 (via Virtual Host)."@en ;
    noria:networkLinkId "NL-LAN-002" ;
    noria:networkLinkType "Virtual Ethernet"@en ;
    noria:networkLinkInstallationDate "2023-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_AppServer01_Eth0_extra_node_3 ;
    noria:networkInterfaceConnects noria:NetworkInterface_VMWeb01_Eth0_extra_node_3 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_AppServer01_extra_node_3 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_VMWeb01_extra_node_3 .

