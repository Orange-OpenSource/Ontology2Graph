    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 Security Monitoring"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alert_system_extra_node_5> ;
    noria:agentInstructions "Automated alerts for critical security events. Manual review for suspicious activities."@en .

