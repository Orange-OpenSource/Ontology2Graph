    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack1A ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_AppServerVM01 a noria:Resource ;
    rdfs:label "Application Server VM 01"@en ;
    rdfs:label "VM Serveur Applicatif 01"@fr ;
