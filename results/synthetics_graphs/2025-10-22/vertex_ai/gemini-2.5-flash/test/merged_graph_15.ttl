# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical network interface on Core Router 1 went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "ALERT: Interface Gi0/0/1 on router-core-01.corp.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckFiberLink .

noria:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router 1."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logText "INFO: Configuration changed by Jane Smith from console. Interface Gi0/0/1 shutdown."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1 ;
    noria:logOriginatingAgent foaf:Agent_JaneSmith ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_VMCPUHigh a noria:EventRecord ;
    rdfs:label "VM CPU Usage High Alert"@en ;
    rdfs:comment "Alert for high CPU utilization on Web Server VM 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU usage on webvm01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_VMWeb01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Critical incident: Corporate DNS server is unreachable, impacting all services."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedService noria:Application_DNS_Service ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty foaf:Agent_DNSAdminTeam ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketCause "Unknown, suspected network connectivity issue."@en ;
    noria:documentHRef "https://itsm.example.com/tt/DNSOutage" .

noria:TroubleTicket_WANLinkDown a noria:TroubleTicket ;
    rdfs:label "WAN Link Down Incident"@en ;
    rdfs:comment "Major incident: External WAN link on Core Router 1 is down, impacting internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedService noria:Application_CorpInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_RouterCore1 ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkOpsTeam ;
    noria:troubleTicketTrigger noria:EventRecord_InterfaceDown ;
    noria:troubleTicketCause "Physical fiber cut suspected."@en ;
    noria:documentHRef "https://itsm.example.com/tt/WANLinkDown" .

noria:TroubleTicket_WebPortalPerformance a noria:TroubleTicket ;
    rdfs:label "Web Portal Slow Performance"@en ;
    rdfs:comment "Minor incident: Corporate Web Portal experiencing slow response times."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/User> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedService noria:Application_WebPortal ;
    noria:troubleTicketRelatedResource noria:Resource_VMWeb01 ;
    noria:troubleTicketRelatedParty foaf:Agent_AppSupportTeam ;
    noria:troubleTicketTrigger noria:EventRecord_VMCPUHigh ;
    noria:troubleTicketCause "High CPU usage on VM."@en ;
    noria:documentHRef "https://itsm.example.com/tt/WebPortalSlow" .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote_DNSDiag1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage - Initial Diagnosis"@en ;
    rdfs:comment "Initial checks confirm DNS service is not responding on port 53. Pinging server IP is successful. Suspect DNS service process issue or firewall."@en ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage ;
    dcterms:created "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote_WANLinkDiag1 a noria:TroubleTicketNote ;
    rdfs:label "WAN Link Down - Physical Check"@en ;
    rdfs:comment "Physical inspection of fiber optic cable at DC-A-01 confirms a cut. Escalated to external provider for repair."@en ;
    dcterms:isPartOf noria:TroubleTicket_WANLinkDown ;
    dcterms:created "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JaneSmith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> .

