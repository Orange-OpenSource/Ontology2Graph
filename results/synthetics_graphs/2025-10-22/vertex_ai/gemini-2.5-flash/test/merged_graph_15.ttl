# =============================================================================
# Services (noria:Service)
# =============================================================================

<service/CriticalInternetAccess> a noria:Service ;
    rdfs:label "Critical Internet Access Service"@en ;
    rdfs:comment "End-to-end service providing internet access for critical business functions."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <service/CriticalInternetAccess> ; # Self-reference or to a higher-level service if applicable
    noria:elementManagedBy <agent/NetworkOpsTeam> .

<applicationmodule/CorporateDNS-Prod> seas:subSystemOf <service/CriticalInternetAccess> .
<application/CorporateDNS> seas:subSystemOf <service/CriticalInternetAccess> . # An application can also be part of a service

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

<eventrecord/DNSOutageAlarm-20240120-0900> a noria:EventRecord ;
    rdfs:label "DNS Server 01 Unreachable Alarm"@en ;
    rdfs:comment "Alarm triggered due to DNS01 not responding to health checks."@en ;
    noria:loggingTime "2024-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/DNS01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "Host dns01.corp.example.com is UNREACHABLE. Ping failed."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/OperationalAlarm> .

<application/MonitoringSystem> a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Application responsible for collecting and analyzing system health data."@en ;
    noria:applicationType <kos/application/type/monitoring> .

<eventrecord/CR01InterfaceDown-20240120-0915> a noria:EventRecord ;
    rdfs:label "CR01 GigE 0/0/1 Interface Down"@en ;
    rdfs:comment "Log entry indicating that the uplink interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-01-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/CoreRouter01> ;
    noria:logOriginatingManagementSystem <application/SyslogServer> ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/StateChange> .

<application/SyslogServer> a noria:Application ;
    rdfs:label "Central Syslog Server"@en ;
    rdfs:comment "Application for centralizing log messages from network devices."@en ;
    noria:applicationType <kos/application/type/logging> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

<troubleticket/TT-20240120-001> a noria:TroubleTicket ;
    rdfs:label "Critical DNS Outage - Impacting Internet Access"@en ;
    rdfs:comment "DNS server dns01.corp.example.com is unreachable, causing widespread internet access issues."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2024-01-20T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedService <application/CorporateDNS> ;
    noria:troubleTicketRelatedResource <resource/DNS01> ;
    noria:troubleTicketRelatedParty <agent/NOCSupportTeam> ;
    noria:troubleTicketTrigger <eventrecord/DNSOutageAlarm-20240120-0900> ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring"@en ;
    noria:troubleTicketCause "Suspected network connectivity issue to primary DNS server."@en ;
    noria:documentHRef <http://ticketing.example.com/TT-20240120-001> .

<troubleticket/TT-20240120-002> a noria:TroubleTicket ;
    rdfs:label "Core Router Uplink Down - Secondary Impact"@en ;
    rdfs:comment "Secondary trouble ticket opened after identifying CR01 uplink as root cause for DNS outage."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Internal> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2024-01-20T09:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedService <service/CriticalInternetAccess> ;
    noria:troubleTicketRelatedResource <resource/CoreRouter01> ;
    noria:troubleTicketRelatedParty <agent/NOCSupportTeam> ;
    noria:troubleTicketTrigger <eventrecord/CR01InterfaceDown-20240120-0915> ;
    noria:troubleTicketCause "Physical fiber cut on ISP uplink."@en ;
    noria:documentHRef <http://ticketing.example.com/TT-20240120-002> .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

<troubleticketnote/TTN-20240120-001-01> a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for TT-001"@en ;
    rdfs:comment "NOC team confirmed DNS01 unreachable. Initial checks show no local server issues. Suspecting upstream network."@en ;
    dcterms:created "2024-01-20T09:10:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/JaneSmith> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf <troubleticket/TT-20240120-001> .

<troubleticketnote/TTN-20240120-001-02> a noria:TroubleTicketNote ;
    rdfs:label "Root Cause Identified for TT-001"@en ;
    rdfs:comment "Traced connectivity issue to CR01 GigE 0/0/1 interface being down. Opening new TT for network team."@en ;
    dcterms:created "2024-01-20T09:25:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/JaneSmith> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf <troubleticket/TT-20240120-001> .

# =============================================================================
# Change Requests (noria:ChangeRequest)
# =============================================================================

<changerequest/CR-20240120-001> a noria:ChangeRequest ;
    rdfs:label "Replace Faulty Fiber Optic Link to ISP"@en ;
    rdfs:comment "Emergency change request to replace the fiber optic link connected to CR01 GigE 0/0/1 due to physical damage."@en ;
    noria:changeRequestPlannedStartTime "2024-01-20T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-01-20T12:00:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestType <kos/ChangeRequest/type/Emergency> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/HardwareReplacement> ;
    noria:changeRequestImpact <networklink/Link-CR01-ISP> ;
    noria:changeRequestImpact <networkinterface/CR01-GigE0-0-1> ;
    noria:changeRequestInitiatorParty <agent/JaneSmith> ;
    noria:changeRequestPilotParty <agent/NetworkOpsTeam> ;
    noria:changeRequestActorParty <agent/NetworkOpsTeam> ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:documentHRef <http://changemanagement.example.com/CR-20240120-001> .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

<operationplan/FiberReplacementProcedure> a noria:OperationPlan ;
    rdfs:label "Fiber Optic Link Replacement Procedure"@en ;
    rdfs:comment "Standard operating procedure for replacing a faulty fiber optic link."@en ;
    noria:operationPlanPreCondition <actionprecondition/VerifyFaultyLink> ;
    noria:operationPlanPostCondition <actionpostcondition/VerifyLinkRestored> .

<actionprecondition/VerifyFaultyLink> a noria:ActionPreCondition ;
    rdfs:label "Verify Faulty Link"@en ;
    rdfs:comment "Ensure the link is indeed faulty and requires replacement."@en .

<actionpostcondition/VerifyLinkRestored> a noria:ActionPostCondition ;
    rdfs:label "Verify Link Restored"@en ;
    rdfs:comment "Confirm that the new link is operational and traffic is flowing."@en .

<changerequest/CR-20240120-001> pep:usedProcedure <operationplan/FiberReplacementProcedure> .

# =============================================================================
# Additional Connectivity and Density
# =============================================================================

<agent/DNSAdminTeam> noria:agentManagesResource <resource/DNS01>, <resource/DNS02> .
<agent/NetworkOpsTeam> noria:agentManagesResource <resource/CoreRouter01>, <networklink/Link-CR01-ISP> .
<agent/NOCSupportTeam> noria:agentManagesResource <resource/VirtualMachine01> .

<application/CorporateDNS> noria:elementManagedBy <agent/DNSAdminTeam> .
<application/WebPortal> noria:elementManagedBy <agent/NOCSupportTeam> .
<application/MonitoringSystem> noria:elementManagedBy <agent/NOCSupportTeam> .

<troubleticket/TT-20240120-001> noria:documentStatusHistory <eventrecord/DNSOutageAlarm-20240120-0900> .
<troubleticket/TT-20240120-002> noria:documentStatusHistory <eventrecord/CR01InterfaceDown-20240120-0915> .

<changerequest/CR-20240120-001> noria:documentStatusHistory <eventrecord/CR01InterfaceDown-20240120-0915> .

# Example of a resource being a cluster controller for another resource
<resource/LoadBalancer01> a noria:Resource ;
    rdfs:label "Application Load Balancer 01"@en ;
    noria:resourceType <kos/Resource/type/LoadBalancer> ;
    noria:resourceHostName "lb01.corp.example.com" .

<resource/WebFrontend01> a noria:Resource ;
    rdfs:label "Web Frontend Server 01"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:clusterController <resource/LoadBalancer01> .

<resource/WebFrontend02> a noria:Resource ;
    rdfs:label "Web Frontend Server 02"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceHostName "web02.corp.example.com" ;
    noria:clusterController <resource/LoadBalancer01> .

# Example of a more complex application module relationship
<applicationmodule/CorporateDNS-Test> a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Test Module"@en ;
    noria:applicationModuleOf <application/CorporateDNS> ;
    noria:applicationModuleName "CORP-DNS_TEST" ;
    noria:applicationModuleIdentifier "TEST" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InDevelopment> ;
    noria:applicationModuleSupportTeam <agent/DNSAdminTeam> .

<application/CorporateDNS> noria:elementManagedBy <agent/DNSAdminTeam> .
<application/WebPortal> noria:elementManagedBy <agent/NOCSupportTeam> .
<application/MonitoringSystem> noria:elementManagedBy <agent/NOCSupportTeam> .
<application/SyslogServer> noria:elementManagedBy <agent/NetworkOpsTeam> .

# Example of a trouble ticket impacting multiple entities
<troubleticket/TT-20240120-001> noria:troubleTicketImpacts <application/CorporateDNS> .
<troubleticket/TT-20240120-001> noria:troubleTicketImpacts <resource/DNS01> .
<troubleticket/TT-20240120-001> noria:troubleTicketImpacts <service/CriticalInternetAccess> .

# Example of a change request impacting multiple entities
<changerequest/CR-20240120-001> noria:changeRequestImpact <networklink/Link-CR01-ISP> .
<changerequest/CR-20240120-001> noria:changeRequestImpact <resource/CoreRouter01> .
<changerequest/CR-20240120-001> noria:changeRequestImpact <service/CriticalInternetAccess> .

# Example of a trouble ticket with a problem category and responsibility
<troubleticket/TT-20240120-002> noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> .

# Example of a change request being regulated
<changerequest/CR-20240120-001> noria:changeRequestIsRegulated true .

# Example of an event record with an originating agent
<eventrecord/CR01ConfigChange-20240120-1030> a noria:EventRecord ;
    rdfs:label "CR01 Configuration Change by John Doe"@en ;
    rdfs:comment "Configuration change applied to Core Router 01 by John Doe."@en ;
    noria:loggingTime "2024-01-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/CoreRouter01> ;
    noria:logOriginatingAgent <agent/JohnDoe> ;
    noria:logText "Configuration updated: interface GigE 0/0/1 no shutdown"@en ;
    dcterms:type <kos/Notification/EventType/ConfigurationChange> .

# Example of an alarm being mitigated by a procedure execution container (e.g., a change request)
<eventrecord/DNSOutageAlarm-20240120-0900> noria:alarmMitigatedBy <changerequest/CR-20240120-001> .


# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Immediate phone call for any network outage. Use ticketing for routine changes."@en .

foaf:Agent_AppSupportL2 a foaf:Agent ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support for critical business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing> ;
    noria:agentInstructions "Escalate from L1 via ticketing system. Direct contact only for P1 incidents."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
