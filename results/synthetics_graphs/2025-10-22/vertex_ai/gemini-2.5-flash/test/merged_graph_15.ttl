noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel_CiscoASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Enterprise-class aggregation services router."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com> .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for internal and external resolution."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_10 .

noria:Resource_RouterCore1 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTRC01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_1 .

noria:Resource_AppServer01 a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting critical business applications."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam ;
    noria:resourceHostName "appserver01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-APPS01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_20 .

noria:Resource_VirtualHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server running multiple virtual machines."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam ;
    noria:resourceHostName "vhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceSerialNumber "SN-VHOST01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_30 .

noria:Resource_VMWeb01 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam ;
    noria:resourceHostName "webvm01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_VirtualHost01 ;
    noria:resourceManagementIPAddress observable:IPAddress_172_16_0_10 .

