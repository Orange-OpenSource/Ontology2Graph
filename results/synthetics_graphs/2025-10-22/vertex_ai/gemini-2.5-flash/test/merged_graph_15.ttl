# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical router interface went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "LINKPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartInterface .

noria:EventRecord_LoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security event: multiple failed login attempts on appvm01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "AUTH_FAILED: User 'attacker' failed to login 5 times from 1.2.3.4 on appvm01."@en ;
    noria:logOriginatingManagedObject noria:Resource_AppServerVM01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logOriginatingAgent <http://example.com/external/attacker> ; # Example of external agent
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<http://example.com/external/attacker> a foaf:Agent ;
    rdfs:label "External Attacker"@en ;
    rdfs:comment "Hypothetical external entity attempting unauthorized access."@en .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket_DNSOutage_TT001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident de Panne Serveur DNS"@fr ;
    rdfs:comment "DNS server unreachable causing internet access issues for corporate users."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
