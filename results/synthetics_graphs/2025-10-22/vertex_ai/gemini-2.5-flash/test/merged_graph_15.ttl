    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application_CorporateDNS ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty noria:Agent_DNSAdminTeam ;
    noria:troubleTicketTrigger noria:Event_DNS01_Down ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:documentStatusHistory noria:Event_DNS01_Down .

noria:TroubleTicket_InternetAccessDegradation a noria:TroubleTicket ;
    rdfs:label "Internet Access Degradation"@en ;
    rdfs:comment "Users reporting slow internet access, potentially due to router interface issue."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_RouterCore01 ;
    noria:troubleTicketRelatedParty noria:Agent_NetworkOpsTeam ;
    noria:troubleTicketTrigger noria:Event_RouterCore01_InterfaceDown ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketCause "Suspected fiber cut on ISP uplink."@en ;
    noria:documentExternalId "CUST-INC-2024-001" ;
    noria:documentHRef "https://ticketing.example.com/ticket/CUST-INC-2024-001" .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote_DNSDiag1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Diagnosis Note 1"@en ;
    rdfs:comment "Initial diagnosis: confirmed DNS service is not responding on dns01.corp.example.com. Checked network connectivity, appears fine."@en ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:creator noria:Agent_JohnDoe .

noria:TroubleTicketNote_RouterDiag1 a noria:TroubleTicketNote ;
    rdfs:label "Router Interface Diagnosis Note 1"@en ;
    rdfs:comment "Confirmed Gi0/0/1 is physically down. Initiated contact with ISP for line check."@en ;
    dcterms:isPartOf noria:TroubleTicket_InternetAccessDegradation ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:creator noria:Agent_NetworkOpsTeam .

