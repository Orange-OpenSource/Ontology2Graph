    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 Security Monitoring"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alert_system> ;
    noria:agentInstructions "Automated alerts for critical security events. Manual review for suspicious activities."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual IT administrator."@en .

org:OrgUnit_ITInfrastructure a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en ;
    rdfs:comment "Department overseeing all IT infrastructure components."@en .

org:OrgUnit_AppDev a org:OrganizationalUnit ;
    rdfs:label "Application Development Unit"@en ;
    rdfs:comment "Unit responsible for developing and maintaining business applications."@en .

