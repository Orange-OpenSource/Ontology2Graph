# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:Event_DNS01_Down a noria:EventRecord ;
    rdfs:label "DNS01 Server Down Event"@en ;
    rdfs:comment "Log entry indicating DNS01 server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN!"@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "Application responsible for monitoring IT infrastructure."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

noria:Event_RouterCore01_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Core 01 Interface Down Event"@en ;
    rdfs:comment "Log entry for Gi0/0/1 interface going down on Core Router 01."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_VMWeb01_HighCPU a noria:EventRecord ;
    rdfs:label "Web VM High CPU Warning"@en ;
    rdfs:comment "Log entry indicating high CPU utilization on Web Server VM 01."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_VMWeb01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_JohnDoe_ConfigChange a noria:EventRecord ;
    rdfs:label "John Doe Config Change Event"@en ;
    rdfs:comment "Log entry for a configuration change made by John Doe."@en ;
    noria:loggingTime "2024-04-19T14:00:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by vty0 (10.0.0.5) by user JohnDoe"@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent noria:Agent_JohnDoe .

