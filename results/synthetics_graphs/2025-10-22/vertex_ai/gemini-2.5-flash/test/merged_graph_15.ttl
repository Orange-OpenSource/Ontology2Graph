    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ789" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <location/LocusA1-R1-C1> ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

<resource/DNS02> a noria:Resource ;
    rdfs:label "Corporate DNS Server 02"@en ;
    rdfs:comment "Secondary DNS server for redundancy."@en ;
    noria:resourceManagedBy <agent/DNSAdminTeam> ;
    noria:resourceHostName "dns02.corp.example.com" ;
    noria:resourceProductModel <productmodel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS02-ABC123" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <location/LocusA1-R1-C2> ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.11> .

<resource/CoreRouter01> a noria:Resource ;
    rdfs:label "Core Network Router 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy <agent/NetworkOpsTeam> ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceProductModel <productmodel/CiscoCatalyst9300> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR01-DEF456" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-01T14:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <location/LocusA1-R1-C1> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

<resource/VirtualMachine01> a noria:Resource ;
    rdfs:label "Application Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting a critical application component."@en ;
    noria:resourceManagedBy <agent/NOCSupportTeam> ;
    noria:resourceHostName "appvm01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

<networkinterface/DNS01-Eth0> a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01."@en ;
    noria:networkInterfaceOf <resource/DNS01> ;
    noria:networkInterfaceDescription "Management interface for DNS01" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkinterface/CR01-GigE0-0-1> a noria:NetworkInterface ;
    rdfs:label "CR01 GigE 0/0/1"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to ISP."@en ;
    noria:networkInterfaceOf <resource/CoreRouter01> ;
    noria:networkInterfaceDescription "ISP Uplink 1" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

<networkinterface/CR01-GigE0-0-2> a noria:NetworkInterface ;
    rdfs:label "CR01 GigE 0/0/2"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to internal network."@en ;
    noria:networkInterfaceOf <resource/CoreRouter01> ;
    noria:networkInterfaceDescription "Internal Network Link" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

<networklink/Link-CR01-ISP> a noria:NetworkLink ;
    rdfs:label "Core Router 01 to ISP Link"@en ;
    rdfs:comment "High-speed fiber link connecting CR01 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-CR01-ISP-001" ;
    noria:networkLinkTerminationResourceOrigin <resource/CoreRouter01> ;
    noria:networkLinkTerminationResourceDestination <resource/ISP-Router-A> ; # Assuming an external ISP router resource
    noria:networkLinkInstallationDate "2021-08-01T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" ;
    noria:resourceManagedBy <agent/NetworkOpsTeam> ;
    noria:networkInterfaceConnects <networkinterface/CR01-GigE0-0-1> .

<resource/ISP-Router-A> a noria:Resource ;
    rdfs:label "ISP Router A"@en ;
    rdfs:comment "External ISP router, termination point for corporate uplink."@en ;
    noria:resourceType <kos/Resource/type/Router> .

<networklink/Link-CR01-Internal> a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Internal Network Link"@en ;
    rdfs:comment "Internal network link connecting CR01 to the rest of the corporate LAN."@en ;
    noria:networkLinkId "NL-CR01-INT-001" ;
    noria:networkLinkTerminationResourceOrigin <resource/CoreRouter01> ;
    noria:networkLinkInstallationDate "2021-08-01T15:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy <agent/NetworkOpsTeam> ;
    noria:networkInterfaceConnects <networkinterface/CR01-GigE0-0-2> .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

<application/CorporateDNS> a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:comment "Provides DNS resolution for all corporate services and users."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "DNS Resolution"@en ;
    noria:applicationShortIdentifier "CORP-DNS" ;
    noria:applicationNumericalIdentifier 101 .

<application/WebPortal> a noria:Application ;
    rdfs:label "Internal Web Portal"@en ;
    rdfs:comment "Web portal for internal employee services."@en ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Human Resources"@en ;
    noria:applicationFunctionalSubDomain "Employee Self-Service"@en ;
    noria:applicationShortIdentifier "INT-PORTAL" ;
    noria:applicationNumericalIdentifier 201 .

<resource/DNS01> noria:resourceForApplication <application/CorporateDNS> .
<resource/DNS02> noria:resourceForApplication <application/CorporateDNS> .
<resource/VirtualMachine01> noria:resourceForApplication <application/WebPortal> .

