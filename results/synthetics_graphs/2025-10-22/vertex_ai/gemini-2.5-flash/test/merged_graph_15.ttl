# Change Requests (noria:ChangeRequest)
# =============================================================================

noria:ChangeRequest_RouterUpgrade a noria:ChangeRequest ;
    rdfs:label "Core Router Software Upgrade"@en ;
    rdfs:comment "Planned software upgrade for RouterCore1 to enhance security and performance."@en ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestPlannedStartTime "2024-05-10T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-10T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestImpact noria:Resource_RouterCore1 ;
    noria:changeRequestImpact noria:Service_InternetAccess ;
    noria:changeRequestInitiatorParty foaf:Agent_NetworkOpsTeam ;
    noria:changeRequestPilotParty foaf:Agent_JohnDoe ;
    noria:changeRequestActorParty foaf:Agent_NetworkOpsTeam ;
    noria:changeRequestIsRegulated true ;
    noria:documentExternalId "CR-2024-05-10-001" ;
    noria:documentHRef "https://itsm.example.com/change/CR-2024-05-10-001" .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_CheckFiberLink a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Standard operating procedure to diagnose and troubleshoot fiber optic link issues."@en ;
    skos:example "1. Verify physical connection. 2. Check optical power levels. 3. Contact ISP if issue persists."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_LinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LinkRestored .

noria:ActionPreCondition_LinkDown a noria:ActionPreCondition ;
    rdfs:label "Network Link Down Pre-Condition"@en ;
    rdfs:comment "Condition where a network link's operational status is 'down'."@en .

noria:ActionPostCondition_LinkRestored a noria:ActionPostCondition ;
    rdfs:label "Network Link Restored Post-Condition"@en ;
    rdfs:comment "Expected outcome: network link's operational status is 'up' and traffic flows."@en .

noria:OperationPlan_DNSFailover a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Procedure to activate secondary DNS server in case of primary DNS failure."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSFunctional .

noria:ActionPreCondition_DNSUnreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unreachable Pre-Condition"@en ;
    rdfs:comment "Condition where primary DNS server is not responding to queries."@en .

noria:ActionPostCondition_DNSFunctional a noria:ActionPostCondition ;
    rdfs:label "DNS Service Functional Post-Condition"@en ;
    rdfs:comment "Expected outcome: DNS resolution is restored via secondary server."@en .

# =============================================================================
# Connectivity and Density Check
# =============================================================================
# All entities created are linked to at least one other entity via NORIA properties.
# - foaf:Agent, org:OrganizationalUnit: linked to Resources, ApplicationModules, TroubleTickets, ChangeRequests.
# - bot:Site, noria:Room, noria:Locus: linked to Resources.
# - noria:ProductModel: linked to Resources.
# - noria:Resource: linked to Agents, ProductModels, Locus, NetworkInterfaces, Applications, EventRecords, TroubleTickets, ChangeRequests.
# - noria:NetworkInterface: linked to Resources, NetworkLinks.
# - noria:NetworkLink: linked to NetworkInterfaces, Resources, Agents.
# - noria:Application: linked to Resources, ApplicationModules, EventRecords, TroubleTickets, ChangeRequests.
# - noria:ApplicationModule: linked to Applications, Agents, Services.
# - noria:Service: linked to ApplicationModules, Resources, TroubleTickets, ChangeRequests.
# - noria:EventRecord: linked to Resources, Applications, Agents, TroubleTickets, OperationPlans.
# - noria:TroubleTicket: linked to Resources, Applications, Services, Agents, EventRecords, TroubleTicketNotes.
# - noria:TroubleTicketNote: linked to TroubleTickets, Agents.
# - noria:ChangeRequest: linked to Resources, Applications, Services, Agents.
# - noria:OperationPlan: linked to EventRecords, ActionPreCondition, ActionPostCondition.
# - noria:ActionPreCondition, noria:ActionPostCondition: linked to OperationPlans.
# The graph is dense and reflects typical IT infrastructure and incident management scenarios.


# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person)
# =============================================================================

noria:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and support."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

noria:Agent_NetworkOps a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:label "Centre d'Opérations Réseau"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

noria:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team A"@en ;
    rdfs:label "Équipe de Développement Applicatif A"@fr ;
    rdfs:comment "Team responsible for developing and maintaining critical business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en .

noria:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cyber Security Operations"@en ;
    rdfs:label "Opérations de Cybersécurité"@fr ;
    rdfs:comment "Team dedicated to monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en .

noria:Agent_JohnDoe a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:label "Jean Dupont"@fr ;
    rdfs:comment "Lead administrator for DNS services."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

noria:Agent_JaneSmith a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:label "Jeanne Martin"@fr ;
    rdfs:comment "Network engineer responsible for core routing."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

