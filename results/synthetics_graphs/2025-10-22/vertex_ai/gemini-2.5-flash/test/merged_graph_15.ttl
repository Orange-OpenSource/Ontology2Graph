    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkInterface_AppServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "appserver01-eth0"@en ;
    rdfs:comment "Ethernet interface for Application Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_AppServer01 ;
    noria:networkInterfaceDescription "Primary network interface for application traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_VMWeb01_Eth0 a noria:NetworkInterface ;
    rdfs:label "webvm01-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Web Server VM 01."@en ;
    noria:networkInterfaceOf noria:Resource_VMWeb01 ;
    noria:networkInterfaceDescription "Virtual network interface for web traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_LAN_Core_DNS a noria:NetworkLink ;
    rdfs:label "LAN Link Core-DNS"@en ;
    rdfs:comment "Internal LAN link between Core Router 1 and DNS Server 01."@en ;
    noria:networkLinkId "NL-LAN-001" ;
    noria:networkLinkType "Ethernet 10Gbps"@en ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore1_Gi0_0_0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DNS01 .

noria:NetworkLink_WAN_External a noria:NetworkLink ;
    rdfs:label "WAN Link External"@en ;
    rdfs:comment "External WAN link from Core Router 1 to ISP."@en ;
    noria:networkLinkId "NL-WAN-001" ;
    noria:networkLinkType "Fiber Optic 100Gbps"@en ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore1_Gi0_0_1 ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore1 ; # Assuming the other end is external and not modeled
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam .

noria:NetworkLink_LAN_App_VM a noria:NetworkLink ;
    rdfs:label "LAN Link App-VM"@en ;
    rdfs:comment "Internal LAN link between Application Server 01 and Web Server VM 01 (via Virtual Host)."@en ;
    noria:networkLinkId "NL-LAN-002" ;
    noria:networkLinkType "Virtual Ethernet"@en ;
    noria:networkLinkInstallationDate "2023-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_AppServer01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_VMWeb01_Eth0 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_AppServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_VMWeb01 .

