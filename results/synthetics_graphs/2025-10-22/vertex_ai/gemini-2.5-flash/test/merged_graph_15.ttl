    rdfs:label "Customer Portal Service"@en ;
    rdfs:label "Service Portail Client"@fr ;
    rdfs:comment "Service exposing CRM functionalities to external customers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> .

