### Event Records (noria:EventRecord) ###

<https://w3id.org/noria/event/RouterInterfaceDown>
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Core Router 01."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/CoreRouter01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringPlatform> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<https://w3id.org/noria/event/WebServerCPULoadHigh>
    a noria:EventRecord ;
    rdfs:label "Web Server CPU Load High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-23T10:15:30Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.app.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/WebServer01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringPlatform> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction <https://w3id.org/noria/operationplan/RestartWebServerService> .

<https://w3id.org/noria/event/BillingAPIError>
    a noria:EventRecord ;
    rdfs:label "Billing API Error Log"@en ;
    rdfs:comment "Application error logged by the Billing API module."@en ;
    noria:loggingTime "2024-04-23T10:20:10Z"^^xsd:dateTime ;
    noria:logText "ERROR: Database connection failed for Billing API. Retrying..."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/application/BillingSystem> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringPlatform> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

<https://w3id.org/noria/event/FirewallBlockedTraffic>
    a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en ;
    rdfs:comment "Firewall log indicating blocked suspicious traffic from an external IP."@en ;
    noria:loggingTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Blocked traffic from 192.168.1.100 to internal network on port 22. Policy violation."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/FirewallFW01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/agent/SecurityTeam> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

