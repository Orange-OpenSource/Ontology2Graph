### Agents (foaf:Agent & org:OrganizationalUnit) ###

<https://w3id.org/noria/agent/ITOpsTeam>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en, "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for the daily operation and maintenance of IT infrastructure."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Contact via internal ticketing system for all non-critical issues. For critical issues, use emergency hotline."@en .

<https://w3id.org/noria/agent/NetworkAdminJohn>
    a foaf:Agent ;
    rdfs:label "John Doe (Network Admin)"@en, "Jean Dupont (Admin Réseau)"@fr ;
    rdfs:comment "Senior Network Administrator, specialized in core routing and switching."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

<https://w3id.org/noria/agent/AppSupportL2>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support L2 Team"@en, "Équipe Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support for critical business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> .

<https://w3id.org/noria/agent/CustomerService>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Service Department"@en, "Service Client"@fr ;
    rdfs:comment "First point of contact for customer inquiries and issues."@en ;
    noria:agentWorkingHours "8:00-20:00 (Mon-Sat)" .

<https://w3id.org/noria/agent/SecurityTeam>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center"@en, "Centre d'Opérations de Cybersécurité"@fr ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alert-system> .

