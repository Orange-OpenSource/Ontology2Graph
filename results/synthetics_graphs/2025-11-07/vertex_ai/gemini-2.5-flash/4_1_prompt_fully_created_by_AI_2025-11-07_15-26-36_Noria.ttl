    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Coordination> ;
    noria:troubleTicketNoteCorrelatedExecution <https://w3id.org/noria/event/FiberProviderDispatched> .

