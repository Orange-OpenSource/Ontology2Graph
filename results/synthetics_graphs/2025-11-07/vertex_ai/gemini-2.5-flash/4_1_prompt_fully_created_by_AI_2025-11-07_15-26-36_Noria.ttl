### Network Links (noria:NetworkLink) ###

<https://w3id.org/noria/networklink/WANLinkParisLyon>
    a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-Lyon"@en, "Liaison WAN Paris-Lyon"@fr ;
    rdfs:comment "Dedicated WAN link between Paris and Lyon data centers."@en ;
    noria:networkLinkId "WAN-PL-001" ;
    noria:networkLinkTerminationResourceOrigin <https://w3id.org/noria/resource/CoreRouter01> ;
    noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/resource/CoreRouter02> ; # Assuming CoreRouter02 exists in Lyon
    noria:networkLinkInstallationDate "2022-03-10T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN" ;
    noria:resourceManagedBy <https://w3id.org/noria/agent/NetworkAdminJohn> .

<https://w3id.org/noria/networklink/InternalLANSegmentA>
    a noria:NetworkLink ;
    rdfs:label "Internal LAN Segment A"@en, "Segment LAN Interne A"@fr ;
    rdfs:comment "Local Area Network segment connecting servers and core router."@en ;
    noria:networkLinkId "LAN-PDC01-A" ;
    noria:networkLinkInstallationDate "2022-01-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy <https://w3id.org/noria/agent/ITOpsTeam> .

