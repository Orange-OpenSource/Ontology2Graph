noria:TroubleTicket_AppOutage_001 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Outage - AppServer01 Down"@en ;
    rdfs:comment "Critical incident: Customer Portal is completely down due to AppServer01 being unreachable."@en ;
    dcterms:identifier "TT-20240423-001" ;
    noria:documentExternalId "INC-12345" ;
    noria:documentHRef <http://itsm.example.com/tickets/TT-20240423-001> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Incident> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/MonitoringSystem> ;
    noria:troubleTicketTrigger noria:EventRecord_AppServerDown ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServerFailure> ;
    noria:troubleTicketCause "Application server unresponsive, likely hardware failure or OS crash."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ; # Example, could be IT Operations
    noria:troubleTicketDetectionDateTime "2024-04-23T10:00:05Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Agent_IT_Operations, noria:Agent_App_Support ;
    noria:troubleTicketRelatedService noria:ApplicationModule_CustomerPortal_Prod ;
    noria:troubleTicketRelatedResource noria:Resource_AppServer01 ;
    noria:troubleTicketImpacts noria:Application_CustomerPortal, noria:Resource_AppServer01 .

noria:TroubleTicket_NetworkIssue_002 a noria:TroubleTicket ;
    rdfs:label "Intermittent Network Connectivity"@en ;
    rdfs:comment "Users reporting intermittent connectivity issues, correlated with router interface flaps."@en ;
