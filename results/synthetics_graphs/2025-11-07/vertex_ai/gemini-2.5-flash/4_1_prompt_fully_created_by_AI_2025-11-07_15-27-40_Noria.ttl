    noria:troubleTicketDetectionDateTime "2024-04-23T09:58:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
