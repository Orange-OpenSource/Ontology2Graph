    noria:resourceLogisticId "CR-01-DC-PAR" ;
    noria:resourceHostName "corerouter01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR01-ABC456" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-05-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_Network_Team ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.254> ;
    noria:locatedAtLocus noria:Locus_Rack_B5_U10 .

noria:Resource_EdgeSwitch01 a noria:Resource ;
    rdfs:label "Edge Switch 01"@en ;
    rdfs:comment "Access layer switch for Server Room A."@en ;
    noria:resourceLogisticId "ES-01-DC-PAR" ;
    noria:resourceHostName "edgeswitch01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-ES01-DEF789" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-03-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_Network_Team ;
    noria:locatedAtLocus noria:Locus_Rack_B5_U10 .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Database server for the Customer Portal application."@en ;
    noria:resourceLogisticId "DB-01-DC-PAR" ;
    noria:resourceHostName "dbserver01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB01-GHI012" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_IT_Operations ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:locatedAtLocus noria:Locus_Rack_A1_U23 .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_AppServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "AppServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Application Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_AppServer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Connected to internal application network."@en ;
    noria:networkInterfaceConnects noria:NetworkLink_AppServer_Switch .

noria:NetworkInterface_CoreRouter01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface for Core Router 01 to the WAN."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceConnects noria:NetworkLink_WAN_Uplink .

noria:NetworkInterface_EdgeSwitch01_Gi1_0_1 a noria:NetworkInterface ;
    rdfs:label "EdgeSwitch01 GigabitEthernet 1/0/1"@en ;
    rdfs:comment "Port connecting to AppServer01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeSwitch01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_AppServer_Switch .

noria:NetworkInterface_DBServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Connected to internal database network."@en ;
    noria:networkInterfaceConnects noria:NetworkLink_DBServer_Switch .

noria:NetworkInterface_EdgeSwitch01_Gi1_0_2 a noria:NetworkInterface ;
    rdfs:label "EdgeSwitch01 GigabitEthernet 1/0/2"@en ;
    rdfs:comment "Port connecting to DBServer01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeSwitch01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_DBServer_Switch .

# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_AppServer_Switch a noria:NetworkLink ;
    rdfs:label "AppServer01 to EdgeSwitch01 Link"@en ;
    rdfs:comment "Ethernet link between Application Server 01 and Edge Switch 01."@en ;
    noria:networkLinkId "NL-AS01-ES01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2023-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_Network_Team ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_AppServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeSwitch01 .

noria:NetworkLink_WAN_Uplink a noria:NetworkLink ;
    rdfs:label "Core Router WAN Uplink"@en ;
    rdfs:comment "Fiber optic link connecting Core Router 01 to the external WAN."@en ;
    noria:networkLinkId "NL-CR01-WAN" ;
    noria:networkLinkType "Fiber Optic 100Gbps" ;
    noria:networkLinkInstallationDate "2022-05-20T15:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_Network_Team ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter01 .

noria:NetworkLink_DBServer_Switch a noria:NetworkLink ;
    rdfs:label "DBServer01 to EdgeSwitch01 Link"@en ;
    rdfs:comment "Ethernet link between Database Server 01 and Edge Switch 01."@en ;
    noria:networkLinkId "NL-DB01-ES01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2023-01-15T11:15:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_Network_Team ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DBServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeSwitch01 .

# =============================================================================
# Applications
# =============================================================================

noria:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CP-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CustPortal" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Self-Service Management"@en ;
    noria:elementManagedBy noria:Agent_App_Support .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "System responsible for collecting and analyzing logs and metrics from IT infrastructure."@en ;
    noria:applicationModelIdentifier "CMS-V3" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "CMS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:elementManagedBy noria:Agent_IT_Operations .

# =============================================================================
# Application Modules
# =============================================================================

noria:ApplicationModule_CustomerPortal_Prod a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "The production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf noria:Application_CustomerPortal ;
    noria:applicationModuleIdentifier "CP-PROD-01" ;
    noria:applicationModuleName "CustPortal_CP-PROD-01" ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
