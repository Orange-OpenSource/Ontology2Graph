# --- Services (noria:Service) ---
noria:Service1 a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "Provides all necessary network connectivity for the enterprise."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:ApplicationModule1, noria:ApplicationModule4, noria:ApplicationModule6 .

noria:Service2 a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "Aggregates all customer-facing web applications and their underlying infrastructure."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:ApplicationModule2 .

noria:Service3 a noria:Service ;
    rdfs:label "Internal Business Application Service"@en ;
    rdfs:comment "Provides core business applications for internal operations."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:ApplicationModule3 .

noria:Service4 a noria:Service ;
    rdfs:label "Core Infrastructure Service"@en ;
    rdfs:comment "Underlying infrastructure services critical for all other services."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:ApplicationModule5, noria:ApplicationModule7, noria:ApplicationModule8, noria:ApplicationModule9, noria:ApplicationModule10 .

# --- Trouble Tickets (noria:TroubleTicket) ---
noria:TroubleTicket1 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Primary DNS server unreachable, causing internet access issues across the corporate network."@en ;
    rdfs:label "Incident de Panne du Serveur DNS"@fr ;
    dcterms:identifier "TT-20240423-001" ;
    dcterms:created "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Hardware failure on DNS server."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application1 ;
    noria:troubleTicketRelatedResource noria:Resource1 ;
    noria:troubleTicketRelatedParty foaf:Agent1, foaf:Agent2 ;
    noria:troubleTicketTrigger noria:EventRecord1 ;
    noria:troubleTicketImpacts noria:Application1, noria:Service1 ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-20240423-001" .

noria:TroubleTicket2 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Slow Performance"@en ;
    rdfs:comment "Customers reporting slow loading times and occasional timeouts on the portal."@en ;
    rdfs:label "Performances Lentes du Portail Client"@fr ;
