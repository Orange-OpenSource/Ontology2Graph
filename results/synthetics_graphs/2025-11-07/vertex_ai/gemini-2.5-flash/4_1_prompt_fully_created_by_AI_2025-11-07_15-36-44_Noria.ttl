# --- Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person) ---
noria:Agent_IT_Ops_Team a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:label "Équipe Opérations IT"@fr ;
    rdfs:comment "The primary team responsible for managing core IT infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "For critical issues, use the emergency hotline after creating a ticket."@en .

noria:Agent_Network_Admin a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:label "Alice Smith"@fr ;
    rdfs:comment "Network Administrator responsible for routing and switching infrastructure."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via email for non-urgent matters. For urgent issues, call the IT Operations Team hotline."@en .

noria:Agent_DB_Admin_Team a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:label "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Team responsible for database server management and performance."@en ;
    noria:agentWorkingHours "8:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> .

noria:Agent_Security_Team a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:label "Centre Opérations Sécurité"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/security-alert-system> .

noria:Agent_App_Dev_Team a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development Team X"@en ;
    rdfs:label "Équipe Développement Application X"@fr ;
    rdfs:comment "Team responsible for developing and maintaining the Customer Portal application."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/internal-chat> .

# --- Organizations (org:Organization) ---
noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en ;
    rdfs:comment "Leading manufacturer of networking hardware."@en .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware, Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

noria:Org_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en .

# --- Product Models (noria:ProductModel) ---
noria:ProductModel_Cisco_ASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "High-end router series for carrier-grade networks."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_Dell_PowerEdge_R750 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "Dell server model for enterprise applications."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_VMware_ESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for hosting virtual machines."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:ProductModel_Juniper_SRX300 a noria:ProductModel ;
    rdfs:label "Juniper SRX300 Series Firewall"@en ;
    rdfs:comment "Next-generation firewall for network security."@en ;
    noria:productManufacturedBy noria:Org_Juniper .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
noria:Site_Paris_DC1 a bot:Site ;
    rdfs:label "Paris Data Center 1"@en ;
    rdfs:comment "Primary data center for European operations."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_Server_Hall_A a noria:Room ;
    rdfs:label "Server Hall A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Main server hall within Paris Data Center 1."@en ;
    bot:hasSpace noria:Site_Paris_DC1 .

noria:Locus_Rack_A12_U24 a noria:Locus ;
    rdfs:label "Rack A12, Unit 24"@en ;
    rdfs:comment "Specific location within Server Hall A for a server."@en ;
    noria:locusLine "A12" ;
    noria:locusRow "24" ;
    bot:hasSpace noria:Room_Server_Hall_A .

noria:Site_London_Office a bot:Site ;
    rdfs:label "London Head Office"@en ;
    rdfs:comment "Main administrative office in London."@en ;
    noria:siteId "OFF-LDN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddressStreet "45 Park Lane" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressPostalCode "W1K 1PN" ;
    noria:sitePrincipalAddressCountry "UK" .

# --- Resources (noria:Resource) ---
noria:Resource_CoreRouter_R1 a noria:Resource ;
    rdfs:label "Core Router R1"@en ;
    rdfs:comment "Main backbone router in Paris Data Center 1."@en ;
    noria:resourceLogisticId "CR-PAR-01-R1" ;
    noria:resourceHostName "cr01.par.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco_ASR9K ;
    noria:resourceManagedBy noria:Agent_Network_Admin ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "JMX12345678" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
