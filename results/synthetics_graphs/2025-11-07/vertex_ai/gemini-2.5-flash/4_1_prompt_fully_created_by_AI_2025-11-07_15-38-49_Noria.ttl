noria:ChangeRequest_RouterOSUpgrade a noria:ChangeRequest ;
    rdfs:label "Core Router OS Upgrade"@en, "Mise à Jour OS Routeur Cœur"@fr ;
    rdfs:comment "Planned operating system upgrade for Core Router 01 to enhance security and performance."@en ;
