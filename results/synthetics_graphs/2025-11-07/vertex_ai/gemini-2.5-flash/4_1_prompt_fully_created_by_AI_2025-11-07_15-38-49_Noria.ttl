    noria:changeRequestPlannedStartTime "2024-04-28T20:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-28T20:30:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:FirewallFW01 ;
    noria:changeRequestOutageDuration "PT0H5M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty noria:AppSupportL2Team ;
