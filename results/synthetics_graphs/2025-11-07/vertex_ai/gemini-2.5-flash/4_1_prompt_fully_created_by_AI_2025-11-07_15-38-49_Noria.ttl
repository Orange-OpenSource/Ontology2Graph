# =============================================================================
# Network Interfaces
# =============================================================================

noria:CoreRouter01_GE001 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"@en ;
    rdfs:comment "Uplink interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 .

noria:WebServer01_ETH0 a noria:NetworkInterface ;
    rdfs:label "eth0 on Web Server 01"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:WebServer01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:DatabaseServer02_ETH0 a noria:NetworkInterface ;
    rdfs:label "eth0 on Database Server 02"@en ;
    rdfs:comment "Primary network interface for Database Server 02."@en ;
    noria:networkInterfaceOf noria:DatabaseServer02 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:FirewallFW01_EXT a noria:NetworkInterface ;
    rdfs:label "External Interface on Firewall FW-01"@en ;
    rdfs:comment "External facing interface of the firewall."@en ;
    noria:networkInterfaceOf noria:FirewallFW01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

