# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# NORIA Ontology Metadata (as provided in the schema)
# =============================================================================

<https://w3id.org/noria/ontology/>
	a voaf:Vocabulary, owl:Ontology ;
	dcterms:title "The NORIA Ontology"@en ;
    dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.

Alignment with third parties vocabularies is implemented on a per class or per property basis when relevant (e.g. with `rdfs:subClassOf`, `owl:equivalentClass`).
Directions for direct instanciation of these vocabularies are provided for cases where implementing a class/property alignment is redundant.
Alignment holds for the following vocabulary releases:
- [BBO](https://hal.archives-ouvertes.fr/hal-02365012/) 1.0.0
- [BOT](https://w3id.org/bot/) 0.3.2
- [DevOps-Infra](https://oeg-upm.github.io/devops-infra/) 1.0.0
- [FOLIO](https://github.com/IBCNServices/Folio-Ontology) 1.0.0
- [ORG](https://www.w3.org/TR/vocab-org/) 0.8
- [PEP](https://w3id.org/pep/) 1.1
- [SEAS](https://w3id.org/seas/) 1.1
- [SLOGERT](https://sepses.ifs.tuwien.ac.at/ns/log/index-en.html) 1.1.0
- [UCO](https://unifiedcyberontology.org/ontology/uco) Release-0.8.0
"""@en ;
    foaf:depiction <https://github.com/Orange-OpenSource/noria-ontology/raw/master/dataset/noria-0.2/noria-ontology-UC.png> ;
    bibo:status <http://purl.org/ontology/bibo/status/accepted> ;  # https://www.dublincore.org/specifications/bibo/bibo/bibo.rdf.xml#
	dcterms:creator "Lionel Tailhardat (https://orcid.org/0000-0001-5887-899X)" ;  # Lionel Tailhardat
	dcterms:creator "Yoan Chabot (https://orcid.org/0000-0001-5639-1504)" ;  # Yoan Chabot
	dcterms:creator "Raphaël Troncy (https://orcid.org/0000-0003-0457-1436)" ;  # Raphaël Troncy
    dcterms:publisher <https://www.orange.com/> ;
    dcterms:license <https://spdx.org/licenses/BSD-4-Clause> ;
    vann:preferredNamespacePrefix "noria" ;
    vann:preferredNamespaceUri "https://w3id.org/noria/ontology/" ;  # See https://dgarijo.github.io/Widoco/doc/bestPractices/index-en.html
    dcterms:issued "2022-05-10"^^xsd:date ;
	dcterms:modified "2024-03-15"^^xsd:date ;
	skos:changeNote """Changes in v0.3:

- Changed the ontology architecture from micro-architecture to single file.
- Removed owl:imports for NORIA foundations.

2024-03-15:

- Changed bibo:status
"""@en ;
	owl:versionInfo "v0.3" ;
	owl:versionIRI <ontology/noria-0.3> ;
	owl:priorVersion <ontology/noria-0.2> ;
    rdfs:seeAlso <https://w3id.org/noria/doc/> ;
.

# =============================================================================
# KOS Concepts (defined inline for brevity and adherence to example pattern)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/business> a skos:Concept ; rdfs:label "Business Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; rdfs:label "Monitoring Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .
<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ; rdfs:label "Network Outage"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ; rdfs:label "Network Team Responsibility"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .

<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade Cause"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .
<kos/ChangeRequest/status/Scheduled> a skos:Concept ; rdfs:label "Scheduled Status"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .

<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Firewall> a skos:Concept ; rdfs:label "Firewall"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/LifecycleState/InUse> a skos:Concept ; rdfs:label "In Use"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .
<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; rdfs:label "Administrative Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Administrative Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .

# =============================================================================
# Agents and Organizations
# =============================================================================

noria:ITOperationsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en, "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for the overall IT infrastructure and application operations."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

noria:NetworkAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en, "Équipe Administration Réseau"@fr ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Open a change request for any planned network modifications."@en .

noria:AppSupportL2Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support L2 Team"@en, "Équipe Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support for business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate to L3 for unresolvable issues after initial diagnosis."@en .

noria:CustomerService a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Service"@en, "Service Client"@fr ;
    rdfs:comment "First point of contact for customer inquiries and incident reporting."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual network administrator."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string .

noria:JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Lead application developer."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+33198765432" ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string .

# =============================================================================
# Locations
# =============================================================================

noria:ParisDataCenter a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    rdfs:comment "Main data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "A specific server room within the Paris Data Center."@en ;
    bot:hasSpace noria:ParisDataCenter .

noria:Rack12U01 a noria:Locus ;
    rdfs:label "Rack 12U-01"@en, "Baie 12U-01"@fr ;
    rdfs:comment "A specific rack location within Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "12" ;
    bot:hasSpace noria:ServerRoomA .

noria:NetworkCloset1 a noria:Room ;
    rdfs:label "Network Closet 1"@en, "Local Réseau 1"@fr ;
    rdfs:comment "Network equipment closet in the Headquarters Building."@en ;
    bot:hasSpace noria:HeadquartersBuilding .

noria:HeadquartersBuilding a bot:Site ;
    rdfs:label "Headquarters Building"@en, "Bâtiment du Siège Social"@fr ;
    rdfs:comment "Corporate headquarters building."@en ;
    noria:siteId "HQ-01" ;
    noria:siteType "building" ;
    noria:sitePrincipalAddress "456 Avenue des Champs-Élysées" ;
    noria:sitePrincipalAddressPostalCode "75008" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

