# Network Links
# =============================================================================

noria:FiberLinkDC_HQ a noria:NetworkLink ;
    rdfs:label "Fiber Link Data Center - HQ"@en, "Liaison Fibre Centre de Données - Siège"@fr ;
    rdfs:comment "High-speed fiber optic link connecting the data center to headquarters."@en ;
    noria:networkLinkId "FL-DC-HQ-01" ;
