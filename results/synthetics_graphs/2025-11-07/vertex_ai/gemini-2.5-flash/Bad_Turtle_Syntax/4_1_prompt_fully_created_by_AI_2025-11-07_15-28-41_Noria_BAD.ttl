    rdfs:label "Network Diagram DC1"@en ;
    rdfs:comment "Diagram of the network topology in Paris Data Center 1."@en ;
    dcterms:created "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "NET-DIAG-DC1-V2.pdf" ;
    dcterms:isPartOf :ChangeRequest_Router_Firmware_Upgrade .
