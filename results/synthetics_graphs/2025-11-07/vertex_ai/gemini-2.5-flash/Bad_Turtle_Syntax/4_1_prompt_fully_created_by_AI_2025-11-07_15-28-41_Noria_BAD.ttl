# --- Operation Plans (noria:OperationPlan) ---
:OperationPlan_Router_Firmware_Procedure a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading Cisco ASR router firmware."@en ;
    skos:example "Steps include backup configuration, upload image, reload, verify."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Router_Backup_Complete ;
    noria:operationPlanPostCondition :ActionPostCondition_Router_Operational .

:OperationPlan_Web_Server_PowerCycle a noria:OperationPlan ;
    rdfs:label "Web Server Power Cycle Procedure"@en ;
    rdfs:comment "Procedure for physically power cycling a web server in the data center."@en ;
    skos:example "Steps include notifying stakeholders, remote power off, physical power on, verify service."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Stakeholder_Notified ;
    noria:operationPlanPostCondition :ActionPostCondition_WebServer_Service_Restored .

:OperationPlan_APIGW_Troubleshooting a noria:OperationPlan ;
    rdfs:label "API Gateway Troubleshooting Guide"@en ;
    rdfs:comment "Standard procedure for diagnosing and resolving 5xx errors on the API Gateway."@en ;
    skos:example "Steps include checking backend service health, reviewing logs, restarting gateway."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_APIGW_Logs_Collected ;
    noria:operationPlanPostCondition :ActionPostCondition_APIGW_Service_Restored .

:OperationPlan_DB_Troubleshooting a noria:OperationPlan ;
    rdfs:label "Database Performance Troubleshooting"@en ;
    rdfs:comment "Procedure for diagnosing and resolving database performance issues."@en ;
    skos:example "Steps include checking active queries, reviewing execution plans, optimizing indexes."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_DB_Metrics_Collected ;
    noria:operationPlanPostCondition :ActionPostCondition_DB_Performance_Restored .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
:ActionPreCondition_Router_Backup_Complete a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Complete"@en ;
    rdfs:comment "Ensures a recent backup of the router configuration is available before upgrade."@en .

:ActionPostCondition_Router_Operational a noria:ActionPostCondition ;
    rdfs:label "Router Operational and Services Restored"@en ;
    rdfs:comment "Verifies that the router is fully operational and all connected services are functioning after upgrade."@en .

:ActionPreCondition_Stakeholder_Notified a noria:ActionPreCondition ;
    rdfs:label "Stakeholders Notified of Downtime"@en ;
    rdfs:comment "Confirmation that all affected parties have been informed about the planned power cycle and potential service interruption."@en .

:ActionPostCondition_WebServer_Service_Restored a noria:ActionPostCondition ;
    rdfs:label "Web Server Service Restored"@en ;
    rdfs:comment "Verification that the web server is accessible and the customer portal is functioning correctly."@en .

:ActionPreCondition_APIGW_Logs_Collected a noria:ActionPreCondition ;
    rdfs:label "API Gateway Logs Collected"@en ;
    rdfs:comment "Ensures relevant logs from the API Gateway and backend services are collected for analysis."@en .

:ActionPostCondition_APIGW_Service_Restored a noria:ActionPostCondition ;
    rdfs:label "API Gateway Service Restored"@en ;
    rdfs:comment "Verification that API calls are successfully processed without 5xx errors."@en .

:ActionPreCondition_DB_Metrics_Collected a noria:ActionPreCondition ;
    rdfs:label "Database Performance Metrics Collected"@en ;
    rdfs:comment "Ensures relevant database performance metrics are collected for analysis."@en .

:ActionPostCondition_DB_Performance_Restored a noria:ActionPostCondition ;
    rdfs:label "Database Performance Restored"@en ;
    rdfs:comment "Verification that database CPU usage is within normal limits and query latency is acceptable."@en .

# --- Anomaly Patterns (noria:AnomalyPattern) ---
:AnomalyPattern_High_CPU_DB_VM a noria:AnomalyPattern ;
    rdfs:label "High CPU on Database VM Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating potential database performance issues or attack: sustained high CPU on DB VM, coupled with increased query latency."@en ;
    folio:hasCause "Database query optimization needed or DoS attack."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
