# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (implicitly defined by usage)
# =============================================================================

# Application Types
noria:kos/application/type/infrastructure a skos:Concept ; rdfs:label "Infrastructure Application"@en .
noria:kos/application/type/business-critical a skos:Concept ; rdfs:label "Business Critical Application"@en .

# Application Business Importance
noria:kos/application/business-importance/high a skos:Concept ; rdfs:label "High Business Importance"@en .
noria:kos/application/business-importance/medium a skos:Concept ; rdfs:label "Medium Business Importance"@en .

# Application Status
noria:kos/application/status/InProduction a skos:Concept ; rdfs:label "In Production"@en .
noria:kos/application/status/Development a skos:Concept ; rdfs:label "Development"@en .

# Trouble Ticket Severity
noria:kos/TroubleTicket/severity/Critical a skos:Concept ; rdfs:label "Critical Severity"@en .
noria:kos/TroubleTicket/severity/Major a skos:Concept ; rdfs:label "Major Severity"@en .

# Trouble Ticket Priority
noria:kos/TroubleTicket/priority/P1 a skos:Concept ; rdfs:label "Priority 1"@en .
noria:kos/TroubleTicket/priority/P2 a skos:Concept ; rdfs:label "Priority 2"@en .

# Trouble Ticket Origin
noria:kos/TroubleTicket/origin/Supervision a skos:Concept ; rdfs:label "Supervision System Origin"@en .
noria:kos/TroubleTicket/origin/Customer a skos:Concept ; rdfs:label "Customer Origin"@en .

# Trouble Ticket Urgency
noria:kos/TroubleTicket/urgency/ImmediateIntervention a skos:Concept ; rdfs:label "Immediate Intervention"@en .
noria:kos/TroubleTicket/urgency/DeferredIntervention a skos:Concept ; rdfs:label "Deferred Intervention"@en .

# Trouble Ticket Category
noria:kos/TroubleTicket/trouble-category/NetworkOutage a skos:Concept ; rdfs:label "Network Outage"@en .
noria:kos/TroubleTicket/trouble-category/ServerFailure a skos:Concept ; rdfs:label "Server Failure"@en .

# Trouble Ticket Problem Responsibility
noria:kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks a skos:Concept ; rdfs:label "Managed Backbone Networks Responsibility"@en .
noria:kos/TroubleTicket/problemResponsibility/ApplicationTeam a skos:Concept ; rdfs:label "Application Team Responsibility"@en .

# Trouble Ticket Status
noria:kos/TroubleTicket/status/InProgress a skos:Concept ; rdfs:label "In Progress"@en .
noria:kos/TroubleTicket/status/Resolved a skos:Concept ; rdfs:label "Resolved"@en .

# Trouble Ticket Comment Type
noria:kos/TroubleTicket/commentType/System a skos:Concept ; rdfs:label "System Comment"@en .
noria:kos/TroubleTicket/commentType/Internal a skos:Concept ; rdfs:label "Internal Comment"@en .

# Trouble Ticket Operation Type
noria:kos/TroubleTicket/operationType/Diagnosis a skos:Concept ; rdfs:label "Diagnosis Operation"@en .
noria:kos/TroubleTicket/operationType/TestsAndMeasurements a skos:Concept ; rdfs:label "Tests and Measurements Operation"@en .

# Change Request Category
noria:kos/ChangeRequest/category/InternalIntervention a skos:Concept ; rdfs:label "Internal Intervention"@en .

# Change Request Type
noria:kos/ChangeRequest/type/Standard a skos:Concept ; rdfs:label "Standard Change"@en .

# Change Request Cause
noria:kos/ChangeRequest/cause/SoftwareUpgrade a skos:Concept ; rdfs:label "Software Upgrade Cause"@en .

# Change Request Status
noria:kos/ChangeRequest/status/Approved a skos:Concept ; rdfs:label "Approved Status"@en .
noria:kos/ChangeRequest/status/Implemented a skos:Concept ; rdfs:label "Implemented Status"@en .

# Resource Operational State
noria:kos/Resource/OperationalState/Up a skos:Concept ; rdfs:label "Operational State Up"@en .
noria:kos/Resource/OperationalState/Down a skos:Concept ; rdfs:label "Operational State Down"@en .

# Resource Administrative State
noria:kos/Resource/AdministrativeState/Up a skos:Concept ; rdfs:label "Administrative State Up"@en .
noria:kos/Resource/AdministrativeState/Down a skos:Concept ; rdfs:label "Administrative State Down"@en .

# Resource Lifecycle State
noria:kos/Resource/LifecycleState/InProduction a skos:Concept ; rdfs:label "In Production Lifecycle State"@en .
noria:kos/Resource/LifecycleState/Staging a skos:Concept ; rdfs:label "Staging Lifecycle State"@en .

# Resource Type
noria:kos/Resource/type/Server a skos:Concept ; rdfs:label "Server Resource Type"@en .
noria:kos/Resource/type/Router a skos:Concept ; rdfs:label "Router Resource Type"@en .
noria:kos/Resource/type/Switch a skos:Concept ; rdfs:label "Switch Resource Type"@en .

# Notification Event Type
noria:kos/Notification/EventType/stateChange a skos:Concept ; rdfs:label "State Change Event Type"@en .
noria:kos/Notification/EventType/alarm a skos:Concept ; rdfs:label "Alarm Event Type"@en .

# Notification Severity
noria:Notification/Severity/PerceivedSeverity/Critical a skos:Concept ; rdfs:label "Critical Perceived Severity"@en .
noria:Notification/Severity/PerceivedSeverity/Major a skos:Concept ; rdfs:label "Major Perceived Severity"@en .

# Agent Contact Method
noria:kos/org/agent-contact-method/Email a skos:Concept ; rdfs:label "Email Contact Method"@en .
noria:kos/org/agent-contact-method/Phone a skos:Concept ; rdfs:label "Phone Contact Method"@en .

# Service Type
noria:kos/service/type/CustomerFacingService a skos:Concept ; rdfs:label "Customer Facing Service"@en .
noria:kos/service/type/InternalService a skos:Concept ; rdfs:label "Internal Service"@en .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

<agent/TeamA> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Team"@en ;
    rdfs:label "Équipe du Centre d'Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for monitoring and managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone ;
    noria:agentInstructions "For critical issues, call the hotline immediately. For non-critical, use ticketing system."@en ;
    foaf:mbox <mailto:noc@example.com> ;
    foaf:phone <tel:+1-800-555-0100> .

<agent/TeamB> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe de Support Applicatif"@fr ;
    rdfs:comment "Team responsible for supporting business-critical applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email ;
    noria:agentInstructions "Submit a ticket via the portal for all application-related issues."@en ;
    foaf:mbox <mailto:appsupport@example.com> .

<agent/JohnDoe> a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead engineer for network infrastructure."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone <tel:+1-800-555-0101> ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone .

<agent/JaneSmith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Product owner for the Customer Portal application."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

<productmodel/ServerModelX> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <org/Dell> .

<productmodel/RouterModelY> a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9800"@en ;
    rdfs:comment "Enterprise-grade network router model."@en ;
    noria:productManufacturedBy <org/Cisco> .

<productmodel/SwitchModelZ> a noria:ProductModel ;
    rdfs:label "Juniper EX4650"@en ;
    rdfs:comment "High-density data center switch model."@en ;
    noria:productManufacturedBy <org/Juniper> .

<org/Dell> a org:Organization ;
    rdfs:label "Dell Technologies"@en .

<org/Cisco> a org:Organization ;
    rdfs:label "Cisco Systems"@en .

<org/Juniper> a org:Organization ;
    rdfs:label "Juniper Networks"@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

<location/SiteDC01> a bot:Site ;
    rdfs:label "Main Data Center 01"@en ;
    rdfs:comment "Primary data center facility for corporate services."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

<location/RoomA01> a noria:Room ;
    rdfs:label "Server Room A01"@en ;
    rdfs:comment "Contains critical application servers."@en ;
    bot:hasSpace <location/SiteDC01> .

<location/RoomB02> a noria:Room ;
    rdfs:label "Network Room B02"@en ;
    rdfs:comment "Houses core network devices."@en ;
    bot:hasSpace <location/SiteDC01> .

<location/LocusR1A01> a noria:Locus ;
    rdfs:label "Rack 1, Row A01"@en ;
    rdfs:comment "Specific location for Server01 in Room A01."@en ;
    noria:locusLine "Rack1"@en ;
    noria:locusRow "A01"@en ;
    bot:hasSpace <location/RoomA01> .

<location/LocusR2B02> a noria:Locus ;
    rdfs:label "Rack 2, Row B02"@en ;
    rdfs:comment "Specific location for Router01 in Room B02."@en ;
    noria:locusLine "Rack2"@en ;
    noria:locusRow "B02"@en ;
    bot:hasSpace <location/RoomB02> .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

<resource/Server01> a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Primary server for the Customer Portal application."@en ;
    noria:resourceHostName "appserver01.corp.example.com" ;
    noria:resourceLogisticId "AS01-DC01-12345" ;
    noria:resourceProductModel <productmodel/ServerModelX> ;
    noria:resourceManagedBy <agent/TeamB> ;
    noria:resourceType noria:kos/Resource/type/Server ;
    noria:resourceSerialNumber "SN-AS01-XYZ" ;
    noria:resourceUsageState noria:kos/Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <application/CustomerPortal> ;
    noria:locatedAtLocus <location/LocusR1A01> ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

<resource/Router01> a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for data center network connectivity."@en ;
    noria:resourceHostName "router01.corp.example.com" ;
    noria:resourceLogisticId "CR01-DC01-67890" ;
    noria:resourceProductModel <productmodel/RouterModelY> ;
    noria:resourceManagedBy <agent/TeamA> ;
    noria:resourceType noria:kos/Resource/type/Router ;
    noria:resourceSerialNumber "SN-CR01-ABC" ;
    noria:resourceUsageState noria:kos/Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2022-05-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <application/CoreNetwork> ;
    noria:locatedAtLocus <location/LocusR2B02> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

<resource/Switch01> a noria:Resource ;
    rdfs:label "Access Switch 01"@en ;
    rdfs:comment "Provides network access for servers in Room A01."@en ;
    noria:resourceHostName "switch01.corp.example.com" ;
    noria:resourceLogisticId "AS01-DC01-SW01" ;
    noria:resourceProductModel <productmodel/SwitchModelZ> ;
    noria:resourceManagedBy <agent/TeamA> ;
    noria:resourceType noria:kos/Resource/type/Switch ;
    noria:resourceSerialNumber "SN-SW01-DEF" ;
    noria:resourceUsageState noria:kos/Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2023-03-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <application/CoreNetwork> ;
    noria:locatedAtLocus <location/LocusR1A01> ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.2> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

<networkinterface/Server01-Eth0> a noria:NetworkInterface ;
    rdfs:label "Server01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Server01."@en ;
    noria:networkInterfaceOf <resource/Server01> ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceDescription "Gigabit Ethernet port connected to Switch01."@en ;
    noria:networkInterfaceAdministrativeStatus noria:kos/Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus noria:kos/Resource/OperationalState/Up ;
    noria:networkInterfaceConnects <networklink/Link-Server01-Switch01> .

<networkinterface/Router01-Gi0-0-0> a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface for Router01."@en ;
    noria:networkInterfaceOf <resource/Router01> ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceDescription "Fiber uplink to external network."@en ;
    noria:networkInterfaceAdministrativeStatus noria:kos/Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus noria:kos/Resource/OperationalState/Up ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceConnects <networklink/Link-Router01-External> .

<networkinterface/Switch01-Gi1-0-1> a noria:NetworkInterface ;
    rdfs:label "Switch01 GigabitEthernet 1/0/1"@en ;
    rdfs:comment "Port connecting to Server01."@en ;
    noria:networkInterfaceOf <resource/Switch01> ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceDescription "Access port for appserver01."@en ;
    noria:networkInterfaceAdministrativeStatus noria:kos/Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus noria:kos/Resource/OperationalState/Up ;
    noria:networkInterfaceConnects <networklink/Link-Server01-Switch01> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

<networklink/Link-Server01-Switch01> a noria:NetworkLink ;
    rdfs:label "Link Server01 to Switch01"@en ;
    rdfs:comment "Direct Ethernet connection between Server01 and Switch01."@en ;
    noria:networkLinkId "NL-AS01-SW01" ;
    noria:networkLinkType "Ethernet"@en ;
    noria:networkLinkInstallationDate "2023-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/TeamA> ;
    noria:networkLinkTerminationResourceOrigin <resource/Server01> ;
    noria:networkLinkTerminationResourceDestination <resource/Switch01> .

<networklink/Link-Router01-External> a noria:NetworkLink ;
    rdfs:label "Link Router01 to External Network"@en ;
    rdfs:comment "Fiber optic link connecting Router01 to the internet backbone."@en ;
    noria:networkLinkId "NL-CR01-EXT" ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2022-05-20T15:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/TeamA> ;
    noria:networkLinkTerminationResourceOrigin <resource/Router01> .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

<application/CustomerPortal> a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CP-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CustPortal" ;
    noria:applicationType noria:kos/application/type/business-critical ;
    noria:applicationBusinessImportance noria:kos/application/business-importance/high ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Self-Service Management"@en ;
    noria:elementManagedBy <agent/TeamB> .

<application/CoreNetwork> a noria:Application ;
    rdfs:label "Core Network Infrastructure"@en ;
    rdfs:comment "Underlying network infrastructure supporting all corporate applications."@en ;
    noria:applicationModelIdentifier "CN-V1" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "CoreNet" ;
    noria:applicationType noria:kos/application/type/infrastructure ;
    noria:applicationBusinessImportance noria:kos/application/business-importance/high ;
    noria:applicationFunctionalDomain "Resource Development, Management and Operations"@en ;
    noria:applicationFunctionalSubDomain "Network Management"@en ;
    noria:elementManagedBy <agent/TeamA> .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

<applicationmodule/CustomerPortal-Frontend> a noria:ApplicationModule ;
    rdfs:label "Customer Portal Frontend Module"@en ;
    rdfs:comment "User interface component of the Customer Portal."@en ;
    noria:applicationModuleOf <application/CustomerPortal> ;
    noria:applicationModuleIdentifier "CP-FE-01" ;
    noria:applicationModuleName "CustPortal_CP-FE-01" ;
    noria:applicationModuleStatus noria:kos/application/status/InProduction ;
    noria:applicationModuleAdministrationTeam <agent/TeamB> ;
    noria:applicationModuleAdministrationLeader <agent/JaneSmith> ;
    noria:applicationModuleSupportTeam <agent/TeamB> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

<applicationmodule/CustomerPortal-Backend> a noria:ApplicationModule ;
    rdfs:label "Customer Portal Backend Module"@en ;
    rdfs:comment "API and business logic component of the Customer Portal."@en ;
    noria:applicationModuleOf <application/CustomerPortal> ;
    noria:applicationModuleIdentifier "CP-BE-01" ;
    noria:applicationModuleName "CustPortal_CP-BE-01" ;
    noria:applicationModuleStatus noria:kos/application/status/InProduction ;
    noria:applicationModuleAdministrationTeam <agent/TeamB> ;
    noria:applicationModuleSupportTeam <agent/TeamB> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

# =============================================================================
# Services (noria:Service)
# =============================================================================

<service/CustomerFacingWebAccess> a noria:Service ;
    rdfs:label "Customer Facing Web Access Service"@en ;
    rdfs:comment "Provides external customers with access to web applications, including the Customer Portal."@en ;
    noria:serviceType noria:kos/service/type/CustomerFacingService ;
    noria:elementManagedBy <agent/TeamB> ;
    seas:subSystemOf <application/CustomerPortal> ; # A service can be composed of applications/modules
    seas:subSystemOf <applicationmodule/CustomerPortal-Frontend> .

<service/InternalNetworkConnectivity> a noria:Service ;
    rdfs:label "Internal Network Connectivity Service"@en ;
    rdfs:comment "Ensures reliable network connectivity for internal systems and users."@en ;
    noria:serviceType noria:kos/service/type/InternalService ;
    noria:elementManagedBy <agent/TeamA> ;
    seas:subSystemOf <application/CoreNetwork> .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

<eventrecord/Server01-Down-20240423> a noria:EventRecord ;
    rdfs:label "Server01 Down Alert"@en ;
    rdfs:comment "Automated alert indicating that Application Server 01 is unreachable."@en ;
    noria:loggingTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Server01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "CRITICAL: Host appserver01.corp.example.com is DOWN."@en ;
    dcterms:type noria:kos/Notification/EventType/alarm ;
    noria:alarmSeverity noria:Notification/Severity/PerceivedSeverity/Critical .

<eventrecord/Router01-Interface-StateChange-20240423> a noria:EventRecord ;
    rdfs:label "Router01 Interface State Change"@en ;
    rdfs:comment "Log entry indicating a network interface state change on Router01."@en ;
    noria:loggingTime "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Router01> ;
    noria:logOriginatingManagementSystem <application/SyslogServer> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    dcterms:type noria:kos/Notification/EventType/stateChange ;
    noria:alarmSeverity noria:Notification/Severity/PerceivedSeverity/Major .

<application/MonitoringSystem> a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
