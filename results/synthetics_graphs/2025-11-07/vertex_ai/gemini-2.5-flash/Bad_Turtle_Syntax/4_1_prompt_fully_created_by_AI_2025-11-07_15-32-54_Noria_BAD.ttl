    noria:applicationShortIdentifier "CMS" ;
    noria:applicationType noria:kos/application/type/infrastructure ;
    noria:elementManagedBy <agent/TeamA> .

<application/SyslogServer> a noria:Application ;
    rdfs:label "Central Syslog Server"@en ;
    rdfs:comment "Collects syslog messages from network devices and servers."@en ;
    noria:applicationShortIdentifier "Syslog" ;
    noria:applicationType noria:kos/application/type/infrastructure ;
    noria:elementManagedBy <agent/TeamA> .

