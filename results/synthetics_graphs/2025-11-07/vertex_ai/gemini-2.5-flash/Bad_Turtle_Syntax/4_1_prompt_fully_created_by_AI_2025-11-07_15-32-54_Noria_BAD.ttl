    noria:changeRequestType noria:kos/ChangeRequest/type/Standard ;
    noria:changeRequestChangeCause noria:kos/ChangeRequest/cause/SoftwareUpgrade ;
    noria:changeRequestStatusCurrent noria:kos/ChangeRequest/status/Approved ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestImpact <resource/Router01>, <application/CoreNetwork> ;
    noria:changeRequestInitiatorParty <agent/JohnDoe> ;
    noria:changeRequestPilotParty <agent/JohnDoe> ;
    noria:changeRequestActorParty <agent/TeamA> ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef <http://changemanagement.example.com/CR-20240501-001> .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

<operationplan/RouterUpgradeProcedure> a noria:OperationPlan ;
    rdfs:label "Standard Router Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading router software, including pre-checks, upgrade, and post-checks."@en ;
    skos:example "This procedure ensures minimal downtime and verifies system health after upgrade."@en ;
    noria:operationPlanPreCondition <actionprecondition/RouterReachabilityCheck> ;
    noria:operationPlanPostCondition <actionpostcondition/RouterHealthVerification> .

<actionprecondition/RouterReachabilityCheck> a noria:ActionPreCondition ;
    rdfs:label "Router Reachability Check"@en ;
    rdfs:comment "Verify router is reachable and has active sessions before starting upgrade."@en .

<actionpostcondition/RouterHealthVerification> a noria:ActionPostCondition ;
    rdfs:label "Router Health Verification"@en ;
    rdfs:comment "Confirm all interfaces are up, routing protocols converged, and CPU/memory within normal limits after upgrade."@en .

# =============================================================================
# Interconnections and Density
# =============================================================================

# Link agents to resources they manage (inverse of noria:resourceManagedBy)
<agent/TeamA> noria:agentManagesResource <resource/Router01>, <resource/Switch01>, <networklink/Link-Server01-Switch01>, <networklink/Link-Router01-External> .
<agent/TeamB> noria:agentManagesResource <resource/Server01> .

# Link applications to resources (already done via noria:resourceForApplication)
# Link application modules to applications (already done via noria:applicationModuleOf)

# Link TroubleTicket to EventRecord (already done via noria:troubleTicketTrigger)
# Link TroubleTicket to TroubleTicketNote (already done via dcterms:isPartOf inverse)

# Link ChangeRequest to OperationPlan (via actionCorrelatedOperationPlan if an action was executed)
# For now, let's assume the CR implies the OP, but no specific action is recorded yet.

# Example of a resource's virtual server status (if applicable)
<resource/Server01> noria:virtualServerStatus noria:kos/Resource/OperationalState/Up .

# Example of a TroubleTicket being resolved and its cause identified
<troubleticket/TT-20240423-001>
    noria:problemCategory noria:kos/TroubleTicket/trouble-category/ServerFailure ;
    noria:problemResponsibility noria:kos/TroubleTicket/problemResponsibility/ApplicationTeam ;
    noria:troubleTicketCause "Power supply failure on Server01."@en ;
    noria:troubleTicketStatusCurrent noria:kos/TroubleTicket/status/Resolved ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime .

# Example of a TroubleTicket's status history (via EventRecord)
<eventrecord/TT-20240423-001-StatusChange-Resolved> a noria:EventRecord ;
    rdfs:label "TT-20240423-001 Status Changed to Resolved"@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <application/TicketingSystem> ;
    noria:logText "Trouble Ticket TT-20240423-001 status updated to Resolved."@en ;
    dcterms:type noria:kos/Notification/EventType/stateChange ;
    dcterms:references <troubleticket/TT-20240423-001> .

<application/TicketingSystem> a noria:Application ;
    rdfs:label "ITSM Ticketing System"@en ;
    rdfs:comment "System for managing incidents and service requests."@en ;
    noria:applicationShortIdentifier "ITSM" ;
    noria:applicationType noria:kos/application/type/business-critical ;
    noria:elementManagedBy <agent/TeamB> .

<troubleticket/TT-20240423-001> noria:documentStatusHistory <eventrecord/TT-20240423-001-StatusChange-Resolved> .

# Example of a Change Request being implemented
<changerequest/CR-20240501-001>
    noria:changeRequestActualStartTime "2024-05-01T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-05-01T03:45:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent noria:kos/ChangeRequest/status/Implemented .

# Example of an EventRecord being mitigated by a ProcedureExecutionContainer (e.g., a ChangeRequest)
<eventrecord/Router01-Interface-StateChange-20240423>
    noria:alarmMitigatedBy <changerequest/CR-20240501-001> . # This is a bit of a stretch, but shows connection. A CR might resolve an underlying issue that caused an alarm.

# Example of a Corporate User Identifier
<cuid/JohnDoe> a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount <agent/JohnDoe> .

<cuid/JaneSmith> a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount <agent/JaneSmith> .

# Further linking:
# - A resource can be part of a cluster, controlled by another resource.
<resource/ClusterController01> a noria:Resource ;
    rdfs:label "Virtualization Cluster Controller 01"@en ;
    rdfs:comment "Manages the virtualization cluster where Server01 resides."@en ;
    noria:resourceHostName "vcc01.corp.example.com" ;
    noria:resourceType noria:kos/Resource/type/Server ;
    noria:resourceManagedBy <agent/TeamA> .

<resource/Server01> noria:clusterController <resource/ClusterController01> .

# - A service can be composed of multiple application modules
<service/CustomerFacingWebAccess>
    seas:subSystemOf <applicationmodule/CustomerPortal-Backend> .

# - An application module can have a support group (L1) and hotline group
<applicationmodule/CustomerPortal-Frontend>
    noria:applicationModuleSupportGroup <agent/TeamA> ; # NOC team might be L1 for some app issues
    noria:applicationModuleHotlineGroup <agent/TeamB> .

# - A trouble ticket can have an external ID
<troubleticket/TT-20240423-001>
    noria:documentExternalId "CUST-INC-98765" .

# - A change request can have a specification
<changerequest/CR-20240501-001>
    noria:changeRequestSpecification <https://w3id.org/noria/kos/ChangeRequest/specification/RouterOSUpgrade> .

<https://w3id.org/noria/kos/ChangeRequest/specification/RouterOSUpgrade> a skos:Concept ;
    rdfs:label "Router OS Upgrade Specification"@en ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems."@en .

