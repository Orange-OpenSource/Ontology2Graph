# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# NORIA Ontology Metadata (as provided in the schema)
# =============================================================================

<https://w3id.org/noria/ontology/>
	a voaf:Vocabulary, owl:Ontology ;
	dcterms:title "The NORIA Ontology"@en ;
    dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.

Alignment with third parties vocabularies is implemented on a per class or per property basis when relevant (e.g. with `rdfs:subClassOf`, `owl:equivalentClass`).
Directions for direct instanciation of these vocabularies are provided for cases where implementing a class/property alignment is redundant.
Alignment holds for the following vocabulary releases:
- [BBO](https://hal.archives-ouvertes.fr/hal-02365012/) 1.0.0
- [BOT](https://w3id.org/bot/) 0.3.2
- [DevOps-Infra](https://oeg-upm.github.io/devops-infra/) 1.0.0
- [FOLIO](https://github.com/IBCNServices/Folio-Ontology) 1.0.0
- [ORG](https://www.w3.org/TR/vocab-org/) 0.8
- [PEP](https://w3id.org/pep/) 1.1
- [SEAS](https://w3id.org/seas/) 1.1
- [SLOGERT](https://sepses.ifs.tuwien.ac.at/ns/log/index-en.html) 1.1.0
- [UCO](https://unifiedcyberontology.org/ontology/uco) Release-0.8.0
"""@en ;
    foaf:depiction <https://github.com/Orange-OpenSource/noria-ontology/raw/master/dataset/noria-0.2/noria-ontology-UC.png> ;
    bibo:status <http://purl.org/ontology/bibo/status/accepted> ;  # https://www.dublincore.org/specifications/bibo/bibo/bibo.rdf.xml#
	dcterms:creator "Lionel Tailhardat (https://orcid.org/0000-0001-5887-899X)" ;  # Lionel Tailhardat
	dcterms:creator "Yoan Chabot (https://orcid.org/0000-0001-5639-1504)" ;  # Yoan Chabot
	dcterms:creator "Raphaël Troncy (https://orcid.org/0000-0003-0457-1436)" ;  # Raphaël Troncy
    dcterms:publisher <https://www.orange.com/> ;
    dcterms:license <https://spdx.org/licenses/BSD-4-Clause> ;
    vann:preferredNamespacePrefix "noria" ;
    vann:preferredNamespaceUri "https://w3id.org/noria/ontology/" ;  # See https://dgarijo.github.io/Widoco/doc/bestPractices/index-en.html
    dcterms:issued "2022-05-10"^^xsd:date ;
	dcterms:modified "2024-03-15"^^xsd:date ;
	skos:changeNote """Changes in v0.3:

- Changed the ontology architecture from micro-architecture to single file.
- Removed owl:imports for NORIA foundations.

2024-03-15:

- Changed bibo:status
"""@en ;
	owl:versionInfo "v0.3" ;
	owl:versionIRI <ontology/noria-0.3> ;
	owl:priorVersion <ontology/noria-0.2> ;
    rdfs:seeAlso <https://w3id.org/noria/doc/> ;
.

# =============================================================================
# KOS (Knowledge Organization System) Concepts
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .
<kos/application/type/infrastructure> a skos:Concept ;
    skos:prefLabel "Infrastructure"@en, "Infrastructure"@fr ;
    skos:inScheme <kos/application/type> .
<kos/application/type/business-critical> a skos:Concept ;
    skos:prefLabel "Business Critical"@en, "Critique Métier"@fr ;
    skos:inScheme <kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ;
    skos:prefLabel "Monitoring System"@en, "Système de Supervision"@fr ;
    skos:inScheme <kos/application/type> .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .
<kos/application/business-importance/high> a skos:Concept ;
    skos:prefLabel "High"@en, "Élevée"@fr ;
    skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ;
    skos:prefLabel "Medium"@en, "Moyenne"@fr ;
    skos:inScheme <kos/application/business-importance> .

# Application Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en, "En Production"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ;
    skos:prefLabel "In Maintenance"@en, "En Maintenance"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

# Service Types
<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .
<kos/service/type/customer-facing> a skos:Concept ;
    skos:prefLabel "Customer Facing Service"@en, "Service Client"@fr ;
    skos:inScheme <kos/service/type> .
<kos/service/type/resource-facing> a skos:Concept ;
    skos:prefLabel "Resource Facing Service"@en, "Service Interne"@fr ;
    skos:inScheme <kos/service/type> .

# Trouble Ticket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .
<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en, "Critique"@fr ;
    skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:prefLabel "Major"@en, "Majeure"@fr ;
    skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:prefLabel "Minor"@en, "Mineure"@fr ;
    skos:inScheme <kos/TroubleTicket/severity> .

# Trouble Ticket Priority
<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A scheme for classifying the priority of trouble tickets."@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:prefLabel "Priority 1"@en, "Priorité 1"@fr ;
    skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:prefLabel "Priority 2"@en, "Priorité 2"@fr ;
    skos:inScheme <kos/TroubleTicket/priority> .

# Trouble Ticket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of trouble tickets."@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:prefLabel "In Progress"@en, "En Cours"@fr ;
    skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:prefLabel "Resolved"@en, "Résolu"@fr ;
    skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ;
    skos:prefLabel "Closed"@en, "Fermé"@fr ;
    skos:inScheme <kos/TroubleTicket/status> .

# Trouble Ticket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:prefLabel "Customer"@en, "Client"@fr ;
    skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:prefLabel "Supervision"@en, "Supervision"@fr ;
    skos:inScheme <kos/TroubleTicket/origin> .

# Trouble Ticket Trouble Category
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the technical impact or nature of the incident."@en .
<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ;
    skos:prefLabel "Network Outage"@en, "Panne Réseau"@fr ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/trouble-category/ServiceDegradation> a skos:Concept ;
    skos:prefLabel "Service Degradation"@en, "Dégradation de Service"@fr ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying the final area of responsibility for an incident."@en .
<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ;
    skos:prefLabel "Internal IT"@en, "IT Interne"@fr ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/ExternalProvider> a skos:Concept ;
    skos:prefLabel "External Provider"@en, "Fournisseur Externe"@fr ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the provenance or disclosure rules of a trouble ticket note comment."@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:prefLabel "Internal"@en, "Interne"@fr ;
    skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/CustomerVisible> a skos:Concept ;
    skos:prefLabel "Customer Visible"@en, "Visible Client"@fr ;
    skos:inScheme <kos/TroubleTicket/commentType> .

# Change Request Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of change requests."@en .
<kos/ChangeRequest/status/Planned> a skos:Concept ;
    skos:prefLabel "Planned"@en, "Planifié"@fr ;
    skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:prefLabel "Implemented"@en, "Implémenté"@fr ;
    skos:inScheme <kos/ChangeRequest/status> .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of resources."@en .
<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:prefLabel "Up"@en, "Actif"@fr ;
    skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:prefLabel "Down"@en, "Inactif"@fr ;
    skos:inScheme <kos/Resource/OperationalState> .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of resources."@en .
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ;
    skos:prefLabel "Enabled"@en, "Activé"@fr ;
    skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Disabled> a skos:Concept ;
    skos:prefLabel "Disabled"@en, "Désactivé"@fr ;
    skos:inScheme <kos/Resource/AdministrativeState> .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying the lifecycle state of resources."@en .
<kos/Resource/LifecycleState/InUse> a skos:Concept ;
    skos:prefLabel "In Use"@en, "En Service"@fr ;
    skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:prefLabel "Decommissioned"@en, "Hors Service"@fr ;
    skos:inScheme <kos/Resource/LifecycleState> .

# Resource Type
<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of IT resources."@en .
<kos/Resource/type/Server> a skos:Concept ;
    skos:prefLabel "Server"@en, "Serveur"@fr ;
    skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ;
    skos:prefLabel "Router"@en, "Routeur"@fr ;
    skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Switch> a skos:Concept ;
    skos:prefLabel "Switch"@en, "Commutateur"@fr ;
    skos:inScheme <kos/Resource/type> .

# Notification Severity Perceived Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the perceived severity of notifications/alarms."@en .
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en, "Critique"@fr ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:prefLabel "Warning"@en, "Avertissement"@fr ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .
<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:prefLabel "Email"@en, "Courriel"@fr ;
    skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:prefLabel "Phone"@en, "Téléphone"@fr ;
    skos:inScheme <kos/org/agent-contact-method> .

# Application SLA Level
<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying Service Level Agreement levels for applications."@en .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ;
    skos:prefLabel "Gold"@en, "Or"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ;
    skos:prefLabel "Silver"@en, "Argent"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizational Units (Teams)
:OrgUnit_DNSAdminTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

:OrgUnit_NOC a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Center"@en, "Centre d'Opérations Réseau"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure and handling incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Follow standard incident response procedures. Escalate to L2 support if needed."@en .

:OrgUnit_InfraTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Infrastructure Team"@en, "Équipe Infrastructure"@fr ;
    rdfs:comment "Team responsible for core IT infrastructure planning and changes."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit change requests via the change management system."@en .

# Individual Agents
:Agent_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en, "Alice Smith"@fr ;
    rdfs:comment "Lead engineer in the DNS Admin Team."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    foaf:member <http://example.com/OrgUnit_DNSAdminTeam> ; # Assuming foaf:member can link to org:OrganizationalUnit
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

:Agent_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en, "Bob Johnson"@fr ;
    rdfs:comment "NOC operator on duty."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    foaf:member <http://example.com/OrgUnit_NOC> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

# Corporate User Identifier
:CUid_AliceSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount :Agent_AliceSmith .

# =============================================================================
# Locations
# =============================================================================

:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    rdfs:comment "Primary data center for corporate IT infrastructure."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace :Site_MainDC .

:Locus_RackDNS01 a noria:Locus ;
    rdfs:label "Rack DNS01 Location"@en, "Emplacement Rack DNS01"@fr ;
    rdfs:comment "Specific rack location for DNS servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "05" ;
    bot:hasSpace :Room_ServerRoomA .

:Locus_RackWeb01 a noria:Locus ;
    rdfs:label "Rack Web01 Location"@en, "Emplacement Rack Web01"@fr ;
    rdfs:comment "Specific rack location for Web servers."@en ;
    noria:locusLine "B" ;
    noria:locusRow "10" ;
    bot:hasSpace :Room_ServerRoomA .

