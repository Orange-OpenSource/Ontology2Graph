# Add another agent and CUid
:Agent_CarolWhite a foaf:Person, foaf:Agent ;
    rdfs:label "Carol White"@en, "Carole Blanc"@fr ;
    rdfs:comment "Network engineer in the NOC team."@en ;
    foaf:mbox <mailto:carol.white@example.com> ;
