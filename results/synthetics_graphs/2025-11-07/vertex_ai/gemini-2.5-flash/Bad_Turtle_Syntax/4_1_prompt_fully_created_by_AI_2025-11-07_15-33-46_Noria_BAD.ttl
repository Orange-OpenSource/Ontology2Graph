# Add a more specific type for TroubleTicket
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of trouble tickets."@en .
<kos/TroubleTicket/type/Incident> a skos:Concept ;
    skos:prefLabel "Incident"@en, "Incident"@fr ;
    skos:inScheme <kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Problem> a skos:Concept ;
    skos:prefLabel "Problem"@en, "Problème"@fr ;
    skos:inScheme <kos/TroubleTicket/type> .

:TroubleTicket_DNSOutage_TT001 noria:troubleTicketType <kos/TroubleTicket/type/Incident> .
:TroubleTicket_WebSrvDegradation_TT002 noria:troubleTicketType <kos/TroubleTicket/type/Problem> .

# Add a problem category (final nature)
