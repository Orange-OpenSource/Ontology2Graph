# =============================================================================
# Event Records
# =============================================================================

:EventRecord_DNSOutage a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Alert"@en ;
    rdfs:comment "Automated alert indicating DNS01 server is unreachable."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN. DNS service not responding."@en ;
    noria:logOriginatingManagedObject :Resource_DNS01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical router interface has gone down."@en ;
    noria:loggingTime "2024-04-23T09:55:00Z"^^xsd:dateTime ;
    noria:logText "INTERFACE_STATUS: GigabitEthernet0/0/1 on cr01.corp.example.com changed state to DOWN."@en ;
    noria:logOriginatingManagedObject :Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_DNSConfigChange a noria:EventRecord ;
    rdfs:label "DNS Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on DNS01."@en ;
    noria:loggingTime "2024-04-22T14:30:00Z"^^xsd:dateTime ;
    noria:logText "CONFIG_CHANGE: DNS zone file updated by asmith."@en ;
    noria:logOriginatingManagedObject :Resource_DNS01 ;
    noria:logOriginatingAgent :Agent_AliceSmith ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

