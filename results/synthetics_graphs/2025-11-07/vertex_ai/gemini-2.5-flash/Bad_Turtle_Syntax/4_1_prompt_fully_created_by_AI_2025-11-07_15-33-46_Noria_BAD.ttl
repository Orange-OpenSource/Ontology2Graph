:TroubleTicket_DNSOutage_TT001 a noria:TroubleTicket ;
    rdfs:label "Critical DNS Server Outage"@en, "Panne Critique Serveur DNS"@fr ;
    rdfs:comment "DNS server dns01.corp.example.com is unreachable, impacting corporate internet access."@en ;
    dcterms:identifier "TT-20240423-001" ;
    dcterms:created "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :EventRecord_DNSOutage ;
    noria:troubleTicketRelatedService :Application_CorpInternetAccess ;
    noria:troubleTicketRelatedResource :Resource_DNS01 ;
    noria:troubleTicketRelatedParty :OrgUnit_NOC ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring"@en ;
    noria:documentHRef <https://ticketing.example.com/TT-20240423-001> ;
    dcterms:hasPart :TroubleTicketNote_DNSOutage_InitialDiag .

:TroubleTicket_WebSrvDegradation_TT002 a noria:TroubleTicket ;
    rdfs:label "Web Server Performance Degradation"@en, "Dégradation Performance Serveur Web"@fr ;
    rdfs:comment "Corporate website experiencing slow response times during peak hours."@en ;
    dcterms:identifier "TT-20240423-002" ;
    dcterms:created "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketRelatedService :Application_CorpWebsite ;
    noria:troubleTicketRelatedResource :Resource_WebSrv01 ;
    noria:troubleTicketRelatedParty :OrgUnit_InfraTeam ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServiceDegradation> ;
    noria:documentHRef <https://ticketing.example.com/TT-20240423-002> .

# =============================================================================
# Trouble Ticket Notes
# =============================================================================

:TroubleTicketNote_DNSOutage_InitialDiag a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for DNS Outage"@en ;
    rdfs:comment "NOC operator performed initial checks. Confirmed DNS service is not responding on port 53. No local network issues detected on the server itself."@en ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_BobJohnson ;
    dcterms:isPartOf :TroubleTicket_DNSOutage_TT001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

:TroubleTicketNote_DNSOutage_Resolution a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Resolution Note"@en ;
    rdfs:comment "DNS Admin Team restarted DNS service. Service restored. Monitoring confirmed."@en ;
    dcterms:created "2024-04-23T11:45:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_AliceSmith ;
    dcterms:isPartOf :TroubleTicket_DNSOutage_TT001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    noria:troubleTicketNoteCorrelatedExecution :OperationPlan_RestartDNSService . # Linking to the procedure that was executed

# =============================================================================
# Operation Plans and Conditions
# =============================================================================

:OperationPlan_RestartDNSService a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS service on a server."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_DNSServiceDown ;
    noria:operationPlanPostCondition :ActionPostCondition_DNSServiceUp .

:ActionPreCondition_DNSServiceDown a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS service (port 53) is not responding from external and internal checks."@en ;
    skos:example "Check DNS resolution from multiple vantage points."@en .

:ActionPostCondition_DNSServiceUp a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS service (port 53) is responding, and DNS resolution is successful."@en ;
    skos:example "Verify DNS resolution for key internal and external domains."@en .

:OperationPlan_WebSrvOptimization a noria:OperationPlan ;
    rdfs:label "Web Server Performance Optimization Procedure"@en ;
    rdfs:comment "Procedure for optimizing web server performance, including cache clearing and resource allocation checks."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_WebSrvSlow ;
    noria:operationPlanPostCondition :ActionPostCondition_WebSrvFast .

:ActionPreCondition_WebSrvSlow a noria:ActionPreCondition ;
    rdfs:label "Web Server Slow Response"@en ;
    rdfs:comment "Condition: Web server response time exceeds 5 seconds for critical pages."@en .

:ActionPostCondition_WebSrvFast a noria:ActionPostCondition ;
    rdfs:label "Web Server Response Optimized"@en ;
    rdfs:comment "Outcome: Web server response time is consistently below 2 seconds."@en .

