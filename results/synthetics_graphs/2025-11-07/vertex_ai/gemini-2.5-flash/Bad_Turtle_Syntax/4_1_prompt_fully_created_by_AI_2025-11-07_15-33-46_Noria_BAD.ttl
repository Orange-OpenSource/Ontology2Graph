# =============================================================================
# Connections and Density Enhancements
# =============================================================================

# Further connect Agents to Resources they manage
:OrgUnit_DNSAdminTeam noria:agentManagesResource :Resource_DNS01 .
:OrgUnit_NOC noria:agentManagesResource :Resource_CoreRouter01 .
:OrgUnit_InfraTeam noria:agentManagesResource :Resource_WebSrv01 .

# Connect Network Interfaces to Network Links
:NetworkInterface_DNS01_Eth0 noria:networkInterfaceConnects :NetworkLink_DNS01_LAN .
:NetworkInterface_CR01_Gi0_0_1 noria:networkInterfaceConnects :NetworkLink_CR01_ISP_Uplink .

# Connect Application Modules to Services (using seas:subSystemOf as a general grouping)
:ApplicationModule_CIA_Prod seas:subSystemOf :Service_GlobalConnectivity .
:ApplicationModule_CWEB_Prod seas:subSystemOf :Service_WebHosting .

# Connect Event Records to proposed repair actions
:EventRecord_DNSOutage noria:alarmProposedRepairAction :OperationPlan_RestartDNSService .

# Connect Trouble Tickets to their status history (represented by EventRecords)
:TroubleTicket_DNSOutage_TT001 noria:documentStatusHistory :EventRecord_DNSOutage_StatusChange_InProgress .
:EventRecord_DNSOutage_StatusChange_InProgress a noria:EventRecord ;
    rdfs:label "TT-001 Status Change to InProgress"@en ;
    noria:loggingTime "2024-04-23T10:06:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240423-001 status changed to InProgress."@en ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:TroubleTicket_DNSOutage_TT001 noria:documentStatusHistory :EventRecord_DNSOutage_StatusChange_Resolved .
:EventRecord_DNSOutage_StatusChange_Resolved a noria:EventRecord ;
    rdfs:label "TT-001 Status Change to Resolved"@en ;
    noria:loggingTime "2024-04-23T11:50:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240423-001 status changed to Resolved."@en ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# Example of an alarm being mitigated by a procedure execution container (the TT itself)
:EventRecord_DNSOutage noria:alarmMitigatedBy :TroubleTicket_DNSOutage_TT001 .

# Connect Change Request to its status history
:ChangeRequest_DNSUpgrade_CR001 noria:documentStatusHistory :EventRecord_CR001_StatusChange_Planned .
:EventRecord_CR001_StatusChange_Planned a noria:EventRecord ;
    rdfs:label "CR-001 Status Change to Planned"@en ;
    noria:loggingTime "2024-04-25T09:05:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-20240501-001 status changed to Planned."@en ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# Add more details to resources
:Resource_DNS01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
:Resource_CoreRouter01 noria:networkInterfaceLaserRxOpticalPowerAverage -4 .
:Resource_CoreRouter01 noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 .
:Resource_CoreRouter01 noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

