# =============================================================================
# Network Interfaces and Links
# =============================================================================

:NetworkInterface_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface for Web Server 01."@en ;
    noria:networkInterfaceOf :Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Primary network interface for web traffic."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects :NetworkLink_WebSrv01_to_AccSwitch01 .

:NetworkInterface_DBSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBSrv01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface for DB Server 01."@en ;
    noria:networkInterfaceOf :Resource_DBSrv01 ;
    noria:networkInterfaceDescription "Primary network interface for database traffic."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects :NetworkLink_DBSrv01_to_AccSwitch01 .

:NetworkInterface_AccSwitch01_Port1 a noria:NetworkInterface ;
    rdfs:label "AccSwitch01 Port 1"@en ;
    rdfs:comment "Port 1 on Access Switch 01, connected to WebSrv01."@en ;
    noria:networkInterfaceOf :Resource_AccessSwitch01 ;
    noria:networkInterfaceDescription "Uplink to WebSrv01."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects :NetworkLink_WebSrv01_to_AccSwitch01 .

:NetworkInterface_AccSwitch01_Port2 a noria:NetworkInterface ;
    rdfs:label "AccSwitch01 Port 2"@en ;
    rdfs:comment "Port 2 on Access Switch 01, connected to DBSrv01."@en ;
    noria:networkInterfaceOf :Resource_AccessSwitch01 ;
    noria:networkInterfaceDescription "Uplink to DBSrv01."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects :NetworkLink_DBSrv01_to_AccSwitch01 .

:NetworkInterface_CoreRouter01_Gig0_0_0 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 Gig0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 01."@en ;
    noria:networkInterfaceOf :Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to external network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

:NetworkLink_WebSrv01_to_AccSwitch01 a noria:NetworkLink ;
    rdfs:label "Link WebSrv01 to AccSwitch01"@en ;
    rdfs:comment "Ethernet link between WebSrv01 and AccessSwitch01."@en ;
    noria:networkLinkId "LINK-WS01-AS01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination :Resource_AccessSwitch01 ;
    noria:resourceManagedBy :Agent_Network_Team .

:NetworkLink_DBSrv01_to_AccSwitch01 a noria:NetworkLink ;
    rdfs:label "Link DBSrv01 to AccSwitch01"@en ;
    rdfs:comment "Ethernet link between DBSrv01 and AccessSwitch01."@en ;
    noria:networkLinkId "LINK-DB01-AS01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_DBSrv01 ;
    noria:networkLinkTerminationResourceDestination :Resource_AccessSwitch01 ;
    noria:resourceManagedBy :Agent_Network_Team .

# =============================================================================
# Applications and Application Modules
# =============================================================================

:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CP-APP-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CustPortal" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Self-Service" .

:ApplicationModule_CustomerPortal_Prod a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "Production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf :Application_CustomerPortal ;
    noria:applicationModuleName "CustPortal_Prod" ;
    noria:applicationModuleIdentifier "CP-MOD-PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam :Agent_App_Support_L2 ;
    noria:applicationModuleAdministrationLeader :Agent_Jane_Smith ;
    noria:applicationModuleSupportTeam :Agent_IT_Ops_Team ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

:ApplicationModule_CustomerPortal_Staging a noria:ApplicationModule ;
    rdfs:label "Customer Portal Staging Module"@en ;
    rdfs:comment "Staging instance of the Customer Portal application for testing."@en ;
    noria:applicationModuleOf :Application_CustomerPortal ;
