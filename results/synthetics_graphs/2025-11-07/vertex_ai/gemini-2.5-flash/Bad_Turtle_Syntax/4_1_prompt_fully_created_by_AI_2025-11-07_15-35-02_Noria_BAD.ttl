# =============================================================================
# Operation Plans and Conditions
# =============================================================================

:OperationPlan_RouterOSUpgrade a noria:OperationPlan ;
    rdfs:label "Standard Router OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the operating system of a Cisco ASR 9000 series router."@en ;
    skos:example "1. Backup configuration. 2. Download new OS image. 3. Install image. 4. Reboot. 5. Verify services."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_RouterReadyForUpgrade ;
    noria:operationPlanPostCondition :ActionPostCondition_RouterOSUpgraded .

:ActionPreCondition_RouterReadyForUpgrade a noria:ActionPreCondition ;
    rdfs:label "Router Ready for Upgrade Pre-Condition"@en ;
    rdfs:comment "Verify router health, backup status, and maintenance window approval."@en .

:ActionPostCondition_RouterOSUpgraded a noria:ActionPostCondition ;
    rdfs:label "Router OS Upgraded Post-Condition"@en ;
    rdfs:comment "Confirm new OS version, verify network connectivity, and service functionality."@en .

:ProcedureExecution_WebSrv01_PowerCycle a pep:ProcedureExecutionContainer ;
    rdfs:label "WebSrv01 Power Cycle Execution"@en ;
    rdfs:comment "Record of the power cycle action performed on WebSrv01."@en ;
    dcterms:created "2024-03-20T14:55:00Z"^^xsd:dateTime ;
    pep:hasProcedure :OperationPlan_ServerPowerCycle .

:OperationPlan_ServerPowerCycle a noria:OperationPlan ;
    rdfs:label "Server Power Cycle Procedure"@en ;
    rdfs:comment "Standard procedure for power cycling a server."@en .

# =============================================================================
# Anomaly Patterns
# =============================================================================

:AnomalyPattern_HighCPUUsage a noria:AnomalyPattern ;
    rdfs:label "High CPU Usage Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage, potentially leading to performance degradation or service outage."@en ;
    skos:example "CPU usage > 90% for 15 minutes on a critical server."@en .
