    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceHostName "corerouter01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_Cisco_ASR9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-DEF" ;
