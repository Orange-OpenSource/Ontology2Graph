    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_IT_Ops_Team ;
    noria:resourceForApplication :Application_CustomerPortal ;
    noria:locatedAtLocus :Locus_Rack_A1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

