# =============================================================================
# Document Attachments
# =============================================================================

noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram - Paris DC"@en ;
    rdfs:comment "PDF document showing the network topology of the Paris Data Center."@en ;
    dcterms:created "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf" ;
    dcterms:title "Paris_DC_Network_Diagram.pdf"@en ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade_001 .

noria:DocumentAttachment_ServerLog a noria:DocumentAttachment ;
    rdfs:label "AppServer01 Crash Log"@en ;
    rdfs:comment "Log file from AppServer01 at the time of the outage."@en ;
    dcterms:created "2024-04-23T10:10:00Z"^^xsd:dateTime ;
