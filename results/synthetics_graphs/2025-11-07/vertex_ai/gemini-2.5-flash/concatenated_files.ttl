    noria:changeRequestImpact noria:Resource_DBServer_SQL01 ;
    noria:changeRequestImpact noria:ApplicationModule_CP_Prod ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ; # 1 hour 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty noria:Agent_App_Dev_Team ;
    noria:changeRequestPilotParty noria:Agent_DB_Admin_Team ;
    noria:changeRequestActorParty noria:Agent_DB_Admin_Team ;
    noria:changeRequestIsRegulated false .

# --- Operation Plans (noria:OperationPlan) ---
noria:OperationPlan_Router_Upgrade_Procedure a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router software, including pre-checks, upgrade steps, and post-checks."@en ;
    skos:example "Refer to document 'SOP-NET-001-V2.3' for detailed steps."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Router_Connectivity_Check ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Router_Operational_Check .

noria:OperationPlan_DB_Schema_Update_Procedure a noria:OperationPlan ;
    rdfs:label "Database Schema Update Procedure"@en ;
    rdfs:comment "Procedure for applying database schema changes, including backup, script execution, and verification."@en ;
    skos:example "Refer to document 'SOP-DB-005-V1.1' for detailed steps."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DB_Backup_Complete ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DB_Schema_Verified .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:ActionPreCondition_Router_Connectivity_Check a noria:ActionPreCondition ;
    rdfs:label "Router Connectivity Pre-Check"@en ;
    rdfs:comment "Verify network connectivity to the router and its neighbors before starting the upgrade."@en ;
    skos:example "Ping all adjacent devices, check routing table stability."@en .

noria:ActionPostCondition_Router_Operational_Check a noria:ActionPostCondition ;
    rdfs:label "Router Operational Post-Check"@en ;
    rdfs:comment "Verify router is fully operational and traffic is flowing correctly after the upgrade."@en ;
    skos:example "Verify BGP sessions are up, check interface status, monitor traffic."@en .

noria:ActionPreCondition_DB_Backup_Complete a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completion Pre-Check"@en ;
    rdfs:comment "Ensure a full backup of the database is successfully completed before applying schema changes."@en ;
    skos:example "Check backup logs, verify backup file integrity."@en .

noria:ActionPostCondition_DB_Schema_Verified a noria:ActionPostCondition ;
    rdfs:label "Database Schema Verification Post-Check"@en ;
    rdfs:comment "Verify the new database schema is correctly applied and applications can access it."@en ;
    skos:example "Run schema validation scripts, test application connectivity to DB."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
noria:DocumentAttachment_NetworkDiagram_CR001 a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for CR001"@en ;
    rdfs:comment "Diagram showing the network topology affected by CR001."@en ;
    dcterms:isPartOf noria:ChangeRequest_CR001 ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "network_diagram_cr001.pdf" .

noria:DocumentAttachment_DB_Schema_Script_CR002 a noria:DocumentAttachment ;
    rdfs:label "DB Schema Update Script for CR002"@en ;
    rdfs:comment "SQL script to apply the database schema changes for CR002."@en ;
    dcterms:isPartOf noria:ChangeRequest_CR002 ;
    dcterms:format "application/sql" ;
    dcterms:identifier "db_schema_update_cr002.sql" .

noria:DocumentAttachment_FiberRepairReport_TT001 a noria:DocumentAttachment ;
    rdfs:label "Fiber Repair Report for TT001"@en ;
    rdfs:comment "Report from ISP A detailing the fiber repair for TT001."@en ;
    dcterms:isPartOf noria:TroubleTicket_TT001 ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "isp_fiber_repair_report_tt001.pdf" .
