    noria:logText "Interface GigabitEthernet0/0/1 on cr01.dc.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemApp ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_ConfigChangeRouter a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router 01."@en ;
    noria:loggingTime "2024-04-22T14:20:30Z"^^xsd:dateTime ;
    noria:logText "Configuration changed by John Doe from console."@en ;
    noria:logOriginatingManagedObject noria:CoreRouter01 ;
    noria:logOriginatingAgent noria:JohnDoe ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemApp ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

