# --- Operation Plans (noria:OperationPlan) ---
noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Firewall Rule Deployment Guide"@en ;
    rdfs:comment "Guide for deploying new firewall rules, including rollback steps."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Database Performance Tuning Steps"@en ;
    rdfs:comment "Steps to diagnose and resolve database performance bottlenecks."@en .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Status Check"@en ;
    rdfs:comment "Verify current status of DNS service and network reachability before restart."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Reachable"@en ;
    rdfs:comment "Confirm DNS service is up and resolving queries after restart."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Firewall Policy Review"@en ;
    rdfs:comment "Review proposed firewall rules against existing policy and network topology."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Traffic Flow Verified"@en ;
    rdfs:comment "Verify that intended traffic flows are permitted and unintended traffic is blocked after rule deployment."@en .

# --- Additional Connectivity ---
# Link TroubleTicket to OperationPlan via EventRecord (alarmMitigatedBy)
noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord10 .
noria:TroubleTicket3 noria:documentStatusHistory noria:EventRecord11 .

# Link ChangeRequest to OperationPlan (actionCorrelatedOperationPlan)
noria:ChangeRequest1 pep:usedProcedure noria:OperationPlan2 .
noria:ChangeRequest2 pep:usedProcedure noria:OperationPlan3 .
noria:ChangeRequest3 pep:usedProcedure noria:OperationPlan1 . # Example: OS patching might involve a standard reboot procedure.

# Link EventRecords to TroubleTickets (inverse of troubleTicketTrigger)
noria:EventRecord1 dcterms:relation noria:TroubleTicket1 .
noria:EventRecord3 dcterms:relation noria:TroubleTicket2 .
noria:EventRecord4 dcterms:relation noria:TroubleTicket2, noria:TroubleTicket4 .
noria:EventRecord5 dcterms:relation noria:TroubleTicket3 .
noria:EventRecord6 dcterms:relation noria:TroubleTicket5 .

# Link Resources to Applications (noria:resourceForApplication is already used, but let's add more)
noria:Resource1 noria:resourceForApplication noria:Application6 . # DNS also for Identity Management
noria:Resource2 noria:resourceForApplication noria:Application10 . # Core Router for Network Security Gateway
noria:Resource3 noria:resourceForApplication noria:Application5 . # Web server is monitored
noria:Resource4 noria:resourceForApplication noria:Application8 . # DB server is backed up
noria:Resource5 noria:resourceForApplication noria:Application1, noria:Application2, noria:Application3, noria:Application4, noria:Application5, noria:Application6, noria:Application7, noria:Application8, noria:Application9, noria:Application10 . # Firewall protects all applications
noria:Resource6 noria:resourceForApplication noria:Application2 . # Load Balancer for Customer Portal
noria:Resource7 noria:resourceForApplication noria:Application6 . # VPN Gateway for Identity Management
noria:Resource8 noria:resourceForApplication noria:Application7 . # Monitoring Server for Log Aggregation
noria:Resource9 noria:resourceForApplication noria:Application4 . # Backup Storage for Email Service
noria:Resource10 noria:resourceForApplication noria:Application2, noria:Application3 . # Virtualization Host for Customer Portal and Internal CRM
noria:Resource11 noria:resourceForApplication noria:Application1, noria:Application4 . # Edge Router for Corporate Internet Access and Email Service
noria:Resource12 noria:resourceForApplication noria:Application1 . # Proxy Server for Corporate Internet Access
noria:Resource13 noria:resourceForApplication noria:Application5 . # Mail Server is monitored
noria:Resource14 noria:resourceForApplication noria:Application2, noria:Application3 . # Identity Provider for Customer Portal and Internal CRM
noria:Resource15 noria:resourceForApplication noria:Application5, noria:Application10 . # Log Management System for Monitoring Platform and Network Security Gateway

# Link Application Modules to Services (seas:subSystem is already used, but let's add more)
noria:ApplicationModule1 seas:subSystemOf noria:Service1 .
noria:ApplicationModule2 seas:subSystemOf noria:Service2 .
noria:ApplicationModule3 seas:subSystemOf noria:Service3 .
noria:ApplicationModule4 seas:subSystemOf noria:Service1 .
noria:ApplicationModule5 seas:subSystemOf noria:Service4 .
noria:ApplicationModule6 seas:subSystemOf noria:Service1 .
noria:ApplicationModule7 seas:subSystemOf noria:Service4 .
noria:ApplicationModule8 seas:subSystemOf noria:Service4 .
noria:ApplicationModule9 seas:subSystemOf noria:Service4 .
noria:ApplicationModule10 seas:subSystemOf noria:Service4 .

# Link Agents to resources they manage (noria:agentManagesResource)
foaf:Agent1 noria:agentManagesResource noria:Resource1 .
foaf:Agent2 noria:agentManagesResource noria:Resource2, noria:Resource11, noria:NetworkLink1, noria:NetworkLink2, noria:NetworkLink4, noria:NetworkLink5, noria:NetworkLink6 .
foaf:Agent3 noria:agentManagesResource noria:Resource3, noria:Resource6, noria:NetworkLink3 .
foaf:Agent4 noria:agentManagesResource noria:Resource5, noria:Resource7, noria:Resource12, noria:Resource14, noria:Resource15, noria:NetworkLink7 .
foaf:Agent7 noria:agentManagesResource noria:Resource9, noria:Resource13 .
foaf:Agent8 noria:agentManagesResource noria:Resource4 .
foaf:Agent9 noria:agentManagesResource noria:Resource10 .

# Link Agents to applications/modules they administer/support
noria:ApplicationModule1 noria:applicationModuleAdministrationTeam foaf:Agent2 ;
                         noria:applicationModuleSupportTeam foaf:Agent2 .
noria:ApplicationModule2 noria:applicationModuleAdministrationTeam foaf:Agent3 ;
                         noria:applicationModuleSupportTeam foaf:Agent3 .
noria:ApplicationModule3 noria:applicationModuleAdministrationTeam foaf:Agent10 ;
                         noria:applicationModuleSupportTeam foaf:Agent10 .
noria:ApplicationModule4 noria:applicationModuleAdministrationTeam foaf:Agent7 ;
                         noria:applicationModuleSupportTeam foaf:Agent7 .
noria:ApplicationModule5 noria:applicationModuleAdministrationTeam foaf:Agent2 ;
                         noria:applicationModuleSupportTeam foaf:Agent2 .
noria:ApplicationModule6 noria:applicationModuleAdministrationTeam foaf:Agent4 ;
                         noria:applicationModuleSupportTeam foaf:Agent4 .
noria:ApplicationModule7 noria:applicationModuleAdministrationTeam foaf:Agent4 ;
                         noria:applicationModuleSupportTeam foaf:Agent4 .
noria:ApplicationModule8 noria:applicationModuleAdministrationTeam foaf:Agent7 ;
                         noria:applicationModuleSupportTeam foaf:Agent7 .
noria:ApplicationModule9 noria:applicationModuleAdministrationTeam foaf:Agent9 ;
                         noria:applicationModuleSupportTeam foaf:Agent9 .
noria:ApplicationModule10 noria:applicationModuleAdministrationTeam foaf:Agent4 ;
                          noria:applicationModuleSupportTeam foaf:Agent4 .

# Link TroubleTickets to other related parties
noria:TroubleTicket1 noria:troubleTicketRelatedParty foaf:Agent7 . # John Doe as the admin who worked on it
noria:TroubleTicket2 noria:troubleTicketRelatedParty foaf:Agent18 . # Bob White as DB specialist
noria:TroubleTicket3 noria:troubleTicketRelatedParty foaf:Agent20 . # David Black as security analyst
noria:TroubleTicket4 noria:troubleTicketRelatedParty foaf:Agent18 .
noria:TroubleTicket5 noria:troubleTicketRelatedParty foaf:Agent15 . # Jane Smith as network engineer

# Link ChangeRequests to other related parties
noria:ChangeRequest1 noria:changeRequestInitiatorParty foaf:Agent10 ;
                     noria:changeRequestPilotParty foaf:Agent20 ;
                     noria:changeRequestActorParty foaf:Agent20 .
noria:ChangeRequest2 noria:changeRequestInitiatorParty foaf:Agent11 ;
                     noria:changeRequestPilotParty foaf:Agent18 ;
                     noria:changeRequestActorParty foaf:Agent18 .
noria:ChangeRequest3 noria:changeRequestInitiatorParty foaf:Agent7 ;
                     noria:changeRequestPilotParty foaf:Agent16 ;
                     noria:changeRequestActorParty foaf:Agent16 .
noria:ChangeRequest4 noria:changeRequestInitiatorParty foaf:Agent2 ;
                     noria:changeRequestPilotParty foaf:Agent15 ;
                     noria:changeRequestActorParty foaf:Agent23 .

# Link EventRecords to TroubleTickets and ChangeRequests for status history
noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord10 .
noria:TroubleTicket3 noria:documentStatusHistory noria:EventRecord11 .
noria:ChangeRequest1 dcterms:references noria:EventRecord11 . # Assuming the firewall rule change was related to a previous CR.

# Example of a CUid
<http://example.com/cuid/jdoe> a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount foaf:Agent7 .

# Example of a more complex relationship for a resource
noria:Resource10 noria:clusterController noria:Resource10 . # Self-referential if it's the controller itself, or another resource if it's part of a cluster managed by another resource. Let's assume it's managed by a virtual controller on itself for simplicity.
noria:Resource10 noria:virtualServerStatus <kos/Resource/OperationalState/up> .

# Example of network interface observables
noria:NetworkInterface2 noria:networkInterfaceRoutingPriorityMetric 100 .
noria:NetworkInterface2 noria:networkInterfaceLaserTxOpticalPower -3 .
noria:NetworkInterface2 noria:networkInterfaceLaserRxOpticalPower -5 .
noria:NetworkInterface2 noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 .
noria:NetworkInterface2 noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Example of a TroubleTicketNote correlated execution
noria:TroubleTicketNote1 noria:troubleTicketNoteCorrelatedExecution noria:EventRecord10 . # The restart action resulted in this event.

# Example of a ChangeRequest specification
noria:ChangeRequest1 noria:changeRequestSpecification <kos/ChangeRequest/specification/FirewallPolicyUpdate> .

# Example of a TroubleTicket with problem responsibility
noria:TroubleTicket1 noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> .
noria:TroubleTicket2 noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> .
noria:TroubleTicket3 noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedSpecificNetworks> .

# Example of a TroubleTicket with documentExternalId
noria:TroubleTicket2 noria:documentExternalId "CUST-REF-XYZ-456" .

# Example of a TroubleTicket with isNotificationEnable
noria:TroubleTicket1 noria:troubleTicketIsNotificationEnable true .
noria:TroubleTicket2 noria:troubleTicketIsNotificationEnable false .

# Example of a ChangeRequest with isRegulated
noria:ChangeRequest2 noria:changeRequestIsRegulated true .
noria:ChangeRequest1 noria:changeRequestIsRegulated false .

# Example of a TroubleTicket freeze item (linking to an EventRecord that signifies a freeze)
noria:TroubleTicket2 noria:troubleTicketFreezeItem noria:EventRecord8 . # Monitoring agent offline might cause a freeze in resolution time calculation.

