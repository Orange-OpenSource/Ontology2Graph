noria:ChangeRequest_RouterUpgrade_001 a noria:ChangeRequest ;
    rdfs:label "Core Router OS Upgrade"@en ;
    rdfs:comment "Planned OS upgrade for Core Router 01 to address known vulnerabilities and improve performance."@en ;
    dcterms:identifier "CR-20240501-001" ;
    noria:documentExternalId "CHG-54321" ;
    noria:documentHRef <http://itsm.example.com/changes/CR-20240501-001> ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource_CoreRouter01, noria:Service_InternetAccess ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ; # 30 minutes outage
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty noria:Employee_Alice ;
    noria:changeRequestPilotParty noria:Agent_Network_Team ;
    noria:changeRequestActorParty noria:Agent_Network_Team ;
    noria:changeRequestIsRegulated true .

noria:ChangeRequest_DBPatch_002 a noria:ChangeRequest ;
    rdfs:label "Database Security Patch Deployment"@en ;
    rdfs:comment "Deployment of critical security patches to DBServer01."@en ;
    dcterms:identifier "CR-20240428-002" ;
    noria:documentExternalId "CHG-54322" ;
    noria:documentHRef <http://itsm.example.com/changes/CR-20240428-002> ;
    noria:changeRequestPlannedStartTime "2024-04-28T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-28T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource_DBServer01, noria:Application_CustomerPortal ;
    noria:changeRequestOutageDuration "PT15M"^^xsd:duration ; # 15 minutes outage
