noria:TroubleTicket_WebServerOutage a noria:TroubleTicket ;
    rdfs:label "Web Server Outage Incident"@en, "Incident Panne Serveur Web"@fr ;
    rdfs:comment "Critical incident regarding the unavailability of the customer portal web server."@en ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:documentExternalId "TT-20240423-001" ;
    noria:documentHRef <https://ticketing.example.com/TT-20240423-001> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_WebServerCPUHigh ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:CustomerPortalProdModule ;
    noria:troubleTicketRelatedResource noria:WebServer01 ;
    noria:troubleTicketRelatedParty noria:AppSupportL2Team, noria:ITOperationsTeam ;
    noria:troubleTicketDescription "Web server web01.app.example.com is unresponsive, affecting customer portal access. High CPU alerts received."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Prometheus" .

noria:TroubleTicket_VPNConnectivity a noria:TroubleTicket ;
    rdfs:label "Corporate VPN Connectivity Issue"@en, "Problème de Connectivité VPN d'Entreprise"@fr ;
    rdfs:comment "Users reporting intermittent connectivity to the corporate VPN service."@en ;
    dcterms:created "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:documentExternalId "TT-20240423-002" ;
    noria:documentHRef <https://ticketing.example.com/TT-20240423-002> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:CorporateVPNService ;
    noria:troubleTicketRelatedParty noria:NetworkAdminTeam, noria:CustomerService ;
    noria:troubleTicketDescription "Multiple users are unable to connect to the corporate VPN or experience frequent disconnections."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Zabbix" .

# =============================================================================
# Trouble Ticket Notes
# =============================================================================

noria:TTNote_WebServerOutage_Diag a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for Web Server Outage"@en ;
    rdfs:comment "First steps taken to diagnose the web server outage."@en ;
    dcterms:created "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    dcterms:creator noria:AppSupportL2Team ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:description "Checked server logs, confirmed high CPU and unresponsive web service. Attempted restart of web service, no change."@en ;
    dcterms:isPartOf noria:TroubleTicket_WebServerOutage .

noria:TTNote_WebServerOutage_Resolved a noria:TroubleTicketNote ;
    rdfs:label "Web Server Outage Resolution"@en ;
    rdfs:comment "Steps taken to resolve the web server outage."@en ;
    dcterms:created "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    dcterms:creator noria:AppSupportL2Team ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:description "Identified runaway process consuming CPU. Killed process and restarted web service. Service restored."@en ;
    dcterms:isPartOf noria:TroubleTicket_WebServerOutage ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_ConfigChangeRouter . # Example of correlation, though this specific event is for router.

