# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:StandardRouterRebootProcedure a noria:OperationPlan ;
    rdfs:label "Standard Router Reboot Procedure"@en ;
    rdfs:comment "A documented procedure for safely rebooting network routers."@en ;
    skos:example "Steps include notifying stakeholders, checking network redundancy, executing reboot command, and verifying service restoration."@en ;
    noria:operationPlanPreCondition noria:PreCond_NetworkRedundancyOK ;
    noria:operationPlanPostCondition noria:PostCond_RouterOnlineAndTrafficFlowing .

noria:PreCond_NetworkRedundancyOK a noria:ActionPreCondition ;
    rdfs:label "Network Redundancy is OK"@en ;
    rdfs:comment "Ensures that redundant paths are active before performing maintenance on a network device."@en .

noria:PostCond_RouterOnlineAndTrafficFlowing a noria:ActionPostCondition ;
    rdfs:label "Router Online and Traffic Flowing"@en ;
    rdfs:comment "Verifies that the router has successfully rebooted and network traffic is flowing as expected."@en .

noria:DatabaseBackupRoutine a noria:OperationPlan ;
    rdfs:label "Daily Database Backup Routine"@en ;
    rdfs:comment "Automated procedure for daily backups of critical databases."@en ;
    noria:operationPlanPreCondition noria:PreCond_BackupStorageAvailable ;
    noria:operationPlanPostCondition noria:PostCond_BackupCompletedSuccessfully .

noria:PreCond_BackupStorageAvailable a noria:ActionPreCondition ;
    rdfs:label "Backup Storage Available"@en ;
    rdfs:comment "Ensures that sufficient storage space is available for the backup operation."@en .

noria:PostCond_BackupCompletedSuccessfully a noria:ActionPostCondition ;
    rdfs:label "Backup Completed Successfully"@en ;
    rdfs:comment "Confirms that the database backup process finished without errors."@en .

# =============================================================================
# Connectivity and Density Enhancements
# =============================================================================

# Link more agents to resources/applications
noria:ITOperationsTeam noria:agentManagesResource noria:WebServer01, noria:DatabaseServer02 .
noria:NetworkAdminTeam noria:agentManagesResource noria:CoreRouter01, noria:FirewallFW01, noria:FiberLinkDC_HQ .
noria:AppSupportL2Team noria:agentManagesResource noria:CustomerPortalApp, noria:CustomerPortalProdModule .

# Link applications to resources
noria:CustomerPortalApp seas:subSystem noria:WebServer01, noria:DatabaseServer02 .
noria:MonitoringSystemApp seas:subSystem noria:CoreRouter01, noria:WebServer01, noria:DatabaseServer02, noria:FirewallFW01 .

# Link services to application modules
noria:EcommercePlatformService seas:subSystem noria:CustomerPortalProdModule .
noria:CorporateVPNService seas:subSystem noria:CoreRouter01, noria:FirewallFW01 . # VPN service relies on router and firewall

# Link trouble tickets to event records for status history
noria:TroubleTicket_WebServerOutage noria:documentStatusHistory noria:EventRecord_WebServerCPUHigh .
noria:TroubleTicket_WebServerOutage noria:documentStatusHistory noria:EventRecord_ConfigChangeRouter . # A config change might be part of the resolution history

# Link change requests to event records for actual execution
noria:ChangeRequest_RouterOSUpgrade noria:documentStatusHistory noria:EventRecord_ConfigChangeRouter .

# Example of a resource being a cluster controller for another resource
noria:VirtualizationHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    noria:resourceHostName "vhost01.dc.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy noria:ITOperationsTeam .

noria:VirtualMachineAppX a noria:Resource ;
    rdfs:label "Virtual Machine AppX"@en ;
    noria:resourceHostName "vm-appx.app.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy noria:AppSupportL2Team ;
    noria:clusterController noria:VirtualizationHost01 .

# Example of a trouble ticket impacting multiple entities
noria:TroubleTicket_VPNConnectivity noria:troubleTicketImpacts noria:CoreRouter01, noria:FirewallFW01 .

# Example of a trouble ticket cause and responsibility
noria:TroubleTicket_WebServerOutage noria:troubleTicketCause "Runaway process on web server."@en ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/ApplicationFailure> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ApplicationTeam> .

<kos/TroubleTicket/trouble-category/ApplicationFailure> a skos:Concept ; rdfs:label "Application Failure"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ; rdfs:label "Application Team Responsibility"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .

# Example of agent contact method KOS
<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; rdfs:label "Ticketing System"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .

# Example of SLA Level KOS
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# Example of Change Request Category KOS
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .

# Example of Trouble Ticket Urgency KOS
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> .

# Example of Service Type KOS
<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .

