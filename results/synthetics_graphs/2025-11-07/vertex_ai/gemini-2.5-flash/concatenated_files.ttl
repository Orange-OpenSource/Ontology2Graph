# --- Change Requests (noria:ChangeRequest) ---
noria:ChangeRequest1 a noria:ChangeRequest ;
    rdfs:label "Firewall Rule Update for New Service"@en ;
    rdfs:comment "Add new firewall rules to allow traffic for the upcoming 'New Service' application."@en ;
    dcterms:identifier "CR-20240424-001" ;
    dcterms:created "2024-04-22T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-24T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-24T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ;
    noria:changeRequestImpact noria:Resource5, noria:Application10 ;
    noria:changeRequestOutageDuration "PT0H0M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty foaf:Agent10 ;
    noria:changeRequestPilotParty foaf:Agent4 ;
    noria:changeRequestActorParty foaf:Agent20 ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef "https://itsm.example.com/change/CR-20240424-001" .

noria:ChangeRequest2 a noria:ChangeRequest ;
    rdfs:label "Database Schema Migration for CRM"@en ;
    rdfs:comment "Perform a schema migration on the Internal CRM database to support new features."@en ;
    dcterms:identifier "CR-20240425-002" ;
    dcterms:created "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-25T04:30:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource4, noria:Application3, noria:ApplicationModule3 ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent11 ;
    noria:changeRequestPilotParty foaf:Agent8 ;
    noria:changeRequestActorParty foaf:Agent18 ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef "https://itsm.example.com/change/CR-20240425-002" .

noria:ChangeRequest3 a noria:ChangeRequest ;
    rdfs:label "OS Patching for Web Servers"@en ;
    rdfs:comment "Apply critical OS security patches to all web application servers."@en ;
    dcterms:identifier "CR-20240426-003" ;
    dcterms:created "2024-04-18T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-26T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-26T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource3, noria:Resource6, noria:Application2, noria:ApplicationModule2 ;
    noria:changeRequestOutageDuration "PT0H30M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty foaf:Agent7 ;
    noria:changeRequestPilotParty foaf:Agent7 ;
    noria:changeRequestActorParty foaf:Agent16 ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef "https://itsm.example.com/change/CR-20240426-003" .

noria:ChangeRequest4 a noria:ChangeRequest ;
    rdfs:label "WAN Link Upgrade DC-Paris"@en ;
    rdfs:comment "Upgrade bandwidth of the WAN link between Main Data Center and Paris Branch Office."@en ;
    dcterms:identifier "CR-20240501-004" ;
    dcterms:created "2024-04-15T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T06:00:00Z"^^xsd:dateTime ;
