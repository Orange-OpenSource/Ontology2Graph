    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

<https://w3id.org/noria/troubleticketnote/TT20240423-001-Note2>
    a noria:TroubleTicketNote ;
    rdfs:label "Resolution Steps for TT20240423-001"@en ;
    rdfs:comment "Engaged external fiber provider. They confirmed a fiber cut and dispatched a team. ETR 4 hours."@en ;
