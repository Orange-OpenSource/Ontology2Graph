noria:EventRecord_WebServerCPUHigh a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.app.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:WebServer01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemApp ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating that an interface on Core Router 01 went down."@en ;
