# =============================================================================
# Services
# =============================================================================

noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    noria:elementManagedBy noria:Agent_Network_Team .

noria:Service_CustomerFacingWeb a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "High-level service encompassing all customer-facing web applications, including the Customer Portal."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    noria:elementManagedBy noria:Agent_App_Support .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_AppServerDown a noria:EventRecord ;
    rdfs:label "AppServer01 Down Alert"@en ;
    rdfs:comment "Alert indicating that Application Server 01 is unreachable."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Host appserver01.corp.example.com is DOWN."@en ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/alarm> .

noria:EventRecord_NetworkInterfaceFlap a noria:EventRecord ;
    rdfs:label "CoreRouter01 Interface Flap"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 flapped (went down and up)."@en ;
    noria:loggingTime "2024-04-23T09:55:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet 0/0/0 changed state to down, then to up."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    dcterms:type <kos/Notification/EventType/stateChange> .

noria:EventRecord_DBConnectionError a noria:EventRecord ;
    rdfs:label "DBServer01 Connection Error"@en ;
    rdfs:comment "Log entry indicating a database connection error on DBServer01."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "Database connection pool exhausted on dbserver01."@en ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/alarm> .

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TroubleTicket_AppOutage_001 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Outage - AppServer01 Down"@en ;
    rdfs:comment "Critical incident: Customer Portal is completely down due to AppServer01 being unreachable."@en ;
    dcterms:identifier "TT-20240423-001" ;
    noria:documentExternalId "INC-12345" ;
    noria:documentHRef <http://itsm.example.com/tickets/TT-20240423-001> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Incident> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/MonitoringSystem> ;
    noria:troubleTicketTrigger noria:EventRecord_AppServerDown ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServerFailure> ;
    noria:troubleTicketCause "Application server unresponsive, likely hardware failure or OS crash."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ; # Example, could be IT Operations
    noria:troubleTicketDetectionDateTime "2024-04-23T10:00:05Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Agent_IT_Operations, noria:Agent_App_Support ;
    noria:troubleTicketRelatedService noria:ApplicationModule_CustomerPortal_Prod ;
    noria:troubleTicketRelatedResource noria:Resource_AppServer01 ;
    noria:troubleTicketImpacts noria:Application_CustomerPortal, noria:Resource_AppServer01 .

noria:TroubleTicket_NetworkIssue_002 a noria:TroubleTicket ;
    rdfs:label "Intermittent Network Connectivity"@en ;
    rdfs:comment "Users reporting intermittent connectivity issues, correlated with router interface flaps."@en ;
    dcterms:identifier "TT-20240423-002" ;
    noria:documentExternalId "INC-12346" ;
    noria:documentHRef <http://itsm.example.com/tickets/TT-20240423-002> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Incident> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_NetworkInterfaceFlap ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Zabbix" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ;
    noria:troubleTicketCause "Suspected faulty transceiver on Core Router 01."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T09:58:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Agent_Network_Team ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRouter01 ;
    noria:troubleTicketImpacts noria:Service_InternetAccess, noria:Resource_CoreRouter01 .

# =============================================================================
# Trouble Ticket Notes
# =============================================================================

noria:TroubleTicketNote_TT001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT-001"@en ;
    rdfs:comment "Performed basic connectivity checks (ping, SSH) to AppServer01, no response. Escalated to L2."@en ;
    dcterms:created "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_IT_Operations ;
    dcterms:isPartOf noria:TroubleTicket_AppOutage_001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote_TT001_Note2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Attempt for TT-001"@en ;
    rdfs:comment "Attempted remote power cycle of AppServer01. Server came back online. Monitoring for stability."@en ;
    dcterms:created "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_IT_Operations ;
    dcterms:isPartOf noria:TroubleTicket_AppOutage_001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> .

noria:TroubleTicketNote_TT002_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Interface Status Check for TT-002"@en ;
    rdfs:comment "Checked interface status on CoreRouter01, observed intermittent link up/down events on Gi0/0/0. Suspect hardware issue."@en ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_Network_Team ;
    dcterms:isPartOf noria:TroubleTicket_NetworkIssue_002 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

