# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OperationPlan_RouterOSUpgrade a noria:OperationPlan ;
    rdfs:label "Standard Router OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for performing a safe OS upgrade on Juniper MX series routers."@en ;
    skos:example "1. Backup configuration. 2. Copy new OS image. 3. Verify image. 4. Reboot with new image. 5. Verify services."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_NetworkStable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterOnline .

noria:ActionPreCondition_NetworkStable a noria:ActionPreCondition ;
    rdfs:label "Network Stability Check"@en ;
    rdfs:comment "Verify that the network is stable and no active incidents are ongoing before starting the upgrade."@en .

noria:ActionPostCondition_RouterOnline a noria:ActionPostCondition ;
    rdfs:label "Router Online and Services Restored"@en ;
    rdfs:comment "Confirm router is online, all interfaces are up, and critical services are reachable after upgrade."@en .

noria:OperationPlan_ServerReboot a noria:OperationPlan ;
    rdfs:label "Standard Server Remote Reboot Procedure"@en ;
    rdfs:comment "Procedure for remotely rebooting a server via IPMI/iDRAC."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_ServerUnresponsive ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ServerPingable .

noria:ActionPreCondition_ServerUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Server Unresponsive"@en ;
    rdfs:comment "Server is not responding to ping or SSH."@en .

noria:ActionPostCondition_ServerPingable a noria:ActionPostCondition ;
    rdfs:label "Server Pingable"@en ;
    rdfs:comment "Server is responding to ping after reboot."@en .

# =============================================================================
# Anomaly Patterns
# =============================================================================

noria:AnomalyPattern_HighCPUUsage a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Usage"@en ;
    rdfs:comment "Anomaly pattern indicating a resource is experiencing prolonged high CPU utilization, potentially leading to performance degradation or crash."@en ;
    skos:example "CPU usage > 90% for more than 15 minutes."@en .

noria:AnomalyPattern_LinkFlap a noria:AnomalyPattern ;
    rdfs:label "Frequent Network Link Flapping"@en ;
    rdfs:comment "Anomaly pattern indicating a network link repeatedly goes down and up within a short period, suggesting instability."@en ;
    skos:example "Interface status changes from up to down and back to up more than 3 times in 5 minutes."@en .

# =============================================================================
# Interconnections and additional details
# =============================================================================

# Link EventRecord to TroubleTicket for status history
noria:TroubleTicket_AppOutage_001 noria:documentStatusHistory noria:EventRecord_AppServerDown .
noria:TroubleTicket_NetworkIssue_002 noria:documentStatusHistory noria:EventRecord_NetworkInterfaceFlap .

# Link ChangeRequest to OperationPlan
noria:ChangeRequest_RouterUpgrade_001 pep:usedProcedure noria:OperationPlan_RouterOSUpgrade .

# Link TroubleTicketNote to potential correlated execution (if any)
# For example, if a specific command was run as part of the diagnosis
# This would typically be an EventRecord representing the command execution
# For this example, we'll link it to a hypothetical EventRecord
noria:TroubleTicketNote_TT001_Note2 noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_AppServerRebootCommand .

noria:EventRecord_AppServerRebootCommand a noria:EventRecord ;
    rdfs:label "AppServer01 Remote Reboot Command"@en ;
    rdfs:comment "System log of the remote reboot command issued to AppServer01."@en ;
    noria:loggingTime "2024-04-23T11:25:00Z"^^xsd:dateTime ;
    noria:logText "Issued remote reboot command to appserver01 via iDRAC."@en ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingAgent noria:Agent_IT_Operations ;
    dcterms:type <kos/Notification/EventType/stateChange> .

# Link agents to resources they manage (inverse of resourceManagedBy)
noria:Agent_IT_Operations noria:agentManagesResource noria:Resource_AppServer01, noria:Resource_DBServer01 .
noria:Agent_Network_Team noria:agentManagesResource noria:Resource_CoreRouter01, noria:Resource_EdgeSwitch01, noria:NetworkLink_AppServer_Switch, noria:NetworkLink_WAN_Uplink, noria:NetworkLink_DBServer_Switch .
noria:Agent_App_Support noria:agentManagesResource noria:Application_CustomerPortal, noria:ApplicationModule_CustomerPortal_Prod, noria:ApplicationModule_CustomerPortal_Staging .

# Example of a virtual server status
noria:Resource_AppServer01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
noria:Resource_DBServer01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Example of network interface thresholds
noria:NetworkInterface_CoreRouter01_Gi0_0_0
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Example of a Corporate User Identifier
noria:CUid_Alice a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount noria:Employee_Alice .

noria:CUid_Bob a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount noria:Employee_Bob .

# Example of an application module support leader
noria:ApplicationModule_CustomerPortal_Prod noria:applicationModuleSupportLeader noria:Employee_Bob .
noria:ApplicationModule_CustomerPortal_Prod noria:applicationModuleAdministrationLeader noria:Employee_Bob .

# Example of a hotline group
noria:ApplicationModule_CustomerPortal_Prod noria:applicationModuleHotlineGroup noria:Agent_IT_Operations .

# Example of a problem category update (final category)
noria:TroubleTicket_AppOutage_001 noria:problemCategory <kos/TroubleTicket/trouble-category/ServerFailure> .
noria:TroubleTicket_NetworkIssue_002 noria:problemCategory <kos/TroubleTicket/trouble-category/NetworkOutage> .

# Example of a change request status update
noria:ChangeRequest_RouterUpgrade_001 noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> .
noria:ChangeRequest_RouterUpgrade_001 noria:changeRequestActualStartTime "2024-05-01T02:05:00Z"^^xsd:dateTime .
noria:ChangeRequest_RouterUpgrade_001 noria:changeRequestActualEndTime "2024-05-01T03:30:00Z"^^xsd:dateTime .
