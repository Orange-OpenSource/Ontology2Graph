# --- Operational Plans and Conditions ---
<https://w3id.org/noria/operationplan/DBRestartProcedure> a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the E-commerce database service."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/DBUnreachable> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/DBReachable> ;
.

<https://w3id.org/noria/actionprecondition/DBUnreachable> a noria:ActionPreCondition ;
    rdfs:label "Database Unreachable"@en ;
    rdfs:comment "Condition: Database service is not responding to connection attempts."@en ;
    skos:example "Ping to DB server fails, application cannot connect to database."@en ;
.

<https://w3id.org/noria/actionpostcondition/DBReachable> a noria:ActionPostCondition ;
    rdfs:label "Database Reachable"@en ;
    rdfs:comment "Outcome: Database service is responding and applications can connect successfully."@en ;
    skos:example "Ping to DB server succeeds, application connects to database, data integrity checks pass."@en ;
.

