    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all non-critical issues. For critical issues, use emergency hotline."@en ;
    noria:agentManagesResource <https://w3id.org/noria/resource/DBServer01>, <https://w3id.org/noria/resource/WebServer01> ;
    org:member <https://w3id.org/noria/agent/DBA_JohnDoe> ;
    org:member <https://w3id.org/noria/agent/NetworkEngineer_JaneSmith> ;
.

