# --- Dynamic Elements (Trouble Tickets, Events, Change Requests) ---
<https://w3id.org/noria/troubleticket/TT_DBOutage_20240423> a noria:TroubleTicket ;
    rdfs:label "Database Server Outage Incident - ECOMM_PROD"@en ;
    rdfs:label "Incident de Panne Serveur BD - ECOMM_PROD"@fr ;
    rdfs:comment "Critical incident affecting the E-commerce Platform due to database server unreachability."@en ;
    dcterms:identifier "TT-20240423-001" ;
    dcterms:created "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <https://w3id.org/noria/eventrecord/ER_DBMonitorAlert> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring System" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ; # Initial and final category are the same for this example
    noria:troubleTicketCause "Database service unresponsive, possibly due to resource exhaustion or network isolation."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ; # Assuming network issue
    noria:troubleTicketDetectionDateTime "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <https://w3id.org/noria/agent/NOC>, <https://w3id.org/noria/agent/DBA_JohnDoe>, <https://w3id.org/noria/agent/NetworkEngineer_JaneSmith> ;
    noria:troubleTicketRelatedService <https://w3id.org/noria/application/ECommercePlatform> ;
    noria:troubleTicketRelatedResource <https://w3id.org/noria/resource/DBServer01> ;
