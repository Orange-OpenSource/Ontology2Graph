# --- Event Records ---
noria:EventRecord_DBDownAlert
    a noria:EventRecord ;
    rdfs:label "Database Server Down Alert"@en ;
    rdfs:comment "Automated alert indicating that the production database server is unreachable."@en ;
    noria:loggingTime "2024-04-23T14:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host db01.prod.example.com is DOWN - PING CRITICAL."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_InterfaceDownLog
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "Log entry from Core Router 01 indicating an interface went down."@en ;
    noria:loggingTime "2024-04-23T14:29:50Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_SyslogServer ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DBRestartLog
    a noria:EventRecord ;
    rdfs:label "Database Service Restart Log"@en ;
