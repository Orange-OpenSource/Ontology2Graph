# --- Anomaly Patterns ---
noria:AnomalyPattern_DBMemoryLeak
    a noria:AnomalyPattern ;
    rdfs:label "Database Memory Leak Pattern"@en ;
    rdfs:comment "Pattern describing symptoms of the database memory leak: high CPU, increasing memory usage, eventual service crash."@en ;
    skos:example "High CPU usage followed by OOM killer events and service restart."@en ;
    folio:hasCause noria:TroubleTicket_DBOutage .

# --- Operation Plans and Conditions ---
noria:OperationPlan_DBRestart
    a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the PostgreSQL database service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBServiceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBServiceUp .

noria:ActionPreCondition_DBServiceDown
    a noria:ActionPreCondition ;
    rdfs:label "Database Service is Down"@en ;
    rdfs:comment "Condition: The PostgreSQL service on the database server is not running or unresponsive."@en .

noria:ActionPostCondition_DBServiceUp
    a noria:ActionPostCondition ;
    rdfs:label "Database Service is Up and Accessible"@en ;
    rdfs:comment "Outcome: The PostgreSQL service is running, accepting connections, and application can access it."@en .

noria:OperationPlan_DBPatchProcedure
    a noria:OperationPlan ;
    rdfs:label "Database Patch Deployment Procedure"@en ;
    rdfs:comment "Step-by-step guide for deploying the critical database patch."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBServiceUp ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBServiceUp .
