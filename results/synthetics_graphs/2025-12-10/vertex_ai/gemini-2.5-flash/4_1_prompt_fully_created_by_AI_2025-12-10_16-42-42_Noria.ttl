# --- Trouble Tickets ---
noria:TroubleTicket_DBOutage
    a noria:TroubleTicket ;
    rdfs:label "Critical DB Server Outage for E-commerce"@en ;
    rdfs:comment "Incident reported due to production database server being unreachable, impacting E-commerce platform."@en ;
    noria:documentExternalId "TT-20240423-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-20240423-001" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DBDownAlert ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Database service crashed due to resource exhaustion."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T14:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T16:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T15:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T17:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_DB_Admin_Team, foaf:Agent_IT_Ops_Team, foaf:Agent_John_Doe, foaf:Agent_Jane_Smith ;
    noria:troubleTicketRelatedService noria:ApplicationModule_ECommerceProd ;
    noria:troubleTicketRelatedResource noria:Resource_DBServer01 ;
    noria:troubleTicketImpacts noria:Application_ECommercePlatform, noria:Resource_DBServer01, noria:Service_CustomerFacingWeb ;
    noria:documentStatusHistory noria:EventRecord_TT_StatusChange_InProgress, noria:EventRecord_TT_StatusChange_Resolved .

noria:TroubleTicket_WebPerformance
    a noria:TroubleTicket ;
    rdfs:label "E-commerce Web Performance Degradation"@en ;
    rdfs:comment "Customers reporting slow response times on the E-commerce platform."@en ;
    noria:documentExternalId "TT-20240424-002" ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-20240424-002" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_WebServerCPUHigh ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:troubleTicketDetectionDateTime "2024-04-24T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-24T18:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_IT_Ops_Team, org:OrganizationalUnit_CustomerSupport, foaf:Agent_Alice_Brown ;
    noria:troubleTicketRelatedService noria:ApplicationModule_ECommerceProd ;
    noria:troubleTicketImpacts noria:Resource_WebServer01, noria:Resource_LoadBalancer01 .

# --- Trouble Ticket Notes ---
noria:TroubleTicketNote_DBOutage_Initial
    a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for DB Outage"@en ;
    rdfs:comment "Initial assessment: Database service unresponsive. Attempting restart."@en ;
    dcterms:isPartOf noria:TroubleTicket_DBOutage ;
