    noria:resourceForApplication noria:Application_ECommercePlatform ;
    noria:locatedAtLocus noria:Locus_RackA1_U20 ;
    noria:resourceManagementIPAddress "192.168.10.20" ;
    seas:dependsOn noria:Resource_DBServer01 .

noria:Resource_RouterCore01
    a noria:Resource ;
