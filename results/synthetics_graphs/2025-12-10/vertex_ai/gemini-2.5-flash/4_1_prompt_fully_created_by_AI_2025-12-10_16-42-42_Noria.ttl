# --- Network Interfaces ---
noria:NetworkInterface_DBServer01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "db01-eth0"@en ;
    rdfs:comment "Ethernet interface for DBServer01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_RouterCore01_Gi0_1
    a noria:NetworkInterface ;
    rdfs:label "router01-Gi0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface on RouterCore01, connected to DB server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -5 ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_LoadBalancer01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "lb01-eth0"@en ;
    rdfs:comment "Ethernet interface for LoadBalancer01."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links ---
noria:NetworkLink_DB_Router
    a noria:NetworkLink ;
    rdfs:label "Link DBServer01 to RouterCore01"@en ;
    rdfs:comment "Physical link between the database server and the core router."@en ;
    noria:networkLinkId "NL-DB-RTR-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-15T12:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DBServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore01 ;
    noria:resourceManagedBy foaf:Agent_Network_Team .

noria:NetworkInterface_DBServer01_Eth0 noria:networkInterfaceConnects noria:NetworkLink_DB_Router .
noria:NetworkInterface_RouterCore01_Gi0_1 noria:networkInterfaceConnects noria:NetworkLink_DB_Router .

