# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents and Organizations ---
foaf:Agent_IT_Ops_Team
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for general IT infrastructure operations and first-level support."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for non-urgent issues, hotline for critical incidents."@en .

foaf:Agent_DB_Admin_Team
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Specialized team managing all database systems."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Escalate critical database issues directly to on-call DBA."@en .

foaf:Agent_Network_Team
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For network outages, use the dedicated network hotline."@en .

foaf:Agent_John_Doe
    a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer in the IT Operations Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:member foaf:Agent_IT_Ops_Team .

foaf:Agent_Jane_Smith
    a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Database Administrator."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:member foaf:Agent_DB_Admin_Team .

org:OrganizationalUnit_CustomerSupport
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Support Department"@en ;
    rdfs:comment "First line of contact for customer issues."@en .

foaf:Agent_Alice_Brown
    a foaf:Agent, foaf:Person ;
    rdfs:label "Alice Brown"@en ;
    rdfs:comment "Customer Support Representative."@en ;
    foaf:mbox <mailto:alice.brown@example.com> ;
    foaf:member org:OrganizationalUnit_CustomerSupport .

org:Organization_OurCompany
    a org:Organization ;
    rdfs:label "Example Corp"@en ;
    rdfs:comment "The main company operating the IT infrastructure."@en .

org:Organization_ServerVendor
    a org:Organization ;
    rdfs:label "ServerTech Inc."@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

# --- Location ---
