    rdfs:comment "A dedicated room within the Main Data Center housing critical servers."@en ;
    bot:hasSpace bot:Site_MainDataCenter .

noria:Locus_RackA1_U20
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 20"@en ;
    rdfs:comment "Specific location within Server Room A for a server rack and unit."@en ;
