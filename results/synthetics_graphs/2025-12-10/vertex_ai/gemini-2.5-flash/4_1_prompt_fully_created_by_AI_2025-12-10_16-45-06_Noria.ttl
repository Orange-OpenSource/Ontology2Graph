    noria:changeRequestImpact noria:Resource_Firewall_DMZ ;
    noria:changeRequestInitiatorParty org:OrgUnit_SecurityTeam ;
    noria:changeRequestPilotParty org:OrgUnit_SecurityTeam ;
    noria:changeRequestActorParty org:OrgUnit_SecurityTeam ;
    noria:changeRequestOutageDuration "PT0S"^^xsd:duration ; # No outage expected
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef "https://itsm.example.com/change/CR002" .

### Procedural Elements ###

noria:OperationPlan_FiberRepair a noria:OperationPlan ;
    rdfs:label "Fiber Optic Repair Procedure"@en ;
    rdfs:comment "Standard operating procedure for repairing damaged fiber optic cables."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FiberDamageConfirmed ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LinkRestored .

noria:ActionPreCondition_FiberDamageConfirmed a noria:ActionPreCondition ;
    rdfs:label "Fiber Damage Confirmed"@en ;
    rdfs:comment "Pre-condition: Optical Time-Domain Reflectometer (OTDR) test confirms physical fiber damage."@en .

noria:ActionPostCondition_LinkRestored a noria:ActionPostCondition ;
    rdfs:label "Network Link Restored"@en ;
    rdfs:comment "Post-condition: Network link operational status is 'up' and traffic flows normally."@en .

noria:OperationPlan_DB_Patching a noria:OperationPlan ;
    rdfs:label "Database Patching Procedure"@en ;
    rdfs:comment "Procedure for applying security patches and updates to database servers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_BackupCompleted ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DB_Operational .

noria:ActionPreCondition_BackupCompleted a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completed"@en ;
    rdfs:comment "Pre-condition: A full backup of the database has been successfully completed."@en .

noria:ActionPostCondition_DB_Operational a noria:ActionPostCondition ;
    rdfs:label "Database Operational and Verified"@en ;
    rdfs:comment "Post-condition: Database service is running, accessible, and data integrity checks are passed."@en .

# Connecting EventRecord to OperationPlan (as proposed repair action)
noria:EventRecord_CR_Paris_Link_Down noria:alarmProposedRepairAction noria:OperationPlan_FiberRepair .

# Connecting ChangeRequest to OperationPlan (as specification)
noria:ChangeRequest_CR001_DB_Upgrade noria:changeRequestSpecification <kos/ChangeRequest/specification/DatabaseUpgradeStandardProcedure> .
noria:ChangeRequest_CR002_Firewall_Rule_Update noria:changeRequestSpecification <kos/ChangeRequest/specification/FirewallRuleUpdateStandardProcedure> .

# Example of a Corporate User Identifier (CUid)
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

# Example of an EventRecord mitigating an alarm (e.g., a configuration change that fixed an issue)
noria:EventRecord_CR_Paris_Link_Restored a noria:EventRecord ;
    rdfs:label "Core Router Paris Uplink Restored"@en ;
    rdfs:comment "Event indicating the uplink interface of Core Router Paris is back up after repair."@en ;
    noria:loggingTime "2024-04-23T11:50:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to up."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter_Paris ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# This EventRecord (restoration) is part of a ProcedureExecutionContainer that mitigated the initial alarm.
# For simplicity, we'll link the original TT to this restoration event directly, implying the TT's resolution.
# In a more complex scenario, a pep:ProcedureExecutionContainer would group multiple events.
noria:TroubleTicket_TT001_UplinkOutage noria:documentStatusHistory noria:EventRecord_CR_Paris_Link_Restored .
noria:EventRecord_CR_Paris_Link_Down noria:alarmMitigatedBy noria:TroubleTicket_TT001_UplinkOutage . # The TT itself acts as the container for the mitigation process.

# Example of DocumentAttachment
noria:DocumentAttachment_TT001_Diagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for TT001"@en ;
    rdfs:comment "Attached network diagram showing the affected uplink for TT001."@en ;
    dcterms:isPartOf noria:TroubleTicket_TT001_UplinkOutage ;
    dcterms:format "image/png" ;
    dcterms:identifier "diagram-TT001.png" .

noria:DocumentAttachment_CR001_Plan a noria:DocumentAttachment ;
    rdfs:label "CR001 Implementation Plan"@en ;
    rdfs:comment "Detailed plan for the database software upgrade."@en ;
    dcterms:isPartOf noria:ChangeRequest_CR001_DB_Upgrade ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "CR001-Impl-Plan.pdf" .

