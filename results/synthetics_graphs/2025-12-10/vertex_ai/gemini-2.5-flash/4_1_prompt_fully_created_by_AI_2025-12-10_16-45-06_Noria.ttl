### Resources for Applications ###

noria:Resource_WebSrv01 noria:resourceForApplication noria:Application_CustomerPortal .
noria:Resource_DB_Srv01 noria:resourceForApplication noria:Application_CustomerPortal .
noria:Resource_CoreRouter_Paris noria:resourceForApplication noria:Application_MonitoringSystem .
noria:Resource_Firewall_DMZ noria:resourceForApplication noria:Application_MonitoringSystem .

### Services ###

noria:Service_CustomerFacingWeb a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "End-to-end service providing web access to customers, including portal and underlying infrastructure."@en ;
    rdfs:label "Service Web Client"@fr ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule_CustomerPortal_Prod . # Example of how ApplicationModule can be part of a Service

noria:Service_InternalMonitoring a noria:Service ;
    rdfs:label "Internal Infrastructure Monitoring Service"@en ;
    rdfs:comment "Service providing real-time monitoring and alerting for internal IT infrastructure."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:ApplicationModule_MonitoringSystem_Main .

### Event Records ###

noria:EventRecord_WebSrv01_CPU_High a noria:EventRecord ;
    rdfs:label "WebSrv01 High CPU Alert"@en ;
    rdfs:comment "Alert triggered by monitoring system due to high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on websrv01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DB_Srv01_Disk_Full a noria:EventRecord ;
    rdfs:label "DBSrv01 Disk Full Warning"@en ;
    rdfs:comment "Warning from monitoring system: database server disk space is critically low."@en ;
    noria:loggingTime "2024-04-23T09:30:00Z"^^xsd:dateTime ;
    noria:logText "Disk usage on /var/lib/mysql on dbsrv01.corp.example.com is 95%."@en ;
    noria:logOriginatingManagedObject noria:Resource_DB_Srv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_CR_Paris_Link_Down a noria:EventRecord ;
    rdfs:label "Core Router Paris Uplink Down"@en ;
    rdfs:comment "Critical event: Uplink interface of Core Router Paris went down."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter_Paris ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_User_Login_Failure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt Customer Portal"@en ;
    rdfs:comment "Multiple failed login attempts detected on the Customer Portal."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logText "User 'baduser' failed to log in 5 times from IP 203.0.113.42."@en ;
    noria:logOriginatingManagedObject noria:Application_CustomerPortal ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord_Admin_Config_Change a noria:EventRecord ;
    rdfs:label "Admin Configuration Change on Firewall"@en ;
    rdfs:comment "Log entry for a configuration change performed by an administrator on the DMZ Firewall."@en ;
    noria:loggingTime "2024-04-22T15:30:00Z"^^xsd:dateTime ;
    noria:logText "Configuration changed by admin_user from 192.168.1.100. Rule 'Block_Malware' updated."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_DMZ ;
    noria:logOriginatingAgent foaf:Agent_NetworkAdmin ; # Assuming NetworkAdmin is the agent who made the change
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

### Trouble Tickets ###

noria:TroubleTicket_TT001_UplinkOutage a noria:TroubleTicket ;
