### Network Links ###

noria:NetworkLink_Uplink_CR_ISP a noria:NetworkLink ;
    rdfs:label "Uplink Core Router Paris to ISP"@en ;
    rdfs:comment "High-speed fiber link connecting the Paris Core Router to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-UPLINK-PAR-ISP" ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter_Paris ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR_Paris_Gi0_0_0 ;
    noria:networkLinkInstallationDate "2022-04-28T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "fiber optic" ;
    noria:resourceManagedBy foaf:Agent_NetworkAdmin .

noria:NetworkLink_FW_CR_Internal a noria:NetworkLink ;
    rdfs:label "Firewall to Core Router Internal Link"@en ;
    rdfs:comment "Internal link between DMZ Firewall and Core Router Paris."@en ;
    noria:networkLinkId "NL-FW-CR-INT" ;
    noria:networkLinkTerminationResource noria:Resource_Firewall_DMZ, noria:Resource_CoreRouter_Paris ;
    noria:networkInterfaceConnects noria:NetworkInterface_FW_DMZ_Eth1, noria:NetworkInterface_CR_Paris_Gi0_0_1 ;
    noria:networkLinkInstallationDate "2022-06-01T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "ethernet" ;
    noria:resourceManagedBy foaf:Agent_NetworkAdmin .

noria:NetworkLink_WebSrv_FW_DMZ a noria:NetworkLink ;
    rdfs:label "Web Server to DMZ Firewall Link"@en ;
    rdfs:comment "Link between Web Server 01 and the DMZ Firewall."@en ;
    noria:networkLinkId "NL-WEB-FW-DMZ" ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv01, noria:Resource_Firewall_DMZ ;
    noria:networkInterfaceConnects noria:NetworkInterface_WebSrv01_Eth0, noria:NetworkInterface_FW_DMZ_Eth1 ;
    noria:networkLinkInstallationDate "2023-01-15T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "ethernet" ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam .

noria:NetworkLink_DB_WebSrv a noria:NetworkLink ;
    rdfs:label "Database Server to Web Server Link"@en ;
    rdfs:comment "Internal link between Database Server 01 and Web Server 01."@en ;
    noria:networkLinkId "NL-DB-WEB" ;
    noria:networkLinkTerminationResource noria:Resource_DB_Srv01, noria:Resource_WebSrv01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_DB_Srv01_Eth0, noria:NetworkInterface_WebSrv01_Eth0 ; # Assuming WebSrv01 has multiple interfaces or a logical connection
    noria:networkLinkInstallationDate "2023-01-15T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "ethernet" ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam .

### Applications ###

noria:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "Web application allowing customers to manage their accounts and services."@en ;
    rdfs:label "Application Portail Client"@fr ;
    noria:applicationModelIdentifier "CP-V2.0" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CUSTPORT" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Self-Service" .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Infrastructure Monitoring System"@en ;
    rdfs:comment "System for monitoring the health and performance of IT infrastructure."@en ;
    rdfs:label "Système de Supervision d'Infrastructure"@fr ;
    noria:applicationModelIdentifier "MON-V3.1" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "INFRAMON" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance Monitoring" .

noria:Application_TicketingSystem a noria:Application ;
    rdfs:label "ITSM Ticketing System"@en ;
    rdfs:comment "System used for managing incidents, problems, and changes."@en ;
    rdfs:label "Système de Ticketing ITSM"@fr ;
