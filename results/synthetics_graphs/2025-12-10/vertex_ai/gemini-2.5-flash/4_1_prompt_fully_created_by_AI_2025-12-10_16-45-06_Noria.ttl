### Change Requests ###

noria:ChangeRequest_CR001_DB_Upgrade a noria:ChangeRequest ;
    rdfs:label "Database Software Upgrade for Customer Portal"@en ;
    rdfs:comment "Planned upgrade of the database software for performance and security enhancements."@en ;
    noria:changeRequestPlannedStartTime "2024-05-10T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-11T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_DB_Srv01, noria:Application_CustomerPortal ;
    noria:changeRequestInitiatorParty foaf:Agent_AppDevTeam ;
    noria:changeRequestPilotParty foaf:Agent_JohnDoe ;
    noria:changeRequestActorParty foaf:Agent_ITOpsTeam ;
    noria:changeRequestOutageDuration "PT4H"^^xsd:duration ; # 4 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef "https://itsm.example.com/change/CR001" .

noria:ChangeRequest_CR002_Firewall_Rule_Update a noria:ChangeRequest ;
    rdfs:label "Firewall Rule Update for New Service"@en ;
