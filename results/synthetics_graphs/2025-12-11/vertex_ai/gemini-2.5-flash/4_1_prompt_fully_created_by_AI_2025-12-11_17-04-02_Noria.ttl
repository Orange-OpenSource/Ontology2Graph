# --- Operation Plans ---
<https://w3id.org/noria/operationplan/DBRestartProcedure>
    a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the PostgreSQL database service."@en ;
    skos:example "Steps: 1. Check database logs. 2. Attempt graceful restart. 3. Force restart if necessary. 4. Verify service availability."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/DBUnreachable> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/DBAccessible> ;
    .

<https://w3id.org/noria/actionprecondition/DBUnreachable>
    a noria:ActionPreCondition ;
    rdfs:label "Database Unreachable Pre-Condition"@en ;
    rdfs:comment "Condition: Database server is not responding to network requests or application queries."@en ;
    skos:example "Ping to DB server fails, application logs show connection errors."@en ;
    .

<https://w3id.org/noria/actionpostcondition/DBAccessible>
    a noria:ActionPostCondition ;
    rdfs:label "Database Accessible Post-Condition"@en ;
    rdfs:comment "Condition: Database server is responding to network requests and application queries, and service is restored."@en ;
    skos:example "Ping to DB server succeeds, application can connect to database, E-commerce platform is functional."@en ;
    .

