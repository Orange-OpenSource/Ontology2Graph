# --- Trouble Ticket Notes ---
<https://w3id.org/noria/troubleticketnote/DBOutage_TT001_Note1>
    a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for TT-20240423-001"@en ;
    rdfs:comment "First note on the database outage incident."@en ;
    dcterms:created "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator <https://w3id.org/noria/agent/John_Doe> ;
