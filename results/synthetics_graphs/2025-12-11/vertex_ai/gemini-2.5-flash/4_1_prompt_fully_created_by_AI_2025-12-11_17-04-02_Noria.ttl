    dcterms:created "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:documentHRef "https://ticketing.example.com/TT-20240423-001" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <https://w3id.org/noria/event/DBDownAlert_20240423_1000> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DatabaseUnreachable> ;
    noria:troubleTicketCause "Database service crashed due to unknown error."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedApplication> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <https://w3id.org/noria/agent/DB_Admin_Team> ;
