    noria:changeRequestActorParty noria:NOC_Team ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef "https://itsm.example.com/change/CR-2024-002" .

# =============================================================================
# Procedural Elements (Operation Plans, Pre/Post Conditions)
# =============================================================================

noria:RestartWebServerProcedure a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and restarting the web server service in case of performance issues."@en ;
    skos:example "Steps: 1. SSH to server. 2. Check process status. 3. Stop Apache/Nginx service. 4. Verify service stopped. 5. Start Apache/Nginx service. 6. Verify service started and accessible."@en ;
    noria:operationPlanPreCondition noria:WebServerPerformanceDegradation ;
    noria:operationPlanPostCondition noria:WebServerPerformanceRestored .

noria:NetworkTroubleshootingPlan a noria:OperationPlan ;
    rdfs:label "Network Troubleshooting Plan"@en ;
    rdfs:comment "Standard procedure for diagnosing and resolving network connectivity issues, including physical and logical checks."@en ;
    skos:example "Steps: 1. Check interface status. 2. Verify cabling. 3. Test connectivity (ping/traceroute). 4. Review routing tables. 5. Consult network diagrams."@en ;
    noria:operationPlanPreCondition noria:NetworkConnectivityIssueDetected ;
    noria:operationPlanPostCondition noria:NetworkConnectivityRestored .

noria:WebServerPerformanceDegradation a noria:ActionPreCondition ;
    rdfs:label "Web Server Performance Degradation Detected"@en ;
    rdfs:comment "Pre-condition: An event indicating high CPU, memory, or slow response times on a web server has been detected."@en ;
    skos:example "High CPU alert, slow page load times, service unresponsiveness."@en .

noria:WebServerPerformanceRestored a noria:ActionPostCondition ;
    rdfs:label "Web Server Performance Restored"@en ;
    rdfs:comment "Post-condition: Web server performance metrics have returned to normal levels, and service is responsive."@en ;
    skos:example "CPU utilization below threshold, fast page load times, successful health checks."@en .

noria:NetworkConnectivityIssueDetected a noria:ActionPreCondition ;
    rdfs:label "Network Connectivity Issue Detected"@en ;
    rdfs:comment "Pre-condition: An event indicating loss of network connectivity or degraded link status has been detected."@en ;
    skos:example "Interface down alert, unreachable host, high packet loss, BGP peer down."@en .

noria:NetworkConnectivityRestored a noria:ActionPostCondition ;
    rdfs:label "Network Connectivity Restored"@en ;
    rdfs:comment "Post-condition: Network connectivity has been successfully restored and verified end-to-end."@en ;
    skos:example "Interface up, host reachable, no packet loss, BGP peer up."@en .

