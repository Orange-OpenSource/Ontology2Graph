# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix org: <http://www.w3.org/ns/org#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix bot:  <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (Teams and Individuals)
# =============================================================================

noria:NOC_Team a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Center Team"@en ;
    rdfs:label "Équipe du Centre d'Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for 24/7 network monitoring and initial incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Contact via dedicated hotline for critical incidents."@en ;
    noria:agentManagesResource noria:CoreRouter01, noria:Firewall01, noria:LinkCR1_CR2 .

noria:AppSupportTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe de Support Applicatif"@fr ;
    rdfs:comment "Team responsible for maintaining and supporting business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all issues."@en ;
    noria:agentManagesResource noria:CustomerPortalApp, noria:InternalCRMApp, noria:WebSrv01, noria:DbSrv01 .

noria:JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:label "Jean Dupont"@fr ;
    rdfs:comment "Lead Network Engineer in the NOC Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "For urgent matters, call his mobile."@en ;
    noria:agentManagesResource noria:CoreRouter01 .

noria:JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:label "Jeanne Martin"@fr ;
    rdfs:comment "Senior Application Developer, part of the App Support Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentManagesResource noria:CustomerPortalProdModule .

noria:ExternalUser a foaf:Agent ;
    rdfs:label "External User"@en ;
    rdfs:comment "Represents an external user attempting to log in to an application."@en .

noria:CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of network hardware."@en .

noria:DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

noria:PaloAltoNetworks a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "Manufacturer of cybersecurity products."@en .

# =============================================================================
# Locations
# =============================================================================

noria:ParisDataCenter a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    rdfs:comment "Main data center located in Paris, hosting critical IT infrastructure."@en ;
    noria:siteId "PDC01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    bot:hasSpace noria:ServerRoom101 .

noria:ServerRoom101 a noria:Room ;
    rdfs:label "Server Room 101"@en ;
    rdfs:label "Salle Serveurs 101"@fr ;
    rdfs:comment "A dedicated room within the Paris Data Center for critical servers and network equipment."@en ;
    bot:hasSpace noria:RackA5Locus, noria:RackB2Locus .

noria:RackA5Locus a noria:Locus ;
    rdfs:label "Rack A5, Position 1"@en ;
    rdfs:comment "Specific location within Server Room 101 for rack A5, position 1, typically for network devices."@en ;
    noria:locusLine "A5" ;
    noria:locusRow "1" .

noria:RackB2Locus a noria:Locus ;
    rdfs:label "Rack B2, Position 3"@en ;
    rdfs:comment "Specific location within Server Room 101 for rack B2, position 3, typically for application servers."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "3" .

# =============================================================================
# Product Models
# =============================================================================

noria:CiscoCatalyst9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch/router model, commonly used in core networks."@en ;
    noria:productManufacturedBy noria:CiscoSystems .

noria:DellPowerEdgeR650 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R650"@en ;
    rdfs:comment "High-performance rack server model, suitable for demanding applications and databases."@en ;
    noria:productManufacturedBy noria:DellTechnologies .

noria:PaloAltoFirewall a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220"@en ;
    rdfs:comment "Next-generation firewall appliance for advanced threat prevention."@en ;
    noria:productManufacturedBy noria:PaloAltoNetworks .

# =============================================================================
# Resources
# =============================================================================

noria:CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Primary core router for the corporate network, handling inter-VLAN routing and external connectivity."@en ;
    noria:resourceManagedBy noria:NOC_Team ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceProductModel noria:CiscoCatalyst9300 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "CR01-SN-X12345" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:RackA5Locus ;
    noria:resourceManagementIPAddress "10.0.0.1" ;
    noria:resourceForApplication noria:CorporateNetworkService .

noria:CoreRouter02 a noria:Resource ;
    rdfs:label "Core Router 02"@en ;
    rdfs:label "Routeur Cœur 02"@fr ;
    rdfs:comment "Secondary core router for redundancy and load balancing in the corporate network."@en ;
    noria:resourceManagedBy noria:NOC_Team ;
    noria:resourceHostName "cr02.corp.example.com" ;
    noria:resourceProductModel noria:CiscoCatalyst9300 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "CR02-SN-X54321" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:RackA5Locus ;
    noria:resourceManagementIPAddress "10.0.0.2" ;
    noria:resourceForApplication noria:CorporateNetworkService .

noria:WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:label "Serveur Web 01"@fr ;
    rdfs:comment "Server hosting the main customer portal application, part of the DMZ."@en ;
    noria:resourceManagedBy noria:AppSupportTeam ;
    noria:resourceHostName "web01.portal.example.com" ;
    noria:resourceProductModel noria:DellPowerEdgeR650 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "WS01-SN-Y67890" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:RackB2Locus ;
    noria:resourceManagementIPAddress "172.16.1.10" ;
    noria:resourceForApplication noria:CustomerPortalApp .

noria:DbSrv01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:label "Serveur Base de Données 01"@fr ;
    rdfs:comment "Database server for the internal CRM application, hosting critical customer data."@en ;
    noria:resourceManagedBy noria:AppSupportTeam ;
    noria:resourceHostName "db01.crm.example.com" ;
    noria:resourceProductModel noria:DellPowerEdgeR650 ;
    noria:resourceType <kos/Resource/type/database_server> ;
    noria:resourceSerialNumber "DB01-SN-Z11223" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:RackB2Locus ;
    noria:resourceManagementIPAddress "172.16.2.20" ;
    noria:resourceForApplication noria:InternalCRMApp .

noria:Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:label "Pare-feu Périmétrique 01"@fr ;
    rdfs:comment "Main firewall protecting the corporate network perimeter from external threats."@en ;
    noria:resourceManagedBy noria:NOC_Team ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:PaloAltoFirewall ;
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceSerialNumber "FW01-SN-P54321" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-05-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:RackA5Locus ;
    noria:resourceManagementIPAddress "10.0.0.254" ;
    noria:resourceForApplication noria:CorporateNetworkService .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:CR01_Gi0_1 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 - GigabitEthernet0/1"@en ;
    rdfs:comment "Interface Gi0/1 on Core Router 01, serving as an uplink to Core Router 02."@en ;
    noria:networkInterfaceOf noria:CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to Core Router 02" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects noria:LinkCR1_CR2 .

noria:CR01_Gi0_2 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 - GigabitEthernet0/2"@en ;
    rdfs:comment "Interface Gi0/2 on Core Router 01, connected to Perimeter Firewall 01."@en ;
    noria:networkInterfaceOf noria:CoreRouter01 ;
    noria:networkInterfaceDescription "Link to Perimeter Firewall 01" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects noria:LinkCR1_FW1 .

noria:WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Web Server 01 - Ethernet0"@en ;
    rdfs:comment "Main network interface for Web Server 01, connecting to the application VLAN."@en ;
    noria:networkInterfaceOf noria:WebSrv01 ;
    noria:networkInterfaceDescription "Primary network interface for web traffic" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:DbSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Database Server 01 - Ethernet0"@en ;
    rdfs:comment "Main network interface for Database Server 01, connecting to the database VLAN."@en ;
    noria:networkInterfaceOf noria:DbSrv01 ;
    noria:networkInterfaceDescription "Primary network interface for database traffic" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:FW01_Eth1 a noria:NetworkInterface ;
    rdfs:label "Firewall 01 - Ethernet1"@en ;
    rdfs:comment "Interface Eth1 on Firewall 01, connected to Core Router 01 for internal network traffic."@en ;
    noria:networkInterfaceOf noria:Firewall01 ;
    noria:networkInterfaceDescription "Internal link to Core Router 01" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects noria:LinkCR1_FW1 .

# =============================================================================
# Network Links
# =============================================================================

noria:LinkCR1_CR2 a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to Core Router 02"@en ;
    rdfs:comment "High-speed fiber link providing redundant connectivity between Core Router 01 and Core Router 02."@en ;
    noria:networkLinkId "LINK-CR1-CR2-001" ;
    noria:networkLinkTerminationResource noria:CoreRouter01, noria:CoreRouter02 ;
    noria:networkLinkInstallationDate "2021-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 10Gbps" ;
    noria:resourceManagedBy noria:NOC_Team .

noria:LinkCR1_FW1 a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to Firewall 01"@en ;
    rdfs:comment "Internal network link connecting Core Router 01 to Perimeter Firewall 01 for traffic filtering."@en ;
    noria:networkLinkId "LINK-CR1-FW1-001" ;
    noria:networkLinkTerminationResource noria:CoreRouter01, noria:Firewall01 ;
    noria:networkLinkInstallationDate "2021-05-10T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:resourceManagedBy noria:NOC_Team .

# =============================================================================
# Applications
# =============================================================================

noria:CustomerPortalApp a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:label "Application Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their accounts, view services, and submit support requests."@en ;
    noria:applicationModelIdentifier "CP-V2.0" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CUSTPORTAL" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Online Account Management"@en .

noria:InternalCRMApp a noria:Application ;
    rdfs:label "Internal CRM Application"@en ;
    rdfs:label "Application CRM Interne"@fr ;
    rdfs:comment "Application used by internal sales and support teams for customer relationship management and data tracking."@en ;
    noria:applicationModelIdentifier "CRM-V3.1" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "INTCRM" ;
    noria:applicationType <kos/application/type/internal-business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Sales and Marketing"@en ;
    noria:applicationFunctionalSubDomain "Customer Data Management"@en .

noria:CorporateNetworkService a noria:Application ;
    rdfs:label "Corporate Network Infrastructure"@en ;
    rdfs:comment "Underlying network infrastructure supporting all corporate services, including connectivity and security."@en ;
    noria:applicationModelIdentifier "CNI-V1.0" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "CORPNET" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "IT Infrastructure Management"@en ;
    noria:applicationFunctionalSubDomain "Network Operations"@en .

noria:NMS_System a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "System responsible for monitoring network devices, collecting metrics, and generating alerts."@en ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

noria:MonitoringPlatform a noria:Application ;
    rdfs:label "Application Monitoring Platform"@en ;
    rdfs:comment "Platform for monitoring application performance, server metrics, and user experience."@en ;
    noria:applicationShortIdentifier "APM" ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

noria:SIEM_System a noria:Application ;
    rdfs:label "Security Information and Event Management System"@en ;
    rdfs:comment "System for collecting, analyzing, and correlating security logs from various sources."@en ;
    noria:applicationShortIdentifier "SIEM" ;
    noria:applicationType <kos/application/type/security> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> .

# =============================================================================
# Application Modules
# =============================================================================

noria:CustomerPortalProdModule a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "Production instance of the Customer Portal Application, serving live customer traffic."@en ;
    noria:applicationModuleOf noria:CustomerPortalApp ;
    noria:applicationModuleName "CUSTPORTAL_PROD" ;
    noria:applicationModuleIdentifier "PROD-CP-001" ;
    noria:applicationModuleAdministrationTeam noria:AppSupportTeam ;
    noria:applicationModuleSupportTeam noria:AppSupportTeam ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:InternalCRMDevModule a noria:ApplicationModule ;
    rdfs:label "Internal CRM Development Module"@en ;
    rdfs:comment "Development instance of the Internal CRM Application, used for new feature development and testing."@en ;
    noria:applicationModuleOf noria:InternalCRMApp ;
    noria:applicationModuleName "INTCRM_DEV" ;
    noria:applicationModuleIdentifier "DEV-CRM-001" ;
    noria:applicationModuleAdministrationTeam noria:AppSupportTeam ;
    noria:applicationModuleSupportTeam noria:AppSupportTeam ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleSlaLevelDate "2023-03-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false .

# =============================================================================
# Services
# =============================================================================

noria:ECommerceService a noria:Service ;
    rdfs:label "E-commerce Platform Service"@en ;
    rdfs:comment "End-to-end service for online sales, encompassing the customer portal, payment gateway, and order fulfillment systems."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:CustomerPortalProdModule .

noria:InternalDataService a noria:Service ;
    rdfs:label "Internal Data Management Service"@en ;
    rdfs:comment "Service providing data management capabilities for internal operations, including CRM and reporting."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:InternalCRMDevModule .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_CR01_InterfaceDown a noria:EventRecord ;
    rdfs:label "Core Router 01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating that a critical network interface on Core Router 01 went down, impacting connectivity."@en ;
    noria:logOriginatingManagedObject noria:CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:NMS_System ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/1, changed state to down"@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_WebSrv01_CPUHigh a noria:EventRecord ;
    rdfs:label "Web Server 01 CPU High Alert"@en ;
    rdfs:comment "Alert indicating sustained high CPU utilization on Web Server 01, potentially affecting application performance."@en ;
    noria:logOriginatingManagedObject noria:WebSrv01 ;
    noria:logOriginatingManagementSystem noria:MonitoringPlatform ;
    noria:logText "CPU utilization on web01.portal.example.com exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-04-23T11:15:30Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:RestartWebServerProcedure .

noria:EventRecord_UserLoginFailure a noria:EventRecord ;
    rdfs:label "User Login Failure Event"@en ;
    rdfs:comment "Log entry for a failed login attempt on the Customer Portal, potentially indicating a brute-force attack."@en ;
    noria:logOriginatingManagedObject noria:CustomerPortalApp ;
    noria:logOriginatingManagementSystem noria:SIEM_System ;
    noria:logOriginatingAgent noria:ExternalUser ;
    noria:logText "Failed login attempt for user 'baduser' from IP 203.0.113.42"@en ;
    noria:loggingTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TroubleTicket_WebOutage a noria:TroubleTicket ;
    rdfs:label "Customer Portal Outage Incident"@en ;
    rdfs:comment "Incident reported by customers regarding the unavailability of the Customer Portal, leading to business impact."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_WebSrv01_CPUHigh ;
    noria:troubleTicketRelatedService noria:CustomerPortalProdModule ;
    noria:troubleTicketRelatedResource noria:WebSrv01 ;
    noria:troubleTicketRelatedParty noria:AppSupportTeam, noria:JaneSmith ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T11:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCause "High CPU utilization on web server leading to service unresponsiveness."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedApplication> ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-2024-001" .

noria:TroubleTicket_RouterLinkDown a noria:TroubleTicket ;
    rdfs:label "Core Router Link Down Incident"@en ;
    rdfs:comment "Incident detected by monitoring system: a critical link on Core Router 01 is down, affecting network connectivity."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_CR01_InterfaceDown ;
    noria:troubleTicketRelatedResource noria:CoreRouter01, noria:LinkCR1_CR2 ;
    noria:troubleTicketRelatedParty noria:NOC_Team, noria:JohnDoe ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCause "Physical fiber cut on link between CR01 and CR02, requiring physical intervention."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-2024-002" .

# =============================================================================
# Trouble Ticket Notes
# =============================================================================

noria:TT_WebOutage_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for Web Portal Outage"@en ;
    rdfs:comment "First note on the Web Portal Outage ticket, detailing initial findings and actions."@en ;
    dcterms:description "Initial investigation shows high CPU on web01.portal.example.com. Attempting to restart Apache service to mitigate."@en ;
    dcterms:created "2024-04-23T11:25:00Z"^^xsd:dateTime ;
    dcterms:creator noria:JaneSmith ;
    dcterms:isPartOf noria:TroubleTicket_WebOutage ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TT_WebOutage_Note2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution for Web Portal Outage"@en ;
    rdfs:comment "Resolution note for the Web Portal Outage ticket, confirming successful restoration."@en ;
    dcterms:description "Apache service restarted successfully. CPU utilization returned to normal levels. Customer confirmed service restored and accessible."@en ;
    dcterms:created "2024-04-23T11:50:00Z"^^xsd:dateTime ;
    dcterms:creator noria:JaneSmith ;
    dcterms:isPartOf noria:TroubleTicket_WebOutage ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ;
    noria:troubleTicketNoteCorrelatedExecution noria:RestartWebServerProcedureExecution .

noria:RestartWebServerProcedureExecution a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Restart Web Server Procedure"@en ;
    rdfs:comment "Container for events related to the execution of the web server restart procedure, initiated during the outage."@en ;
    pep:executedProcedure noria:RestartWebServerProcedure ;
    dcterms:created "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    dcterms:creator noria:JaneSmith .

# =============================================================================
# Change Requests
# =============================================================================

noria:CR_WebSrvOSPatch a noria:ChangeRequest ;
    rdfs:label "Web Server OS Patching"@en ;
    rdfs:comment "Scheduled change request for applying critical OS security patches to Web Server 01 during a maintenance window."@en ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:WebSrv01, noria:CustomerPortalProdModule ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty noria:JaneSmith ;
    noria:changeRequestActorParty noria:AppSupportTeam ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:documentHRef "https://itsm.example.com/change/CR-2024-001" .

noria:CR_RouterFirmwareUpgrade a noria:ChangeRequest ;
    rdfs:label "Core Router Firmware Upgrade"@en ;
    rdfs:comment "Planned firmware upgrade for Core Router 01 to enhance security and performance, requiring a brief network outage."@en ;
