    noria:agentInstructions "Contact for any network connectivity or performance issues."@en ;
    noria:agentManagesResource <https://w3id.org/noria/resource/Router_Core_01> ;
    noria:agentManagesResource <https://w3id.org/noria/resource/Firewall_DMZ_01> ;
    noria:agentManagesResource <https://w3id.org/noria/networklink/DB_to_Router_Link> ;
    .

<https://w3id.org/noria/org/App_Dev_Team>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the E-commerce Platform."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    .

