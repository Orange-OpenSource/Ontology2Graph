    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Escalate database-related incidents to this team via the ticketing system."@en ;
    noria:agentManagesResource <https://w3id.org/noria/resource/DB_Server_01> ;
    .

<https://w3id.org/noria/org/Network_Team>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for network infrastructure_extra_node_1 management."@en ;
    noria:agentWorkingHours "24/7"@en ;
