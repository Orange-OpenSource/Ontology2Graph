# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .

# --- Domain specific ---
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix bot:  <https://w3id.org/bot#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix time: <http://www.w3.org/2006/time#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# NORIA Ontology Declaration (as provided in the schema)
# =============================================================================

<https://w3id.org/noria/ontology/>
	a voaf:Vocabulary, owl:Ontology ;
	dcterms:title "The NORIA Ontology"@en ;
    dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.
"""@en ;
    bibo:status <http://purl.org/ontology/bibo/status/accepted> ;
    dcterms:issued "2022-05-10"^^xsd:date ;
	dcterms:modified "2024-03-15"^^xsd:date ;
	owl:versionInfo "v0.3" ;
	rdfs:seeAlso <https://w3id.org/noria/doc/> ;
.

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

### 1. Agents and Organizations ###

# Organizational Units (Teams)
<https://w3id.org/noria/org/IT_Ops_Team>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:label "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure_extra_node_1 operations and incident response."@en ;
    noria:agentWorkingHours "24/7 (on-call rotation)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical incidents, call the hotline. For non-critical, use the ticketing system."@en ;
    noria:agentManagesResource <https://w3id.org/noria/resource/DB_Server_01> ;
    noria:agentManagesResource <https://w3id.org/noria/resource/Web_Server_01> ;
    noria:agentManagesResource <https://w3id.org/noria/resource/Router_Core_01> ;
    noria:agentManagesResource <https://w3id.org/noria/resource/Firewall_DMZ_01> ;
    noria:agentManagesResource <https://w3id.org/noria/networklink/DB_to_Router_Link> ;
    .

<https://w3id.org/noria/org/DB_Admin_Team>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:label "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Specialized team managing all database systems."@en ;
