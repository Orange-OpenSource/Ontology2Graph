# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (defined inline for this example)
# =============================================================================

<kos/application/type/infrastructure_extra_node_0> a skos:Concept ; skos:prefLabel "Infrastructure Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/business> a skos:Concept ; skos:prefLabel "Business Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/business-importance/high_extra_node_0> a skos:Concept ; skos:prefLabel "High Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<https://w3id.org/noria/kos/application/status/InProduction_extra_node_0> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:prefLabel "En Production"@fr ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en ; skos:prefLabel "En Développement"@fr ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

<kos/TroubleTicket/severity/Critical_extra_node_0> a skos:Concept ; skos:prefLabel "Critical_extra_node_0 Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major_extra_node_0> a skos:Concept ; skos:prefLabel "Major_extra_node_0 Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/type/Failure_extra_node_0> a skos:Concept ; skos:prefLabel "Failure_extra_node_0 Ticket"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:prefLabel "Assistance Ticket"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .
<kos/TroubleTicket/origin/Supervision_extra_node_0> a skos:Concept ; skos:prefLabel "Supervision_extra_node_0 System Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/priority/P1_extra_node_0> a skos:Concept ; skos:prefLabel "Priority 1"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .
<kos/TroubleTicket/problemResponsibility/ManagedBackbone> a skos:Concept ; skos:prefLabel "Managed Backbone Network"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/commentType/Internal_extra_node_0> a skos:Concept ; skos:prefLabel "Internal_extra_node_0 Comment"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .
<kos/TroubleTicket/operationType/Diagnosis_extra_node_0> a skos:Concept ; skos:prefLabel "Diagnosis_extra_node_0 Operation"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .

<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Router_extra_node_0> a skos:Concept ; skos:prefLabel "Router_extra_node_0 Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Firewall_extra_node_0> a skos:Concept ; skos:prefLabel "Firewall_extra_node_0 Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/LifecycleState/InProduction_extra_node_0> a skos:Concept ; skos:prefLabel "In Production Lifecycle State"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; skos:prefLabel "Staging Lifecycle State"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .
<kos/Resource/OperationalState/Up_extra_node_0> a skos:Concept ; skos:prefLabel "Operational State Up_extra_node_0"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Operational State Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .
<kos/Resource/AdministrativeState/Up_extra_node_0> a skos:Concept ; skos:prefLabel "Administrative State Up_extra_node_0"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; skos:prefLabel "Administrative State Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .

<kos/ChangeRequest/category/Internal_extra_node_0Intervention> a skos:Concept ; skos:prefLabel "Internal_extra_node_0 Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .
<kos/ChangeRequest/type/Standard_extra_node_0> a skos:Concept ; skos:prefLabel "Standard_extra_node_0 Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .
<kos/ChangeRequest/cause/SoftwareUpgrade_extra_node_0> a skos:Concept ; skos:prefLabel "Software Upgrade Cause"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:prefLabel "Approved Status"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .

<kos/service/type/CustomerFacingService_extra_node_0> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .

<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email Contact Method"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone Contact Method"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .

<Notification/Severity/PerceivedSeverity/Critical_extra_node_0> a skos:Concept ; skos:prefLabel "Critical_extra_node_0 Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents and Organizations ---
noria:Agent_NetOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for monitoring and maintaining network infrastructure_extra_node_0."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via dedicated hotline for critical issues."@en .

noria:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all requests."@en .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com_extra_node_0> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "IT Change Manager."@en ;
    foaf:mbox <mailto:jane.smith@example.com_extra_node_0> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en .

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for John Doe within the corporate IT system."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount noria:Agent_JohnDoe .

noria:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department of the company."@en ;
    org:hasUnit noria:Agent_NetOpsTeam, noria:Agent_AppSupportTeam .

# --- Product Models ---
noria:ProductModel_Cisco3850 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 3850"@en ;
    rdfs:comment "Enterprise-class stackable access layer switch."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server for data centers."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Leading manufacturer of networking hardware."@en .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

# --- Locations ---
noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "PARIS-DC-01" ;
    noria:siteType "Data Center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Site_ParisDC .

noria:Locus_Rack12U5 a noria:Locus ;
    rdfs:label "Rack 12, Unit 5"@en ;
    rdfs:comment "Specific location within Server Room A for a server unit."@en ;
    noria:locusLine "12" ;
    noria:locusRow "5" .

noria:Room_ServerRoomA bot:containsZone noria:Locus_Rack12U5 .

# --- Resources ---
noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server hosting the corporate website."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_0> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12U5 ;
    noria:resourceManagementIPAddress "192.168.10.101" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router_extra_node_0 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy noria:Agent_NetOpsTeam ;
    noria:resourceHostName "routercore01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco3850 ;
    noria:resourceType <kos/Resource/type/Router_extra_node_0> ;
    noria:resourceSerialNumber "SN-RTR-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_0> ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12U5 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_FirewallDMZ a noria:Resource ;
    rdfs:label "DMZ Firewall_extra_node_0"@en ;
    rdfs:comment "Firewall_extra_node_0 protecting the DMZ segment."@en ;
    noria:resourceManagedBy noria:Agent_NetOpsTeam ;
    noria:resourceHostName "fw-dmz01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco3850 ;
    noria:resourceType <kos/Resource/type/Firewall_extra_node_0> ;
    noria:resourceSerialNumber "SN-FW-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_0> ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12U5 ;
    noria:resourceManagementIPAddress "172.16.0.1" .

noria:Resource_ClusterController01 a noria:Resource ;
    rdfs:label "Virtualization Cluster Controller 01"@en ;
    rdfs:comment "Controller for the virtual machine cluster."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "vcc01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_0> .

noria:Resource_VirtualMachine01 a noria:Resource ;
    rdfs:label "Virtual Machine 01"@en ;
    rdfs:comment "A virtual machine running a critical application component."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "vm01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_0> ;
    noria:clusterController noria:Resource_ClusterController01 .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Primary database server for critical applications."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_0> ;
    noria:resourceInstallationDate "2023-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12U5 ;
    noria:resourceManagementIPAddress "192.168.20.10" .

# --- Network Interfaces ---
noria:NetInt_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Uplink to corporate LAN" ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetInt_RouterCore01_Gig0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router_extra_node_0 01 to the Web Server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceDescription "Link to Web Server VLAN" .

noria:NetInt_RouterCore01_Gig0_0_2 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router_extra_node_0 01 to the DMZ Firewall_extra_node_0."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceDescription "Link to DMZ Firewall_extra_node_0" .

noria:NetInt_FirewallDMZ_Eth0 a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ Ethernet 0"@en ;
    rdfs:comment "Interface connecting DMZ Firewall_extra_node_0 to Core Router_extra_node_0 01."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceRoutingPriorityMetric 60 ;
    noria:networkInterfaceDescription "Uplink from Core Router_extra_node_0" .

noria:NetInt_DBServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Uplink to database LAN" .

# --- Network Links ---
noria:NetLink_WebSrv_RtrCore a noria:NetworkLink ;
    rdfs:label "Web Server to Core Router_extra_node_0 Link"@en ;
    rdfs:comment "Logical link between Web Server 01 and Core Router_extra_node_0 01."@en ;
    noria:networkInterfaceConnects noria:NetInt_WebSrv01_Eth0, noria:NetInt_RouterCore01_Gig0_0_1 ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv01, noria:Resource_RouterCore01 ;
    noria:networkLinkId "NL-WS-RC-001" ;
    noria:networkLinkType "Ethernet VLAN" ;
    noria:networkLinkInstallationDate "2023-01-15T11:00:00Z"^^xsd:dateTime .

noria:NetLink_RtrCore_FwDMZ a noria:NetworkLink ;
    rdfs:label "Core Router_extra_node_0 to DMZ Firewall_extra_node_0 Link"@en ;
    rdfs:comment "Physical link between Core Router_extra_node_0 01 and DMZ Firewall_extra_node_0."@en ;
    noria:networkInterfaceConnects noria:NetInt_RouterCore01_Gig0_0_2, noria:NetInt_FirewallDMZ_Eth0 ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01, noria:Resource_FirewallDMZ ;
    noria:networkLinkId "NL-RC-FW-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2022-05-01T10:00:00Z"^^xsd:dateTime .

noria:NetLink_DB_RtrCore a noria:NetworkLink ;
