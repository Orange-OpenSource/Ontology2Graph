# --- Procedural Elements ---
noria:OperationPlan_RouterReboot a noria:OperationPlan ;
    rdfs:label "Standard_extra_node_0 Router_extra_node_0 Reboot Procedure"@en ;
    rdfs:comment "A documented procedure for safely rebooting a network router."@en ;
    skos:example "Steps include: notify stakeholders, save configuration, execute reboot command, verify connectivity."@en .

noria:ActionPreCondition_RouterUnreachable a noria:ActionPreCondition ;
    rdfs:label "Router_extra_node_0 Unreachable Pre-Condition"@en ;
    rdfs:comment "Condition: Router_extra_node_0 is not responding to ping or management access."@en .

noria:ActionPostCondition_RouterPingable a noria:ActionPostCondition ;
    rdfs:label "Router_extra_node_0 Pingable Post-Condition"@en ;
    rdfs:comment "Outcome: Router_extra_node_0 is responding to ping and management access is restored."@en .

noria:OperationPlan_RouterReboot
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterPingable .

# --- Anomaly Patterns ---
noria:AnomalyPattern_HighCPULoop a noria:AnomalyPattern ;
    rdfs:label "High CPU Loop Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a software process stuck in a high_extra_node_0 CPU consumption loop."@en ;
    skos:example "Repeated 'High CPU Usage Alert' events from the same resource without resolution."@en .

# --- Document Attachments ---
noria:DocAttach_RouterConfig a noria:DocumentAttachment ;
