    dcterms:created "2024-04-30T23:00:00Z"^^xsd:dateTime .

# --- Cross-entity Connections for Density ---
noria:Agent_NetOpsTeam noria:agentManagesResource noria:Resource_RouterCore01, noria:Resource_FirewallDMZ .
noria:Agent_AppSupportTeam noria:agentManagesResource noria:Resource_WebSrv01, noria:Resource_DBServer01, noria:Resource_VirtualMachine01 .

noria:Event_RouterDown dcterms:relation noria:TroubleTicket_NetOutage01 .
noria:Event_WebSrvHighCPU dcterms:relation noria:TroubleTicket_WebSrvPerf .
noria:Event_WebSrvHighCPU dcterms:subject noria:AnomalyPattern_HighCPULoop . # Event is about this anomaly pattern.

noria:Event_RouterDown noria:alarmProposedRepairAction noria:OperationPlan_RouterReboot .
noria:Event_RouterDown noria:alarmMitigatedBy noria:TroubleTicket_NetOutage01 . # The TT is the container for the mitigation actions.

noria:ChangeRequest_RouterUpgrade noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterReboot .
