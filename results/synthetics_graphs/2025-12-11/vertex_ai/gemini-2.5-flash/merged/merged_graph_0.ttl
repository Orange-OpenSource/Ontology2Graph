# --- Event Records ---
noria:Event_RouterDown a noria:EventRecord ;
    rdfs:label "RouterCore01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router_extra_node_0 01 went down."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_0> .

noria:Event_WebSrvHighCPU a noria:EventRecord ;
