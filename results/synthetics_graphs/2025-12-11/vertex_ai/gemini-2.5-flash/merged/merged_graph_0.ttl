# --- Agents and Organizations ---
noria:Agent_NetOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for monitoring and maintaining network infrastructure_extra_node_0."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via dedicated hotline for critical issues."@en .

noria:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all requests."@en .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com_extra_node_0> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "IT Change Manager."@en ;
    foaf:mbox <mailto:jane.smith@example.com_extra_node_0> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en .

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for John Doe within the corporate IT system."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount noria:Agent_JohnDoe .

noria:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department of the company."@en ;
    org:hasUnit noria:Agent_NetOpsTeam, noria:Agent_AppSupportTeam .

