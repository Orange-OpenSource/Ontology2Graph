### 5. Procedural Elements ###

# Operation Plans
<https://w3id.org/noria/operationplan/DB_Restart_Procedure>
    a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Standard_extra_node_1 operating procedure for restarting the PostgreSQL database service."@en ;
    skos:example "Steps: 1. Check service status. 2. Attempt graceful restart. 3. Force stop if necessary. 4. Verify service status."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/DB_Unreachable> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/DB_Accessible> ;
    .

<https://w3id.org/noria/operationplan/Network_Troubleshooting_Procedure>
    a noria:OperationPlan ;
    rdfs:label "Network Connectivity Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving network connectivity issues."@en ;
    skos:example "Steps: 1. Ping test. 2. Traceroute. 3. Check interface status. 4. Review router logs."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/Network_Unreachable> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/Network_Reachable> ;
    .

<https://w3id.org/noria/operationplan/DB_Patch_Procedure>
    a noria:OperationPlan ;
    rdfs:label "Database Security Patch Procedure"@en ;
    rdfs:comment "Standard_extra_node_1 procedure for applying security patches to the database server."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/DB_Patch_Readiness> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/DB_Patched_Verified> ;
    .

# Action Pre-conditions
<https://w3id.org/noria/actionprecondition/DB_Unreachable>
    a noria:ActionPreCondition ;
    rdfs:label "Database Unreachable Pre-condition"@en ;
    rdfs:comment "Condition where the database server is not responding to network requests or service checks."@en ;
    .

<https://w3id.org/noria/actionprecondition/Network_Unreachable>
    a noria:ActionPreCondition ;
    rdfs:label "Network Unreachable Pre-condition"@en ;
    rdfs:comment "Condition where a network resource is not reachable via standard network protocols."@en ;
    .

<https://w3id.org/noria/actionprecondition/DB_Patch_Readiness>
    a noria:ActionPreCondition ;
    rdfs:label "Database Patch Readiness Check"@en ;
    rdfs:comment "Pre-condition: database backup completed, maintenance window confirmed, patch files downloaded."@en ;
    .

# Action Post-conditions
<https://w3id.org/noria/actionpostcondition/DB_Accessible>
    a noria:ActionPostCondition ;
    rdfs:label "Database Accessible Post-condition"@en ;
    rdfs:comment "Condition where the database server is responding to network requests and service checks, and the database service is running."@en ;
    .

<https://w3id.org/noria/actionpostcondition/Network_Reachable>
    a noria:ActionPostCondition ;
    rdfs:label "Network Reachable Post-condition"@en ;
    rdfs:comment "Condition where a network resource is reachable via standard network protocols."@en ;
    .

<https://w3id.org/noria/actionpostcondition/DB_Patched_Verified>
    a noria:ActionPostCondition ;
    rdfs:label "Database Patched and Verified Post-condition"@en ;
    rdfs:comment "Post-condition: patch applied, database service restarted, functionality verified, version checked."@en ;
    .

# Anomaly Patterns
<https://w3id.org/noria/anomalypattern/DB_Crash_Pattern>
    a noria:AnomalyPattern ;
    rdfs:label "Database Crash Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a database service crash, characterized by specific log entries and unavailability."@en ;
    skos:example "Detection of 'FATAL: database system is shut down' log message followed by connection failures."@en ;
