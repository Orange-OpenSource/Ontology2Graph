# =============================================================================
# Event Records
# =============================================================================

<https://w3id.org/noria/event/DBServer01_DownAlert>
    a noria:EventRecord ;
    rdfs:label "DBServer01 Down Alert"@en ;
    rdfs:comment "Automated alert indicating that DBServer01 is unreachable."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/DBServer01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/app/MonitoringSystem> ;
    noria:logText "CRITICAL: Host 'dbserver01.prod.example.com' is DOWN!"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <https://w3id.org/noria/operationplan/RestartDBService> ;
.

<https://w3id.org/noria/event/InterfaceDownAlert>
    a noria:EventRecord ;
    rdfs:label "RouterCore01 Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a network interface on RouterCore01 went down."@en ;
    noria:loggingTime "2024-04-23T09:59:50Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/RouterCore01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/app/MonitoringSystem> ;
    noria:logText "Interface GigabitEthernet0/1 on routercore01.dc.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
.

<https://w3id.org/noria/event/DBRestartLog>
    a noria:EventRecord ;
    rdfs:label "Database Service Restart Log"@en ;
    rdfs:comment "Log entry confirming the restart of the database service on DBServer01."@en ;
    noria:loggingTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/DBServer01> ;
    noria:logOriginatingAgent <https://w3id.org/noria/agent/JaneSmith> ;
    noria:logText "Database service 'postgresql' restarted successfully."@en ;
    noria:alarmMitigatedBy <https://w3id.org/noria/troubleticket/DBOutage_20240423> ; # The TT is the container for the resolution actions
.

<https://w3id.org/noria/app/MonitoringSystem>
    a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Application responsible for collecting and analyzing system metrics and logs."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
.

# =============================================================================
# Trouble Tickets
# =============================================================================

<https://w3id.org/noria/troubleticket/DBOutage_20240423>
    a noria:TroubleTicket ;
    rdfs:label "Critical: DBServer01 Outage Impacting E-commerce"@en ;
    rdfs:comment "Incident reported due to primary database server being down, affecting the E-commerce Platform."@en ;
    dcterms:identifier "TT-20240423-001"@en ;
    dcterms:created "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CUST-INC-98765"@en ;
    noria:documentHRef "https://ticketing.example.com/TT-20240423-001" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <https://w3id.org/noria/event/DBServer01_DownAlert> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/DatabaseFailure> ;
    noria:troubleTicketCause "Database service crashed due to resource exhaustion."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketRelatedParty <https://w3id.org/noria/org/Database_Admin_Team> ;
    noria:troubleTicketRelatedParty <https://w3id.org/noria/agent/JaneSmith> ;
    noria:troubleTicketRelatedService <https://w3id.org/noria/appmodule/ECommerceProd> ;
    noria:troubleTicketRelatedResource <https://w3id.org/noria/resource/DBServer01> ;
    noria:troubleTicketImpacts <https://w3id.org/noria/app/ECommercePlatform> ;
    noria:troubleTicketImpacts <https://w3id.org/noria/service/CustomerFacingWeb> ;
.

# Trouble Ticket Notes
<https://w3id.org/noria/troubleticketnote/DBOutage_Initial>
    a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for DB Outage"@en ;
    rdfs:comment "First note on the DB outage, confirming alert and starting investigation."@en ;
    dcterms:created "2024-04-23T10:08:00Z"^^xsd:dateTime ;
    dcterms:creator <https://w3id.org/noria/agent/JohnDoe> ;
    dcterms:description "Received alert for DBServer01. Pinging host failed. Checking database service status."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf <https://w3id.org/noria/troubleticket/DBOutage_20240423> ;
.

<https://w3id.org/noria/troubleticketnote/DBOutage_Resolution>
    a noria:TroubleTicketNote ;
    rdfs:label "Resolution Note for DB Outage"@en ;
    rdfs:comment "Note detailing the steps taken to resolve the DB outage."@en ;
