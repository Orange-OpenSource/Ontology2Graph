# =============================================================================
# Operation Plans and Conditions
# =============================================================================

<https://w3id.org/noria/operationplan/RestartDBService>
    a noria:OperationPlan ;
    rdfs:label "Restart Database Service Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the PostgreSQL database service."@en ;
    skos:example "Steps include checking logs, stopping service, starting service, verifying status."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/DBServiceStopped> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/DBServiceRunning> ;
.

<https://w3id.org/noria/actionprecondition/DBServiceStopped>
    a noria:ActionPreCondition ;
    rdfs:label "Database Service Stopped"@en ;
    rdfs:comment "Pre-condition: The database service (e.g., PostgreSQL) is not running on the server."@en ;
.

<https://w3id.org/noria/actionpostcondition/DBServiceRunning>
    a noria:ActionPostCondition ;
    rdfs:label "Database Service Running"@en ;
    rdfs:comment "Post-condition: The database service is running and accessible, and application connectivity is restored."@en ;
.

<https://w3id.org/noria/operationplan/ApplyDBPatch>
    a noria:OperationPlan ;
    rdfs:label "Apply Database Patch Procedure"@en ;
    rdfs:comment "Procedure for applying a critical patch to the production database server."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/DBBackupComplete> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/DBPatchApplied> ;
.

<https://w3id.org/noria/actionprecondition/DBBackupComplete>
    a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete"@en ;
    rdfs:comment "Pre-condition: A full backup of the database has been successfully completed and verified."@en ;
.

<https://w3id.org/noria/actionpostcondition/DBPatchApplied>
    a noria:ActionPostCondition ;
    rdfs:label "Database Patch Applied and Verified"@en ;
    rdfs:comment "Post-condition: The database patch has been applied, and system stability and performance are verified."@en ;
.

# Example of action correlated to an operation plan
<https://w3id.org/noria/action/DBServiceRestartAction>
    a pep:Action ; # Assuming pep:Action is a valid class for actions
    rdfs:label "Database Service Restart Action"@en ;
    rdfs:comment "An action representing the execution of the database service restart."@en ;
    noria:actionCorrelatedOperationPlan <https://w3id.org/noria/operationplan/RestartDBService> ;
    pep:hasInput <https://w3id.org/noria/actionprecondition/DBServiceStopped> ;
    pep:hasOutput <https://w3id.org/noria/actionpostcondition/DBServiceRunning> ;
.

<https://w3id.org/noria/action/DBPatchApplicationAction>
    a pep:Action ;
    rdfs:label "Database Patch Application Action"@en ;
    rdfs:comment "An action representing the execution of applying the database patch."@en ;
    noria:actionCorrelatedOperationPlan <https://w3id.org/noria/operationplan/ApplyDBPatch> ;
    pep:hasInput <https://w3id.org/noria/actionprecondition/DBBackupComplete> ;
    pep:hasOutput <https://w3id.org/noria/actionpostcondition/DBPatchApplied> ;
.

