.

<https://w3id.org/noria/locus/RackA1_U20>
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 20"@en ;
    rdfs:comment "Specific location within Server Room A for a server."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "20"@en ;
    bot:containsZone <https://w3id.org/noria/room/ServerRoomA> ; # Assuming bot:containsZone can link a locus to a room
.

<https://w3id.org/noria/locus/RackA1_U21>
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 21"@en ;
    rdfs:comment "Specific location within Server Room A for another server."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "21"@en ;
    bot:containsZone <https://w3id.org/noria/room/ServerRoomA> ;
.

