# --- Procedural Elements ---

noria:OperationPlan_RestartDBService a noria:OperationPlan ;
    rdfs:label "Restart Database Service Procedure"@en ;
    rdfs:comment "Standard operating procedure to safely restart the database service on a production server, including pre-checks and post-verification."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBHighCPU ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBServiceRestored .

noria:OperationPlan_TroubleshootNetworkLink a noria:OperationPlan ;
    rdfs:label "Troubleshoot Network Link Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving network link issues, including physical inspection, cable testing, and interface diagnostics."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:OperationPlan_DeployHotfix a noria:OperationPlan ;
    rdfs:label "Deploy Application Hotfix Procedure"@en ;
    rdfs:comment "Procedure for deploying an urgent hotfix to a production application, minimizing downtime and ensuring proper rollback."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_AppErrorCritical ;
    noria:operationPlanPostCondition noria:ActionPostCondition_AppServiceRestored .

noria:OperationPlan_IncidentResponse a noria:OperationPlan ;
    rdfs:label "Security Incident Response Plan"@en ;
    rdfs:comment "Standard operating procedure for responding to security incidents, covering detection, containment, eradication, recovery, and post-incident analysis."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_SecurityBreach ;
    noria:operationPlanPostCondition noria:ActionPostCondition_SystemSecured .

noria:OperationPlan_OpticalTroubleshooting a noria:OperationPlan ;
    rdfs:label "Optical Link Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving optical power issues on network links, including cleaning connectors and checking transceivers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_OpticalPowerAnomaly ;
    noria:operationPlanPostCondition noria:ActionPostCondition_OpticalPowerNormal .

# --- Action Pre/Post Conditions ---

noria:ActionPreCondition_DBHighCPU a noria:ActionPreCondition ;
    rdfs:label "Database High CPU Pre-Condition"@en ;
    rdfs:comment "Condition: Database server CPU utilization is consistently above 90% for more than 5 minutes, impacting application responsiveness."@en ;
    skos:example "Monitoring alert for high CPU on DB server, correlated with slow query logs."@en .

noria:ActionPostCondition_DBServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Database Service Restored Post-Condition"@en ;
    rdfs:comment "Outcome: Database service is running, connections are stable, and CPU utilization is normalized below 50%."@en ;
    skos:example "Successful database connection tests, CPU < 50%, application response times within SLA."@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition: A critical network interface is reported as administratively or operationally down, causing service interruption."@en ;
    skos:example "Router log message 'Interface down', loss of ping to connected device."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-Condition"@en ;
    rdfs:comment "Outcome: The network interface is operational, traffic is flowing, and connectivity tests are successful."@en ;
    skos:example "Router log message 'Interface up', successful end-to-end connectivity tests."@en .

noria:ActionPreCondition_AppErrorCritical a noria:ActionPreCondition ;
    rdfs:label "Application Critical Error Pre-Condition"@en ;
    rdfs:comment "Condition: Application is returning critical errors (e.g., HTTP 500) and is inaccessible to users."@en ;
    skos:example "Multiple HTTP 500 errors, service unavailable, user reports."@en .

noria:ActionPostCondition_AppServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Application Service Restored Post-Condition"@en ;
    rdfs:comment "Outcome: Application is accessible, no critical errors, and core functionality is verified by automated tests and user checks."@en ;
    skos:example "Application health checks pass, users can access the service, error rates normalized."@en .

noria:ActionPreCondition_SecurityBreach a noria:ActionPreCondition ;
    rdfs:label "Security Breach Detected Pre-Condition"@en ;
    rdfs:comment "Condition: Evidence of unauthorized access, data exfiltration, or malicious activity on a system, confirmed by security tools."@en ;
    skos:example "SIEM alert for critical security event, unusual login activity, suspicious file modifications."@en .

noria:ActionPostCondition_SystemSecured a noria:ActionPostCondition ;
    rdfs:label "System Secured Post-Condition"@en ;
    rdfs:comment "Outcome: Compromised system is isolated, threat mitigated, vulnerability patched, and forensic analysis initiated."@en ;
    skos:example "System isolated, malware removed, vulnerability fixed, forensic image acquired."@en .

noria:ActionPreCondition_OpticalPowerAnomaly a noria:ActionPreCondition ;
    rdfs:label "Optical Power Anomaly Pre-Condition"@en ;
    rdfs:comment "Condition: Received or transmitted optical power is outside normal operating thresholds, triggering a warning or alarm."@en ;
    skos:example "Monitoring alert for high/low Rx/Tx power on fiber optic interfaces."@en .

noria:ActionPostCondition_OpticalPowerNormal a noria:ActionPostCondition ;
    rdfs:label "Optical Power Normal Post-Condition"@en ;
    rdfs:comment "Outcome: Optical power levels are within acceptable thresholds, and link quality is stable."@en ;
    skos:example "Rx/Tx power within normal range, no alarms, bit error rate (BER) is zero."@en .

# --- Anomaly Patterns ---

noria:AnomalyPattern_MemoryLeak a noria:AnomalyPattern ;
    rdfs:label "Application Memory Leak Pattern"@en ;
    rdfs:comment "Pattern indicating a memory leak: gradual increase in application memory usage over time, eventually leading to performance degradation or application crash."@en ;
    skos:example "Observed on noria:Resource_WebServer01, leading to noria:TroubleTicket_WebOutage, characterized by increasing RSS/VSZ metrics."@en .

noria:AnomalyPattern_DDoSAttack a noria:AnomalyPattern ;
    rdfs:label "DDoS Attack Pattern"@en ;
    rdfs:comment "Pattern indicating a Distributed Denial of Service attack: sudden, massive surge in network traffic from multiple, often disparate, sources, overwhelming target resources."@en ;
    skos:example "High traffic volume on noria:NetworkInterface_VFW_Eth1, correlated with service degradation and high connection rates."@en .

noria:AnomalyPattern_NetworkFlapping a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Pattern"@en ;
    rdfs:comment "Pattern indicating a network interface repeatedly changing between up and down states in a short period, often due to physical layer issues or faulty transceivers."@en ;
    skos:example "Observed on noria:NetworkInterface_ES01_Eth0_0, causing intermittent connectivity and routing instability."@en .

