# --- Event Records ---

noria:EventRecord_WebServerError a noria:EventRecord ;
    rdfs:label "Web Server Error Log"@en ;
    rdfs:comment "Log entry indicating an application error (HTTP 500) on the production web server."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "HTTP 500 Internal Server Error on /api/v1/data request. Stack trace: java.lang.OutOfMemoryError."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DBConnectionFailure a noria:EventRecord ;
    rdfs:label "Database Connection Failure Alert"@en ;
    rdfs:comment "Alert from the monitoring system about database connection issues affecting the CRM application."@en ;
    noria:loggingTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Database connection pool exhausted for CRM application. Max connections reached."@en ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartDBService .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Notification"@en ;
    rdfs:comment "Network device log indicating a critical interface on the core router went down."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on cr01.par.orange.com, changed state to down. Link protocol failure."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_TroubleshootNetworkLink .

noria:EventRecord_FirewallBlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en ;
    rdfs:comment "Security alert indicating suspicious traffic blocked by the virtual firewall, potentially a port scan."@en ;
    noria:loggingTime "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:logText "Blocked connection attempt from 192.168.1.100 to 10.0.0.10 on port 8080. Reason: Policy violation (port scan detected)."@en ;
    noria:logOriginatingManagedObject noria:Resource_VirtualFirewall ;
    noria:logOriginatingManagementSystem noria:Application_SecurityInfoPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent noria:CUid_JohnDoe . # Assuming John Doe configured the policy that triggered this.

noria:EventRecord_UserLoginFailure a noria:EventRecord ;
    rdfs:label "User Login Failure"@en ;
    rdfs:comment "Log entry for a failed login attempt to the corporate website admin panel."@en ;
    noria:loggingTime "2024-04-23T10:25:00Z"^^xsd:dateTime ;
    noria:logText "Failed login for user 'jsmith' from IP 192.168.1.50. Invalid credentials."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingManagementSystem noria:Application_SecurityInfoPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Minor> ;
    noria:logOriginatingAgent noria:CUid_JaneSmith . # Jane Smith tried to log in.

noria:EventRecord_HighRxPowerWarning a noria:EventRecord ;
    rdfs:label "High Rx Optical Power Warning"@en ;
    rdfs:comment "Warning indicating high received optical power on a core router uplink interface, suggesting potential signal issues."@en ;
    noria:loggingTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Rx optical power on CR01_Eth0_0 is -1.5 dBm, exceeding warning threshold of -2 dBm. Check fiber cleanliness."@en ;
    noria:logOriginatingManagedObject noria:NetworkInterface_CR01_Eth0_0 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmMonitoredAttribute noria:networkInterfaceLaserRxOpticalPower .

noria:EventRecord_InterfaceFlapping a noria:EventRecord ;
    rdfs:label "Edge Switch Interface Flapping"@en ;
    rdfs:comment "Repeated up/down events on an edge switch uplink interface, causing intermittent connectivity."@en ;
    noria:loggingTime "2024-04-24T09:00:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on es01.lyn.orange.com, changed state to down. (repeated 5 times in 1 minute). Suspected SFP issue."@en ;
    noria:logOriginatingManagedObject noria:Resource_EdgeSwitch01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:relation noria:AnomalyPattern_NetworkFlapping .

noria:EventRecord_NetworkSegmentCreated a noria:EventRecord ;
    rdfs:label "New Network Segment Created Log"@en ;
    rdfs:comment "Log entry confirming the successful creation of a new network segment (VLAN 100) on core and edge devices."@en ;
    noria:loggingTime "2024-05-10T16:30:00Z"^^xsd:dateTime ;
    noria:logText "New VLAN 100 for Dev environment provisioned on cr01.par.orange.com and es01.lyn.orange.com. Configuration applied successfully."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagedObject noria:Resource_EdgeSwitch01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> ;
    noria:logOriginatingAgent noria:CUid_JohnDoe .

noria:EventRecord_FiberCleaned a noria:EventRecord ;
    rdfs:label "Fiber Cleaning Completed Log"@en ;
    rdfs:comment "Log entry confirming successful fiber cleaning and normalized optical power levels on CR01 uplink."@en ;
    noria:loggingTime "2024-04-26T01:25:00Z"^^xsd:dateTime ;
    noria:logText "Fiber connectors on CR01_Eth0_0 cleaned. Rx power now -4.0 dBm, within normal range. Service verified."@en ;
    noria:logOriginatingManagedObject noria:NetworkInterface_CR01_Eth0_0 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> ;
    noria:logOriginatingAgent noria:CUid_JohnDoe .

noria:EventRecord_SFPReplaced a noria:EventRecord ;
    rdfs:label "SFP Module Replaced Log"@en ;
    rdfs:comment "Log entry confirming successful SFP module replacement on Edge Switch 01 and stable interface operation."@en ;
    noria:loggingTime "2024-04-24T10:55:00Z"^^xsd:dateTime ;
    noria:logText "SFP module on es01.lyn.orange.com GigabitEthernet0/0/0 replaced. Interface stable, no more flapping detected."@en ;
