# Virtual Resources
noria:Resource_VirtualFirewall a noria:Resource ;
    rdfs:label "Virtual Firewall DMZ"@en ;
    rdfs:comment "Virtual firewall protecting the DMZ segment, hosted on Hypervisor 01."@en ;
    noria:resourceHostName "vfw01.dmz.orange.com" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualFirewall> ;
    noria:resourceProductModel noria:ProductModel_CiscoASAv ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy foaf:Agent_SOC_Team ;
    noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Running> ;
    noria:clusterController noria:Resource_Hypervisor01 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_5 .

