# --- Network Interfaces ---

noria:NetworkInterface_CR01_Eth0_0 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 - Ethernet 0/0"@en ;
    rdfs:comment "Uplink interface for Core Router 01, connecting to the ISP backbone."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Uplink to external ISP, 10Gbps"@en ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_CR01_Eth0_1 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 - Ethernet 0/1"@en ;
    rdfs:comment "Interface connecting to the DB server segment (VLAN 10)."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
