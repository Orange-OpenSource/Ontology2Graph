@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- Agents and Organizations ---

# Organizations
org:OrangeSA a org:Organization ;
    rdfs:label "Orange S.A."@en ;
    rdfs:comment "Global telecommunications operator providing mobile, fixed, internet, and TV services."@en ;
    org:hasUnit org:ITOperationsDept, org:NetworkEngineeringDept, org:CustomerSupportDept, org:CyberSecurityUnit .

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for managing IT infrastructure, applications, and data centers for Orange S.A."@en ;
    org:unitOf org:OrangeSA ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the dedicated incident management platform and follow up with a phone call to the on-call manager."@en .

org:NetworkEngineeringDept a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Department"@en ;
    rdfs:comment "Department responsible for designing, deploying, and maintaining the core and access network infrastructure."@en ;
    org:unitOf org:OrangeSA ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always open a Change Request for planned network modifications. For outages, contact the Network Operations Center (NOC) directly via hotline."@en .

org:CustomerSupportDept a org:OrganizationalUnit ;
    rdfs:label "Customer Support Department"@en ;
    rdfs:comment "Department handling customer inquiries, first-level technical support, and service activation requests."@en ;
    org:unitOf org:OrangeSA ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sat)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate to L2 support for technical issues beyond basic troubleshooting or requiring specialized expertise."@en .

org:CyberSecurityUnit a org:OrganizationalUnit ;
    rdfs:label "Cyber Security Unit"@en ;
    rdfs:comment "Unit responsible for defining security policies, monitoring threats, and responding to cyber incidents across the organization."@en ;
    org:unitOf org:OrangeSA ;
    noria:agentWorkingHours "24/7 Operations"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "All security incidents must be reported immediately via the SIEM platform and followed by a direct alert to the SOC."@en .

org:VendorDell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Leading multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

org:VendorCisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

# Agents (Teams/Individuals)
foaf:Agent_NOC_Team a foaf:Agent ;
    rdfs:label "Network Operations Center Team"@en ;
    rdfs:comment "Team responsible for 24/7 network monitoring, initial incident response, and routine network maintenance."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical network alarms, follow the 'Critical Network Outage' runbook and initiate bridge calls."@en ;
    org:memberOf org:NetworkEngineeringDept .

foaf:Agent_AppDev_Team_A a foaf:Agent ;
    rdfs:label "Application Development Team A"@en ;
    rdfs:comment "Team developing and maintaining core business applications, including the corporate website and CRM."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit all feature requests via Jira. For production issues, use the dedicated incident channel and create a P1 ticket."@en ;
    org:memberOf org:ITOperationsDept .

foaf:Agent_DBA_Team a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems, ensuring their performance, availability, and security."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri), On-Call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For urgent database issues, create a P1 ticket and call the on-call DBA immediately."@en ;
    org:memberOf org:ITOperationsDept .

foaf:Agent_SOC_Team a foaf:Agent ;
    rdfs:label "Security Operations Center Team"@en ;
    rdfs:comment "Team responsible for monitoring, detecting, analyzing, and responding to cybersecurity incidents."@en ;
    noria:agentWorkingHours "24/7 Operations"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "All security incidents must be reported immediately via the SIEM platform and escalated according to severity."@en ;
    org:memberOf org:CyberSecurityUnit .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior Network Engineer and Team Lead for the NOC."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    org:memberOf foaf:Agent_NOC_Team .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead Application Developer for Corporate Website and CRM applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    org:memberOf foaf:Agent_AppDev_Team_A .

foaf:Agent_AliceJohnson a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Database Administrator specializing in Oracle and PostgreSQL."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    org:memberOf foaf:Agent_DBA_Team .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe, used for system access and logging."@en ;
    foaf:accountName "jdoe" ;
    observable:accountIdentifier "jdoe@corp.orange.com" .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith, used for system access and logging."@en ;
    foaf:accountName "jsmith" ;
    observable:accountIdentifier "jsmith@corp.orange.com" .

noria:CUid_AliceJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Johnson, used for system access and logging."@en ;
    foaf:accountName "ajohnson" ;
    observable:accountIdentifier "ajohnson@corp.orange.com" .

# --- Locations ---

# Sites
bot:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris, France, hosting critical production infrastructure."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site_LyonOffice a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office building in Lyon, France, serving as a hub for regional operations."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site_MarseillePOP a bot:Site ;
    rdfs:label "Marseille Point of Presence"@en ;
    rdfs:comment "Network Point of Presence in Marseille, connecting regional networks to the core backbone."@en ;
    noria:siteId "POP-MRS-01" ;
    noria:siteType "network POP" ;
    noria:sitePrincipalAddress "789 Boulevard de la Liberté"@en ;
    noria:sitePrincipalAddressPostalCode "13001" ;
    noria:sitePrincipalAddressCityName "Marseille" ;
    noria:sitePrincipalAddressCountry "FR" .

# Rooms
noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center, housing racks of servers and storage."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Room_NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in the Lyon Office, providing local network distribution."@en ;
    bot:hasSpace bot:Site_LyonOffice .

noria:Room_EquipmentRoomPOP a noria:Room ;
    rdfs:label "Equipment Room POP"@en ;
    rdfs:comment "Dedicated equipment room at the Marseille Point of Presence for network devices."@en ;
    bot:hasSpace bot:Site_MarseillePOP .

# Loci
noria:Locus_Rack12_Unit23 a noria:Locus ;
    rdfs:label "Rack 12, Unit 23"@en ;
    rdfs:comment "Specific location for a server within Rack 12, at Unit 23, in Server Room A."@en ;
    noria:locusLine "Rack 12"@en ;
    noria:locusRow "Unit 23"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_Cabinet05_Shelf03 a noria:Locus ;
    rdfs:label "Cabinet 05, Shelf 03"@en ;
    rdfs:comment "Location for a network switch within Cabinet 05, on Shelf 03, in Network Closet B."@en ;
    noria:locusLine "Cabinet 05"@en ;
    noria:locusRow "Shelf 03"@en ;
    bot:hasSpace noria:Room_NetworkClosetB .

noria:Locus_Rack01_Unit10 a noria:Locus ;
    rdfs:label "Rack 01, Unit 10"@en ;
    rdfs:comment "Location for a core router within Rack 01, at Unit 10, in Equipment Room POP."@en ;
    noria:locusLine "Rack 01"@en ;
    noria:locusRow "Unit 10"@en ;
    bot:hasSpace noria:Room_EquipmentRoomPOP .

# --- Product Models ---
noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance 2U rack server model, commonly used for virtualization and demanding applications."@en ;
