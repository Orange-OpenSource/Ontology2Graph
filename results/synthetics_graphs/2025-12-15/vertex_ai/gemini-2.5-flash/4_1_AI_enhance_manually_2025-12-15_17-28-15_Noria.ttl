# Example of a TroubleTicketFreezeItem (using an EventRecord to represent a freeze period)
noria:EventRecord_TTWebOutageFreeze a noria:EventRecord ;
    rdfs:label "Trouble Ticket Web Outage Freeze Start"@en ;
    rdfs:comment "Log entry indicating that Trouble Ticket TT-20240423-001 was temporarily frozen due to an external dependency or planned maintenance window."@en ;
    noria:loggingTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240423-001 status changed to Frozen due to external dependency on network team for fiber repair."@en ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

noria:TroubleTicket_WebOutage noria:troubleTicketFreezeItem noria:EventRecord_TTWebOutageFreeze .

