    noria:productManufacturedBy org:VendorCisco .

noria:ProductModel_CiscoASAv a noria:ProductModel ;
    rdfs:label "Cisco Adaptive Security Virtual Appliance"@en ;
    rdfs:comment "Virtual firewall appliance providing comprehensive security services for virtualized and cloud environments."@en ;
    noria:productManufacturedBy org:VendorCisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
