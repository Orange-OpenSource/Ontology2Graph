noria:TroubleTicket_WANOutage a noria:TroubleTicket ;
    rdfs:label "WAN Link Outage - Paris-Lyon"@en ;
    rdfs:comment "Critical incident: WAN link between Paris DC and Lyon office is down, impacting regional connectivity."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_CR01_LinkDown ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "NMS-V3" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Fiber cut suspected on WAN link."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:31:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:NetworkOpsTeam ;
    noria:troubleTicketRelatedParty foaf:Person_AliceSmith ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRouter01 ;
    noria:troubleTicketRelatedResource noria:Resource_EdgeRouter01 ;
    noria:troubleTicketImpacts noria:Application_CustomerPortal ;
    noria:troubleTicketImpacts noria:NetworkLink_WAN_Paris_Lyon ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-2024-04-20-001" .

noria:TroubleTicketNote_WAN_InitialDiag a noria:TroubleTicketNote ;
    rdfs:label "WAN Outage - Initial Diagnosis"@en ;
    rdfs:comment "Confirmed link down on Gi0/0/1 of CR01. No local physical damage observed. Initiating remote diagnostics."@en ;
    dcterms:created "2024-04-20T09:35:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person_AliceSmith ;
    dcterms:isPartOf noria:TroubleTicket_WANOutage ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote_WAN_Restored a noria:TroubleTicketNote ;
    rdfs:label "WAN Outage - Service Restored"@en ;
    rdfs:comment "Link restored after remote port flap. Monitoring for stability. Root cause analysis pending."@en ;
    dcterms:created "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person_AliceSmith ;
    dcterms:isPartOf noria:TroubleTicket_WANOutage ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Restoration> ;
    noria:troubleTicketNoteCorrelatedExecution noria:TroubleTicket_WANOutage . # The ticket itself acts as a container for the execution.
    # Also, the EventRecord_CR01_LinkUp is part of the execution that led to restoration.

