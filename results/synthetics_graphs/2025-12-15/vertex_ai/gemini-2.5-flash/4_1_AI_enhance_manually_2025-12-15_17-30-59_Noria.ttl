@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix devopsprod: <http://w3id.org/devops-infra/product#> .

# =============================================================================
# 1. Agents and Organizations
# =============================================================================

# Organizations
org:OrangeCorp a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main telecommunications company."@en .

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for overall IT infrastructure operations."@en ;
    org:unitOf org:OrangeCorp .

org:NetworkOpsTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical network issues, call the hotline immediately. For non-critical, use ticketing system."@en .

org:AppSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all application-related issues."@en .

org:SecurityOpsTeam a org:OrganizationalUnit ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> ;
    noria:agentInstructions "Follow established security incident response playbooks."@en .

org:CloudInfraTeam a org:OrganizationalUnit ;
    rdfs:label "Cloud Infrastructure Team"@en ;
    rdfs:comment "Team managing cloud-based resources and services."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "All requests must go through the cloud service management portal."@en .

# Persons (as foaf:Agent)
foaf:Person_AliceSmith a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    org:memberOf org:NetworkOpsTeam ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

foaf:Person_BobJohnson a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    org:memberOf org:AppSupportTeam ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

foaf:Person_CharlieBrown a foaf:Person ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Security Analyst."@en ;
    org:memberOf org:SecurityOpsTeam ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> .

# Corporate User Identifiers
noria:CUid_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount foaf:Person_AliceSmith .

noria:CUid_BJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount foaf:Person_BobJohnson .

# =============================================================================
# 2. Locations
# =============================================================================

bot:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center for European operations."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site_LyonOffice a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office with local IT infrastructure."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Room_NetworkCloset1 a noria:Room ;
    rdfs:label "Network Closet 1"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace bot:Site_LyonOffice .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Specific rack location for critical servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5 a noria:Locus ;
    rdfs:label "Rack B5 in Server Room A"@en ;
    rdfs:comment "Rack location for less critical servers."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_WallMount1 a noria:Locus ;
    rdfs:label "Wall Mount 1 in Network Closet 1"@en ;
    rdfs:comment "Wall mount location for network devices."@en ;
    noria:locusLine "WM" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_NetworkCloset1 .

# =============================================================================
# 3. Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy org:Dell . # Assuming Dell is an org:Organization

org:Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series."@en ;
    noria:productManufacturedBy org:Cisco .

org:Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy org:VMware .

org:VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization software company."@en .

# =============================================================================
# 4. Resources
# =============================================================================

# Physical Servers
noria:Resource_AppServer01 a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Primary server for the Customer Portal application."@en ;
    noria:resourceHostName "appserver01.corp.example.com" ;
    noria:resourceLogisticId "LOG-AS01-PAR" ;
    noria:resourceSerialNumber "SN-AS01-XYZ" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/physical-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:AppSupportTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_10 .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Database server for critical business applications."@en ;
    noria:resourceHostName "dbserver01.corp.example.com" ;
    noria:resourceLogisticId "LOG-DB01-PAR" ;
    noria:resourceSerialNumber "SN-DB01-ABC" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/physical-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:AppSupportTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_11 .

# Network Devices
noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the data center network."@en ;
    noria:resourceHostName "cr01.par.example.com" ;
    noria:resourceLogisticId "LOG-CR01-PAR" ;
    noria:resourceSerialNumber "SN-CR01-DEF" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkOpsTeam ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_1 .

noria:Resource_EdgeRouter01 a noria:Resource ;
    rdfs:label "Edge Router 01"@en ;
    rdfs:comment "Router connecting Lyon office to the corporate network."@en ;
    noria:resourceHostName "er01.lyn.example.com" ;
    noria:resourceLogisticId "LOG-ER01-LYN" ;
    noria:resourceSerialNumber "SN-ER01-GHI" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-02-01T14:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkOpsTeam ;
    noria:locatedAtLocus noria:Locus_WallMount1 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_1_1 .

# Virtual Machines
noria:Resource_VMWeb01 a noria:Resource ;
    rdfs:label "Virtual Web Server 01"@en ;
    rdfs:comment "Virtual machine hosting web services for Customer Portal."@en ;
    noria:resourceHostName "vmweb01.corp.example.com" ;
    noria:resourceLogisticId "LOG-VMW01-PAR" ;
    noria:resourceSerialNumber "SN-VMW01-JKL" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-10T12:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:CloudInfraTeam ;
    noria:clusterController noria:Resource_AppServer01 ; # AppServer01 acts as hypervisor
    noria:virtualServerStatus <kos/Resource/OperationalState/Running> ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_20 .

noria:Resource_VMAuth01 a noria:Resource ;
    rdfs:label "Virtual Authentication Server 01"@en ;
    rdfs:comment "Virtual machine for user authentication services."@en ;
    noria:resourceHostName "vmauth01.corp.example.com" ;
    noria:resourceLogisticId "LOG-VMA01-PAR" ;
    noria:resourceSerialNumber "SN-VMA01-MNO" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-10T13:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:CloudInfraTeam ;
    noria:clusterController noria:Resource_AppServer01 ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Running> ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_21 .

# IP Addresses (as observable:IPAddress)
observable:IPAddress_10_0_0_10 a observable:IPAddress ;
    rdfs:label "10.0.0.10"@en ;
    rdfs:comment "Management IP for AppServer01."@en .

observable:IPAddress_10_0_0_11 a observable:IPAddress ;
    rdfs:label "10.0.0.11"@en ;
    rdfs:comment "Management IP for DBServer01."@en .

observable:IPAddress_10_0_0_1 a observable:IPAddress ;
    rdfs:label "10.0.0.1"@en ;
    rdfs:comment "Management IP for CoreRouter01."@en .

observable:IPAddress_10_0_1_1 a observable:IPAddress ;
    rdfs:label "10.0.1.1"@en ;
    rdfs:comment "Management IP for EdgeRouter01."@en .

observable:IPAddress_10_0_0_20 a observable:IPAddress ;
    rdfs:label "10.0.0.20"@en ;
    rdfs:comment "Management IP for VMWeb01."@en .

observable:IPAddress_10_0_0_21 a observable:IPAddress ;
    rdfs:label "10.0.0.21"@en ;
    rdfs:comment "Management IP for VMAuth01."@en .

# =============================================================================
# 5. Network Interfaces and Links
# =============================================================================

# Network Interfaces for AppServer01
noria:NetworkInterface_AppServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "AppServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for AppServer01."@en ;
    noria:networkInterfaceOf noria:Resource_AppServer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to core switch" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# Network Interfaces for CoreRouter01
noria:NetworkInterface_CR01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Interface connecting CoreRouter01 to AppServer01's segment."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Link to server farm" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_CR01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting CoreRouter01 to EdgeRouter01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "WAN link to Lyon office" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Network Interfaces for EdgeRouter01
noria:NetworkInterface_ER01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "EdgeRouter01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Interface connecting EdgeRouter01 to CoreRouter01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "WAN link to Paris DC" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceLaserTxOpticalPower -4 ;
    noria:networkInterfaceLaserRxOpticalPower -6 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Network Links
noria:NetworkLink_DC_ServerFarm a noria:NetworkLink ;
    rdfs:label "DC Server Farm Link"@en ;
    rdfs:comment "High-speed link between CoreRouter01 and the server farm switch."@en ;
    noria:networkLinkId "NL-DC-SF-01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2020-01-20T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_AppServer01 ; # Simplified, in reality it would be a switch
    noria:resourceManagedBy org:NetworkOpsTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_Gi0_0_0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_AppServer01_Eth0 .

noria:NetworkLink_WAN_Paris_Lyon a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-Lyon"@en ;
    rdfs:comment "Dedicated WAN link between Paris Data Center and Lyon Office."@en ;
    noria:networkLinkId "NL-WAN-PAR-LYN" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2020-02-01T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeRouter01 ;
    noria:resourceManagedBy org:NetworkOpsTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_Gi0_0_1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_ER01_Gi0_0_0 .

# =============================================================================
# 6. Applications and Application Modules
# =============================================================================

noria:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:comment "Web application for customer self-service."@en ;
    noria:applicationModelIdentifier "CP-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CustPortal" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Self-Service" ;
    noria:elementManagedBy org:AppSupportTeam ;
    noria:resourceForApplication noria:Resource_AppServer01 ;
    noria:resourceForApplication noria:Resource_DBServer01 ;
    noria:resourceForApplication noria:Resource_VMWeb01 ;
    noria:resourceForApplication noria:Resource_VMAuth01 .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "System for monitoring network devices and services."@en ;
    noria:applicationModelIdentifier "NMS-V3" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Network Performance Monitoring" ;
    noria:elementManagedBy org:NetworkOpsTeam .

noria:Application_SecurityInfoSystem a noria:Application ;
    rdfs:label "Security Information and Event Management (SIEM)"@en ;
    rdfs:comment "Centralized logging and security event analysis platform."@en ;
    noria:applicationModelIdentifier "SIEM-V1" ;
    noria:applicationNumericalIdentifier 3001 ;
    noria:applicationShortIdentifier "SIEM" ;
    noria:applicationType <kos/application/type/security> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Security Management" ;
    noria:applicationFunctionalSubDomain "Security Event Analysis" ;
    noria:elementManagedBy org:SecurityOpsTeam .

# Application Modules for Customer Portal
noria:ApplicationModule_CP_Prod a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "Production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf noria:Application_CustomerPortal ;
    noria:applicationModuleName "CustPortal_Prod" ;
    noria:applicationModuleIdentifier "CP-PROD-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam org:AppSupportTeam ;
    noria:applicationModuleAdministrationLeader foaf:Person_BobJohnson ;
    noria:applicationModuleSupportTeam org:AppSupportTeam ;
    noria:applicationModuleSupportLeader foaf:Person_BobJohnson ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:ApplicationModule_CP_Dev a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en ;
    rdfs:comment "Development instance of the Customer Portal application."@en ;
    noria:applicationModuleOf noria:Application_CustomerPortal ;
    noria:applicationModuleName "CustPortal_Dev" ;
    noria:applicationModuleIdentifier "CP-DEV-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleAdministrationTeam org:AppSupportTeam ;
    noria:applicationModuleSupportTeam org:AppSupportTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleHotlineEnabled false .

# Application Modules for Monitoring System
noria:ApplicationModule_NMS_Core a noria:ApplicationModule ;
    rdfs:label "NMS Core Module"@en ;
    rdfs:comment "Core components of the Network Monitoring System."@en ;
    noria:applicationModuleOf noria:Application_MonitoringSystem ;
    noria:applicationModuleName "NMS_Core" ;
    noria:applicationModuleIdentifier "NMS-CORE-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam org:NetworkOpsTeam ;
    noria:applicationModuleSupportTeam org:NetworkOpsTeam ;
    noria:applicationModuleHotlineGroup org:NetworkOpsTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleHotlineEnabled true .

# =============================================================================
# 7. Services
# =============================================================================

noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_MonitoringSystem ; # NMS monitors this service
    seas:subSystemOf noria:ApplicationModule_NMS_Core ;
    noria:elementManagedBy org:NetworkOpsTeam .

noria:Service_CustomerFacingWeb a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "The end-to-end service for customers accessing the portal."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_CustomerPortal ;
    seas:subSystemOf noria:ApplicationModule_CP_Prod ;
    noria:elementManagedBy org:AppSupportTeam .

# =============================================================================
# 8. Event Records
# =============================================================================

noria:EventRecord_CR01_LinkDown a noria:EventRecord ;
    rdfs:label "CoreRouter01 Link Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on CoreRouter01."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckFiber ;
    noria:alarmMonitoredAttribute noria:NetworkInterface_CR01_Gi0_0_1 .

noria:EventRecord_AppServer_HighCPU a noria:EventRecord ;
    rdfs:label "AppServer01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Application Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on appserver01 exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
