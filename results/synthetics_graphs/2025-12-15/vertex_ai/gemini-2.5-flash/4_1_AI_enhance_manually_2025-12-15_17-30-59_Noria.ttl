# =============================================================================
# 11. Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_CheckFiber a noria:OperationPlan ;
    rdfs:label "Check Fiber Optic Link Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing fiber optic link issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_LinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LinkUp .

noria:ActionPreCondition_LinkDown a noria:ActionPreCondition ;
    rdfs:label "Network Link is Down"@en ;
    rdfs:comment "Condition: A network interface or link is reported as administratively or operationally down."@en ;
    skos:example "noria:NetworkInterface.networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Down>" .

noria:ActionPostCondition_LinkUp a noria:ActionPostCondition ;
    rdfs:label "Network Link is Up"@en ;
    rdfs:comment "Expected outcome: The network interface or link is reported as administratively and operationally up."@en ;
    skos:example "noria:NetworkInterface.networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Up>" .

noria:OperationPlan_DBQueryOptimize a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_HighCPU_SlowResponse ;
    noria:operationPlanPostCondition noria:ActionPostCondition_NormalCPU_FastResponse .

noria:ActionPreCondition_HighCPU_SlowResponse a noria:ActionPreCondition ;
    rdfs:label "High CPU and Slow Response Time"@en ;
    rdfs:comment "Condition: Application server CPU utilization is consistently high, and application response times are degraded."@en ;
    skos:example "noria:Resource_AppServer01 CPU > 90% AND noria:ApplicationModule_CP_Prod response time > 500ms" .

noria:ActionPostCondition_NormalCPU_FastResponse a noria:ActionPostCondition ;
    rdfs:label "Normal CPU and Fast Response Time"@en ;
    rdfs:comment "Expected outcome: Application server CPU utilization returns to normal levels, and application response times improve."@en ;
    skos:example "noria:Resource_AppServer01 CPU < 50% AND noria:ApplicationModule_CP_Prod response time < 200ms" .

noria:AnomalyPattern_RepeatedLinkFlap a noria:AnomalyPattern ;
    rdfs:label "Repeated Network Link Flap Anomaly"@en ;
    rdfs:comment "Pattern indicating a network link repeatedly goes up and down within a short period, suggesting an unstable physical layer issue."@en ;
    folio:hasCause "Unstable physical layer, faulty transceiver, or power issue."@en .

noria:AnomalyPattern_DDoSAttack a noria:AnomalyPattern ;
    rdfs:label "Distributed Denial of Service (DDoS) Attack Pattern"@en ;
    rdfs:comment "Pattern indicating a high volume of malicious traffic targeting a service, leading to unavailability."@en ;
    folio:hasCause "External malicious actor attempting to disrupt service."@en .

# Linking Event Records to Anomaly Patterns (conceptual link, not direct property in NORIA)
# This would typically be inferred or detected by a system, but we can show a potential correlation.
# For example, an EventRecord could be a symptom of an AnomalyPattern.
# The schema doesn't provide a direct property for this, so I'll use rdfs:comment to illustrate.
noria:EventRecord_CR01_LinkDown
    rdfs:comment "Log entry indicating a network interface went down on CoreRouter01. This event could be a symptom of noria:AnomalyPattern_RepeatedLinkFlap if it recurs frequently."@en .

noria:EventRecord_SIEM_LoginFail
    rdfs:comment "Security event: multiple failed login attempts detected on VMAuth01. This event could be a symptom of noria:AnomalyPattern_DDoSAttack if combined with high traffic volume."@en .

