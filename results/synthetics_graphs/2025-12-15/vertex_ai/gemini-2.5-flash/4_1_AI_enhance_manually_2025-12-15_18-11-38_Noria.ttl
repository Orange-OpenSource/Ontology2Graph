    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

# Services
noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "End-to-end service providing internet access to corporate users."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:App_CorporateWebsite ; # Example: Corporate Website relies on Internet Access
    seas:subSystemOf noria:App_InternalCRM ; # CRM also relies on Internet Access for updates/external integrations
    noria:resourceManagedBy org:NetworkOpsTeam .

noria:Service_DNSResolution a noria:Service ;
    rdfs:label "Internal DNS Resolution Service"@en ;
    rdfs:comment "Service providing DNS resolution for internal network resources."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:App_CorporateWebsite ; # Corporate Website needs DNS
    seas:subSystemOf noria:App_InternalCRM ; # CRM needs DNS
    seas:subSystemOf noria:App_MonitoringPlatform ; # Monitoring needs DNS
    noria:resourceManagedBy org:NetworkOpsTeam .

noria:Resource_DNS01 noria:resourceForApplication noria:App_CorporateWebsite, noria:App_InternalCRM, noria:App_MonitoringPlatform .
noria:Resource_RouterCore01 noria:resourceForApplication noria:App_CorporateWebsite, noria:App_InternalCRM, noria:App_MonitoringPlatform .
noria:Resource_WebSrv01 noria:resourceForApplication noria:App_CorporateWebsite .
noria:Resource_Firewall01 noria:resourceForApplication noria:App_CorporateWebsite, noria:App_InternalCRM, noria:App_MonitoringPlatform .

