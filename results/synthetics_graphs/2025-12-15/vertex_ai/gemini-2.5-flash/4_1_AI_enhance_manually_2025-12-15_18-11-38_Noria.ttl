# Applications
noria:App_CorporateWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "The official corporate website, accessible externally."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CW" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/CustomerFacing> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Marketing and Sales" ;
    noria:applicationFunctionalSubDomain "Online Presence Management" .

noria:App_InternalCRM a noria:Application ;
    rdfs:label "Internal CRM System"@en ;
    rdfs:comment "Customer Relationship Management system for internal use."@en ;
    noria:applicationModelIdentifier "CRMINT" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/InternalBusiness> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Service" ;
    noria:applicationFunctionalSubDomain "Customer Data Management" .

noria:App_MonitoringPlatform a noria:Application ;
    rdfs:label "IT Monitoring Platform"@en ;
    rdfs:comment "Platform for monitoring IT infrastructure and applications."@en ;
    noria:applicationModelIdentifier "ITMON" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Performance Monitoring" .

# Application Modules
noria:AppMod_CorpWeb_Prod a noria:ApplicationModule ;
