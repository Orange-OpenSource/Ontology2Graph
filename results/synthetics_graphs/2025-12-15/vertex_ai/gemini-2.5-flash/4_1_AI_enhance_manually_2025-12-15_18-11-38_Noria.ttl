# Event Records
noria:Event_DNS_Down a noria:EventRecord ;
    rdfs:label "DNS Server 01 Down Alert"@en ;
    rdfs:comment "Automated alert indicating DNS01 server is unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OP_RestartService ;
    noria:alarmMonitoredAttribute "ping_status" .

noria:Event_Router_Interface_Down a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/2, changed state to down" ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> .

noria:Event_WebSrv_HighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert for high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "WARNING: WebSrv01 CPU usage > 90% for 5 minutes" ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_User_Login_Failure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log of a failed login attempt on a critical system."@en ;
    noria:loggingTime "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logOriginatingAgent foaf:Agent_ExternalAttacker ; # Example of an external agent
    noria:logText "Failed login from IP 203.0.113.42 to admin account" ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Minor> .

foaf:Agent_ExternalAttacker a foaf:Agent ;
    rdfs:label "Unknown External Attacker"@en ;
    rdfs:comment "Hypothetical agent representing an external threat actor."@en .

