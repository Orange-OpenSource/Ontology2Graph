# =============================================================================
# Procedural Elements
# =============================================================================

# Operation Plans
noria:OP_RestartService a noria:OperationPlan ;
    rdfs:label "Standard Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a critical service."@en ;
    skos:example "Steps: 1. Check service status. 2. Attempt graceful restart. 3. Force restart if graceful fails. 4. Verify service functionality."@en ;
    noria:operationPlanPreCondition noria:APC_ServiceDown ;
    noria:operationPlanPostCondition noria:APOC_ServiceRunning .

noria:OP_FirmwareUpgrade a noria:OperationPlan ;
    rdfs:label "Network Device Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed procedure for upgrading firmware on network devices."@en ;
    skos:example "Steps: 1. Backup configuration. 2. Download firmware. 3. Install firmware. 4. Reboot device. 5. Verify functionality."@en ;
    noria:operationPlanPreCondition noria:APC_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:APOC_FirmwareUpdated .

# Action Pre-Conditions
noria:APC_ServiceDown a noria:ActionPreCondition ;
    rdfs:label "Service Down Pre-Condition"@en ;
    rdfs:comment "Condition: The target service is currently in a 'down' or 'unresponsive' state."@en ;
    skos:example "Ping failure, port unreachable, application logs showing errors."@en .

noria:APC_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Pre-Condition"@en ;
    rdfs:comment "Condition: The operation is scheduled within an approved maintenance window."@en ;
    skos:example "Change Request approved and scheduled for off-peak hours."@en .

# Action Post-Conditions
noria:APOC_ServiceRunning a noria:ActionPostCondition ;
    rdfs:label "Service Running Post-Condition"@en ;
    rdfs:comment "Expected outcome: The target service is running and responsive."@en ;
    skos:example "Service responds to pings, port 53 is open, application logs show normal operation."@en .

noria:APOC_FirmwareUpdated a noria:ActionPostCondition ;
    rdfs:label "Firmware Updated Post-Condition"@en ;
    rdfs:comment "Expected outcome: Device firmware is successfully updated to the new version."@en ;
    skos:example "Device shows new firmware version in 'show version' command output."@en .

# Anomaly Patterns
noria:AP_DNS_CachePoisoning a noria:AnomalyPattern ;
    rdfs:label "DNS Cache Poisoning Pattern"@en ;
    rdfs:comment "Pattern indicating a potential DNS cache poisoning attack: unusual DNS queries, high CPU on DNS server, unexpected DNS responses."@en ;
    skos:example "Multiple EventRecords showing DNS query anomalies and high resource utilization on DNS servers."@en .

noria:AP_NetworkLoop a noria:AnomalyPattern ;
    rdfs:label "Network Loop Detection Pattern"@en ;
    rdfs:comment "Pattern indicating a network loop: high broadcast traffic, MAC address flapping, interface errors."@en ;
    skos:example "EventRecords from multiple network devices showing high broadcast rates and MAC address changes on connected interfaces."@en .

# Procedure Execution (linking EventRecords to Operation Plans)
noria:PE_DNS_Restart a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS Service Restart Execution"@en ;
    rdfs:comment "Execution of the standard service restart procedure for DNS01."@en ;
    pep:usedProcedure noria:OP_RestartService ;
    dcterms:created "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_Alice .

noria:Event_DNS_Restart_Command a noria:EventRecord ;
    rdfs:label "DNS Restart Command Log"@en ;
    rdfs:comment "Log of the command executed to restart the DNS service."@en ;
    noria:loggingTime "2024-04-20T09:35:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingAgent foaf:Agent_Alice ;
    noria:logText "systemctl restart named.service" ;
    pep:member noria:PE_DNS_Restart .

noria:Event_DNS_Service_Up a noria:EventRecord ;
    rdfs:label "DNS Service Up Log"@en ;
    rdfs:comment "Log indicating the DNS service came back up after restart."@en ;
    noria:loggingTime "2024-04-20T09:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "INFO: named.service started successfully" ;
    pep:member noria:PE_DNS_Restart .

noria:TT_DNS_Outage noria:troubleTicketCharacteristic noria:TTChar_RootCauseIdentified .
noria:TTChar_RootCauseIdentified a noria:Property ; # Using noria:Property as a generic characteristic
    rdfs:label "Root Cause Identified Characteristic"@en ;
    rdfs:comment "Indicates that the root cause for the incident has been identified."@en ;
    skos:example "Root cause: disk full on DNS server."@en .

noria:TT_DNS_Outage noria:problemCategory <https://w3id.org/noria/kos/TroubleTicket/trouble-category/SoftwareFailure> .
noria:TT_DNS_Outage noria:problemResponsibility <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/ManagedApplicationHostingServices> .
noria:TT_DNS_Outage noria:troubleTicketCause "Disk space exhaustion on DNS server leading to service crash."@en .

noria:TT_Website_Performance noria:troubleTicketCategory <https://w3id.org/noria/kos/TroubleTicket/trouble-category/PerformanceDegradation> .
noria:TT_Website_Performance noria:troubleTicketCriticity <https://w3id.org/noria/kos/TroubleTicket/category/CorruptedService> .
noria:TT_Website_Performance noria:troubleTicketUrgency <https://w3id.org/noria/kos/TroubleTicket/urgency/ImmediateIntervention> .
noria:TT_Website_Performance noria:troubleTicketSupervisionTool "Prometheus/Grafana"@en .

