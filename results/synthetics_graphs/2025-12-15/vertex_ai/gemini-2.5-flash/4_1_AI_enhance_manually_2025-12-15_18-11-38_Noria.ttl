# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizations
org:OrangeCorp a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main telecommunications company."@en ;
    noria:sitePrincipalAddress "78 Rue Olivier de Serres, 75015 Paris, France"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    noria:sitePrincipalAddressPostalCode "75015"@en .

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for overall IT infrastructure and application operations."@en ;
    org:unitOf org:OrangeCorp .

org:NetworkOpsTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, call the hotline after sending an email."@en .

org:AppSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal."@en .

org:SecurityOpsCenter a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate phone call for any critical security alert."@en .

# Agents (Individuals)
foaf:Agent_Alice a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, Team Lead for Network Operations."@en ;
    org:memberOf org:NetworkOpsTeam ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

foaf:Agent_Bob a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer, part of App Support Team."@en ;
    org:memberOf org:AppSupportTeam ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> .

foaf:Agent_Charlie a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "SOC Analyst, responsible for incident response."@en ;
    org:memberOf org:SecurityOpsCenter ;
    noria:agentWorkingHours "Shift-based 24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

# Corporate User Identifiers
noria:CUid_Alice a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount foaf:Agent_Alice .

noria:CUid_Bob a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount foaf:Agent_Bob .

# =============================================================================
# Locations
# =============================================================================

bot:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center for corporate services."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Data Center Ave, 75013 Paris, France"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    noria:sitePrincipalAddressPostalCode "75013"@en .

bot:Site_LyonOffice a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office with local IT infrastructure."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddress "456 Tech Park, 69007 Lyon, France"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    noria:sitePrincipalAddressPostalCode "69007"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Room_NetworkCloset1 a noria:Room ;
    rdfs:label "Network Closet 1"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace bot:Site_LyonOffice .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Specific rack location for critical servers."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_RackB5 a noria:Locus ;
    rdfs:label "Rack B5 in Server Room A"@en ;
    rdfs:comment "Location for less critical infrastructure."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "5"@en ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_WallMount1 a noria:Locus ;
    rdfs:label "Wall Mount 1 in Network Closet 1"@en ;
    rdfs:comment "Location for network switches in Lyon office."@en ;
    noria:locusLine "WM"@en ;
    noria:locusRow "1"@en ;
    bot:hasZone noria:Room_NetworkCloset1 .

# =============================================================================
# Resources and Product Models
# =============================================================================

# Product Models
noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy org:Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center network switch series."@en ;
    noria:productManufacturedBy org:Cisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy org:VMware .

org:Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

org:Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

org:VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

# Resources
noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, located in Paris DC."@en ;
    noria:resourceManagedBy org:NetworkOpsTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ123" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the Paris Data Center network."@en ;
    noria:resourceManagedBy org:NetworkOpsTeam ;
    noria:resourceHostName "router-core-01.paris.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC456" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_VMHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines in Paris DC."@en ;
    noria:resourceManagedBy org:ITOperationsDept ;
    noria:resourceHostName "vmhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "LOG-VMH-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Hypervisor> ;
    noria:resourceSerialNumber "SN-VMH01-DEF789" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress "10.0.0.20" .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy org:AppSupportTeam ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # Represents the VM itself, not the underlying hardware
    noria:resourceLogisticId "LOG-WEB-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-WEB01-GHI012" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-06-10T11:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_VMHost01 ;
    noria:resourceManagementIPAddress "10.0.1.50" ;
    noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Running> .

noria:Resource_Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Main firewall protecting the corporate network."@en ;
    noria:resourceManagedBy org:SecurityOpsCenter ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Example, could be a dedicated firewall vendor
    noria:resourceLogisticId "LOG-FW-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW01-JKL345" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-01T16:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.5" .

# Network Interfaces
noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Management interface" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NI_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal network segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Internal LAN connection" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NI_RouterCore01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the external WAN link."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "WAN Uplink to ISP" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NI_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Virtual network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Web traffic interface" ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

# Network Links
noria:NL_LAN_Segment1 a noria:NetworkLink ;
    rdfs:label "LAN Segment 1 - Paris DC"@en ;
    rdfs:comment "Internal network link connecting servers in Paris DC."@en ;
    noria:networkLinkId "NL-LAN-PAR-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_DNS01, noria:Resource_RouterCore01, noria:Resource_VMHost01 ;
    noria:resourceManagedBy org:NetworkOpsTeam .

noria:NL_WAN_ISP_Link a noria:NetworkLink ;
    rdfs:label "WAN Link to ISP"@en ;
    rdfs:comment "External link connecting Paris DC to the Internet via an ISP."@en ;
    noria:networkLinkId "NL-WAN-ISP-01" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:ISP_Router ; # Assuming an external ISP router
    noria:resourceManagedBy org:NetworkOpsTeam .

noria:ISP_Router a noria:Resource ;
    rdfs:label "ISP Edge Router"@en ;
    rdfs:comment "External router managed by the Internet Service Provider."@en ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceHostName "isp-edge-rtr.example.com" .

noria:NI_DNS01_Eth0 noria:networkInterfaceConnects noria:NL_LAN_Segment1 .
noria:NI_RouterCore01_Gi0_0_1 noria:networkInterfaceConnects noria:NL_LAN_Segment1 .
noria:NI_RouterCore01_Gi0_0_2 noria:networkInterfaceConnects noria:NL_WAN_ISP_Link .
noria:NI_WebSrv01_Eth0 noria:networkInterfaceConnects noria:NL_LAN_Segment1 . # Assuming VMs are on the same LAN segment

# =============================================================================
# Applications and Services
