# =============================================================================
# 5. Network Interfaces and Links
# =============================================================================

# Network Interfaces
noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS_Server_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to core network" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_Web_Server_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to load balancer" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_DBSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DB Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DB_Server_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to application network" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_CR01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface on Core Router 01 connecting to internal network."@en ;
    noria:networkInterfaceOf noria:Resource_Core_Router_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Internal LAN segment" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkInterface_CR01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface on Core Router 01 connecting to external network (ISP)."@en ;
    noria:networkInterfaceOf noria:Resource_Core_Router_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "ISP Uplink" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_ES01_Fa0_1 a noria:NetworkInterface ;
    rdfs:label "ES01 FastEthernet 0/1"@en ;
    rdfs:comment "Interface on Edge Switch 01 connecting to end-user devices."@en ;
    noria:networkInterfaceOf noria:Resource_Edge_Switch_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "User access port" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_FW01_Ext a noria:NetworkInterface ;
    rdfs:label "FW01 External Interface"@en ;
    rdfs:comment "External interface of Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to ISP router" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_FW01_Int a noria:NetworkInterface ;
    rdfs:label "FW01 Internal Interface"@en ;
    rdfs:comment "Internal interface of Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to core router" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_LB01_Int a noria:NetworkInterface ;
    rdfs:label "LB01 Internal Interface"@en ;
    rdfs:comment "Internal interface of Load Balancer 01, connecting to web servers."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Backend server pool" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_LB01_Ext a noria:NetworkInterface ;
    rdfs:label "LB01 External Interface"@en ;
    rdfs:comment "External interface of Load Balancer 01, receiving client traffic."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Client-facing interface" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# Network Links
noria:NetworkLink_DNS_CR01 a noria:NetworkLink ;
    rdfs:label "Link DNS01 to CR01"@en ;
    rdfs:comment "Physical link between DNS Server 01 and Core Router 01."@en ;
    noria:networkLinkId "NL-DNS-CR-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS_Server_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Core_Router_01 ;
    noria:resourceManagedBy org:NetworkServices .

noria:NetworkLink_CR01_FW01 a noria:NetworkLink ;
    rdfs:label "Link CR01 to FW01"@en ;
    rdfs:comment "Link between Core Router 01 and Perimeter Firewall 01."@en ;
    noria:networkLinkId "NL-CR-FW-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-04-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_Gi0_0_2 ;
    noria:networkInterfaceConnects noria:NetworkInterface_FW01_Int ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Core_Router_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall_01 ;
    noria:resourceManagedBy org:NetworkServices .

