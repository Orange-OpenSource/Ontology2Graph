    rdfs:label "TT-2024-04-20-001 Status InProgress"@en ;
    noria:loggingTime "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-2024-04-20-001 status changed to InProgress."@en ;
    noria:logOriginatingManagedObject noria:TroubleTicket_DNS_Outage ;
    noria:logOriginatingAgent org:NetworkServices .

noria:TroubleTicket_DNS_Outage noria:documentStatusHistory noria:EventRecord_TT_DNS_Status_InProgress .

