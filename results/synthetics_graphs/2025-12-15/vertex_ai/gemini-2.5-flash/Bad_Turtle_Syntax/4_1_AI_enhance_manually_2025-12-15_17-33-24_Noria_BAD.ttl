En tant qu'expert en modélisation de graphes de connaissances RDF/OWL et en syntaxe Turtle, je vais générer un graphe de connaissances complet, dense et connecté, en respectant scrupuleusement le vocabulaire NORIA fourni.

@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# =============================================================================
# 1. Agents and Organizations
# =============================================================================

# Organizational Units (Teams)
org:ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department responsible for all IT operations."@en .

org:NetworkServices a org:OrganizationalUnit ;
    rdfs:label "Network Services Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:subOrganizationOf org:ITDepartment .

org:ApplicationServices a org:OrganizationalUnit ;
    rdfs:label "Application Services Team"@en ;
    rdfs:comment "Team responsible for managing business applications."@en ;
    org:subOrganizationOf org:ITDepartment .

org:SecurityOperationsCenter a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:subOrganizationOf org:ITDepartment .

org:CustomerSupport a org:OrganizationalUnit ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "First-line support for customer issues."@en ;
    org:subOrganizationOf org:ITDepartment .

# Individual Agents (Persons)
foaf:Agent_JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Network Engineer responsible for core infrastructure."@en ;
    org:memberOf org:NetworkServices ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via internal ticketing system for non-urgent issues."@en .

foaf:Agent_JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead Application Developer for WebApp Portal."@en ;
    org:memberOf org:ApplicationServices ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TeamsChat> ;
    noria:agentInstructions "For critical issues, use emergency phone number."@en .

foaf:Agent_AliceBrown a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Brown"@en ;
    rdfs:comment "Security Analyst at the SOC."@en ;
    org:memberOf org:SecurityOperationsCenter ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Pager> ;
    noria:agentInstructions "Always page for critical security alerts."@en .

foaf:Agent_BobWhite a foaf:Person, foaf:Agent ;
    rdfs:label "Bob White"@en ;
    rdfs:comment "Customer Support Representative."@en ;
    org:memberOf org:CustomerSupport ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Sat)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate to L2 support for technical issues."@en .

# Corporate User Identifiers
noria:CorporateUserIdentifier_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CorporateUserIdentifier_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

# =============================================================================
# 2. Locations
# =============================================================================

# Sites
bot:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

bot:Site_BranchOfficeA a bot:Site ;
    rdfs:label "Branch Office A"@en ;
    rdfs:comment "Smaller office location with local network infrastructure."@en ;
    noria:siteId "BOA01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Business Road"@en ;
    noria:sitePrincipalAddressCityName "Smallville"@en ;
    noria:sitePrincipalAddressPostalCode "20002"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

# Rooms
noria:Room_ServerRoomDC1 a noria:Room ;
    rdfs:label "Server Room DC1"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace bot:Site_MainDataCenter .

noria:Room_NetworkClosetBOA a noria:Room ;
    rdfs:label "Network Closet BOA"@en ;
    rdfs:comment "Network equipment closet in Branch Office A."@en ;
    bot:hasSpace bot:Site_BranchOfficeA .

# Loci
noria:Locus_RackA1_U10 a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Specific location for a server in Server Room DC1."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "10"@en ;
    bot:hasSpace noria:Room_ServerRoomDC1 .

noria:Locus_RackB2_U5 a noria:Locus ;
    rdfs:label "Rack B2, Unit 5"@en ;
    rdfs:comment "Specific location for a router in Server Room DC1."@en ;
    noria:locusLine "B2"@en ;
    noria:locusRow "5"@en ;
    bot:hasSpace noria:Room_ServerRoomDC1 .

noria:Locus_WallMountBOA a noria:Locus ;
    rdfs:label "Wall Mount BOA"@en ;
    rdfs:comment "Location for network switch in Network Closet BOA."@en ;
    noria:locusLine "Wall"@en ;
    noria:locusRow "1"@en ;
    bot:hasSpace noria:Room_NetworkClosetBOA .

# =============================================================================
# 3. Product Models
# =============================================================================

noria:ProductModel_DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy org:DellTechnologies .

noria:ProductModel_CiscoCatalyst9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch."@en ;
    noria:productManufacturedBy org:CiscoSystems .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "Modular router for service provider and enterprise applications."@en ;
    noria:productManufacturedBy org:JuniperNetworks .

noria:ProductModel_PaloAltoFirewall a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy org:PaloAltoNetworks .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi"@en ;
    rdfs:comment "Hypervisor for virtualized environments."@en ;
    noria:productManufacturedBy org:VMware .

noria:ProductModel_F5BIGIP a noria:ProductModel ;
    rdfs:label "F5 BIG-IP iSeries"@en ;
    rdfs:comment "Application delivery controller and load balancer."@en ;
    noria:productManufacturedBy org:F5Networks .

# Manufacturers (Organizations)
org:DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

org:CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

org:JuniperNetworks a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en .

org:PaloAltoNetworks a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "American multinational cybersecurity company."@en .

org:VMware a org:Organization ;
    rdfs:label "VMware"@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

org:F5Networks a org:Organization ;
    rdfs:label "F5 Networks"@en ;
    rdfs:comment "Company that specializes in application delivery networking (ADN) technology."@en .

