# =============================================================================

# Operation Plans
noria:OperationPlan_DNS_Failover_Procedure a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over DNS services to a secondary server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNS_Primary_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_Service_Restored .

noria:OperationPlan_WebApp_Restart_Procedure a noria:OperationPlan ;
    rdfs:label "Web Application Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting the web application portal services."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebApp_Performance_Degraded ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebApp_Performance_Normal .

noria:OperationPlan_Firewall_Rule_Add_Procedure a noria:OperationPlan ;
    rdfs:label "Firewall Rule Addition Procedure"@en ;
    rdfs:comment "Standard procedure for adding new rules to the perimeter firewall."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Firewall_Change_Approved ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Firewall_Rule_Active .

noria:OperationPlan_Router_Interface_Troubleshoot a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues with router interfaces."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Router_Interface_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Router_Interface_Up .

# Action Pre-Conditions
noria:ActionPreCondition_DNS_Primary_Down a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Down"@en ;
    rdfs:comment "Condition: Primary DNS server is unresponsive or unreachable."@en .

noria:ActionPreCondition_WebApp_Performance_Degraded a noria:ActionPreCondition ;
    rdfs:label "Web App Performance Degraded"@en ;
    rdfs:comment "Condition: Web application response times are consistently above threshold."@en .

noria:ActionPreCondition_Firewall_Change_Approved a noria:ActionPreCondition ;
    rdfs:label "Firewall Change Approved"@en ;
    rdfs:comment "Condition: The change request for firewall rule modification has been formally approved."@en .

noria:ActionPreCondition_Router_Interface_Down a noria:ActionPreCondition ;
    rdfs:label "Router Interface Operational Status Down"@en ;
    rdfs:comment "Condition: A critical router interface's operational status is 'down'."@en .

# Action Post-Conditions
noria:ActionPostCondition_DNS_Service_Restored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Expected outcome: DNS resolution is functional and stable."@en .

noria:ActionPostCondition_WebApp_Performance_Normal a noria:ActionPostCondition ;
    rdfs:label "Web App Performance Normal"@en ;
    rdfs:comment "Expected outcome: Web application response times are within acceptable limits."@en .

noria:ActionPostCondition_Firewall_Rule_Active a noria:ActionPostCondition ;
    rdfs:label "Firewall Rule Active"@en ;
    rdfs:comment "Expected outcome: The new firewall rule is correctly configured and active."@en .

noria:ActionPostCondition_Router_Interface_Up a noria:ActionPostCondition ;
    rdfs:label "Router Interface Operational Status Up"@en ;
    rdfs:comment "Expected outcome: The router interface's operational status is 'up'."@en .

# Anomaly Patterns
noria:AnomalyPattern_DNS_Resolution_Failure_Pattern a noria:AnomalyPattern ;
    rdfs:label "DNS Resolution Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a widespread DNS resolution failure, often linked to primary DNS server issues."@en ;
    skos:example "Multiple 'DNS_SERVER_ERROR' events from various clients, coupled with 'DNS_SERVER_OUTAGE' alerts."@en .

noria:AnomalyPattern_High_CPU_Low_Throughput_Pattern a noria:AnomalyPattern ;
    rdfs:label "High CPU Low Throughput Pattern"@en ;
    rdfs:comment "Pattern indicating a performance bottleneck where a server has high CPU usage but low network throughput, suggesting application-level issues or resource starvation."@en ;
    skos:example "Simultaneous 'CPU_UTILIZATION_HIGH' alerts and 'NETWORK_THROUGHPUT_LOW' metrics on the same server."@en .

# Linking actions to operation plans
noria:TroubleTicketNote_DNS_Diag_1 noria:troubleTicketNoteCorrelatedExecution noria:OperationPlan_DNS_Failover_Procedure .
noria:TroubleTicketNote_WebApp_Fix_1 noria:troubleTicketNoteCorrelatedExecution noria:OperationPlan_WebApp_Restart_Procedure .
noria:ChangeRequest_Firewall_Rule_Add noria:actionCorrelatedOperationPlan noria:OperationPlan_Firewall_Rule_Add_Procedure .

