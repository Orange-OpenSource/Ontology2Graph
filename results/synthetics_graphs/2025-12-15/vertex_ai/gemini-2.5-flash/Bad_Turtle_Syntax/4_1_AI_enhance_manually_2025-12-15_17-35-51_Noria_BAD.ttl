noria:ApplicationModule_CIA_Prod noria:applicationModuleSupportGroup org:OrgUnit_NetworkOperations ;
    noria:applicationModuleHotlineGroup org:OrgUnit_NetworkOperations .

noria:ApplicationModule_CRM_Prod noria:applicationModuleSupportGroup org:OrgUnit_ApplicationSupport ;
    noria:applicationModuleHotlineGroup org:OrgUnit_ApplicationSupport .

# Trouble ticket characteristic
noria:TroubleTicket_DNSOutage001 noria:troubleTicketCharacteristic noria:TroubleTicketCharacteristic_ImpactScope .

noria:TroubleTicketCharacteristic_ImpactScope a noria:Property ; # noria:Property is an abstract class, but can be instantiated for characteristics
    rdfs:label "Impact Scope"@en ;
    rdfs:comment "Characteristic describing the scope of impact for a trouble ticket."@en ;
    skos:example "Global, Regional, Local"@en .

# Trouble ticket freeze item (represented by an EventRecord)
noria:TroubleTicket_DNSOutage001 noria:troubleTicketFreezeItem noria:EventRecord_DNSOutageFreeze .

noria:EventRecord_DNSOutageFreeze a noria:EventRecord ;
    rdfs:label "DNS Outage Freeze Event"@en ;
    rdfs:comment "Event indicating the DNS outage ticket was temporarily frozen for external dependency."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Trouble Ticket TT-2024-04-20-001 status changed to Frozen due to ISP outage."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Indeterminate> .

# Change request status history
noria:ChangeRequest_RouterUpgrade001 noria:documentStatusHistory noria:EventRecord_CRApprovedLog .

noria:EventRecord_CRApprovedLog a noria:EventRecord ;
    rdfs:label "Change Request Approved Log"@en ;
    rdfs:comment "Log entry indicating approval of Router OS Upgrade Change Request."@en ;
    noria:loggingTime "2024-04-25T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ; # Or a Change Management System
    noria:logOriginatingAgent foaf:Agent_NetworkOpsTeam ;
    noria:logText "Change Request CR-2024-04-15-001 approved by Change Advisory Board."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Indeterminate> .

