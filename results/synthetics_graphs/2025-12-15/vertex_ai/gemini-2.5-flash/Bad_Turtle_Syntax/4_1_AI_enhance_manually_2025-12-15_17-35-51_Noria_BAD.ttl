# Additional Connectivity and Density
# =============================================================================

# Linking agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_DNSAdminTeam noria:agentManagesResource noria:Resource_DNS01 .
foaf:Agent_NetworkOpsTeam noria:agentManagesResource noria:Resource_RouterCore01, noria:Resource_DRRouter01, noria:Resource_FirewallDMZ, noria:Resource_LoadBalancer01 .
foaf:Agent_AppSupportTeam noria:agentManagesResource noria:Resource_AppServer01 .
foaf:Agent_DBA_JohnDoe noria:agentManagesResource noria:Resource_VirtualDB01 .
foaf:Agent_SecurityTeam noria:agentManagesResource noria:Resource_FirewallDMZ .

# Linking applications to resources (inverse of resourceForApplication)
noria:Resource_RouterCore01 noria:resourceForApplication noria:Application_CorporateInternetAccess .
noria:Resource_FirewallDMZ noria:resourceForApplication noria:Application_CorporateInternetAccess .
noria:Resource_AppServer01 noria:resourceForApplication noria:Application_CRMSystem .
noria:Resource_VirtualDB01 noria:resourceForApplication noria:Application_CRMSystem .
noria:Resource_LoadBalancer01 noria:resourceForApplication noria:Application_CRMSystem .

# Linking EventRecords to TroubleTickets via documentStatusHistory
noria:TroubleTicket_DNSOutage001 noria:documentStatusHistory noria:EventRecord_DNSOutageLog .
noria:TroubleTicket_DNSOutage001 noria:documentStatusHistory noria:EventRecord_DNSOutageResolvedLog .

# Linking ChangeRequests to EventRecords (e.g., for audit logs of changes)
noria:ChangeRequest_RouterUpgrade001 noria:documentStatusHistory noria:EventRecord_RouterConfigChangeLog . # Assuming such a log exists
noria:EventRecord_RouterConfigChangeLog a noria:EventRecord ;
    rdfs:label "Router Config Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on router-core01."@en ;
    noria:loggingTime "2024-05-01T02:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_NetworkOpsTeam ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by NetworkOpsTeam (10.0.0.50)."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Indeterminate> .

# Example of a cluster controller
noria:Resource_HypervisorCluster a noria:Resource ;
    rdfs:label "VMware vCenter Cluster"@en ;
    rdfs:comment "Management cluster for virtual machines."@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy foaf:Agent_SysAdmin_JaneSmith .

noria:Resource_VirtualDB01 noria:clusterController noria:Resource_HypervisorCluster .
noria:Resource_AppServer01 noria:clusterController noria:Resource_HypervisorCluster .

# Example of alarm mitigation
noria:EventRecord_AppServerHighCPU noria:alarmMitigatedBy noria:TroubleTicketNote_CRM01_Note1 . # The note describes the action that mitigated the alarm

# Example of proposed repair action for an alarm
noria:EventRecord_RouterInterfaceDown noria:alarmProposedRepairAction noria:OperationPlan_TroubleshootNetworkLink .

noria:OperationPlan_TroubleshootNetworkLink a noria:OperationPlan ;
    rdfs:label "Troubleshoot Network Link Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network link issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_LinkStatusCheck ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LinkRestored .

noria:ActionPreCondition_LinkStatusCheck a noria:ActionPreCondition ;
    rdfs:label "Link Status Pre-Check"@en ;
    rdfs:comment "Verify current administrative and operational status of the network interface."@en .

noria:ActionPostCondition_LinkRestored a noria:ActionPostCondition ;
    rdfs:label "Link Restored Verification"@en ;
    rdfs:comment "Confirm network link is operational and traffic is flowing."@en .

# More detailed network interface properties
noria:NetworkInterface_RouterCore01_Gi0_0_1 noria:networkInterfaceLaserRxHighPowerWarningThreshold -3 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

