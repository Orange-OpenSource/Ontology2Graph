# =============================================================================
# Operational Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_RouterOSUpgrade a noria:OperationPlan ;
    rdfs:label "Standard Router OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the operating system of core routers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterConnectivityCheck ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterOperationalCheck ;
    noria:actionCorrelatedOperationPlan noria:ChangeRequest_RouterUpgrade001 .

noria:ActionPreCondition_RouterConnectivityCheck a noria:ActionPreCondition ;
    rdfs:label "Router Connectivity Pre-Check"@en ;
    rdfs:comment "Verify reachability to the router and its management interfaces before starting the upgrade."@en ;
    skos:example "Ping management IP, SSH access, BGP neighbor status."@en .

noria:ActionPostCondition_RouterOperationalCheck a noria:ActionPostCondition ;
    rdfs:label "Router Operational Post-Check"@en ;
    rdfs:comment "Confirm router is fully operational after upgrade, including routing protocols and interface status."@en ;
    skos:example "Verify BGP peers are up, all interfaces are up/up, no critical alarms."@en .

noria:OperationPlan_DBMigration a noria:OperationPlan ;
    rdfs:label "CRM Database Migration Procedure"@en ;
    rdfs:comment "Procedure for migrating the CRM database to a new server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBBackupComplete ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBAccessVerified ;
    noria:actionCorrelatedOperationPlan noria:ChangeRequest_DBMigration002 .

noria:ActionPreCondition_DBBackupComplete a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completion Check"@en ;
    rdfs:comment "Ensure a full, verified backup of the CRM database is completed before migration."@en .

noria:ActionPostCondition_DBAccessVerified a noria:ActionPostCondition ;
    rdfs:label "Database Access Verification"@en ;
    rdfs:comment "Verify that applications can connect to and query the migrated database successfully."@en .

noria:AnomalyPattern_HighCPU_DBLatency a noria:AnomalyPattern ;
    rdfs:label "High CPU & Database Latency Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential database performance issue: high CPU on DB server combined with increased database query latency."@en ;
    folio:hasCause noria:TroubleTicket_CRMPerfIssue002 . # Linking an anomaly pattern to a trouble ticket as a potential cause

noria:AnomalyPattern_NetworkInterfaceFlap a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating an unstable network link: repeated up/down transitions on a network interface."@en ;
    folio:hasCause noria:TroubleTicket_NetworkLinkDown003 .

