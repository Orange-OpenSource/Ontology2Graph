noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating an interface on router-core01 went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DBA_LoginFailure a noria:EventRecord ;
    rdfs:label "DBA Login Failure"@en ;
    rdfs:comment "Failed login attempt by John Doe on the virtual database server."@en ;
    noria:loggingTime "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_VirtualDB01 ;
    noria:logOriginatingAgent foaf:Agent_DBA_JohnDoe ;
    noria:logText "Authentication failure for user 'jdoe' from IP 172.16.0.50 on vdb01."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_FirewallBlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en ;
    rdfs:comment "Firewall alert indicating blocked suspicious traffic to DMZ."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "FW-ALERT: Blocked inbound traffic from 1.2.3.4 to 10.0.1.10 (DMZ Web Server) on port 8080."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord_AppServerHighCPU a noria:EventRecord ;
    rdfs:label "App Server High CPU Alert"@en ;
    rdfs:comment "Monitoring alert for high CPU utilization on Application Server 01."@en ;
    noria:loggingTime "2024-04-20T09:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "ALERT: appserver01 CPU utilization exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DNSOutageResolvedLog a noria:EventRecord ;
    rdfs:label "DNS Server Reachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became reachable again."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "OK: Host dns01.corp.example.com is UP - DNS service reachable."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Indeterminate> .

