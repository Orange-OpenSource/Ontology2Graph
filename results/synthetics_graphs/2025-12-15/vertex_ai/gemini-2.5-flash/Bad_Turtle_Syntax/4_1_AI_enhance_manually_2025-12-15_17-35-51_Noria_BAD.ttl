Voici un graphe de connaissances détaillé, dense et connecté, modélisé en Turtle, respectant scrupuleusement le vocabulaire NORIA fourni. J'ai veillé à maximiser le nombre d'entités et de relations, tout en assurant une parfaite conformité syntaxique et une organisation claire.

@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix time: <http://www.w3.org/2006/time#> .

# =============================================================================
# SKOS Concepts (simulated for demonstration based on vocabulary patterns)
# =============================================================================

# Application Types
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure Application"@en .
<kos/application/type/business> a skos:Concept ; skos:prefLabel "Business Application"@en .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring Application"@en .
<kos/application/type/security> a skos:Concept ; skos:prefLabel "Security Application"@en .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; skos:prefLabel "Low Business Importance"@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:prefLabel "En Production"@fr .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en ; skos:prefLabel "En Développement"@fr .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:prefLabel "Maintenance"@en ; skos:prefLabel "En Maintenance"@fr .

# Service Types
<kos/service/type/customer-facing> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en .
<kos/service/type/resource-facing> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en .
<kos/service/type/internal> a skos:Concept ; skos:prefLabel "Internal Service"@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en .
<kos/TroubleTicket/severity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en .

# Trouble Ticket Type
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:prefLabel "Failure"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:prefLabel "Assistance"@en .
<kos/TroubleTicket/type/Maintenance> a skos:Concept ; skos:prefLabel "Maintenance"@en .

# Trouble Ticket Criticity
<kos/TroubleTicket/category/InterruptedService> a skos:Concept ; skos:prefLabel "Interrupted Service"@en .
<kos/TroubleTicket/category/CorruptedService> a skos:Concept ; skos:prefLabel "Corrupted Service"@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer Origin"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision System Origin"@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency/Immediate> a skos:Concept ; skos:prefLabel "Immediate Intervention"@en .
<kos/TroubleTicket/urgency/Deferred> a skos:Concept ; skos:prefLabel "Deferred Intervention"@en .

# Trouble Ticket Trouble Category
<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ; skos:prefLabel "Network Outage"@en .
<kos/TroubleTicket/trouble-category/ServerFailure> a skos:Concept ; skos:prefLabel "Server Failure"@en .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ; skos:prefLabel "Network Team"@en .
<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ; skos:prefLabel "Application Team"@en .

# Trouble Ticket Status
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved"@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; skos:prefLabel "Closed"@en .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:prefLabel "Customer Comment"@en .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis Operation"@en .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; skos:prefLabel "Resolution Operation"@en .

# Change Request Category
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; skos:prefLabel "Internal Intervention"@en .
<kos/ChangeRequest/category/CustomerRequest> a skos:Concept ; skos:prefLabel "Customer Requested Change"@en .

# Change Request Type
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:prefLabel "Emergency Change"@en .

# Change Request Cause
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; skos:prefLabel "Configuration Change"@en .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; skos:prefLabel "Software Upgrade"@en .

# Change Request Status
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:prefLabel "Approved"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; skos:prefLabel "Implemented"@en .

# Change Request Specification
<kos/ChangeRequest/specification/NetworkConfigUpdate> a skos:Concept ; skos:prefLabel "Network Configuration Update Plan"@en .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Operational Up"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Operational Down"@en .

# Resource Administrative State
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ; skos:prefLabel "Administrative Enabled"@en .
<kos/Resource/AdministrativeState/Disabled> a skos:Concept ; skos:prefLabel "Administrative Disabled"@en .

# Resource Type
<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server"@en .
<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router"@en .
<kos/Resource/type/Switch> a skos:Concept ; skos:prefLabel "Switch"@en .
<kos/Resource/type/Firewall> a skos:Concept ; skos:prefLabel "Firewall"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine"@en .
<kos/Resource/type/LoadBalancer> a skos:Concept ; skos:prefLabel "Load Balancer"@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InUse> a skos:Concept ; skos:prefLabel "In Use"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:prefLabel "Decommissioned"@en .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:prefLabel "Minor Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ; skos:prefLabel "Indeterminate Perceived Severity"@en .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone"@en .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; skos:prefLabel "Ticketing System"@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, call the on-call number after hours."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use the dedicated incident hotline for immediate network issues."@en .

foaf:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket via the internal portal for all application-related problems."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report all suspected security breaches immediately."@en .

foaf:Agent_DBA_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe (DBA)"@en ;
    rdfs:comment "Database Administrator responsible for critical databases."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_SysAdmin_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith (System Admin)"@en ;
    rdfs:comment "System Administrator for virtual infrastructure."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "Main IT department of the company."@en .

org:OrgUnit_NetworkOperations a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Sub-unit of IT Department focused on network operations."@en ;
    org:unitOf org:Org_ITDepartment ;
    noria:applicationModuleSupportTeam foaf:Agent_NetworkOpsTeam .

org:OrgUnit_ApplicationSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support Unit"@en ;
    rdfs:comment "Sub-unit of IT Department focused on application support."@en ;
    org:unitOf org:Org_ITDepartment ;
    noria:applicationModuleSupportTeam foaf:Agent_AppSupportTeam .

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "jdoe"@en ;
    rdfs:comment "Corporate User ID for John Doe."@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "jsmith"@en ;
    rdfs:comment "Corporate User ID for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    observable:accountLogin "jsmith" .

# =============================================================================
# Locations
# =============================================================================

bot:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "USA"@en .

bot:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary data center for disaster recovery purposes."@en ;
    noria:siteId "DR01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "456 Backup Road"@en ;
    noria:sitePrincipalAddressCityName "Gotham City"@en ;
    noria:sitePrincipalAddressPostalCode "20002"@en ;
    noria:sitePrincipalAddressCountry "USA"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within DC01."@en ;
    bot:hasSpace bot:Site_MainDataCenter .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room within DC01."@en ;
    bot:hasSpace bot:Site_MainDataCenter .

noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "23"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5_U10 a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Specific location for a router in Network Room B."@en ;
    noria:locusLine "B5"@en ;
    noria:locusRow "10"@en ;
    bot:hasSpace noria:Room_NetworkRoomB .

