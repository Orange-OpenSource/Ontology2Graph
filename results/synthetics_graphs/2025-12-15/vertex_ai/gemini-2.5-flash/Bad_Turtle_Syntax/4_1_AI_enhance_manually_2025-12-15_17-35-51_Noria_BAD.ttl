# =============================================================================
# Network Interfaces and Links
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface 0 on DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_DC01_LAN .

noria:NetworkInterface_RouterCore01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "router-core01-Gi0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/0 on Core Router 01, connecting to internal LAN."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:NetworkLink_DC01_LAN .

noria:NetworkInterface_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "router-core01-Gi0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/1 on Core Router 01, connecting to WAN."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -7 ;
    noria:networkInterfaceConnects noria:NetworkLink_WAN_DC01_DR01 .

noria:NetworkInterface_AppServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "appserver01-eth0"@en ;
    rdfs:comment "Ethernet interface 0 on Application Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_AppServer01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_DC01_LAN .

noria:NetworkInterface_VirtualDB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "vdb01-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface on Virtual Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_VirtualDB01 ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_DC01_DB_LAN .

noria:NetworkInterface_FirewallDMZ_Eth0 a noria:NetworkInterface ;
    rdfs:label "fw-dmz01-eth0"@en ;
    rdfs:comment "External interface of DMZ Firewall."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
