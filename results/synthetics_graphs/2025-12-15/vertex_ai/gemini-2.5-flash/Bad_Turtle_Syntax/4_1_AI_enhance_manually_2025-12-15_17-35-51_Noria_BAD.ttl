    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy org:Org_VMware .

org:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

org:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

org:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, located in DC01."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_10 .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main core router for the corporate network, located in DC01."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2020-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB5_U10 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_1 .

noria:Resource_AppServer01 a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting critical business applications."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam ;
    noria:resourceHostName "appserver01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceLogisticId "LOG-APP-001" ;
    noria:resourceSerialNumber "SN-APP-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-06-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_20 .

noria:Resource_VirtualDB01 a noria:Resource ;
    rdfs:label "Virtual Database Server 01"@en ;
    rdfs:comment "Virtual machine hosting the main corporate database."@en ;
    noria:resourceManagedBy foaf:Agent_DBA_JohnDoe ;
    noria:resourceHostName "vdb01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:IPAddress_172_16_0_10 .

noria:Resource_FirewallDMZ a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:comment "Firewall protecting the DMZ segment."@en ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:resourceHostName "fw-dmz01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1K ; # Placeholder, assuming Cisco also makes firewalls or similar appliances
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-09-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_1_1 .

noria:Resource_LoadBalancer01 a noria:Resource ;
    rdfs:label "Web Load Balancer 01"@en ;
    rdfs:comment "Load balancer for public-facing web applications."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "lb-web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ; # Can be a hardware appliance or software on a server
    noria:resourceType <kos/Resource/type/LoadBalancer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-03-20T13:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_2_1 .

observable:IPAddress_192_168_1_10 a observable:IPAddress ; rdfs:label "192.168.1.10"@en .
observable:IPAddress_10_0_0_1 a observable:IPAddress ; rdfs:label "10.0.0.1"@en .
observable:IPAddress_192_168_1_20 a observable:IPAddress ; rdfs:label "192.168.1.20"@en .
