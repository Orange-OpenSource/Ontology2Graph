# =============================================================================
# Further Interconnections and Density
# =============================================================================

# Link resources to applications they support
noria:Resource_WebServer01 noria:resourceForApplication noria:App_CustomerPortal .
noria:Resource_WebServer02 noria:resourceForApplication noria:App_CustomerPortal .
noria:Resource_DBServer01 noria:resourceForApplication noria:App_CustomerPortal .
noria:Resource_CoreRouter01 noria:resourceForApplication noria:App_MonitoringSystem .
noria:Resource_AccessSwitch01 noria:resourceForApplication noria:App_MonitoringSystem .

# Link agents to resources they manage (inverse of resourceManagedBy)
org:ITOperationsDept noria:agentManagesResource noria:Resource_WebServer01, noria:Resource_WebServer02 .
org:DatabaseAdminTeam noria:agentManagesResource noria:Resource_DBServer01 .
org:NetworkOperationsCenter noria:agentManagesResource noria:Resource_CoreRouter01, noria:Resource_AccessSwitch01, noria:NetworkLink_WS01_ASW01, noria:NetworkLink_CR01_Internet .
org:ApplicationSupportTeam noria:agentManagesResource noria:App_CustomerPortal .

# Link applications to their modules
noria:App_CustomerPortal seas:subSystem noria:AppModule_CustomerPortal_Prod, noria:AppModule_CustomerPortal_Dev .
noria:App_MonitoringSystem seas:subSystem noria:AppModule_MonitoringSystem_Prod .

# Link trouble tickets to related parties (e.g., who is working on it)
noria:TroubleTicket_WS01_Performance noria:troubleTicketRelatedParty org:ITOperationsDept .
noria:TroubleTicket_CR01_Outage noria:troubleTicketRelatedParty foaf:Agent_JohnDoe .

# Link change requests to related parties
noria:ChangeRequest_DBUpgrade_001 dcterms:contributor foaf:Agent_JaneSmith .

# Link event records to related procedures/actions
noria:EventRecord_HighCPU_WS01 noria:alarmMitigatedBy noria:TroubleTicket_WS01_Performance .
noria:EventRecord_DBUpgrade_Log pep:wasPerformedBy foaf:Agent_JaneSmith .

# Link operation plan to anomaly pattern
noria:OperationPlan_RestartWebServer dcterms:conformsTo noria:AnomalyPattern_WebServerOverload .

# Example of a virtual server status
noria:Resource_WebServer01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
noria:Resource_WebServer02 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Example of network interface optical power metrics
noria:NetworkInterface_CR01_GigE0_0_0 noria:networkInterfaceLaserTxOpticalPower -2^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower -3^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -3^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10^^xsd:int .

