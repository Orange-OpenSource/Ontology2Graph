# =============================================================================
# Organization and Agent Entities
# =============================================================================

org:GlobalTechCorp a org:Organization ;
    rdfs:label "GlobalTech Corporation"@en ;
    rdfs:comment "A multinational technology company."@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Innovation City"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "USA"@en .

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for managing IT infrastructure and operations."@en ;
    org:unitOf org:GlobalTechCorp .

org:DatabaseAdminTeam a org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team specializing in database management and support."@en ;
    org:unitOf org:ITOperationsDept .

org:NetworkOperationsCenter a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "Team responsible for monitoring and managing network infrastructure."@en ;
    org:unitOf org:ITOperationsDept .

org:ApplicationSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    org:unitOf org:ITOperationsDept .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer in the IT Operations Department."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-critical issues, phone for critical incidents."@en .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Database Administrator."@en ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call directly for database emergencies."@en .

foaf:Agent_NOCBot a foaf:Agent ;
    rdfs:label "NOC Monitoring Bot"@en ;
    rdfs:comment "Automated agent for network monitoring and alert generation."@en .

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en .

# =============================================================================
# Location Entities
# =============================================================================

bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center for GlobalTech Corp."@en ;
    noria:siteId "DC01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "456 Server Lane"@en ;
    noria:sitePrincipalAddressCityName "Innovation City"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "USA"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the data center."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Room dedicated to network equipment."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5 a noria:Locus ;
    rdfs:label "Rack B5 in Network Room B"@en ;
    rdfs:comment "Specific rack location for network devices."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "5"@en ;
    bot:hasSpace noria:Room_NetworkRoomB .

