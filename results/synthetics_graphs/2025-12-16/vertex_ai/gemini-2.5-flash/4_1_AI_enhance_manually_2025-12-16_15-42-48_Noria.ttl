# Linking Change Request to Operation Plan
noria:CR001 noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterOSUpgrade .
noria:CR002 noria:actionCorrelatedOperationPlan noria:OperationPlan_DBOptimization .
noria:CR003 noria:actionCorrelatedOperationPlan noria:OperationPlan_FirewallRuleUpdate .
noria:CR004 noria:actionCorrelatedOperationPlan noria:OperationPlan_VMMigration .

# Linking Event Record to Trouble Ticket Status History (example)
noria:EventRecord_TT001_StatusChange_InProgress a noria:EventRecord ;
    rdfs:label "TT001 Status Change to InProgress"@en ;
    rdfs:comment "Internal event recording the status change of Trouble Ticket TT001 to 'In Progress'."@en ;
    noria:loggingTime "2024-04-20T08:06:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-2024-04-20-001 status changed to InProgress."@en ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:TroubleTicket_TT001 noria:documentStatusHistory noria:EventRecord_TT001_StatusChange_InProgress .

noria:EventRecord_TT002_StatusChange_InProgress a noria:EventRecord ;
    rdfs:label "TT002 Status Change to InProgress"@en ;
