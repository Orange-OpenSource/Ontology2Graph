@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizations
org:OrangeSA a org:Organization ;
    rdfs:label "Orange S.A."@en ;
    rdfs:comment "Major telecommunications operator and digital services provider."@en .

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for the day-to-day operation of IT infrastructure."@en ;
    org:unitOf org:OrangeSA .

org:NetworkTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network devices and connectivity."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical network incidents, call the on-call number. For routine requests, use the ticketing system."@en .

org:AppSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for critical business applications."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "24/7 Shift-based"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> .

org:CloudInfraTeam a org:OrganizationalUnit ;
    rdfs:label "Cloud Infrastructure Team"@en ;
    rdfs:comment "Team managing cloud-based resources and services."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en .

org:DatabaseTeam a org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database systems."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en .

org:CustomerSupport a org:OrganizationalUnit ;
    rdfs:label "Customer Support Center"@en ;
    rdfs:comment "First-line support for customer inquiries and issues."@en ;
    org:unitOf org:OrangeSA ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:VendorDell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of IT hardware and software."@en .

org:VendorCisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware and software."@en .

# Agents (Persons/Teams)
foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, responsible for core network infrastructure."@en ;
    org:memberOf org:NetworkTeam ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via corporate email for non-urgent matters. For critical issues, use the on-call rotation number."@en .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer and Team Lead for Customer Portal."@en ;
    org:memberOf org:AppSupportTeam ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Available for urgent application support during working hours."@en .

foaf:Agent_AliceJohnson a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Cloud Architect, specializing in virtualization and containerization."@en ;
    org:memberOf org:CloudInfraTeam ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

foaf:Agent_BobWhite a foaf:Agent ;
    rdfs:label "Bob White"@en ;
    rdfs:comment "Database Administrator, expert in Oracle and PostgreSQL."@en ;
    org:memberOf org:DatabaseTeam ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_SecurityAnalyst1 a foaf:Agent ;
    rdfs:label "Security Analyst 1"@en ;
    rdfs:comment "First-line security incident responder, monitoring SIEM alerts."@en ;
    org:memberOf org:SecurityTeam ;
    noria:agentWorkingHours "Shift A (06:00-14:00)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/InternalTicketing> .

foaf:Agent_CustomerServiceRep a foaf:Agent ;
    rdfs:label "Customer Service Representative"@en ;
    rdfs:comment "Handles initial customer inquiries and creates trouble tickets."@en ;
    org:memberOf org:CustomerSupport ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Login identifier for John Doe across corporate systems."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Login identifier for Jane Smith across corporate systems."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

noria:CUid_AliceJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Johnson's Corporate ID"@en ;
    rdfs:comment "Login identifier for Alice Johnson across corporate systems."@en ;
    foaf:accountName "ajohnson" ;
    foaf:holdsAccount foaf:Agent_AliceJohnson .

# =============================================================================
# Locations
# =============================================================================

bot:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris, France."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

bot:Site_LyonOffice a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office building in Lyon, France, hosting local network infrastructure."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69007"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center, housing critical IT equipment."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Room_NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in Lyon Office, containing access switches and routers."@en ;
    bot:hasSpace bot:Site_LyonOffice .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1, Server Room A"@en ;
    rdfs:comment "Physical rack location for critical servers and network devices."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_RackB5 a noria:Locus ;
    rdfs:label "Rack B5, Network Closet B"@en ;
    rdfs:comment "Physical rack location for core network routers in Lyon."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "5"@en ;
    bot:hasZone noria:Room_NetworkClosetB .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2, Server Room A"@en ;
    rdfs:comment "Physical rack location for virtualization hosts."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en ;
    bot:hasZone noria:Room_ServerRoomA .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy org:VendorDell .

noria:ProductModel_CiscoASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Modular edge router for enterprise and service provider networks."@en ;
    noria:productManufacturedBy org:VendorCisco .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series Switch"@en ;
    rdfs:comment "High-density data center switch for modern networks."@en ;
    noria:productManufacturedBy org:VendorCisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor for creating and running virtual machines."@en .

noria:ProductModel_PaloAltoFirewall a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-500 Series Firewall"@en ;
    rdfs:comment "Next-generation firewall for network security."@en .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Production Database Server 01"@en ;
    rdfs:comment "Primary database server for core business applications, hosting critical data."@en ;
    noria:resourceLogisticId "LOG-DB-001" ;
    noria:resourceHostName "dbprod01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB01-XYZ123" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:DatabaseTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router Paris 01"@en ;
    rdfs:comment "Main router for the Paris Data Center network, handling inter-DC and internet traffic."@en ;
    noria:resourceLogisticId "LOG-RTR-PAR01" ;
    noria:resourceHostName "router-par-core01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC456" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.254" .

noria:Resource_FirewallDMZ01 a noria:Resource ;
    rdfs:label "DMZ Firewall 01"@en ;
    rdfs:comment "Firewall protecting the DMZ segment, filtering public-facing application traffic."@en ;
    noria:resourceLogisticId "LOG-FW-DMZ01" ;
    noria:resourceHostName "fw-dmz01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_PaloAltoFirewall ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW01-DEF789" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:SecurityTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.253" .

noria:Resource_VMHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines for various applications."@en ;
    noria:resourceLogisticId "LOG-VMH-001" ;
    noria:resourceHostName "vmhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
    noria:resourceSerialNumber "SN-VMH01-GHI012" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:CloudInfraTeam ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.20" .

noria:Resource_WebFrontendVM01 a noria:Resource ;
    rdfs:label "Web Frontend VM 01"@en ;
    rdfs:comment "Virtual machine serving web content for the main customer-facing application."@en ;
    noria:resourceHostName "webfront01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # Represents the VM's virtual hardware
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T15:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:AppSupportTeam ;
    noria:resourceManagementIPAddress "10.0.1.10" ;
    noria:clusterController noria:Resource_VMHost01 ; # Link to its host
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

noria:Resource_SwitchAccessLyon01 a noria:Resource ;
    rdfs:label "Access Switch Lyon Office 01"@en ;
    rdfs:comment "Access layer switch in Lyon office, providing connectivity to end-user devices."@en ;
    noria:resourceLogisticId "LOG-SW-LYN01" ;
    noria:resourceHostName "switch-lyn-acc01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-SWLYN01-JKL345" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-09-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress "10.0.2.1" .

noria:Resource_LoadBalancer01 a noria:Resource ;
    rdfs:label "Application Load Balancer 01"@en ;
    rdfs:comment "Distributes incoming application traffic across multiple web servers."@en ;
    noria:resourceHostName "lb-app01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ; # Example, could be a dedicated appliance
    noria:resourceType <kos/Resource/type/LoadBalancer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-04-01T13:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:AppSupportTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.1.5" .

# =============================================================================
# Network Interfaces and Links
# =============================================================================

# Interfaces for DBServer01
noria:NI_DBServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dbprod01.corp.example.com:eth0"@en ;
    noria:networkInterfaceDescription "Primary network interface for database traffic."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

# Interfaces for RouterCore01
noria:NI_RouterCore01_Gig0_0_0 a noria:NetworkInterface ;
    rdfs:label "router-par-core01:GigabitEthernet0/0/0"@en ;
    noria:networkInterfaceDescription "Uplink to ISP A for internet access."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NI_RouterCore01_Gig0_0_1 a noria:NetworkInterface ;
    rdfs:label "router-par-core01:GigabitEthernet0/0/1"@en ;
    noria:networkInterfaceDescription "Inter-DC link to Lyon office."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -4 ;
    noria:networkInterfaceLaserRxOpticalPower -6 .

# Interfaces for FirewallDMZ01
noria:NI_FirewallDMZ01_Eth0 a noria:NetworkInterface ;
    rdfs:label "fw-dmz01:Ethernet0/0"@en ;
    noria:networkInterfaceDescription "External interface to public network, facing the internet."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_FirewallDMZ01_Eth1 a noria:NetworkInterface ;
    rdfs:label "fw-dmz01:Ethernet0/1"@en ;
    noria:networkInterfaceDescription "Internal interface to DMZ segment, connecting to load balancers."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# Interfaces for VMHost01
noria:NI_VMHost01_vSwitch0 a noria:NetworkInterface ;
    rdfs:label "vmhost01:vSwitch0"@en ;
    rdfs:comment "Virtual switch for VM connectivity, managing traffic between VMs and physical network."@en ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceOf noria:Resource_VMHost01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# Interfaces for WebFrontendVM01
noria:NI_WebFrontendVM01_Eth0 a noria:NetworkInterface ;
    rdfs:label "webfront01:eth0"@en ;
    noria:networkInterfaceDescription "Network interface for web traffic, connected to virtual switch."@en ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceOf noria:Resource_WebFrontendVM01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# Interfaces for SwitchAccessLyon01
noria:NI_SwitchAccessLyon01_Gig0_1 a noria:NetworkInterface ;
    rdfs:label "switch-lyn-acc01:GigabitEthernet0/1"@en ;
    noria:networkInterfaceDescription "Uplink to core network, connecting Lyon office to Paris DC."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceOf noria:Resource_SwitchAccessLyon01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# Interfaces for LoadBalancer01
noria:NI_LoadBalancer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "lb-app01:Ethernet0/0"@en ;
    noria:networkInterfaceDescription "External interface for incoming client connections."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_LoadBalancer01_Eth1 a noria:NetworkInterface ;
    rdfs:label "lb-app01:Ethernet0/1"@en ;
    noria:networkInterfaceDescription "Internal interface to web frontend servers."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# Network Links
noria:NL_Paris_ISP_A a noria:NetworkLink ;
    rdfs:label "Paris DC to ISP A Uplink"@en ;
    rdfs:comment "Primary internet uplink for Paris Data Center, connecting to external ISP."@en ;
    noria:networkLinkId "NL-PAR-ISP-A" ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2021-06-01T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_FirewallDMZ01 ; # Simplified, could be ISP router
    noria:resourceManagedBy org:NetworkTeam ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gig0_0_0 .

noria:NL_Paris_Lyon_DC a noria:NetworkLink ;
    rdfs:label "Paris DC to Lyon Office Interconnect"@en ;
    rdfs:comment "Dedicated MPLS VPN link between Paris Data Center and Lyon Office."@en ;
    noria:networkLinkId "NL-PAR-LYN-DC" ;
    noria:networkLinkType "MPLS VPN"@en ;
    noria:networkLinkInstallationDate "2021-06-01T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_SwitchAccessLyon01 ; # Simplified, could be another router
    noria:resourceManagedBy org:NetworkTeam ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gig0_0_1 ;
    noria:networkInterfaceConnects noria:NI_SwitchAccessLyon01_Gig0_1 .

noria:NL_DBServer_Switch a noria:NetworkLink ;
    rdfs:label "DB Server to DC Switch Link"@en ;
    rdfs:comment "Internal Ethernet link for database server connectivity within the data center."@en ;
    noria:networkLinkId "NL-DB-SW" ;
    noria:networkLinkType "Ethernet"@en ;
    noria:networkLinkInstallationDate "2022-03-15T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_DBServer01 ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:networkInterfaceConnects noria:NI_DBServer01_Eth0 .

noria:NL_VMHost_VMNetwork a noria:NetworkLink ;
    rdfs:label "VM Host to Virtual Network Link"@en ;
    rdfs:comment "Internal virtual network link within the hypervisor, connecting VMs to the physical network."@en ;
    noria:networkLinkId "NL-VMH-VMNET" ;
    noria:networkLinkType "Virtual Ethernet"@en ;
    noria:networkLinkInstallationDate "2023-02-10T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_VMHost01 ;
    noria:resourceManagedBy org:CloudInfraTeam ;
    noria:networkInterfaceConnects noria:NI_VMHost01_vSwitch0 .

noria:NL_WebFrontendVM_vSwitch a noria:NetworkLink ;
    rdfs:label "Web Frontend VM to vSwitch Link"@en ;
    rdfs:comment "Virtual link connecting Web Frontend VM to its virtual switch for network access."@en ;
    noria:networkLinkId "NL-WEBVM-VSW" ;
    noria:networkLinkType "Virtual Ethernet"@en ;
    noria:networkLinkInstallationDate "2023-05-01T15:10:00Z"^^xsd:dateTime ;
