noria:EventRecord_RouterDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on a core router, impacting connectivity."@en ;
    noria:loggingTime "2024-04-20T08:05:10Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_DBHighCPU a noria:EventRecord ;
    rdfs:label "Database High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on the production database server, potentially affecting application performance."@en ;
    noria:loggingTime "2024-04-20T09:15:22Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on dbprod01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmMonitoredAttribute "CPU_Utilization" .

noria:EventRecord_LoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Multiple failed login attempts detected on a critical application, possibly indicating a security breach attempt."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "User 'unknown_user' failed to log in 5 times to Customer Portal."@en ;
    noria:logOriginatingManagedObject noria:Application_CustomerPortal ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logOriginatingAgent noria:CUid_JohnDoe ; # Example of a user account being the source of the event, even if failed.
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Configuration change applied to the core router by an engineer, recorded for audit purposes."@en ;
    noria:loggingTime "2024-04-19T16:45:00Z"^^xsd:dateTime ;
    noria:logText "Configuration changed by jdoe from console. Added static route."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_FirewallBlocked a noria:EventRecord ;
    rdfs:label "Firewall Blocked Connection"@en ;
    rdfs:comment "Firewall log entry showing a blocked connection attempt to DMZ, indicating potential malicious activity or misconfiguration."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Blocked TCP connection from 1.2.3.4 to 10.0.0.53 on port 80."@en ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_SwitchPortError a noria:EventRecord ;
    rdfs:label "Switch Port Error"@en ;
    rdfs:comment "Error counter incremented on a switch port in Lyon office, suggesting physical layer issues."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/1 on switch-lyn-acc01 showing input errors."@en ;
    noria:logOriginatingManagedObject noria:Resource_SwitchAccessLyon01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_LoadBalancerHealthCheckFail a noria:EventRecord ;
    rdfs:label "Load Balancer Health Check Failure"@en ;
    rdfs:comment "Load balancer detected a backend server as unhealthy."@en ;
    noria:loggingTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:logText "Health check failed for webfront01.corp.example.com on port 80."@en ;
    noria:logOriginatingManagedObject noria:Resource_LoadBalancer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

