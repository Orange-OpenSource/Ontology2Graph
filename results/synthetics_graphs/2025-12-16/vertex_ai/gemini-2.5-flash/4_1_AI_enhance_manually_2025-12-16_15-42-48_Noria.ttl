# Linking Trouble Ticket Note to Correlated Execution (example)
noria:EventRecord_RouterCLI_Command a noria:EventRecord ;
    rdfs:label "Router CLI Command Execution"@en ;
    rdfs:comment "CLI command executed on router-par-core01 to bring up interface, part of troubleshooting TT001."@en ;
    noria:loggingTime "2024-04-20T08:15:00Z"^^xsd:dateTime ;
    noria:logText "Command 'no shutdown' executed on GigabitEthernet0/0/0 by jdoe."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:TroubleTicketNote_TT001_Note1 noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_RouterCLI_Command .

noria:EventRecord_DBQueryOptimization a noria:EventRecord ;
    rdfs:label "Database Query Optimization"@en ;
    rdfs:comment "Database administrator executed a query optimization script."@en ;
    noria:loggingTime "2024-05-01T01:45:00Z"^^xsd:dateTime ;
    noria:logText "Executed 'optimize_customer_queries.sql' by bwhite."@en ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingAgent foaf:Agent_BobWhite ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:ChangeRequest_CR002 noria:documentStatusHistory noria:EventRecord_DBQueryOptimization .

