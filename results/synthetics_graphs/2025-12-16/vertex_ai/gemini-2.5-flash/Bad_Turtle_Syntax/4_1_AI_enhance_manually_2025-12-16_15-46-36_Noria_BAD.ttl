# Base URI for NORIA instances
@base <https://w3id.org/noria/data/> .

# =============================================================================
# 1. Agents and Organizations
# =============================================================================

# Organizations
:Org_IT_Operations a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Central department responsible for overall IT infrastructure and service management."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentInstructions "Contact via internal ticketing system for all issues." .

:Org_Network_Team a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    org:unitOf :Org_IT_Operations ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri, on-call for critical issues" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For network outages, open a P1 ticket and call the hotline." .

:Org_Server_Team a org:OrganizationalUnit ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team responsible for server infrastructure, both physical and virtual."@en ;
    org:unitOf :Org_IT_Operations ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit all server-related requests via the service portal." .

:Org_App_Support a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    org:unitOf :Org_IT_Operations ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate application issues to L2 via the dedicated queue." .

:Org_Security_Team a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:unitOf :Org_IT_Operations ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "All security alerts are automatically routed to the SIEM. For manual reports, use the security incident portal." .

:Org_Vendor_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server and network hardware."@en .

:Org_Vendor_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

# Agents (Persons)
:Agent_Alice a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, member of Network Operations Team."@en ;
    org:memberOf :Org_Network_Team ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

:Agent_Bob a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Server Administrator, leader of Server Administration Team."@en ;
    org:memberOf :Org_Server_Team ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

:Agent_Carol a foaf:Agent ;
    rdfs:label "Carol White"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    org:memberOf :Org_App_Support ;
    foaf:mbox <mailto:carol.white@example.com> ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Chat> .

:Agent_David a foaf:Agent ;
    rdfs:label "David Green"@en ;
    rdfs:comment "Security Analyst, member of CSOC."@en ;
    org:memberOf :Org_Security_Team ;
    foaf:mbox <mailto:david.green@example.com> ;
    noria:agentWorkingHours "24/7 Shift" .

:Agent_External_Customer a foaf:Agent ;
    rdfs:label "External Customer Support"@en ;
    rdfs:comment "Represents the external customer contact point for service issues."@en .

# Corporate User Identifiers
:CUid_Alice a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount :Agent_Alice .

:CUid_Bob a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount :Agent_Bob .

:CUid_David a noria:CorporateUserIdentifier ;
    rdfs:label "David Green's Corporate ID"@en ;
    foaf:accountName "dgreen" ;
    foaf:holdsAccount :Agent_David .

# =============================================================================
# 2. Locations
# =============================================================================

:Site_HQ_DataCenter a bot:Site ;
    rdfs:label "Headquarters Data Center"@en ;
    noria:siteId "DC-HQ-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Main Street" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "USA" ;
    wgs84_pos:lat "34.0522"^^xsd:float ;
    wgs84_pos:long "-118.2437"^^xsd:float .

:Room_ServerRoom_A a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in the Headquarters Data Center."@en ;
    bot:hasSpace :Site_HQ_DataCenter .

:Locus_Rack_A1_U1 a noria:Locus ;
    rdfs:label "Rack A1, Unit 1"@en ;
    rdfs:comment "Location for server equipment in Rack A1, Unit 1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "1" ;
    bot:containsZone :Room_ServerRoom_A .

:Locus_Rack_A1_U2 a noria:Locus ;
    rdfs:label "Rack A1, Unit 2"@en ;
    rdfs:comment "Location for server equipment in Rack A1, Unit 2."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "2" ;
    bot:containsZone :Room_ServerRoom_A .

:Locus_Rack_B5_U10 a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Location for network equipment in Rack B5, Unit 10."@en ;
    noria:locusLine "B5" ;
    noria:locusRow "10" ;
    bot:containsZone :Room_ServerRoom_A .

:Site_DR_DataCenter a bot:Site ;
    rdfs:label "Disaster Recovery Data Center"@en ;
    noria:siteId "DC-DR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Lane" ;
    noria:sitePrincipalAddressCityName "Safetown" ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "USA" ;
    wgs84_pos:lat "38.9072"^^xsd:float ;
    wgs84_pos:long "-77.0369"^^xsd:float .

:Room_ServerRoom_B a noria:Room ;
    rdfs:label "Server Room B"@en ;
    rdfs:comment "DR server room in the Disaster Recovery Data Center."@en ;
    bot:hasSpace :Site_DR_DataCenter .

:Locus_Rack_C1_U1 a noria:Locus ;
    rdfs:label "Rack C1, Unit 1"@en ;
    rdfs:comment "Location for DR server equipment in Rack C1, Unit 1."@en ;
    noria:locusLine "C1" ;
    noria:locusRow "1" ;
    bot:containsZone :Room_ServerRoom_B .

