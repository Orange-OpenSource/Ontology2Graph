# =============================================================================
# 5. Network Interfaces and Links
# =============================================================================

# Network Interfaces for AppServer01
:NI_AppServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "AppServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for AppServer01."@en ;
    noria:networkInterfaceOf :Resource_AppServer01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to internal LAN." ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

# Network Interfaces for CoreRouter01
:NI_CoreRouter01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting CoreRouter01 to AppServer01's segment and EdgeSwitch01."@en ;
    noria:networkInterfaceOf :Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to server segment A and access switch." ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -5 .

:NI_CoreRouter01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/2"@en ;
    rdfs:comment "Interface connecting CoreRouter01 to Firewall01."@en ;
    noria:networkInterfaceOf :Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Link to perimeter firewall." ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -4 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -11 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -4.5 .

# Network Interfaces for Firewall01
:NI_Firewall01_Eth1_1 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet1/1"@en ;
    rdfs:comment "Internal interface of Firewall01, connected to CoreRouter01."@en ;
    noria:networkInterfaceOf :Resource_Firewall01 ;
    noria:networkInterfaceDescription "Internal interface to core network." ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3.5 ;
    noria:networkInterfaceLaserRxOpticalPower -4.2 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -11 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -4.8 .

:NI_Firewall01_Eth1_2 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet1/2"@en ;
    rdfs:comment "External interface of Firewall01, connected to ISP."@en ;
    noria:networkInterfaceOf :Resource_Firewall01 ;
    noria:networkInterfaceDescription "External interface to Internet." ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -11 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -5.5 .

# Network Interfaces for EdgeSwitch01
:NI_EdgeSwitch01_Gi0_1 a noria:NetworkInterface ;
    rdfs:label "EdgeSwitch01 GigabitEthernet0/1"@en ;
    rdfs:comment "Uplink to CoreRouter01."@en ;
    noria:networkInterfaceOf :Resource_EdgeSwitch01 ;
    noria:networkInterfaceDescription "Uplink to core network." ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

# Network Links
:NL_AppServer01_CoreRouter01 a noria:NetworkLink ;
    rdfs:label "Link AppServer01 to CoreRouter01"@en ;
    rdfs:comment "Direct link between AppServer01 and CoreRouter01."@en ;
    noria:networkLinkId "NL-AS01-CR01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects :NI_AppServer01_Eth0 ;
    noria:networkInterfaceConnects :NI_CoreRouter01_Gi0_0_1 ;
    noria:networkLinkTerminationResourceOrigin :Resource_AppServer01 ;
    noria:networkLinkTerminationResourceDestination :Resource_CoreRouter01 ;
    noria:resourceManagedBy :Org_Network_Team .

:NL_CoreRouter01_Firewall01 a noria:NetworkLink ;
    rdfs:label "Link CoreRouter01 to Firewall01"@en ;
    rdfs:comment "Internal link between CoreRouter01 and Firewall01."@en ;
    noria:networkLinkId "NL-CR01-FW01" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects :NI_CoreRouter01_Gi0_0_2 ;
    noria:networkInterfaceConnects :NI_Firewall01_Eth1_1 ;
    noria:networkLinkTerminationResourceOrigin :Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Firewall01 ;
    noria:resourceManagedBy :Org_Network_Team .

:NL_Firewall01_ISP a noria:NetworkLink ;
    rdfs:label "Link Firewall01 to ISP"@en ;
    rdfs:comment "External link from Firewall01 to Internet Service Provider."@en ;
    noria:networkLinkId "NL-FW01-ISP" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2021-05-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects :NI_Firewall01_Eth1_2 ;
    noria:resourceManagedBy :Org_Network_Team .

:NL_CoreRouter01_EdgeSwitch01 a noria:NetworkLink ;
    rdfs:label "Link CoreRouter01 to EdgeSwitch01"@en ;
    rdfs:comment "Link connecting CoreRouter01 to EdgeSwitch01."@en ;
    noria:networkLinkId "NL-CR01-ES01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-02-10T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects :NI_CoreRouter01_Gi0_0_1 ;
    noria:networkInterfaceConnects :NI_EdgeSwitch01_Gi0_1 ;
    noria:networkLinkTerminationResourceOrigin :Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination :Resource_EdgeSwitch01 ;
    noria:resourceManagedBy :Org_Network_Team .

# =============================================================================
# 6. Applications and Application Modules
# =============================================================================

:App_CorporateWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "Public-facing website for the company."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CWEB" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/BusinessApplication> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Marketing and Sales" ;
    noria:applicationFunctionalSubDomain "Online Presence Management" ;
