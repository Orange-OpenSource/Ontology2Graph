# =============================================================================
# 11. Operational Procedures and Anomaly Patterns
# =============================================================================

:OpPlan_CheckCable a noria:OperationPlan ;
    rdfs:label "Check and Replace Network Cable Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network cable issues."@en ;
    noria:operationPlanPreCondition :PreCond_InterfaceDown ;
    noria:operationPlanPostCondition :PostCond_InterfaceUp .

:PreCond_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en .

:PostCond_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up' after intervention."@en .

:OpPlanExec_CableReplacement a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Cable Replacement for TT_NetworkOutage_001"@en ;
    rdfs:comment "Container for events related to the cable replacement procedure."@en ;
    pep:hasProcedure :OpPlan_CheckCable ;
    dcterms:created "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_Alice .

:AnomalyPattern_HighCPU_SlowResponse a noria:AnomalyPattern ;
    rdfs:label "High CPU & Slow Application Response"@en ;
    rdfs:comment "Anomaly pattern indicating a potential performance bottleneck: sustained high CPU utilization on a server correlated with slow application response times."@en ;
    folio:hasCause "Unoptimized code or resource exhaustion" ;
    folio:hasControlMethod :OpPlan_OptimizeDBQueries .

:OpPlan_OptimizeDBQueries a noria:OperationPlan ;
    rdfs:label "Optimize Database Queries Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing slow database queries."@en ;
    noria:operationPlanPreCondition :AnomalyPattern_HighCPU_SlowResponse ;
    noria:operationPlanPostCondition :PostCond_AppPerformanceRestored .

:PostCond_AppPerformanceRestored a noria:ActionPostCondition ;
    rdfs:label "Application Performance Restored"@en ;
    rdfs:comment "Expected outcome: Application response times return to normal, and CPU utilization stabilizes."@en .

:OpPlanExec_DBOptimization a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of DB Optimization for TT_WebsiteDegradation_002"@en ;
    rdfs:comment "Container for events related to database query optimization."@en ;
    pep:hasProcedure :OpPlan_OptimizeDBQueries ;
    dcterms:created "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_Carol .

:OpPlan_FirewallRuleAdd a noria:OperationPlan ;
    rdfs:label "Add Firewall Rule Procedure"@en ;
    rdfs:comment "Standard procedure for adding new firewall rules."@en ;
    noria:operationPlanPreCondition :PreCond_NewAppTrafficNeeded ;
    noria:operationPlanPostCondition :PostCond_TrafficFlows .

:PreCond_NewAppTrafficNeeded a noria:ActionPreCondition ;
    rdfs:label "New Application Traffic Required"@en ;
    rdfs:comment "Condition: A new application requires specific network traffic to be allowed through the firewall."@en .

:PostCond_TrafficFlows a noria:ActionPostCondition ;
    rdfs:label "New Traffic Flows Successfully"@en ;
    rdfs:comment "Expected outcome: Network traffic for the new application flows as expected through the firewall."@en .

:AnomalyPattern_LoginFailure a noria:AnomalyPattern ;
    rdfs:label "Repeated Login Failure Pattern"@en ;
    rdfs:comment "Anomaly pattern: multiple failed login attempts from a single source IP or user account within a short period."@en ;
    folio:hasCause "Brute-force attack or misconfigured client" .

:OpPlan_InvestigateLoginFailures a noria:OperationPlan ;
    rdfs:label "Investigate Login Failures Procedure"@en ;
    rdfs:comment "Procedure for investigating and mitigating repeated login failures."@en ;
    noria:operationPlanPreCondition :AnomalyPattern_LoginFailure ;
    noria:operationPlanPostCondition :PostCond_LoginIssueResolved .

:PostCond_LoginIssueResolved a noria:ActionPostCondition ;
    rdfs:label "Login Issue Resolved"@en ;
    rdfs:comment "Expected outcome: Login failures cease, and security posture is restored."@en .

