noria:RouterCore01Gi0_0_1LaserTxPower_extra_node_0 a noria:NetworkInterface ;
    rdfs:label "RouterCore01_extra_node_0 Gi0/0/1 Laser Tx Power"@en ;
    rdfs:comment "Transmitted optical power for Gi0/0/1 on Core Router_extra_node_0 01."@en ;
    noria:networkInterfaceOf noria:RouterCore01_extra_node_0 ;
    noria:networkInterfaceLaserTxOpticalPower -2 .

noria:RouterCore01Gi0_0_1LaserRxPower_extra_node_0 a noria:NetworkInterface ;
    rdfs:label "RouterCore01_extra_node_0 Gi0/0/1 Laser Rx Power"@en ;
    rdfs:comment "Received optical power for Gi0/0/1 on Core Router_extra_node_0 01."@en ;
    noria:networkInterfaceOf noria:RouterCore01_extra_node_0 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:VMMonitoring01Status_extra_node_0 a noria:Resource ;
    rdfs:label "Monitoring VM 01 Operational Status"@en ;
    rdfs:comment "Current operational status of the Monitoring VM."@en ;
