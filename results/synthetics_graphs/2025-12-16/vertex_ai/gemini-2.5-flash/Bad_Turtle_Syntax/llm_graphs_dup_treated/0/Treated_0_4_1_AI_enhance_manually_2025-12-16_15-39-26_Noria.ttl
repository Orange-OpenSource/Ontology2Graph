    noria:resourceType <kos/Resource/type/PhysicalServer> ;
    noria:resourceSerialNumber "SN-CRM-P01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_1> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
