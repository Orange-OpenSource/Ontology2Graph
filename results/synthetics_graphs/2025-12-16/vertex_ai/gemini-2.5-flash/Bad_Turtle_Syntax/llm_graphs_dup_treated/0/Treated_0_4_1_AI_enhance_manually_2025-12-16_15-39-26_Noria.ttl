# =============================================================================
# 5. Network Interfaces and Links (noria:NetworkInterface, noria:NetworkLink)
# =============================================================================

# Network Interfaces
noria:ServerCRMProd01Eth0 a noria:NetworkInterface ;
    rdfs:label "crmprod01.techcorp.com:eth0"@en ;
    rdfs:comment "Ethernet interface 0 on CRM Production Server 01."@en ;
    noria:networkInterfaceOf noria:ServerCRMProd01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to core switch for CRM production traffic."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> ;
    noria:networkInterfaceConnects noria:LinkServerCRMProdToCoreSwitch .

noria:RouterCore01Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "routercore01.techcorp.com:Gi0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/1 on Core Router_extra_node_1 01."@en ;
    noria:networkInterfaceOf noria:RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to DMZ Firewall_extra_node_1 01."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:LinkCoreRouterToFirewall .

noria:FirewallDMZ01Eth1 a noria:NetworkInterface ;
    rdfs:label "firewalldmz01.techcorp.com:eth1"@en ;
    rdfs:comment "Ethernet interface 1 on DMZ Firewall_extra_node_1 01."@en ;
    noria:networkInterfaceOf noria:FirewallDMZ01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to Core Router_extra_node_1 01."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> ;
    noria:networkInterfaceConnects noria:LinkCoreRouterToFirewall .

noria:VMMonitoring01Eth0 a noria:NetworkInterface ;
    rdfs:label "monvm01.techcorp.com:eth0"@en ;
    rdfs:comment "Virtual Ethernet interface 0 on Monitoring VM 01."@en ;
    noria:networkInterfaceOf noria:VMMonitoring01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "Uplink to virtual switch for monitoring traffic."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> ;
    noria:networkInterfaceConnects noria:LinkVMMonitoringToVirtualSwitch .

# Network Links
noria:LinkServerCRMProdToCoreSwitch a noria:NetworkLink ;
    rdfs:label "Link: CRM Prod Server to Core Switch"@en ;
    rdfs:comment "Physical link connecting CRM Production Server 01 to the core network switch."@en ;
    noria:networkLinkId "LINK-CRM-PROD-CSW" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2022-03-15T10:15:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:NetworkTeam_extra_node_1 ;
    noria:networkLinkTerminationResourceOrigin noria:ServerCRMProd01 ;
    noria:networkLinkTerminationResourceDestination noria:RouterCore01 . # Assuming core switch is part of routercore01 for simplicity

noria:LinkCoreRouterToFirewall a noria:NetworkLink ;
    rdfs:label "Link: Core Router_extra_node_1 to DMZ Firewall_extra_node_1"@en ;
    rdfs:comment "High_extra_node_1-speed link between Core Router_extra_node_1 01 and DMZ Firewall_extra_node_1 01."@en ;
    noria:networkLinkId "LINK-RTR-FW-DMZ" ;
    noria:networkLinkType "Fiber Optic 40Gbps" ;
    noria:networkLinkInstallationDate "2021-06-01T09:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:NetworkTeam_extra_node_1 ;
    noria:networkLinkTerminationResourceOrigin noria:RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:FirewallDMZ01 .

noria:LinkVMMonitoringToVirtualSwitch a noria:NetworkLink ;
    rdfs:label "Link: Monitoring VM to Virtual Switch"@en ;
    rdfs:comment "Virtual link connecting Monitoring VM 01 to its virtual switch."@en ;
    noria:networkLinkId "LINK-VM-MON-VSW" ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:networkLinkInstallationDate "2023-05-01T16:10:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:ITOpsTeam ;
    noria:networkLinkTerminationResourceOrigin noria:VMMonitoring01 ;
    noria:networkLinkTerminationResourceDestination noria:ServerCRMProd01 . # Assuming the VM is hosted on ServerCRMProd01 for simplicity

# =============================================================================
# 6. Applications and Modules (noria:Application, noria:ApplicationModule)
# =============================================================================

# Applications
noria:CRMSystem a noria:Application ;
    rdfs:label "Customer_extra_node_1 Relationship Management System"@en, "Système de Gestion de la Relation Client"@fr ;
    rdfs:comment "Core application for managing customer interactions and data."@en ;
    noria:applicationModelIdentifier "CRM-APP-V3" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/BusinessApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High_extra_node_1> ;
    noria:applicationFunctionalDomain "Customer_extra_node_1 Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales & Support" .

noria:MonitoringPlatform a noria:Application ;
    rdfs:label "IT Monitoring Platform"@en, "Plateforme de Supervision_extra_node_1 IT"@fr ;
    rdfs:comment "Platform for monitoring the health and performance of IT infrastructure."@en ;
    noria:applicationModelIdentifier "MON-PLAT-V2" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/Infrastructure_extra_node_1> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical_extra_node_1> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance & Availability Monitoring" .

noria:ERPSuite a noria:Application ;
    rdfs:label "Enterprise Resource Planning Suite"@en, "Suite Progiciel de Gestion Intégrée"@fr ;
    rdfs:comment "Integrated software suite for managing business processes."@en ;
    noria:applicationModelIdentifier "ERP-SUITE-V5" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "ERP" ;
    noria:applicationType <kos/application/type/BusinessApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical_extra_node_1> ;
    noria:applicationFunctionalDomain "Enterprise Management" ;
    noria:applicationFunctionalSubDomain "Finance & Supply Chain" .

# Application Modules
noria:CRMProdModule a noria:ApplicationModule ;
    rdfs:label "CRM Production Module"@en ;
    rdfs:comment "Production instance of the CRM system, serving live customer data."@en ;
    noria:applicationModuleOf noria:CRMSystem ;
    noria:applicationModuleName "CRM-APP-V3_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction_extra_node_1> ;
    noria:applicationModuleAdministrationTeam org:TechCorpITDepartment ;
    noria:applicationModuleAdministrationLeader foaf:JohnDoe ;
    noria:applicationModuleSupportTeam foaf:ITOpsTeam ;
    noria:applicationModuleSupportLeader foaf:JohnDoe ;
    noria:applicationModuleHotlineGroup foaf:ITOpsTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum_extra_node_1> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:CRMDevModule a noria:ApplicationModule ;
    rdfs:label "CRM Development Module"@en ;
