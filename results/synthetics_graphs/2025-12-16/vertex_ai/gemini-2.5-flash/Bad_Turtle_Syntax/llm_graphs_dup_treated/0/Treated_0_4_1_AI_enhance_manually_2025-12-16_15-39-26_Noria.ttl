# =============================================================================
# 11. Operations and Procedures (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition, noria:AnomalyPattern)
# =============================================================================

# Operation Plans
noria:CRMServerRestartPlan a noria:OperationPlan ;
    rdfs:label "CRM Server Application Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting CRM application services on production servers."@en ;
    noria:operationPlanPreCondition noria:PreCondCRMAppDown ;
    noria:operationPlanPostCondition noria:PostCondCRMAppRunning .

noria:RouterInterfaceTroubleshootPlan a noria:OperationPlan ;
    rdfs:label "Router_extra_node_1 Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues with router network interfaces."@en ;
    noria:operationPlanPreCondition noria:PreCondNetworkInterfaceDown ;
    noria:operationPlanPostCondition noria:PostCondNetworkInterfaceUp .

noria:RouterFirmwareUpgradePlan a noria:OperationPlan ;
    rdfs:label "Router_extra_node_1 Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading firmware on Cisco Catalyst 9300 routers."@en ;
    noria:operationPlanPreCondition noria:PreCondRouterBackupComplete ;
    noria:operationPlanPostCondition noria:PostCondRouterFirmwareUpdated .

# Action Pre-Conditions
noria:PreCondCRMAppDown a noria:ActionPreCondition ;
    rdfs:label "CRM Application Down Pre-Condition"@en ;
    rdfs:comment "Condition: CRM application is not responding or inaccessible."@en ;
    skos:example "Monitoring alerts indicate CRM service is down; users report inability to access CRM."@en .

noria:PreCondNetworkInterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition: A critical network interface is in an operational 'down' state."@en ;
    skos:example "Monitoring system reports interface Gi0/0/1 on routercore01 is down."@en .

noria:PreCondRouterBackupComplete a noria:ActionPreCondition ;
    rdfs:label "Router_extra_node_1 Configuration Backup Complete Pre-Condition"@en ;
    rdfs:comment "Condition: A full backup of the router's configuration has been successfully completed."@en ;
    skos:example "Backup system confirms successful configuration backup for routercore01."@en .

# Action Post-Conditions
noria:PostCondCRMAppRunning a noria:ActionPostCondition ;
    rdfs:label "CRM Application Running Post-Condition"@en ;
    rdfs:comment "Expected outcome: CRM application services are running and accessible."@en ;
    skos:example "CRM service monitoring shows 'up'; users can log in and access data."@en .

noria:PostCondNetworkInterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up_extra_node_1 Post-Condition"@en ;
    rdfs:comment "Expected outcome: The network interface is in an operational 'up' state."@en ;
    skos:example "Monitoring system reports interface Gi0/0/1 on routercore01 is up and passing traffic."@en .

noria:PostCondRouterFirmwareUpdated a noria:ActionPostCondition ;
    rdfs:label "Router_extra_node_1 Firmware Updated Post-Condition"@en ;
    rdfs:comment "Expected outcome: Router_extra_node_1 firmware has been successfully updated to the target version."@en ;
    skos:example "Router_extra_node_1 shows new firmware version in 'show version' output; network connectivity is stable."@en .

# Anomaly Patterns
noria:HighCPUDiskIOPattern a noria:AnomalyPattern ;
    rdfs:label "High_extra_node_1 CPU, Low Disk I/O Anomaly Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating a potential application deadlock or infinite loop: high CPU usage but very little disk activity."@en ;
    skos:example "CPU > 90% for 10min AND Disk I/O < 5MB/s for 10min."@en .

noria:NetworkFlapPattern a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Anomaly Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating an unstable network link: interface repeatedly goes up and down."@en ;
    skos:example "Interface operational status changes from UP to DOWN and back to UP more than 3 times in 5 minutes."@en .

# Procedure Execution Containers for correlating notes to actions
noria:CRMServerRestartExecution a pep:ProcedureExecutionContainer ;
    rdfs:label "CRM Server Restart Execution"@en ;
    rdfs:comment "Container for events related to the CRM server application restart."@en ;
    dcterms:created "2024-03-20T10:16:00Z"^^xsd:dateTime ;
    pep:hasProcedure noria:CRMServerRestartPlan ;
    # Example of a member event (not explicitly defined in NORIA, but pep:ProcedureExecutionContainer can have ldp:member)
    # For this exercise, we'll just link it to the note.
    .

# =============================================================================
# 12. Observables (additional properties for resources/interfaces)
# =============================================================================

noria:RouterCore01Gi0_0_1LaserTxPower a noria:NetworkInterface ;
    rdfs:label "RouterCore01 Gi0/0/1 Laser Tx Power"@en ;
    rdfs:comment "Transmitted optical power for Gi0/0/1 on Core Router_extra_node_1 01."@en ;
    noria:networkInterfaceOf noria:RouterCore01 ;
    noria:networkInterfaceLaserTxOpticalPower -2 .

noria:RouterCore01Gi0_0_1LaserRxPower a noria:NetworkInterface ;
    rdfs:label "RouterCore01 Gi0/0/1 Laser Rx Power"@en ;
    rdfs:comment "Received optical power for Gi0/0/1 on Core Router_extra_node_1 01."@en ;
    noria:networkInterfaceOf noria:RouterCore01 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:VMMonitoring01Status a noria:Resource ;
    rdfs:label "Monitoring VM 01 Operational Status"@en ;
    rdfs:comment "Current operational status of the Monitoring VM."@en ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Running> .

