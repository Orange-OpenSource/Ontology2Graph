bot:Site_ParisDC_extra_node_1 a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris, France."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

bot:Site_LyonOffice_extra_node_1 a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office building in Lyon, France, hosting local network infrastructure."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69007"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

noria:Room_ServerRoomA_extra_node_1 a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center, housing critical IT equipment."@en ;
    bot:hasSpace bot:Site_ParisDC_extra_node_1 .

noria:Room_NetworkClosetB_extra_node_1 a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in Lyon Office, containing access switches and routers."@en ;
    bot:hasSpace bot:Site_LyonOffice_extra_node_1 .

noria:Locus_RackA1_extra_node_1 a noria:Locus ;
    rdfs:label "Rack A1, Server Room A"@en ;
    rdfs:comment "Physical rack location for critical servers and network devices."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasZone noria:Room_ServerRoomA_extra_node_1 .

noria:Locus_RackB5_extra_node_1 a noria:Locus ;
    rdfs:label "Rack B5, Network Closet B"@en ;
    rdfs:comment "Physical rack location for core network routers in Lyon."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "5"@en ;
    bot:hasZone noria:Room_NetworkClosetB_extra_node_1 .

noria:Locus_RackA2_extra_node_1 a noria:Locus ;
    rdfs:label "Rack A2, Server Room A"@en ;
    rdfs:comment "Physical rack location for virtualization hosts."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en ;
    bot:hasZone noria:Room_ServerRoomA_extra_node_1 .

