# =============================================================================
# 5. Network Interfaces and Links (noria:NetworkInterface, noria:NetworkLink)
# =============================================================================

# Network Interfaces
noria:ServerCRMProd01Eth0_extra_node_0 a noria:NetworkInterface ;
    rdfs:label "crmprod01.techcorp.com:eth0"@en ;
    rdfs:comment "Ethernet interface 0 on CRM Production Server_extra_node_0 01."@en ;
    noria:networkInterfaceOf noria:ServerCRMProd01_extra_node_0 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to core switch for CRM production traffic."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceConnects noria:LinkServerCRMProdToCoreSwitch_extra_node_0 .

noria:RouterCore01Gi0_0_1_extra_node_0 a noria:NetworkInterface ;
    rdfs:label "routercore01.techcorp.com:Gi0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/1 on Core Router_extra_node_0 01."@en ;
    noria:networkInterfaceOf noria:RouterCore01_extra_node_0 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to DMZ Firewall_extra_node_0 01."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:LinkCoreRouterToFirewall_extra_node_0 .

noria:FirewallDMZ01Eth1_extra_node_0 a noria:NetworkInterface ;
    rdfs:label "firewalldmz01.techcorp.com:eth1"@en ;
    rdfs:comment "Ethernet interface 1 on DMZ Firewall_extra_node_0 01."@en ;
    noria:networkInterfaceOf noria:FirewallDMZ01_extra_node_0 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to Core Router_extra_node_0 01."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceConnects noria:LinkCoreRouterToFirewall_extra_node_0 .

noria:VMMonitoring01Eth0_extra_node_0 a noria:NetworkInterface ;
    rdfs:label "monvm01.techcorp.com:eth0"@en ;
    rdfs:comment "Virtual Ethernet interface 0 on Monitoring VM 01."@en ;
    noria:networkInterfaceOf noria:VMMonitoring01_extra_node_0 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "Uplink to virtual switch for monitoring traffic."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceConnects noria:LinkVMMonitoringToVirtualSwitch_extra_node_0 .

# Network Links
noria:LinkServerCRMProdToCoreSwitch_extra_node_0 a noria:NetworkLink ;
    rdfs:label "Link: CRM Prod Server_extra_node_0 to Core Switch_extra_node_0"@en ;
    rdfs:comment "Physical link connecting CRM Production Server_extra_node_0 01 to the core network switch."@en ;
    noria:networkLinkId "LINK-CRM-PROD-CSW" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2022-03-15T10:15:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:NetworkTeam_extra_node_0 ;
    noria:networkLinkTerminationResourceOrigin noria:ServerCRMProd01_extra_node_0 ;
    noria:networkLinkTerminationResourceDestination noria:RouterCore01_extra_node_0 . # Assuming core switch is part of routercore01 for simplicity

noria:LinkCoreRouterToFirewall_extra_node_0 a noria:NetworkLink ;
    rdfs:label "Link: Core Router_extra_node_0 to DMZ Firewall_extra_node_0"@en ;
    rdfs:comment "High_extra_node_0-speed link between Core Router_extra_node_0 01 and DMZ Firewall_extra_node_0 01."@en ;
    noria:networkLinkId "LINK-RTR-FW-DMZ" ;
    noria:networkLinkType "Fiber Optic 40Gbps" ;
    noria:networkLinkInstallationDate "2021-06-01T09:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:NetworkTeam_extra_node_0 ;
    noria:networkLinkTerminationResourceOrigin noria:RouterCore01_extra_node_0 ;
    noria:networkLinkTerminationResourceDestination noria:FirewallDMZ01_extra_node_0 .

noria:LinkVMMonitoringToVirtualSwitch_extra_node_0 a noria:NetworkLink ;
    rdfs:label "Link: Monitoring VM to Virtual Switch_extra_node_0"@en ;
    rdfs:comment "Virtual link connecting Monitoring VM 01 to its virtual switch."@en ;
    noria:networkLinkId "LINK-VM-MON-VSW" ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:networkLinkInstallationDate "2023-05-01T16:10:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:ITOpsTeam_extra_node_0 ;
    noria:networkLinkTerminationResourceOrigin noria:VMMonitoring01_extra_node_0 ;
    noria:networkLinkTerminationResourceDestination noria:ServerCRMProd01_extra_node_0 . # Assuming the VM is hosted on ServerCRMProd01_extra_node_0 for simplicity

# =============================================================================
# 6. Applications and Modules (noria:Application, noria:ApplicationModule)
# =============================================================================

# Applications
noria:CRMSystem_extra_node_0 a noria:Application ;
    rdfs:label "Customer_extra_node_0 Relationship Management System"@en, "Système de Gestion de la Relation Client"@fr ;
    rdfs:comment "Core application for managing customer interactions and data."@en ;
    noria:applicationModelIdentifier "CRM-APP-V3" ;
