    rdfs:comment "Procedure for diagnosing and resolving issues with router network interfaces."@en ;
    noria:operationPlanPreCondition noria:PreCondNetworkInterfaceDown_extra_node_0 ;
    noria:operationPlanPostCondition noria:PostCondNetworkInterfaceUp_extra_node_0 .

noria:RouterFirmwareUpgradePlan_extra_node_0 a noria:OperationPlan ;
    rdfs:label "Router_extra_node_0 Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading firmware on Cisco Catalyst 9300 routers."@en ;
    noria:operationPlanPreCondition noria:PreCondRouterBackupComplete_extra_node_0 ;
    noria:operationPlanPostCondition noria:PostCondRouterFirmwareUpdated_extra_node_0 .

# Action Pre-Conditions
noria:PreCondCRMAppDown_extra_node_0 a noria:ActionPreCondition ;
    rdfs:label "CRM Application Down Pre-Condition"@en ;
    rdfs:comment "Condition: CRM application is not responding or inaccessible."@en ;
    skos:example "Monitoring alerts indicate CRM service is down; users report inability to access CRM."@en .

noria:PreCondNetworkInterfaceDown_extra_node_0 a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition: A critical network interface is in an operational 'down' state."@en ;
    skos:example "Monitoring system reports interface Gi0/0/1 on routercore01 is down."@en .

noria:PreCondRouterBackupComplete_extra_node_0 a noria:ActionPreCondition ;
    rdfs:label "Router_extra_node_0 Configuration_extra_node_0 Backup Complete Pre-Condition"@en ;
    rdfs:comment "Condition: A full backup of the router's configuration has been successfully completed."@en ;
    skos:example "Backup system confirms successful configuration backup for routercore01."@en .

# Action Post-Conditions
noria:PostCondCRMAppRunning_extra_node_0 a noria:ActionPostCondition ;
    rdfs:label "CRM Application Running_extra_node_0 Post-Condition"@en ;
    rdfs:comment "Expected outcome: CRM application services are running and accessible."@en ;
    skos:example "CRM service monitoring shows 'up'; users can log in and access data."@en .

noria:PostCondNetworkInterfaceUp_extra_node_0 a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up_extra_node_0 Post-Condition"@en ;
    rdfs:comment "Expected outcome: The network interface is in an operational 'up' state."@en ;
    skos:example "Monitoring system reports interface Gi0/0/1 on routercore01 is up and passing traffic."@en .

noria:PostCondRouterFirmwareUpdated_extra_node_0 a noria:ActionPostCondition ;
    rdfs:label "Router_extra_node_0 Firmware Updated Post-Condition"@en ;
    rdfs:comment "Expected outcome: Router_extra_node_0 firmware has been successfully updated to the target version."@en ;
    skos:example "Router_extra_node_0 shows new firmware version in 'show version' output; network connectivity is stable."@en .

# Anomaly Patterns
noria:HighCPUDiskIOPattern a noria:AnomalyPattern ;
    rdfs:label "High_extra_node_0 CPU, Low Disk I/O Anomaly Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating a potential application deadlock or infinite loop: high CPU usage but very little disk activity."@en ;
    skos:example "CPU > 90% for 10min AND Disk I/O < 5MB/s for 10min."@en .

noria:NetworkFlapPattern a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Anomaly Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating an unstable network link: interface repeatedly goes up and down."@en ;
    skos:example "Interface operational status changes from UP to DOWN and back to UP more than 3 times in 5 minutes."@en .

# Procedure Execution Containers for correlating notes to actions
noria:CRMServerRestartExecution_extra_node_0 a pep:ProcedureExecutionContainer ;
    rdfs:label "CRM Server_extra_node_0 Restart Execution"@en ;
    rdfs:comment "Container for events related to the CRM server application restart."@en ;
    dcterms:created "2024-03-20T10:16:00Z"^^xsd:dateTime ;
    pep:hasProcedure noria:CRMServerRestartPlan_extra_node_0 ;
    # Example of a member event (not explicitly defined in NORIA, but pep:ProcedureExecutionContainer can have ldp:member)
    # For this exercise, we'll just link it to the note.
    .

