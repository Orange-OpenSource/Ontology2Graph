noria:OperationPlan_RouterOSUpgrade_extra_node_1 a noria:OperationPlan ;
    rdfs:label "Standard Router_extra_node_1 OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading Cisco ASR router operating system, including pre-checks, upgrade, and post-checks."@en ;
    noria:operationPlanPreCondition noria:PreCondition_BackupComplete_extra_node_1 ;
    noria:operationPlanPreCondition noria:PreCondition_MaintenanceWindow_extra_node_1 ;
    noria:operationPlanPostCondition noria:PostCondition_ConnectivityVerified_extra_node_1 ;
    noria:operationPlanPostCondition noria:PostCondition_SystemHealthCheck_extra_node_1 .

noria:OperationPlan_DBOptimization_extra_node_1 a noria:OperationPlan ;
    rdfs:label "Database Performance Optimization Procedure"@en ;
    rdfs:comment "Steps for analyzing and optimizing database performance, including index creation and query tuning."@en ;
    noria:operationPlanPreCondition noria:PreCondition_PerformanceBaseline_extra_node_1 ;
    noria:operationPlanPostCondition noria:PostCondition_PerformanceImprovement_extra_node_1 .

noria:OperationPlan_FirewallRuleUpdate_extra_node_1 a noria:OperationPlan ;
    rdfs:label "Standard Firewall_extra_node_1 Rule Update Procedure"@en ;
    rdfs:comment "Procedure for safely updating firewall rules, ensuring no unintended service interruptions."@en ;
    noria:operationPlanPreCondition noria:PreCondition_RuleReviewApproved_extra_node_1 ;
    noria:operationPlanPostCondition noria:PostCondition_ConnectivityVerified_extra_node_1 .

noria:OperationPlan_VMMigration_extra_node_1 a noria:OperationPlan ;
    rdfs:label "Virtual Machine Live Migration Procedure"@en ;
    rdfs:comment "Procedure for live migrating virtual machines between hypervisors with minimal downtime."@en ;
    noria:operationPlanPreCondition noria:PreCondition_HostCompatibilityCheck_extra_node_1 ;
    noria:operationPlanPostCondition noria:PostCondition_VMMigrationSuccess_extra_node_1 .

noria:PreCondition_BackupComplete_extra_node_1 a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup Complete"@en ;
    rdfs:comment "Ensure a full configuration backup of the device is completed and verified before proceeding with changes."@en .

noria:PreCondition_MaintenanceWindow_extra_node_1 a noria:ActionPreCondition ;
    rdfs:label "Approved Maintenance Window"@en ;
    rdfs:comment "Confirm that the change is scheduled within an approved maintenance window to minimize impact."@en .

noria:PreCondition_PerformanceBaseline_extra_node_1 a noria:ActionPreCondition ;
    rdfs:label "Performance Baseline Established"@en ;
    rdfs:comment "Collect baseline performance metrics before applying changes to allow for comparison."@en .

noria:PreCondition_RuleReviewApproved_extra_node_1 a noria:ActionPreCondition ;
    rdfs:label "Firewall_extra_node_1 Rule Review Approved"@en ;
    rdfs:comment "Ensure new firewall rules have been reviewed and approved by security team and relevant stakeholders."@en .

noria:PreCondition_HostCompatibilityCheck_extra_node_1 a noria:ActionPreCondition ;
    rdfs:label "Hypervisor_extra_node_1 Host Compatibility Check"@en ;
    rdfs:comment "Verify source and destination hypervisor hosts are compatible for live migration."@en .

noria:PostCondition_ConnectivityVerified_extra_node_1 a noria:ActionPostCondition ;
    rdfs:label "Network Connectivity Verified"@en ;
    rdfs:comment "Verify end-to-end network connectivity and service reachability after changes."@en .

noria:PostCondition_SystemHealthCheck_extra_node_1 a noria:ActionPostCondition ;
    rdfs:label "System Health Check Passed"@en ;
    rdfs:comment "Perform a full system health check to ensure all components are functioning correctly."@en .

noria:PostCondition_PerformanceImprovement_extra_node_1 a noria:ActionPostCondition ;
    rdfs:label "Database Performance Improved"@en ;
    rdfs:comment "Confirm performance metrics show improvement and meet target SLAs after optimization."@en .

noria:PostCondition_VMMigrationSuccess_extra_node_1 a noria:ActionPostCondition ;
    rdfs:label "Virtual Machine Migration Successful"@en ;
    rdfs:comment "Verify the virtual machine has successfully migrated and is operational on the new host."@en .

noria:AnomalyPattern_HighCPU_DB_extra_node_1 a noria:AnomalyPattern ;
    rdfs:label "Database High_extra_node_1 CPU Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage on database servers, often preceding performance degradation and outages."@en ;
    folio:hasCause noria:EventRecord_DBHighCPU_extra_node_1 . # Linking an anomaly pattern to a specific event that matches it.

noria:AnomalyPattern_NetworkDegradation_extra_node_1 a noria:AnomalyPattern ;
    rdfs:label "Network Interface Error Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating increasing error rates on network interfaces, suggesting cable issues, faulty hardware, or duplex mismatches."@en ;
    folio:hasCause noria:EventRecord_SwitchPortError_extra_node_1 .

noria:AnomalyPattern_ServiceUnresponsive_extra_node_1 a noria:AnomalyPattern ;
    rdfs:label "Service Unresponsive Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a critical service or application component is not responding to health checks or user requests."@en ;
    folio:hasCause noria:EventRecord_LoadBalancerHealthCheckFail_extra_node_1 .

