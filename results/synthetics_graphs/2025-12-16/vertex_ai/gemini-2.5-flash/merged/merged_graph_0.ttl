# =============================================================================
# 1. Organizational Entities (foaf:Agent, org:Organization, noria:CorporateUserIdentifier)
# =============================================================================

# Organizations
org:TechCorpGlobal_extra_node_0 a org:Organization ;
    rdfs:label "TechCorp Global"@en ;
    rdfs:comment "The global parent organization for all TechCorp operations."@en ;
    org:hasUnit org:TechCorpITDepartment_extra_node_0, org:TechCorpNetworkOperations_extra_node_0 ;
    org:hasMember foaf:JohnDoe_extra_node_0, foaf:JaneSmith_extra_node_0 .

org:TechCorpITDepartment_extra_node_0 a org:OrganizationalUnit ;
    rdfs:label "TechCorp IT Department"@en ;
    rdfs:comment "Manages all IT infrastructure and applications for TechCorp."@en ;
    org:unitOf org:TechCorpGlobal_extra_node_0 ;
    org:hasMember foaf:ITOpsTeam_extra_node_0, foaf:CRMDevsTeam_extra_node_0, foaf:JohnDoe_extra_node_0 .

org:TechCorpNetworkOperations_extra_node_0 a org:OrganizationalUnit ;
    rdfs:label "TechCorp Network Operations"@en ;
    rdfs:comment "Responsible for the design, implementation, and maintenance of TechCorp's network infrastructure."@en ;
    org:unitOf org:TechCorpGlobal_extra_node_0 ;
    org:hasMember foaf:NetworkTeam_extra_node_0, foaf:JaneSmith_extra_node_0 .

# Agents (Teams and Individuals)
foaf:ITOpsTeam_extra_node_0 a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for general IT infrastructure and application support."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> ;
    noria:agentInstructions "For critical issues, use the ticketing system and call the hotline."@en ;
    noria:agentManagesResource noria:ServerCRMProd01_extra_node_0, noria:VMMonitoring01_extra_node_0 ;
    org:memberOf org:TechCorpITDepartment_extra_node_0 .

foaf:NetworkTeam_extra_node_0 a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "24/7 (On-call rotation)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_0> ;
    noria:agentInstructions "Always open a high-priority ticket for network outages."@en ;
    noria:agentManagesResource noria:RouterCore01_extra_node_0, noria:FirewallDMZ01_extra_node_0, noria:LinkCoreRouterToFirewall_extra_node_0 ;
    org:memberOf org:TechCorpNetworkOperations_extra_node_0 .

foaf:CRMDevsTeam_extra_node_0 a foaf:Agent ;
    rdfs:label "CRM Development_extra_node_0 Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the CRM application."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat_extra_node_0> ;
    noria:agentInstructions "Contact via internal chat for non-critical issues."@en ;
    noria:agentManagesResource noria:ServerCRMDev01_extra_node_0 ;
    org:memberOf org:TechCorpITDepartment_extra_node_0 .

foaf:JohnDoe_extra_node_0 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead System Administrator for TechCorp."@en ;
    foaf:mbox <mailto:john.doe@techcorp.com_extra_node_0> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "08:30-17:30 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> ;
    noria:agentManagesResource noria:ServerCRMProd01_extra_node_0 ;
    org:memberOf org:TechCorpITDepartment_extra_node_0 .

foaf:JaneSmith_extra_node_0 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Network Engineer at TechCorp."@en ;
    foaf:mbox <mailto:jane.smith@techcorp.com_extra_node_0> ;
    foaf:phone "+33198765432" ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_0> ;
    noria:agentManagesResource noria:RouterCore01_extra_node_0 ;
    org:memberOf org:TechCorpNetworkOperations_extra_node_0 .

# Corporate User Identifiers
noria:JohnDoeCUid_extra_node_0 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User_extra_node_0 Identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:JohnDoe_extra_node_0 .

noria:JaneSmithCUid_extra_node_0 a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User_extra_node_0 Identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:JaneSmith_extra_node_0 .

# =============================================================================
# 2. Location Entities (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:DCPARIS_extra_node_0 a bot:Site ;
    rdfs:label "TechCorp Paris Data Center"@en ;
    rdfs:comment "Main data center for TechCorp in Paris, France."@en ;
    noria:siteId "DC-PARIS-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" ;
    bot:hasSpace noria:ServerRoomA_extra_node_0, noria:NetworkRoomB_extra_node_0 .

noria:ServerRoomA_extra_node_0 a noria:Room ;
    rdfs:label "Server_extra_node_0 Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server room in the Paris Data Center."@en ;
    bot:hasZone noria:Rack12U20_extra_node_0, noria:Rack15U10_extra_node_0 ;
    bot:hasSpace bot:DCPARIS_extra_node_0 . # Inverse of bot:hasSpace

noria:NetworkRoomB_extra_node_0 a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Dedicated room for core network equipment."@en ;
    bot:hasZone noria:Rack01U05_extra_node_0 ;
    bot:hasSpace bot:DCPARIS_extra_node_0 .

noria:Rack12U20_extra_node_0 a noria:Locus ;
    rdfs:label "Rack 12, Unit 20"@en ;
    rdfs:comment "Specific location for a server in Server_extra_node_0 Room A."@en ;
    noria:locusLine "12" ;
    noria:locusRow "20" ;
    bot:hasSpace noria:ServerRoomA_extra_node_0 .

noria:Rack15U10_extra_node_0 a noria:Locus ;
    rdfs:label "Rack 15, Unit 10"@en ;
    rdfs:comment "Specific location for a server in Server_extra_node_0 Room A."@en ;
    noria:locusLine "15" ;
    noria:locusRow "10" ;
    bot:hasSpace noria:ServerRoomA_extra_node_0 .

noria:Rack01U05_extra_node_0 a noria:Locus ;
    rdfs:label "Rack 01, Unit 05"@en ;
    rdfs:comment "Specific location for a router in Network Room B."@en ;
    noria:locusLine "01" ;
    noria:locusRow "05" ;
    bot:hasSpace noria:NetworkRoomB_extra_node_0 .

