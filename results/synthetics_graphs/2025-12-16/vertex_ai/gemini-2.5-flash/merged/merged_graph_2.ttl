# Network Links
noria:NL_Paris_ISP_A a noria:NetworkLink ;
    rdfs:label "Paris DC to ISP A Uplink"@en ;
    rdfs:comment "Primary internet uplink for Paris Data Center, connecting to external ISP."@en ;
    noria:networkLinkId "NL-PAR-ISP-A" ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2021-06-01T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_FirewallDMZ01 ; # Simplified, could be ISP router
    noria:resourceManagedBy org:NetworkTeam ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gig0_0_0 .

noria:NL_Paris_Lyon_DC a noria:NetworkLink ;
