    noria:resourceType <kos/Resource/type/PhysicalServer> ;
    noria:resourceSerialNumber "SN-CRM-D01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InDevelopment> ;
    noria:resourceInstallationDate "2023-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:CRMDevsTeam ;
    noria:resourceForApplication noria:CRMSystem ;
    noria:locatedAtLocus noria:Rack15U10 ;
    noria:resourceManagementIPAddress observable:IPAddress192_168_1_11 .

noria:RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the TechCorp internal network."@en ;
    noria:resourceLogisticId "TC-RTR-CORE-01" ;
    noria:resourceHostName "routercore01.techcorp.com" ;
    noria:resourceProductModel noria:CiscoCatalyst9300 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-C01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:NetworkTeam ;
