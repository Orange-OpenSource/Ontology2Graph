    noria:resourceManagedBy foaf:NetworkTeam ;
    noria:locatedAtLocus noria:Rack01U05 ;
    noria:resourceManagementIPAddress observable:IPAddress10_0_0_2 .

noria:VMMonitoring01 a noria:Resource ;
    rdfs:label "Monitoring VM 01"@en ;
    rdfs:comment "Virtual machine hosting the monitoring platform."@en ;
    noria:resourceLogisticId "TC-VM-MON-01" ;
