noria:RouterCore01Gi0_0_1LaserTxPower a noria:NetworkInterface ;
    rdfs:label "RouterCore01 Gi0/0/1 Laser Tx Power"@en ;
    rdfs:comment "Transmitted optical power for Gi0/0/1 on Core Router 01."@en ;
    noria:networkInterfaceOf noria:RouterCore01 ;
    noria:networkInterfaceLaserTxOpticalPower -2 .

noria:RouterCore01Gi0_0_1LaserRxPower a noria:NetworkInterface ;
    rdfs:label "RouterCore01 Gi0/0/1 Laser Rx Power"@en ;
    rdfs:comment "Received optical power for Gi0/0/1 on Core Router 01."@en ;
