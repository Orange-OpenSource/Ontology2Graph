# =============================================================================
# 1. Organizational Entities (foaf:Agent, org:Organization, noria:CorporateUserIdentifier)
# =============================================================================

# Organizations
org:TechCorpGlobal a org:Organization ;
    rdfs:label "TechCorp Global"@en ;
    rdfs:comment "The global parent organization for all TechCorp operations."@en ;
    org:hasUnit org:TechCorpITDepartment, org:TechCorpNetworkOperations ;
    org:hasMember foaf:JohnDoe, foaf:JaneSmith .

org:TechCorpITDepartment a org:OrganizationalUnit ;
    rdfs:label "TechCorp IT Department"@en ;
    rdfs:comment "Manages all IT infrastructure and applications for TechCorp."@en ;
    org:unitOf org:TechCorpGlobal ;
    org:hasMember foaf:ITOpsTeam, foaf:CRMDevsTeam, foaf:JohnDoe .

org:TechCorpNetworkOperations a org:OrganizationalUnit ;
    rdfs:label "TechCorp Network Operations"@en ;
    rdfs:comment "Responsible for the design, implementation, and maintenance of TechCorp's network infrastructure."@en ;
    org:unitOf org:TechCorpGlobal ;
    org:hasMember foaf:NetworkTeam, foaf:JaneSmith .

# Agents (Teams and Individuals)
foaf:ITOpsTeam a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for general IT infrastructure and application support."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the ticketing system and call the hotline."@en ;
    noria:agentManagesResource noria:ServerCRMProd01, noria:VMMonitoring01 ;
    org:memberOf org:TechCorpITDepartment .

foaf:NetworkTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "24/7 (On-call rotation)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always open a high-priority ticket for network outages."@en ;
    noria:agentManagesResource noria:RouterCore01, noria:FirewallDMZ01, noria:LinkCoreRouterToFirewall ;
    org:memberOf org:TechCorpNetworkOperations .

foaf:CRMDevsTeam a foaf:Agent ;
    rdfs:label "CRM Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the CRM application."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Contact via internal chat for non-critical issues."@en ;
    noria:agentManagesResource noria:ServerCRMDev01 ;
    org:memberOf org:TechCorpITDepartment .

foaf:JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead System Administrator for TechCorp."@en ;
    foaf:mbox <mailto:john.doe@techcorp.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "08:30-17:30 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource noria:ServerCRMProd01 ;
    org:memberOf org:TechCorpITDepartment .

foaf:JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Network Engineer at TechCorp."@en ;
    foaf:mbox <mailto:jane.smith@techcorp.com> ;
    foaf:phone "+33198765432" ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentManagesResource noria:RouterCore01 ;
    org:memberOf org:TechCorpNetworkOperations .

# Corporate User Identifiers
noria:JohnDoeCUid a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:JohnDoe .

noria:JaneSmithCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:JaneSmith .

# =============================================================================
# 2. Location Entities (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:DCPARIS a bot:Site ;
    rdfs:label "TechCorp Paris Data Center"@en ;
    rdfs:comment "Main data center for TechCorp in Paris, France."@en ;
    noria:siteId "DC-PARIS-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" ;
    bot:hasSpace noria:ServerRoomA, noria:NetworkRoomB .

noria:ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server room in the Paris Data Center."@en ;
    bot:hasZone noria:Rack12U20, noria:Rack15U10 ;
    bot:hasSpace bot:DCPARIS . # Inverse of bot:hasSpace

noria:NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Dedicated room for core network equipment."@en ;
    bot:hasZone noria:Rack01U05 ;
    bot:hasSpace bot:DCPARIS .

noria:Rack12U20 a noria:Locus ;
    rdfs:label "Rack 12, Unit 20"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "12" ;
    noria:locusRow "20" ;
    bot:hasSpace noria:ServerRoomA .

noria:Rack15U10 a noria:Locus ;
    rdfs:label "Rack 15, Unit 10"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "15" ;
    noria:locusRow "10" ;
    bot:hasSpace noria:ServerRoomA .

noria:Rack01U05 a noria:Locus ;
    rdfs:label "Rack 01, Unit 05"@en ;
    rdfs:comment "Specific location for a router in Network Room B."@en ;
    noria:locusLine "01" ;
    noria:locusRow "05" ;
    bot:hasSpace noria:NetworkRoomB .

# =============================================================================
# 3. Product Models (noria:ProductModel)
# =============================================================================

noria:DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy org:DellTechnologies .

noria:CiscoCatalyst9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch from Cisco."@en ;
    noria:productManufacturedBy org:CiscoSystems .

noria:PaloAltoFirewallPA500 a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-500"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy org:PaloAltoNetworks .

noria:VMwareESXiHost a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization hypervisor platform."@en ;
    noria:productManufacturedBy org:VMware .

# Manufacturer Organizations
org:DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

org:CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

org:PaloAltoNetworks a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "American multinational cybersecurity company."@en .

org:VMware a org:Organization ;
    rdfs:label "VMware"@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

# =============================================================================
# 4. Resources (noria:Resource)
# =============================================================================

noria:ServerCRMProd01 a noria:Resource ;
    rdfs:label "CRM Production Server 01"@en ;
    rdfs:comment "Physical server hosting the production CRM application database."@en ;
    noria:resourceLogisticId "TC-SRV-CRM-P01" ;
    noria:resourceHostName "crmprod01.techcorp.com" ;
    noria:resourceProductModel noria:DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/PhysicalServer> ;
    noria:resourceSerialNumber "SN-CRM-P01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:ITOpsTeam ;
    noria:resourceForApplication noria:CRMSystem ;
    noria:locatedAtLocus noria:Rack12U20 ;
    noria:resourceManagementIPAddress observable:IPAddress192_168_1_10 .

noria:ServerCRMDev01 a noria:Resource ;
    rdfs:label "CRM Development Server 01"@en ;
    rdfs:comment "Physical server for CRM application development environment."@en ;
