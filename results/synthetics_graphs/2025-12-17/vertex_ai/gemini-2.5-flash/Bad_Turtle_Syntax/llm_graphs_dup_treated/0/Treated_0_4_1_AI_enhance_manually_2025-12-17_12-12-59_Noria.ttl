# Organizations
org:ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department of the company."@en ;
    org:hasSubOrganization org:ITOpsTeam_extra_node_9, org:NetworkTeam_extra_node_9, org:AppSupportTeam_extra_node_9, org:SecurityTeam_extra_node_9 .

org:Vendor_Cisco a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of network hardware."@en ;
