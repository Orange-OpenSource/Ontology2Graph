org:Vendor_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server hardware."@en ;
    noria:productManufacturedBy noria:ProductModel_Dell_PowerEdge_R740 .

# =============================================================================
# 2. Locations (Sites, Rooms, Loci)
# =============================================================================

bot:Site_DC1_extra_node_9 a bot:Site ;
    rdfs:label "Main Data Center 1"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure_extra_node_9."@en ;
    noria:siteId "DC1" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" ;
    bot:hasBuilding noria:Building_DC1 ;
    bot:hasZone noria:Room_ServerRoom_DC1_A .

bot:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary data center for disaster recovery purposes."@en ;
    noria:siteId "DRS" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Road" ;
    noria:sitePrincipalAddressCityName "Gotham" ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "US" ;
    bot:hasBuilding noria:Building_DRS ;
    bot:hasZone noria:Room_ServerRoom_DRS_B .

noria:Building_DC1 a bot:Building ;
    rdfs:label "DC1 Building"@en ;
    bot:hasSpace noria:Room_ServerRoom_DC1_A .

noria:Building_DRS a bot:Building ;
    rdfs:label "DRS Building"@en ;
    bot:hasSpace noria:Room_ServerRoom_DRS_B .

noria:Room_ServerRoom_DC1_A a noria:Room ;
    rdfs:label "Server_extra_node_9 Room DC1-A"@en ;
    rdfs:comment "Main server room in Data Center 1."@en ;
    skos:example "SALLE SERVEURS DC1-A"@fr ;
    bot:hasZone noria:Locus_Rack_A1, noria:Locus_Rack_A2 ;
    bot:hasElement noria:Resource_CoreRouter01_extra_node_9, noria:Resource_WebServer01_extra_node_9 .

noria:Room_ServerRoom_DRS_B a noria:Room ;
    rdfs:label "Server_extra_node_9 Room DRS-B"@en ;
    rdfs:comment "Server_extra_node_9 room in Disaster Recovery Site."@en ;
    skos:example "SALLE SERVEURS DRS-B"@fr ;
    bot:hasZone noria:Locus_Rack_B1 ;
    bot:hasElement noria:Resource_DBServer01_DR .

noria:Locus_Rack_A1 a noria:Locus ;
    rdfs:label "Rack A1 in DC1-A"@en ;
    rdfs:comment "Location of critical_extra_node_9 network and server equipment."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    noria:locatedAtLocus noria:Resource_CoreRouter01_extra_node_9, noria:Resource_WebServer01_extra_node_9 .

noria:Locus_Rack_A2 a noria:Locus ;
    rdfs:label "Rack A2 in DC1-A"@en ;
    rdfs:comment "Location for application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    noria:locatedAtLocus noria:Resource_AppServer01_extra_node_9, noria:Resource_AppServer02 .

noria:Locus_Rack_B1 a noria:Locus ;
    rdfs:label "Rack B1 in DRS-B"@en ;
    rdfs:comment "Location for disaster recovery database server."@en ;
    noria:locusLine "B" ;
    noria:locusRow "1" ;
    noria:locatedAtLocus noria:Resource_DBServer01_DR .

