# =============================================================================
# 1. Agents and Organizations
# =============================================================================

# Organizational Units (Teams)
org:ITOpsTeam_extra_node_9 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure_extra_node_9 operations and incident response."@en ;
    noria:agentWorkingHours "24/7 (Shift-based)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_9> ;
    noria:agentInstructions "For critical_extra_node_9 issues, open a P1_extra_node_9 ticket and call the hotline. For non-critical_extra_node_9, use the ticketing system."@en ;
    noria:agentManagesResource noria:Resource_CoreRouter01_extra_node_9, noria:Resource_WebServer01_extra_node_9, noria:Resource_DBServer01_extra_node_9 ;
    noria:agentManagesResource noria:NetworkLink_DC1_DC2_Fiber ;
    noria:agentManagesResource noria:Application_CorporateEmail, noria:Application_CRMSystem_extra_node_9 ;
    noria:agentManagesResource noria:Service_CorporateConnectivity ;
    noria:agentManagesResource noria:ApplicationModule_EmailProd_DC1 ;
    org:member foaf:Person_Alice, foaf:Person_Bob ;
    org:subOrganizationOf org:ITDepartment .

org:NetworkTeam_extra_node_9 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team for network design, implementation, and advanced troubleshooting."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_9> ;
    noria:agentInstructions "Contact via email_extra_node_9 for routine requests. For urgent network issues, escalate via IT Operations."@en ;
    noria:agentManagesResource noria:Resource_CoreRouter01_extra_node_9, noria:Resource_EdgeRouter01_extra_node_9 ;
    noria:agentManagesResource noria:NetworkLink_DC1_DC2_Fiber, noria:NetworkLink_Edge_ISP ;
    org:member foaf:Person_Charlie ;
    org:subOrganizationOf org:ITDepartment .

org:AppSupportTeam_extra_node_9 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team dedicated to supporting specific business_extra_node_9 applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_9> ;
    noria:agentManagesResource noria:Application_CorporateEmail, noria:Application_CRMSystem_extra_node_9 ;
    noria:agentManagesResource noria:ApplicationModule_EmailProd_DC1, noria:ApplicationModule_CRMProd ;
    org:member foaf:Person_David ;
    org:subOrganizationOf org:ITDepartment .

org:SecurityTeam_extra_node_9 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team responsible for monitoring_extra_node_9, detecting, analyzing, and responding to cybersecurity incidents."@en ;
    noria:agentWorkingHours "24/7 (Shift-based)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts_extra_node_9> ;
    noria:agentInstructions "All security incidents must be reported via SIEM alerts or direct phone_extra_node_9 call for critical_extra_node_9 events."@en ;
    noria:agentManagesResource noria:Resource_Firewall01_extra_node_9, noria:Resource_IDS01 ;
    org:member foaf:Person_Eve ;
    org:subOrganizationOf org:ITDepartment .

