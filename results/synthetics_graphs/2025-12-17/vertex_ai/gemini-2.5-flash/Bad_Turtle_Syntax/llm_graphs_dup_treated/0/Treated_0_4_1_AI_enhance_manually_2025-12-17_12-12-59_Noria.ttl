# =============================================================================
# 5. Network Interfaces and Links
# =============================================================================

noria:NetworkInterface_CR01_GE0_0_0 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router_extra_node_9 01 to the internal network segment."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01_extra_node_9 ;
    noria:networkInterfaceType "physical" ;
