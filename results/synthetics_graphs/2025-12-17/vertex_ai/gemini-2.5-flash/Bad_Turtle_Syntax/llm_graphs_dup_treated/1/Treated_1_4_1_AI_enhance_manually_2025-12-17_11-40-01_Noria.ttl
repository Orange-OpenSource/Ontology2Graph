# =============================================================================
# 8. Event Records
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_6 Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%" ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_6> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartDNSService .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a network interface on Core Switch_extra_node_6 01 went down."@en ;
    noria:loggingTime "2024-04-10T09:01:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/1, changed state to down" ;
    noria:logOriginatingManagedObject noria:Resource_CoreSwitch01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_6> ;
    noria:alarmMonitoredAttribute "interface_status" .

noria:EventRecord_DBHighCPU a noria:EventRecord ;
    rdfs:label "Database High CPU Usage Alert"@en ;
    rdfs:comment "Alert indicating sustained high_extra_node_6 CPU usage on the production database server."@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: Host db01.prod.example.com CPU usage 95% for 15 minutes" ;
    noria:logOriginatingManagedObject noria:Resource_DB01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_6> .

noria:EventRecord_UserLoginFailure_extra_node_6 a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on a web frontend VM."@en ;
    noria:loggingTime "2024-04-10T11:05:20Z"^^xsd:dateTime ;
    noria:logText "Authentication failure for user 'unknown_user' from IP 1.2.3.4" ;
    noria:logOriginatingManagedObject noria:Resource_WebFrontendVM01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoring ;
    noria:logOriginatingAgent foaf:Agent3 ; # SOC analyst might be investigating
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor_extra_node_6> .

noria:EventRecord_ConfigChangeER01 a noria:EventRecord ;
    rdfs:label "Router_extra_node_6 Configuration_extra_node_6 Change"@en ;
    rdfs:comment "Log entry for a configuration change on Edge Router_extra_node_6 01."@en ;
    noria:loggingTime "2024-04-09T15:30:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by asmith (192.168.1.10)" ;
    noria:logOriginatingManagedObject noria:Resource_EdgeRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoring ;
    noria:logOriginatingAgent foaf:Agent1 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational_extra_node_6> .

