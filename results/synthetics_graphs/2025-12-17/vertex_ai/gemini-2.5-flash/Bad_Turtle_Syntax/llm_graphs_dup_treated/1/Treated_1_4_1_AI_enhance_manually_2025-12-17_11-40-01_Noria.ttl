# Application Modules for Corporate Internet Access
noria:ApplicationModule_CIA_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate Internet Access - Production"@en ;
    rdfs:comment "Production instance of the Corporate Internet Access application."@en ;
    noria:applicationModuleOf noria:Application_CorporateInternetAccess ;
    noria:applicationModuleName "CIA_PROD" ;
    noria:applicationModuleIdentifier "CIA-PROD-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction_extra_node_6> ;
