    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_6> ;
    noria:resourceInstallationDate "2023-05-10T14:05:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_DNS01 ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Running> ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_1_101 .

