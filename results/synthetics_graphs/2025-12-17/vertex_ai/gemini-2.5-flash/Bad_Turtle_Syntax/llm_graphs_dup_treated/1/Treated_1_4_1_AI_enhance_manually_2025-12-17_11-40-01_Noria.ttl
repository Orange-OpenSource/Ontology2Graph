    rdfs:comment "Primary data center for corporate services."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site_LyonOffice_extra_node_6 a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA_extra_node_6 a noria:Room ;
    rdfs:label "Server_extra_node_6 Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC_extra_node_6 .

noria:Room_NetworkCloset1 a noria:Room ;
    rdfs:label "Network Closet 1"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace bot:Site_LyonOffice_extra_node_6 .

noria:Locus_RackA1_extra_node_6 a noria:Locus ;
    rdfs:label "Rack A1 in Server_extra_node_6 Room A"@en ;
    rdfs:comment "Specific rack location for critical_extra_node_6 servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoomA_extra_node_6 .

noria:Locus_RackB5_extra_node_6 a noria:Locus ;
    rdfs:label "Rack B5 in Server_extra_node_6 Room A"@en ;
    rdfs:comment "Rack location for database servers."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room_ServerRoomA_extra_node_6 .

noria:Locus_WallMountC2 a noria:Locus ;
    rdfs:label "Wall Mount C2 in Network Closet 1"@en ;
    rdfs:comment "Wall mount location for access switches."@en ;
    noria:locusLine "C" ;
    noria:locusRow "2" ;
    bot:hasSpace noria:Room_NetworkCloset1 .

