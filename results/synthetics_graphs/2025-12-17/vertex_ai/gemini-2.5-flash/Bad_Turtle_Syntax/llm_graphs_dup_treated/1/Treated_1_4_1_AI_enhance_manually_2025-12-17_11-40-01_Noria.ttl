# =============================================================================

# Physical Servers
noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server_extra_node_6 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, physical host."@en ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceType <kos/Resource/type/physical_server> ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_6 ;
    noria:resourceManagedBy org:NetworkOperationsTeam ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_6> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_6 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_10_extra_node_6 .

noria:Resource_DB01 a noria:Resource ;
    rdfs:label "Production Database Server_extra_node_6 01"@en ;
    rdfs:comment "Primary database server for critical_extra_node_6 applications."@en ;
    noria:resourceHostName "db01.prod.example.com" ;
    noria:resourceLogisticId "LOG-DB-001" ;
    noria:resourceSerialNumber "SN-DB01-ABC" ;
    noria:resourceType <kos/Resource/type/physical_server> ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_6 ;
    noria:resourceManagedBy org:DatabaseAdminTeam ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_6> ;
    noria:resourceInstallationDate "2022-03-01T11:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB5_extra_node_6 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_20 .

# Virtual Servers
noria:Resource_WebFrontendVM01 a noria:Resource ;
    rdfs:label "Web Frontend VM 01"@en ;
    rdfs:comment "Virtual machine hosting web application frontend."@en ;
    noria:resourceHostName "web01.app.example.com" ;
    noria:resourceType <kos/Resource/type/virtual_server> ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi_extra_node_6 ; # The hypervisor model
    noria:resourceManagedBy org:ApplicationSupportTeam ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_6> ;
    noria:resourceInstallationDate "2023-05-10T14:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_DNS01 ; # Example: DNS01 acts as a cluster controller for VMs
    noria:virtualServerStatus <kos/Resource/OperationalState/Running> ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_1_100 .

noria:Resource_WebFrontendVM02 a noria:Resource ;
    rdfs:label "Web Frontend VM 02"@en ;
    rdfs:comment "Virtual machine hosting web application frontend."@en ;
