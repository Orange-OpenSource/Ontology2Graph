# =============================================================================

# Network Interfaces for DNS01
noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to Core Switch_extra_node_6 01" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_6> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Running> .

noria:NetworkInterface_DNS01_Eth1 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 1"@en ;
    rdfs:comment "Secondary network interface for DNS01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Backup uplink" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_6> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Running> .

# Network Interfaces for CoreSwitch01
noria:NetworkInterface_CS01_Gi0_1 a noria:NetworkInterface ;
    rdfs:label "CS01 GigabitEthernet 0/1"@en ;
    rdfs:comment "Interface connecting to DNS01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreSwitch01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Link to dns01.corp.example.com" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_6> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Running> .

noria:NetworkInterface_CS01_Gi0_2 a noria:NetworkInterface ;
    rdfs:label "CS01 GigabitEthernet 0/2"@en ;
    rdfs:comment "Interface connecting to DB01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreSwitch01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Link to db01.prod.example.com" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_6> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Running> .

noria:NetworkInterface_CS01_Gi0_3 a noria:NetworkInterface ;
    rdfs:label "CS01 GigabitEthernet 0/3"@en ;
    rdfs:comment "Interface connecting to Edge Router_extra_node_6 01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreSwitch01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to er01.edge.example.com" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_6> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Running> .

# Network Interfaces for EdgeRouter01
noria:NetworkInterface_ER01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "ER01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Interface connecting to Core Switch_extra_node_6 01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Downlink to cs01.dc.example.com" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_6> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Running> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_ER01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "ER01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting to Internet Service Provider."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to ISP" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_6> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Running> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Network Links
noria:NetworkLink_DNS01_CS01 a noria:NetworkLink ;
    rdfs:label "Link DNS01-CS01"@en ;
    rdfs:comment "Physical link between DNS01 and Core Switch_extra_node_6 01."@en ;
    noria:networkLinkId "LINK-DC-001" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreSwitch01 ;
    noria:resourceManagedBy org:NetworkOperationsTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CS01_Gi0_1 .

noria:NetworkLink_CS01_ER01 a noria:NetworkLink ;
    rdfs:label "Link CS01-ER01"@en ;
    rdfs:comment "Physical link between Core Switch_extra_node_6 01 and Edge Router_extra_node_6 01."@en ;
    noria:networkLinkId "LINK-DC-002" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2021-11-20T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreSwitch01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeRouter01 ;
    noria:resourceManagedBy org:NetworkOperationsTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_CS01_Gi0_3 ;
    noria:networkInterfaceConnects noria:NetworkInterface_ER01_Gi0_0_0 .

noria:NetworkLink_ER01_ISP a noria:NetworkLink ;
    rdfs:label "Link ER01-ISP"@en ;
    rdfs:comment "External link from Edge Router_extra_node_6 01 to Internet Service Provider."@en ;
    noria:networkLinkId "LINK-EXT-001" ;
    noria:networkLinkType "Fiber Optic 100Gbps" ;
    noria:networkLinkInstallationDate "2022-02-10T13:45:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_EdgeRouter01 ;
    noria:resourceManagedBy org:NetworkOperationsTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_ER01_Gi0_0_1 .

