# =============================================================================
# 1. Agents and Organizations
# =============================================================================

# Organizations
org:OrangeSA a org:Organization ;
    rdfs:label "Orange S.A."@en ;
    rdfs:comment "The main telecommunications company."@en .

org:DellTechnologies_extra_node_6 a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of IT hardware and software."@en .

org:CiscoSystems_extra_node_6 a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

org:MicrosoftCorp a org:Organization ;
    rdfs:label "Microsoft Corporation"@en ;
    rdfs:comment "Software and cloud services provider."@en .

# Organizational Units (Teams)
org:NetworkOperationsTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure_extra_node_6."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_6> ;
    noria:agentInstructions "For critical_extra_node_6 issues, call the hotline. For non-critical_extra_node_6, use the ticketing system."@en ;
    org:memberOf org:OrangeSA .

org:ApplicationSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business_extra_node_6 applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_6> ;
    noria:agentInstructions "Email_extra_node_6 for all requests, critical_extra_node_6 issues via ticketing system."@en ;
    org:memberOf org:OrangeSA .

org:SecurityOperationsCenter a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring_extra_node_6 and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure_chat> ;
    noria:agentInstructions "Immediate escalation for any detected threat."@en ;
    org:memberOf org:OrangeSA .

org:DatabaseAdminTeam a org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri, on-call for emergencies"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing_system> ;
    noria:agentInstructions "Submit all database-related requests via the DB ticketing system."@en ;
    org:memberOf org:OrangeSA .

# Individual Agents (Employees)
foaf:Agent1 a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_6> ;
    org:memberOf org:NetworkOperationsTeam .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_6> ;
    org:memberOf org:ApplicationSupportTeam .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "SOC Analyst Level 2."@en ;
    noria:agentWorkingHours "Shift-based 24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure_chat> ;
    org:memberOf org:SecurityOperationsCenter .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Diana Prince"@en ;
    rdfs:comment "Database Administrator."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing_system> ;
    org:memberOf org:DatabaseAdminTeam .

# Corporate User Identifiers
noria:CUid_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    foaf:accountName "asmith" ;
    observable:accountIdentifier "asmith@corp.example.com" ;
    foaf:holdsAccount foaf:Agent1 .

noria:CUid_BJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    foaf:accountName "bjohnson" ;
    observable:accountIdentifier "bjohnson@corp.example.com" ;
    foaf:holdsAccount foaf:Agent2 .

