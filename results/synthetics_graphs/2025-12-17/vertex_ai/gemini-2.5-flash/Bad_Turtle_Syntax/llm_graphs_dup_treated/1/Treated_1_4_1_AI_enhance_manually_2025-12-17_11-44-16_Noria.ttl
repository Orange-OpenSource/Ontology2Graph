    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_5> ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_5 ;
    noria:resourceManagementIPAddress observable:IPAddress_WEB01_MGMT .

noria:Resource_RouterCore01_extra_node_5 a noria:Resource ;
    rdfs:label "Core Router_extra_node_5 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy org:NetworkTeam_extra_node_5 ;
    noria:resourceHostName "routercore01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K_extra_node_5 ;
    noria:resourceType <kos/Resource/type/Router_extra_node_5> ;
    noria:resourceSerialNumber "SN-RTR01-DEF456" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_5> ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_5 ;
    noria:resourceManagementIPAddress observable:IPAddress_RTR01_MGMT .

noria:Resource_Firewall01_extra_node_5 a noria:Resource ;
    rdfs:label "Perimeter Firewall_extra_node_5 01"@en ;
    rdfs:comment "Primary firewall protecting the corporate network from external threats."@en ;
