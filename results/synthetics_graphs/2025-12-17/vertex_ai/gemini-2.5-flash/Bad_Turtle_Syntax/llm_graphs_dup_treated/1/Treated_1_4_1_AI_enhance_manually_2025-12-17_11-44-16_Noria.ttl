# Network Links
noria:NL_DB_Switch a noria:NetworkLink ;
    rdfs:label "Link DBServer01 to Core Switch_extra_node_5"@en ;
    noria:networkLinkId "NL-DB01-SW01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-03-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_DB01_Eth0 ;
    noria:networkLinkTerminationResource noria:Resource_DBServer01_extra_node_5 ;
    noria:networkLinkTerminationResource noria:Resource_Router_extra_node_5Core01_extra_node_5 . # Assuming Core Router_extra_node_5 acts as a switch for simplicity

noria:NL_Web_Switch a noria:NetworkLink ;
    rdfs:label "Link WebServer01 to Core Switch_extra_node_5"@en ;
    noria:networkLinkId "NL-WEB01-SW01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-03-15T10:20:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_WEB01_Eth0 ;
    noria:networkLinkTerminationResource noria:Resource_WebServer01_extra_node_5 ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01_extra_node_5 .

noria:NL_RTR_FW_Internal a noria:NetworkLink ;
    rdfs:label "Link RouterCore01 to Firewall01 Internal_extra_node_5"@en ;
    noria:networkLinkId "NL-RTR01-FW01-INT" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-03-10T09:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_RTR01_Gig0_0_1 ;
    noria:networkInterfaceConnects noria:NI_FW01_Eth1 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01_extra_node_5 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01_extra_node_5 .

noria:NL_FW_ISP_Uplink a noria:NetworkLink ;
    rdfs:label "Link Firewall01 to ISP Uplink"@en ;
    noria:networkLinkId "NL-FW01-ISP" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2022-03-10T09:30:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_FW01_Eth0 ;
    noria:networkLinkTerminationResource noria:Resource_Firewall01_extra_node_5 .

noria:NL_VM_VHost a noria:NetworkLink ;
