    noria:locatedAtLocus noria:Locus_RackA1_extra_node_5 ;
    noria:resourceManagementIPAddress observable:IPAddress_FW01_MGMT .

noria:Resource_VirtualHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server running VMware ESXi to host virtual machines."@en ;
    noria:resourceManagedBy org:ITOpsTeam_extra_node_5 ;
