# =============================================================================
# Operational Procedures and Anomaly Patterns
# =============================================================================

noria:OperationPlan_ClearDiskSpace a noria:OperationPlan ;
    rdfs:label "Procedure: Clear Disk Space on DB Servers"@en ;
    rdfs:comment "Standard_extra_node_5 operating procedure for resolving disk space issues on database servers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DiskFull ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DiskSpaceCleared .

noria:OperationPlan_TroubleshootNetworkLink a noria:OperationPlan ;
    rdfs:label "Procedure: Troubleshoot Network Link Failure_extra_node_5"@en ;
    rdfs:comment "Procedure for diagnosing and resolving network link outages."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_LinkDown_extra_node_5 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LinkUp_extra_node_5 .

noria:ActionPreCondition_DiskFull a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Disk Usage > 90%"@en ;
    rdfs:comment "Condition indicating that disk usage on a server has exceeded 90%."@en .

noria:ActionPreCondition_LinkDown_extra_node_5 a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Network Interface Operational Status is Down"@en ;
    rdfs:comment "Condition indicating that a network interface's operational status is 'down'."@en .

noria:ActionPostCondition_DiskSpaceCleared a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Disk Usage < 80%"@en ;
    rdfs:comment "Expected outcome: Disk usage on the server is below 80%."@en .

noria:ActionPostCondition_LinkUp_extra_node_5 a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Network Interface Operational Status is Up_extra_node_5"@en ;
    rdfs:comment "Expected outcome: Network interface's operational status is 'up_extra_node_5'."@en .

noria:AnomalyPattern_HighDiskUsage a noria:AnomalyPattern ;
    rdfs:label "Anomaly Pattern: Persistent High Disk Usage"@en ;
    rdfs:comment "Describes a recurring pattern of high_extra_node_5 disk usage leading to performance degradation or outages."@en ;
    folio:hasCause noria:EventRecord_DBDiskFull . # Linking an anomaly pattern to a specific event as an example

noria:AnomalyPattern_FlappingInterface a noria:AnomalyPattern ;
    rdfs:label "Anomaly Pattern: Network Interface Flapping"@en ;
    rdfs:comment "Describes a pattern where a network interface repeatedly goes up_extra_node_5 and down in a short period."@en ;
    folio:hasCause noria:EventRecord_RouterInterfaceDown_extra_node_5 .

# Linking Operation Plans to Change Requests (as actions)
noria:ChangeRequest_DBUpgrade noria:actionCorrelatedOperationPlan noria:OperationPlan_ClearDiskSpace . # Example: part of the upgrade might involve clearing space.

# Linking Event Records to Trouble Tickets (status history)
noria:TroubleTicket_DBOutage noria:documentStatusHistory noria:EventRecord_DBDiskFull .
noria:TroubleTicket_NetworkConnectivity noria:documentStatusHistory noria:EventRecord_RouterInterfaceDown_extra_node_5 .

# Example of alarm mitigation
noria:EventRecord_DBDiskFull noria:alarmMitigatedBy noria:TroubleTicket_DBOutage . # The trouble ticket process is mitigating the alarm.

# Example of virtual server status
noria:Resource_VM_CRMApp noria:virtualServerStatus <kos/Resource/OperationalState/up_extra_node_5> .

# Example of network interface thresholds
noria:NI_RTR01_Gig0_0_0 noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Example of agent managing resources
org:ITOpsTeam_extra_node_5 noria:agentManagesResource noria:Resource_WebServer01_extra_node_5 .
org:NetworkTeam_extra_node_5 noria:agentManagesResource noria:Resource_RouterCore01_extra_node_5 .
org:SecurityTeam_extra_node_5 noria:agentManagesResource noria:Resource_Firewall01_extra_node_5 .
org:DatabaseTeam noria:agentManagesResource noria:Resource_DBServer01_extra_node_5 .
org:AppDevTeam_extra_node_5 noria:agentManagesResource noria:Resource_VM_CRMApp .

# Example of CorporateUserIdentifier usage
noria:CUid_jdoe rdfs:comment "Corporate login for John Doe, used to access IT resources."@en .
noria:CUid_jsmith rdfs:comment "Corporate login for Jane Smith, used for network device access."@en .

# Example of a more complex relationship for a TroubleTicketCharacteristic
noria:TroubleTicket_DBOutage noria:troubleTicketCharacteristic noria:TTChar_HighIOPS .

noria:TTChar_HighIOPS a noria:Property ; # Using noria:Property as a generic characteristic
    rdfs:label "High IOPS Characteristic"@en ;
    rdfs:comment "Indicates that the database server experienced unusually high_extra_node_5 I/O operations per second prior to the outage."@en .

# Example of a TroubleTicketFreezeItem
noria:TroubleTicket_DBOutage noria:troubleTicketFreezeItem noria:EventRecord_TTFreeze_DBOutage .

noria:EventRecord_TTFreeze_DBOutage a noria:EventRecord ;
    rdfs:label "Trouble Ticket DB Outage Freeze Event"@en ;
    rdfs:comment "Event indicating the DB Outage ticket was temporarily frozen due to awaiting vendor response."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Ticket TT-20240420-001 status changed to Frozen: Awaiting vendor response for disk expansion."@en ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_5 .

# Example of a TroubleTicketPartyIntervention
noria:TroubleTicket_DBOutage noria:troubleTicketPartyIntervention noria:TTIntervention_DBTeam .

noria:TTIntervention_DBTeam a noria:Property ; # Using noria:Property as a generic intervention record
    rdfs:label "DB Team Intervention Record"@en ;
    rdfs:comment "Record of the Database Team taking ownership and performing initial diagnosis on TT-20240420-001."@en ;
    dcterms:created "2024-04-20T08:40:00Z"^^xsd:dateTime ;
    dcterms:creator org:DatabaseTeam .

# Example of a ChangeRequestNote (using dcterms:hasPart for a generic note)
noria:ChangeRequest_DBUpgrade dcterms:hasPart noria:CRNote_VendorApproval .

noria:CRNote_VendorApproval a BBO:DocumentResource ; # Using BBO:DocumentResource for a generic note
    rdfs:label "Vendor Approval Note for DB Upgrade"@en ;
    rdfs:comment "Note confirming vendor approval for the database software upgrade."@en ;
    dcterms:created "2024-04-22T11:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JohnDoe_extra_node_5 .

# Example of a ChangeRequestAttachment
noria:ChangeRequest_DBUpgrade dcterms:hasPart noria:CRAttachment_UpgradePlan .

noria:CRAttachment_UpgradePlan a noria:DocumentAttachment ;
    rdfs:label "Database Upgrade Plan Document"@en ;
    rdfs:comment "Detailed plan for the database software upgrade, including rollback procedures."@en ;
    dcterms:created "2024-04-20T15:00:00Z"^^xsd:dateTime .
