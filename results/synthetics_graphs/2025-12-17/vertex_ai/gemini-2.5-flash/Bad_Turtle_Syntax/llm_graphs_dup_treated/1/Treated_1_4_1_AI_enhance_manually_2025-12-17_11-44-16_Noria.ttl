    rdfs:label "Enterprise Resource Planning System"@en ;
    rdfs:comment "Integrated management of main business_extra_node_5 processes."@en ;
    noria:applicationModelIdentifier "ERP-PROD-V3" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "ERP" ;
    noria:applicationType <kos/application/type/business_extra_node_5-application_extra_node_5> ;
