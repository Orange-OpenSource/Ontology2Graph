noria:Resource_DBServer01_extra_node_5 a noria:Resource ;
    rdfs:label "Production Database Server_extra_node_5 01"@en ;
    rdfs:comment "Primary database server for critical_extra_node_5 business_extra_node_5 applications."@en ;
