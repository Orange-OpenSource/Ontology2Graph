    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_5 ;
    noria:resourceType <kos/Resource/type/PhysicalServer> ;
    noria:resourceSerialNumber "SN-DB01-XYZ789" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_5> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB2 ;
    noria:resourceManagementIPAddress observable:IPAddress_DB01_MGMT .

noria:Resource_WebServer01_extra_node_5 a noria:Resource ;
    rdfs:label "Production Web Server_extra_node_5 01"@en ;
    rdfs:comment "Web server hosting the main corporate website."@en ;
