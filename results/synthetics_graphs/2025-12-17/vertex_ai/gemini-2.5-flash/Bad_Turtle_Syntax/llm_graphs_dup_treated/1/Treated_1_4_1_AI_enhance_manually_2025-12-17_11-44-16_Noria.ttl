    rdfs:comment "Network Architect in the Network Operations Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone_extra_node_5 "+1-555-987-6543" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

foaf:Agent_AliceJohnson a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Senior Developer in the Application Development_extra_node_5 Team."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    foaf:phone_extra_node_5 "+1-555-111-2222" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

foaf:Agent_BobWhite a foaf:Agent ;
    rdfs:label "Bob White"@en ;
    rdfs:comment "Security Analyst in the Cybersecurity Operations Center."@en ;
    foaf:mbox <mailto:bob.white@example.com> ;
    foaf:phone_extra_node_5 "+1-555-333-4444" ;
    noria:agentWorkingHours "24/7 Shift A"@en .

# Corporate User Identifiers
noria:CUid_jdoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    observable:accountIdentifier "jdoe_corp_id_12345" .

noria:CUid_jsmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    observable:accountIdentifier "jsmith_corp_id_67890" .

foaf:Agent_JohnDoe_extra_node_5 foaf:holdsAccount noria:CUid_jdoe .
foaf:Agent_JaneSmith_extra_node_5 foaf:holdsAccount noria:CUid_jsmith .

