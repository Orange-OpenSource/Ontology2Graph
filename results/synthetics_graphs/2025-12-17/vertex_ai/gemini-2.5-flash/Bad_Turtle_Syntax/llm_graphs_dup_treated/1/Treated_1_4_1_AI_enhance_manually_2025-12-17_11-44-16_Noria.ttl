    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_5> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis_extra_node_5> ;
    dcterms:isPartOf noria:TroubleTicket_NetworkConnectivity .

