noria:Resource_VM_CRMApp a noria:Resource ;
    rdfs:label "CRM Application VM"@en ;
    rdfs:comment "Virtual machine hosting the CRM application components."@en ;
    noria:resourceManagedBy org:AppDevTeam_extra_node_5 ;
    noria:resourceHostName "vm-crmapp01.corp.example.com" ;
