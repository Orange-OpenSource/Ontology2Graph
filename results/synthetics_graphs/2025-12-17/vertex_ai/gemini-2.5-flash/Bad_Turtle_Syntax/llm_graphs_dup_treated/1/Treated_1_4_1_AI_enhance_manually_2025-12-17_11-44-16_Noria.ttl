# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizational Units (Teams)
org:ITOpsTeam_extra_node_5 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure_extra_node_5 operations and incident response."@en ;
    noria:agentWorkingHours "24/7 (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_5> ;
    noria:agentInstructions "For critical_extra_node_5 issues, open a P1_extra_node_5 ticket and call the hotline."@en .

org:NetworkTeam_extra_node_5 a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_5> ;
    noria:agentInstructions "Submit network change requests via the dedicated portal."@en .

org:AppDevTeam_extra_node_5 a org:OrganizationalUnit ;
    rdfs:label "Application Development_extra_node_5 Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business_extra_node_5 applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/InternalChat> ;
    noria:agentInstructions "Contact for application-specific issues or feature requests."@en .

org:SecurityTeam_extra_node_5 a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team dedicated to monitoring_extra_node_5, detecting, and responding to cybersecurity threats."@en ;
    noria:agentWorkingHours "24/7 (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts_extra_node_5> ;
    noria:agentInstructions "All security incidents must be reported immediately through the SIEM."@en .

org:DatabaseTeam a org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_5> ;
    noria:agentInstructions "For database performance issues, provide query logs."@en .

