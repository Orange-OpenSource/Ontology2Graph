noria:Application_CRMSystem_extra_node_5 a noria:Application ;
    rdfs:label "Customer_extra_node_5 Relationship Management System"@en ;
    rdfs:comment "Core application for managing customer interactions and sales."@en ;
    noria:applicationModelIdentifier "CRM-PROD-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/business_extra_node_5-application_extra_node_5> ;
    noria:applicationBusinessImportance <kos/application/business_extra_node_5-importance/high_extra_node_5> ;
    noria:applicationFunctionalDomain "Customer_extra_node_5 Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales and Service Management" ;
