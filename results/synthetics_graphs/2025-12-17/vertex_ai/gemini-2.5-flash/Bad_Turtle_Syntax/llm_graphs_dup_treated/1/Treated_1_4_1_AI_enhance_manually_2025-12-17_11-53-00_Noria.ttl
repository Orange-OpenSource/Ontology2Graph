@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# =============================================================================
# 1. Organizational Entities (foaf:Agent, org:Organization, org:OrganizationalUnit)
# =============================================================================

# Organizations
org:OrangeCorp a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main corporate entity."@en .

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for overall IT infrastructure_extra_node_8 and operations."@en ;
    org:unitOf org:OrangeCorp .

org:NetworkTeam_extra_node_8 a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure_extra_node_8."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_8> ;
    noria:agentInstructions "For critical_extra_node_8 issues, call the hotline after sending an email."@en .

org:ServerTeam a org:OrganizationalUnit ;
    rdfs:label "Server_extra_node_8 Administration Team"@en ;
    rdfs:comment "Team managing server infrastructure_extra_node_8."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem_extra_node_8> .

org:AppDevTeam_extra_node_8 a org:OrganizationalUnit ;
    rdfs:label "Application Development_extra_node_8 Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business_extra_node_8 applications."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Chat> .

org:SecurityTeam_extra_node_8 a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team responsible for monitoring_extra_node_8 and responding to security incidents."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

# Agents (Persons)
foaf:Agent_Alice a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone_extra_node_8 "+33123456789" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_8> ;
    noria:agentManagesResource noria:Router_Core1, noria:Firewall_DMZ1 .

foaf:Agent_Bob a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Server_extra_node_8 Administrator."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone_extra_node_8 "+33987654321" ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem_extra_node_8> ;
    noria:agentManagesResource noria:Server_Web1, noria:Server_DB1 .

foaf:Agent_Carol a foaf:Agent ;
    rdfs:label "Carol White"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    foaf:mbox <mailto:carol.white@example.com> ;
    foaf:phone_extra_node_8 "+33611223344" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Chat> ;
    noria:agentManagesResource noria:App_CRM, noria:App_ERP .

foaf:Agent_David a foaf:Agent ;
    rdfs:label "David Green"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:david.green@example.com> ;
    foaf:phone_extra_node_8 "+33755667788" ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

# Corporate User Identifiers
noria:CUid_Alice a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate login for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount foaf:Agent_Alice .

noria:CUid_Bob a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate login for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount foaf:Agent_Bob .

# =============================================================================
# 2. Location Entities (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center location in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site_LyonOffice a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoom1_extra_node_8 a noria:Room ;
    rdfs:label "Server_extra_node_8 Room 1"@en ;
    rdfs:comment "Main server room within Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Room_NetworkCloset a noria:Room ;
    rdfs:label "Network Closet 201"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace bot:Site_LyonOffice .

noria:Locus_RackA1_extra_node_8 a noria:Locus ;
    rdfs:label "Rack A1 in Server_extra_node_8 Room 1"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoom1_extra_node_8 .

noria:Locus_RackB5 a noria:Locus ;
    rdfs:label "Rack B5 in Server_extra_node_8 Room 1"@en ;
    rdfs:comment "Specific rack location for network devices."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room_ServerRoom1_extra_node_8 .

noria:Locus_WallMount1 a noria:Locus ;
    rdfs:label "Wall Mount 1 in Network Closet 201"@en ;
    rdfs:comment "Wall mount location for small network devices."@en ;
    noria:locusLine "WM" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_NetworkCloset .

# =============================================================================
# 3. Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740_extra_node_8 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy org:OrangeCorp . # Assuming Orange is also a manufacturer or reseller for simplicity, or create a new org:Dell .

noria:ProductModel_CiscoNexus9K_extra_node_8 a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series."@en ;
    noria:productManufacturedBy org:OrangeCorp .

noria:ProductModel_PaloAltoFW_extra_node_8 a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy org:OrangeCorp .

noria:ProductModel_VMwareESXi_extra_node_8 a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor_extra_node_8"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy org:OrangeCorp .

# =============================================================================
# 4. Resources (noria:Resource, noria:NetworkInterface, noria:NetworkLink)
# =============================================================================

# Servers
noria:Server_Web1 a noria:Resource ;
    rdfs:label "Web Server_extra_node_8 01"@en ;
    rdfs:comment "Primary web server hosting corporate applications."@en ;
    noria:resourceLogisticId "SRV-WEB-01-PAR" ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_8 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server_extra_node_8> ;
    noria:resourceSerialNumber "SN-WEB01-XYZ123" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_8> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:ServerTeam ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_8 ;
    noria:resourceManagementIPAddress observable:IPAddress_Web1Mgmt .

noria:Server_DB1 a noria:Resource ;
    rdfs:label "Database Server_extra_node_8 01"@en ;
    rdfs:comment "Primary database server for critical_extra_node_8 applications."@en ;
    noria:resourceLogisticId "SRV-DB-01-PAR" ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_8 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server_extra_node_8> ;
    noria:resourceSerialNumber "SN-DB01-ABC456" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_8> ;
    noria:resourceInstallationDate "2022-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:ServerTeam ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_8 ;
    noria:resourceManagementIPAddress observable:IPAddress_DB1Mgmt .

noria:VM_App1 a noria:Resource ;
    rdfs:label "Virtual Machine for CRM App"@en ;
    rdfs:comment "Virtual machine hosting the CRM application module."@en ;
    noria:resourceHostName "crm-vm01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi_extra_node_8 ; # The hypervisor model, not the VM itself
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine_extra_node_8> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_8> ;
    noria:resourceInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:ServerTeam ;
    noria:clusterController noria:Server_Web1 ; # Assuming Web1 is also a hypervisor host
    noria:resourceManagementIPAddress observable:IPAddress_VMApp1Mgmt .

# Network Devices
noria:Router_Core1 a noria:Resource ;
    rdfs:label "Core Router_extra_node_8 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceLogisticId "RTR-CORE-01-PAR" ;
    noria:resourceHostName "core-rtr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K_extra_node_8 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router_extra_node_8> ;
    noria:resourceSerialNumber "SN-RTR01-DEF789" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_8> ;
    noria:resourceInstallationDate "2021-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam_extra_node_8 ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress observable:IPAddress_RtrCore1Mgmt .

noria:Firewall_DMZ1 a noria:Resource ;
    rdfs:label "DMZ Firewall_extra_node_8 01"@en ;
    rdfs:comment "Firewall_extra_node_8 protecting the DMZ segment."@en ;
    noria:resourceLogisticId "FW-DMZ-01-PAR" ;
    noria:resourceHostName "dmz-fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_PaloAltoFW_extra_node_8 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall_extra_node_8> ;
    noria:resourceSerialNumber "SN-FW01-GHI012" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_8> ;
    noria:resourceInstallationDate "2022-01-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam_extra_node_8 ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress observable:IPAddress_FwDMZ1Mgmt .

noria:Switch_AccessLyon a noria:Resource ;
    rdfs:label "Lyon Access Switch_extra_node_8"@en ;
    rdfs:comment "Access layer switch in Lyon office."@en ;
    noria:resourceLogisticId "SW-ACC-01-LYN" ;
    noria:resourceHostName "lyon-sw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K_extra_node_8 ; # Using same product model for simplicity
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch_extra_node_8> ;
    noria:resourceSerialNumber "SN-SWLYN-JKL345" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_8> ;
    noria:resourceInstallationDate "2023-05-20T13:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam_extra_node_8 ;
    noria:locatedAtLocus noria:Locus_WallMount1 ;
    noria:resourceManagementIPAddress observable:IPAddress_SwLyonMgmt .

# IP Addresses (as observable:IPAddress, not noria:Resource)
observable:IPAddress_Web1Mgmt a observable:IPAddress ;
    rdfs:label "Web Server_extra_node_8 01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.10" .

observable:IPAddress_DB1Mgmt a observable:IPAddress ;
    rdfs:label "Database Server_extra_node_8 01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.11" .

observable:IPAddress_VMApp1Mgmt a observable:IPAddress ;
    rdfs:label "CRM VM Management IP"@en ;
    observable:ipAddressValue "10.0.0.12" .

observable:IPAddress_RtrCore1Mgmt a observable:IPAddress ;
    rdfs:label "Core Router_extra_node_8 01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.1" .

observable:IPAddress_FwDMZ1Mgmt a observable:IPAddress ;
    rdfs:label "DMZ Firewall_extra_node_8 01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.2" .

observable:IPAddress_SwLyonMgmt a observable:IPAddress ;
    rdfs:label "Lyon Access Switch_extra_node_8 Management IP"@en ;
    observable:ipAddressValue "10.0.1.1" .

# Network Interfaces
noria:NI_Web1_Eth0 a noria:NetworkInterface ;
