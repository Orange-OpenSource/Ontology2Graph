    noria:logOriginatingManagedObject noria:Server_Web1 ; # Assuming Web1 tries to resolve DNS
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "DNS resolution failed for primary DNS server dns01.corp.example.com (10.0.0.100)."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical_extra_node_8> .

noria:Event_Router_InterfaceDown a noria:EventRecord ;
