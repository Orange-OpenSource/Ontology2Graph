    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up_extra_node_8> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up_extra_node_8> ;
    noria:networkInterfaceDescription "Uplink to corporate LAN" .

noria:NI_VMApp1_Eth0 a noria:NetworkInterface ;
