noria:NI_FwDMZ1_Eth0_0 a noria:NetworkInterface ;
    rdfs:label "dmz-fw01.corp.example.com:Eth0/0"@en ;
    rdfs:comment "Ethernet interface connecting to Core Router_extra_node_8."@en ;
