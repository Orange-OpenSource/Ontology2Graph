# =============================================================================
# SKOS Concept Definitions (for property ranges)
# These are not part of the NORIA ontology itself, but are used as values for NORIA properties.
# They follow the pattern provided in the NORIA schema.
# =============================================================================

# Application Types
<kos/application/type/infrastructure_extra_node_3> a skos:Concept ; skos:prefLabel "Infrastructure Application"@en .
<kos/application/type/business_extra_node_3> a skos:Concept ; skos:prefLabel "Business Application"@en .
<kos/application/type/monitoring_extra_node_3> a skos:Concept ; skos:prefLabel "Monitoring Application"@en .
