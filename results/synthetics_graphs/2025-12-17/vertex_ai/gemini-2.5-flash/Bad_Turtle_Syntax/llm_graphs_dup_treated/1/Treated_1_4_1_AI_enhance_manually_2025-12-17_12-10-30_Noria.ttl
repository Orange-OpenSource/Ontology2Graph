    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_3> .

noria:EventRecord_RouterInterfaceDown_extra_node_3 a noria:EventRecord ;
    rdfs:label "Router_extra_node_3 Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that interface ge-0/0/0 on router-core-01 went down."@en ;
