    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform_extra_node_3 ;
    noria:logText "WARNING: websrv01.corp.example.com CPU utilization > 90% for 5 minutes" ;
