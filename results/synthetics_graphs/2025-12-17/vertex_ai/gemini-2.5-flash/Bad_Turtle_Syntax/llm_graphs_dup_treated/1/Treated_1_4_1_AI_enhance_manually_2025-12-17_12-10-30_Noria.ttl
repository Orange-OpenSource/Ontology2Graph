# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_DNSAdminTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_3> ;
    noria:agentInstructions "Submit a ticket via the corporate ITSM portal for all DNS-related issues."@en .

foaf:Agent_NetworkOpsTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure_extra_node_3 and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_3> ;
    noria:agentInstructions "For critical_extra_node_3 network outages, call the emergency hotline. For other issues, use the ticketing system."@en .

foaf:Agent_AppDevTeam_CRM a foaf:Agent ;
    rdfs:label "CRM Application Development_extra_node_3 Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the Customer_extra_node_3 Relationship Management application."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_3> ;
    noria:agentInstructions "Email_extra_node_3 for non-urgent requests, ticketing system for bugs."@en .

foaf:Agent_SecurityTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "Cyber Security Operations Center (CSOC)"@en ;
    rdfs:comment "Monitors and responds to security incidents across the IT landscape."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_3> ;
    noria:agentInstructions "All security incidents must be reported via the dedicated security incident portal."@en .

foaf:Agent_DBA_Team a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Manages all corporate database systems."@en ;
    noria:agentWorkingHours "08:30-17:30 Mon-Fri, On-Call for critical_extra_node_3 issues"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_3> ;
    noria:agentInstructions "For database performance issues or outages, create a high_extra_node_3-priority ticket."@en .

foaf:Agent_JohnDoe_extra_node_3 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual network engineer, member of Network Operations Team."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_3> .

foaf:Agent_JaneSmith_extra_node_3 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual application developer, member of CRM Application Development_extra_node_3 Team."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_3> .

org:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department of the company."@en .

org:OrgUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Organizational unit for network operations."@en ;
    org:unitOf org:Org_ITDepartment ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_3> .

org:OrgUnit_AppDev a org:OrganizationalUnit ;
    rdfs:label "Application Development_extra_node_3 Unit"@en ;
    rdfs:comment "Organizational unit for application development."@en ;
    org:unitOf org:Org_ITDepartment .

noria:CorporateUserIdentifier_JDoe a noria:CorporateUserIdentifier ;
    rdfs:label "jdoe"@en ;
    foaf:accountName "jdoe" ;
    rdfs:comment "Corporate User_extra_node_3 ID for John Doe."@en .

noria:CorporateUserIdentifier_JSmith a noria:CorporateUserIdentifier ;
    rdfs:label "jsmith"@en ;
    foaf:accountName "jsmith" ;
    rdfs:comment "Corporate User_extra_node_3 ID for Jane Smith."@en .

foaf:Agent_JohnDoe_extra_node_3 foaf:holdsAccount noria:CorporateUserIdentifier_JDoe .
foaf:Agent_JaneSmith_extra_node_3 foaf:holdsAccount noria:CorporateUserIdentifier_JSmith .

