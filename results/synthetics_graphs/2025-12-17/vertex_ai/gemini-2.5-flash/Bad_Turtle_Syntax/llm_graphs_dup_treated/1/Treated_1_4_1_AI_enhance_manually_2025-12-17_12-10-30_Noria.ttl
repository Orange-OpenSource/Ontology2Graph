    noria:logOriginatingManagedObject noria:NetworkInterface_RouterCore01_Ge0_0_0 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform_extra_node_3 ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down" ;
