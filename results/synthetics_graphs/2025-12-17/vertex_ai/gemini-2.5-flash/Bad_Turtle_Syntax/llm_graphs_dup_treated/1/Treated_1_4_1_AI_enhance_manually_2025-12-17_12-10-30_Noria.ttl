noria:Resource_DNS01_extra_node_3 a noria:Resource ;
    rdfs:label "Corporate DNS Server_extra_node_3 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, located in HQ Data Center."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam_extra_node_3 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_3 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceType <kos/Resource/type/Server_extra_node_3> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse_extra_node_3> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U10_extra_node_3 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_10 .

noria:Resource_RouterCore01_extra_node_3 a noria:Resource ;
    rdfs:label "Core Router_extra_node_3 01"@en ;
    rdfs:comment "Main core router for internal network traffic, located in HQ Data Center."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam_extra_node_3 ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480_extra_node_3 ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceType <kos/Resource/type/Router_extra_node_3> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse_extra_node_3> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB5_U2 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_1_extra_node_3 .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server_extra_node_3 01"@en ;
    rdfs:comment "Host for corporate website, virtual machine."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam_CRM ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi_extra_node_3 ; # The hypervisor model, not the VM OS
    noria:resourceLogisticId "ASSET-VM-WEB-001" ;
    noria:resourceSerialNumber "VM-WEB-001-UUID" ;
    noria:resourceType <kos/Resource/type/VirtualMachine_extra_node_3> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse_extra_node_3> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:IPAddress_172_16_0_10 ;
    noria:clusterController noria:Resource_VMwareCluster01_extra_node_3 .

noria:Resource_VMwareCluster01_extra_node_3 a noria:Resource ;
    rdfs:label "VMware Production Cluster 01"@en ;
    rdfs:comment "VMware vSphere cluster managing virtual machines."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam_extra_node_3 ; # Assuming infrastructure_extra_node_3 team manages virtualization
    noria:resourceHostName "vcenter01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_3 ; # Physical hosts in the cluster
    noria:resourceType <kos/Resource/type/Server_extra_node_3> ; # Representing the cluster as a logical server resource
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse_extra_node_3> ;
