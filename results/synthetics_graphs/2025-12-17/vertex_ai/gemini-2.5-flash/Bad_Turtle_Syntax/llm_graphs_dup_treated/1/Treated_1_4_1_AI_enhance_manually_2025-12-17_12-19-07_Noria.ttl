@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

# =============================================================================
# SKOS Concept Schemes and Concepts (for properties with owl:hasValue restrictions)
# =============================================================================

# Application related KOS
<https://w3id.org/noria/kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Concept Scheme"@en ;
    rdfs:comment "Defines types of applications within the NORIA ontology."@en .

<https://w3id.org/noria/kos/application/type/infrastructure_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application providing core infrastructure_extra_node_5 services."@en .

<https://w3id.org/noria/kos/application/type/business_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "An application directly supporting business_extra_node_5 operations."@en .

<https://w3id.org/noria/kos/application/type/monitoring_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "An application used for monitoring_extra_node_5 IT systems."@en .

<https://w3id.org/noria/kos/application/business_extra_node_5-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Concept Scheme"@en ;
    rdfs:comment "Defines levels of business_extra_node_5 importance for applications."@en .

<https://w3id.org/noria/kos/application/business_extra_node_5-importance/high_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business_extra_node_5-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical_extra_node_5 for business_extra_node_5 operations."@en .

<https://w3id.org/noria/kos/application/business_extra_node_5-importance/medium_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business_extra_node_5-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application is important but not critical_extra_node_5 for immediate business_extra_node_5 operations."@en .

<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Module Status Concept Scheme"@en ;
    rdfs:comment "Defines operational statuses for application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application module is currently live and operational."@en .

<https://w3id.org/noria/kos/application/status/Development_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Development_extra_node_5"@en ;
    rdfs:comment "Application module is under development."@en .

<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
    rdfs:label "Application Module SLA Level Concept Scheme"@en ;
    rdfs:comment "Defines Service Level Agreement levels for application modules."@en .

<https://w3id.org/noria/kos/application/sla-level/Gold_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold_extra_node_5 SLA Level"@en ;
    rdfs:comment "Highest SLA level with minimal downtime and rapid response."@en .

# Service related KOS
<https://w3id.org/noria/kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Concept Scheme"@en ;
    rdfs:comment "Defines types of services."@en .

<https://w3id.org/noria/kos/service/type/CustomerFacingService_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Customer_extra_node_5 Facing Service"@en ;
    rdfs:comment "A service directly consumed by customers."@en .

<https://w3id.org/noria/kos/service/type/ResourceFacingService_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service supporting other services or internal operations, not directly exposed to customers."@en .

# TroubleTicket related KOS
<https://w3id.org/noria/kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Concept Scheme"@en ;
    rdfs:comment "Defines severity levels for trouble tickets."@en .

<https://w3id.org/noria/kos/TroubleTicket/severity/Critical_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Critical_extra_node_5 Severity"@en ;
    rdfs:comment "Service completely down or major business_extra_node_5 impact."@en .

<https://w3id.org/noria/kos/TroubleTicket/severity/Major_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Major_extra_node_5 Severity"@en ;
    rdfs:comment "Service degraded or significant business_extra_node_5 impact."@en .

<https://w3id.org/noria/kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Concept Scheme"@en ;
    rdfs:comment "Defines types of trouble tickets."@en .

<https://w3id.org/noria/kos/TroubleTicket/type/Incident_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> ;
    rdfs:label "Incident_extra_node_5 Ticket"@en ;
    rdfs:comment "Ticket for an unplanned interruption to an IT service or reduction in the quality of an IT service."@en .

<https://w3id.org/noria/kos/TroubleTicket/category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Criticity Concept Scheme"@en ;
    rdfs:comment "Defines criticity levels for trouble tickets based on customer impact."@en .

<https://w3id.org/noria/kos/TroubleTicket/category/ServiceInterrupted> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/category> ;
    rdfs:label "Service Interrupted"@en ;
    rdfs:comment "The service is completely unavailable."@en .

<https://w3id.org/noria/kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Concept Scheme"@en ;
    rdfs:comment "Defines priority levels for trouble tickets."@en .

<https://w3id.org/noria/kos/TroubleTicket/priority/P1_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate action required."@en .

<https://w3id.org/noria/kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Concept Scheme"@en ;
    rdfs:comment "Defines the origin of a trouble ticket."@en .

<https://w3id.org/noria/kos/TroubleTicket/origin/Supervision_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> ;
    rdfs:label "Supervision_extra_node_5 System"@en ;
    rdfs:comment "Ticket originated from an automated monitoring_extra_node_5 or supervision system."@en .

<https://w3id.org/noria/kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Concept Scheme"@en ;
    rdfs:comment "Defines urgency levels for trouble tickets."@en .

<https://w3id.org/noria/kos/TroubleTicket/urgency/Immediate_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate_extra_node_5 Intervention"@en ;
    rdfs:comment "Requires immediate action to prevent further impact."@en .

<https://w3id.org/noria/kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category Concept Scheme"@en ;
    rdfs:comment "Defines categories for the nature of the trouble."@en .

<https://w3id.org/noria/kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> ;
    rdfs:label "Network Outage"@en ;
    rdfs:comment "Complete loss of network connectivity."@en .

<https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem_extra_node_5 Responsibility Concept Scheme"@en ;
    rdfs:comment "Defines areas of responsibility for problems."@en .

<https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/NetworkTeam_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Network Team Responsibility"@en ;
    rdfs:comment "Problem_extra_node_5 is attributed to the network operations team."@en .

<https://w3id.org/noria/kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Concept Scheme"@en ;
    rdfs:comment "Defines current activity statuses for trouble tickets."@en .

<https://w3id.org/noria/kos/TroubleTicket/status/InProgress_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Trouble ticket is currently being worked on."@en .

<https://w3id.org/noria/kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Concept Scheme"@en ;
    rdfs:comment "Defines types of comments for trouble ticket notes."@en .

<https://w3id.org/noria/kos/TroubleTicket/commentType/Internal_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> ;
    rdfs:label "Internal_extra_node_5 Comment"@en ;
    rdfs:comment "Comment intended for internal team use."@en .

<https://w3id.org/noria/kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Concept Scheme"@en ;
    rdfs:comment "Defines types of operations recorded in trouble ticket notes."@en .

<https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis_extra_node_5 Operation"@en ;
    rdfs:comment "Note detailing diagnostic steps taken."@en .

# ChangeRequest related KOS
<https://w3id.org/noria/kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Concept Scheme"@en ;
    rdfs:comment "Defines categories for change requests."@en .

<https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> ;
    rdfs:label "Internal_extra_node_5 Intervention"@en ;
    rdfs:comment "Change performed by internal teams."@en .

<https://w3id.org/noria/kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Concept Scheme"@en ;
    rdfs:comment "Defines types of change requests."@en .

<https://w3id.org/noria/kos/ChangeRequest/type/Standard_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> ;
    rdfs:label "Standard_extra_node_5 Change"@en ;
    rdfs:comment "Pre-authorized change with low risk and well-defined procedure."@en .

<https://w3id.org/noria/kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Concept Scheme"@en ;
    rdfs:comment "Defines causes or reasons for change requests."@en .

<https://w3id.org/noria/kos/ChangeRequest/cause/SoftwareUpgrade_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change initiated due to a software upgrade requirement."@en .

<https://w3id.org/noria/kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Concept Scheme"@en ;
    rdfs:comment "Defines current statuses for change requests."@en .

<https://w3id.org/noria/kos/ChangeRequest/status/Approved_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> ;
    rdfs:label "Approved_extra_node_5"@en ;
    rdfs:comment "Change request has been approved for implementation."@en .

# Resource related KOS
<https://w3id.org/noria/kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Concept Scheme"@en ;
    rdfs:comment "Defines operational states for resources."@en .

<https://w3id.org/noria/kos/Resource/OperationalState/Up_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Up_extra_node_5"@en ;
    rdfs:comment "Resource is operational."@en .

<https://w3id.org/noria/kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

<https://w3id.org/noria/kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Concept Scheme"@en ;
    rdfs:comment "Defines administrative states for resources."@en .

<https://w3id.org/noria/kos/Resource/AdministrativeState/Up_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ;
    rdfs:label "Up_extra_node_5"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

<https://w3id.org/noria/kos/Resource/AdministrativeState/Down> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

<https://w3id.org/noria/kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Concept Scheme"@en ;
    rdfs:comment "Defines types of IT resources."@en .

<https://w3id.org/noria/kos/Resource/type/Server_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Server_extra_node_5"@en ;
    rdfs:comment "A computing server resource."@en .

<https://w3id.org/noria/kos/Resource/type/Router_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Router_extra_node_5"@en ;
    rdfs:comment "A network router resource."@en .

<https://w3id.org/noria/kos/Resource/type/Switch_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Switch_extra_node_5"@en ;
    rdfs:comment "A network switch resource."@en .

<https://w3id.org/noria/kos/Resource/type/Firewall_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Firewall_extra_node_5"@en ;
    rdfs:comment "A network firewall resource."@en .

<https://w3id.org/noria/kos/Resource/type/VirtualHost> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Virtual Host"@en ;
    rdfs:comment "A physical server hosting virtual machines."@en .

<https://w3id.org/noria/kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Concept Scheme"@en ;
    rdfs:comment "Defines lifecycle states for resources."@en .

<https://w3id.org/noria/kos/Resource/LifecycleState/InUse> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ;
    rdfs:label "In Use"@en ;
    rdfs:comment "Resource is actively being used in production."@en .

# Notification related KOS
<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Concept Scheme"@en ;
    rdfs:comment "Defines perceived severity levels for notifications/alarms."@en .

<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical_extra_node_5 Perceived Severity"@en ;
    rdfs:comment "Indicates a critical_extra_node_5 condition requiring immediate attention."@en .

<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning_extra_node_5 Perceived Severity"@en ;
    rdfs:comment "Indicates a potential issue that may require attention."@en .

# Agent Contact Method KOS
<https://w3id.org/noria/kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Concept Scheme"@en ;
    rdfs:comment "Defines preferred contact methods for agents."@en .

<https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ;
    rdfs:label "Email_extra_node_5"@en ;
    rdfs:comment "Preferred contact method is email_extra_node_5."@en .

<https://w3id.org/noria/kos/org/agent-contact-method/Phone_extra_node_5> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ;
    rdfs:label "Phone_extra_node_5"@en ;
    rdfs:comment "Preferred contact method is phone_extra_node_5."@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_5> ;
    noria:agentInstructions "Email_extra_node_5 dns-support@example.com for non-critical_extra_node_5 issues. Call hotline for critical_extra_node_5 outages."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure_extra_node_5."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone_extra_node_5> ;
    noria:agentInstructions "Always call the NOC for network incidents."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development_extra_node_5 Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business_extra_node_5 applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_5> .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring_extra_node_5 and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone_extra_node_5> ;
    noria:agentInstructions "Report all security incidents immediately via phone_extra_node_5."@en .

foaf:Agent_JohnDoe_extra_node_5 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the Network Operations Team."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone_extra_node_5> .

foaf:Agent_JaneSmith_extra_node_5 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Application Development_extra_node_5 Team."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_5> .

org:Organization_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "Overall IT department of the company."@en ;
    org:hasUnit org:OrganizationalUnit_NetworkServices, org:OrganizationalUnit_ApplicationServices .

org:OrganizationalUnit_NetworkServices a org:OrganizationalUnit ;
    rdfs:label "Network Services Unit"@en ;
    rdfs:comment "Organizational unit responsible for network infrastructure_extra_node_5."@en ;
    org:unitOf org:Organization_ITDepartment ;
    org:member foaf:Agent_NetworkOpsTeam, foaf:Agent_JohnDoe_extra_node_5 .

org:OrganizationalUnit_ApplicationServices a org:OrganizationalUnit ;
    rdfs:label "Application Services Unit"@en ;
    rdfs:comment "Organizational unit responsible for application delivery."@en ;
    org:unitOf org:Organization_ITDepartment ;
    org:member foaf:Agent_AppDevTeam, foaf:Agent_JaneSmith_extra_node_5 .

noria:CorporateUserIdentifier_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe_extra_node_5 .

noria:CorporateUserIdentifier_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_JaneSmith_extra_node_5 .

# =============================================================================
# Locations
# =============================================================================

bot:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "USA"@en .

bot:Site_BranchOfficeA a bot:Site ;
    rdfs:label "Branch Office A"@en ;
    rdfs:comment "Remote branch office location."@en ;
    noria:siteId "BOA01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Business Road"@en ;
    noria:sitePrincipalAddressCityName "Smallville"@en ;
