    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "WARNING: websrv01.corp.example.com CPU utilization > 90% for 5 minutes" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_FirewallConfigChange a noria:EventRecord ;
