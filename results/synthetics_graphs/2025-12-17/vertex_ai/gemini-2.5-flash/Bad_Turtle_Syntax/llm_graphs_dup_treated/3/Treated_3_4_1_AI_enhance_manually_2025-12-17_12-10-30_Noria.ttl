noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing."@en ;
    noria:productManufacturedBy org:Org_Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Cisco data center switch series."@en ;
    noria:productManufacturedBy org:Org_Cisco .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "Juniper universal routing platform."@en ;
    noria:productManufacturedBy org:Org_Juniper .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for virtual machines."@en ;
    noria:productManufacturedBy org:Org_VMware .

org:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

org:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

org:Org_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking hardware and services."@en .

org:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization software company."@en .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, located in HQ Data Center."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U10 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_10 .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main core router for internal network traffic, located in HQ Data Center."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB5_U2 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_0_1 .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Host for corporate website, virtual machine."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam_CRM ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM OS
    noria:resourceLogisticId "ASSET-VM-WEB-001" ;
    noria:resourceSerialNumber "VM-WEB-001-UUID" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:IPAddress_172_16_0_10 ;
    noria:clusterController noria:Resource_VMwareCluster01 .

noria:Resource_VMwareCluster01 a noria:Resource ;
    rdfs:label "VMware Production Cluster 01"@en ;
    rdfs:comment "VMware vSphere cluster managing virtual machines."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ; # Assuming infrastructure team manages virtualization
    noria:resourceHostName "vcenter01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ; # Physical hosts in the cluster
    noria:resourceType <kos/Resource/type/Server> ; # Representing the cluster as a logical server resource
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-03-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U10 .

noria:Resource_FirewallDMZ a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:comment "Firewall protecting the Demilitarized Zone (DMZ)."@en ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:resourceHostName "fw-dmz-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Using a Cisco Nexus as a high-end firewall example
    noria:resourceLogisticId "ASSET-FW-001" ;
    noria:resourceSerialNumber "SN-FW-001-DEF" ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-08-10T16:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB5_U2 ;
    noria:resourceManagementIPAddress observable:IPAddress_10_0_1_1 .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Production Database Server 01"@en ;
    rdfs:comment "Primary database server for critical business applications."@en ;
    noria:resourceManagedBy foaf:Agent_DBA_Team ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceSerialNumber "SN-DB-001-GHI" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-11-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U10 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_20 .

