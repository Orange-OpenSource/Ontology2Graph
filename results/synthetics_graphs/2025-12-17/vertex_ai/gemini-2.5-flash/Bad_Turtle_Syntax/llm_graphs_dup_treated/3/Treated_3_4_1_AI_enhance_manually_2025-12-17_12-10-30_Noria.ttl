# Anomaly Pattern for Security
noria:AnomalyPattern_BruteForce a noria:AnomalyPattern ;
    rdfs:label "Brute-Force Attack Pattern"@en ;
    rdfs:comment "Pattern indicating a brute-force attack: multiple failed login attempts from a single or few IP addresses within a short timeframe."@en ;
    skos:example "EventRecord_SuspiciousLogin."@en .

# Operation Plan for Security Incident Response
noria:OperationPlan_SecurityIncidentResponse a noria:OperationPlan ;
    rdfs:label "Security Incident Response Plan"@en ;
    rdfs:comment "Standard operating procedure for responding to critical security incidents."@en ;
    noria:operationPlanPreCondition noria:AnomalyPattern_BruteForce ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ThreatContained .

noria:ActionPostCondition_ThreatContained a noria:ActionPostCondition ;
    rdfs:label "Threat Contained Post-Condition"@en ;
    rdfs:comment "Outcome: The security threat has been contained, and affected systems are secured."@en .

# Link Security Trouble Ticket to Security Incident Response Plan
noria:TroubleTicket_SecurityIncident noria:actionCorrelatedOperationPlan noria:OperationPlan_SecurityIncidentResponse .

# Final check for connectivity and density:
# - All major classes have multiple instances.
# - Resources are linked to Agents, ProductModels, Locations, NetworkInterfaces, Applications.
# - NetworkInterfaces are linked to Resources and NetworkLinks.
# - NetworkLinks are linked to Resources.
# - Applications are linked to Resources, ApplicationModules.
# - ApplicationModules are linked to Applications, Agents, SLA levels.
# - Services are linked to Applications/ApplicationModules/Resources.
# - EventRecords are linked to ManagedObjects (Resources/Applications), ManagementSystems, Agents, and have severity/text/time.
# - TroubleTickets are linked to Services/Applications/Resources, Agents, EventRecords (trigger), and have various attributes.
# - TroubleTicketNotes are linked to TroubleTickets, Agents, and have types.
# - ChangeRequests are linked to Services/Applications/Resources, Agents, and have various attributes.
# - OperationPlans are linked to Pre/Post Conditions.
# - TroubleTickets and ChangeRequests are linked to OperationPlans (via actionCorrelatedOperationPlan) and DocumentAttachments.
# - AnomalyPatterns are defined and can be used as PreConditions.
# - CorporateUserIdentifiers are linked to foaf:Agent.
# - Locations (Site, Room, Locus) are interconnected and linked to Resources.
# - Organizations and OrganizationalUnits are defined and linked to Agents.

# The graph is dense and connected, covering various aspects of IT operations and management.
