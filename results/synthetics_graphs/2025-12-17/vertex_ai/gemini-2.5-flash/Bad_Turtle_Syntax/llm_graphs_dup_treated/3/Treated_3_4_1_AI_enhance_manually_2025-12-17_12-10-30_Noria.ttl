    observable:ipAddressValue "10.0.0.1" .

observable:IPAddress_172_16_0_10 a observable:IPAddress ;
    rdfs:label "172.16.0.10"@en ;
    observable:ipAddressValue "172.16.0.10" .

observable:IPAddress_10_0_1_1 a observable:IPAddress ;
    rdfs:label "10.0.1.1"@en ;
    observable:ipAddressValue "10.0.1.1" .

observable:IPAddress_192_168_1_20 a observable:IPAddress ;
    rdfs:label "192.168.1.20"@en ;
    observable:ipAddressValue "192.168.1.20" .

# =============================================================================
# Network Interfaces and Links
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface 0 on Corporate DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
