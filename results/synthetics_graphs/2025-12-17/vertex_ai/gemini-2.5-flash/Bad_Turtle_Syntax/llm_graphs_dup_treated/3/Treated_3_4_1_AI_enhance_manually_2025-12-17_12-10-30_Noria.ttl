noria:TroubleTicket_SecurityIncident a noria:TroubleTicket ;
    rdfs:label "Security Incident: Brute-Force Attack"@en ;
    rdfs:comment "Investigation into a suspected brute-force attack against the production database server."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Incident> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_SuspiciousLogin ;
