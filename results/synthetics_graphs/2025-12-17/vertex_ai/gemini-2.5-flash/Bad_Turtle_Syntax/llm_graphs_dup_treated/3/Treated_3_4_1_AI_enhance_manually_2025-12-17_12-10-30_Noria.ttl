@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix time: <http://www.w3.org/2006/time#> .

# =============================================================================
# SKOS Concept Definitions (for property ranges)
# These are not part of the NORIA ontology itself, but are used as values for NORIA properties.
# They follow the pattern provided in the NORIA schema.
# =============================================================================

# Application Types
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure Application"@en .
<kos/application/type/business> a skos:Concept ; skos:prefLabel "Business Application"@en .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring Application"@en .
<kos/application/type/security> a skos:Concept ; skos:prefLabel "Security Application"@en .

# Application Business Importance
<kos/application/business-importance/critical> a skos:Concept ; skos:prefLabel "Critical Business Importance"@en .
<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; skos:prefLabel "Low Business Importance"@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:prefLabel "Maintenance"@en .

# Application Module SLA Level
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; skos:prefLabel "Gold SLA Level"@en .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; skos:prefLabel "Silver SLA Level"@en .
<https://w3id.org/noria/kos/application/sla-level/Bronze> a skos:Concept ; skos:prefLabel "Bronze SLA Level"@en .

# Service Types
<kos/service/type/customer-facing> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en .
<kos/service/type/resource-facing> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical Severity"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major Severity"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor Severity"@en .
<kos/TroubleTicket/severity/Warning> a skos:Concept ; skos:prefLabel "Warning Severity"@en .

# Trouble Ticket Type
<kos/TroubleTicket/type/Incident> a skos:Concept ; skos:prefLabel "Incident Ticket"@en .
<kos/TroubleTicket/type/Problem> a skos:Concept ; skos:prefLabel "Problem Ticket"@en .
<kos/TroubleTicket/type/Request> a skos:Concept ; skos:prefLabel "Service Request Ticket"@en .

# Trouble Ticket Criticity
<kos/TroubleTicket/category/ServiceInterruption> a skos:Concept ; skos:prefLabel "Service Interruption"@en .
<kos/TroubleTicket/category/PerformanceDegradation> a skos:Concept ; skos:prefLabel "Performance Degradation"@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en .
<kos/TroubleTicket/priority/P3> a skos:Concept ; skos:prefLabel "Priority 3"@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer Origin"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision System Origin"@en .
<kos/TroubleTicket/origin/Internal> a skos:Concept ; skos:prefLabel "Internal Origin"@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency/Immediate> a skos:Concept ; skos:prefLabel "Immediate Intervention"@en .
<kos/TroubleTicket/urgency/Deferred> a skos:Concept ; skos:prefLabel "Deferred Intervention"@en .

# Trouble Ticket Trouble Category
<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ; skos:prefLabel "Network Outage"@en .
<kos/TroubleTicket/trouble-category/ServerFailure> a skos:Concept ; skos:prefLabel "Server Failure"@en .
<kos/TroubleTicket/trouble-category/SoftwareBug> a skos:Concept ; skos:prefLabel "Software Bug"@en .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ; skos:prefLabel "Network Team Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ; skos:prefLabel "Application Team Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/Vendor> a skos:Concept ; skos:prefLabel "Vendor Responsibility"@en .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment"@en .
<kos/TroubleTicket/commentType/CustomerFacing> a skos:Concept ; skos:prefLabel "Customer Facing Comment"@en .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis Operation"@en .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; skos:prefLabel "Resolution Operation"@en .
<kos/TroubleTicket/operationType/Testing> a skos:Concept ; skos:prefLabel "Testing Operation"@en .

# Change Request Category
<kos/ChangeRequest/category/Maintenance> a skos:Concept ; skos:prefLabel "Maintenance Change"@en .
<kos/ChangeRequest/category/Upgrade> a skos:Concept ; skos:prefLabel "Upgrade Change"@en .
<kos/ChangeRequest/category/Configuration> a skos:Concept ; skos:prefLabel "Configuration Change"@en .

# Change Request Type
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change"@en .
<kos/ChangeRequest/type/Normal> a skos:Concept ; skos:prefLabel "Normal Change"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:prefLabel "Emergency Change"@en .

# Change Request Cause
<kos/ChangeRequest/cause/SecurityPatch> a skos:Concept ; skos:prefLabel "Security Patch"@en .
<kos/ChangeRequest/cause/PerformanceImprovement> a skos:Concept ; skos:prefLabel "Performance Improvement"@en .
<kos/ChangeRequest/cause/NewFeature> a skos:Concept ; skos:prefLabel "New Feature Deployment"@en .

# Change Request Status
<kos/ChangeRequest/status/Planned> a skos:Concept ; skos:prefLabel "Planned"@en .
<kos/ChangeRequest/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en .
<kos/ChangeRequest/status/Completed> a skos:Concept ; skos:prefLabel "Completed"@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:prefLabel "Approved"@en .

# Change Request Specification
<kos/ChangeRequest/specification/NetworkConfigUpdate> a skos:Concept ; skos:prefLabel "Network Configuration Update Plan"@en .
<kos/ChangeRequest/specification/ServerOSUpgrade> a skos:Concept ; skos:prefLabel "Server OS Upgrade Procedure"@en .

# Event Record Alarm Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:prefLabel "Minor Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ; skos:prefLabel "Indeterminate Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Cleared> a skos:Concept ; skos:prefLabel "Cleared Perceived Severity"@en .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Operational State Up"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Operational State Down"@en .
<kos/Resource/OperationalState/Degraded> a skos:Concept ; skos:prefLabel "Operational State Degraded"@en .

# Resource Administrative State
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ; skos:prefLabel "Administrative State Enabled"@en .
<kos/Resource/AdministrativeState/Disabled> a skos:Concept ; skos:prefLabel "Administrative State Disabled"@en .

# Resource Type
<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server Resource Type"@en .
<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router Resource Type"@en .
<kos/Resource/type/Switch> a skos:Concept ; skos:prefLabel "Switch Resource Type"@en .
<kos/Resource/type/Firewall> a skos:Concept ; skos:prefLabel "Firewall Resource Type"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine Resource Type"@en .
<kos/Resource/type/LoadBalancer> a skos:Concept ; skos:prefLabel "Load Balancer Resource Type"@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InUse> a skos:Concept ; skos:prefLabel "In Use Lifecycle State"@en .
<kos/Resource/LifecycleState/Standby> a skos:Concept ; skos:prefLabel "Standby Lifecycle State"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:prefLabel "Decommissioned Lifecycle State"@en .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email Contact Method"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone Contact Method"@en .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; skos:prefLabel "Ticketing System Contact Method"@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket via the corporate ITSM portal for all DNS-related issues."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical network outages, call the emergency hotline. For other issues, use the ticketing system."@en .

foaf:Agent_AppDevTeam_CRM a foaf:Agent ;
    rdfs:label "CRM Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the Customer Relationship Management application."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for non-urgent requests, ticketing system for bugs."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Cyber Security Operations Center (CSOC)"@en ;
    rdfs:comment "Monitors and responds to security incidents across the IT landscape."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All security incidents must be reported via the dedicated security incident portal."@en .

foaf:Agent_DBA_Team a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Manages all corporate database systems."@en ;
    noria:agentWorkingHours "08:30-17:30 Mon-Fri, On-Call for critical issues"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For database performance issues or outages, create a high-priority ticket."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual network engineer, member of Network Operations Team."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual application developer, member of CRM Application Development Team."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department of the company."@en .

org:OrgUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Organizational unit for network operations."@en ;
    org:unitOf org:Org_ITDepartment ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:OrgUnit_AppDev a org:OrganizationalUnit ;
    rdfs:label "Application Development Unit"@en ;
    rdfs:comment "Organizational unit for application development."@en ;
    org:unitOf org:Org_ITDepartment .

noria:CorporateUserIdentifier_JDoe a noria:CorporateUserIdentifier ;
    rdfs:label "jdoe"@en ;
    foaf:accountName "jdoe" ;
    rdfs:comment "Corporate User_extra_node_7 ID for John Doe."@en .

noria:CorporateUserIdentifier_JSmith a noria:CorporateUserIdentifier ;
    rdfs:label "jsmith"@en ;
    foaf:accountName "jsmith" ;
    rdfs:comment "Corporate User_extra_node_7 ID for Jane Smith."@en .

foaf:Agent_JohnDoe foaf:holdsAccount noria:CorporateUserIdentifier_JDoe .
foaf:Agent_JaneSmith foaf:holdsAccount noria:CorporateUserIdentifier_JSmith .

# =============================================================================
# Locations
# =============================================================================

bot:Site_HQDataCenter a bot:Site ;
    rdfs:label "Headquarters Data Center"@en ;
    rdfs:comment "Main data center located at the company headquarters."@en ;
    noria:siteId "DC-HQ-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Main Street" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

bot:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary data center for disaster recovery purposes."@en ;
    noria:siteId "DC-DR-02" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Avenue" ;
    noria:sitePrincipalAddressCityName "Gotham" ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room in the Headquarters Data Center."@en ;
    bot:hasSpace bot:Site_HQDataCenter .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room in the Headquarters Data Center."@en ;
    bot:hasSpace bot:Site_HQDataCenter .

noria:Locus_RackA1_U10 a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Specific location within Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "U10" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5_U2 a noria:Locus ;
    rdfs:label "Rack B5, Unit 2"@en ;
    rdfs:comment "Specific location within Network Room B."@en ;
    noria:locusLine "B5" ;
    noria:locusRow "U2" ;
    bot:hasSpace noria:Room_NetworkRoomB .

