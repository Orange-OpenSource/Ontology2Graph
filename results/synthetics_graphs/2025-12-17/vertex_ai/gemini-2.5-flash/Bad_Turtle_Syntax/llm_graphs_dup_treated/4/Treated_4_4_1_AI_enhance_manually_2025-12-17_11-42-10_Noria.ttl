# 6. Applications and Application Modules
# =============================================================================

noria:App_CorporateWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "The main public-facing website of the company."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CW" ;
    noria:applicationType <kos/application/type/CustomerFacing> ;
    noria:applicationBusinessImportance <kos/application/business_extra_node_0-importance/High> ;
    noria:applicationFunctionalDomain "Marketing and Sales"@en ;
    noria:applicationFunctionalSubDomain "Online Presence Management"@en ;
    noria:resourceForApplication noria:Resource_WebSrv01, noria:Resource_DBSrv01, noria:Resource_VirtualAppSrv01 .

noria:App_InternalCRM a noria:Application ;
    rdfs:label "Internal_extra_node_0 CRM System"@en ;
    rdfs:comment "Customer_extra_node_0 Relationship Management system for internal use."@en ;
    noria:applicationModelIdentifier "CRMINT" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/InternalBusiness> ;
    noria:applicationBusinessImportance <kos/application/business_extra_node_0-importance/Critical_extra_node_0> ;
    noria:applicationFunctionalDomain "Customer_extra_node_0 Service"@en ;
    noria:applicationFunctionalSubDomain "Customer_extra_node_0 Data Management"@en ;
    noria:resourceForApplication noria:Resource_DBSrv01, noria:Resource_VirtualAppSrv01 .

noria:App_MonitoringSystem a noria:Application ;
    rdfs:label "IT Monitoring System"@en ;
    rdfs:comment "System for monitoring_extra_node_0 the health and performance of IT infrastructure_extra_node_0."@en ;
    noria:applicationModelIdentifier "ITMON" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business_extra_node_0-importance/High> ;
    noria:applicationFunctionalDomain "IT Operations"@en ;
    noria:applicationFunctionalSubDomain "Performance and Availability Monitoring"@en ;
    noria:resourceForApplication noria:Resource_VMHost01 . # Assuming it runs on a VM on this host

noria:AppModule_CorporateWebsite_Prod a noria:ApplicationModule ;
