    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceType <kos/Resource/type/WebServer> ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_0 ;
    noria:resourceManagedBy noria:OrgUnit_AppDev ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_0> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U1 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_10 .

noria:Resource_DBSrv01 a noria:Resource ;
    rdfs:label "Database Server_extra_node_0 01"@en ;
    rdfs:comment "Primary database server for critical_extra_node_0 business_extra_node_0 applications."@en ;
