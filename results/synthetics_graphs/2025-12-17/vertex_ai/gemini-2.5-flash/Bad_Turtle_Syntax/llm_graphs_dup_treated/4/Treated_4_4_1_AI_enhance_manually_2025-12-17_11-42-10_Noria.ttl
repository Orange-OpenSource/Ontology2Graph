    rdfs:comment "Development_extra_node_0 instance of the Corporate Website application."@en ;
    noria:applicationModuleOf noria:App_CorporateWebsite ;
    noria:applicationModuleName "CORPWEB_DEV" ;
    noria:applicationModuleIdentifier "DEV-CW-01" ;
