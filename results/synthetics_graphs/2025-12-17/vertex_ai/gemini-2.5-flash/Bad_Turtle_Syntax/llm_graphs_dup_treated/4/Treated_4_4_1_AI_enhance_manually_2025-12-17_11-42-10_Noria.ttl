noria:Resource_VirtualAppSrv01 a noria:Resource ;
    rdfs:label "Virtual Application Server_extra_node_0 01"@en ;
    rdfs:comment "Virtual machine hosting a critical_extra_node_0 application component."@en ;
    noria:resourceHostName "vappsrv01.corp.example.com" ;
