    noria:resourceInstallationDate "2022-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U1 ;
    noria:resourceManagementIPAddress observable:IPAddress_192_168_1_11 .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router_extra_node_0 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceHostName "routercore01.corp.example.com" ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-DEF" ;
    noria:resourceType <kos/Resource/type/Router_extra_node_0> ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K_extra_node_0 ;
