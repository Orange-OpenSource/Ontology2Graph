# =============================================================================
# 5. Network Interfaces and Links
# =============================================================================

noria:NI_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server_extra_node_0 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceDescription "Uplink to corporate LAN switch."@en .

noria:NI_DBSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Database Server_extra_node_0 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBSrv01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceDescription "Uplink to corporate LAN switch."@en .

noria:NI_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Uplink interface from Core Router_extra_node_0 01 to ISP."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 ;
    noria:networkInterfaceDescription "WAN link to ISP A."@en .

noria:NI_RouterCore01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/2"@en ;
    rdfs:comment "Uplink interface from Core Router_extra_node_0 01 to DR site."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceRoutingPriorityMetric 200 ;
    noria:networkInterfaceLaserTxOpticalPower -4 ;
    noria:networkInterfaceLaserRxOpticalPower -6 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -3 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -11 ;
    noria:networkInterfaceDescription "Inter-DC link to DR site."@en .

noria:NI_VirtualAppSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "VirtualAppSrv01 Ethernet 0"@en ;
    rdfs:comment "Network interface for Virtual Application Server_extra_node_0 01."@en ;
    noria:networkInterfaceOf noria:Resource_VirtualAppSrv01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_0> ;
    noria:networkInterfaceDescription "Virtual NIC connected to VM Host 01 virtual switch."@en .

noria:NL_LAN_Segment1 a noria:NetworkLink ;
    rdfs:label "LAN Segment 1"@en ;
    rdfs:comment "Local Area Network segment connecting servers in Server_extra_node_0 Room A."@en ;
    noria:networkLinkId "LAN-SEG-001" ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkLinkInstallationDate "2022-03-10T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:OrgUnit_NetworkOps ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv01, noria:Resource_DBSrv01, noria:Resource_VMHost01 ;
    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0, noria:NI_DBSrv01_Eth0, noria:NI_VirtualAppSrv01_Eth0 . # Virtual NICs are connected to a virtual switch which is part of the LAN segment.

noria:NL_WAN_ISP_A a noria:NetworkLink ;
    rdfs:label "WAN Link to ISP A"@en ;
    rdfs:comment "Wide Area Network link providing internet connectivity via ISP A."@en ;
    noria:networkLinkId "WAN-ISP-A-001" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2021-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:OrgUnit_NetworkOps ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_ISP_Router_A ; # Assuming an external ISP router
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gi0_0_1 .

noria:Resource_ISP_Router_A a noria:Resource ;
    rdfs:label "ISP Router_extra_node_0 A"@en ;
    rdfs:comment "External router managed by ISP A."@en ;
    noria:resourceType <kos/Resource/type/Router_extra_node_0> ;
    noria:resourceManagedBy noria:Org_ISP_A .

noria:Org_ISP_A a org:Organization ;
    rdfs:label "Internet Service Provider A"@en ;
    rdfs:comment "External internet service provider."@en .

