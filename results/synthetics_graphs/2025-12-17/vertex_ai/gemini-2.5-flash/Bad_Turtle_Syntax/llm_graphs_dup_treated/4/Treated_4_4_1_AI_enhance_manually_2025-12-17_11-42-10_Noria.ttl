@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# =============================================================================
# 1. Agents and Organizations
# =============================================================================

# Organizational Units (Teams)
noria:OrgUnit_NetworkOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the core network infrastructure_extra_node_0."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/EmailAndPhone> ;
    noria:agentInstructions "For critical_extra_node_0 issues, call the on-call engineer directly. For non-critical_extra_node_0, open a ticket."@en .

noria:OrgUnit_AppDev a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development_extra_node_0 Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business_extra_node_0 applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_0> ;
    noria:agentInstructions "All requests must go through the Jira ticketing system."@en .

noria:OrgUnit_DBA a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_0> ;
    noria:agentInstructions "Use the dedicated database support portal for all requests."@en .

noria:OrgUnit_SecurityOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring_extra_node_0 and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 Continuous Monitoring"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SecureChatAndEmail> ;
    noria:agentInstructions "Report all potential security breaches immediately via secure channels."@en .

# Individual Agents (Persons)
noria:Person_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    org:memberOf noria:OrgUnit_NetworkOps .

noria:Person_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf noria:OrgUnit_AppDev .

noria:Person_CharlieBrown a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Database Administrator."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    org:memberOf noria:OrgUnit_DBA .

# Corporate User Identifiers
noria:CUid_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "ASmith Corporate ID"@en ;
    rdfs:comment "Corporate login for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount noria:Person_AliceSmith .

noria:CUid_BJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "BJohnson Corporate ID"@en ;
    rdfs:comment "Corporate login for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount noria:Person_BobJohnson .

# =============================================================================
# 2. Locations
# =============================================================================

noria:Site_HQ a bot:Site ;
    rdfs:label "Corporate Headquarters Data Center"@en ;
    rdfs:comment "Main data center for the company's IT infrastructure_extra_node_0."@en ;
    noria:siteId "DC-HQ-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Main Street"@en ;
    noria:sitePrincipalAddressCityName "Anytown"@en ;
    noria:sitePrincipalAddressPostalCode "12345"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Site_DR a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary data center for disaster recovery and business_extra_node_0 continuity."@en ;
    noria:siteId "DC-DR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Avenue"@en ;
    noria:sitePrincipalAddressCityName "Otherville"@en ;
    noria:sitePrincipalAddressPostalCode "67890"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_ServerRoomA_extra_node_0 a noria:Room ;
    rdfs:label "Server_extra_node_0 Room A - HQ"@en ;
    rdfs:comment "Primary server room within the Headquarters Data Center."@en ;
    bot:hasSpace noria:Site_HQ .

noria:Room_NetworkCloset1 a noria:Room ;
    rdfs:label "Network Closet 1 - HQ"@en ;
    rdfs:comment "Network equipment closet on the 1st floor of HQ."@en ;
    bot:hasSpace noria:Site_HQ .

noria:Locus_RackA1_U1 a noria:Locus ;
    rdfs:label "Rack A1, Unit 1"@en ;
    rdfs:comment "Specific location for a server in Rack A1, Unit 1."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "1"@en ;
    bot:hasSpace noria:Room_ServerRoomA_extra_node_0 .

noria:Locus_RackB5_U10 a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Location for a network device in Rack B5, Unit 10."@en ;
    noria:locusLine "B5"@en ;
    noria:locusRow "10"@en ;
    bot:hasSpace noria:Room_NetworkCloset1 .

