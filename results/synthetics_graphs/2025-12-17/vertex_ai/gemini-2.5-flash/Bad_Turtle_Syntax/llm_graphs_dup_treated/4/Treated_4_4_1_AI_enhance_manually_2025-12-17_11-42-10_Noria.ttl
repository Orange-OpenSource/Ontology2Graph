# =============================================================================
# 7. Services
# =============================================================================

noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/InfrastructureService> ;
    seas:subSystemOf noria:App_CorporateWebsite, noria:App_InternalCRM ; # Applications rely on this service
    noria:resourceManagedBy noria:OrgUnit_NetworkOps .

noria:Service_DatabaseBackend a noria:Service ;
    rdfs:label "Shared Database Backend Service"@en ;
    rdfs:comment "Provides database services to multiple internal applications."@en ;
    noria:serviceType <kos/service/type/InternalService> ;
    seas:subSystemOf noria:AppModule_CorporateWebsite_Prod, noria:AppModule_InternalCRM_Prod ;
    noria:resourceManagedBy noria:OrgUnit_DBA .

# =============================================================================
# 8. Event Records
# =============================================================================

noria:Event_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router_extra_node_0 Interface Down Event"@en ;
