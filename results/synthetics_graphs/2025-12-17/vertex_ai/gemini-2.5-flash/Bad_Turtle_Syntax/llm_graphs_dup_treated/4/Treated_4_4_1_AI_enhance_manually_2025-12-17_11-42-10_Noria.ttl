    noria:resourceInstallationDate "2023-05-01T09:30:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_VMHost01 ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Running> ;
    noria:resourceManagementIPAddress observable:IPAddress_172_16_0_10 .

