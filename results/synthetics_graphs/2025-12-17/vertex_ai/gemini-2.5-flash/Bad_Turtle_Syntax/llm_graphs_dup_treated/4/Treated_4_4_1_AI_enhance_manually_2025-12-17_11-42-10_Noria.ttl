    noria:applicationModuleAdministrationLeader noria:Person_BobJohnson ;
    noria:applicationModuleSupportTeam noria:OrgUnit_AppDev ;
    noria:applicationModuleSupportLeader noria:Person_BobJohnson ;
    noria:applicationModuleHotlineGroup noria:OrgUnit_AppDev .

noria:AppModule_CorporateWebsite_Dev a noria:ApplicationModule ;
