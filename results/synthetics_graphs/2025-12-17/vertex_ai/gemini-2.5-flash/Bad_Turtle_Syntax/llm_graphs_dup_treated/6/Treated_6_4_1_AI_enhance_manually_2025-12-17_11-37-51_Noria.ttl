# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS_Server_01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for internal and external resolution."@en ;
    noria:resourceManagedBy foaf:Agent_Network_Admin_Team ;
    noria:resourceHostName "dns01.techcorp.com"@en ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceLogisticId "LOG-DNS-001"@en ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12 ;
    noria:resourceManagementIPAddress observable:IPAddress_DNS_Mgmt ;
    noria:resourceForApplication noria:Application_Corporate_Internet_Access .

noria:Resource_Web_Server_VM_01 a noria:Resource ;
    rdfs:label "E-commerce Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the frontend of the e-commerce platform."@en ;
    noria:resourceManagedBy foaf:Agent_Cloud_Support_Team ;
    noria:resourceHostName "webvm01.ecommerce.techcorp.com"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceForApplication noria:Application_E-commerce_Platform ;
    noria:clusterController noria:Resource_Hypervisor_Host_01 .

noria:Resource_Database_Server_VM_01 a noria:Resource ;
    rdfs:label "E-commerce Database Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the database for the e-commerce platform."@en ;
    noria:resourceManagedBy foaf:Agent_Cloud_Support_Team ;
    noria:resourceHostName "dbvm01.ecommerce.techcorp.com"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceForApplication noria:Application_E-commerce_Platform ;
    noria:clusterController noria:Resource_Hypervisor_Host_01 .

noria:Resource_Core_Router_01 a noria:Resource ;
    rdfs:label "Main Data Center Core Router 01"@en ;
    rdfs:comment "Core router providing connectivity within the data center and to external networks."@en ;
    noria:resourceManagedBy foaf:Agent_Network_Admin_Team ;
    noria:resourceHostName "cr01.dc-mia-01.techcorp.com"@en ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceLogisticId "LOG-CR-001"@en ;
    noria:resourceSerialNumber "SN-CR-001-ABC"@en ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Cabinet05 ;
    noria:resourceManagementIPAddress observable:IPAddress_Router_Mgmt .

noria:Resource_Firewall_01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Security firewall protecting the corporate network perimeter."@en ;
    noria:resourceManagedBy foaf:Agent_Security_Analyst_Bob ;
    noria:resourceHostName "fw01.techcorp.com"@en ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceForApplication noria:Application_Corporate_Internet_Access .

noria:Resource_Hypervisor_Host_01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical host running virtual machines for cloud services."@en ;
    noria:resourceManagedBy foaf:Agent_Cloud_Support_Team ;
    noria:resourceHostName "hv01.dc-mia-01.techcorp.com"@en ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12 .

# Dummy IP Addresses (UCO observable:IPAddress is a class, not a datatype)
observable:IPAddress_DNS_Mgmt a observable:IPAddress ;
    rdfs:label "192.168.1.10"@en ;
    observable:ipAddressValue "192.168.1.10"^^xsd:string .

observable:IPAddress_Router_Mgmt a observable:IPAddress ;
    rdfs:label "10.0.0.1"@en ;
    observable:ipAddressValue "10.0.0.1"^^xsd:string .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_DNS_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on DNS Server 01"@en ;
    rdfs:comment "Main network interface for DNS_Server_01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS_Server_01 ;
    noria:networkInterfaceConnects noria:NetworkLink_DC_Core_A ;
    noria:networkInterfaceDescription "Uplink to core switch"@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_Router_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"@en ;
    rdfs:comment "Interface connecting to the DNS server segment."@en ;
    noria:networkInterfaceOf noria:Resource_Core_Router_01 ;
    noria:networkInterfaceConnects noria:NetworkLink_DC_Core_A ;
    noria:networkInterfaceDescription "Connection to server rack 12"@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkInterface_Router_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/2 on Core Router 01"@en ;
    rdfs:comment "Interface connecting to the regional office network."@en ;
    noria:networkInterfaceOf noria:Resource_Core_Router_01 ;
    noria:networkInterfaceConnects noria:NetworkLink_DC_Regional_B ;
    noria:networkInterfaceDescription "WAN link to NYC office"@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 70 .

noria:NetworkInterface_VM_Web_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Web Server VM 01"@en ;
    rdfs:comment "Virtual network interface for the web server VM."@en ;
    noria:networkInterfaceOf noria:Resource_Web_Server_VM_01 ;
    noria:networkInterfaceDescription "Virtual NIC for E-commerce frontend"@en ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_DC_Core_A a noria:NetworkLink ;
    rdfs:label "Data Center Core Link A"@en ;
    rdfs:comment "High-speed link between DNS server and core router."@en ;
    noria:networkLinkId "NL-DC-CORE-A-001"@en ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS_Server_01 ;
