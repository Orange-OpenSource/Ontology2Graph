# =============================================================================
# KOS (Knowledge Organization System) Concepts - Dummy declarations for range constraints
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application Type"@en .
<kos/application/type/business-critical> a skos:Concept ; rdfs:label "Business Critical Application Type"@en .
<kos/application/type/it-operations> a skos:Concept ; rdfs:label "IT Operations Application Type"@en .
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en .
<kos/application/business-importance/critical> a skos:Concept ; rdfs:label "Critical Business Importance"@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA Level"@en .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; rdfs:label "Silver SLA Level"@en .

<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en .
<kos/service/type/InfrastructureService> a skos:Concept ; rdfs:label "Infrastructure Service"@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en .
<kos/TroubleTicket/type/Incident> a skos:Concept ; rdfs:label "Incident Type"@en .
<kos/TroubleTicket/type/Problem> a skos:Concept ; rdfs:label "Problem Type"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision Origin"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Origin"@en .
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention Urgency"@en .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention Urgency"@en .
<kos/TroubleTicket/trouble-category/ServiceOutage> a skos:Concept ; rdfs:label "Service Outage Category"@en .
<kos/TroubleTicket/trouble-category/PerformanceDegradation> a skos:Concept ; rdfs:label "Performance Degradation Category"@en .
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; rdfs:label "Managed Backbone Networks Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> a skos:Concept ; rdfs:label "Contract Application Hosting Services Responsibility"@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress Status"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved Status"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment Type"@en .
<kos/TroubleTicket/commentType/System> a skos:Concept ; rdfs:label "System Comment Type"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation Type"@en .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; rdfs:label "Tests and Measurements Operation Type"@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention Category"@en .
<kos/ChangeRequest/category/CustomerIntervention> a skos:Concept ; rdfs:label "Customer Intervention Category"@en .
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change Type"@en .
<kos/ChangeRequest/type/Major> a skos:Concept ; rdfs:label "Major Change Type"@en .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade Cause"@en .
<kos/ChangeRequest/cause/NetworkExtension> a skos:Concept ; rdfs:label "Network Extension Cause"@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved Status"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented Status"@en .
<kos/ChangeRequest/specification/StandardOperatingProcedure> a skos:Concept ; rdfs:label "Standard Operating Procedure Specification"@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning Perceived Severity"@en .

<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Operational State Up"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Operational State Down"@en .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; rdfs:label "Administrative State Up"@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Administrative State Down"@en .
<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server Resource Type"@en .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router Resource Type"@en .
<kos/Resource/type/Firewall> a skos:Concept ; rdfs:label "Firewall Resource Type"@en .
<kos/Resource/type/Hypervisor> a skos:Concept ; rdfs:label "Hypervisor Resource Type"@en .
<kos/Resource/LifecycleState/InUse> a skos:Concept ; rdfs:label "In Use Lifecycle State"@en .
<kos/Resource/LifecycleState/Maintenance> a skos:Concept ; rdfs:label "Maintenance Lifecycle State"@en .

<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email Contact Method"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone Contact Method"@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_IT_Operations_Team a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, call the hotline. For non-critical, use the ticketing system."@en .

foaf:Agent_Network_Admin_Team a foaf:Agent ;
    rdfs:label "Network Admin Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit network change requests via the Change Management System."@en .

foaf:Agent_Cloud_Support_Team a foaf:Agent ;
    rdfs:label "Cloud Support Team"@en ;
    rdfs:comment "Team dedicated to managing cloud-based resources and applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_Customer_Service_Agent_Alice a foaf:Agent ;
    rdfs:label "Alice Smith (Customer Service)"@en ;
    rdfs:comment "A customer service representative who handles initial customer inquiries."@en .

foaf:Agent_Security_Analyst_Bob a foaf:Agent ;
    rdfs:label "Bob Johnson (Security Analyst)"@en ;
    rdfs:comment "An analyst responsible for monitoring and responding to security threats."@en .

org:Organization_TechCorp a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "A leading technology company providing various digital services."@en .

org:Organization_ServerManufacturer a org:Organization ;
    rdfs:label "ServerTech Solutions"@en ;
    rdfs:comment "Manufacturer of high-performance server hardware."@en .

org:Organization_NetworkGearVendor a org:Organization ;
    rdfs:label "NetConnect Systems"@en ;
    rdfs:comment "Vendor of network routing and switching equipment."@en .

org:OrganizationalUnit_NOC a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "The central location from which network monitoring and control are exercised."@en ;
    org:member foaf:Agent_IT_Operations_Team .

org:OrganizationalUnit_SOC a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "A facility where enterprise information systems are monitored, assessed, and defended."@en ;
    org:member foaf:Agent_Security_Analyst_Bob .

noria:CorporateUserIdentifier_JS001 a noria:CorporateUserIdentifier ;
    rdfs:label "JohnDoe_CUid"@en ;
    foaf:accountName "johndoe"@en ;
    rdfs:comment "Corporate User_extra_node_4 ID for John Doe, an IT Operations Team member."@en .

# =============================================================================
# Locations
# =============================================================================

bot:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for TechCorp."@en ;
    noria:siteId "DC-MIA-01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Miami"@en ;
    noria:sitePrincipalAddressPostalCode "33101"@en ;
    noria:sitePrincipalAddressCountry "USA"@en .

bot:Site_RegionalOffice a bot:Site ;
    rdfs:label "Regional Office - New York"@en ;
    rdfs:comment "TechCorp's regional office in New York."@en ;
    noria:siteId "RO-NYC-01"@en ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddressStreet "456 Business Street"@en ;
    noria:sitePrincipalAddressCityName "New York"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "USA"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace noria:Locus_Rack12 ;
    bot:hasSpace noria:Locus_Cabinet05 ;
    seas:isLocatedIn bot:Site_MainDataCenter .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Dedicated network equipment room in the Main Data Center."@en ;
    seas:isLocatedIn bot:Site_MainDataCenter .

noria:Locus_Rack12 a noria:Locus ;
    rdfs:label "Rack 12"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "12"@en ;
    seas:isLocatedIn noria:Room_ServerRoomA .

noria:Locus_Cabinet05 a noria:Locus ;
    rdfs:label "Cabinet 05"@en ;
    rdfs:comment "Specific cabinet location for network devices."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "05"@en ;
    seas:isLocatedIn noria:Room_NetworkRoomB .

