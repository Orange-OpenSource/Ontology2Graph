    noria:networkLinkTerminationResourceOrigin noria:Resource_Core_Router_01 ;
    noria:networkLinkInstallationDate "2021-08-01T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN"@en ;
    noria:resourceManagedBy foaf:Agent_Network_Admin_Team .

