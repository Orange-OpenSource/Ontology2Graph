    noria:agentManagesResource noria:NetworkLink_AppServer01_CoreRouter01 ;
    noria:agentManagesResource noria:NetworkLink_CoreRouter01_ISP .

foaf:JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer and Administrator for CRM systems."@en ;
    org:memberOf org:AppSupportTeam ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentManagesResource noria:Resource_AppServer01 ;
    noria:agentManagesResource noria:Resource_DBServer01 ;
    noria:agentManagesResource noria:Resource_WebFrontend01 ;
    noria:agentManagesResource noria:Application_CRMSystem ;
    noria:agentManagesResource noria:ApplicationModule_CRM_Prod .

foaf:AliceJohnson a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Security Analyst responsible for threat detection and vulnerability management."@en ;
    org:memberOf org:SecurityTeam ;
    foaf:mbox <mailto:alice.johnson@example.com> .

# Corporate User Identifier
