    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -7 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -4 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -12 .

