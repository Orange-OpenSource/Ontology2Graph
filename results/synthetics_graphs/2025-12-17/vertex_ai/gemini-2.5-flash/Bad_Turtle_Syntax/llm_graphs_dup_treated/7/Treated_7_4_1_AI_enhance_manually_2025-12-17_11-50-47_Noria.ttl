# =============================================================================
# 1. Agents and Organizations
# =============================================================================

# Organization
org:OrangeCorp a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main telecommunications company, providing various services."@en .

org:DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

org:CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high_extra_node_2-technology services and products."@en .

org:VMwareInc a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

# Organizational Units (Teams)
org:NetworkOpsTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing core network infrastructure_extra_node_2 and connectivity."@en ;
    org:unitOf org:OrangeCorp ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical_extra_node_2 issues, call the on-call engineer directly. For non-critical_extra_node_2, use the ticketing system."@en .

org:AppSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting critical_extra_node_2 business_extra_node_2 applications and their underlying servers."@en ;
    org:unitOf org:OrangeCorp ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all application-related issues."@en .

org:SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Cyber Security Operations Center (CSOC)"@en ;
    rdfs:comment "Team responsible for monitoring_extra_node_2, detecting, and responding to security incidents and threats."@en ;
    org:unitOf org:OrangeCorp ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> ;
    noria:agentInstructions "Follow established incident response playbooks for all security alerts."@en .

# Individual Agents
