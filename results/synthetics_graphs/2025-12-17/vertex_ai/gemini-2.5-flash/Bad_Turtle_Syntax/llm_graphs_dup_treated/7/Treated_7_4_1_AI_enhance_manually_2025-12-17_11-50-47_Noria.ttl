# =============================================================================
# 10. Trouble Tickets and Notes
# =============================================================================

# Trouble Tickets
noria:TroubleTicket_CRM_Outage_001 a noria:TroubleTicket ;
    rdfs:label "CRM Production Outage"@en ;
    rdfs:comment "Critical_extra_node_2 incident affecting the CRM Production Module, leading to service unavailability due to high_extra_node_2 CPU on AppServer01."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical_extra_node_2> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure_extra_node_2> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1_extra_node_2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer_extra_node_2> ;
    noria:troubleTicketCause "Unresponsive application server due to sustained high_extra_node_2 CPU usage, leading to application crash."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress_extra_node_2> ;
    noria:troubleTicketRelatedService noria:ApplicationModule_CRM_Prod ;
    noria:troubleTicketRelatedResource noria:Resource_AppServer01 ;
    noria:troubleTicketRelatedParty foaf:JaneSmith ; # Application owner
    noria:troubleTicketRelatedParty foaf:JohnDoe ; # Network engineer involved for connectivity checks
    noria:troubleTicketTrigger noria:EventRecord_HighCPU_AppServer01_20240423_1000 ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/ApplicationCrash> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:documentExternalId "CUST-INC-2024-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/CRM-OUTAGE-001" ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:documentStatusHistory noria:EventRecord_TT_CRM_001_StatusChange_InProgress ;
    noria:documentStatusHistory noria:EventRecord_TT_CRM_001_StatusChange_Resolved ;
    noria:troubleTicketCharacteristic noria:AnomalyPattern_HighCPUUsage .

noria:TroubleTicket_NetworkIssue_002 a noria:TroubleTicket ;
    rdfs:label "Core Router_extra_node_2 Interface Down"@en ;
    rdfs:comment "Incident reported by monitoring_extra_node_2 system about a critical_extra_node_2 network interface going down on Core Router_extra_node_2 01, affecting internal network access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major_extra_node_2> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure_extra_node_2> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision_extra_node_2> ;
    noria:troubleTicketCause "ISP link flapping, likely due to optical power issues or external fiber cut."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress_extra_node_2> ;
    noria:troubleTicketRelatedService noria:Service_InternalNetworkAccess ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRouter01 ;
    noria:troubleTicketRelatedResource noria:NetworkInterface_CoreRouter01_Gi0_0_2 ;
    noria:troubleTicketRelatedParty foaf:JohnDoe ;
    noria:troubleTicketTrigger noria:EventRecord_NetIfDown_CoreRouter01_20240423_1015 ;
    noria:troubleTicketSupervisionTool "Zabbix" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/InaccessibleDestination> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/ExternalLinkFailure> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:documentExternalId "MON-INC-2024-002" ;
    noria:documentHRef "https://itsm.example.com/ticket/NET-ISSUE-002" ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:documentStatusHistory noria:EventRecord_TT_Net_002_StatusChange_InProgress ;
    noria:troubleTicketCharacteristic noria:AnomalyPattern_NetworkLinkFlap .

noria:TroubleTicket_SecurityIncident_005 a noria:TroubleTicket ;
    rdfs:label "Failed Login Brute Force Attempt"@en ;
    rdfs:comment "Security incident triggered by multiple failed login attempts on AppServer01, indicating a potential brute-force attack."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/SecurityIncident> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision_extra_node_2> ;
    noria:troubleTicketCause "Automated brute-force attack detected from external IP address."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:50:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/New> ;
    noria:troubleTicketRelatedResource noria:Resource_AppServer01 ;
    noria:troubleTicketRelatedParty foaf:AliceJohnson ;
    noria:troubleTicketTrigger noria:EventRecord_FailedLogin_AppServer01_20240423_1045 ;
    noria:troubleTicketSupervisionTool "SIEM" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/SecurityBreachAttempt> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/UnauthorizedAccessAttempt> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/NoIntervention> ;
    noria:documentExternalId "SEC-INC-2024-005" ;
    noria:documentHRef "https://itsm.example.com/ticket/SEC-INC-005" ;
    noria:troubleTicketIsNotificationEnable false .

# Trouble Ticket Notes
noria:TroubleTicketNote_CRM_001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis_extra_node_2 Note for CRM Outage"@en ;
    rdfs:comment "Initial check shows AppServer01 CPU at 98%. Attempting graceful restart of application services as first step."@en ;
    dcterms:isPartOf noria:TroubleTicket_CRM_Outage_001 ;
    dcterms:created "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:JaneSmith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_2> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis_extra_node_2> .

noria:TroubleTicketNote_CRM_001_Note2 a noria:TroubleTicketNote ;
    rdfs:label "Application Restart Attempt"@en ;
    rdfs:comment "Graceful restart failed. Initiating full server reboot as per OperationPlan_RestartAppServer. Monitoring for recovery."@en ;
    dcterms:isPartOf noria:TroubleTicket_CRM_Outage_001 ;
    dcterms:created "2024-04-23T10:25:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:JaneSmith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_2> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_ConfigChange_CoreRouter01_20240423_1030 . # Example of linking an event record (even if it's a config change on another device, for demonstration of property usage)

noria:TroubleTicketNote_Net_002_Note1 a noria:TroubleTicketNote ;
    rdfs:label "ISP Link Check Note"@en ;
    rdfs:comment "Contacted ISP, they are investigating the link issue. Local optical power levels are within acceptable range on our side, suggesting external fault."@en ;
    dcterms:isPartOf noria:TroubleTicket_NetworkIssue_002 ;
    dcterms:created "2024-04-23T10:35:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:JohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Carrier> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis_extra_node_2> .

# Document Attachment
noria:DocumentAttachment_CRM_LogFile a noria:DocumentAttachment ;
    rdfs:label "CRM Application Log File"@en ;
    rdfs:comment "Compressed log file from AppServer01 during the outage, attached for further analysis."@en ;
    dcterms:isPartOf noria:TroubleTicket_CRM_Outage_001 ;
    dcterms:created "2024-04-23T10:40:00Z"^^xsd:dateTime ;
    dcterms:format "application/zip" ;
    dcterms:title "appserver01_logs_20240423.zip" .

# Party Intervention for Trouble Ticket (using blank nodes as no specific class is defined)
_:TTIntervention_JaneSmith_Diagnosis a owl:Thing ;
    rdfs:label "Jane Smith's Initial Diagnosis_extra_node_2 Intervention"@en ;
    rdfs:comment "Jane Smith performed initial diagnosis on AppServer01 for the CRM outage."@en ;
    dcterms:created "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:JaneSmith .

noria:TroubleTicket_CRM_Outage_001 noria:troubleTicketPartyIntervention _:TTIntervention_JaneSmith_Diagnosis .

_:TTIntervention_JohnDoe_NetworkCheck a owl:Thing ;
    rdfs:label "John Doe's Network Check Intervention"@en ;
    rdfs:comment "John Doe checked network connectivity for CoreRouter01 related to the ISP link issue."@en ;
    dcterms:created "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:JohnDoe .

noria:TroubleTicket_NetworkIssue_002 noria:troubleTicketPartyIntervention _:TTIntervention_JohnDoe_NetworkCheck .

# Link alarms to mitigating actions (Trouble Tickets as ProcedureExecutionContainers)
noria:EventRecord_HighCPU_AppServer01_20240423_1000 noria:alarmMitigatedBy noria:TroubleTicket_CRM_Outage_001 .
noria:EventRecord_NetIfDown_CoreRouter01_20240423_1015 noria:alarmMitigatedBy noria:TroubleTicket_NetworkIssue_002 .
noria:EventRecord_FailedLogin_AppServer01_20240423_1045 noria:alarmMitigatedBy noria:TroubleTicket_SecurityIncident_005 .

