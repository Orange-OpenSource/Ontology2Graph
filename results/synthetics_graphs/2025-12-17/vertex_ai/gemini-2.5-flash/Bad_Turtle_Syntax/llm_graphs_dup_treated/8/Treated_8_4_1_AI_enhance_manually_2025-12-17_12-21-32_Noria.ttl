# =============================================================================
# 15. Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OP_CheckFiberLink a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Standard_extra_node_1 operating procedure for diagnosing and resolving fiber optic link issues."@en ;
    noria:operationPlanPreCondition noria:PreCond_FiberLinkDown ;
    noria:operationPlanPostCondition noria:PostCond_FiberLinkRestored .

noria:PreCond_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'down' and administrative status is 'up'."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/down> AND noria:networkInterfaceAdministrativeStatus = <kos/Resource/AdministrativeState/up>" .

noria:PostCond_FiberLinkRestored a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored Post-Condition"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up' and traffic flow is normal."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/up> AND traffic_rate > 0" .

noria:OP_OptimizeDatabaseQuery a noria:OperationPlan ;
    rdfs:label "Optimize Database Query Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries."@en ;
    noria:operationPlanPreCondition noria:PreCond_AppSlowPerformance ;
    noria:operationPlanPostCondition noria:PostCond_AppPerformanceImproved .

noria:PreCond_AppSlowPerformance a noria:ActionPreCondition ;
    rdfs:label "Application Slow Performance Pre-Condition"@en ;
    rdfs:comment "Condition: Application response time is above threshold and CPU/memory on application server is high_extra_node_1."@en .

noria:PostCond_AppPerformanceImproved a noria:ActionPostCondition ;
    rdfs:label "Application Performance Improved Post-Condition"@en ;
    rdfs:comment "Expected outcome: Application response time is within acceptable limits and CPU/memory utilization is normalized."@en .

noria:AnomalyPattern_NetworkOutage a noria:AnomalyPattern ;
    rdfs:label "Network Outage Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a network outage: multiple critical_extra_node_1 link down events, loss of connectivity to multiple resources, and impact on critical_extra_node_1 services."@en ;
    folio:hasCause noria:Event_Log_RouterCore01_LinkDown ;
    folio:hasControlMethod noria:OP_CheckFiberLink .

noria:AnomalyPattern_DBSlowdown a noria:AnomalyPattern ;
    rdfs:label "Database Slowdown Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a database slowdown: high_extra_node_1 disk I/O, slow query logs, and increased application response times."@en ;
    folio:hasCause noria:Event_Log_DBSrv01_DiskFull ;
    folio:hasControlMethod noria:OP_OptimizeDatabaseQuery .

# Link Trouble Ticket to Operation Plan (via correlated execution)
noria:TTNote_20231027_001_01 noria:troubleTicketNoteCorrelatedExecution noria:OP_CheckFiberLink .
noria:TTNote_20231027_002_01 noria:troubleTicketNoteCorrelatedExecution noria:OP_OptimizeDatabaseQuery .

# Link Change Request to Operation Plan
noria:CR_20231101_001 noria:actionCorrelatedOperationPlan noria:OP_UpgradeRouterOS .
noria:OP_UpgradeRouterOS a noria:OperationPlan ;
    rdfs:label "Router_extra_node_1 OS Upgrade Procedure"@en ;
    rdfs:comment "Standard_extra_node_1 procedure for upgrading the operating system of network routers."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterBackupComplete ;
    noria:operationPlanPostCondition noria:PostCond_RouterOSUpdatedAndOperational .

noria:PreCond_RouterBackupComplete a noria:ActionPreCondition ;
    rdfs:label "Router_extra_node_1 Backup Complete Pre-Condition"@en ;
    rdfs:comment "Condition: Configuration backup of the router is successfully completed and verified."@en .

noria:PostCond_RouterOSUpdatedAndOperational a noria:ActionPostCondition ;
    rdfs:label "Router_extra_node_1 OS Updated and Operational Post-Condition"@en ;
    rdfs:comment "Expected outcome: Router_extra_node_1 OS is updated to the target version, all interfaces are up, and routing protocols are stable."@en .

# Example of alarm mitigation
noria:Event_Log_RouterCore01_LinkDown noria:alarmMitigatedBy noria:TT_20231027_001 . # The TT is the container for the mitigation process

# Example of virtual server status
noria:Resource_VM_App01 noria:virtualServerStatus <kos/Resource/OperationalState/up> .
noria:Resource_VM_DBProxy noria:virtualServerStatus <kos/Resource/OperationalState/up> .
