# =============================================================================
# 9. Services
# =============================================================================

noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CorpPortal_Prod ; # Corporate Portal relies on Internet Access
    seas:subSystemOf noria:AppMod_Monitoring_Prod ; # Monitoring system needs Internet access for updates/alerts
    seas:subSystemOf noria:AppMod_Database_Prod . # Database might need external connectivity

noria:Service_VPNRemoteAccess a noria:Service ;
    rdfs:label "VPN Remote Access Service"@en ;
    rdfs:comment "Enables secure remote access to the corporate network."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:AppMod_Monitoring_Prod . # VPN is monitored

noria:Service_Email a noria:Service ;
    rdfs:label "Corporate Email Service"@en ;
    rdfs:comment "Provides email communication for employees."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CorpPortal_Prod . # Portal might integrate with email

