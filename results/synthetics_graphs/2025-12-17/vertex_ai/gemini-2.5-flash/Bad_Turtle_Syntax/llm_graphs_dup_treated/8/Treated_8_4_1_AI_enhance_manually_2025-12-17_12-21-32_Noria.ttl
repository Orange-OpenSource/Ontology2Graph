# =============================================================================
# 6. Network Links
# =============================================================================

noria:NL_ServerNet_CoreRtr a noria:NetworkLink ;
    rdfs:label "Server_extra_node_1 Network to Core Router_extra_node_1 Link"@en ;
    rdfs:comment "High-speed link between the server network segment and the core router."@en ;
    noria:networkLinkId "NL-SRV-RTR-001" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2022-01-15T09:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0 ;
    noria:networkInterfaceConnects noria:NI_DBSrv01_Eth0 ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gi0_0_0 ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResource noria:Resource_DBSrv01 ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 .

noria:NL_DMZ_CoreRtr_FW a noria:NetworkLink ;
    rdfs:label "DMZ Core Router_extra_node_1 to Firewall Link"@en ;
    rdfs:comment "Link connecting the core router to the DMZ firewall."@en ;
    noria:networkLinkId "NL-DMZ-RTR-FW-001" ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:networkLinkInstallationDate "2022-01-15T09:30:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gi0_0_1 ;
    noria:networkInterfaceConnects noria:NI_FirewallDMZ01_Eth0_1 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_FirewallDMZ01 .

noria:NL_WAN_FW_External a noria:NetworkLink ;
    rdfs:label "WAN to DMZ Firewall Link"@en ;
    rdfs:comment "External WAN connection to the DMZ firewall."@en ;
    noria:networkLinkId "NL-WAN-FW-001" ;
    noria:networkLinkType "Fiber Optic 10Gbps" ;
    noria:networkLinkInstallationDate "2022-01-10T08:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_FirewallDMZ01_Eth0_0 ;
    noria:networkLinkTerminationResource noria:Resource_FirewallDMZ01 .

noria:NL_VM_Hypervisor_Internal a noria:NetworkLink ;
    rdfs:label "VM Internal_extra_node_1 Network Link"@en ;
    rdfs:comment "Internal_extra_node_1 virtual network link within the hypervisor."@en ;
    noria:networkLinkId "NL-VM-HYP-001" ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:networkLinkInstallationDate "2022-03-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NI_VM_App01_Eth0 ;
    noria:networkLinkTerminationResource noria:Resource_VM_App01 ;
    noria:networkLinkTerminationResource noria:Resource_Hypervisor01 .

