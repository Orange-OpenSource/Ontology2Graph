# =============================================================================
# 1. Agents and Organizations
# =============================================================================

# Organizational Units (Teams)
org:ITOpsTeam a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure_extra_node_1 operations and incident response."@en ;
    noria:agentWorkingHours "24/7 (Shift-based)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For critical_extra_node_1 incidents, use hotline after creating ticket."@en .

org:NetworkTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team managing network infrastructure_extra_node_1."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for non-urgent requests, ticketing system for incidents."@en .

org:AppDevTeam a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business_extra_node_1 applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/InternalChat> ;
    noria:agentInstructions "Contact via internal chat for immediate issues, otherwise use project management tool."@en .

org:SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team dedicated to monitoring_extra_node_1, detecting, and responding to cybersecurity threats."@en ;
    noria:agentWorkingHours "24/7 (Shift-based)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "All security incidents must be reported via SIEM or dedicated security ticketing system."@en .

org:DatabaseTeam a org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket for all database-related requests or issues."@en .

# Individual Agents
foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer in the IT Operations Team."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Available for escalations during working hours."@en .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network Architect in the Network Operations Team."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call for urgent network design or troubleshooting issues."@en .

foaf:Agent_AliceBrown a foaf:Agent ;
    rdfs:label "Alice Brown"@en ;
    rdfs:comment "Senior Developer in the Application Development Team."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/InternalChat> .

foaf:Agent_BobWhite a foaf:Agent ;
    rdfs:label "Bob White"@en ;
    rdfs:comment "Security Analyst in the Cybersecurity Operations Center."@en ;
    noria:agentWorkingHours "24/7 (Shift-based)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    rdfs:comment "Corporate login for John Doe."@en .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    rdfs:comment "Corporate login for Jane Smith."@en .

foaf:Agent_JohnDoe foaf:holdsAccount noria:CUid_JohnDoe .
foaf:Agent_JaneSmith foaf:holdsAccount noria:CUid_JaneSmith .

