# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_DNS_Router a noria:NetworkLink ;
    rdfs:label "Link: DNS01 to CR01"@en ;
    rdfs:comment "Network link between DNS Server_extra_node_3 01 and Core Router_extra_node_3 01."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkLinkId "NL-DNS-CR-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS_Server_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Core_Router_01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_Router01_Gi0_0_1 ;
    noria:networkLinkInstallationDate "2021-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" .

noria:NetworkLink_Router_Firewall a noria:NetworkLink ;
    rdfs:label "Link: CR01 to FW01"@en ;
    rdfs:comment "Network link between Core Router_extra_node_3 01 and Perimeter Firewall_extra_node_3 01."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkLinkId "NL-CR-FW-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Core_Router_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall_01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_Router01_Gi0_0_2 ;
    noria:networkInterfaceConnects noria:NetworkInterface_Firewall01_Int ;
    noria:networkLinkInstallationDate "2021-06-01T16:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" .

noria:NetworkLink_Firewall_ISP a noria:NetworkLink ;
    rdfs:label "Link: FW01 to ISP"@en ;
    rdfs:comment "External network link between Firewall_extra_node_3 01 and Internet Service Provider."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkLinkId "NL-FW-ISP-001" ;
    noria:networkLinkTerminationResource noria:Resource_Firewall_01 ; # Assuming ISP is external and not a NORIA resource
    noria:networkInterfaceConnects noria:NetworkInterface_Firewall01_Ext ;
    noria:networkLinkInstallationDate "2021-06-01T17:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN" .

noria:NetworkLink_WebSrv_LoadBalancer a noria:NetworkLink ;
    rdfs:label "Link: WebSrv01 to LB01"@en ;
    rdfs:comment "Network link between Web Server_extra_node_3 01 and Load Balancer 01."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:networkLinkId "NL-WEB-LB-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Web_Server_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_LoadBalancer_01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_WebSrv01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_LoadBalancer01_Int ;
    noria:networkLinkInstallationDate "2022-01-20T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" .

