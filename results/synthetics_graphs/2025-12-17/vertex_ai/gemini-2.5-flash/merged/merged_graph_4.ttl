    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for routine requests. For urgent network issues, escalate via IT Operations."@en ;
    noria:agentManagesResource noria:Resource_CoreRouter01, noria:Resource_EdgeRouter01 ;
    noria:agentManagesResource noria:NetworkLink_DC1_DC2_Fiber, noria:NetworkLink_Edge_ISP ;
    org:member foaf:Person_Charlie ;
    org:subOrganizationOf org:ITDepartment .

org:AppSupportTeam a org:OrganizationalUnit, foaf:Agent ;
