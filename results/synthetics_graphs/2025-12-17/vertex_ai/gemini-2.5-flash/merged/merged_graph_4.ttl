noria:TT_NetworkOutage_001 a noria:TroubleTicket ;
    rdfs:label "Critical Network Outage - ISP A Link Down"@en ;
    rdfs:comment "Incident reported due to complete loss of internet access affecting all corporate services."@en ;
    noria:documentExternalId "INC-2024-04-20-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-2024-04-20-001" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:Event_RouterInterfaceDown ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/InaccessibleDestination> ;
    noria:troubleTicketCause "ISP A link failure."@en ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/ExternalProviderIssue> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ExternalProvider> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:OrgUnit_NetworkOps, noria:Org_ISP_A ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_RouterCore01, noria:NI_RouterCore01_Gi0_0_1, noria:NL_WAN_ISP_A ;
    noria:troubleTicketImpacts noria:App_CorporateWebsite, noria:App_InternalCRM .

noria:TT_WebsitePerformance_002 a noria:TroubleTicket ;
    rdfs:label "Corporate Website Performance Degradation"@en ;
    rdfs:comment "Users reporting slow loading times for the corporate website."@en ;
