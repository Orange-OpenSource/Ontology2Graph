# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_DNS_Restart_Procedure a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Standard_extra_node_4 operating procedure for restarting the corporate DNS service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNS_Service_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_Service_Up .

noria:OperationPlan_Router_Firmware_Upgrade_Plan a noria:OperationPlan ;
    rdfs:label "Router_extra_node_4 Firmware Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for upgrading firmware on core network routers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Router_Maintenance_Window ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Router_Firmware_Updated .

noria:ActionPreCondition_DNS_Service_Down a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down Condition"@en ;
    rdfs:comment "Condition where the DNS service is not running or unreachable."@en .

noria:ActionPreCondition_Router_Maintenance_Window a noria:ActionPreCondition ;
    rdfs:label "Router_extra_node_4 Maintenance Window Condition"@en ;
    rdfs:comment "Condition where a pre-approved maintenance window is active for router changes."@en .

noria:ActionPostCondition_DNS_Service_Up a noria:ActionPostCondition ;
    rdfs:label "DNS Service Up_extra_node_4 Condition"@en ;
    rdfs:comment "Expected outcome: DNS service is running and responding to queries."@en .

noria:ActionPostCondition_Router_Firmware_Updated a noria:ActionPostCondition ;
    rdfs:label "Router_extra_node_4 Firmware Updated Condition"@en ;
    rdfs:comment "Expected outcome: Router_extra_node_4 firmware is successfully upgraded to the target version."@en .

noria:AnomalyPattern_DNS_Resolution_Failure a noria:AnomalyPattern ;
    rdfs:label "DNS Resolution Failure_extra_node_4 Pattern"@en ;
    rdfs:comment "Pattern indicating a widespread failure in DNS resolution, potentially due to a DNS server outage."@en ;
    folio:hasCause "DNS Server_extra_node_4 Process Crash"@en .

# Linking operations to actions (e.g., a trouble ticket note might describe an action guided by an operation plan)
noria:TroubleTicketNote_TTN-2024-001-01 noria:troubleTicketNoteCorrelatedExecution noria:OperationPlan_DNS_Restart_Procedure .
noria:ChangeRequest_CR-2024-001_Router_Upgrade noria:actionCorrelatedOperationPlan noria:OperationPlan_Router_Firmware_Upgrade_Plan .

# Example of alarm mitigation
noria:EventRecord_DNS_Outage_Log noria:alarmMitigatedBy noria:TroubleTicket_TT-2024-001_DNS_Outage .

# Example of resource observables
noria:Resource_Web_Server_VM_01 noria:virtualServerStatus <kos/Resource/OperationalState/Up_extra_node_4> .
noria:NetworkInterface_DNS_Eth0 noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .


