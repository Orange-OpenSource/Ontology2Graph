# =============================================================================
# 8. Procedural Elements (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition, noria:AnomalyPattern)
# =============================================================================

noria:OP_CheckFiberLink a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Standard operating procedure to diagnose and resolve fiber optic link issues."@en ;
    noria:operationPlanPreCondition noria:APC_FiberLinkDown ;
    noria:operationPlanPostCondition noria:APOC_FiberLinkUp .

noria:OP_DNS_Rollback a noria:OperationPlan ;
    rdfs:label "DNS Configuration Rollback Procedure"@en ;
    rdfs:comment "Procedure to revert DNS configuration to a previous stable state."@en ;
    noria:operationPlanPreCondition noria:APC_DNSMisconfigDetected ;
    noria:operationPlanPostCondition noria:APOC_DNSServiceRestored ;
    noria:actionCorrelatedOperationPlan noria:CR_DNS_Rollback_001 .

noria:OP_OptimizeDBQuery a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries."@en ;
    noria:operationPlanPreCondition noria:APC_HighDBLoad ;
    noria:operationPlanPostCondition noria:APOC_DBPerfImproved .

noria:APC_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition: A fiber optic network link is reported as down."@en ;
    skos:example "Network interface operational status is 'down' and administrative status is 'up'."@en .

noria:APOC_FiberLinkUp a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Up Post-Condition"@en ;
    rdfs:comment "Post-condition: The fiber optic network link is restored and operational."@en ;
    skos:example "Network interface operational status is 'up'."@en .

noria:APC_DNSMisconfigDetected a noria:ActionPreCondition ;
    rdfs:label "DNS Misconfiguration Detected Pre-Condition"@en ;
    rdfs:comment "Pre-condition: DNS resolution failures are widespread, and recent configuration changes are suspected."@en .

noria:APOC_DNSServiceRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: DNS resolution is successful across the network."@en .

noria:APC_HighDBLoad a noria:ActionPreCondition ;
    rdfs:label "High Database Load Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Database server CPU or I/O utilization is consistently high, impacting application performance."@en .

noria:APOC_DBPerfImproved a noria:ActionPostCondition ;
    rdfs:label "Database Performance Improved Post-Condition"@en ;
    rdfs:comment "Post-condition: Database server metrics return to normal, and application response times improve."@en .

noria:AP_NetworkLoop a noria:AnomalyPattern ;
    rdfs:label "Network Loop Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential network loop: high broadcast traffic, MAC address flapping, and interface errors."@en ;
    folio:hasCause "Misconfigured spanning tree protocol or cabling error."@en .

noria:AP_DDoSAttack a noria:AnomalyPattern ;
    rdfs:label "DDoS Attack Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a Distributed Denial of Service attack: sudden surge in traffic from multiple sources, high CPU on firewall/router, service unavailability."@en ;
    folio:hasCause "Malicious external activity."@en .

# Example of linking an EventRecord to an AnomalyPattern (as a potential cause)
noria:Event_UserLoginFailure
    dcterms:relation noria:AP_DDoSAttack . # A security event might be related to a DDoS pattern.

noria:TT_DNS_Outage_001
    dcterms:relation noria:AP_NetworkLoop . # A critical network outage might be related to a network loop.


