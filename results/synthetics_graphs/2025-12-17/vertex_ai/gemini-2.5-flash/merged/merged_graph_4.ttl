# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_DNS_Troubleshooting_SOP a noria:OperationPlan ;
    rdfs:label "DNS Troubleshooting SOP"@en ;
    rdfs:comment "Standard_extra_node_3 Operating Procedure for diagnosing and resolving DNS issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNS_Troubleshooting_PreCond ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_Troubleshooting_PostCond .

noria:OperationPlan_WebSrv_Restart_Procedure a noria:OperationPlan ;
    rdfs:label "Web Server_extra_node_3 Restart Procedure"@en ;
    rdfs:comment "Procedure to safely restart the web application server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebSrv_Restart_PreCond ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebSrv_Restart_PostCond .

noria:OperationPlan_Firewall_Upgrade_Procedure a noria:OperationPlan ;
    rdfs:label "Firewall_extra_node_3 OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the firewall operating system."@en ;
    noria:actionCorrelatedOperationPlan noria:ChangeRequest_Firewall_Upgrade . # This property is for action to procedure, not procedure to procedure. Let's link it to the CR.

noria:ActionPreCondition_DNS_Troubleshooting_PreCond a noria:ActionPreCondition ;
    rdfs:label "DNS Troubleshooting Pre-Condition"@en ;
    rdfs:comment "Condition: DNS service is reported as unreachable or slow."@en ;
    skos:example "Ping to DNS server fails; DNS queries timeout."@en .

noria:ActionPostCondition_DNS_Troubleshooting_PostCond a noria:ActionPostCondition ;
    rdfs:label "DNS Troubleshooting Post-Condition"@en ;
    rdfs:comment "Expected outcome: DNS service is restored and accessible."@en ;
    skos:example "Ping to DNS server succeeds; DNS queries resolve correctly."@en .

noria:ActionPreCondition_WebSrv_Restart_PreCond a noria:ActionPreCondition ;
    rdfs:label "Web Server_extra_node_3 Restart Pre-Condition"@en ;
    rdfs:comment "Condition: Web server CPU is consistently high_extra_node_3, or application is unresponsive."@en .

noria:ActionPostCondition_WebSrv_Restart_PostCond a noria:ActionPostCondition ;
    rdfs:label "Web Server_extra_node_3 Restart Post-Condition"@en ;
    rdfs:comment "Expected outcome: Web server CPU returns to normal levels, application is responsive."@en .

noria:AnomalyPattern_HighDNSTrafficAnomaly a noria:AnomalyPattern ;
    rdfs:label "High DNS Traffic Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating unusually high_extra_node_3 DNS query traffic, potentially a DDoS attack or misconfiguration."@en ;
    folio:hasCause "Potential DDoS attack or DNS misconfiguration."@en .

noria:AnomalyPattern_WebSrvMemoryLeakPattern a noria:AnomalyPattern ;
    rdfs:label "Web Server_extra_node_3 Memory Leak Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating gradual increase in memory usage on web servers, leading to performance degradation."@en ;
    folio:hasCause "Application memory leak."@en .

# =============================================================================
# Additional Connections for Density
# =============================================================================

# Link resources to applications
noria:Resource_DNS_Server_01 noria:resourceForApplication noria:Application_CorporateDNS .
noria:Resource_Web_Server_01 noria:resourceForApplication noria:Application_WebAppPortal .
noria:Resource_DB_Server_01 noria:resourceForApplication noria:Application_CustomerCRM .
noria:Resource_Core_Router_01 noria:resourceForApplication noria:Application_CorporateDNS, noria:Application_WebAppPortal, noria:Application_CustomerCRM .
noria:Resource_Firewall_01 noria:resourceForApplication noria:Application_CorporateDNS, noria:Application_WebAppPortal, noria:Application_CustomerCRM .
noria:Resource_Virtual_Host_ESXi01 noria:resourceForApplication noria:Application_LogManagementSystem . # Assuming LogManagementSystem runs on a VM on this host
noria:Resource_LoadBalancer_01 noria:resourceForApplication noria:Application_WebAppPortal .

# Link application modules to resources
noria:ApplicationModule_CorporateDNS_Prod seas:subSystemOf noria:Resource_DNS_Server_01 .
noria:ApplicationModule_WebAppPortal_Frontend seas:subSystemOf noria:Resource_Web_Server_01, noria:Resource_LoadBalancer_01 .
noria:ApplicationModule_WebAppPortal_Backend seas:subSystemOf noria:Resource_Web_Server_01 .
noria:ApplicationModule_CustomerCRM_DB seas:subSystemOf noria:Resource_DB_Server_01 .
noria:ApplicationModule_LogManagement_Collector seas:subSystemOf noria:Resource_Virtual_Host_ESXi01 .

# Link agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_DNSAdminTeam noria:agentManagesResource noria:Resource_DNS_Server_01 .
foaf:Agent_NetworkOpsTeam noria:agentManagesResource noria:Resource_Core_Router_01, noria:Resource_Edge_Switch_01, noria:NetworkLink_DNS_Router, noria:NetworkLink_Router_Firewall, noria:NetworkLink_Firewall_ISP, noria:Resource_Virtual_Host_ESXi01 .
foaf:Agent_AppDevTeam noria:agentManagesResource noria:Resource_Web_Server_01, noria:Resource_DB_Server_01, noria:Resource_LoadBalancer_01, noria:NetworkLink_WebSrv_LoadBalancer .
foaf:Agent_SecurityTeam noria:agentManagesResource noria:Resource_Firewall_01 .

# Link trouble tickets to event records (documentStatusHistory)
noria:TroubleTicket_DNS_Outage noria:documentStatusHistory noria:EventRecord_DNS_Outage_Log .
noria:TroubleTicket_WebSrv_Performance noria:documentStatusHistory noria:EventRecord_WebSrv_HighCPU_Alert .
noria:TroubleTicket_Router_Link_Down noria:documentStatusHistory noria:EventRecord_Router_Interface_Down .

# Link change requests to event records (documentStatusHistory)
noria:ChangeRequest_Firewall_Upgrade noria:documentStatusHistory noria:EventRecord_Firewall_Config_Change_Log .

# Example of alarmMitigatedBy
noria:EventRecord_WebSrv_HighCPU_Alert noria:alarmMitigatedBy noria:TroubleTicket_WebSrv_Performance . # The TT represents the container of actions to mitigate the alarm

# Example of clusterController
noria:Resource_DNS_Server_01 noria:clusterController noria:Resource_Virtual_Host_ESXi01 . # Assuming DNS server is a VM on ESXi01
noria:Resource_Web_Server_01 noria:clusterController noria:Resource_Virtual_Host_ESXi01 . # Assuming Web server is a VM on ESXi01

# Example of applicationModuleSupportGroup
noria:ApplicationModule_CorporateDNS_Prod noria:applicationModuleSupportGroup org:OrganizationalUnit_NetworkServices .
noria:ApplicationModule_WebAppPortal_Frontend noria:applicationModuleSupportGroup org:OrganizationalUnit_ApplicationServices .

# Example of noria:troubleTicketCharacteristic
noria:TroubleTicket_DNS_Outage noria:troubleTicketCharacteristic noria:AnomalyPattern_HighDNSTrafficAnomaly .
noria:TroubleTicket_WebSrv_Performance noria:troubleTicketCharacteristic noria:AnomalyPattern_WebSrvMemoryLeakPattern .

# Example of noria:troubleTicketFreezeItem (using an EventRecord to represent a freeze event)
noria:EventRecord_TT_DNS_Freeze_Start a noria:EventRecord ;
    rdfs:label "TT DNS Outage Freeze Start"@en ;
    rdfs:comment "Trouble ticket TT-20240420-001 put on hold due to external dependency."@en ;
    noria:loggingTime "2024-04-20T08:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_LogManagementSystem ;
    noria:logText "TT-20240420-001 status changed to Frozen."@en .

noria:TroubleTicket_DNS_Outage noria:troubleTicketFreezeItem noria:EventRecord_TT_DNS_Freeze_Start .

# Example of noria:changeRequestSpecification (assuming a KOS for specifications)
<https://w3id.org/noria/kos/ChangeRequest/specification/FW_OS_Upgrade_Standard> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> ;
    rdfs:label "Firewall_extra_node_3 OS Upgrade Standard_extra_node_3 Specification"@en ;
    rdfs:comment "Standard_extra_node_3 specification for firewall operating system upgrades."@en .

<https://w3id.org/noria/kos/ChangeRequest/specification> a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Concept Scheme"@en ;
    rdfs:comment "Defines standard operation plan catalogs for recurring activities."@en .

noria:ChangeRequest_Firewall_Upgrade noria:changeRequestSpecification <https://w3id.org/noria/kos/ChangeRequest/specification/FW_OS_Upgrade_Standard> .


