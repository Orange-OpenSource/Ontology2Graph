# =============================================================================
# 8. Event Records
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_1 Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%" ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_1> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartDNSService .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a network interface on Core Switch_extra_node_1 01 went down."@en ;
    noria:loggingTime "2024-04-10T09:01:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/1, changed state to down" ;
    noria:logOriginatingManagedObject noria:Resource_CoreSwitch01 ;
    noria:logOriginatingManagementSystem noria:Application_InternalMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_1> ;
    noria:alarmMonitoredAttribute "interface_status" .

noria:EventRecord_DBHighCPU a noria:EventRecord ;
    rdfs:label "Database High CPU Usage Alert"@en ;
    rdfs:comment "Alert indicating sustained high_extra_node_1 CPU usage on the production database server."@en ;
