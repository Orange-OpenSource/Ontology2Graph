    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Name Resolution" ;
    noria:resourceForApplication noria:Server_Web1 . # Assuming DNS runs on a server

