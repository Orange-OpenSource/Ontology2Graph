# =============================================================================
# Services
# =============================================================================

noria:Service_EnterpriseConnectivity a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "Provides end-to-end network connectivity for all corporate operations."@en ;
    noria:serviceType <kos/service/type/customer-facing> ;
    seas:subSystem noria:Application_CorporateInternetAccess, noria:Resource_RouterCore01, noria:Resource_FirewallDMZ .

noria:Service_CustomerDataManagement a noria:Service ;
    rdfs:label "Customer Data Management Service"@en ;
    rdfs:comment "Manages all customer-related data, underpinning the CRM system."@en ;
    noria:serviceType <kos/service/type/customer-facing> ;
    seas:subSystem noria:Application_CRMSystem, noria:Resource_DBServer01 .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that interface ge-0/0/0 on router-core-01 went down."@en ;
    noria:loggingTime "2024-04-20T09:01:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:NetworkInterface_RouterCore01_Ge0_0_0 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_WebSrvHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert for high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "WARNING: websrv01.corp.example.com CPU utilization > 90% for 5 minutes" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_FirewallConfigChange a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change applied to the DMZ Firewall by John Doe."@en ;
    noria:loggingTime "2024-04-19T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Configuration changed by jdoe: added new ACL rule for port 8080" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Indeterminate> .

noria:EventRecord_DBErrorLog a noria:EventRecord ;
    rdfs:label "Database Error Log"@en ;
    rdfs:comment "Error log from the production database server indicating a query timeout."@en ;
    noria:loggingTime "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "ERROR: SQL Query Timeout on CRM_PROD database" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Primary DNS server unreachable, impacting corporate internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Incident> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/ServiceInterruption> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/Immediate> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServerFailure> ;
    noria:troubleTicketCause "Unidentified OS crash on DNS01."@en ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/ServerFailure> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/NetworkTeam> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application_CorporateInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty foaf:Agent_DNSAdminTeam, foaf:Agent_NetworkOpsTeam ;
    noria:documentExternalId "INC-2024-04-20-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-2024-04-20-001" .

noria:TroubleTicket_CRMPerformance a noria:TroubleTicket ;
    rdfs:label "CRM System Performance Degradation"@en ;
    rdfs:comment "Users reporting slow response times on the CRM application."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Problem> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/PerformanceDegradation> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_WebSrvHighCPU ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/Deferred> ;
