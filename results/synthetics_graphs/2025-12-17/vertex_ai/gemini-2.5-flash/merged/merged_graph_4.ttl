# =============================================================================
# 1. Organizational Entities (foaf:Agent, org:Organization, org:OrganizationalUnit)
# =============================================================================

# Organizations
org:OrangeCorp a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main corporate entity."@en .

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for overall IT infrastructure and operations."@en ;
    org:unitOf org:OrangeCorp .

org:NetworkTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, call the hotline after sending an email."@en .

org:ServerTeam a org:OrganizationalUnit ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team managing server infrastructure."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> .

org:AppDevTeam a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Chat> .

org:SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:unitOf org:ITOperationsDept ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

# Agents (Persons)
foaf:Agent_Alice a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource noria:Router_Core1, noria:Firewall_DMZ1 .

foaf:Agent_Bob a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Server Administrator."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+33987654321" ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentManagesResource noria:Server_Web1, noria:Server_DB1 .

foaf:Agent_Carol a foaf:Agent ;
    rdfs:label "Carol White"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    foaf:mbox <mailto:carol.white@example.com> ;
    foaf:phone "+33611223344" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Chat> ;
    noria:agentManagesResource noria:App_CRM, noria:App_ERP .

foaf:Agent_David a foaf:Agent ;
    rdfs:label "David Green"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:david.green@example.com> ;
    foaf:phone "+33755667788" ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

# Corporate User Identifiers
noria:CUid_Alice a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate login for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount foaf:Agent_Alice .

noria:CUid_Bob a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate login for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount foaf:Agent_Bob .

# =============================================================================
# 2. Location Entities (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center location in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site_LyonOffice a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoom1 a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "Main server room within Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Room_NetworkCloset a noria:Room ;
    rdfs:label "Network Closet 201"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace bot:Site_LyonOffice .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room 1"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoom1 .

noria:Locus_RackB5 a noria:Locus ;
    rdfs:label "Rack B5 in Server Room 1"@en ;
    rdfs:comment "Specific rack location for network devices."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room_ServerRoom1 .

noria:Locus_WallMount1 a noria:Locus ;
    rdfs:label "Wall Mount 1 in Network Closet 201"@en ;
    rdfs:comment "Wall mount location for small network devices."@en ;
    noria:locusLine "WM" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_NetworkCloset .

# =============================================================================
# 3. Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy org:OrangeCorp . # Assuming Orange is also a manufacturer or reseller for simplicity, or create a new org:Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series."@en ;
    noria:productManufacturedBy org:OrangeCorp .

noria:ProductModel_PaloAltoFW a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy org:OrangeCorp .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy org:OrangeCorp .

# =============================================================================
# 4. Resources (noria:Resource, noria:NetworkInterface, noria:NetworkLink)
# =============================================================================

# Servers
noria:Server_Web1 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server hosting corporate applications."@en ;
    noria:resourceLogisticId "SRV-WEB-01-PAR" ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB01-XYZ123" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:ServerTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress observable:IPAddress_Web1Mgmt .

noria:Server_DB1 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Primary database server for critical applications."@en ;
    noria:resourceLogisticId "SRV-DB-01-PAR" ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB01-ABC456" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:ServerTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress observable:IPAddress_DB1Mgmt .

noria:VM_App1 a noria:Resource ;
    rdfs:label "Virtual Machine for CRM App"@en ;
    rdfs:comment "Virtual machine hosting the CRM application module."@en ;
    noria:resourceHostName "crm-vm01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:ServerTeam ;
    noria:clusterController noria:Server_Web1 ; # Assuming Web1 is also a hypervisor host
    noria:resourceManagementIPAddress observable:IPAddress_VMApp1Mgmt .

# Network Devices
noria:Router_Core1 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceLogisticId "RTR-CORE-01-PAR" ;
    noria:resourceHostName "core-rtr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-DEF789" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress observable:IPAddress_RtrCore1Mgmt .

noria:Firewall_DMZ1 a noria:Resource ;
    rdfs:label "DMZ Firewall 01"@en ;
    rdfs:comment "Firewall protecting the DMZ segment."@en ;
    noria:resourceLogisticId "FW-DMZ-01-PAR" ;
    noria:resourceHostName "dmz-fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_PaloAltoFW ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW01-GHI012" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress observable:IPAddress_FwDMZ1Mgmt .

noria:Switch_AccessLyon a noria:Resource ;
    rdfs:label "Lyon Access Switch"@en ;
    rdfs:comment "Access layer switch in Lyon office."@en ;
    noria:resourceLogisticId "SW-ACC-01-LYN" ;
    noria:resourceHostName "lyon-sw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Using same product model for simplicity
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-SWLYN-JKL345" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-20T13:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:locatedAtLocus noria:Locus_WallMount1 ;
    noria:resourceManagementIPAddress observable:IPAddress_SwLyonMgmt .

# IP Addresses (as observable:IPAddress, not noria:Resource)
observable:IPAddress_Web1Mgmt a observable:IPAddress ;
    rdfs:label "Web Server 01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.10" .

observable:IPAddress_DB1Mgmt a observable:IPAddress ;
    rdfs:label "Database Server 01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.11" .

observable:IPAddress_VMApp1Mgmt a observable:IPAddress ;
    rdfs:label "CRM VM Management IP"@en ;
    observable:ipAddressValue "10.0.0.12" .

observable:IPAddress_RtrCore1Mgmt a observable:IPAddress ;
    rdfs:label "Core Router 01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.1" .

observable:IPAddress_FwDMZ1Mgmt a observable:IPAddress ;
    rdfs:label "DMZ Firewall 01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.2" .

observable:IPAddress_SwLyonMgmt a observable:IPAddress ;
    rdfs:label "Lyon Access Switch Management IP"@en ;
    observable:ipAddressValue "10.0.1.1" .

# Network Interfaces
noria:NI_Web1_Eth0 a noria:NetworkInterface ;
    rdfs:label "web01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Server_Web1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Uplink to corporate LAN" .

noria:NI_DB1_Eth0 a noria:NetworkInterface ;
    rdfs:label "db01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface for Database Server 01."@en ;
    noria:networkInterfaceOf noria:Server_DB1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Uplink to corporate LAN" .

noria:NI_VMApp1_Eth0 a noria:NetworkInterface ;
    rdfs:label "crm-vm01.corp.example.com:eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for CRM VM."@en ;
    noria:networkInterfaceOf noria:VM_App1 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Virtual NIC for CRM application" .

noria:NI_RtrCore1_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "core-rtr01.corp.example.com:Gi0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to internal network."@en ;
    noria:networkInterfaceOf noria:Router_Core1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Internal LAN uplink" .

noria:NI_RtrCore1_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "core-rtr01.corp.example.com:Gi0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to DMZ firewall."@en ;
    noria:networkInterfaceOf noria:Router_Core1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 ;
    noria:networkInterfaceDescription "DMZ Firewall link" .

noria:NI_FwDMZ1_Eth0_0 a noria:NetworkInterface ;
    rdfs:label "dmz-fw01.corp.example.com:Eth0/0"@en ;
    rdfs:comment "Ethernet interface connecting to Core Router."@en ;
    noria:networkInterfaceOf noria:Firewall_DMZ1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Internal interface to Core Router" .

noria:NI_FwDMZ1_Eth0_1 a noria:NetworkInterface ;
    rdfs:label "dmz-fw01.corp.example.com:Eth0/1"@en ;
    rdfs:comment "Ethernet interface connecting to external internet."@en ;
    noria:networkInterfaceOf noria:Firewall_DMZ1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "External WAN interface" .

noria:NI_SwLyon_Gi0_1 a noria:NetworkInterface ;
    rdfs:label "lyon-sw01.corp.example.com:Gi0/1"@en ;
    rdfs:comment "Gigabit Ethernet uplink from Lyon office switch."@en ;
    noria:networkInterfaceOf noria:Switch_AccessLyon ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Uplink to regional WAN" .

# Network Links
noria:NL_CoreRtr_DMZ_Link a noria:NetworkLink ;
    rdfs:label "Core Router to DMZ Firewall Link"@en ;
    rdfs:comment "Direct link between core router and DMZ firewall."@en ;
    noria:networkLinkId "NL-CR-DMZ-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-10T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Router_Core1 ;
    noria:networkLinkTerminationResourceDestination noria:Firewall_DMZ1 ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:networkInterfaceConnects noria:NI_RtrCore1_Gi0_0_1, noria:NI_FwDMZ1_Eth0_0 .

noria:NL_DMZ_Internet_Link a noria:NetworkLink ;
    rdfs:label "DMZ Firewall to Internet Link"@en ;
    rdfs:comment "External link from DMZ firewall to the internet."@en ;
    noria:networkLinkId "NL-DMZ-INT-01" ;
    noria:networkLinkType "Fiber Optic WAN" ;
    noria:networkLinkInstallationDate "2022-01-10T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Firewall_DMZ1 ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:networkInterfaceConnects noria:NI_FwDMZ1_Eth0_1 .

noria:NL_Lyon_WAN_Link a noria:NetworkLink ;
    rdfs:label "Lyon Office to WAN Link"@en ;
    rdfs:comment "WAN link connecting Lyon office to corporate network."@en ;
    noria:networkLinkId "NL-LYN-WAN-01" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2023-05-20T13:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Switch_AccessLyon ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:networkInterfaceConnects noria:NI_SwLyon_Gi0_1 .

# =============================================================================
# 5. Applications and Services (noria:Application, noria:ApplicationModule, noria:Service)
# =============================================================================

# Applications
noria:App_CRM a noria:Application ;
    rdfs:label "Customer Relationship Management (CRM)"@en ;
    rdfs:comment "Core application for managing customer interactions."@en ;
    noria:applicationModelIdentifier "CRM-V2.0" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/business-application> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales & Marketing" ;
    noria:resourceForApplication noria:Server_Web1, noria:Server_DB1, noria:VM_App1 .

noria:App_ERP a noria:Application ;
    rdfs:label "Enterprise Resource Planning (ERP)"@en ;
    rdfs:comment "Integrated management of main business processes."@en ;
    noria:applicationModelIdentifier "ERP-SAP-S4HANA" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "ERP" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/business-application> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Finance & Operations" ;
    noria:applicationFunctionalSubDomain "Supply Chain Management" ;
    noria:resourceForApplication noria:Server_DB1 .

noria:App_Monitoring a noria:Application ;
    rdfs:label "Network Monitoring System (NMS)"@en ;
    rdfs:comment "System for monitoring network devices and services."@en ;
    noria:applicationModelIdentifier "NMS-PRTG" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/monitoring-system> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Network Performance Monitoring" ;
    noria:resourceForApplication noria:Server_Web1 . # Assuming NMS runs on a server

noria:App_DNS a noria:Application ;
