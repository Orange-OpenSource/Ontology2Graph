    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:locatedAtLocus noria:Locus_Rack_A1 ;
    noria:resourceManagementIPAddress observable:IPAddress_CR02_Mgmt ;
    noria:resourceForApplication noria:Application_CorporateEmail, noria:Application_CRMSystem .

