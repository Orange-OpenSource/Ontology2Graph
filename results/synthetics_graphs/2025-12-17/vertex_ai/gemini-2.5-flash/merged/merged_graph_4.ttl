foaf:Agent_IT_Operations_Team a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure_extra_node_4 operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical_extra_node_4 incidents, call the hotline. For non-critical_extra_node_4, use the ticketing system."@en .

