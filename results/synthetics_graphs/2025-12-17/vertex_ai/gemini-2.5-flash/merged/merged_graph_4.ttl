# =============================================================================
# 8. Operational Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

# Anomaly Pattern
noria:AnomalyPattern_HighCPUUsage a noria:AnomalyPattern ;
    rdfs:label "High CPU Usage Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high_extra_node_2 CPU usage on a server, potentially leading to performance degradation or service outage."@en ;
    skos:example "CPU utilization consistently above 90% for a period exceeding 15 minutes."@en .

noria:AnomalyPattern_NetworkLinkFlap a noria:AnomalyPattern ;
    rdfs:label "Network Link Flapping Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating frequent up_extra_node_2/down transitions of a network interface, suggesting instability."@en ;
    skos:example "Network interface operational status changes from 'up_extra_node_2' to 'down' and back multiple times within a short interval (e.g., 5 minutes)."@en .

# Action Pre-Condition
noria:ActionPreCondition_ServerReachable a noria:ActionPreCondition ;
    rdfs:label "Server_extra_node_2 Reachable Pre-Condition"@en ;
    rdfs:comment "Condition: The target server must be reachable via network protocols (e.g., ping, SSH) before proceeding with an action."@en .

noria:ActionPreCondition_HighCPUConfirmed a noria:ActionPreCondition ;
    rdfs:label "High CPU Confirmed Pre-Condition"@en ;
    rdfs:comment "Condition: Monitoring system confirms CPU usage above a predefined critical_extra_node_2 threshold."@en .

noria:ActionPreCondition_ISPContacted a noria:ActionPreCondition ;
    rdfs:label "ISP Contacted Pre-Condition"@en ;
    rdfs:comment "Condition: The Internet Service Provider (ISP) has been contacted and is aware of the network issue."@en .

# Action Post-Condition
noria:ActionPostCondition_ServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Expected outcome: The affected service is fully operational, accessible, and performing within normal parameters."@en .

noria:ActionPostCondition_CPUNormalized a noria:ActionPostCondition ;
    rdfs:label "CPU Usage Normalized Post-Condition"@en ;
    rdfs:comment "Expected outcome: CPU utilization on the server returns to normal operating levels (e.g., below 50%)."@en .

noria:ActionPostCondition_NetworkStable a noria:ActionPostCondition ;
    rdfs:label "Network Link Stable Post-Condition"@en ;
    rdfs:comment "Expected outcome: The network link remains in an 'up_extra_node_2' operational state without further flapping for a sustained period."@en .

# Operation Plan
noria:OperationPlan_RestartAppServer a noria:OperationPlan ;
    rdfs:label "Restart Application Server_extra_node_2 Procedure"@en ;
    rdfs:comment "Standard_extra_node_2 operating procedure for gracefully restarting an application server to resolve performance issues or application hangs."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_ServerReachable ;
    noria:operationPlanPreCondition noria:ActionPreCondition_HighCPUConfirmed ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ServiceRestored ;
    noria:operationPlanPostCondition noria:ActionPostCondition_CPUNormalized .

noria:OperationPlan_NetworkTroubleshooting a noria:OperationPlan ;
    rdfs:label "Network Connectivity Troubleshooting"@en ;
    rdfs:comment "Procedure for diagnosing and resolving network connectivity issues, including physical layer checks and ISP coordination."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_ServerReachable ; # Can be used to check if it's NOT reachable
    noria:operationPlanPreCondition noria:ActionPreCondition_ISPContacted ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ServiceRestored ;
    noria:operationPlanPostCondition noria:ActionPostCondition_NetworkStable .

noria:OperationPlan_SecurityIncidentResponse a noria:OperationPlan ;
    rdfs:label "Security Incident_extra_node_2 Response Plan"@en ;
    rdfs:comment "Procedure for responding to detected security incidents, including containment, eradication, and recovery steps."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_HighCPUConfirmed ; # Example: High CPU could be a symptom of a security incident
    noria:operationPlanPostCondition noria:ActionPostCondition_ServiceRestored . # Example: Service restored after incident resolution

