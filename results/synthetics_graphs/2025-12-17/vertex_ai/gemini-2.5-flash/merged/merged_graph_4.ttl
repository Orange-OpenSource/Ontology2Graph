# =============================================================================
# Services
# =============================================================================

noria:Service_InternetAccessService a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService_extra_node_3> ;
    seas:subSystemOf noria:Application_CorporateDNS, noria:Application_WebAppPortal ; # Services are composed of applications/modules
    seas:subSystemOf noria:ApplicationModule_CorporateDNS_Prod, noria:ApplicationModule_WebAppPortal_Frontend .

noria:Service_CRMDataService a noria:Service ;
    rdfs:label "CRM Data Access Service"@en ;
    rdfs:comment "Provides access to customer data for internal business_extra_node_3 processes."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Application_CustomerCRM ;
    seas:subSystemOf noria:ApplicationModule_CustomerCRM_DB .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_DNS_Outage_Log a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_3 Outage Log"@en ;
    rdfs:comment "Log entry indicating an outage of the primary DNS server."@en ;
    noria:loggingTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_LogManagementSystem ;
    noria:logText "CRITICAL: DNS service on dns01.corp.example.com is unreachable."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical_extra_node_3> ;
    noria:alarmProposedRepairAction noria:OperationPlan_DNS_Troubleshooting_SOP .

