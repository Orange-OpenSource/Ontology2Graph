# =============================================================================
# 11. Operational Plans and Conditions
# =============================================================================

noria:OperationPlan_TroubleshootLink a noria:OperationPlan ;
    rdfs:label "Network Link Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network link issues."@en ;
    skos:example "A system upgrade procedure, a network traffic fail-over activation, the control method for qualifying some system fault."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_LinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LinkUp .

noria:OperationPlan_RouterFirmwareUpgrade a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FirmwareUpdated .

noria:ActionPreCondition_LinkDown a noria:ActionPreCondition ;
    rdfs:label "Network Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: A critical network link is reported as down."@en ;
    skos:example "In an Incident Management context: when in situation X, shut link may help"@en .

noria:ActionPostCondition_LinkUp a noria:ActionPostCondition ;
    rdfs:label "Network Link Up Post-Condition"@en ;
    rdfs:comment "Expected outcome: The network link is restored and operational."@en ;
    skos:example "In an Incident Management context, the materialization to expect, such as: 'service restored', 'traffic down', 'Customer or a probe with that traffic coming up after some CLI command'."@en .

noria:ActionPreCondition_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Scheduled Maintenance Window Pre-Condition"@en ;
    rdfs:comment "Condition: The change is scheduled within an approved maintenance window."@en .

noria:ActionPostCondition_FirmwareUpdated a noria:ActionPostCondition ;
    rdfs:label "Firmware Updated Post-Condition"@en ;
    rdfs:comment "Expected outcome: Router firmware is successfully updated and verified."@en .

# =============================================================================
# 12. Anomaly Patterns
# =============================================================================

noria:AnomalyPattern_LinkFlap a noria:AnomalyPattern ;
    rdfs:label "Network Link Flapping Pattern"@en ;
    rdfs:comment "Pattern indicating a network link repeatedly goes up and down in a short period, suggesting instability."@en ;
    skos:example "Repeated 'LINEPROTO-5-UPDOWN' events for the same interface within 5 minutes."@en .

noria:AnomalyPattern_HighCPU_DB a noria:AnomalyPattern ;
    rdfs:label "Database High CPU Anomaly"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage on a database server, potentially leading to performance degradation."@en ;
    skos:example "CPU utilization > 90% for more than 15 minutes on a DB server, correlated with slow query logs."@en .



