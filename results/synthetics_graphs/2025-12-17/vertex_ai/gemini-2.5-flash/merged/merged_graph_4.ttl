noria:AnomalyPattern_DNSFailureChain a noria:AnomalyPattern ;
    rdfs:label "DNS Failure_extra_node_1 Chain Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a DNS server outage followed by widespread internet access issues."@en ;
    skos:example "EventRecord_DNSOutageLog followed by multiple 'internet access down' alerts."@en ;
    folio:hasCause noria:ActionPreCondition_DNSServiceDown .

noria:AnomalyPattern_HighCPUDB a noria:AnomalyPattern ;
    rdfs:label "High CPU Database Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high_extra_node_1 CPU on database server, potentially leading to application slowdown."@en ;
    skos:example "EventRecord_DBHighCPU correlated with slow application response times."@en .

