# =============================================================================
# Network Interfaces and Links
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface 0 on Corporate DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary management interface" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_LAN_Segment1 .

noria:NetworkInterface_RouterCore01_Ge0_0_0 a noria:NetworkInterface ;
    rdfs:label "router-core-01-ge-0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/0 on Core Router 01, connecting to LAN Segment 1."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to internal LAN segment 1" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:NetworkLink_LAN_Segment1 .

noria:NetworkInterface_RouterCore01_Ge0_0_1 a noria:NetworkInterface ;
    rdfs:label "router-core-01-ge-0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/1 on Core Router 01, connecting to DMZ Firewall."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to DMZ Firewall" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_CoreRouter_DMZ_FW .

noria:NetworkInterface_FirewallDMZ_Eth1 a noria:NetworkInterface ;
    rdfs:label "fw-dmz-01-eth1"@en ;
    rdfs:comment "Ethernet interface 1 on DMZ Firewall, connecting to Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Internal interface to Core Router" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_CoreRouter_DMZ_FW .

noria:NetworkInterface_FirewallDMZ_Eth2 a noria:NetworkInterface ;
    rdfs:label "fw-dmz-01-eth2"@en ;
    rdfs:comment "Ethernet interface 2 on DMZ Firewall, connecting to external internet."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "External interface to Internet" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 ;
    noria:networkInterfaceConnects noria:NetworkLink_InternetUplink .

noria:NetworkInterface_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "websrv01-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface on Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "Primary network interface for web traffic" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_DMZ_Segment .

noria:NetworkInterface_DBServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "db01-eth0"@en ;
    rdfs:comment "Ethernet interface on Production Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary network interface for database traffic" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_LAN_Segment1 .

noria:NetworkLink_LAN_Segment1 a noria:NetworkLink ;
    rdfs:label "LAN Segment 1"@en ;
    rdfs:comment "Internal Local Area Network segment connecting core infrastructure."@en ;
    noria:networkLinkId "LAN-SEG-001" ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkLinkInstallationDate "2021-03-20T14:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkLinkTerminationResource noria:Resource_DNS01, noria:Resource_RouterCore01, noria:Resource_DBServer01 .

noria:NetworkLink_CoreRouter_DMZ_FW a noria:NetworkLink ;
    rdfs:label "Core Router to DMZ Firewall Link"@en ;
    rdfs:comment "Dedicated link between Core Router and DMZ Firewall."@en ;
    noria:networkLinkId "CR-DMZ-FW-001" ;
    noria:networkLinkType "Gigabit Ethernet" ;
    noria:networkLinkInstallationDate "2022-08-10T15:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_FirewallDMZ .

noria:NetworkLink_InternetUplink a noria:NetworkLink ;
    rdfs:label "Internet Uplink"@en ;
    rdfs:comment "Primary internet connection from DMZ Firewall."@en ;
    noria:networkLinkId "ISP-UPLINK-001" ;
    noria:networkLinkType "Fiber Optic WAN" ;
    noria:networkLinkInstallationDate "2022-08-10T15:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkLinkTerminationResource noria:Resource_FirewallDMZ .

noria:NetworkLink_DMZ_Segment a noria:NetworkLink ;
    rdfs:label "DMZ Segment"@en ;
    rdfs:comment "Network segment within the DMZ, hosting web servers."@en ;
    noria:networkLinkId "DMZ-SEG-001" ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkLinkInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv01, noria:Resource_FirewallDMZ .

