# Connect Event Records to Trouble Tickets via documentStatusHistory
noria:TT_NetworkOutage_001 noria:documentStatusHistory noria:Event_RouterInterfaceDown .
noria:TT_WebsitePerformance_002 noria:documentStatusHistory noria:Event_WebServerCPUHigh .

# Connect Change Requests to Event Records (e.g., for audit trail)
noria:CR_RouterUpgrade_001 noria:documentStatusHistory noria:Event_ConfigChangeRouter .

# Example of a TroubleTicketCharacteristic
noria:TT_NetworkOutage_001 noria:troubleTicketCharacteristic noria:TTC_CustomerImpactHigh .
noria:TTC_CustomerImpactHigh a noria:Property ;
    rdfs:label "High Customer Impact"@en ;
    rdfs:comment "Characteristic indicating that the incident has a high impact on customer-facing services."@en .

# Example of a ChangeRequestCharacteristic (using a generic Property for now)
noria:CR_RouterUpgrade_001 noria:changeRequestCharacteristic noria:CRC_RequiresDowntime .
noria:CRC_RequiresDowntime a noria:Property ;
    rdfs:label "Requires Downtime"@en ;
    rdfs:comment "Characteristic indicating that the change requires a service interruption."@en .

# Example of a TroubleTicketFreezeItem (linking to an EventRecord that signifies a freeze)
noria:TT_NetworkOutage_001 noria:troubleTicketFreezeItem noria:Event_TTFreeze_001 .
noria:Event_TTFreeze_001 a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Event"@en ;
    rdfs:comment "Event indicating that TT_NetworkOutage_001 was put on hold due to external dependency."@en ;
    noria:loggingTime "2024-04-20T10:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "Trouble Ticket INC-2024-04-20-001 status changed to 'Frozen' due to ISP dependency."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# Example of a TroubleTicketPartyIntervention (using a generic Property for now, could be more detailed)
noria:TT_NetworkOutage_001 noria:troubleTicketPartyIntervention noria:TTPI_ISPContacted .
noria:TTPI_ISPContacted a noria:Property ;
    rdfs:label "ISP Contacted"@en ;
    rdfs:comment "Intervention record: ISP A was contacted at 10:15 AM."@en .

# Connect Anomaly Patterns to potential causes or related events
noria:AnomalyPattern_HighCPULoad dcterms:relation noria:Event_WebServerCPUHigh .
noria:AnomalyPattern_NetworkFlap dcterms:relation noria:Event_RouterInterfaceDown .

# Connect Operation Plans to Anomaly Patterns (as a response)
noria:OP_RouterFailover dcterms:relation noria:AnomalyPattern_NetworkFlap .
noria:OP_DBIndexCreation dcterms:relation noria:AnomalyPattern_HighCPULoad .

# Connect CorporateUserIdentifier to EventRecords where they are the originating agent
noria:CUid_ASmith noria:eventRelatedParty noria:Event_ConfigChangeRouter .
noria:CUid_BJohnson noria:eventRelatedParty noria:Event_DBLoginFailure .

# Connect Application Modules to Support Group
noria:AppModule_CorporateWebsite_Prod noria:applicationModuleSupportGroup noria:OrgUnit_AppDev .
noria:AppModule_InternalCRM_Prod noria:applicationModuleSupportGroup noria:OrgUnit_DBA .

# Connect Application Modules to Hotline Group
noria:AppModule_CorporateWebsite_Prod noria:applicationModuleHotlineGroup noria:OrgUnit_AppDev .

