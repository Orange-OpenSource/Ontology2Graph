# Organizational Units (Teams)
org:ITOpsTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7 (Shift-based)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For critical issues, open a P1 ticket and call the hotline. For non-critical, use the ticketing system."@en ;
    noria:agentManagesResource noria:Resource_CoreRouter01, noria:Resource_WebServer01, noria:Resource_DBServer01 ;
    noria:agentManagesResource noria:NetworkLink_DC1_DC2_Fiber ;
    noria:agentManagesResource noria:Application_CorporateEmail, noria:Application_CRMSystem ;
    noria:agentManagesResource noria:Service_CorporateConnectivity ;
    noria:agentManagesResource noria:ApplicationModule_EmailProd_DC1 ;
