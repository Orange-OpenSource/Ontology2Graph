# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_DNSReboot a noria:OperationPlan ;
    rdfs:label "DNS Server Reboot Procedure"@en ;
    rdfs:comment "Standard operating procedure for rebooting a corporate DNS server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSRestored .

noria:ActionPreCondition_DNSUnreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unreachable Pre-Condition"@en ;
    rdfs:comment "Condition: DNS server is not responding to queries, and ping fails."@en ;
    skos:example "EventRecord_DNSOutageLog indicates server is down."@en .

noria:ActionPostCondition_DNSRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Post-Condition"@en ;
    rdfs:comment "Outcome: DNS server is responding to queries, and ping is successful. Service is confirmed by users."@en ;
    skos:example "EventRecord_DNSOutageCleared indicates server is up."@en .

noria:OperationPlan_FirewallACLUpdateProcedure a noria:OperationPlan ;
    rdfs:label "Firewall ACL Update Procedure"@en ;
    rdfs:comment "Detailed steps for safely updating Access Control Lists on production firewalls."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_ChangeApproved ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ACLVerified .

noria:ActionPreCondition_ChangeApproved a noria:ActionPreCondition ;
    rdfs:label "Change Approved Pre-Condition"@en ;
    rdfs:comment "Condition: The Change Request has been formally approved by the Change Advisory Board (CAB)."@en ;
    skos:example "ChangeRequest_FirewallACLUpdate status is 'Approved'."@en .

noria:ActionPostCondition_ACLVerified a noria:ActionPostCondition ;
    rdfs:label "ACL Verified Post-Condition"@en ;
    rdfs:comment "Outcome: New ACL rules are active and verified to function as expected without unintended side effects."@en ;
    skos:example "Network connectivity tests pass for the new service."@en .

noria:AnomalyPattern_HighCPU_SlowDB a noria:AnomalyPattern ;
    rdfs:label "High CPU & Slow DB Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential application performance issue: sustained high CPU on web servers coupled with slow database query response times."@en ;
    skos:example "Correlated EventRecord_WebSrvHighCPU and EventRecord_DBErrorLog."@en .

noria:OperationPlan_CRMPerformanceDiagnosis a noria:OperationPlan ;
    rdfs:label "CRM Performance Diagnosis Procedure"@en ;
    rdfs:comment "Procedure for diagnosing performance issues in the CRM application."@en ;
    noria:operationPlanPreCondition noria:AnomalyPattern_HighCPU_SlowDB ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RootCauseIdentified .

noria:ActionPostCondition_RootCauseIdentified a noria:ActionPostCondition ;
    rdfs:label "Root Cause Identified Post-Condition"@en ;
    rdfs:comment "Outcome: The root cause of the CRM performance degradation has been identified (e.g., inefficient query, resource bottleneck)."@en .

# Linking Change Request to Operation Plan
noria:ChangeRequest_FirewallACLUpdate noria:actionCorrelatedOperationPlan noria:OperationPlan_FirewallACLUpdateProcedure .

