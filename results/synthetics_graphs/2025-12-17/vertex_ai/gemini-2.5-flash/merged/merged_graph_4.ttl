# Applications
# =============================================================================

noria:Application_CorporateDNS a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:comment "Provides name resolution services for the entire corporate network."@en ;
    noria:applicationModelIdentifier "CORP-DNS-V1" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CORPDNS" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/infrastructure_extra_node_3> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business_extra_node_3-importance/high_extra_node_3> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Name Resolution_extra_node_3" ;
    noria:resourceForApplication noria:Resource_DNS_Server_01 .

noria:Application_WebAppPortal a noria:Application ;
    rdfs:label "Corporate Web Application Portal"@en ;
    rdfs:comment "Main web portal for internal and external users."@en ;
    noria:applicationModelIdentifier "WEBAPP-PORTAL-V2" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "WEBPORTAL" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/business_extra_node_3> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business_extra_node_3-importance/high_extra_node_3> ;
    noria:applicationFunctionalDomain "Customer_extra_node_3 Relationship Management" ;
    noria:applicationFunctionalSubDomain "Online Services" ;
    noria:resourceForApplication noria:Resource_Web_Server_01, noria:Resource_LoadBalancer_01 .

noria:Application_CustomerCRM a noria:Application ;
    rdfs:label "Customer_extra_node_3 Relationship Management System"@en ;
    rdfs:comment "System for managing customer data and interactions."@en ;
    noria:applicationModelIdentifier "CRM-SYSTEM-V3" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/business_extra_node_3> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business_extra_node_3-importance/high_extra_node_3> ;
    noria:applicationFunctionalDomain "Customer_extra_node_3 Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer_extra_node_3 Data Management" ;
    noria:resourceForApplication noria:Resource_DB_Server_01 .

noria:Application_LogManagementSystem a noria:Application ;
    rdfs:label "Centralized Log Management System"@en ;
    rdfs:comment "Collects, stores, and analyzes logs from all IT infrastructure_extra_node_3."@en ;
    noria:applicationModelIdentifier "LOG-MGMT-V1" ;
    noria:applicationNumericalIdentifier 1004 ;
    noria:applicationShortIdentifier "LOGMGMT" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/monitoring_extra_node_3> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business_extra_node_3-importance/medium> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Monitoring and Logging" .

