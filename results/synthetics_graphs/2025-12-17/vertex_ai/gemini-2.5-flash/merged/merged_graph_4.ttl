# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_DBDiskFull a noria:EventRecord ;
    rdfs:label "Database Disk Full Alert"@en ;
    rdfs:comment "Alert indicating that the disk space on the production database server is critically low."@en ;
    noria:loggingTime "2024-04-20T08:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Disk usage on /var/lib/mysql is 95% on dbprod01.corp.example.com."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_5> ;
    noria:alarmProposedRepairAction noria:OperationPlan_ClearDiskSpace .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router_extra_node_5 Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that a critical_extra_node_5 network interface on the core router went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_5> ;
    noria:alarmProposedRepairAction noria:OperationPlan_TroubleshootNetworkLink .

noria:EventRecord_FirewallBlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Log"@en ;
    rdfs:comment "Log entry showing traffic blocked by the perimeter firewall due to a security policy violation."@en ;
    noria:loggingTime "2024-04-20T09:15:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Traffic from 192.168.1.5 to 203.0.113.10 on port 8080 blocked by policy 'External_Access_Restrict'."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_5> .

noria:EventRecord_UserLoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on a critical_extra_node_5 server."@en ;
    noria:loggingTime "2024-04-20T09:20:10Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_ExternalAttacker ; # Example of an external agent
    noria:logText "Failed login for user 'admin' from IP 1.2.3.4."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

foaf:Agent_ExternalAttacker a foaf:Agent ;
    rdfs:label "External Attacker"@en ;
    rdfs:comment "Hypothetical external entity attempting unauthorized access."@en .

