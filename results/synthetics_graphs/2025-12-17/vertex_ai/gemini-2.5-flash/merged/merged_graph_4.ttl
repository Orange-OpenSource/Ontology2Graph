noria:Event_Log_WebSrv01_CPUHigh a noria:EventRecord ;
    rdfs:label "WebSrv01 CPU High Alert"@en ;
    rdfs:comment "Log entry indicating high_extra_node_0 CPU utilization on Web Server_extra_node_0 01."@en ;
    noria:loggingTime "2023-10-26T14:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "CPU utilization on websrv01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_0> .

noria:Event_Log_RouterCore01_LinkDown a noria:EventRecord ;
    rdfs:label "RouterCore01 Link Down Alert"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Core Router_extra_node_0 01."@en ;
    noria:loggingTime "2023-10-27T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_0> ;
    noria:alarmProposedRepairAction noria:OP_CheckFiberLink .

noria:Event_Log_FirewallDMZ01_Attack a noria:EventRecord ;
    rdfs:label "Firewall_extra_node_0 DMZ01 Attack Attempt"@en ;
    rdfs:comment "Log entry from firewall indicating a detected attack attempt."@en ;
    noria:loggingTime "2023-10-27T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_BobWhite ; # Bob White configured the alert
    noria:logText "Detected SQL Injection attempt from 192.168.1.100 on DMZ web server."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_0> .

noria:Event_Log_DBSrv01_DiskFull a noria:EventRecord ;
    rdfs:label "DBSrv01 Disk Full Alert"@en ;
    rdfs:comment "Log entry indicating a disk space issue on Database Server_extra_node_0 01."@en ;
    noria:loggingTime "2023-10-27T11:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "Disk /var/lib/mysql is 95% full on dbsrv01.corp.example.com."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor_extra_node_0> .

noria:Event_Log_VM_App01_Restart a noria:EventRecord ;
