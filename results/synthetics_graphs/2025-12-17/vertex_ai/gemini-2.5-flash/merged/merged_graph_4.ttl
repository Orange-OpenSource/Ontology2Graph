# =============================================================================
# 11. Operations and Procedures
# =============================================================================

noria:OperationPlan_RestartDNSService a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en ;
    rdfs:comment "Standard_extra_node_1 operating procedure for restarting the corporate DNS service."@en ;
    skos:example "Steps: 1. Check service status. 2. Attempt graceful restart. 3. Force restart if necessary. 4. Verify service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSServiceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSServiceUp .

noria:OperationPlan_InterfaceTroubleshooting a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues with network interfaces."@en ;
    skos:example "Steps: 1. Check cable. 2. Check port status. 3. Clear counters. 4. Reconfigure interface."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:OperationPlan_FirmwareUpgrade a noria:OperationPlan ;
    rdfs:label "Network Device Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard_extra_node_1 procedure for upgrading firmware on network devices."@en ;
    skos:example "Steps: 1. Backup configuration. 2. Download firmware. 3. Install firmware. 4. Reboot. 5. Verify."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FirmwareUpdated .

# Action Pre-Conditions
noria:ActionPreCondition_DNSServiceDown a noria:ActionPreCondition ;
    rdfs:label "DNS Service is Down"@en ;
    rdfs:comment "Condition: DNS service is not responding or is in a failed state."@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en .

noria:ActionPreCondition_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Scheduled_extra_node_1 Maintenance Window"@en ;
    rdfs:comment "Condition: The change is scheduled within an approved maintenance window."@en .

# Action Post-Conditions
noria:ActionPostCondition_DNSServiceUp a noria:ActionPostCondition ;
    rdfs:label "DNS Service is Up_extra_node_1"@en ;
    rdfs:comment "Expected outcome: DNS service is running and responding to queries."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up_extra_node_1"@en ;
    rdfs:comment "Expected outcome: Network interface's operational status is 'up_extra_node_1'."@en .

noria:ActionPostCondition_FirmwareUpdated a noria:ActionPostCondition ;
    rdfs:label "Firmware Successfully Updated"@en ;
    rdfs:comment "Expected outcome: Device firmware is updated to the target version and operating normally."@en .

# Procedure Execution Containers (linking actions to procedures)
noria:ProcedureExecutionContainer_InterfaceFix a pep:ProcedureExecutionContainer ;
    rdfs:label "Interface Fix Execution"@en ;
    rdfs:comment "Container for actions taken to fix the network interface issue."@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_InterfaceTroubleshooting ;
    dcterms:created "2024-04-10T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent1 .

noria:ProcedureExecutionContainer_FirmwareUpgradeCR a pep:ProcedureExecutionContainer ;
    rdfs:label "Firmware Upgrade Execution for CR001"@en ;
    rdfs:comment "Container for the execution of the firmware upgrade procedure as part of CR001."@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_FirmwareUpgrade ;
    dcterms:created "2024-04-20T02:00:00Z"^^xsd:dateTime ;
    dcterms:creator org:NetworkOperationsTeam .

