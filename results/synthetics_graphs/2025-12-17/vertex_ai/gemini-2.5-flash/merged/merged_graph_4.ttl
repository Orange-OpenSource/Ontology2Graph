    noria:troubleTicketRelatedResource noria:VM_App1, noria:Server_DB1 ;
    noria:troubleTicketImpacts noria:App_CRM .

# Trouble Ticket Notes
noria:TTN_DNS_001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT-001"@en ;
    rdfs:comment "Confirmed primary DNS server is not responding to ping or DNS queries. Investigating network path."@en ;
    dcterms:created "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_Alice ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TT_DNS_Outage_001 .

noria:TTN_DNS_001_Note2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Steps for TT-001"@en ;
    rdfs:comment "Identified misconfiguration in DNS zone file. Rolled back to previous version. Service restored."@en ;
    dcterms:created "2024-04-20T09:40:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_Alice ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Resolution> ;
    dcterms:isPartOf noria:TT_DNS_Outage_001 ;
    noria:troubleTicketNoteCorrelatedExecution noria:CR_DNS_Rollback_001 . # Link to a Change Request for the rollback

noria:TTN_CRM_002_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Database Query Optimization for TT-002"@en ;
    rdfs:comment "Identified a slow SQL query. Working with dev team to optimize it. Applied temporary index."@en ;
    dcterms:created "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_Bob ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TT_CRM_Perf_002 .

# Document Attachments
noria:Doc_DNS_Config a noria:DocumentAttachment ;
    rdfs:label "DNS Configuration File"@en ;
    rdfs:comment "Snapshot of the DNS zone file before and after rollback."@en ;
    dcterms:isPartOf noria:TT_DNS_Outage_001 ;
    dcterms:format "text/plain" .

noria:Doc_CRM_PerfReport a noria:DocumentAttachment ;
    rdfs:label "CRM Performance Report"@en ;
    rdfs:comment "Performance metrics report for CRM application during degradation."@en ;
    dcterms:isPartOf noria:TT_CRM_Perf_002 ;
    dcterms:format "application/pdf" .

