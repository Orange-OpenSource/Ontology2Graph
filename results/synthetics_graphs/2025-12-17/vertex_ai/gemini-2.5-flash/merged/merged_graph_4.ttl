# Trouble Tickets
noria:TT_DNS_Outage_001 a noria:TroubleTicket ;
    rdfs:label "Critical DNS Service Outage"@en ;
    rdfs:comment "Corporate DNS service is completely down, impacting all internal applications and internet access."@en ;
    dcterms:identifier "TT-20240420-001" ;
    noria:documentExternalId "INC-DNS-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-20240420-001" ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <https://w3id.org/noria/kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <https://w3id.org/noria/kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <https://w3id.org/noria/kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:Event_DNS_Outage ;
    noria:troubleTicketUrgency <https://w3id.org/noria/kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "NMS-PRTG" ;
    noria:troubleTicketCategory <https://w3id.org/noria/kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketCause "Misconfiguration on primary DNS server."@en ;
    noria:problemCategory <https://w3id.org/noria/kos/TroubleTicket/category/ConfigurationError> ;
    noria:problemResponsibility <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T09:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:NetworkTeam, foaf:Agent_Alice ;
    noria:troubleTicketRelatedService noria:Service_CorporateInternetAccess, noria:AppMod_DNS_Prod ;
    noria:troubleTicketRelatedResource noria:Server_Web1 ;
    noria:troubleTicketImpacts noria:App_CRM, noria:App_ERP, noria:Service_CorporateInternetAccess .

noria:TT_CRM_Perf_002 a noria:TroubleTicket ;
    rdfs:label "CRM Application Performance Degradation"@en ;
    rdfs:comment "Users report slow response times for the CRM application."@en ;
    dcterms:identifier "TT-20240420-002" ;
    noria:documentExternalId "INC-CRM-002" ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-20240420-002" ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <https://w3id.org/noria/kos/TroubleTicket/category/PerformanceDegradation> ;
    noria:troubleTicketPriority <https://w3id.org/noria/kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <https://w3id.org/noria/kos/TroubleTicket/origin/Customer> ;
