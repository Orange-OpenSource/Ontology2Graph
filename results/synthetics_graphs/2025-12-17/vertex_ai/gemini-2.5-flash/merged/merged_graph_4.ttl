# =============================================================================
# 11. Operational Procedures and Anomaly Patterns
# =============================================================================

noria:OP_RouterFailover a noria:OperationPlan ;
    rdfs:label "Router WAN Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure to failover WAN traffic in case of primary link failure."@en ;
    skos:example "Steps include verifying link status, disabling primary interface, verifying traffic shift."@en ;
    noria:operationPlanPreCondition noria:APC_PrimaryWANLinkDown ;
    noria:operationPlanPostCondition noria:APOC_TrafficShiftedToBackup .

noria:APC_PrimaryWANLinkDown a noria:ActionPreCondition ;
    rdfs:label "Primary WAN Link Down Condition"@en ;
    rdfs:comment "Condition: noria:NI_RouterCore01_Gi0_0_1 noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Down>."@en .

noria:APOC_TrafficShiftedToBackup a noria:ActionPostCondition ;
    rdfs:label "Traffic Shifted to Backup WAN Link"@en ;
    rdfs:comment "Expected outcome: Traffic is successfully routed via the backup WAN link."@en .

noria:OP_DBIndexCreation a noria:OperationPlan ;
    rdfs:label "Database Index Creation Procedure"@en ;
    rdfs:comment "Procedure for creating a new index on a database table to improve query performance."@en ;
    skos:example "Steps include analyzing query, creating index, monitoring performance."@en ;
    noria:operationPlanPreCondition noria:APC_SlowDBQueries ;
    noria:operationPlanPostCondition noria:APOC_DBPerformanceImproved .

noria:APC_SlowDBQueries a noria:ActionPreCondition ;
    rdfs:label "Slow Database Queries Condition"@en ;
    rdfs:comment "Condition: Application performance monitoring reports slow database query execution times."@en .

noria:APOC_DBPerformanceImproved a noria:ActionPostCondition ;
    rdfs:label "Database Performance Improved Outcome"@en ;
    rdfs:comment "Expected outcome: Database query execution times are within acceptable thresholds."@en .

noria:AnomalyPattern_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Anomaly"@en ;
    rdfs:comment "Pattern indicating a server experiencing abnormally high CPU utilization for an extended period, potentially leading to service degradation."@en ;
    skos:example "CPU > 90% for 15 minutes on a production server."@en .

noria:AnomalyPattern_NetworkFlap a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Anomaly"@en ;
    rdfs:comment "Pattern indicating a network interface repeatedly changing its operational status (up/down) in a short period, suggesting instability."@en ;
    skos:example "Interface status changes 5 times in 1 minute."@en .

# Procedure Execution for a Trouble Ticket Note
noria:PE_DBIndexCreation a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of DB Index Creation"@en ;
    rdfs:comment "Record of the actual execution of the database index creation procedure."@en ;
    pep:usedProcedure noria:OP_DBIndexCreation ;
    dcterms:created "2024-04-20T11:10:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Person_CharlieBrown .

# Link an EventRecord to a proposed repair action
noria:Event_RouterInterfaceDown noria:alarmProposedRepairAction noria:OP_RouterFailover .

# Link an EventRecord to a mitigated action
noria:Event_WebServerCPUHigh noria:alarmMitigatedBy noria:PE_DBIndexCreation .

