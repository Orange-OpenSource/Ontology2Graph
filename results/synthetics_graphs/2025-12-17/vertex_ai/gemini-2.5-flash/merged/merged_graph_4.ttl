noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router in DC1, handling inter-VLAN routing and WAN connectivity."@en ;
    noria:resourceHostName "cr01.dc1.example.com" ;
    noria:resourceLogisticId "CR01-DC1-XYZ" ;
    noria:resourceSerialNumber "JNX123456789" ;
    noria:resourceProductModel noria:ProductModel_Cisco_ASR9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:locatedAtLocus noria:Locus_Rack_A1 ;
    noria:resourceManagementIPAddress observable:IPAddress_CR01_Mgmt ;
    noria:resourceForApplication noria:Application_CorporateEmail, noria:Application_CRMSystem ;
    noria:clusterController noria:Resource_CoreRouter02 . # Example of cluster controller

