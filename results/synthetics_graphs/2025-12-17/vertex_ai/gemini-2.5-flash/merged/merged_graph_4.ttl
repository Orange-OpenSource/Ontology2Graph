    seas:subSystemOf noria:AppMod_DNS_Prod, noria:Firewall_DMZ1, noria:Router_Core1 .

noria:Service_CRM_E2E a noria:Service ;
    rdfs:label "End-to-End CRM Service"@en ;
    rdfs:comment "Comprehensive service encompassing all CRM application modules and underlying infrastructure."@en ;
