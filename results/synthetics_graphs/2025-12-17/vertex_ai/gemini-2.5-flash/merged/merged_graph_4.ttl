    seas:subSystemOf noria:Router_Core1, noria:Switch_AccessLyon, noria:NL_Lyon_WAN_Link .

# =============================================================================
# 6. Event Records (noria:EventRecord)
# =============================================================================

noria:Event_DNS_Outage a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Event"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Server_Web1 ; # Assuming Web1 tries to resolve DNS
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "DNS resolution failed for primary DNS server dns01.corp.example.com (10.0.0.100)."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_Router_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a critical router interface went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Router_Core1 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface Gi0/0/1, changed state to down."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OP_CheckFiberLink .

noria:Event_CRM_HighCPU a noria:EventRecord ;
    rdfs:label "CRM VM High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on CRM application VM."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:VM_App1 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "CPU utilization on crm-vm01 exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_Firewall_ConfigChange a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Event"@en ;
    rdfs:comment "Log entry for a configuration change on the DMZ firewall."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Firewall_DMZ1 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logOriginatingAgent foaf:Agent_Alice ;
    noria:logText "Configuration changed by user 'asmith' from 10.0.0.5. Added new rule for port 8443."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

noria:Event_UserLoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security event: multiple failed login attempts on a server."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Server_Web1 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "Multiple failed login attempts for user 'unknown' from IP 192.168.1.10."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> .

