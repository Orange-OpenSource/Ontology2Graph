    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/ApplicationCrash> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention_extra_node_2> ;
    noria:documentExternalId "CUST-INC-2024-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/CRM-OUTAGE-001" ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:documentStatusHistory noria:EventRecord_TT_CRM_001_StatusChange_InProgress ;
    noria:documentStatusHistory noria:EventRecord_TT_CRM_001_StatusChange_Resolved ;
