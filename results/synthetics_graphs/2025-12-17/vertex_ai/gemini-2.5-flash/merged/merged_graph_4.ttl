# =============================================================================
# 5. Network Interfaces and Links
# =============================================================================

noria:NetworkInterface_CR01_GE0_0_0 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal network segment."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Internal LAN interface" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_CR01_GE0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to Core Router 02 for inter-DC link."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Inter-DC Link to CR02" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_DC1_DC2_Fiber ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_CR02_GE0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR02 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 02 to Core Router 01 for inter-DC link."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter02 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Inter-DC Link to CR01" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_DC1_DC2_Fiber ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_WEB01_ETH0 a noria:NetworkInterface ;
    rdfs:label "WEB01 Ethernet0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "VM NIC for Web Server" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_DB01_ETH0 a noria:NetworkInterface ;
    rdfs:label "DB01 Ethernet0"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "VM NIC for DB Server" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_FW01_EXT a noria:NetworkInterface ;
    rdfs:label "FW01 External Interface"@en ;
    rdfs:comment "External facing interface of Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "WAN Uplink" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkLink_DC1_DC2_Fiber a noria:NetworkLink ;
    rdfs:label "DC1-DC2 Fiber Link"@en ;
    rdfs:comment "High-speed fiber optic link connecting Data Center 1 and Data Center 2."@en ;
    noria:networkLinkId "LINK-DC1-DC2-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2019-10-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter02 ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter01, noria:Resource_CoreRouter02 .

noria:NetworkLink_Edge_ISP a noria:NetworkLink ;
    rdfs:label "Edge Router to ISP Link"@en ;
    rdfs:comment "Link connecting the corporate edge router to the Internet Service Provider."@en ;
    noria:networkLinkId "LINK-EDGE-ISP-001" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2018-05-20T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:networkLinkTerminationResource noria:Resource_Firewall01 . # Assuming Firewall is the edge device here

# =============================================================================
# 6. Applications and Application Modules
# =============================================================================

noria:Application_CorporateEmail a noria:Application ;
    rdfs:label "Corporate Email System"@en ;
    rdfs:comment "Critical application providing email services to all employees."@en ;
    noria:applicationModelIdentifier "EMAIL-CORP-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CorpEmail" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Collaboration and Communication" ;
    noria:applicationFunctionalSubDomain "Email Services" ;
    noria:elementManagedBy org:AppSupportTeam ;
    seas:hasSubSystem noria:ApplicationModule_EmailProd_DC1, noria:ApplicationModule_EmailDev .

noria:Application_CRMSystem a noria:Application ;
    rdfs:label "Customer Relationship Management (CRM)"@en ;
    rdfs:comment "Application for managing customer interactions and data."@en ;
    noria:applicationModelIdentifier "CRM-PROD-V3" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Sales and Marketing" ;
    noria:applicationFunctionalSubDomain "Customer Data Management" ;
    noria:elementManagedBy org:AppSupportTeam ;
    seas:hasSubSystem noria:ApplicationModule_CRMProd .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "IT Monitoring System"@en ;
    rdfs:comment "System for monitoring the health and performance of IT infrastructure and applications."@en ;
    noria:applicationModelIdentifier "MONITOR-V1" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "ITMon" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance and Availability Monitoring" ;
    noria:elementManagedBy org:ITOpsTeam .

noria:Application_CorporateInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet access for all corporate users and systems."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:elementManagedBy org:NetworkTeam .

noria:ApplicationModule_EmailProd_DC1 a noria:ApplicationModule ;
    rdfs:label "Corporate Email Production Module (DC1)"@en ;
    rdfs:comment "Production instance of the Corporate Email system hosted in DC1."@en ;
    noria:applicationModuleOf noria:Application_CorporateEmail ;
    noria:applicationModuleName "CorpEmail_Prod_DC1" ;
    noria:applicationModuleIdentifier "EMAIL-PROD-DC1" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam org:AppSupportTeam ;
    noria:applicationModuleAdministrationLeader foaf:Person_David ;
    noria:applicationModuleSupportTeam org:ITOpsTeam ;
    noria:applicationModuleSupportLeader foaf:Person_Bob ;
    noria:applicationModuleHotlineGroup org:ITOpsTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:ApplicationModule_EmailDev a noria:ApplicationModule ;
    rdfs:label "Corporate Email Development Module"@en ;
    rdfs:comment "Development instance of the Corporate Email system."@en ;
    noria:applicationModuleOf noria:Application_CorporateEmail ;
    noria:applicationModuleName "CorpEmail_Dev" ;
    noria:applicationModuleIdentifier "EMAIL-DEV" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleAdministrationTeam org:AppSupportTeam ;
    noria:applicationModuleSupportTeam org:AppSupportTeam ;
    noria:applicationModuleHotlineEnabled false .

noria:ApplicationModule_CRMProd a noria:ApplicationModule ;
    rdfs:label "CRM System Production Module"@en ;
    rdfs:comment "Production instance of the CRM System."@en ;
    noria:applicationModuleOf noria:Application_CRMSystem ;
    noria:applicationModuleName "CRM_Prod" ;
    noria:applicationModuleIdentifier "CRM-PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam org:AppSupportTeam ;
    noria:applicationModuleSupportTeam org:ITOpsTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleHotlineEnabled true .

# =============================================================================
# 7. Services
# =============================================================================

noria:Service_CorporateConnectivity a noria:Service ;
    rdfs:label "Corporate Connectivity Service"@en ;
    rdfs:comment "Provides network connectivity across all corporate sites and to the internet."@en ;
    noria:serviceType <kos/service/type/InfrastructureService> ;
    seas:hasSubSystem noria:Application_CorporateInternetAccess, noria:Resource_CoreRouter01, noria:NetworkLink_DC1_DC2_Fiber ;
    noria:elementManagedBy org:NetworkTeam .

noria:Service_EmailAsAService a noria:Service ;
    rdfs:label "Email as a Service"@en ;
    rdfs:comment "End-to-end email service delivery to users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:hasSubSystem noria:Application_CorporateEmail, noria:ApplicationModule_EmailProd_DC1, noria:Resource_WebServer01, noria:Resource_DBServer01 ;
    noria:elementManagedBy org:AppSupportTeam .

# =============================================================================
# 8. Event Records
# =============================================================================

noria:EventRecord_CR01_LinkDown a noria:EventRecord ;
    rdfs:label "CR01 Link Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-03-15T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
