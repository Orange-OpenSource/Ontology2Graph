# =============================================================================
# Operational Procedures and Anomaly Patterns
# =============================================================================

noria:OperationPlan_NetworkTroubleshooting a noria:OperationPlan ;
    rdfs:label "Network Link Down Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network link outages."@en ;
    noria:operationPlanPreCondition noria:PreCond_LinkDownAlert ;
    noria:operationPlanPostCondition noria:PostCond_LinkRestored .

noria:PreCond_LinkDownAlert a noria:ActionPreCondition ;
    rdfs:label "Link Down Alert Received"@en ;
    rdfs:comment "Condition: A critical alert indicating a network interface or link is down."@en .

noria:PostCond_LinkRestored a noria:ActionPostCondition ;
    rdfs:label "Network Link Restored"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up' and traffic flows normally."@en .

noria:OperationPlan_DBPoolAdjustment a noria:OperationPlan ;
    rdfs:label "Database Connection Pool Adjustment"@en ;
    rdfs:comment "Procedure for adjusting database connection pool settings to resolve performance issues."@en ;
    noria:operationPlanPreCondition noria:PreCond_AppDegradation ;
    noria:operationPlanPostCondition noria:PostCond_AppPerformanceRestored .

noria:PreCond_AppDegradation a noria:ActionPreCondition ;
    rdfs:label "Application Performance Degradation"@en ;
    rdfs:comment "Condition: Users report slow application response times, and monitoring shows high DB connection usage."@en .

noria:PostCond_AppPerformanceRestored a noria:ActionPostCondition ;
    rdfs:label "Application Performance Restored"@en ;
    rdfs:comment "Expected outcome: Application response times return to normal, and DB connection usage stabilizes."@en .

noria:AnomalyPattern_HighCPULoop a noria:AnomalyPattern ;
    rdfs:label "Persistent High CPU Loop"@en ;
    rdfs:comment "Anomaly pattern characterized by sustained high CPU usage without corresponding workload, often indicating a software bug or runaway process."@en ;
    folio:hasCause noria:EventRecord_CPU_Spike_AppServer01 .

# Procedure Execution Container for DB Pool Increase
noria:PEC_DBPoolIncrease a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of DB Pool Increase"@en ;
    rdfs:comment "Container for actions taken to increase DB connection pool."@en ;
    pep:hasProcedure noria:OperationPlan_DBPoolAdjustment .

