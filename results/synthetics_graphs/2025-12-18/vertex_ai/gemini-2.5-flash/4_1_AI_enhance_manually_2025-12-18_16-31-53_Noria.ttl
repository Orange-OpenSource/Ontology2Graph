# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizations
org:CorporateITDept a org:Organization ;
    rdfs:label "Corporate IT Department"@en ;
    rdfs:comment "The main IT department responsible for all corporate IT infrastructure and applications."@en ;
    org:hasUnit org:NetworkOperationsUnit, org:CloudOperationsUnit, org:SecurityOperationsUnit, org:ApplicationSupportUnit .

org:NetworkOperationsUnit a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Unit responsible for managing and maintaining the corporate network infrastructure."@en ;
    org:unitOf org:CorporateITDept .

org:CloudOperationsUnit a org:OrganizationalUnit ;
    rdfs:label "Cloud Operations Unit"@en ;
    rdfs:comment "Unit responsible for managing cloud-based infrastructure and services."@en ;
    org:unitOf org:CorporateITDept .

org:SecurityOperationsUnit a org:OrganizationalUnit ;
    rdfs:label "Security Operations Unit"@en ;
    rdfs:comment "Unit responsible for cybersecurity monitoring, incident response, and security policy enforcement."@en ;
    org:unitOf org:CorporateITDept .

org:ApplicationSupportUnit a org:OrganizationalUnit ;
    rdfs:label "Application Support Unit"@en ;
    rdfs:comment "Unit responsible for supporting business applications."@en ;
    org:unitOf org:CorporateITDept .

org:HardwareVendor a org:Organization ;
    rdfs:label "Hardware Solutions Inc."@en ;
    rdfs:comment "A third-party vendor providing server and network hardware."@en .

org:SoftwareVendor a org:Organization ;
    rdfs:label "Software Innovations Corp."@en ;
    rdfs:comment "A third-party vendor providing enterprise software solutions."@en .

# Agents (Teams and Individuals)
foaf:Agent_ITOpsTeam a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "General IT operations team, first line of support."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "For critical issues, call the hotline. For non-critical, open a ticket."@en .

foaf:Agent_NetworkTeam a foaf:Agent ;
    rdfs:label "Network Team"@en ;
    rdfs:comment "Specialized team for network infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Escalate network-related incidents from IT Operations Team."@en ;
    org:memberOf org:NetworkOperationsUnit .

foaf:Agent_CloudOpsTeam a foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Team managing cloud resources and services."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticket-system> ;
    noria:agentInstructions "All cloud-related requests must go through the ticketing system."@en ;
    org:memberOf org:CloudOperationsUnit .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Team handling security incidents and compliance."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> ;
    noria:agentInstructions "Immediate notification for critical security alerts."@en ;
    org:memberOf org:SecurityOperationsUnit .

foaf:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Refer to application-specific runbooks for initial troubleshooting."@en ;
    org:memberOf org:ApplicationSupportUnit .

foaf:Agent_JohnDoe a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Network Engineer, member of the Network Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    org:memberOf org:NetworkOperationsUnit .

foaf:Agent_JaneSmith a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Cloud Architect, member of the Cloud Operations Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    org:memberOf org:CloudOperationsUnit .

foaf:Agent_AliceJohnson a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Security Analyst, member of the Security Operations Team."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    org:memberOf org:SecurityOperationsUnit .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    observable:accountIdentifier "jdoe-corp-id-12345" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    observable:accountIdentifier "jsmith-corp-id-67890" ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

# =============================================================================
# Locations
# =============================================================================

bot:Site_DC1 a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center for corporate infrastructure."@en ;
    noria:siteId "DC-MAIN-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

bot:Site_DRS1 a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary data center for disaster recovery and backup."@en ;
    noria:siteId "DR-SITE-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "456 Backup Boulevard" ;
    noria:sitePrincipalAddressCityName "Safetown" ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in the Main Data Center."@en ;
    bot:hasSpace bot:Site_DC1 .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room in the Main Data Center."@en ;
    bot:hasSpace bot:Site_DC1 .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Location of critical servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5 a noria:Locus ;
    rdfs:label "Rack B5 in Network Room B"@en ;
    rdfs:comment "Location of core network devices."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room_NetworkRoomB .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy org:HardwareVendor .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series."@en ;
    noria:productManufacturedBy org:HardwareVendor .

noria:ProductModel_PaloAltoFW a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5200 Series"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy org:HardwareVendor .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy org:SoftwareVendor .

# =============================================================================
# Resources
# =============================================================================

# Physical Servers
noria:Resource_AppServer01 a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Physical server hosting critical business applications."@en ;
    noria:resourceHostName "appserver01.corp.example.com" ;
    noria:resourceLogisticId "LOG-APP-001" ;
    noria:resourceSerialNumber "SN-APP-001-XYZ" ;
    noria:resourceType <kos/Resource/type/physical-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress observable:IPAddress_AppServer01_Mgmt .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Physical server hosting the main corporate database."@en ;
    noria:resourceHostName "dbserver01.corp.example.com" ;
    noria:resourceLogisticId "LOG-DB-001" ;
    noria:resourceSerialNumber "SN-DB-001-ABC" ;
    noria:resourceType <kos/Resource/type/physical-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress observable:IPAddress_DBServer01_Mgmt .

# Network Devices
noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for internal network routing."@en ;
    noria:resourceHostName "corerouter01.corp.example.com" ;
    noria:resourceLogisticId "LOG-NET-001" ;
    noria:resourceSerialNumber "SN-NET-001-DEF" ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-05-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceManagedBy foaf:Agent_NetworkTeam ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress observable:IPAddress_CoreRouter01_Mgmt .

noria:Resource_Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Primary firewall protecting the corporate network perimeter."@en ;
    noria:resourceHostName "firewall01.corp.example.com" ;
    noria:resourceLogisticId "LOG-SEC-001" ;
    noria:resourceSerialNumber "SN-SEC-001-GHI" ;
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-01T14:00:00Z"^^xsd:dateTime ;
    noria:resourceProductModel noria:ProductModel_PaloAltoFW ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:locatedAtLocus noria:Locus_RackB5 ;
    noria:resourceManagementIPAddress observable:IPAddress_Firewall01_Mgmt .

# Virtual Resources
noria:Resource_WebVM01 a noria:Resource ;
    rdfs:label "Web Application VM 01"@en ;
    rdfs:comment "Virtual machine hosting the main corporate web application."@en ;
    noria:resourceHostName "webvm01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-10T12:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_CloudOpsTeam ;
    noria:virtualServerStatus <kos/Resource/OperationalState/running> ;
    noria:clusterController noria:Resource_Hypervisor01 .

noria:Resource_Hypervisor01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server acting as a hypervisor for virtual machines."@en ;
    noria:resourceHostName "hypervisor01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceManagedBy foaf:Agent_CloudOpsTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 .

# IP Addresses (as observable:IPAddress instances)
observable:IPAddress_AppServer01_Mgmt a observable:IPAddress ;
    rdfs:label "AppServer01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.10" .

observable:IPAddress_DBServer01_Mgmt a observable:IPAddress ;
    rdfs:label "DBServer01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.11" .

observable:IPAddress_CoreRouter01_Mgmt a observable:IPAddress ;
    rdfs:label "CoreRouter01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.1" .

observable:IPAddress_Firewall01_Mgmt a observable:IPAddress ;
    rdfs:label "Firewall01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.2" .

# =============================================================================
# Network Interfaces and Links
# =============================================================================

# Network Interfaces for AppServer01
noria:NI_AppServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "AppServer01 Ethernet 0"@en ;
    noria:networkInterfaceDescription "Primary network interface for application traffic."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:Resource_AppServer01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects noria:NL_AppServer01_CoreRouter01 .

noria:NI_AppServer01_Eth1 a noria:NetworkInterface ;
    rdfs:label "AppServer01 Ethernet 1"@en ;
    noria:networkInterfaceDescription "Secondary network interface for management traffic."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:Resource_AppServer01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects noria:NL_AppServer01_MgmtSwitch .

# Network Interfaces for CoreRouter01
noria:NI_CoreRouter01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/0/0"@en ;
    noria:networkInterfaceDescription "Interface connecting to AppServer01."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:NL_AppServer01_CoreRouter01 .

noria:NI_CoreRouter01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/0/1"@en ;
    noria:networkInterfaceDescription "Interface connecting to Firewall01."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 ;
    noria:networkInterfaceConnects noria:NL_CoreRouter01_Firewall01 .

# Network Interfaces for Firewall01
noria:NI_Firewall01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet 0 (Internal)"@en ;
    noria:networkInterfaceDescription "Internal interface of the firewall."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects noria:NL_CoreRouter01_Firewall01 .

noria:NI_Firewall01_Eth1 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet 1 (External)"@en ;
    noria:networkInterfaceDescription "External interface of the firewall, connected to ISP."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 ;
    noria:networkInterfaceConnects noria:NL_Firewall01_ISP .

# Network Links
noria:NL_AppServer01_CoreRouter01 a noria:NetworkLink ;
    rdfs:label "Link AppServer01 to CoreRouter01"@en ;
    noria:networkLinkId "NL-APP-CORE-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_AppServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ;
    noria:resourceManagedBy foaf:Agent_NetworkTeam .

noria:NL_CoreRouter01_Firewall01 a noria:NetworkLink ;
    rdfs:label "Link CoreRouter01 to Firewall01"@en ;
    noria:networkLinkId "NL-CORE-FW-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-05-20T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01 ;
    noria:resourceManagedBy foaf:Agent_NetworkTeam .

noria:NL_Firewall01_ISP a noria:NetworkLink ;
    rdfs:label "Link Firewall01 to ISP"@en ;
    noria:networkLinkId "NL-FW-ISP-001" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2021-06-01T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Firewall01 ;
    noria:resourceManagedBy foaf:Agent_NetworkTeam .

noria:NL_AppServer01_MgmtSwitch a noria:NetworkLink ;
    rdfs:label "Link AppServer01 to Management Switch"@en ;
    noria:networkLinkId "NL-APP-MGMT-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:45:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_AppServer01 ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam .

# =============================================================================
# Applications and Application Modules
# =============================================================================

noria:Application_WebApp a noria:Application ;
    rdfs:label "Corporate Web Application"@en ;
    rdfs:comment "The main customer-facing web application."@en ;
    noria:applicationModelIdentifier "CWA-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CWA" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Online Sales" ;
    noria:resourceForApplication noria:Resource_WebVM01 .

noria:Application_DBService a noria:Application ;
    rdfs:label "Corporate Database Service"@en ;
    rdfs:comment "Backend database service supporting multiple applications."@en ;
    noria:applicationModelIdentifier "DBS-V1" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "DBS" ;
    noria:applicationType <kos/application/type/backend-service> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Data Management" ;
    noria:applicationFunctionalSubDomain "Transactional Database" ;
    noria:resourceForApplication noria:Resource_DBServer01 .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "IT Monitoring System"@en ;
    rdfs:comment "System for monitoring IT infrastructure and applications."@en ;
    noria:applicationModelIdentifier "MON-V3" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Performance Monitoring" ;
    noria:resourceForApplication noria:Resource_AppServer01 .

