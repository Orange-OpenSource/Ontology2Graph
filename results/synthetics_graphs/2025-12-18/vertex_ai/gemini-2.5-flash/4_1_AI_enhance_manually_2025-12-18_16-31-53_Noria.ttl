    noria:applicationModuleAdministrationLeader foaf:Agent_JaneSmith ;
    noria:applicationModuleSupportTeam org:ApplicationSupportUnit ;
    noria:applicationModuleSupportLeader foaf:Agent_JaneSmith ;
    noria:applicationModuleHotlineGroup foaf:Agent_ITOpsTeam .

noria:AppModule_WebApp_Dev a noria:ApplicationModule ;
    rdfs:label "Corporate Web App - Development"@en ;
