    noria:applicationModuleOf noria:Application_WebApp ;
    noria:applicationModuleName "CWA_DEV" ;
    noria:applicationModuleIdentifier "CWA-DEV-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InDevelopment> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleAdministrationTeam org:ApplicationSupportUnit ;
    noria:applicationModuleAdministrationLeader foaf:Agent_JaneSmith .

# Application Modules for Corporate Database Service
noria:AppModule_DBService_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate DB Service - Production"@en ;
    rdfs:comment "Production instance of the Corporate Database Service."@en ;
    noria:applicationModuleOf noria:Application_DBService ;
    noria:applicationModuleName "DBS_PROD" ;
    noria:applicationModuleIdentifier "DBS-PROD-01" ;
