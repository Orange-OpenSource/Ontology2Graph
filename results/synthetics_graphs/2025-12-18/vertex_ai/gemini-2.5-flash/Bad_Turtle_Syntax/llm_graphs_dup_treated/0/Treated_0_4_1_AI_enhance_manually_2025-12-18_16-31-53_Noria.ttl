observable:IPAddress_DBServer01_Mgmt_extra_node_1 a observable:IPAddress ;
    rdfs:label "DBServer01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.11" .

observable:IPAddress_CoreRouter01_Mgmt_extra_node_1 a observable:IPAddress ;
