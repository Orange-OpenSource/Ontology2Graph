# Network Interfaces for AppServer01
noria:NI_AppServer01_Eth0_extra_node_1 a noria:NetworkInterface ;
    rdfs:label "AppServer01 Ethernet 0"@en ;
    noria:networkInterfaceDescription "Primary network interface for application traffic."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:Resource_AppServer01_extra_node_1 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_1> ;
