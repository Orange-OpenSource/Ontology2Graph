# Network Interfaces for Firewall01
noria:NI_Firewall01_Eth0_extra_node_1 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet 0 (Internal_extra_node_1)"@en ;
    noria:networkInterfaceDescription "Internal_extra_node_1 interface of the firewall_extra_node_1."@en ;
