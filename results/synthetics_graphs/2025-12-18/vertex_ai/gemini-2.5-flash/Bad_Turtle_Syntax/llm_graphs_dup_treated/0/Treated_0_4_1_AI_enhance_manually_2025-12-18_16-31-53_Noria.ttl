noria:NI_Firewall01_Eth1_extra_node_1 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet 1 (External)"@en ;
    noria:networkInterfaceDescription "External interface of the firewall_extra_node_1, connected to ISP."@en ;
    noria:networkInterfaceType "physical" ;
