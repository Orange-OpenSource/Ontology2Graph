    noria:resourceSerialNumber "SN-APP-001-XYZ" ;
    noria:resourceType <kos/Resource/type/physical-server_extra_node_1> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_1> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_1 ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam_extra_node_1 ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_1 ;
