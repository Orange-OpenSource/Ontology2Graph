# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_CheckFiberLink_extra_node_0 a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Standard_extra_node_0 operating procedure for diagnosing fiber optic link issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FiberLinkDown_extra_node_0 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FiberLinkRestored_extra_node_0 .

noria:OperationPlan_NICReplacement_extra_node_0 a noria:OperationPlan ;
    rdfs:label "Network Interface Card Replacement Procedure"@en ;
    rdfs:comment "Detailed steps for replacing a network interface card on a Core Router_extra_node_0."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FaultyNICIdentified_extra_node_0 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_NICReplacedAndOperational_extra_node_0 .

noria:ActionPreCondition_FiberLinkDown_extra_node_0 a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'down' and administrative status is 'up_extra_node_0'."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Down> AND noria:networkInterfaceAdministrativeStatus = <kos/Resource/AdministrativeState/Up_extra_node_0>" .

noria:ActionPreCondition_FaultyNICIdentified_extra_node_0 a noria:ActionPreCondition ;
    rdfs:label "Faulty NIC Identified Pre-Condition"@en ;
    rdfs:comment "Condition: Diagnostics confirm a hardware fault with the network interface card."@en ;
    skos:example "Trouble ticket diagnosis points to NIC hardware failure." .

noria:ActionPostCondition_FiberLinkRestored_extra_node_0 a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored Post-Condition"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up_extra_node_0' and traffic flows normally."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Up_extra_node_0> AND traffic metrics are nominal." .

noria:ActionPostCondition_NICReplacedAndOperational_extra_node_0 a noria:ActionPostCondition ;
    rdfs:label "NIC Replaced and Operational Post-Condition"@en ;
    rdfs:comment "Expected outcome: New NIC is installed, configured, and the interface is operational."@en ;
    skos:example "New NIC detected, interface configured, noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Up_extra_node_0>." .

noria:AnomalyPattern_NetworkInterfaceFlap a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Pattern"@en ;
    rdfs:comment "Pattern indicating an interface repeatedly goes up_extra_node_0 and down within a short period, suggesting instability."@en ;
    folio:hasCause "Unstable physical connection or faulty hardware."@en .

noria:AnomalyPattern_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Pattern"@en ;
    rdfs:comment "Pattern indicating CPU utilization consistently above a threshold for an extended duration."@en ;
    folio:hasCause "Application bug, resource exhaustion, or denial-of-service attack."@en .

