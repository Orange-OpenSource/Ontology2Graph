noria:AnomalyPattern_HighCPU_LowTraffic_extra_node_0 a noria:AnomalyPattern ;
    rdfs:label "High CPU with Low Traffic Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential resource exhaustion or process loop where CPU is high_extra_node_0 but network traffic is low, suggesting an internal issue rather than external load."@en ;
    folio:hasCause noria:NotifProbCause_SoftwareError_extra_node_0 .

noria:AnomalyPattern_InterfaceFlap_extra_node_0 a noria:AnomalyPattern ;
    rdfs:label "Repeated Interface Flap Anomaly"@en ;
    rdfs:comment "Pattern indicating an unstable network link where an interface repeatedly goes up_extra_node_0 and down in a short period, often due to physical layer issues or faulty transceivers."@en ;
    folio:hasCause noria:NotifProbCause_HardwareFailure_extra_node_0, noria:NotifProbCause_NetworkIssue_extra_node_0 .

