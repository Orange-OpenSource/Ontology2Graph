# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizations
noria:Org_ITOperations_extra_node_0 a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Central department responsible for managing IT infrastructure_extra_node_0 and services."@en ;
    org:hasUnit noria:OrgUnit_NetworkTeam_extra_node_0, noria:OrgUnit_ServerTeam_extra_node_0, noria:OrgUnit_AppSupport_extra_node_0 .

noria:Org_NetworkVendor_extra_node_0 a org:Organization ;
    rdfs:label "GlobalNet Solutions Inc."@en ;
    rdfs:comment "Third-party vendor providing network equipment and support."@en .

noria:Org_SoftwareDev_extra_node_0 a org:Organization ;
    rdfs:label "Innovate Software Corp."@en ;
    rdfs:comment "Internal_extra_node_0 software development department."@en .

# Organizational Units (Teams)
noria:OrgUnit_NetworkTeam_extra_node_0 a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure_extra_node_0 management."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Phone_extra_node_0 ;
    noria:agentInstructions "For critical_extra_node_0 issues, call the hotline immediately. For non-critical_extra_node_0, open a ticket."@en ;
    org:unitOf noria:Org_ITOperations_extra_node_0 .

noria:OrgUnit_ServerTeam_extra_node_0 a org:OrganizationalUnit ;
    rdfs:label "Server_extra_node_0 Administration Team"@en ;
    rdfs:comment "Team managing physical and virtual server infrastructure_extra_node_0."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Email_extra_node_0 ;
    noria:agentInstructions "Email_extra_node_0 for routine requests, use ticketing system for incidents."@en ;
    org:unitOf noria:Org_ITOperations_extra_node_0 .

noria:OrgUnit_AppSupport_extra_node_0 a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support for business_extra_node_0 applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Chat_extra_node_0 ;
    noria:agentInstructions "Consult knowledge base before contacting. Use chat for quick queries."@en ;
    org:unitOf noria:Org_ITOperations_extra_node_0 .

noria:OrgUnit_SecurityOps_extra_node_0 a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Phone_extra_node_0 ;
    noria:agentInstructions "Immediate escalation for critical_extra_node_0 security alerts."@en ;
    org:unitOf noria:Org_ITOperations_extra_node_0 .

