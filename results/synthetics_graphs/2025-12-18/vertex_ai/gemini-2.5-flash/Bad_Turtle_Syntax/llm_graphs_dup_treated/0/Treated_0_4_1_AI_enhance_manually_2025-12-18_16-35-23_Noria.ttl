    rdfs:comment "Location for critical_extra_node_0 application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSubSpace noria:Room_ServerRoomA_extra_node_0 .

noria:Locus_RackA2_extra_node_0 a noria:Locus ;
    rdfs:label "Rack A2 in Server_extra_node_0 Room A"@en ;
