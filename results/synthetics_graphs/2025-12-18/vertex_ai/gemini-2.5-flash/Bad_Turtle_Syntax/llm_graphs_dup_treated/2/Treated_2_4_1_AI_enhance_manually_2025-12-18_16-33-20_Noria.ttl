# =============================================================================
# Organizational Entities (foaf:Agent, org:Organization, org:OrganizationalUnit)
# =============================================================================

foaf:Agent_NetOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for monitoring and maintaining network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use emergency hotline after hours."@en .

foaf:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the Online Banking application."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

foaf:Agent_DBATeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for managing and optimizing database systems."@en ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

foaf:Agent_HardwareTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Hardware Maintenance Team"@en ;
    rdfs:comment "Team responsible for physical hardware installation and repair."@en ;
    noria:agentWorkingHours "On-call 24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cyber Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 Monitoring"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

foaf:Person_AliceSmith a foaf:Agent, foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone <tel:+1-555-123-4567> ;
    org:memberOf foaf:Agent_NetOpsTeam .

foaf:Person_BobJohnson a foaf:Agent, foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Database Administrator."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf foaf:Agent_DBATeam .

foaf:Person_CharlieBrown a foaf:Agent, foaf:Person ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Application Developer."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    org:memberOf foaf:Agent_AppDevTeam .

noria:CUid_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Login identifier for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount foaf:Person_AliceSmith .

noria:CUid_BJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Login identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount foaf:Person_BobJohnson .

# =============================================================================
# Location Entities (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

bot:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary data center for disaster recovery purposes."@en ;
    noria:siteId "DR01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Road" ;
    noria:sitePrincipalAddressCityName "Gotham" ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Dedicated room for network equipment in Main Data Center."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Locus_RackA1_U10 a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "10" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5_U2 a noria:Locus ;
    rdfs:label "Rack B5, Unit 2"@en ;
    rdfs:comment "Specific location for a router in Network Room B."@en ;
    noria:locusLine "B5" ;
    noria:locusRow "2" ;
    bot:hasSpace noria:Room_NetworkRoomB .

