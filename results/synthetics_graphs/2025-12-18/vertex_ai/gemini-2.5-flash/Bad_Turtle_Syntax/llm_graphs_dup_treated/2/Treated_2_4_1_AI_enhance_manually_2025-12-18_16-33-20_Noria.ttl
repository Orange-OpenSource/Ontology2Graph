    noria:operationPlanPreCondition noria:ActionPreCondition_FaultyNICIdentified ;
    noria:operationPlanPostCondition noria:ActionPostCondition_NICReplacedAndOperational .

noria:ActionPreCondition_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'down' and administrative status is 'up'."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Down> AND noria:networkInterfaceAdministrativeStatus = <kos/Resource/AdministrativeState/Up>" .

noria:ActionPreCondition_FaultyNICIdentified a noria:ActionPreCondition ;
    rdfs:label "Faulty NIC Identified Pre-Condition"@en ;
    rdfs:comment "Condition: Diagnostics confirm a hardware fault with the network interface card."@en ;
    skos:example "Trouble ticket diagnosis points to NIC hardware failure." .

noria:ActionPostCondition_FiberLinkRestored a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored Post-Condition"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up' and traffic flows normally."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Up> AND traffic metrics are nominal." .

noria:ActionPostCondition_NICReplacedAndOperational a noria:ActionPostCondition ;
    rdfs:label "NIC Replaced and Operational Post-Condition"@en ;
    rdfs:comment "Expected outcome: New NIC is installed, configured, and the interface is operational."@en ;
    skos:example "New NIC detected, interface configured, noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Up>." .

noria:AnomalyPattern_NetworkInterfaceFlap a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Pattern"@en ;
    rdfs:comment "Pattern indicating an interface repeatedly goes up and down within a short period, suggesting instability."@en ;
    folio:hasCause "Unstable physical connection or faulty hardware."@en .

noria:AnomalyPattern_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Pattern"@en ;
    rdfs:comment "Pattern indicating CPU utilization consistently above a threshold for an extended duration."@en ;
    folio:hasCause "Application bug, resource exhaustion, or denial-of-service attack."@en .

# =============================================================================
# Document Attachments (noria:DocumentAttachment)
# =============================================================================

noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for DC01"@en ;
    rdfs:comment "PDF document showing the logical and physical network topology of Main Data Center."@en ;
    dcterms:isPartOf noria:TroubleTicket_NetOutage001 ;
    dcterms:format "application/pdf" ;
    dcterms:title "DC01_Network_Topology_v2.3.pdf" .

noria:DocumentAttachment_DiagnosticLogs a noria:DocumentAttachment ;
    rdfs:label "Diagnostic Logs for CR01"@en ;
    rdfs:comment "Text file containing output from diagnostic commands run on Core Router 01."@en ;
    dcterms:isPartOf noria:TroubleTicket_NetOutage001 ;
    dcterms:format "text/plain" ;
    dcterms:title "cr01_diag_20240420.log" .

noria:DocumentAttachment_ChangePlan a noria:DocumentAttachment ;
    rdfs:label "NIC Replacement Change Plan"@en ;
    rdfs:comment "Detailed plan for the network interface card replacement, including rollback procedures."@en ;
    dcterms:isPartOf noria:ChangeRequest_NICReplacement001 ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:title "CR001_NIC_Replacement_Plan_v1.0.docx" .

