noria:TroubleTicket_001 a noria:TroubleTicket ;
    rdfs:label "Critical Network Outage - Core Router 01"@en ;
    rdfs:comment "Incident reported due to core router interface failure, impacting corporate internet access."@en ;
    dcterms:identifier "TT-2024-04-20-001" ;
    dcterms:created "2024-04-20T09:35:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity noria:TTSeverity_Critical ;
    noria:troubleTicketType noria:TTType_Failure ;
    noria:troubleTicketCriticity noria:TTCriticity_InterruptedService ;
    noria:troubleTicketPriority noria:TTPriority_P1 ;
    noria:troubleTicketOrigin noria:TTOrigin_Supervision ;
    noria:troubleTicketTrigger noria:EventRecord_RouterDown ;
    noria:troubleTicketUrgency noria:TTUrgency_Immediate ;
    noria:troubleTicketSupervisionTool "NMS-PRO-V3" ;
    noria:troubleTicketCategory noria:TTCriticity_InterruptedService ;
    noria:problemCategory noria:TTCriticity_InterruptedService ;
    noria:troubleTicketCause "Physical interface failure on Core Router 01."@en ;
    noria:problemResponsibility noria:TTProblemResp_ManagedNetwork ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent noria:CRStatus_Implemented ; # Using CRStatus for TTStatus as per schema, assuming it's a generic status.
    noria:troubleTicketRelatedParty noria:OrgUnit_NetworkTeam, foaf:Agent_Alice ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRtr01 ;
    noria:troubleTicketImpacts noria:Application_CorporatePortal, noria:Service_InternetAccess ;
    noria:documentHRef <https://ticketing.example.com/TT-2024-04-20-001> .

noria:TroubleTicket_002 a noria:TroubleTicket ;
    rdfs:label "Web Portal Performance Degradation"@en ;
