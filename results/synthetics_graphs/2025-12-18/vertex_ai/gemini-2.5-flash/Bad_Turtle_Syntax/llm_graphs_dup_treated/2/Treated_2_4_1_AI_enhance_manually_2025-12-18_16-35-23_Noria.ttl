noria:OperationPlan_RouterRestart a noria:OperationPlan ;
    rdfs:label "Standard Router Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting a network router."@en ;
    noria:operationPlanPreCondition noria:PreCond_NetworkImpactAssessment ;
    noria:operationPlanPostCondition noria:PostCond_NetworkConnectivityRestored .

noria:OperationPlan_AppModuleDeploy a noria:OperationPlan ;
    rdfs:label "Application Module Deployment Procedure"@en ;
    rdfs:comment "Standard procedure for deploying new application modules."@en ;
    noria:operationPlanPreCondition noria:PreCond_CodeReviewApproved ;
    noria:operationPlanPostCondition noria:PostCond_AppModuleOperational .

noria:ActionPreCond_NetworkImpactAssessment a noria:ActionPreCondition ;
    rdfs:label "Network Impact Assessment Completed"@en ;
    rdfs:comment "Verify that a network impact assessment has been performed and approved."@en .

noria:ActionPreCond_CodeReviewApproved a noria:ActionPreCondition ;
    rdfs:label "Code Review Approved"@en ;
    rdfs:comment "Ensure that the code for the new module has passed review."@en .

noria:ActionPostCond_NetworkConnectivityRestored a noria:ActionPostCondition ;
    rdfs:label "Network Connectivity Restored"@en ;
    rdfs:comment "Confirm that network connectivity is fully restored after the operation."@en ;
    skos:example "Ping tests successful, BGP sessions re-established."@en .

noria:ActionPostCond_AppModuleOperational a noria:ActionPostCondition ;
    rdfs:label "Application Module Operational"@en ;
    rdfs:comment "Verify that the deployed application module is fully operational and accessible."@en ;
    skos:example "Health checks passed, user login successful."@en .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_RouterDown a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRtr01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity noria:NotifSeverity_Critical ;
    dcterms:type noria:NotifEventType_StateChange ;
    noria:alarmProposedRepairAction noria:OperationPlan_RouterRestart .

noria:EventRecord_ServerHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CPU utilization on web-srv-01 exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity noria:NotifSeverity_Major ;
    dcterms:type noria:NotifEventType_ThresholdExceeded ;
    noria:alarmMonitoredAttribute "CPU_Usage" .

noria:EventRecord_UnauthorizedLogin a noria:EventRecord ;
    rdfs:label "Unauthorized Login Attempt Alert"@en ;
    rdfs:comment "Security alert for an unauthorized login attempt on a critical server."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_SecurityInfoSystem ;
    noria:logOriginatingAgent foaf:Agent_Dave ; # Dave might be the one who detected it or is investigating
    noria:logText "Failed login attempt for user 'root' from IP 1.2.3.4 on db-srv-01."@en ;
    noria:alarmSeverity noria:NotifSeverity_Critical ;
    dcterms:type noria:NotifEventType_SecurityAlert ;
    noria:alarmProposedRepairAction noria:OperationPlan_RouterRestart . # Placeholder, should be a security response plan.

noria:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change applied to Firewall 01."@en ;
    noria:loggingTime "2024-04-19T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingAgent foaf:Agent_Alice ;
    noria:logText "Configuration updated by Alice Smith: added new NAT rule."@en ;
    noria:alarmSeverity noria:NotifSeverity_Informational ;
    dcterms:type noria:NotifEventType_ConfigurationChange .

