# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizations
noria:Org_ITOperations a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Central department responsible for managing IT infrastructure and services."@en ;
    org:hasUnit noria:OrgUnit_NetworkTeam, noria:OrgUnit_ServerTeam, noria:OrgUnit_AppSupport .

noria:Org_NetworkVendor a org:Organization ;
    rdfs:label "GlobalNet Solutions Inc."@en ;
    rdfs:comment "Third-party vendor providing network equipment and support."@en .

noria:Org_SoftwareDev a org:Organization ;
    rdfs:label "Innovate Software Corp."@en ;
    rdfs:comment "Internal software development department."@en .

# Organizational Units (Teams)
noria:OrgUnit_NetworkTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Phone ;
    noria:agentInstructions "For critical issues, call the hotline immediately. For non-critical, open a ticket."@en ;
    org:unitOf noria:Org_ITOperations .

noria:OrgUnit_ServerTeam a org:OrganizationalUnit ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team managing physical and virtual server infrastructure."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Email ;
    noria:agentInstructions "Email for routine requests, use ticketing system for incidents."@en ;
    org:unitOf noria:Org_ITOperations .

noria:OrgUnit_AppSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support for business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Chat ;
    noria:agentInstructions "Consult knowledge base before contacting. Use chat for quick queries."@en ;
    org:unitOf noria:Org_ITOperations .

noria:OrgUnit_SecurityOps a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Phone ;
    noria:agentInstructions "Immediate escalation for critical security alerts."@en ;
    org:unitOf noria:Org_ITOperations .

# Individual Agents (foaf:Agent)
foaf:Agent_Alice a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, member of Network Operations Team."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    org:memberOf noria:OrgUnit_NetworkTeam .

