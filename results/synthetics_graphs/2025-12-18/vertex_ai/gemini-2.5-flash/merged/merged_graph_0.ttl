    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_DRC a bot:Site ;
    rdfs:label "Disaster Recovery Center Lyon"@en ;
    rdfs:comment "Secondary data center for disaster recovery."@en ;
    noria:siteId "DRC-LYO-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
