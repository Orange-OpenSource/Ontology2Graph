# Rooms
noria:Room_ServerRoomA_extra_node_2 a noria:Room ;
    rdfs:label "Server Room A - DC1"@en ;
    rdfs:comment "Main server room in Data Center Paris."@en ;
    bot:hasSpace noria:Locus_RackA1_extra_node_2, noria:Locus_RackA2_extra_node_2 ;
    bot:hasElement noria:Resource_WebSrv01_extra_node_2, noria:Resource_DBSrv01_extra_node_2 ;
    bot:hasSubSpace noria:Site_DC1_extra_node_2 . # Assuming bot:hasSubSpace can link a room to a site.

noria:Room_NetworkRoomB_extra_node_2 a noria:Room ;
    rdfs:label "Network Room B - DC1"@en ;
    rdfs:comment "Room dedicated to network equipment in Data Center Paris."@en ;
    bot:hasSpace noria:Locus_RackB1_extra_node_2 ;
    bot:hasElement noria:Resource_CoreRtr01_extra_node_2, noria:Resource_EdgeSw01_extra_node_2 ;
    bot:hasSubSpace noria:Site_DC1_extra_node_2 .

