    noria:troubleTicketRelatedResource noria:Resource_AppServer01_extra_node_1 ;
    noria:troubleTicketImpacts noria:Application_WebApp_extra_node_1 .

noria:TTNote_TT004_1_extra_node_1 a noria:TroubleTicketNote ;
    rdfs:label "Malware Analysis for TT004"@en ;
    rdfs:comment "Full system scan initiated. User account temporarily locked."@en ;
    dcterms:created "2024-04-20T11:15:00Z"^^xsd:dateTime ;
