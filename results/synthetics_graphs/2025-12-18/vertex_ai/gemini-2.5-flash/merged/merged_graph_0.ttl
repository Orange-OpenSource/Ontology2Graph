noria:EventRecord_RouterDown_extra_node_2 a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRtr01_extra_node_2 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_2 ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity noria:NotifSeverity_Critical_extra_node_2 ;
    dcterms:type noria:NotifEventType_StateChange_extra_node_2 ;
    noria:alarmProposedRepairAction noria:OperationPlan_RouterRestart_extra_node_2 .

noria:EventRecord_ServerHighCPU_extra_node_2 a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01_extra_node_2 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_2 ;
    noria:logText "CPU utilization on web-srv-01 exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity noria:NotifSeverity_Major_extra_node_2 ;
    dcterms:type noria:NotifEventType_ThresholdExceeded_extra_node_2 ;
    noria:alarmMonitoredAttribute "CPU_Usage" .

noria:EventRecord_UnauthorizedLogin_extra_node_2 a noria:EventRecord ;
    rdfs:label "Unauthorized Login Attempt Alert"@en ;
    rdfs:comment "Security alert for an unauthorized login attempt on a critical server."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBSrv01_extra_node_2 ;
    noria:logOriginatingManagementSystem noria:Application_SecurityInfoSystem_extra_node_2 ;
    noria:logOriginatingAgent foaf:Agent_Dave_extra_node_2 ; # Dave might be the one who detected it or is investigating
    noria:logText "Failed login attempt for user 'root' from IP 1.2.3.4 on db-srv-01."@en ;
    noria:alarmSeverity noria:NotifSeverity_Critical_extra_node_2 ;
    dcterms:type noria:NotifEventType_SecurityAlert_extra_node_2 ;
    noria:alarmProposedRepairAction noria:OperationPlan_RouterRestart_extra_node_2 . # Placeholder, should be a security response plan.

noria:EventRecord_ConfigChange_extra_node_2 a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change applied to Firewall 01."@en ;
    noria:loggingTime "2024-04-19T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01_extra_node_2 ;
    noria:logOriginatingAgent foaf:Agent_Alice_extra_node_2 ;
    noria:logText "Configuration updated by Alice Smith: added new NAT rule."@en ;
