    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention_extra_node_1> ;
    noria:troubleTicketSupervisionTool "Antivirus Console" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/MalwareInfection_extra_node_1> ;
    noria:troubleTicketCause "User downloaded malicious file."@en ;
