# Add a new event record for a security alert
noria:EventRecord_MalwareDetected_extra_node_1 a noria:EventRecord ;
    rdfs:label "Malware Detected on AppServer01"@en ;
    rdfs:comment "Antivirus detected a malware signature on AppServer01."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Malware 'Trojan.Generic' detected in C:\\temp\\malicious.exe. Quarantined."@en ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01_extra_node_1 ;
