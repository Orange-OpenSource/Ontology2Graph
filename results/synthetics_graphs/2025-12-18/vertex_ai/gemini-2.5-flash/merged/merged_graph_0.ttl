    foaf:mbox <mailto:bob.johnson@example.com_extra_node_2> ;
    org:memberOf noria:OrgUnit_ServerTeam_extra_node_2 .

foaf:Agent_Charlie_extra_node_2 a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    foaf:mbox <mailto:charlie.brown@example.com_extra_node_2> ;
    org:memberOf noria:OrgUnit_AppSupport_extra_node_2 .

foaf:Agent_Dave_extra_node_2 a foaf:Person, foaf:Agent ;
    rdfs:label "Dave Davis"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:dave.davis@example.com_extra_node_2> ;
    org:memberOf noria:OrgUnit_SecurityOps_extra_node_2 .

