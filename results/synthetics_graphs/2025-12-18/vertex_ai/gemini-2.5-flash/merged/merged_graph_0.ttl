noria:OperationPlan_NetworkTroubleshooting_extra_node_1 a noria:OperationPlan ;
    rdfs:label "Network Link Down Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network link outages."@en ;
    noria:operationPlanPreCondition noria:PreCond_LinkDownAlert_extra_node_1 ;
    noria:operationPlanPostCondition noria:PostCond_LinkRestored_extra_node_1 .

noria:PreCond_LinkDownAlert_extra_node_1 a noria:ActionPreCondition ;
    rdfs:label "Link Down Alert Received"@en ;
    rdfs:comment "Condition: A critical alert indicating a network interface or link is down."@en .

noria:PostCond_LinkRestored_extra_node_1 a noria:ActionPostCondition ;
    rdfs:label "Network Link Restored"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up_extra_node_1' and traffic flows normally."@en .

noria:OperationPlan_DBPoolAdjustment_extra_node_1 a noria:OperationPlan ;
    rdfs:label "Database Connection Pool Adjustment"@en ;
    rdfs:comment "Procedure for adjusting database connection pool settings to resolve performance issues."@en ;
    noria:operationPlanPreCondition noria:PreCond_AppDegradation_extra_node_1 ;
    noria:operationPlanPostCondition noria:PostCond_AppPerformanceRestored_extra_node_1 .

noria:PreCond_AppDegradation_extra_node_1 a noria:ActionPreCondition ;
    rdfs:label "Application Performance Degradation"@en ;
    rdfs:comment "Condition: Users report slow application response times, and monitoring shows high_extra_node_1 DB connection usage."@en .

noria:PostCond_AppPerformanceRestored_extra_node_1 a noria:ActionPostCondition ;
    rdfs:label "Application Performance Restored"@en ;
    rdfs:comment "Expected outcome: Application response times return to normal, and DB connection usage stabilizes."@en .

noria:AnomalyPattern_HighCPULoop_extra_node_1 a noria:AnomalyPattern ;
    rdfs:label "Persistent High CPU Loop"@en ;
    rdfs:comment "Anomaly pattern characterized by sustained high_extra_node_1 CPU usage without corresponding workload, often indicating a software bug or runaway process."@en ;
    folio:hasCause noria:EventRecord_CPU_Spike_AppServer01_extra_node_1 .

