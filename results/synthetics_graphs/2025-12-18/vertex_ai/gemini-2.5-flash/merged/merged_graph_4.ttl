# Location Entities (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

bot:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary data center for disaster recovery purposes."@en ;
    noria:siteId "DR01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Road" ;
    noria:sitePrincipalAddressCityName "Gotham" ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Dedicated room for network equipment in Main Data Center."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Locus_RackA1_U10 a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "10" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5_U2 a noria:Locus ;
    rdfs:label "Rack B5, Unit 2"@en ;
    rdfs:comment "Specific location for a router in Network Room B."@en ;
    noria:locusLine "B5" ;
    noria:locusRow "2" ;
    bot:hasSpace noria:Room_NetworkRoomB .

