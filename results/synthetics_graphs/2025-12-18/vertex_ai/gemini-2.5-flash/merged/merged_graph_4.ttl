# Event Records
# =============================================================================

noria:EventRecord_CPU_Spike_AppServer01 a noria:EventRecord ;
    rdfs:label "CPU Spike on AppServer01"@en ;
    rdfs:comment "High CPU utilization detected on AppServer01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on appserver01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_NI_Down_CoreRouter01 a noria:EventRecord ;
    rdfs:label "Network Interface Down on CoreRouter01"@en ;
    rdfs:comment "GigabitEthernet 0/0/0 on CoreRouter01 went down."@en ;
    noria:loggingTime "2024-04-20T10:10:15Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_Login_Failure_WebVM01 a noria:EventRecord ;
    rdfs:label "Repeated Login Failures on WebVM01"@en ;
    rdfs:comment "Multiple failed login attempts detected on WebVM01."@en ;
    noria:loggingTime "2024-04-20T10:20:30Z"^^xsd:dateTime ;
    noria:logText "Authentication failure for user 'admin' from IP 192.168.1.100 (5 attempts)."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebVM01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent foaf:Agent_AliceJohnson . # Security team might be involved in detecting this.

noria:EventRecord_AppError_WebApp_Prod a noria:EventRecord ;
    rdfs:label "Application Error on WebApp Production"@en ;
    rdfs:comment "Critical error detected in the Corporate Web Application production module."@en ;
    noria:loggingTime "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    noria:logText "Unhandled exception in 'OrderProcessing' module. User impact detected."@en ;
    noria:logOriginatingManagedObject noria:AppModule_WebApp_Prod ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_ConfigChange_CoreRouter01 a noria:EventRecord ;
    rdfs:label "Configuration Change on CoreRouter01"@en ;
    rdfs:comment "Configuration change applied to CoreRouter01 by John Doe."@en ;
    noria:loggingTime "2024-04-19T15:00:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jdoe (10.0.0.1)."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

