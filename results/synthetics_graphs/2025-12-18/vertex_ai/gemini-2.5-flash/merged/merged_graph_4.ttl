# =============================================================================
# Anomaly Patterns
# =============================================================================

noria:AnomalyPattern_HighCPU_LowTraffic a noria:AnomalyPattern ;
    rdfs:label "High CPU with Low Traffic Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential resource exhaustion or process loop where CPU is high but network traffic is low, suggesting an internal issue rather than external load."@en ;
    folio:hasCause noria:NotifProbCause_SoftwareError .

noria:AnomalyPattern_InterfaceFlap a noria:AnomalyPattern ;
    rdfs:label "Repeated Interface Flap Anomaly"@en ;
    rdfs:comment "Pattern indicating an unstable network link where an interface repeatedly goes up and down in a short period, often due to physical layer issues or faulty transceivers."@en ;
    folio:hasCause noria:NotifProbCause_HardwareFailure, noria:NotifProbCause_NetworkIssue .

# =============================================================================
# Additional Connections for Density
# =============================================================================

# Link resources to applications they support
noria:Resource_WebSrv01 noria:resourceForApplication noria:Application_CorporatePortal .
noria:Resource_DBSrv01 noria:resourceForApplication noria:Application_CorporatePortal .
noria:Resource_VMSrv01 noria:resourceForApplication noria:Application_MonitoringSystem, noria:Application_SecurityInfoSystem .
noria:Resource_CoreRtr01 noria:resourceForApplication noria:Application_MonitoringSystem .
noria:Resource_EdgeSw01 noria:resourceForApplication noria:Application_MonitoringSystem .
noria:Resource_Firewall01 noria:resourceForApplication noria:Application_SecurityInfoSystem .

# Link applications to resources they use (inverse of resourceForApplication, but not explicitly defined as inverse)
noria:Application_CorporatePortal seas:subSystem noria:Resource_WebSrv01, noria:Resource_DBSrv01 .
noria:Application_MonitoringSystem seas:subSystem noria:Resource_VMSrv01, noria:Resource_CoreRtr01, noria:Resource_EdgeSw01 .
noria:Application_SecurityInfoSystem seas:subSystem noria:Resource_VMSrv01, noria:Resource_Firewall01 .

# Link trouble tickets to document history
noria:TroubleTicket_001 noria:documentStatusHistory noria:EventRecord_RouterDown .
noria:TroubleTicket_002 noria:documentStatusHistory noria:EventRecord_ServerHighCPU .

# Link change requests to document history
noria:ChangeRequest_001 noria:documentStatusHistory noria:EventRecord_ConfigChange .

# Link agents to resources they manage (inverse of resourceManagedBy)
noria:OrgUnit_NetworkTeam noria:agentManagesResource noria:Resource_CoreRtr01, noria:Resource_EdgeSw01, noria:NL_WebSrv01_EdgeSw01, noria:NL_DBSrv01_EdgeSw01, noria:NL_EdgeSw01_CoreRtr01, noria:NL_CoreRtr01_ISP .
noria:OrgUnit_ServerTeam noria:agentManagesResource noria:Resource_WebSrv01, noria:Resource_DBSrv01, noria:Resource_VMSrv01 .
noria:OrgUnit_SecurityOps noria:agentManagesResource noria:Resource_Firewall01, noria:NL_Firewall01_Internal, noria:NL_Firewall01_External .
noria:OrgUnit_AppSupport noria:agentManagesResource noria:AppMod_CorporatePortal_Prod .

# Example of virtual server status
noria:Resource_VMSrv01 noria:virtualServerStatus noria:ResOpState_Up .

# Example of laser optical power for a network interface (assuming it's an optical interface)
noria:NI_CoreRtr01_WAN noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -4 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Example of troubleTicketFreezeItem (using an EventRecord for simplicity, as per skos:example)
noria:TroubleTicket_001 noria:troubleTicketFreezeItem noria:EventRecord_RouterDown . # This is a simplification, typically it would be a specific event indicating freeze.

# Example of troubleTicketCharacteristic (not a defined class, so using a literal for now)
noria:TroubleTicket_001 noria:troubleTicketCharacteristic "Requires on-site intervention" .

# Example of troubleTicketPartyIntervention (not a defined class, so using a literal for now)
noria:TroubleTicket_001 noria:troubleTicketPartyIntervention "Network Team L2 -> Network Team L3" .

# Example of changeRequestLastUpdate
noria:ChangeRequest_001 dcterms:modified "2024-04-20T16:30:00Z"^^xsd:dateTime .

# Example of changeRequestActualStartTime/EndTime
noria:ChangeRequest_001 noria:changeRequestActualStartTime "2024-04-25T22:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-25T22:45:00Z"^^xsd:dateTime .

# Example of alarmMitigatedBy
noria:EventRecord_RouterDown noria:alarmMitigatedBy noria:TroubleTicket_001 . # The TT itself acts as a ProcedureExecutionContainer.

# Example of troubleTicketNoteCorrelatedExecution
noria:TroubleTicketNote_001_2 noria:troubleTicketNoteCorrelatedExecution noria:TroubleTicket_001 . # The note is part of the TT's execution context.


