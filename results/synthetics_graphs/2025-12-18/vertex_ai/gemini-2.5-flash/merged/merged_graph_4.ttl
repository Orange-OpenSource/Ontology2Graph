    noria:troubleTicketRelatedParty noria:OrgUnit_NetworkTeam, foaf:Agent_Alice ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_CoreRtr01 ;
    noria:troubleTicketImpacts noria:Application_CorporatePortal, noria:Service_InternetAccess ;
    noria:documentHRef <https://ticketing.example.com/TT-2024-04-20-001> .

