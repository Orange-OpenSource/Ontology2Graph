    noria:troubleTicketSeverity noria:TTSeverity_Critical ;
    noria:troubleTicketType noria:TTType_Failure ;
    noria:troubleTicketCriticity noria:TTCriticity_InterruptedService ;
    noria:troubleTicketPriority noria:TTPriority_P1 ;
    noria:troubleTicketOrigin noria:TTOrigin_Supervision ;
