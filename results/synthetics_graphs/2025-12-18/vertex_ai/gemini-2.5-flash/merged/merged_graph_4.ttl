# Organizations
noria:Org_ITOperations a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Central department responsible for managing IT infrastructure and services."@en ;
    org:hasUnit noria:OrgUnit_NetworkTeam, noria:OrgUnit_ServerTeam, noria:OrgUnit_AppSupport .

noria:Org_NetworkVendor a org:Organization ;
    rdfs:label "GlobalNet Solutions Inc."@en ;
    rdfs:comment "Third-party vendor providing network equipment and support."@en .

noria:Org_SoftwareDev a org:Organization ;
    rdfs:label "Innovate Software Corp."@en ;
    rdfs:comment "Internal software development department."@en .

# Organizational Units (Teams)
noria:OrgUnit_NetworkTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Phone ;
    noria:agentInstructions "For critical issues, call the hotline immediately. For non-critical, open a ticket."@en ;
    org:unitOf noria:Org_ITOperations .

noria:OrgUnit_ServerTeam a org:OrganizationalUnit ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team managing physical and virtual server infrastructure."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Email ;
    noria:agentInstructions "Email for routine requests, use ticketing system for incidents."@en ;
    org:unitOf noria:Org_ITOperations .

noria:OrgUnit_AppSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support for business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Chat ;
    noria:agentInstructions "Consult knowledge base before contacting. Use chat for quick queries."@en ;
    org:unitOf noria:Org_ITOperations .

noria:OrgUnit_SecurityOps a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod noria:AgentContact_Phone ;
    noria:agentInstructions "Immediate escalation for critical security alerts."@en ;
    org:unitOf noria:Org_ITOperations .

# Individual Agents (foaf:Agent)
foaf:Agent_Alice a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, member of Network Operations Team."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    org:memberOf noria:OrgUnit_NetworkTeam .

foaf:Agent_Bob a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Server Administrator."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf noria:OrgUnit_ServerTeam .

foaf:Agent_Charlie a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    org:memberOf noria:OrgUnit_AppSupport .

foaf:Agent_Dave a foaf:Person, foaf:Agent ;
    rdfs:label "Dave Davis"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:dave.davis@example.com> ;
    org:memberOf noria:OrgUnit_SecurityOps .

# Corporate User Identifiers
noria:CUid_Alice a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount foaf:Agent_Alice .

noria:CUid_Bob a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount foaf:Agent_Bob .

# =============================================================================
# Locations
# =============================================================================

# Sites (Data Centers)
noria:Site_DC1 a bot:Site ;
    rdfs:label "Main Data Center Paris"@en ;
    rdfs:comment "Primary data center for corporate services."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_DRC a bot:Site ;
    rdfs:label "Disaster Recovery Center Lyon"@en ;
    rdfs:comment "Secondary data center for disaster recovery."@en ;
    noria:siteId "DRC-LYO-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

# Rooms
noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A - DC1"@en ;
    rdfs:comment "Main server room in Data Center Paris."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    bot:hasElement noria:Resource_WebSrv01, noria:Resource_DBSrv01 ;
    bot:hasSubSpace noria:Site_DC1 . # Assuming bot:hasSubSpace can link a room to a site.

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B - DC1"@en ;
    rdfs:comment "Room dedicated to network equipment in Data Center Paris."@en ;
    bot:hasSpace noria:Locus_RackB1 ;
    bot:hasElement noria:Resource_CoreRtr01, noria:Resource_EdgeSw01 ;
    bot:hasSubSpace noria:Site_DC1 .

# Loci (Specific locations within rooms)
noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Location for critical application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSubSpace noria:Room_ServerRoomA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2 in Server Room A"@en ;
    rdfs:comment "Location for database servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasSubSpace noria:Room_ServerRoomA .

noria:Locus_RackB1 a noria:Locus ;
    rdfs:label "Rack B1 in Network Room B"@en ;
    rdfs:comment "Location for core network devices."@en ;
    noria:locusLine "B" ;
    noria:locusRow "1" ;
    bot:hasSubSpace noria:Room_NetworkRoomB .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy noria:Org_NetworkVendor . # Assuming Dell is a vendor, using existing org.

noria:ProductModel_CiscoASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "Carrier-grade aggregation services router."@en ;
    noria:productManufacturedBy noria:Org_NetworkVendor .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for virtual machines."@en ;
    noria:productManufacturedBy noria:Org_NetworkVendor . # Using existing vendor for simplicity.

noria:ProductModel_JuniperEX4600 a noria:ProductModel ;
    rdfs:label "Juniper EX4600 Switch"@en ;
    rdfs:comment "High-performance 10/40GbE switch."@en ;
    noria:productManufacturedBy noria:Org_NetworkVendor .

