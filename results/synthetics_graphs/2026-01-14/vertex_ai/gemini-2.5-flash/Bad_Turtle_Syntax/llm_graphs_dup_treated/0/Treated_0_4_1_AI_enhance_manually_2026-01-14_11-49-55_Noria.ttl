# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_NetOpsTeam_extra_node_0 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for managing network infrastructure_extra_node_0 and services."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_0> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical_extra_node_0 issues, use emergency hotline."@en .

foaf:Agent_AppDevTeam_extra_node_0 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development_extra_node_0 Team"@en, "Équipe Développement Application"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_0> .

foaf:Agent_SecurityTeam_extra_node_0 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security_extra_node_0 Operations Center (SOC)"@en, "Centre Opérations Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone_extra_node_0> .

foaf:Agent_JohnDoe_extra_node_0 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the Network Operations Team."@en ;
    foaf:mbox <mailto:john.doe@example.com_extra_node_0> .

foaf:Agent_JaneSmith_extra_node_0 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Application Development_extra_node_0 Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com_extra_node_0> .

noria:CorporateUserIdentifier_JohnDoe_extra_node_0 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount foaf:Agent_JohnDoe_extra_node_0 .

# =============================================================================
# Locations
# =============================================================================

bot:Site_MainDataCenter_extra_node_0 a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    noria:siteId "DC01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_ServerRoomA_extra_node_0 a noria:Room ;
    rdfs:label "Server_extra_node_0 Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server room within the Main Data Center."@en ;
    bot:hasSpace bot:Site_MainDataCenter_extra_node_0 .

noria:Locus_RackA1_U23_extra_node_0 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server in Server_extra_node_0 Room A."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "23"@en ;
    bot:hasSpace noria:Room_ServerRoomA_extra_node_0 .

noria:Locus_RackA2_U10_extra_node_0 a noria:Locus ;
    rdfs:label "Rack A2, Unit 10"@en ;
    rdfs:comment "Specific location for a network device in Server_extra_node_0 Room A."@en ;
    noria:locusLine "A2"@en ;
    noria:locusRow "10"@en ;
    bot:hasSpace noria:Room_ServerRoomA_extra_node_0 .

