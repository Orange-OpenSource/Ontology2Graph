noria:OperationPlan_RouterInterfaceTroubleshoot_extra_node_0 a noria:OperationPlan ;
    rdfs:label "Router_extra_node_0 Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard_extra_node_0 operating procedure for diagnosing and resolving router interface issues."@en ;
    skos:example "Steps include checking cable, interface status, logs, and attempting to bounce the interface."@en .

noria:ActionPreCondition_InterfaceDown_extra_node_0 a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface reports an operational status of 'down_extra_node_0'."@en .

noria:ActionPostCondition_InterfaceUp_extra_node_0 a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up_extra_node_0"@en ;
    rdfs:comment "Expected outcome: The network interface reports an operational status of 'up_extra_node_0' and traffic flows."@en .

noria:OperationPlan_RouterInterfaceTroubleshoot_extra_node_0
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown_extra_node_0 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp_extra_node_0 .

noria:AnomalyPattern_HighCPULowTraffic a noria:AnomalyPattern ;
    rdfs:label "High_extra_node_0 CPU, Low Traffic Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating a potential software loop or misconfiguration: high_extra_node_0 CPU usage on a network device with unexpectedly low traffic throughput."@en ;
    folio:hasCause "Software bug or misconfiguration"@en .

