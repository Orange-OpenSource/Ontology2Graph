# 15. Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OpPlan_RestartWebServer_extra_node_1 a noria:OperationPlan ;
    rdfs:label "Restart Web Server_extra_node_1 Procedure"@en ;
    rdfs:comment "Standard_extra_node_1 operating procedure for restarting the corporate web server."@en ;
    noria:operationPlanPreCondition noria:PreCond_WebServerAccessible_extra_node_1 ;
    noria:operationPlanPostCondition noria:PostCond_WebServerRunning_extra_node_1 .

noria:PreCond_WebServerAccessible_extra_node_1 a noria:ActionPreCondition ;
    rdfs:label "Web Server_extra_node_1 Accessible"@en ;
    rdfs:comment "Verify that the web server is reachable via SSH/ping before attempting restart."@en ;
    skos:example "Ping web01.corp.example.com is successful."@en .

noria:PostCond_WebServerRunning_extra_node_1 a noria:ActionPostCondition ;
    rdfs:label "Web Server_extra_node_1 Running and Responding"@en ;
    rdfs:comment "Verify that the web server process is running and responds to HTTP requests after restart."@en ;
    skos:example "Check 'systemctl status apache2' and 'curl http://web01.corp.example.com/' returns 200 OK."@en .

noria:OpPlan_DiagnoseNetworkIssue_extra_node_1 a noria:OperationPlan ;
    rdfs:label "Diagnose Network Connectivity Issue"@en ;
    rdfs:comment "Procedure for diagnosing network connectivity problems."@en ;
    noria:operationPlanPreCondition noria:PreCond_NetworkIssueReported_extra_node_1 ;
    noria:operationPlanPostCondition noria:PostCond_RootCauseIdentified_extra_node_1 .

noria:PreCond_NetworkIssueReported_extra_node_1 a noria:ActionPreCondition ;
    rdfs:label "Network Issue Reported"@en ;
    rdfs:comment "A network connectivity issue has been reported or detected."@en .

noria:PostCond_RootCauseIdentified_extra_node_1 a noria:ActionPostCondition ;
    rdfs:label "Root Cause Identified"@en ;
    rdfs:comment "The root cause of the network issue has been identified."@en .

noria:AnomalyPattern_HighCPULoad_extra_node_1 a noria:AnomalyPattern ;
    rdfs:label "Sustained High_extra_node_1 CPU Load Anomaly"@en ;
    rdfs:comment "Pattern indicating a sustained period of high_extra_node_1 CPU utilization, potentially leading to performance degradation."@en ;
    folio:hasCause noria:Event_Web_Server_HighCPU_extra_node_1 . # Example of linking an anomaly pattern to an event that might trigger it.

