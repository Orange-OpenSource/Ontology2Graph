# =============================================================================
# 6. Network Links
# =============================================================================

noria:NL_WAN_Paris_Lyon_extra_node_1 a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-Lyon"@en, "Liaison WAN Paris-Lyon"@fr ;
    rdfs:comment "Dedicated WAN link connecting Paris Data Center to Lyon Office."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps_extra_node_1 ;
    noria:networkLinkId "WAN-PAR-LYN-001" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2021-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Core_Router_Paris_extra_node_1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Edge_Switch_Lyon_extra_node_1 ;
    noria:networkInterfaceConnects noria:NI_CR_Paris_Ge0_0_1_extra_node_1, noria:NI_ES_Lyon_Eth0_2_extra_node_1 .

