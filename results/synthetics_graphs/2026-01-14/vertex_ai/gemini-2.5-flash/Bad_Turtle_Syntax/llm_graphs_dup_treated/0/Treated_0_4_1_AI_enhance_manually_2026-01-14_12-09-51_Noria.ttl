# =============================================================================
# 1. Agents and Organizational Units
# =============================================================================

# Individuals (foaf:Agent)
noria:Agent_JohnDoe_extra_node_1 a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "IT Operations Engineer responsible for network infrastructure_extra_node_1."@en ;
    foaf:mbox <mailto:john.doe@example.com_extra_node_1> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Contact via ticketing system first, then email for non-urgent matters."@en .

noria:Agent_JaneSmith_extra_node_1 a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Application Support Lead for critical business applications."@en ;
    foaf:mbox <mailto:jane.smith@example.com_extra_node_1> ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_1> ;
    noria:agentInstructions "For critical incidents, call directly. Otherwise, use the incident management portal."@en .

noria:Agent_AliceJohnson_extra_node_1 a foaf:Agent ;
    rdfs:label "Alice Johnson"@en, "Alice Durand"@fr ;
    rdfs:comment "Network Administrator specializing in routing and switching."@en ;
    foaf:mbox <mailto:alice.johnson@example.com_extra_node_1> ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat_extra_node_1> ;
    noria:agentInstructions "Available on internal chat for quick queries."@en .

noria:Agent_BobWilliams_extra_node_1 a foaf:Agent ;
    rdfs:label "Bob Williams"@en, "Bob Dubois"@fr ;
    rdfs:comment "Database Administrator for core services."@en ;
    foaf:mbox <mailto:bob.williams@example.com_extra_node_1> ;
    noria:agentWorkingHours "8:00-16:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Submit a change request for any database modifications."@en .

# Teams (org:OrganizationalUnit, also foaf:Agent)
noria:Team_NetworkOps_extra_node_1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for the 24/7 operation and maintenance of the network infrastructure_extra_node_1."@en ;
    org:hasMember noria:Agent_JohnDoe_extra_node_1, noria:Agent_AliceJohnson_extra_node_1 ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_1> ;
    noria:agentInstructions "All network incidents must be reported via the ticketing system."@en .

noria:Team_AppSupport_extra_node_1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing Level 2 support for business applications."@en ;
    org:hasMember noria:Agent_JaneSmith_extra_node_1, noria:Agent_BobWilliams_extra_node_1 ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_1> ;
    noria:agentInstructions "For application issues, create a ticket in the AppSupport queue."@en .

noria:Team_SecurityOps_extra_node_1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre des Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts_extra_node_1> ;
    noria:agentInstructions "Automated alerts are processed by the SIEM. For manual reports, use the security incident portal."@en .

# Corporate User Identifiers (noria:CorporateUserIdentifier)
noria:CUid_JohnDoe_extra_node_1 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount noria:Agent_JohnDoe_extra_node_1 .

noria:CUid_JaneSmith_extra_node_1 a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount noria:Agent_JaneSmith_extra_node_1 .

# Manufacturers (org:Organization)
noria:Org_Dell_extra_node_1 a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:Org_Cisco_extra_node_1 a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high_extra_node_1-technology services and products."@en .

noria:Org_Juniper_extra_node_1 a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en .

noria:Org_VMware_extra_node_1 a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

noria:Org_HP_extra_node_1 a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise (HPE)"@en ;
    rdfs:comment "American multinational enterprise information technology company."@en .

