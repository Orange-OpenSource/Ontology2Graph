noria:Event_DNS_Down_Log_extra_node_1 a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_1 01 Interface Down Log"@en ;
    rdfs:comment "Log entry indicating that the network interface on DNS Server_extra_node_1 01 went down_extra_node_1."@en ;
    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS_Server_01_extra_node_1 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem_extra_node_1 ;
    noria:logText "LINEPROTO-5-DOWN: Interface eth0 on dns01.corp.example.com changed state to down_extra_node_1." ;
    dcterms:type <kos/Notification/EventType/stateChange_extra_node_1> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_1> ;
    folio:hasCritical_extra_node_1ity <Notification/Severity/PerceivedSeverity/Critical_extra_node_1> .

noria:Event_Web_Server_HighCPU_extra_node_1 a noria:EventRecord ;
    rdfs:label "Web Server_extra_node_1 01 High_extra_node_1 CPU Alert"@en ;
    rdfs:comment "Alert indicating high_extra_node_1 CPU utilization on Web Server_extra_node_1 01."@en ;
    noria:loggingTime "2023-10-26T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Web_Server_01_extra_node_1 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem_extra_node_1 ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes." ;
    dcterms:type <kos/Notification/EventType/ThresholdExceeded_extra_node_1> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_1> ;
    folio:hasCriticality <Notification/Severity/PerceivedSeverity/Major_extra_node_1> ;
    noria:alarmProposedRepairAction noria:OpPlan_RestartWebServer_extra_node_1 .

