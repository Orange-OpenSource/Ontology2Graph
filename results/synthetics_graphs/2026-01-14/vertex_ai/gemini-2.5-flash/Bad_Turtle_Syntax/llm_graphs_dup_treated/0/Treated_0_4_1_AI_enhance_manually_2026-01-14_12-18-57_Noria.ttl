# Example of an agent managing an application module
foaf:Agent_Jane_Smith_extra_node_2
    noria:agentManagesResource noria:ApplicationModule_Corporate_DNS_Prod_extra_node_2 .

# Example of a resource being part of a service (indirectly via application)
noria:Resource_DNS_Server_01_extra_node_2
    seas:subSystemOf noria:Service_Critical_Infrastructure_Support_extra_node_2 .

