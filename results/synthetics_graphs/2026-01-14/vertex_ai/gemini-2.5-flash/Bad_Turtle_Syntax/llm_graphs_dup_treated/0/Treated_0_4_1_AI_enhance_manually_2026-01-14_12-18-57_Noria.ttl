noria:NetworkInterface_EdgeRtr01_Gi0_0_1_extra_node_2
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -5 .

# Example of a trouble ticket note correlated with an event record
noria:TroubleTicketNote_WAN_Investigation_extra_node_2 a noria:TroubleTicketNote ;
    rdfs:label "WAN Link Investigation Note"@en ;
    rdfs:comment "Confirmed primary WAN link down. Initiating failover procedure."@en ;
    dcterms:created "2023-10-27T10:08:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_John_Doe_extra_node_2 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_2> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis_extra_node_2> ;
    dcterms:isPartOf noria:TroubleTicket_WAN_Link_Degradation_TT002_extra_node_2 ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_Interface_Down_EdgeRtr01_extra_node_2 .

# Example of a change request impacting a network link
noria:ChangeRequest_WAN_Link_Optimization_CR003_extra_node_2 a noria:ChangeRequest ;
    rdfs:label "WAN Link Optimization - CR003"@en ;
    rdfs:comment "Planned optimization of routing metrics on WAN links."@en ;
    dcterms:identifier "CR-20231201-003" ;
    dcterms:created "2023-11-10T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2023-12-01T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2023-12-01T03:30:00Z"^^xsd:dateTime ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard_extra_node_2> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration_extra_node_2> ;
    noria:changeRequestImpact noria:NetworkLink_EdgeRtr01_ISP_A_extra_node_2 ;
    noria:changeRequestImpact noria:NetworkLink_EdgeRtr01_ISP_B_extra_node_2 ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved_extra_node_2> ;
    noria:changeRequestInitiatorParty foaf:Agent_John_Doe_extra_node_2 .

<kos/ChangeRequest/cause/Configuration_extra_node_2> a skos:Concept ;
    rdfs:label "Configuration_extra_node_2 Change Cause"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .

# Example of an event record being mitigated by a procedure execution container (e.g., a change request)
noria:EventRecord_Interface_Down_EdgeRtr01_extra_node_2
    noria:alarmMitigatedBy noria:ChangeRequest_Router_Firmware_CR001_extra_node_2 . # Assuming the firmware upgrade fixed the instability causing interface flaps.

# Another event record for DNS service restored
noria:EventRecord_DNS_Service_Up_extra_node_2 a noria:EventRecord ;
    rdfs:label "DNS Service Up_extra_node_2 Event"@en ;
    rdfs:comment "Log entry indicating that the DNS service on DNS Server_extra_node_2 01 has started."@en ;
    noria:loggingTime "2023-10-27T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS_Server_01_extra_node_2 ;
    noria:logOriginatingManagementSystem noria:Application_NMS_extra_node_2 ;
    noria:logText "Service 'named' on dns01.corp.example.com is up." ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Warning_extra_node_2> ;
    noria:alarmMitigatedBy noria:TroubleTicket_DNS_Outage_TT001_extra_node_2 .

noria:TroubleTicket_DNS_Outage_TT001_extra_node_2
    noria:documentStatusHistory noria:EventRecord_DNS_Service_Up_extra_node_2 .

# Final state for DNS TT
noria:TroubleTicket_DNS_Outage_TT001_extra_node_2
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    dcterms:modified "2023-10-27T10:25:00Z"^^xsd:dateTime .

# Example of a resource being decommissioned
noria:Resource_Old_Backup_Server_extra_node_2 a noria:Resource ;
    rdfs:label "Old Backup Server_extra_node_2"@en ;
    rdfs:comment "Server_extra_node_2 scheduled for decommissioning."@en ;
    noria:resourceHostName "backup-old.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server_extra_node_2> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Decommissioned> ;
    noria:resourceManagedBy foaf:Agent_IT_Operations_Team_extra_node_2 .

# Example of a resource for multiple applications
noria:Resource_Shared_DB_Server_extra_node_2 a noria:Resource ;
    rdfs:label "Shared Database Server_extra_node_2"@en ;
    rdfs:comment "Database server hosting multiple application databases."@en ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server_extra_node_2> ;
    noria:resourceForApplication noria:Application_Web_Portal_extra_node_2 ;
    noria:resourceForApplication noria:Application_Corporate_DNS_extra_node_2 . # Example of shared resource

# Example of an application module with a support group
noria:ApplicationModule_Corporate_DNS_Prod_extra_node_2
    noria:applicationModuleSupportGroup foaf:Agent_IT_Operations_Team_extra_node_2 ; # Can be the same team or a different one
    noria:applicationModuleHotlineGroup foaf:Agent_IT_Operations_Team_extra_node_2 .

# Example of an agent with a corporate user identifier
foaf:Agent_John_Doe_extra_node_2
    foaf:holdsAccount noria:CorporateUserIdentifier_JohnDoe_extra_node_2 .

foaf:Agent_Jane_Smith_extra_node_2
    foaf:holdsAccount noria:CorporateUserIdentifier_JaneSmith_extra_node_2 .

# Example of a trouble ticket with a freeze item (represented by an event record)
noria:EventRecord_TT_Freeze_Start_extra_node_2 a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Start"@en ;
    noria:loggingTime "2023-10-27T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20231027-002 frozen due to external dependency." ;
    noria:logOriginatingManagementSystem noria:Application_NMS_extra_node_2 .

noria:TroubleTicket_WAN_Link_Degradation_TT002_extra_node_2
    noria:troubleTicketFreezeItem noria:EventRecord_TT_Freeze_Start_extra_node_2 .

# Example of a trouble ticket with a characteristic (not explicitly defined as a class, but can be a blank node or literal)
noria:TroubleTicket_DNS_Outage_TT001_extra_node_2
    noria:troubleTicketCharacteristic "Impacted Customer_extra_node_2 Segment: All Internal_extra_node_2 Users"@en .

# Example of a change request specification
<kos/ChangeRequest/specification/StandardRouterUpgrade_extra_node_2> a skos:Concept ;
    rdfs:label "Standard_extra_node_2 Router_extra_node_2 Upgrade Specification"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> .

