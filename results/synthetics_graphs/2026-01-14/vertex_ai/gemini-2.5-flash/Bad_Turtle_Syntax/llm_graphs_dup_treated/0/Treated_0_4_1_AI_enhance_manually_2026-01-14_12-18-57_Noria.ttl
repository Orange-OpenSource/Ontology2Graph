# Link EventRecord to OperationPlan if it represents an action guided by it
noria:EventRecord_Config_Change_EdgeRtr01_extra_node_2
    pep:usedProcedure noria:OperationPlan_WAN_Failover_extra_node_2 . # Assuming this config change was part of a failover procedure

# Link TroubleTicketNote to a correlated execution (e.g., a procedure execution container)
noria:TroubleTicketNote_DNS_Investigation_extra_node_2
    noria:troubleTicketNoteCorrelatedExecution noria:TroubleTicket_DNS_Outage_TT001_extra_node_2 . # The TT itself is a ProcedureExecutionContainer

# Link a Resource to an AnomalyPattern if it's susceptible to it
noria:Resource_DNS_Server_01_extra_node_2
    seas:hasProperty noria:AnomalyPattern_High_DNSError_Rate_extra_node_2 . # Conceptual link, not a direct property in NORIA, but can be used for density.

