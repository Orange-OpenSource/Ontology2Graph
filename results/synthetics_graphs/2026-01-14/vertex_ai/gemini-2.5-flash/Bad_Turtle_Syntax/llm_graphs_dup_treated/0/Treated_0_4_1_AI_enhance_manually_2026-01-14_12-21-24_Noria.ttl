# Application Type
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/type/infrastructure_extra_node_3> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en, "Application d'Infrastructure"@fr ;
    skos:prefLabel "Infrastructure"@en ;
    skos:altLabel "Infra"@en .

<kos/application/type/service-platform_extra_node_3> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Service Platform Application"@en, "Application Plateforme de Service"@fr ;
    skos:prefLabel "Service Platform"@en .

<kos/application/type/business-app_extra_node_3> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en, "Application Métier"@fr ;
    skos:prefLabel "Business App"@en .

