<ChangeRequestFirewallUpdate_extra_node_3> a noria:ChangeRequest ;
    rdfs:label "Firewall_extra_node_3 Rule Update for New Service"@en, "Mise à Jour Règle Pare-feu pour Nouveau Service"@fr ;
    rdfs:comment "Adding new firewall rules to allow traffic for an upcoming service."@en ;
    dcterms:identifier "CR-20240419-001" ;
    dcterms:created "2024-04-18T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-19T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-19T16:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-19T14:03:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-19T15:10:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention_extra_node_3> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard_extra_node_3> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration_extra_node_3> ;
    noria:changeRequestImpact <ResourceFirewall01_extra_node_3>, <ApplicationCorporateInternetAccess_extra_node_3> ;
    noria:changeRequestOutageDuration "PT0H0M0S"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardOperatingProcedure_extra_node_3> ;
    noria:changeRequestInitiatorParty <PersonAliceBrown_extra_node_3> ;
    noria:changeRequestPilotParty <OrgUnitSOC_extra_node_3> ;
    noria:changeRequestActorParty <PersonAliceBrown_extra_node_3> ;
    noria:changeRequestIsRegulated false ;
    noria:documentStatusHistory <EventRecordFirewallRuleChange_extra_node_3> ;
    pep:usedProcedure <OperationPlanFirewallDeployment_extra_node_3> .

<ChangeRequestDBUpgrade_extra_node_3> a noria:ChangeRequest ;
    rdfs:label "Database Server_extra_node_3 OS Upgrade"@en, "Mise à Niveau OS Serveur Base de Données"@fr ;
    rdfs:comment "Planned operating system upgrade for the corporate database server."@en ;
    dcterms:identifier "CR-20240501-001" ;
