# =============================================================================
# Event Records
# =============================================================================

<EventRecordDNSDown_extra_node_3> a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_3 Down Alert"@en ;
    rdfs:comment "Alert indicating that the Corporate DNS Server_extra_node_3 01 is unreachable."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <ResourceDNS01_extra_node_3> ;
    noria:logOriginatingManagementSystem <ApplicationInternalMonitoringSystem_extra_node_3> ;
    noria:logOriginatingAgent <OrgUnitNOC_extra_node_3> ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_3> ;
    noria:alarmProposedRepairAction <OperationPlanDNSRestart_extra_node_3> .

<EventRecordWebAppHighCPU_extra_node_3> a noria:EventRecord ;
    rdfs:label "High CPU on Web App Server_extra_node_3"@en ;
    rdfs:comment "Warning_extra_node_3 alert for high_extra_node_3 CPU utilization on Web Application Server_extra_node_3 01."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <ResourceWebApp01_extra_node_3> ;
    noria:logOriginatingManagementSystem <ApplicationInternalMonitoringSystem_extra_node_3> ;
    noria:logOriginatingAgent <OrgUnitAppSupportA_extra_node_3> ;
    noria:logText "WARNING: CPU utilization on webapp01.corp.example.com is 95%" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_3> .

<EventRecordFirewallRuleChange_extra_node_3> a noria:EventRecord ;
    rdfs:label "Firewall_extra_node_3 Rule Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Perimeter Firewall_extra_node_3 01."@en ;
    noria:loggingTime "2024-04-19T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <ResourceFirewall01_extra_node_3> ;
    noria:logOriginatingManagementSystem <ApplicationInternalMonitoringSystem_extra_node_3> ;
    noria:logOriginatingAgent <PersonAliceBrown_extra_node_3> ;
    noria:logText "INFO: Firewall_extra_node_3 rule 'Allow_SSH_to_DMZ' added by admin_soc" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor_extra_node_3> .

<EventRecordDBDiskSpace_extra_node_3> a noria:EventRecord ;
    rdfs:label "Database Server_extra_node_3 Disk Space Alert"@en ;
    rdfs:comment "Alert indicating low disk space on Database Server_extra_node_3 01."@en ;
    noria:loggingTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <ResourceDB01_extra_node_3> ;
    noria:logOriginatingManagementSystem <ApplicationInternalMonitoringSystem_extra_node_3> ;
    noria:logOriginatingAgent <OrgUnitDBAdmin_extra_node_3> ;
    noria:logText "CRITICAL: Disk space on /var/lib/mysql on db01.corp.example.com is 98% full" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_3> .

<EventRecordDNSRestartAttempt_extra_node_3> a noria:EventRecord ;
    rdfs:label "DNS Service Restart Command Log"@en ;
    rdfs:comment "Log of the command executed to restart DNS service."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <ResourceDNS01_extra_node_3> ;
    noria:logOriginatingManagementSystem <ApplicationInternalMonitoringSystem_extra_node_3> ;
    noria:logOriginatingAgent <PersonJohnDoe_extra_node_3> ;
    noria:logText "Command 'systemctl restart named' executed on dns01.corp.example.com" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor_extra_node_3> .

# =============================================================================
# Trouble Tickets
# =============================================================================

<TroubleTicketDNSOutage_extra_node_3> a noria:TroubleTicket ;
    rdfs:label "DNS Server_extra_node_3 Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "DNS server unreachable causing internet access issues for corporate users."@en ;
    dcterms:identifier "TT-20240420-001" ;
    dcterms:created "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical_extra_node_3> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure_extra_node_3> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService_extra_node_3> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1_extra_node_3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision_extra_node_3> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention_extra_node_3> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage_extra_node_3> ;
    noria:troubleTicketCause "DNS service process crashed on dns01.corp.example.com" ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT_extra_node_3> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress_extra_node_3> ;
    noria:troubleTicketRelatedParty <OrgUnitNOC_extra_node_3> ;
    noria:troubleTicketRelatedService <ApplicationCorporateInternetAccess_extra_node_3> ;
    noria:troubleTicketRelatedResource <ResourceDNS01_extra_node_3> ;
    noria:troubleTicketImpacts <ApplicationCorporateInternetAccess_extra_node_3>, <ResourceDNS01_extra_node_3> ;
    noria:troubleTicketTrigger <EventRecordDNSDown_extra_node_3> ;
    noria:documentStatusHistory <EventRecordDNSDown_extra_node_3>, <EventRecordDNSRestartAttempt_extra_node_3> ;
    dcterms:relation <EventRecordDNSRestartAttempt_extra_node_3> ; # Explicit relation for actions
    pep:usedProcedure <OperationPlanDNSRestart_extra_node_3> .

<TroubleTicketCustomerPortalSlow_extra_node_3> a noria:TroubleTicket ;
    rdfs:label "Customer_extra_node_3 Portal Slow Performance"@en, "Performance Lente Portail Client"@fr ;
    rdfs:comment "Customers reporting slow loading times on the portal, likely due to high_extra_node_3 CPU on web server."@en ;
    dcterms:identifier "TT-20240420-002" ;
    dcterms:created "2024-04-20T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major_extra_node_3> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure_extra_node_3> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/DegradedService_extra_node_3> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2_extra_node_3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer_extra_node_3> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention_extra_node_3> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ApplicationIssue_extra_node_3> ;
    noria:troubleTicketCause "High CPU utilization on webapp01.corp.example.com impacting response times." ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT_extra_node_3> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress_extra_node_3> ;
    noria:troubleTicketRelatedParty <OrgUnitAppSupportA_extra_node_3> ;
    noria:troubleTicketRelatedService <ServiceECommercePlatform_extra_node_3> ;
    noria:troubleTicketRelatedResource <ResourceWebApp01_extra_node_3> ;
    noria:troubleTicketImpacts <ServiceECommercePlatform_extra_node_3>, <ResourceWebApp01_extra_node_3> ;
    noria:troubleTicketTrigger <EventRecordWebAppHighCPU_extra_node_3> ;
    noria:documentStatusHistory <EventRecordWebAppHighCPU_extra_node_3>, <EventRecordDBDiskSpace_extra_node_3> ;
    dcterms:relation <EventRecordDBDiskSpace_extra_node_3> . # Disk space alert also related to this performance issue

<TroubleTicketNoteDNSRestartAttempt_extra_node_3> a noria:TroubleTicketNote ;
    rdfs:label "DNS Server_extra_node_3 Restart Attempt Note"@en ;
    rdfs:comment "Attempted to restart DNS service, but it failed to come up."@en ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:description "Attempted 'systemctl restart named' on dns01.corp.example.com. Service failed to start. Investigating logs."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_3> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis_extra_node_3> ;
    noria:troubleTicketNoteCorrelatedExecution <EventRecordDNSRestartAttempt_extra_node_3> ;
    dcterms:isPartOf <TroubleTicketDNSOutage_extra_node_3> .

