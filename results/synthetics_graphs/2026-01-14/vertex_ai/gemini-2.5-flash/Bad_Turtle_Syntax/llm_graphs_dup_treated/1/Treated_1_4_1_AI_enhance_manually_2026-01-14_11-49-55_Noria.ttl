# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_RouterInterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving router interface issues."@en ;
    skos:example "Steps include checking cable, interface status, logs, and attempting to bounce the interface."@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface reports an operational status of 'down'."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up_extra_node_0"@en ;
    rdfs:comment "Expected outcome: The network interface reports an operational status of 'up' and traffic flows."@en .

noria:OperationPlan_RouterInterfaceTroubleshoot
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:AnomalyPattern_HighCPULowTraffic a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Traffic Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating a potential software loop or misconfiguration: high CPU usage on a network device with unexpectedly low traffic throughput."@en ;
    folio:hasCause "Software bug or misconfiguration"@en .

