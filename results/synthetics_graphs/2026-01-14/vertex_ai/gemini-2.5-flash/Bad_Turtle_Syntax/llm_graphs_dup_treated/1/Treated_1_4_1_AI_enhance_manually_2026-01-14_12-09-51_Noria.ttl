# 16. Procedure Execution Containers
# =============================================================================

noria:ProcExecCont_DNS_Troubleshooting a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS Troubleshooting Actions for TT_DNS_Outage_20231026"@en ;
    rdfs:comment "Container for all actions taken during the troubleshooting of the DNS outage. Conceptually, this container holds EventRecords like noria:Event_DNS_Troubleshoot_Action1 and noria:Event_DNS_Troubleshoot_Action2, which are instances of pep:ProcedureExecution."@en .

