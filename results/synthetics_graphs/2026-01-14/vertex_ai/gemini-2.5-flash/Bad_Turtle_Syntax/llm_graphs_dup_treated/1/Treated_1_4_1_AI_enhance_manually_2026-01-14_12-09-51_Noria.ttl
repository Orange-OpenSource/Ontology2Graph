# =============================================================================
# 15. Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OpPlan_RestartWebServer a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate web server."@en ;
    noria:operationPlanPreCondition noria:PreCond_WebServerAccessible ;
    noria:operationPlanPostCondition noria:PostCond_WebServerRunning .

noria:PreCond_WebServerAccessible a noria:ActionPreCondition ;
    rdfs:label "Web Server Accessible"@en ;
    rdfs:comment "Verify that the web server is reachable via SSH/ping before attempting restart."@en ;
    skos:example "Ping web01.corp.example.com is successful."@en .

noria:PostCond_WebServerRunning a noria:ActionPostCondition ;
    rdfs:label "Web Server Running and Responding"@en ;
    rdfs:comment "Verify that the web server process is running and responds to HTTP requests after restart."@en ;
    skos:example "Check 'systemctl status apache2' and 'curl http://web01.corp.example.com/' returns 200 OK."@en .

noria:OpPlan_DiagnoseNetworkIssue a noria:OperationPlan ;
    rdfs:label "Diagnose Network Connectivity Issue"@en ;
    rdfs:comment "Procedure for diagnosing network connectivity problems."@en ;
    noria:operationPlanPreCondition noria:PreCond_NetworkIssueReported ;
    noria:operationPlanPostCondition noria:PostCond_RootCauseIdentified .

noria:PreCond_NetworkIssueReported a noria:ActionPreCondition ;
    rdfs:label "Network Issue Reported"@en ;
    rdfs:comment "A network connectivity issue has been reported or detected."@en .

noria:PostCond_RootCauseIdentified a noria:ActionPostCondition ;
    rdfs:label "Root Cause Identified"@en ;
    rdfs:comment "The root cause of the network issue has been identified."@en .

noria:AnomalyPattern_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Anomaly"@en ;
    rdfs:comment "Pattern indicating a sustained period of high CPU utilization, potentially leading to performance degradation."@en ;
    folio:hasCause noria:Event_Web_Server_HighCPU . # Example of linking an anomaly pattern to an event that might trigger it.

