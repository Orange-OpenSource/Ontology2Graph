@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

# =============================================================================
# 1. Agents and Organizational Units
# =============================================================================

# Individuals (foaf:Agent)
noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "IT Operations Engineer responsible for network infrastructure."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system first, then email for non-urgent matters."@en .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Application Support Lead for critical business applications."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, call directly. Otherwise, use the incident management portal."@en .

noria:Agent_AliceJohnson a foaf:Agent ;
    rdfs:label "Alice Johnson"@en, "Alice Durand"@fr ;
    rdfs:comment "Network Administrator specializing in routing and switching."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Available on internal chat for quick queries."@en .

noria:Agent_BobWilliams a foaf:Agent ;
    rdfs:label "Bob Williams"@en, "Bob Dubois"@fr ;
    rdfs:comment "Database Administrator for core services."@en ;
    foaf:mbox <mailto:bob.williams@example.com> ;
    noria:agentWorkingHours "8:00-16:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a change request for any database modifications."@en .

# Teams (org:OrganizationalUnit, also foaf:Agent)
noria:Team_NetworkOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for the 24/7 operation and maintenance of the network infrastructure."@en ;
    org:hasMember noria:Agent_JohnDoe, noria:Agent_AliceJohnson ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All network incidents must be reported via the ticketing system."@en .

noria:Team_AppSupport a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing Level 2 support for business applications."@en ;
    org:hasMember noria:Agent_JaneSmith, noria:Agent_BobWilliams ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For application issues, create a ticket in the AppSupport queue."@en .

noria:Team_SecurityOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre des Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "Automated alerts are processed by the SIEM. For manual reports, use the security incident portal."@en .

# Corporate User Identifiers (noria:CorporateUserIdentifier)
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount noria:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount noria:Agent_JaneSmith .

# Manufacturers (org:Organization)
noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

noria:Org_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

noria:Org_HP a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise (HPE)"@en ;
    rdfs:comment "American multinational enterprise information technology company."@en .

# =============================================================================
# 2. Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series Switch"@en ;
    rdfs:comment "Data center-class switch for high-density deployments."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480 Router"@en ;
    rdfs:comment "Modular router for enterprise and service provider edge applications."@en ;
    noria:productManufacturedBy noria:Org_Juniper .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Type-1 hypervisor for virtualizing servers."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:ProductModel_HPProLiantDL380 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Versatile 2U rack server for various workloads."@en ;
    noria:productManufacturedBy noria:Org_HP .

# =============================================================================
# 3. Location Entities
# =============================================================================

# Sites (bot:Site)
noria:Site_DC_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_Office_Lyon a bot:Site ;
    rdfs:label "Lyon Office Building"@en, "Bâtiment de Bureau de Lyon"@fr ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

# Rooms (noria:Room)
noria:Room_ServerRoom_DC_Paris_A1 a noria:Room ;
    rdfs:label "Server Room A1 - Paris DC"@en, "Salle Serveurs A1 - DC Paris"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack_A1_R01, noria:Locus_Rack_A1_R02 ;
    bot:hasBuilding noria:Site_DC_Paris .

noria:Room_NetworkCloset_Lyon_F2 a noria:Room ;
    rdfs:label "Network Closet F2 - Lyon Office"@en, "Local Réseau F2 - Bureau Lyon"@fr ;
    rdfs:comment "Network equipment closet on the second floor of the Lyon office."@en ;
    bot:hasSpace noria:Locus_Rack_F2_N01 ;
    bot:hasBuilding noria:Site_Office_Lyon .

# Loci (noria:Locus)
noria:Locus_Rack_A1_R01 a noria:Locus ;
    rdfs:label "Rack R01 in Server Room A1"@en ;
    rdfs:comment "Location of rack R01 in Server Room A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "R01" ;
    bot:hasZone noria:Room_ServerRoom_DC_Paris_A1 .

noria:Locus_Rack_A1_R02 a noria:Locus ;
    rdfs:label "Rack R02 in Server Room A1"@en ;
    rdfs:comment "Location of rack R02 in Server Room A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "R02" ;
    bot:hasZone noria:Room_ServerRoom_DC_Paris_A1 .

noria:Locus_Rack_F2_N01 a noria:Locus ;
    rdfs:label "Network Rack N01 in Network Closet F2"@en ;
    rdfs:comment "Location of network rack N01 in Network Closet F2."@en ;
    noria:locusLine "F2" ;
    noria:locusRow "N01" ;
    bot:hasZone noria:Room_NetworkCloset_Lyon_F2 .

# =============================================================================
# 4. Resources
# =============================================================================

noria:Resource_DNS_Server_01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC. Critical_extra_node_1 for internal service resolution."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_1> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1_R01 ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
    noria:resourceForApplication noria:App_InternalDNS .

noria:Resource_Web_Server_01 a noria:Resource ;
    rdfs:label "Corporate Web Server 01"@en, "Serveur Web d'Entreprise 01"@fr ;
    rdfs:comment "Web server hosting the main corporate website. Part of the public-facing infrastructure."@en ;
    noria:resourceManagedBy noria:Team_AppSupport ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_HPProLiantDL380 ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_1> ;
    noria:resourceInstallationDate "2022-03-01T11:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1_R02 ;
    noria:resourceManagementIPAddress "10.0.0.20" ;
    noria:resourceForApplication noria:App_CorporateWebsite .

noria:Resource_Core_Router_Paris a noria:Resource ;
    rdfs:label "Core Router Paris"@en, "Routeur Cœur Paris"@fr ;
    rdfs:comment "Main router for the Paris data center network, providing inter-DC and WAN connectivity."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:resourceHostName "cr-par-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_1> ;
    noria:resourceInstallationDate "2021-06-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1_R01 ;
    noria:resourceManagementIPAddress "10.0.0.254" .

noria:Resource_Edge_Switch_Lyon a noria:Resource ;
    rdfs:label "Edge Switch Lyon"@en, "Commutateur Edge Lyon"@fr ;
    rdfs:comment "Edge switch for the Lyon office network, providing local access and WAN uplink."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:resourceHostName "es-lyn-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceLogisticId "ASSET-ES-001" ;
    noria:resourceType <kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-ES-001-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_1> ;
    noria:resourceInstallationDate "2022-02-10T14:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_F2_N01 ;
    noria:resourceManagementIPAddress "10.1.0.253" .

noria:Resource_Virtual_DB_Server_01 a noria:Resource ;
    rdfs:label "Virtual Database Server 01"@en, "Serveur de Base de Données Virtuel 01"@fr ;
    rdfs:comment "Virtual machine hosting the main corporate database."@en ;
    noria:resourceManagedBy noria:Team_AppSupport ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceLogisticId "ASSET-VDB-001" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-DB-001-JKL" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_1> ;
    noria:resourceInstallationDate "2023-01-20T16:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.30" ;
    noria:clusterController noria:Resource_Hypervisor_Host_01 . # Link to its physical host or cluster controller

noria:Resource_Hypervisor_Host_01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en, "Hôte Hyperviseur 01"@fr ;
    rdfs:comment "Physical server hosting virtual machines, including db01."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ; # Or a dedicated virtualization team
    noria:resourceHostName "hv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-HV-001" ;
    noria:resourceType <kos/Resource/type/HypervisorHost> ;
    noria:resourceSerialNumber "SN-HV-001-MNO" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_1> ;
    noria:resourceInstallationDate "2022-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1_R02 ;
    noria:resourceManagementIPAddress "10.0.0.50" .

noria:Resource_LoadBalancer_01 a noria:Resource ;
    rdfs:label "Load Balancer 01"@en, "Équilibreur de Charge 01"@fr ;
    rdfs:comment "Load balancer distributing traffic to web servers."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:resourceHostName "lb01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Using a switch model as a generic network device
    noria:resourceLogisticId "ASSET-LB-001" ;
    noria:resourceType <kos/Resource/type/LoadBalancer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_1> ;
    noria:locatedAtLocus noria:Locus_Rack_A1_R02 ;
    noria:resourceManagementIPAddress "10.0.0.40" ;
    noria:resourceForApplication noria:App_CorporateWebsite .

# =============================================================================
# 5. Network Interfaces
# =============================================================================

noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface 0 on DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS_Server_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> .

noria:NI_Web01_Eth0 a noria:NetworkInterface ;
    rdfs:label "web01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface 0 on Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_Web_Server_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> .

noria:NI_CR_Paris_Ge0_0_0 a noria:NetworkInterface ;
    rdfs:label "cr-par-01:ge-0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/0 on Core Router Paris, connecting to internal network."@en ;
    noria:networkInterfaceOf noria:Resource_Core_Router_Paris ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NI_CR_Paris_Ge0_0_1 a noria:NetworkInterface ;
    rdfs:label "cr-par-01:ge-0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/1 on Core Router Paris, connecting to WAN."@en ;
    noria:networkInterfaceOf noria:Resource_Core_Router_Paris ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> ;
    noria:networkInterfaceRoutingPriorityMetric 120 .

noria:NI_ES_Lyon_Eth0_1 a noria:NetworkInterface ;
    rdfs:label "es-lyn-01:eth0/1"@en ;
    rdfs:comment "Ethernet interface 0/1 on Edge Switch Lyon, connecting to user VLAN."@en ;
    noria:networkInterfaceOf noria:Resource_Edge_Switch_Lyon ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> .

noria:NI_ES_Lyon_Eth0_2 a noria:NetworkInterface ;
    rdfs:label "es-lyn-01:eth0/2"@en ;
    rdfs:comment "Ethernet interface 0/2 on Edge Switch Lyon, connecting to WAN."@en ;
    noria:networkInterfaceOf noria:Resource_Edge_Switch_Lyon ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> .

noria:NI_LB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "lb01.corp.example.com:eth0"@en ;
    rdfs:comment "External interface on Load Balancer 01."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> .

noria:NI_LB01_Eth1 a noria:NetworkInterface ;
    rdfs:label "lb01.corp.example.com:eth1"@en ;
    rdfs:comment "Internal interface on Load Balancer 01, connecting to web servers."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> .

# =============================================================================
# 6. Network Links
# =============================================================================

noria:NL_WAN_Paris_Lyon a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-Lyon"@en, "Liaison WAN Paris-Lyon"@fr ;
    rdfs:comment "Dedicated WAN link connecting Paris Data Center to Lyon Office."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:networkLinkId "WAN-PAR-LYN-001" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2021-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Core_Router_Paris ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Edge_Switch_Lyon ;
    noria:networkInterfaceConnects noria:NI_CR_Paris_Ge0_0_1, noria:NI_ES_Lyon_Eth0_2 .

noria:NL_DC_Internal_Network a noria:NetworkLink ;
    rdfs:label "DC Internal Network Segment"@en, "Segment Réseau Interne DC"@fr ;
    rdfs:comment "Internal network segment within the Paris Data Center."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:networkLinkId "DC-INT-NET-001" ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkLinkInstallationDate "2020-01-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_DNS_Server_01, noria:Resource_Web_Server_01, noria:Resource_Core_Router_Paris, noria:Resource_Hypervisor_Host_01 ;
    noria:networkInterfaceConnects noria:NI_DNS01_Eth0, noria:NI_CR_Paris_Ge0_0_0 . # Assuming other interfaces connect to this logical link

noria:NL_LB_Web_Segment a noria:NetworkLink ;
    rdfs:label "Load Balancer to Web Server Segment"@en ;
    rdfs:comment "Internal network segment between load balancer and web servers."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:networkLinkId "LB-WEB-NET-001" ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkLinkTerminationResource noria:Resource_LoadBalancer_01, noria:Resource_Web_Server_01 ;
    noria:networkInterfaceConnects noria:NI_LB01_Eth1, noria:NI_Web01_Eth0 .

# =============================================================================
# 7. Applications
# =============================================================================

noria:App_CorporateWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en, "Site Web d'Entreprise"@fr ;
    rdfs:comment "The main public-facing website for the corporation. High visibility and business impact."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CWEB" ;
    noria:applicationType <kos/application/type/CustomerFacing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Marketing and Sales" ;
    noria:applicationFunctionalSubDomain "Online Presence Management" ;
    noria:resourceManagedBy noria:Team_AppSupport ;
    noria:resourceForApplication noria:Resource_Web_Server_01, noria:Resource_LoadBalancer_01 .

noria:App_InternalDNS a noria:Application ;
    rdfs:label "Internal DNS Service"@en, "Service DNS Interne"@fr ;
    rdfs:comment "Provides DNS resolution for all internal corporate systems. Essential for all IT services."@en ;
    noria:applicationModelIdentifier "INTDNS" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "IDNS" ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical_extra_node_1> ;
    noria:applicationFunctionalDomain "IT Infrastructure" ;
    noria:applicationFunctionalSubDomain "Network Services" ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
