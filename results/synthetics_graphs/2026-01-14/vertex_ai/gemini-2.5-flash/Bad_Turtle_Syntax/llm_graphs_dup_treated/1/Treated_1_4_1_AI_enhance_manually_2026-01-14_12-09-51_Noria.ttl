noria:Event_DNS_Down_Log a noria:EventRecord ;
    rdfs:label "DNS Server 01 Interface Down Log"@en ;
    rdfs:comment "Log entry indicating that the network interface on DNS Server 01 went down."@en ;
    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS_Server_01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "LINEPROTO-5-DOWN: Interface eth0 on dns01.corp.example.com changed state to down." ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_1> ;
    folio:hasCritical_extra_node_1ity <Notification/Severity/PerceivedSeverity/Critical_extra_node_1> .

noria:Event_Web_Server_HighCPU a noria:EventRecord ;
    rdfs:label "Web Server 01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2023-10-26T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes." ;
    dcterms:type <kos/Notification/EventType/ThresholdExceeded> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_1> ;
    folio:hasCriticality <Notification/Severity/PerceivedSeverity/Major_extra_node_1> ;
    noria:alarmProposedRepairAction noria:OpPlan_RestartWebServer .

noria:Event_Router_Config_Change a noria:EventRecord ;
    rdfs:label "Core Router Paris Configuration Change"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router Paris."@en ;
    noria:loggingTime "2023-10-25T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Core_Router_Paris ;
    noria:logOriginatingAgent noria:Agent_AliceJohnson ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by alice.johnson (10.0.0.100)." ;
    dcterms:type <kos/Notification/EventType/ConfigurationChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:Event_DB_Connection_Error a noria:EventRecord ;
    rdfs:label "Database Connection Error Log"@en ;
    rdfs:comment "Log entry indicating connection errors to the virtual database server."@en ;
    noria:loggingTime "2023-10-26T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Virtual_DB_Server_01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "Database connection pool exhausted for application 'CRM_PROD'." ;
    dcterms:type <kos/Notification/EventType/ApplicationError> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_1> .

noria:Event_LB_HealthCheck_Fail a noria:EventRecord ;
    rdfs:label "Load Balancer Health Check Failure"@en ;
    rdfs:comment "Load balancer detected a health check failure for web01.corp.example.com."@en ;
    noria:loggingTime "2023-10-26T10:16:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_LoadBalancer_01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "Health check failed for backend server web01.corp.example.com on port 80." ;
    dcterms:type <kos/Notification/EventType/ApplicationError> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_1> ;
    folio:hasCriticality <Notification/Severity/PerceivedSeverity/Major_extra_node_1> .

noria:Event_Router_Interface_Flap a noria:EventRecord ;
    rdfs:label "Router Interface Flap Log"@en ;
    rdfs:comment "Log entry indicating an interface on Core Router Paris flapped (went down and up quickly)."@en ;
    noria:loggingTime "2023-10-26T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Core_Router_Paris ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "Interface ge-0/0/1 on cr-par-01 changed state to down, then to up within 10 seconds." ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_DNS_Troubleshoot_Action1 a noria:EventRecord ;
    rdfs:label "DNS Troubleshooting Action: Interface Check"@en ;
    rdfs:comment "Command 'show interface eth0' executed on dns01.corp.example.com."@en ;
    noria:loggingTime "2023-10-26T09:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS_Server_01 ;
    noria:logOriginatingAgent noria:Agent_JohnDoe ;
    noria:logText "Output of 'show interface eth0': Link status down, protocol down." ;
    dcterms:type <kos/Notification/EventType/CommandExecution> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:Event_DNS_Troubleshoot_Action2 a noria:EventRecord ;
    rdfs:label "DNS Troubleshooting Action: Interface No Shutdown"@en ;
    rdfs:comment "Command 'interface eth0; no shutdown' executed on dns01.corp.example.com."@en ;
    noria:loggingTime "2023-10-26T09:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS_Server_01 ;
    noria:logOriginatingAgent noria:Agent_JohnDoe ;
    noria:logText "Command executed: 'interface eth0; no shutdown'. No change in status observed." ;
    dcterms:type <kos/Notification/EventType/CommandExecution> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

