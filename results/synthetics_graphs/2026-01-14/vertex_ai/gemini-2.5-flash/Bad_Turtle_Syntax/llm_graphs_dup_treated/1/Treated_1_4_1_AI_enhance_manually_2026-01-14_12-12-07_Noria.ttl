    noria:applicationModuleHotlineEnabled true .

# =============================================================================
# Services
# =============================================================================

noria:Service_CorpIntranetAccess a noria:Service ;
    rdfs:label "Corporate Intranet Access Service"@en ;
    rdfs:comment "End-to-end service for accessing the corporate intranet."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_IntranetFrontend, noria:AppMod_IntranetBackend .

noria:Service_InternetConnectivity a noria:Service ;
    rdfs:label "Internet Connectivity Service"@en ;
    rdfs:comment "Provides internet access to the corporate network."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:AppMod_RoutingService .

# =============================================================================
# Event Records
# =============================================================================

noria:Event_NI_Down a noria:EventRecord ;
    rdfs:label "Network Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_NetworkInfra ;
    noria:logOriginatingAgent foaf:Agent_NetOpsTeam ; # Could be automated system, but here for example
    noria:logText "LINEPROTO-5-DOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_5> .

noria:Event_App_Error a noria:EventRecord ;
    rdfs:label "Application Error Log"@en ;
    rdfs:comment "Log entry indicating an error in the Corporate Intranet application."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_CorpIntranet ;
    noria:logText "Application error: Database connection failed for user 'jdoe'"@en ;
    dcterms:type <kos/Notification/EventType/ApplicationError> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_Security_Alert a noria:EventRecord ;
    rdfs:label "Security Alert: Unauthorized Access Attempt"@en ;
    rdfs:comment "Security Information and Event Management (SIEM) alert for an unauthorized access attempt."@en ;
