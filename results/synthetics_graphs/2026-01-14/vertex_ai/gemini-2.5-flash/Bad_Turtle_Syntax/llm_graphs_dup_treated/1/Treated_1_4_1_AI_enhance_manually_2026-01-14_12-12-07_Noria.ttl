# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OP_RouterInterfaceBounce a noria:OperationPlan ;
    rdfs:label "Router Interface Bounce Procedure"@en ;
    rdfs:comment "Standard operating procedure to administratively shut down and then bring up a router interface."@en ;
    noria:operationPlanPreCondition noria:PreCond_InterfaceDown ;
    noria:operationPlanPostCondition noria:PostCond_InterfaceUp .

noria:PreCond_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Interface is Administratively Down"@en ;
    rdfs:comment "Condition: The network interface's administrative status is 'down' or operational status is 'down'."@en ;
    skos:example "Check `noria:networkInterfaceAdministrativeStatus` or `noria:networkInterfaceOperationalStatus`."@en .

noria:PostCond_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Interface is Up and Operational"@en ;
    rdfs:comment "Expected outcome: The network interface's administrative and operational statuses are 'up', and traffic flows normally."@en ;
    skos:example "Verify `noria:networkInterfaceAdministrativeStatus` and `noria:networkInterfaceOperationalStatus` are 'up'. Ping test to connected device successful."@en .

noria:OP_DBRestart a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Procedure for restarting the database service on DBSrv01."@en ;
    noria:operationPlanPreCondition noria:PreCond_AppError ;
    noria:operationPlanPostCondition noria:PostCond_AppRestored .

noria:PreCond_AppError a noria:ActionPreCondition ;
    rdfs:label "Application Reporting Errors"@en ;
    rdfs:comment "Condition: Application logs show database connection errors."@en ;
    skos:example "Monitor `noria:Event_App_Error` type events."@en .

noria:PostCond_AppRestored a noria:ActionPostCondition ;
    rdfs:label "Application Functionality Restored"@en ;
    rdfs:comment "Expected outcome: Application logs show no more database errors, and users can access the intranet."@en ;
    skos:example "Verify application logs and user reports."@en .

noria:AnomalyPattern_HighLatency a noria:AnomalyPattern ;
    rdfs:label "High Network Latency Pattern"@en ;
    rdfs:comment "Pattern indicating high network latency, potentially leading to service degradation."@en ;
    skos:example "Repeated `noria:Event_App_Error` events combined with high ping times between `noria:Resource_WebSrv01` and `noria:Resource_DBSrv01`."@en ;
    folio:hasCause noria:NL_WebDbLink . # Assuming high latency is a failure mode of the link

# Linking an EventRecord to an OperationPlan (as a proposed repair action)
noria:Event_NI_Down noria:alarmProposedRepairAction noria:OP_RouterInterfaceBounce .

# Linking a ChangeRequest to an OperationPlan (as the procedure guiding it)
noria:CR_RouterUpgrade_001 noria:actionCorrelatedOperationPlan noria:OP_RouterOSUpgrade .

noria:OP_RouterOSUpgrade a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the operating system of a network router."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterBackup ;
    noria:operationPlanPostCondition noria:PostCond_RouterOSUpdated .

noria:PreCond_RouterBackup a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Completed"@en ;
    rdfs:comment "Condition: A full backup of the router's configuration has been successfully completed and verified."@en .

noria:PostCond_RouterOSUpdated a noria:ActionPostCondition ;
    rdfs:label "Router OS Updated and Operational"@en ;
    rdfs:comment "Expected outcome: Router OS is updated to the target version, all interfaces are up, and routing protocols are stable."@en .

# Linking an EventRecord to a TroubleTicket (as a status history entry)
noria:TT_NetworkOutage_001 noria:documentStatusHistory noria:Event_NI_Down .
noria:TT_NetworkOutage_001 noria:documentStatusHistory noria:Event_NI_Up_AfterFix .

noria:Event_NI_Up_AfterFix a noria:EventRecord ;
    rdfs:label "Network Interface Up Event (After Fix)"@en ;
    rdfs:comment "Log entry indicating a network interface came up after troubleshooting."@en ;
    noria:loggingTime "2024-04-20T10:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_NetworkInfra ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "LINEPROTO-5-UP: Interface GigabitEthernet0/0/1, changed state to up"@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmMitigatedBy noria:TT_NetworkOutage_001 . # The TT container represents the actions taken

# Linking a TroubleTicketNote to a correlated execution (if applicable)
# For simplicity, we'll link it to an EventRecord directly as the note describes an action that might generate a log.
noria:TTN_001_Note1 noria:troubleTicketNoteCorrelatedExecution noria:Event_NI_Down .

# Ensure all entities are connected.
# I've tried to connect most entities to at least two others where logical,
# and ensured all created entities have at least one incoming or outgoing link.
# The use of `seas:subSystemOf`, `dcterms:isPartOf`, `noria:resourceForApplication`,
# `noria:applicationModuleOf`, `noria:troubleTicketRelatedService`, etc.,
# helps create a dense and connected graph.
