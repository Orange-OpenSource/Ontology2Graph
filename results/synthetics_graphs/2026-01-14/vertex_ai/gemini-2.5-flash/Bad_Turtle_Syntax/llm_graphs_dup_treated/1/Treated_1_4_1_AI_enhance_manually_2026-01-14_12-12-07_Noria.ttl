@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# =============================================================================
# Organizational Entities (Agents, Organizations, Corporate User Identifiers)
# =============================================================================

# Agents (Teams and Individuals)
foaf:Agent_NetOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing and monitoring network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical incidents, use emergency hotline."@en .

foaf:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/InternalChat> ;
    noria:agentInstructions "Submit change requests via internal portal. For urgent issues, contact team lead."@en .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Report all security incidents immediately via dedicated channel."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, member of the Network Operations Team."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    org:memberOf foaf:Agent_NetOpsTeam .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer, member of the Application Development Team."@en ;
    noria:agentWorkingHours "9:30-18:30 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/InternalChat> ;
    org:memberOf foaf:Agent_AppDevTeam .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series for high-density deployments."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor for virtualized environments."@en ;
    noria:productManufacturedBy noria:Org_VMware .

# Organizations (Manufacturers)
noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware and software."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware, software, and telecommunications equipment."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

# =============================================================================
# Location Entities
# =============================================================================

bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_ServerHallA a noria:Room ;
    rdfs:label "Server Hall A"@en ;
    rdfs:comment "Main server hall within the Main Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    bot:hasSubSpace bot:Site_MainDC . # Assuming bot:hasSubSpace can link a room to its parent site

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Dedicated room for network equipment within the Main Data Center."@en ;
    bot:hasSpace noria:Locus_RackB1 ;
    bot:hasSubSpace bot:Site_MainDC .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Server Hall A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasSubSpace noria:Room_ServerHallA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of additional servers in Server Hall A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en ;
    bot:hasSubSpace noria:Room_ServerHallA .

noria:Locus_RackB1 a noria:Locus ;
    rdfs:label "Rack B1"@en ;
    rdfs:comment "Location of network devices in Network Room B."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "1"@en ;
    bot:hasSubSpace noria:Room_NetworkRoomB .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server for the corporate intranet application."@en ;
    noria:resourceLogisticId "ASSET-WS01-DC01" ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WS01-12345" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
    noria:resourceForApplication noria:App_CorpIntranet .

noria:Resource_DBSrv01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Primary database server for corporate applications."@en ;
    noria:resourceLogisticId "ASSET-DB01-DC01" ;
    noria:resourceHostName "dbsrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB01-67890" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.11" ;
    noria:resourceForApplication noria:App_CorpIntranet .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for internal network traffic."@en ;
    noria:resourceLogisticId "ASSET-CR01-DC01" ;
    noria:resourceHostName "routercore01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR01-ABCDE" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam ;
    noria:locatedAtLocus noria:Locus_RackB1 ;
    noria:resourceManagementIPAddress "10.0.0.1" ;
    noria:resourceForApplication noria:App_NetworkInfra .

noria:Resource_RouterEdge01 a noria:Resource ;
    rdfs:label "Edge Router 01"@en ;
    rdfs:comment "Edge router connecting the corporate network to the internet."@en ;
    noria:resourceLogisticId "ASSET-ER01-DC01" ;
    noria:resourceHostName "routeredge01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-ER01-FGHIJ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam ;
    noria:locatedAtLocus noria:Locus_RackB1 ;
    noria:resourceManagementIPAddress "10.0.0.2" ;
    noria:resourceForApplication noria:App_NetworkInfra .

noria:Resource_VMHost01 a noria:Resource ;
    rdfs:label "VM Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines."@en ;
    noria:resourceLogisticId "ASSET-VH01-DC01" ;
    noria:resourceHostName "vmhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
    noria:resourceSerialNumber "SN-VH01-KLMNO" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T14:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.12" .

noria:Resource_VirtualAppSrv a noria:Resource ;
    rdfs:label "Virtual Application Server"@en ;
    rdfs:comment "Virtual machine hosting a critical application module."@en ;
    noria:resourceLogisticId "ASSET-VAPPSRV-DC01" ;
    noria:resourceHostName "vappsrv.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # This is the hypervisor model, not the VM itself. A VM doesn't have a product model in the same sense.
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-ID-12345" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-04-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:clusterController noria:Resource_VMHost01 ;
    noria:resourceManagementIPAddress "10.0.0.20" ;
    noria:resourceForApplication noria:App_CriticalService .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NI_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_DBSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBSrv01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_RouterCore01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router 01 to internal network segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NI_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to Edge Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 .

noria:NI_RouterEdge01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "RouterEdge01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Interface connecting Edge Router 01 to Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterEdge01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -4 ;
    noria:networkInterfaceLaserRxOpticalPower -6 .

noria:NI_RouterEdge01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterEdge01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Edge Router 01 to the Internet."@en ;
    noria:networkInterfaceOf noria:Resource_RouterEdge01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_VirtualAppSrv_Eth0 a noria:NetworkInterface ;
    rdfs:label "VirtualAppSrv Ethernet 0"@en ;
    rdfs:comment "Network interface for the Virtual Application Server."@en ;
    noria:networkInterfaceOf noria:Resource_VirtualAppSrv ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links
# =============================================================================

noria:NL_CoreEdgeLink a noria:NetworkLink ;
    rdfs:label "Core-Edge Router Link"@en ;
    rdfs:comment "High-speed link between Core Router 01 and Edge Router 01."@en ;
    noria:networkLinkId "NL-CE-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterEdge01 ;
    noria:networkLinkInstallationDate "2022-05-01T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 10Gbps"@en ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gi0_0_1, noria:NI_RouterEdge01_Gi0_0_0 .

noria:NL_WebDbLink a noria:NetworkLink ;
    rdfs:label "Web-DB Server Link"@en ;
    rdfs:comment "Internal network link between Web Server 01 and Database Server 01."@en ;
    noria:networkLinkId "NL-WD-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DBSrv01 ;
    noria:networkLinkInstallationDate "2023-01-15T12:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps"@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0, noria:NI_DBSrv01_Eth0 .

# =============================================================================
# Applications
# =============================================================================

noria:App_CorpIntranet a noria:Application ;
    rdfs:label "Corporate Intranet"@en ;
    rdfs:comment "Internal web portal for corporate communications and tools."@en ;
    noria:applicationModelIdentifier "CORP-INTRA" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "CI" ;
    noria:applicationType <kos/application/type/BusinessApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Internal Communications"@en ;
    noria:applicationFunctionalSubDomain "Employee Portal"@en ;
    noria:elementManagedBy foaf:Agent_AppDevTeam .

noria:App_NetworkInfra a noria:Application ;
    rdfs:label "Network Infrastructure Management"@en ;
    rdfs:comment "Application representing the core network services and devices."@en ;
    noria:applicationModelIdentifier "NET-INFRA" ;
    noria:applicationNumericalIdentifier 102 ;
    noria:applicationShortIdentifier "NI" ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical_extra_node_5> ;
    noria:applicationFunctionalDomain "IT Operations"@en ;
    noria:applicationFunctionalSubDomain "Network Management"@en ;
    noria:elementManagedBy foaf:Agent_NetOpsTeam .

noria:App_CriticalService a noria:Application ;
    rdfs:label "Critical_extra_node_5 Business Service X"@en ;
    rdfs:comment "A mission-critical application providing essential business functionality."@en ;
    noria:applicationModelIdentifier "CRIT-SVC-X" ;
    noria:applicationNumericalIdentifier 103 ;
    noria:applicationShortIdentifier "CSX" ;
    noria:applicationType <kos/application/type/BusinessApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical_extra_node_5> ;
    noria:applicationFunctionalDomain "Customer Facing Services"@en ;
    noria:applicationFunctionalSubDomain "Order Processing"@en ;
    noria:elementManagedBy foaf:Agent_AppDevTeam .

# =============================================================================
# Application Modules
# =============================================================================

noria:AppMod_IntranetFrontend a noria:ApplicationModule ;
    rdfs:label "Intranet Frontend Module"@en ;
    rdfs:comment "Frontend component of the Corporate Intranet, running on Web Server 01."@en ;
    noria:applicationModuleOf noria:App_CorpIntranet ;
    noria:applicationModuleName "CORP-INTRA_FE" ;
    noria:applicationModuleIdentifier "FE" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam foaf:Agent_AppDevTeam ;
    noria:applicationModuleSupportTeam foaf:Agent_AppDevTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:AppMod_IntranetBackend a noria:ApplicationModule ;
    rdfs:label "Intranet Backend Module"@en ;
    rdfs:comment "Backend component of the Corporate Intranet, interacting with Database Server 01."@en ;
    noria:applicationModuleOf noria:App_CorpIntranet ;
    noria:applicationModuleName "CORP-INTRA_BE" ;
    noria:applicationModuleIdentifier "BE" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam foaf:Agent_AppDevTeam ;
    noria:applicationModuleSupportTeam foaf:Agent_AppDevTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:AppMod_RoutingService a noria:ApplicationModule ;
    rdfs:label "Core Routing Service"@en ;
    rdfs:comment "Module managing routing protocols on Core Router 01."@en ;
    noria:applicationModuleOf noria:App_NetworkInfra ;
    noria:applicationModuleName "NET-INFRA_CR" ;
    noria:applicationModuleIdentifier "CR" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam foaf:Agent_NetOpsTeam ;
    noria:applicationModuleSupportTeam foaf:Agent_NetOpsTeam ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2022-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:AppMod_CriticalAppVM a noria:ApplicationModule ;
    rdfs:label "Critical_extra_node_5 App VM Module"@en ;
    rdfs:comment "Virtual machine module for Critical_extra_node_5 Business Service X."@en ;
    noria:applicationModuleOf noria:App_CriticalService ;
    noria:applicationModuleName "CRIT-SVC-X_VM" ;
    noria:applicationModuleIdentifier "VM" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
