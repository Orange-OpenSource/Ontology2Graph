@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .

# --- Knowledge Organization System (KOS) Concepts ---
# These are defined as skos:Concept instances within specific skos:ConceptScheme.
# For brevity and to avoid defining full SKOS schemes, we'll use direct URIs for these concepts.

# Application Types
<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application"@en ; rdfs:comment "An application providing core infrastructure services."@en .
<kos/application/type/service-platform> a skos:Concept ; rdfs:label "Service Platform Application"@en ; rdfs:comment "An application acting as a platform for other services."@en .
<kos/application/type/business-application> a skos:Concept ; rdfs:label "Business Application"@en ; rdfs:comment "An application directly supporting business operations."@en .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low Business Importance"@en .

# Application Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; rdfs:comment "The application module is currently active and serving users."@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "In Development"@en ; rdfs:comment "The application module is under active development."@en .
<https://w3id.org/noria/kos/application/status/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned"@en ; rdfs:comment "The application module has been retired from service."@en .

# Application SLA Level
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA Level"@en ; rdfs:comment "Highest Service Level Agreement tier."@en .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; rdfs:label "Silver SLA Level"@en ; rdfs:comment "Mid-tier Service Level Agreement."@en .

# Service Types
<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en ; rdfs:comment "A service directly consumed by external customers."@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en ; rdfs:comment "A service that supports other services or internal operations."@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en ; rdfs:comment "Incident causing severe business impact."@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en ; rdfs:comment "Incident causing significant business impact."@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en ; rdfs:comment "Incident causing limited business impact."@en .

# Trouble Ticket Type
<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure Ticket"@en ; rdfs:comment "Ticket reporting a system failure."@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance Ticket"@en ; rdfs:comment "Ticket requesting user assistance."@en .

# Trouble Ticket Category
<kos/TroubleTicket/category/InterruptedService> a skos:Concept ; rdfs:label "Interrupted Service"@en ; rdfs:comment "Service is completely unavailable."@en .
<kos/TroubleTicket/category/DowngradingEquipment> a skos:Concept ; rdfs:label "Downgrading Equipment"@en ; rdfs:comment "Equipment performance is degraded."@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en ; rdfs:comment "Highest priority, immediate action required."@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en ; rdfs:comment "High priority, urgent action required."@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision System"@en ; rdfs:comment "Ticket originated from an automated monitoring system."@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Report"@en ; rdfs:comment "Ticket reported by an external customer."@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention"@en ; rdfs:comment "Action required without delay."@en .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention"@en ; rdfs:comment "Action can be scheduled later."@en .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; rdfs:label "Managed Backbone Networks"@en ; rdfs:comment "Responsibility lies with the internal network team."@en .
<kos/TroubleTicket/problemResponsibility/Customer> a skos:Concept ; rdfs:label "Customer Responsibility"@en ; rdfs:comment "Responsibility lies with the customer."@en .

# Trouble Ticket Status
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en ; rdfs:comment "Ticket is actively being worked on."@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en ; rdfs:comment "Issue has been fixed, awaiting closure."@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en ; rdfs:comment "Ticket has been fully resolved and closed."@en .

# Trouble Ticket Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en ; rdfs:comment "Comment visible only to internal teams."@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment"@en ; rdfs:comment "Comment visible to the customer."@en .

# Trouble Ticket Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation"@en ; rdfs:comment "Activity related to identifying the root cause."@en .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; rdfs:label "Tests and Measurements Operation"@en ; rdfs:comment "Activity involving testing and data collection."@en .

# Change Request Category
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention"@en ; rdfs:comment "Change initiated and performed internally."@en .
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en ; rdfs:comment "Change involving a software version update."@en .

# Change Request Type
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en ; rdfs:comment "Pre-approved change with low risk."@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency Change"@en ; rdfs:comment "Urgent change required to restore service."@en .

# Change Request Cause
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; rdfs:label "Configuration Change"@en ; rdfs:comment "Change due to configuration modification."@en .
<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ; rdfs:label "Preventative Maintenance"@en ; rdfs:comment "Change performed to prevent future issues."@en .

# Change Request Status
<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved"@en ; rdfs:comment "Change request has been approved for implementation."@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented"@en ; rdfs:comment "Change has been successfully applied."@en .

# Change Request Specification
<kos/ChangeRequest/specification/StandardProcedureA> a skos:Concept ; rdfs:label "Standard Procedure A"@en ; rdfs:comment "Reference to a documented standard operating procedure."@en .
<kos/ChangeRequest/specification/EmergencyProcedureB> a skos:Concept ; rdfs:label "Emergency Procedure B"@en ; rdfs:comment "Reference to a documented emergency procedure."@en .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Operational Up"@en ; rdfs:comment "The resource is currently operating normally."@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Operational Down"@en ; rdfs:comment "The resource is currently not operating."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState/Up> a skos:Concept ; rdfs:label "Administrative Up"@en ; rdfs:comment "The resource is administratively enabled."@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Administrative Down"@en ; rdfs:comment "The resource is administratively disabled."@en .

# Resource Type
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router"@en ; rdfs:comment "A network device that forwards data packets between computer networks."@en .
<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server"@en ; rdfs:comment "A computer program or a device that provides functionality for other programs or devices."@en .
<kos/Resource/type/Switch> a skos:Concept ; rdfs:label "Switch"@en ; rdfs:comment "A network device that connects devices in a computer network."@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine"@en ; rdfs:comment "An emulation of a computer system."@en .
<kos/Resource/type/Firewall> a skos:Concept ; rdfs:label "Firewall"@en ; rdfs:comment "A network security system that monitors and controls incoming and outgoing network traffic."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; rdfs:comment "The resource is actively used in the production environment."@en .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; rdfs:label "Staging"@en ; rdfs:comment "The resource is in a pre-production environment for testing."@en .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email"@en ; rdfs:comment "Preferred contact method is email."@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone"@en ; rdfs:comment "Preferred contact method is phone."@en .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical Perceived Severity"@en ; rdfs:comment "Highest perceived severity for an event."@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major Perceived Severity"@en ; rdfs:comment "High perceived severity for an event."@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor Perceived Severity"@en ; rdfs:comment "Low perceived severity for an event."@en .

# --- Agents and Organizational Units ---
foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email dnsteam@example.com for non-urgent issues. Call hotline for critical outages."@en .

foaf:Agent_NetworkOps a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call the NOC for network incidents."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security threats."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual network engineer."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:OrganizationalUnit_ITOperations a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Overall department managing IT infrastructure and services."@en ;
    org:hasMember foaf:Agent_DNSAdminTeam, foaf:Agent_NetworkOps .

org:OrganizationalUnit_NetworkSupport a org:OrganizationalUnit ;
    rdfs:label "Network Support Group"@en ;
    rdfs:comment "Specialized group within IT Operations for network issues."@en ;
    org:hasMember foaf:Agent_JohnDoe .

noria:CorporateUserIdentifier_JohnDoeCUid a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe"@en ;
    observable:accountLogin "jdoe"@en ;
    observable:accountIdentifier "jdoe-corp-id-12345"@en .

foaf:Agent_JohnDoe foaf:holdsAccount noria:CorporateUserIdentifier_JohnDoeCUid .

# --- Locations ---
bot:Site_HQDataCenter a bot:Site ;
    rdfs:label "Headquarters Data Center"@en ;
    rdfs:comment "Main data center for corporate operations."@en ;
    noria:siteId "DC-HQ-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Main Street"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room within the HQ Data Center."@en ;
    bot:hasSpace bot:Site_HQDataCenter .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical servers in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB2 a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:comment "Location of network equipment in Server Room A."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "2"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

# --- Product Models ---
noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various applications."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> . # Assuming Dell is an org:Organization

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch/router."@en ;
    noria:productManufacturedBy <https://www.cisco.com> . # Assuming Cisco is an org:Organization

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com> . # Assuming VMware is an org:Organization

noria:ProductModel_PaloAltoFirewall a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5200 Series"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy <https://www.paloaltonetworks.com> . # Assuming Palo Alto Networks is an org:Organization

# --- Resources ---
noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted on physical hardware."@en ;
    noria:resourceLogisticId "ASSET-DNS-01" ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceForApplication noria:Application_CorporateInternetAccess ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "192.168.10.10" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate backbone network."@en ;
    noria:resourceLogisticId "ASSET-CR-01" ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:resourceForApplication noria:Application_CorporateInternetAccess ;
    noria:locatedAtLocus noria:Locus_RackB2 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_VMWeb01 a noria:Resource ;
    rdfs:label "Web Portal VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate web portal application."@en ;
    noria:resourceLogisticId "ASSET-VM-WEB01" ;
    noria:resourceHostName "web01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-WEB01-UUID" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceForApplication noria:Application_WebPortalApp ;
    noria:clusterController noria:Resource_DNS01 ; # Example of a VM running on a server
    noria:resourceManagementIPAddress "172.16.0.10" .

noria:Resource_Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Firewall protecting the corporate network perimeter."@en ;
    noria:resourceLogisticId "ASSET-FW-01" ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_PaloAltoFirewall ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-09-01T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:resourceForApplication noria:Application_CorporateInternetAccess ;
    noria:locatedAtLocus noria:Locus_RackB2 ;
    noria:resourceManagementIPAddress "10.0.0.254" .

# --- Network Interfaces ---
noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Uplink to Core Router 01"@en .

noria:NetworkInterface_RouterCore01_Eth1 a noria:NetworkInterface ;
    rdfs:label "CR01 Ethernet 1"@en ;
    rdfs:comment "Ethernet interface on Core Router 01, connected to DNS01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Downlink to DNS Server 01"@en .

noria:NetworkInterface_RouterCore01_Eth2 a noria:NetworkInterface ;
    rdfs:label "CR01 Ethernet 2"@en ;
    rdfs:comment "Ethernet interface on Core Router 01, connected to Firewall01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 ;
    noria:networkInterfaceDescription "Uplink to Perimeter Firewall 01"@en .

noria:NetworkInterface_Firewall01_Eth0 a noria:NetworkInterface ;
    rdfs:label "FW01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface on Perimeter Firewall 01, connected to Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Downlink to Core Router 01"@en .

# --- Network Links ---
noria:NetworkLink_DNS_Core a noria:NetworkLink ;
    rdfs:label "Link DNS01 to Core Router 01"@en ;
    rdfs:comment "Physical link connecting DNS01 to Core Router 01."@en ;
    noria:networkLinkId "LINK-DNS-CR01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore01 ;
    noria:networkLinkInstallationDate "2022-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0, noria:NetworkInterface_RouterCore01_Eth1 .

noria:NetworkLink_Core_Firewall a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to Firewall 01"@en ;
    rdfs:comment "Physical link connecting Core Router 01 to Perimeter Firewall 01."@en ;
    noria:networkLinkId "LINK-CR01-FW01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01 ;
    noria:networkLinkInstallationDate "2022-09-01T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Eth2, noria:NetworkInterface_Firewall01_Eth0 .

# --- Applications ---
noria:Application_CorporateInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and systems."@en ;
    noria:applicationModelIdentifier "CIA-MODEL" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "Internet Gateway Management"@en .

noria:Application_WebPortalApp a noria:Application ;
    rdfs:label "Corporate Web Portal Application"@en ;
    rdfs:comment "Internal web application for employee services."@en ;
    noria:applicationModelIdentifier "WPA-MODEL" ;
    noria:applicationNumericalIdentifier 2002 ;
    noria:applicationShortIdentifier "WPA" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Human Resources"@en ;
    noria:applicationFunctionalSubDomain "Employee Self-Service"@en .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "System for collecting and analyzing logs and metrics from IT infrastructure."@en ;
