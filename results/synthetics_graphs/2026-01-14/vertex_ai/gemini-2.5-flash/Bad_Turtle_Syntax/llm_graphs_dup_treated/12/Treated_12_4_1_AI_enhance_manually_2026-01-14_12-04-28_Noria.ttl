# --- Services ---
noria:Service_EnterpriseConnectivity a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing network connectivity to the enterprise."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_CorporateInternetAccess . # A service can be composed of applications/modules

noria:Service_InternalMonitoring a noria:Service ;
    rdfs:label "Internal Monitoring Service"@en ;
    rdfs:comment "Service for internal IT monitoring and alerting."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Application_MonitoringSystem .

# --- Event Records ---
noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Outage Log"@en ;
    rdfs:comment "Log entry indicating a critical outage of the DNS server."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: DNS service on dns01.corp.example.com is unreachable."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Event indicating that an interface on the core router went down."@en ;
    noria:loggingTime "2024-04-20T10:07:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:NetworkInterface_RouterCore01_Eth1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "INTERFACE_STATUS: ge-0/0/1 on cr01.corp.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change applied to the core router."@en ;
    noria:loggingTime "2024-04-19T15:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "CONFIG_CHANGE: User jdoe applied configuration 'no shutdown interface ge-0/0/1'."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord_FirewallAlert a noria:EventRecord ;
    rdfs:label "Firewall Security Alert"@en ;
    rdfs:comment "Alert from firewall indicating suspicious activity."@en ;
    noria:loggingTime "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "SECURITY_ALERT: Multiple failed login attempts from external IP 203.0.113.42."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

# --- Trouble Tickets ---
noria:TroubleTicket_TT2024001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Critical incident regarding the corporate DNS server being unreachable."@en ;
    dcterms:identifier "TT-2024-001" ;
    dcterms:created "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketCause "Unidentified network connectivity issue affecting DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Service_EnterpriseConnectivity ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty foaf:Agent_DNSAdminTeam, foaf:Agent_NetworkOps ;
    noria:troubleTicketImpacts noria:Application_CorporateInternetAccess, noria:Resource_DNS01 .

noria:TroubleTicket_TT2024002 a noria:TroubleTicket ;
    rdfs:label "Web Portal Performance Degradation"@en ;
    rdfs:comment "Users reporting slow response times for the corporate web portal."@en ;
    dcterms:identifier "TT-2024-002" ;
    dcterms:created "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/DowngradingEquipment> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "User Reports"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/category/DowngradingEquipment> ;
    noria:troubleTicketCause "Suspected resource contention on VM host."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ; # Assuming VM host is managed
    noria:troubleTicketDetectionDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application_WebPortalApp ;
    noria:troubleTicketRelatedResource noria:Resource_VMWeb01 ;
    noria:troubleTicketRelatedParty foaf:Agent_AppDevTeam .

# --- Trouble Ticket Notes ---
noria:TroubleTicketNote_TT2024001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT-2024-001"@en ;
    rdfs:comment "First note on DNS outage ticket."@en ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_NetworkOps ;
    dcterms:description "Checked DNS server status, no local issues found. Suspecting upstream network problem. Initiating network path trace."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_TT2024001 .

noria:TroubleTicketNote_TT2024001_Note2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Update for TT-2024-001"@en ;
    rdfs:comment "Update on DNS outage resolution."@en ;
    dcterms:created "2024-04-20T10:55:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_NetworkOps ;
    dcterms:description "Identified faulty fiber link to core router. Failover to redundant link completed. DNS service restored."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TroubleTicket_TT2024001 ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_InterfaceDown . # Correlating the interface down event as part of the resolution

# --- Change Requests ---
noria:ChangeRequest_CR2024001 a noria:ChangeRequest ;
    rdfs:label "Router Firmware Upgrade CR"@en ;
    rdfs:comment "Planned firmware upgrade for Core Router 01."@en ;
    dcterms:identifier "CR-2024-001" ;
    dcterms:created "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/PreventativeMaintenance> ;
    noria:changeRequestImpact noria:Resource_RouterCore01 ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardProcedureA> ;
    noria:changeRequestInitiatorParty foaf:Agent_NetworkOps ;
    noria:changeRequestPilotParty foaf:Agent_JohnDoe ;
    noria:changeRequestActorParty foaf:Agent_JohnDoe ;
    noria:changeRequestIsRegulated false .

noria:ChangeRequest_CR2024002 a noria:ChangeRequest ;
    rdfs:label "Emergency Web Portal Patch Deployment"@en ;
    rdfs:comment "Emergency patch deployment for a critical vulnerability in the Web Portal application."@en ;
    dcterms:identifier "CR-2024-002" ;
    dcterms:created "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-20T14:30:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ;
    noria:changeRequestType <kos/ChangeRequest/type/Emergency> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ; # Could be configuration for patch deployment
    noria:changeRequestImpact noria:Resource_VMWeb01, noria:Application_WebPortalApp ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ; # 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/EmergencyProcedureB> ;
    noria:changeRequestInitiatorParty foaf:Agent_SecurityTeam ;
    noria:changeRequestPilotParty foaf:Agent_AppDevTeam ;
    noria:changeRequestActorParty foaf:Agent_AppDevTeam ;
    noria:changeRequestIsRegulated true .

# --- Operation Plans ---
noria:OperationPlan_RouterFailover a noria:OperationPlan ;
    rdfs:label "Router Link Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for initiating a network link failover on a router."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_NetworkUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ServiceRestored .

noria:OperationPlan_VMReboot a noria:OperationPlan ;
    rdfs:label "Virtual Machine Reboot Procedure"@en ;
    rdfs:comment "Standard operating procedure for safely rebooting a virtual machine."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_VMUnresponsive ;
    noria:operationPlanPostCondition noria:ActionPostCondition_VMOperational .

# --- Action Pre/Post Conditions ---
noria:ActionPreCondition_NetworkUnreachable a noria:ActionPreCondition ;
    rdfs:label "Network Unreachable Pre-Condition"@en ;
    rdfs:comment "Condition where a network segment or service is unreachable."@en ;
    skos:example "Ping to target IP fails, traceroute shows path interruption."@en .

noria:ActionPostCondition_ServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Condition where the affected service has returned to normal operation."@en ;
    skos:example "Ping to target IP succeeds, application health checks pass."@en .

noria:ActionPreCondition_VMUnresponsive a noria:ActionPreCondition ;
    rdfs:label "VM Unresponsive Pre-Condition"@en ;
    rdfs:comment "Condition where a virtual machine is not responding to requests."@en ;
    skos:example "SSH connection fails, web service on VM is down."@en .

noria:ActionPostCondition_VMOperational a noria:ActionPostCondition ;
    rdfs:label "VM Operational Post-Condition"@en ;
    rdfs:comment "Condition where the virtual machine is fully operational."@en ;
    skos:example "SSH connection succeeds, web service on VM is accessible."@en .

# --- Anomaly Patterns ---
noria:AnomalyPattern_HighLatencyDNS a noria:AnomalyPattern ;
    rdfs:label "High Latency DNS Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating unusually high latency for DNS queries, potentially signaling a problem."@en ;
    skos:example "Average DNS query response time exceeds 500ms for more than 5 minutes."@en .

noria:AnomalyPattern_InterfaceFlap a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flap Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a network interface repeatedly changing between up and down states."@en ;
    skos:example "Interface status changes from UP to DOWN and back to UP more than 3 times in 1 minute."@en .

# --- Additional Connections for Density ---
foaf:Agent_DNSAdminTeam noria:agentManagesResource noria:Resource_DNS01 .
foaf:Agent_NetworkOps noria:agentManagesResource noria:Resource_RouterCore01, noria:NetworkLink_DNS_Core, noria:NetworkLink_Core_Firewall .
foaf:Agent_AppDevTeam noria:agentManagesResource noria:Resource_VMWeb01 .
foaf:Agent_SecurityTeam noria:agentManagesResource noria:Resource_Firewall01 .

noria:NetworkInterface_DNS01_Eth0 noria:networkInterfaceConnects noria:NetworkLink_DNS_Core .
noria:NetworkInterface_RouterCore01_Eth1 noria:networkInterfaceConnects noria:NetworkLink_DNS_Core .
noria:NetworkInterface_RouterCore01_Eth2 noria:networkInterfaceConnects noria:NetworkLink_Core_Firewall .
noria:NetworkInterface_Firewall01_Eth0 noria:networkInterfaceConnects noria:NetworkLink_Core_Firewall .

noria:Application_CorporateInternetAccess seas:subSystemOf noria:Service_EnterpriseConnectivity .
noria:Application_MonitoringSystem seas:subSystemOf noria:Service_InternalMonitoring .

noria:TroubleTicket_TT2024001 noria:documentStatusHistory noria:EventRecord_DNSOutageLog .
noria:TroubleTicket_TT2024002 noria:documentStatusHistory noria:EventRecord_InterfaceDown . # Example of an event record being part of the status history

noria:ChangeRequest_CR2024001 noria:documentStatusHistory noria:EventRecord_ConfigChange . # A config change event could be part of a CR's history

noria:EventRecord_InterfaceDown noria:alarmProposedRepairAction noria:OperationPlan_RouterFailover .
noria:EventRecord_DNSOutageLog noria:alarmMitigatedBy noria:TroubleTicketNote_TT2024001_Note2 . # The note describes the action that mitigated the alarm

noria:OperationPlan_RouterFailover pep:usedProcedure noria:OperationPlan_RouterFailover . # Self-referential for procedure execution context

# Example of a document attachment
noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for Core Network"@en ;
    rdfs:comment "Diagram illustrating the topology of the core network."@en ;
    dcterms:isPartOf noria:TroubleTicket_TT2024001, noria:ChangeRequest_CR2024001 ;
    dcterms:format "image/png" ;
    dcterms:source "https://example.com/docs/network_diagram.png" .

