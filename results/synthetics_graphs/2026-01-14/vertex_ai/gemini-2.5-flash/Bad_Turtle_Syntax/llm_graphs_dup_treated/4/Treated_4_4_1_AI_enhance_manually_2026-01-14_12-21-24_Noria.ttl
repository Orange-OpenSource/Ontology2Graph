# =============================================================================
# Network Interfaces
# =============================================================================

<NetworkInterfaceDNS01Eth0> a noria:NetworkInterface ;
    rdfs:label "Eth0 on DNS Server 01"@en ;
    rdfs:comment "Ethernet interface for DNS Server 01."@en ;
    noria:networkInterfaceOf <ResourceDNS01> ;
    noria:networkInterfaceConnects <NetworkLinkDNS_Router> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary network interface for DNS services."@en .

<NetworkInterfaceRouter01Gi001> a noria:NetworkInterface ;
    rdfs:label "Gi0/0/1 on Core Router 01"@en ;
    rdfs:comment "Gigabit Ethernet interface 1 on Core Router 01, connected to DNS server."@en ;
    noria:networkInterfaceOf <ResourceRouter01> ;
    noria:networkInterfaceConnects <NetworkLinkDNS_Router> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to DNS server segment."@en .

<NetworkInterfaceRouter01Gi002> a noria:NetworkInterface ;
    rdfs:label "Gi0/0/2 on Core Router 01"@en ;
    rdfs:comment "Gigabit Ethernet interface 2 on Core Router 01, connected to application server segment."@en ;
    noria:networkInterfaceOf <ResourceRouter01> ;
    noria:networkInterfaceConnects <NetworkLinkRouter_WebApp> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to application server segment."@en .

<NetworkInterfaceWebApp01Eth0> a noria:NetworkInterface ;
    rdfs:label "Eth0 on Web Application Server 01"@en ;
    rdfs:comment "Ethernet interface for Web Application Server 01."@en ;
    noria:networkInterfaceOf <ResourceWebApp01> ;
    noria:networkInterfaceConnects <NetworkLinkRouter_WebApp> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary network interface for web application."@en .

<NetworkInterfaceFirewall01Gi000> a noria:NetworkInterface ;
    rdfs:label "Gi0/0/0 on Perimeter Firewall 01"@en ;
    rdfs:comment "Gigabit Ethernet interface 0 on Perimeter Firewall 01, connected to Load Balancer."@en ;
    noria:networkInterfaceOf <ResourceFirewall01> ;
    noria:networkInterfaceConnects <NetworkLinkFirewall_LB> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Internal interface to DMZ."@en .

<NetworkInterfaceLoadBalancer01Gi000> a noria:NetworkInterface ;
    rdfs:label "Gi0/0/0 on Load Balancer 01"@en ;
    rdfs:comment "Gigabit Ethernet interface 0 on Load Balancer 01, connected to Firewall."@en ;
    noria:networkInterfaceOf <ResourceLoadBalancer01> ;
    noria:networkInterfaceConnects <NetworkLinkFirewall_LB> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Interface facing the firewall."@en .

# =============================================================================
# Network Links
# =============================================================================

<NetworkLinkDNS_Router> a noria:NetworkLink ;
    rdfs:label "Link between DNS Server and Core Router"@en ;
    rdfs:comment "Direct connection between DNS Server 01 and Core Router 01."@en ;
    noria:networkLinkId "NL-DNS-RTR-01" ;
    noria:networkLinkTerminationResourceOrigin <ResourceDNS01> ;
    noria:networkLinkTerminationResourceDestination <ResourceRouter01> ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:resourceManagedBy <OrgUnitNOC> .

<NetworkLinkRouter_WebApp> a noria:NetworkLink ;
    rdfs:label "Link between Core Router and Web App Server"@en ;
    rdfs:comment "Connection between Core Router 01 and Web Application Server 01."@en ;
    noria:networkLinkId "NL-RTR-WEB-01" ;
    noria:networkLinkTerminationResourceOrigin <ResourceRouter01> ;
    noria:networkLinkTerminationResourceDestination <ResourceWebApp01> ;
    noria:networkLinkInstallationDate "2023-02-10T09:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy <OrgUnitNOC> .

<NetworkLinkFirewall_LB> a noria:NetworkLink ;
    rdfs:label "Link between Firewall and Load Balancer"@en ;
    rdfs:comment "Connection between Perimeter Firewall 01 and Load Balancer 01."@en ;
    noria:networkLinkId "NL-FW-LB-01" ;
    noria:networkLinkTerminationResourceOrigin <ResourceFirewall01> ;
    noria:networkLinkTerminationResourceDestination <ResourceLoadBalancer01> ;
    noria:networkLinkInstallationDate "2022-03-01T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy <OrgUnitSOC> .

