# --- Agents and Organizations ---

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use ticketing system for all requests. For critical issues, call the hotline."@en ;
    foaf:mbox "dns-admin@example.com" .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en, "Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate escalation for P1 incidents. Follow runbook for P2/P3."@en ;
    foaf:phone "+1-800-NOC-HELP" .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en, "Équipe Support Application A"@fr ;
    rdfs:comment "Team responsible for the Customer Portal application."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    foaf:mbox "app-support-a@example.com" .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    foaf:mbox "soc@example.com" .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual member of the DNS Admin Team."@en ;
    foaf:holdsAccount noria:CUid1 .

foaf:Agent6 a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Individual member of the Network Operations Center."@en ;
    foaf:holdsAccount noria:CUid2 .

org:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en, "Département Infrastructure IT"@fr ;
    rdfs:comment "Department managing core IT infrastructure."@en ;
    org:hasMember foaf:Agent1, foaf:Agent2 .

org:OrgUnit2 a org:OrganizationalUnit ;
    rdfs:label "Application Development Department"@en, "Département Développement Applications"@fr ;
    rdfs:comment "Department responsible for developing and supporting business applications."@en ;
    org:hasMember foaf:Agent3 .

noria:CUid1 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "john.doe" ;
    observable:accountLogin "john.doe" ;
    observable:accountIdentifier "JD001" .

noria:CUid2 a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jane.smith" ;
    observable:accountLogin "jane.smith" ;
    observable:accountIdentifier "JS002" .

# --- Locations ---

bot:Site1 a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    rdfs:comment "Primary data center facility for corporate IT services."@en ;
    noria:siteId "DC-MAIN-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room1 a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "A dedicated room within the Main Data Center for server racks."@en ;
    bot:hasSpace bot:Site1 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack 1, Unit 10"@en, "Baie 1, Unité 10"@fr ;
    rdfs:comment "Specific location within Server Room A for a resource."@en ;
    noria:locusLine "Rack 1"@en ;
    noria:locusRow "Unit 10"@en ;
    bot:hasSpace noria:Room1 .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack 2, Unit 5"@en, "Baie 2, Unité 5"@fr ;
    rdfs:comment "Specific location within Server Room A for another resource."@en ;
    noria:locusLine "Rack 2"@en ;
    noria:locusRow "Unit 5"@en ;
    bot:hasSpace noria:Room1 .

