<TroubleTicketNoteDNSRestartAttempt_extra_node_3> a noria:TroubleTicketNote ;
    rdfs:label "DNS Server_extra_node_3 Restart Attempt Note"@en ;
    rdfs:comment "Attempted to restart DNS service, but it failed to come up."@en ;
