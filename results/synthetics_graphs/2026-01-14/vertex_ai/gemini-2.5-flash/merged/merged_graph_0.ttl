# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OP_RouterInterfaceBounce_extra_node_5 a noria:OperationPlan ;
    rdfs:label "Router_extra_node_5 Interface Bounce Procedure"@en ;
    rdfs:comment "Standard_extra_node_5 operating procedure to administratively shut down and then bring up a router interface."@en ;
    noria:operationPlanPreCondition noria:PreCond_InterfaceDown_extra_node_5 ;
    noria:operationPlanPostCondition noria:PostCond_InterfaceUp_extra_node_5 .

noria:PreCond_InterfaceDown_extra_node_5 a noria:ActionPreCondition ;
    rdfs:label "Interface is Administratively Down"@en ;
    rdfs:comment "Condition: The network interface's administrative status is 'down' or operational status is 'down'."@en ;
    skos:example "Check `noria:networkInterfaceAdministrativeStatus` or `noria:networkInterfaceOperationalStatus`."@en .

noria:PostCond_InterfaceUp_extra_node_5 a noria:ActionPostCondition ;
    rdfs:label "Interface is Up_extra_node_5 and Operational"@en ;
    rdfs:comment "Expected outcome: The network interface's administrative and operational statuses are 'up', and traffic flows normally."@en ;
    skos:example "Verify `noria:networkInterfaceAdministrativeStatus` and `noria:networkInterfaceOperationalStatus` are 'up'. Ping test to connected device successful."@en .

noria:OP_DBRestart_extra_node_5 a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Procedure for restarting the database service on DBSrv01."@en ;
    noria:operationPlanPreCondition noria:PreCond_AppError_extra_node_5 ;
    noria:operationPlanPostCondition noria:PostCond_AppRestored_extra_node_5 .

noria:PreCond_AppError_extra_node_5 a noria:ActionPreCondition ;
    rdfs:label "Application Reporting Errors"@en ;
    rdfs:comment "Condition: Application logs show database connection errors."@en ;
    skos:example "Monitor `noria:Event_App_Error_extra_node_5` type events."@en .

noria:PostCond_AppRestored_extra_node_5 a noria:ActionPostCondition ;
    rdfs:label "Application Functionality Restored"@en ;
    rdfs:comment "Expected outcome: Application logs show no more database errors, and users can access the intranet."@en ;
    skos:example "Verify application logs and user reports."@en .

noria:AnomalyPattern_HighLatency_extra_node_5 a noria:AnomalyPattern ;
    rdfs:label "High Network Latency Pattern"@en ;
    rdfs:comment "Pattern indicating high network latency, potentially leading to service degradation."@en ;
    skos:example "Repeated `noria:Event_App_Error_extra_node_5` events combined with high ping times between `noria:Resource_WebSrv01_extra_node_5` and `noria:Resource_DBSrv01_extra_node_5`."@en ;
    folio:hasCause noria:NL_WebDbLink_extra_node_5 . # Assuming high latency is a failure mode of the link

# Linking an EventRecord to an OperationPlan (as a proposed repair action)
noria:Event_NI_Down_extra_node_5 noria:alarmProposedRepairAction noria:OP_RouterInterfaceBounce_extra_node_5 .

# Linking a ChangeRequest to an OperationPlan (as the procedure guiding it)
noria:CR_RouterUpgrade_001_extra_node_5 noria:actionCorrelatedOperationPlan noria:OP_RouterOSUpgrade_extra_node_5 .

noria:OP_RouterOSUpgrade_extra_node_5 a noria:OperationPlan ;
    rdfs:label "Router_extra_node_5 OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the operating system of a network router."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterBackup_extra_node_5 ;
    noria:operationPlanPostCondition noria:PostCond_RouterOSUpdated_extra_node_5 .

noria:PreCond_RouterBackup_extra_node_5 a noria:ActionPreCondition ;
    rdfs:label "Router_extra_node_5 Configuration Backup Completed"@en ;
    rdfs:comment "Condition: A full backup of the router's configuration has been successfully completed and verified."@en .

noria:PostCond_RouterOSUpdated_extra_node_5 a noria:ActionPostCondition ;
    rdfs:label "Router_extra_node_5 OS Updated and Operational"@en ;
    rdfs:comment "Expected outcome: Router_extra_node_5 OS is updated to the target version, all interfaces are up, and routing protocols are stable."@en .

# Linking an EventRecord to a TroubleTicket (as a status history entry)
noria:TT_NetworkOutage_001_extra_node_5 noria:documentStatusHistory noria:Event_NI_Down_extra_node_5 .
noria:TT_NetworkOutage_001_extra_node_5 noria:documentStatusHistory noria:Event_NI_Up_AfterFix_extra_node_5 .

noria:Event_NI_Up_AfterFix_extra_node_5 a noria:EventRecord ;
    rdfs:label "Network Interface Up_extra_node_5 Event (After Fix)"@en ;
    rdfs:comment "Log entry indicating a network interface came up after troubleshooting."@en ;
    noria:loggingTime "2024-04-20T10:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01_extra_node_5 ;
    noria:logOriginatingManagementSystem noria:App_NetworkInfra_extra_node_5 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe_extra_node_5 ;
    noria:logText "LINEPROTO-5-UP: Interface GigabitEthernet0/0/1, changed state to up"@en ;
    dcterms:type <kos/Notification/EventType/stateChange_extra_node_5> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational_extra_node_5> ;
    noria:alarmMitigatedBy noria:TT_NetworkOutage_001_extra_node_5 . # The TT container represents the actions taken

# Linking a TroubleTicketNote to a correlated execution (if applicable)
# For simplicity, we'll link it to an EventRecord directly as the note describes an action that might generate a log.
noria:TTN_001_Note1_extra_node_5 noria:troubleTicketNoteCorrelatedExecution noria:Event_NI_Down_extra_node_5 .

# Ensure all entities are connected.
# I've tried to connect most entities to at least two others where logical,
# and ensured all created entities have at least one incoming or outgoing link.
# The use of `seas:subSystemOf`, `dcterms:isPartOf`, `noria:resourceForApplication`,
# `noria:applicationModuleOf`, `noria:troubleTicketRelatedService`, etc.,
# helps create a dense and connected graph.


# --- Knowledge Organization System (KOS) Concepts ---
# These are defined as skos:Concept instances within specific skos:ConceptScheme.
# For brevity and to avoid defining full SKOS schemes, we'll use direct URIs for these concepts.

# Application Types
<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application"@en ; rdfs:comment "An application providing core infrastructure services."@en .
<kos/application/type/service-platform_extra_node_4> a skos:Concept ; rdfs:label "Service Platform Application"@en ; rdfs:comment "An application acting as a platform for other services."@en .
<kos/application/type/business-application_extra_node_4> a skos:Concept ; rdfs:label "Business Application"@en ; rdfs:comment "An application directly supporting business operations."@en .

# Application Business Importance
<kos/application/business-importance/high_extra_node_4> a skos:Concept ; rdfs:label "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low Business Importance"@en .

# Application Status
<https://w3id.org/noria/kos/application/status/InProduction_extra_node_4> a skos:Concept ; rdfs:label "In Production"@en ; rdfs:comment "The application module is currently active and serving users."@en .
<https://w3id.org/noria/kos/application/status/Development_extra_node_4> a skos:Concept ; rdfs:label "In Development_extra_node_4"@en ; rdfs:comment "The application module is under active development."@en .
<https://w3id.org/noria/kos/application/status/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned"@en ; rdfs:comment "The application module has been retired from service."@en .

# Application SLA Level
<https://w3id.org/noria/kos/application/sla-level/Gold_extra_node_4> a skos:Concept ; rdfs:label "Gold_extra_node_4 SLA Level"@en ; rdfs:comment "Highest Service Level Agreement tier."@en .
<https://w3id.org/noria/kos/application/sla-level/Silver_extra_node_4> a skos:Concept ; rdfs:label "Silver_extra_node_4 SLA Level"@en ; rdfs:comment "Mid-tier Service Level Agreement."@en .

# Service Types
<kos/service/type/Customer_extra_node_4FacingService> a skos:Concept ; rdfs:label "Customer_extra_node_4 Facing Service"@en ; rdfs:comment "A service directly consumed by external customers."@en .
<kos/service/type/ResourceFacingService_extra_node_4> a skos:Concept ; rdfs:label "Resource Facing Service"@en ; rdfs:comment "A service that supports other services or internal operations."@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity/Critical_extra_node_4> a skos:Concept ; rdfs:label "Critical_extra_node_4 Severity"@en ; rdfs:comment "Incident causing severe business impact."@en .
<kos/TroubleTicket/severity/Major_extra_node_4> a skos:Concept ; rdfs:label "Major_extra_node_4 Severity"@en ; rdfs:comment "Incident causing significant business impact."@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en ; rdfs:comment "Incident causing limited business impact."@en .

# Trouble Ticket Type
<kos/TroubleTicket/type/Failure_extra_node_4> a skos:Concept ; rdfs:label "Failure_extra_node_4 Ticket"@en ; rdfs:comment "Ticket reporting a system failure."@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance Ticket"@en ; rdfs:comment "Ticket requesting user assistance."@en .

# Trouble Ticket Category
<kos/TroubleTicket/category/InterruptedService_extra_node_4> a skos:Concept ; rdfs:label "Interrupted Service"@en ; rdfs:comment "Service is completely unavailable."@en .
<kos/TroubleTicket/category/DowngradingEquipment_extra_node_4> a skos:Concept ; rdfs:label "Downgrading Equipment"@en ; rdfs:comment "Equipment performance is degraded."@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority/P1_extra_node_4> a skos:Concept ; rdfs:label "Priority 1"@en ; rdfs:comment "Highest priority, immediate action required."@en .
<kos/TroubleTicket/priority/P2_extra_node_4> a skos:Concept ; rdfs:label "Priority 2"@en ; rdfs:comment "High priority, urgent action required."@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin/Supervision_extra_node_4> a skos:Concept ; rdfs:label "Supervision_extra_node_4 System"@en ; rdfs:comment "Ticket originated from an automated monitoring system."@en .
<kos/TroubleTicket/origin/Customer_extra_node_4> a skos:Concept ; rdfs:label "Customer_extra_node_4 Report"@en ; rdfs:comment "Ticket reported by an external customer."@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention_extra_node_4> a skos:Concept ; rdfs:label "Immediate Intervention"@en ; rdfs:comment "Action required without delay."@en .
<kos/TroubleTicket/urgency/DeferredIntervention_extra_node_4> a skos:Concept ; rdfs:label "Deferred Intervention"@en ; rdfs:comment "Action can be scheduled later."@en .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks_extra_node_4> a skos:Concept ; rdfs:label "Managed Backbone Networks"@en ; rdfs:comment "Responsibility lies with the internal network team."@en .
<kos/TroubleTicket/problemResponsibility/Customer_extra_node_4> a skos:Concept ; rdfs:label "Customer_extra_node_4 Responsibility"@en ; rdfs:comment "Responsibility lies with the customer."@en .

# Trouble Ticket Status
<kos/TroubleTicket/status/InProgress_extra_node_4> a skos:Concept ; rdfs:label "In Progress"@en ; rdfs:comment "Ticket is actively being worked on."@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en ; rdfs:comment "Issue has been fixed, awaiting closure."@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en ; rdfs:comment "Ticket has been fully resolved and closed."@en .

# Trouble Ticket Comment Type
<kos/TroubleTicket/commentType/Internal_extra_node_4> a skos:Concept ; rdfs:label "Internal_extra_node_4 Comment"@en ; rdfs:comment "Comment visible only to internal teams."@en .
<kos/TroubleTicket/commentType/Customer_extra_node_4> a skos:Concept ; rdfs:label "Customer_extra_node_4 Comment"@en ; rdfs:comment "Comment visible to the customer."@en .

# Trouble Ticket Operation Type
<kos/TroubleTicket/operationType/Diagnosis_extra_node_4> a skos:Concept ; rdfs:label "Diagnosis_extra_node_4 Operation"@en ; rdfs:comment "Activity related to identifying the root cause."@en .
<kos/TroubleTicket/operationType/TestsAndMeasurements_extra_node_4> a skos:Concept ; rdfs:label "Tests and Measurements Operation"@en ; rdfs:comment "Activity involving testing and data collection."@en .

# Change Request Category
<kos/ChangeRequest/category/Internal_extra_node_4Intervention> a skos:Concept ; rdfs:label "Internal_extra_node_4 Intervention"@en ; rdfs:comment "Change initiated and performed internally."@en .
<kos/ChangeRequest/category/SoftwareUpgrade_extra_node_4> a skos:Concept ; rdfs:label "Software Upgrade"@en ; rdfs:comment "Change involving a software version update."@en .

# Change Request Type
<kos/ChangeRequest/type/Standard_extra_node_4> a skos:Concept ; rdfs:label "Standard_extra_node_4 Change"@en ; rdfs:comment "Pre-approved change with low risk."@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency Change"@en ; rdfs:comment "Urgent change required to restore service."@en .

# Change Request Cause
<kos/ChangeRequest/cause/Configuration_extra_node_4> a skos:Concept ; rdfs:label "Configuration_extra_node_4 Change"@en ; rdfs:comment "Change due to configuration modification."@en .
<kos/ChangeRequest/cause/PreventativeMaintenance_extra_node_4> a skos:Concept ; rdfs:label "Preventative Maintenance"@en ; rdfs:comment "Change performed to prevent future issues."@en .

# Change Request Status
<kos/ChangeRequest/status/Approved_extra_node_4> a skos:Concept ; rdfs:label "Approved_extra_node_4"@en ; rdfs:comment "Change request has been approved for implementation."@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented"@en ; rdfs:comment "Change has been successfully applied."@en .

# Change Request Specification
<kos/ChangeRequest/specification/Standard_extra_node_4ProcedureA_extra_node_4> a skos:Concept ; rdfs:label "Standard_extra_node_4 Procedure A"@en ; rdfs:comment "Reference to a documented standard operating procedure."@en .
<kos/ChangeRequest/specification/EmergencyProcedureB_extra_node_4> a skos:Concept ; rdfs:label "Emergency Procedure B"@en ; rdfs:comment "Reference to a documented emergency procedure."@en .

# Resource Operational State
<kos/Resource/OperationalState/Up_extra_node_4> a skos:Concept ; rdfs:label "Operational Up_extra_node_4"@en ; rdfs:comment "The resource is currently operating normally."@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Operational Down"@en ; rdfs:comment "The resource is currently not operating."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState/Up_extra_node_4> a skos:Concept ; rdfs:label "Administrative Up_extra_node_4"@en ; rdfs:comment "The resource is administratively enabled."@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Administrative Down"@en ; rdfs:comment "The resource is administratively disabled."@en .

# Resource Type
<kos/Resource/type/Router_extra_node_4> a skos:Concept ; rdfs:label "Router_extra_node_4"@en ; rdfs:comment "A network device that forwards data packets between computer networks."@en .
<kos/Resource/type/Server_extra_node_4> a skos:Concept ; rdfs:label "Server_extra_node_4"@en ; rdfs:comment "A computer program or a device that provides functionality for other programs or devices."@en .
<kos/Resource/type/Switch_extra_node_4> a skos:Concept ; rdfs:label "Switch_extra_node_4"@en ; rdfs:comment "A network device that connects devices in a computer network."@en .
<kos/Resource/type/VirtualMachine_extra_node_4> a skos:Concept ; rdfs:label "Virtual Machine"@en ; rdfs:comment "An emulation of a computer system."@en .
<kos/Resource/type/Firewall_extra_node_4> a skos:Concept ; rdfs:label "Firewall_extra_node_4"@en ; rdfs:comment "A network security system that monitors and controls incoming and outgoing network traffic."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InProduction_extra_node_4> a skos:Concept ; rdfs:label "In Production"@en ; rdfs:comment "The resource is actively used in the production environment."@en .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; rdfs:label "Staging"@en ; rdfs:comment "The resource is in a pre-production environment for testing."@en .

# Agent Contact Method
<kos/org/agent-contact-method/Email_extra_node_4> a skos:Concept ; rdfs:label "Email_extra_node_4"@en ; rdfs:comment "Preferred contact method is email."@en .
<kos/org/agent-contact-method/Phone_extra_node_4> a skos:Concept ; rdfs:label "Phone_extra_node_4"@en ; rdfs:comment "Preferred contact method is phone."@en .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical_extra_node_4> a skos:Concept ; rdfs:label "Critical_extra_node_4 Perceived Severity"@en ; rdfs:comment "Highest perceived severity for an event."@en .
<Notification/Severity/PerceivedSeverity/Major_extra_node_4> a skos:Concept ; rdfs:label "Major_extra_node_4 Perceived Severity"@en ; rdfs:comment "High perceived severity for an event."@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor Perceived Severity"@en ; rdfs:comment "Low perceived severity for an event."@en .

# --- Agents and Organizational Units ---
foaf:Agent_DNSAdminTeam_extra_node_4 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_4> ;
    noria:agentInstructions "Email_extra_node_4 dnsteam@example.com for non-urgent issues. Call hotline for critical outages."@en .

foaf:Agent_NetworkOps_extra_node_4 a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_4> ;
    noria:agentInstructions "Always call the NOC for network incidents."@en .

foaf:Agent_AppDevTeam_extra_node_4 a foaf:Agent ;
    rdfs:label "Application Development_extra_node_4 Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
