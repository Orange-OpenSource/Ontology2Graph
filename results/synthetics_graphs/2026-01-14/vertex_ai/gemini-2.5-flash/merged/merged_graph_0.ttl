# =============================================================================
# Procedural Elements
# =============================================================================

<OperationPlanDNSRestart_extra_node_3> a noria:OperationPlan ;
    rdfs:label "DNS Server_extra_node_3 Restart Procedure"@en, "Procédure de Redémarrage Serveur DNS"@fr ;
    rdfs:comment "Standard_extra_node_3 operating procedure for restarting a corporate DNS server."@en ;
    noria:operationPlanPreCondition <ActionPreConditionDNSServiceUnreachable_extra_node_3> ;
    noria:operationPlanPostCondition <ActionPostConditionDNSServiceReachable_extra_node_3> .

<ActionPreConditionDNSServiceUnreachable_extra_node_3> a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en, "Service DNS Inaccessible"@fr ;
    rdfs:comment "Condition: DNS service is not responding to queries."@en .

<ActionPostConditionDNSServiceReachable_extra_node_3> a noria:ActionPostCondition ;
    rdfs:label "DNS Service Reachable"@en, "Service DNS Accessible"@fr ;
    rdfs:comment "Outcome: DNS service is responding to queries and resolving names correctly."@en .

<OperationPlanFirewallDeployment_extra_node_3> a noria:OperationPlan ;
    rdfs:label "Firewall_extra_node_3 Rule Deployment Procedure"@en, "Procédure de Déploiement Règle Pare-feu"@fr ;
    rdfs:comment "Procedure for deploying new firewall rules on perimeter firewalls."@en ;
    noria:operationPlanPreCondition <ActionPreConditionNewRuleApproved_extra_node_3> ;
    noria:operationPlanPostCondition <ActionPostConditionTrafficVerified_extra_node_3> .

<ActionPreConditionNewRuleApproved_extra_node_3> a noria:ActionPreCondition ;
    rdfs:label "New Rule Set Approved_extra_node_3"@en, "Nouvel Ensemble de Règles Approuvé"@fr ;
    rdfs:comment "Condition: The new set of firewall rules has been formally approved."@en .

<ActionPostConditionTrafficVerified_extra_node_3> a noria:ActionPostCondition ;
    rdfs:label "Traffic Flow Verified"@en, "Flux de Trafic Vérifié"@fr ;
    rdfs:comment "Outcome: New traffic flows are correctly routed and filtered by the firewall."@en .

<AnomalyPatternHighCPUDiskSpace_extra_node_3> a noria:AnomalyPattern ;
    rdfs:label "High CPU and Low Disk Space Anomaly"@en, "Anomalie CPU Élevé et Espace Disque Faible"@fr ;
    rdfs:comment "Pattern indicating a potential performance issue or resource exhaustion, e.g., high_extra_node_3 CPU on web server combined with low disk space on database server."@en ;
    folio:hasCause <TroubleTicketCustomerPortalSlow_extra_node_3> .

<EventRecordWebAppHighCPU_extra_node_3> folio:hasFailureMode <AnomalyPatternHighCPUDiskSpace_extra_node_3> .
<EventRecordDBDiskSpace_extra_node_3> folio:hasFailureMode <AnomalyPatternHighCPUDiskSpace_extra_node_3> .


