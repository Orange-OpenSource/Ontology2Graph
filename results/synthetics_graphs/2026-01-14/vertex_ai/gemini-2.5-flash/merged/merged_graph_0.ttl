# --- Event Records ---
noria:EventRecord_DNSOutageLog_extra_node_4 a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_4 Outage Log"@en ;
    rdfs:comment "Log entry indicating a critical outage of the DNS server."@en ;
