    noria:logOriginatingManagedObject noria:Resource_DNS01_extra_node_4 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_4 ;
    noria:logText "CRITICAL: DNS service on dns01.corp.example.com is unreachable."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_4> .

noria:EventRecord_InterfaceDown_extra_node_4 a noria:EventRecord ;
    rdfs:label "Router_extra_node_4 Interface Down Event"@en ;
