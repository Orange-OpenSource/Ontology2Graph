# =============================================================================
# Event Records
# =============================================================================

noria:Event_NI_Down_extra_node_5 a noria:EventRecord ;
    rdfs:label "Network Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01_extra_node_5 ;
    noria:logOriginatingManagementSystem noria:App_NetworkInfra_extra_node_5 ;
    noria:logOriginatingAgent foaf:Agent_NetOpsTeam_extra_node_5 ; # Could be automated system, but here for example
    noria:logText "LINEPROTO-5-DOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    dcterms:type <kos/Notification/EventType/stateChange_extra_node_5> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_5> .

noria:Event_App_Error_extra_node_5 a noria:EventRecord ;
    rdfs:label "Application Error Log"@en ;
    rdfs:comment "Log entry indicating an error in the Corporate Intranet application."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01_extra_node_5 ;
    noria:logOriginatingManagementSystem noria:App_CorpIntranet_extra_node_5 ;
    noria:logText "Application error: Database connection failed for user 'jdoe'"@en ;
    dcterms:type <kos/Notification/EventType/ApplicationError_extra_node_5> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_5> .

noria:Event_Security_Alert_extra_node_5 a noria:EventRecord ;
    rdfs:label "Security Alert: Unauthorized Access Attempt"@en ;
    rdfs:comment "Security Information and Event Management (SIEM) alert for an unauthorized access attempt."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_EdgeRouter01_extra_node_5 ; # Assuming EdgeRouter01 is the point of detection
    noria:logOriginatingManagementSystem noria:App_SecurityMonitoring_extra_node_5 ; # A hypothetical security monitoring app
    noria:logText "Unauthorized access attempt detected from IP 203.0.113.42 on port 22"@en ;
    dcterms:type <kos/Notification/EventType/SecurityAlarm_extra_node_5> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_5> .

noria:App_SecurityMonitoring_extra_node_5 a noria:Application ;
    rdfs:label "Security Monitoring System"@en ;
