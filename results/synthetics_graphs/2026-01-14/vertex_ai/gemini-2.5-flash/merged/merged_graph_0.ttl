# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_IT_Operations_Team_extra_node_2 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure_extra_node_2 operations and incident response."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_2> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. For non-critical, open a ticket."@en .

foaf:Agent_Network_Admin_Team_extra_node_2 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Team managing network infrastructure_extra_node_2, including routers, switches, and firewalls."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_2> .

foaf:Agent_App_Dev_Team_extra_node_2 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development_extra_node_2 Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the core business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri" .

foaf:Agent_John_Doe_extra_node_2 a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com_extra_node_2> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_2> .

foaf:Agent_Jane_Smith_extra_node_2 a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Manager."@en ;
    foaf:mbox <mailto:jane.smith@example.com_extra_node_2> .

noria:CorporateUserIdentifier_JohnDoe_extra_node_2 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_John_Doe_extra_node_2 .

noria:CorporateUserIdentifier_JaneSmith_extra_node_2 a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_Jane_Smith_extra_node_2 .

