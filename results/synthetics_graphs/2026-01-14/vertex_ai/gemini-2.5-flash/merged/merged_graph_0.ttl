    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks_extra_node_1> ;
    noria:troubleTicketDetectionDateTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
