    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:resourceInstallationDate "2021-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_Corporate_Internet_Access_extra_node_2 ;
    noria:locatedAtLocus noria:Locus_Rack_B2_U5_extra_node_2 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_Core_Switch_01_extra_node_2 a noria:Resource ;
    rdfs:label "Core Switch_extra_node_2 01"@en ;
