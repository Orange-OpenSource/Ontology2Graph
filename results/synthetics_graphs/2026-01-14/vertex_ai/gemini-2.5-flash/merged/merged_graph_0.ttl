# --- Agents and Organizations ---

foaf:Agent1_extra_node_6 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_6> ;
    noria:agentInstructions "Use ticketing system for all requests. For critical issues, call the hotline."@en ;
    foaf:mbox "dns-admin@example.com" .

foaf:Agent2_extra_node_6 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en, "Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone_extra_node_6> ;
    noria:agentInstructions "Immediate escalation for P1_extra_node_6 incidents. Follow runbook for P2_extra_node_6/P3."@en ;
    foaf:phone "+1-800-NOC-HELP" .

foaf:Agent3_extra_node_6 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en, "Équipe Support Application A"@fr ;
    rdfs:comment "Team responsible for the Customer Portal application."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_6> ;
    foaf:mbox "app-support-a@example.com" .

foaf:Agent4_extra_node_6 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_6> ;
    foaf:mbox "soc@example.com" .

foaf:Agent5_extra_node_6 a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual member of the DNS Admin Team."@en ;
    foaf:holdsAccount noria:CUid1_extra_node_6 .

foaf:Agent6_extra_node_6 a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Individual member of the Network Operations Center."@en ;
    foaf:holdsAccount noria:CUid2_extra_node_6 .

org:OrgUnit1_extra_node_6 a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en, "Département Infrastructure IT"@fr ;
    rdfs:comment "Department managing core IT infrastructure."@en ;
    org:hasMember foaf:Agent1_extra_node_6, foaf:Agent2_extra_node_6 .

org:OrgUnit2_extra_node_6 a org:OrganizationalUnit ;
    rdfs:label "Application Development Department"@en, "Département Développement Applications"@fr ;
    rdfs:comment "Department responsible for developing and supporting business applications."@en ;
    org:hasMember foaf:Agent3_extra_node_6 .

noria:CUid1_extra_node_6 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "john.doe" ;
    observable:accountLogin "john.doe" ;
    observable:accountIdentifier "JD001" .

noria:CUid2_extra_node_6 a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
