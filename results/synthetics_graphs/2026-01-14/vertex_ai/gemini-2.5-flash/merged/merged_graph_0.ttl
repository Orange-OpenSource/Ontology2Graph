    rdfs:label "Hypervisor Cluster Controller"@en ;
    noria:resourceType <kos/Resource/type/Server_extra_node_2> ;
    noria:resourceHostName "vcenter.corp.example.com" .

noria:Resource_Virtual_Web_Server_extra_node_2
    noria:clusterController noria:Resource_Hypervisor_Cluster_Controller_extra_node_2 .

