noria:Resource_DNS_Server_01_extra_node_2 a noria:Resource ;
    rdfs:label "Corporate DNS Server_extra_node_2 01"@en ;
    rdfs:comment "Primary DNS server for corporate network resolution."@en ;
    noria:resourceManagedBy foaf:Agent_IT_Operations_Team_extra_node_2 ;
    noria:agentManagesResource foaf:Agent_IT_Operations_Team_extra_node_2 ; # Inverse property for density
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R740_extra_node_2 ;
    noria:resourceType <kos/Resource/type/Server_extra_node_2> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ789" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_2> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_Corporate_DNS_extra_node_2 ;
    noria:locatedAtLocus noria:Locus_Rack_A1_U10_extra_node_2 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

