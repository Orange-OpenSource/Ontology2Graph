noria:NetworkLink_DNS01_SW01_extra_node_2 a noria:NetworkLink ;
    rdfs:label "Link DNS01 to Core SW01"@en ;
    rdfs:comment "Ethernet link between DNS Server_extra_node_2 01 and Core Switch_extra_node_2 01."@en ;
