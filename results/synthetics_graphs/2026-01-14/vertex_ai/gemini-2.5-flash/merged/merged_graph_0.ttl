    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_4> .

foaf:Agent_SecurityTeam_extra_node_4 a foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security threats."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_4> .

foaf:Agent_JohnDoe_extra_node_4 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual network engineer."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_4> .

org:OrganizationalUnit_ITOperations_extra_node_4 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Overall department managing IT infrastructure and services."@en ;
    org:hasMember foaf:Agent_DNSAdminTeam_extra_node_4, foaf:Agent_NetworkOps_extra_node_4 .

org:OrganizationalUnit_NetworkSupport_extra_node_4 a org:OrganizationalUnit ;
    rdfs:label "Network Support Group"@en ;
    rdfs:comment "Specialized group within IT Operations for network issues."@en ;
    org:hasMember foaf:Agent_JohnDoe_extra_node_4 .

noria:CorporateUserIdentifier_JohnDoeCUid_extra_node_4 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe"@en ;
    observable:accountLogin "jdoe"@en ;
    observable:accountIdentifier "jdoe-corp-id-12345"@en .

foaf:Agent_JohnDoe_extra_node_4 foaf:holdsAccount noria:CorporateUserIdentifier_JohnDoeCUid_extra_node_4 .

