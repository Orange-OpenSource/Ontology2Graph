# --- Event Records ---

noria:EventRecord1_extra_node_6 a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_6 Down Alert"@en, "Alerte Serveur DNS Hors Service"@fr ;
    rdfs:comment "Alert generated by monitoring system indicating DNS server is unreachable."@en ;
    log:msg "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%"@en ;
    noria:loggingTime "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1_extra_node_6 ;
    noria:logOriginatingManagementSystem noria:Application1_extra_node_6 ;
    noria:logOriginatingAgent foaf:Agent2_extra_node_6 ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical_extra_node_6> ;
    noria:alarmProposedRepairAction noria:OperationPlan1_extra_node_6 ;
    noria:alarmMitigatedBy noria:TroubleTicket1_extra_node_6 .

noria:EventRecord2_extra_node_6 a noria:EventRecord ;
    rdfs:label "Web Server_extra_node_6 High CPU Alert"@en, "Alerte CPU Élevé Serveur Web"@fr ;
    rdfs:comment "Alert indicating high CPU utilization on the web application server."@en ;
    log:msg "WARNING: Host web01.app.example.com CPU utilization is 95% (threshold 90%)"@en ;
    noria:loggingTime "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2_extra_node_6 ;
    noria:logOriginatingManagementSystem noria:Application2_extra_node_6 ;
    noria:logOriginatingAgent foaf:Agent3_extra_node_6 ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major_extra_node_6> ;
    noria:alarmProposedRepairAction noria:OperationPlan2_extra_node_6 ;
    noria:alarmMitigatedBy noria:TroubleTicket2_extra_node_6 .

noria:EventRecord3_extra_node_6 a noria:EventRecord ;
    rdfs:label "Router_extra_node_6 Interface Flap Log"@en, "Log Flap Interface Routeur"@fr ;
    rdfs:comment "Log entry indicating an interface on Core Router_extra_node_6 01 flapped (went down and up)."@en ;
    log:msg "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:loggingTime "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3_extra_node_6 ;
    noria:logOriginatingManagementSystem noria:Application1_extra_node_6 ;
    noria:logOriginatingAgent foaf:Agent2_extra_node_6 ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Minor> ;
    noria:alarmMonitoredAttribute noria:NetworkInterface3_extra_node_6 .

# --- Change Requests ---

noria:ChangeRequest1_extra_node_6 a noria:ChangeRequest ;
    rdfs:label "DNS Server_extra_node_6 Upgrade"@en, "Mise à Jour Serveur DNS"@fr ;
    rdfs:comment "Upgrade the operating system and DNS software on the primary DNS server."@en ;
    dcterms:identifier "CR-20240423-001" ;
    dcterms:created "2024-04-23T11:45:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T12:15:00Z"^^xsd:dateTime ;
    dcterms:description "Planned upgrade of dns01.corp.example.com to resolve recurring stability issues. Requires a maintenance window."@en ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention_extra_node_6> ;
    noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/Standard_extra_node_6> ;
    noria:changeRequestChangeCause <https://w3id.org/noria/kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource1_extra_node_6, noria:ApplicationModule1_extra_node_6 ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Approved_extra_node_6> ;
    noria:changeRequestSpecification <https://w3id.org/noria/kos/ChangeRequest/specification/StandardProcedureA_extra_node_6> ;
    noria:changeRequestInitiatorParty foaf:Agent5_extra_node_6 ;
    noria:changeRequestPilotParty foaf:Agent1_extra_node_6 ;
    noria:changeRequestActorParty foaf:Agent5_extra_node_6 ;
    noria:changeRequestIsRegulated false ;
    noria:documentExternalId "PROJ-DNS-UPG-001" ;
    noria:documentHRef "https://itsm.example.com/cr/CR-20240423-001" .

noria:ChangeRequest2_extra_node_6 a noria:ChangeRequest ;
    rdfs:label "Customer Portal Database Optimization"@en, "Optimisation Base de Données Portail Client"@fr ;
    rdfs:comment "Perform database indexing and query optimization for Customer Portal."@en ;
    dcterms:identifier "CR-20240423-002" ;
    dcterms:created "2024-04-23T12:30:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T13:00:00Z"^^xsd:dateTime ;
    dcterms:description "Optimization of database queries and indexes on db01.app.example.com to improve Customer Portal performance."@en ;
    noria:changeRequestPlannedStartTime "2024-05-05T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-05T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention_extra_node_6> ;
    noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/Standard_extra_node_6> ;
    noria:changeRequestChangeCause <https://w3id.org/noria/kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource4_extra_node_6, noria:ApplicationModule2_extra_node_6 ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Approved_extra_node_6> ;
    noria:changeRequestSpecification <https://w3id.org/noria/kos/ChangeRequest/specification/StandardProcedureA_extra_node_6> ;
    noria:changeRequestInitiatorParty foaf:Agent3_extra_node_6 ;
    noria:changeRequestPilotParty foaf:Agent3_extra_node_6 ;
    noria:changeRequestActorParty foaf:Agent3_extra_node_6 ;
    noria:changeRequestIsRegulated false ;
    noria:documentExternalId "PROJ-CPORTAL-DB-OPT-001" ;
    noria:documentHRef "https://itsm.example.com/cr/CR-20240423-002" .

# --- Operational Plans and Conditions ---

noria:OperationPlan1_extra_node_6 a noria:OperationPlan ;
    rdfs:label "DNS Server_extra_node_6 Failover Procedure"@en, "Procédure de Basculement Serveur DNS"@fr ;
    rdfs:comment "Standard_extra_node_6 operating procedure for failing over DNS services to a secondary server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1_extra_node_6 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1_extra_node_6 .

noria:OperationPlan2_extra_node_6 a noria:OperationPlan ;
    rdfs:label "Database Performance Tuning Guide"@en, "Guide d'Optimisation Performance Base de Données"@fr ;
    rdfs:comment "Guide for optimizing database performance, including indexing and query tuning."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2_extra_node_6 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2_extra_node_6 .

noria:ActionPreCondition1_extra_node_6 a noria:ActionPreCondition ;
    rdfs:label "DNS Secondary Server_extra_node_6 Active Check"@en, "Vérification Serveur DNS Secondaire Actif"@fr ;
    rdfs:comment "Verify that the secondary DNS server is operational and capable of handling queries before initiating failover."@en ;
    skos:example "Check DNS resolution from multiple clients to secondary DNS server."@en .

noria:ActionPostCondition1_extra_node_6 a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored Confirmation"@en, "Confirmation Restauration Résolution DNS"@fr ;
    rdfs:comment "Confirm that DNS resolution is fully restored and services are accessible after failover."@en ;
    skos:example "Verify DNS resolution from internal and external clients. Monitor application logs for DNS errors."@en .

noria:ActionPreCondition2_extra_node_6 a noria:ActionPreCondition ;
    rdfs:label "Database Load Monitoring"@en, "Surveillance Charge Base de Données"@fr ;
    rdfs:comment "Monitor database load and performance metrics before applying optimizations."@en ;
    skos:example "Collect baseline CPU, memory, and I/O metrics for the database server."@en .

noria:ActionPostCondition2_extra_node_6 a noria:ActionPostCondition ;
    rdfs:label "Database Performance Improvement Confirmation"@en, "Confirmation Amélioration Performance Base de Données"@fr ;
    rdfs:comment "Confirm that database performance has improved after applying optimizations."@en ;
    skos:example "Compare post-optimization CPU, memory, and I/O metrics with baseline. Verify application response times."@en .

# --- Anomaly Patterns ---

noria:AnomalyPattern1 a noria:AnomalyPattern ;
    rdfs:label "High Latency DNS Anomaly"@en, "Anomalie Latence DNS Élevée"@fr ;
    rdfs:comment "Pattern indicating unusually high latency for DNS queries, potentially leading to service degradation."@en ;
    skos:example "Multiple EventRecords showing DNS query timeouts and slow responses from DNS servers."@en .

noria:AnomalyPattern2 a noria:AnomalyPattern ;
    rdfs:label "Web Server_extra_node_6 CPU Spike Anomaly"@en, "Anomalie Pic CPU Serveur Web"@fr ;
    rdfs:comment "Pattern indicating sudden and sustained spikes in CPU utilization on web servers, impacting application responsiveness."@en ;
    skos:example "EventRecords showing CPU utilization exceeding 90% for more than 5 minutes, correlated with slow application response times."@en .

