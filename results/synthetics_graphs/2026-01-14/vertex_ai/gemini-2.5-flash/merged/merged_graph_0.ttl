# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_DNS01_Eth0_extra_node_2 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS Server_extra_node_2 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS_Server_01_extra_node_2 ;
    noria:networkInterfaceConnects noria:NetworkLink_DNS01_SW01_extra_node_2 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Uplink to Core Switch_extra_node_2 01" .

noria:NetworkInterface_EdgeRtr01_Gi0_0_1_extra_node_2 a noria:NetworkInterface ;
    rdfs:label "Edge Router_extra_node_2 01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Edge Router_extra_node_2 01 to ISP A."@en ;
    noria:networkInterfaceOf noria:Resource_Edge_Router_01_extra_node_2 ;
    noria:networkInterfaceConnects noria:NetworkLink_EdgeRtr01_ISP_A_extra_node_2 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceDescription "WAN link to ISP A" .

noria:NetworkInterface_EdgeRtr01_Gi0_0_2_extra_node_2 a noria:NetworkInterface ;
    rdfs:label "Edge Router_extra_node_2 01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting Edge Router_extra_node_2 01 to ISP B (backup)."@en ;
    noria:networkInterfaceOf noria:Resource_Edge_Router_01_extra_node_2 ;
    noria:networkInterfaceConnects noria:NetworkLink_EdgeRtr01_ISP_B_extra_node_2 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/down> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/down> ;
    noria:networkInterfaceRoutingPriorityMetric 200 ;
    noria:networkInterfaceDescription "Backup WAN link to ISP B" .

noria:NetworkInterface_CoreSw01_Gi1_0_1_extra_node_2 a noria:NetworkInterface ;
    rdfs:label "Core Switch_extra_node_2 01 GigabitEthernet 1/0/1"@en ;
    rdfs:comment "Interface connecting Core Switch_extra_node_2 01 to DNS Server_extra_node_2 01."@en ;
    noria:networkInterfaceOf noria:Resource_Core_Switch_01_extra_node_2 ;
    noria:networkInterfaceConnects noria:NetworkLink_DNS01_SW01_extra_node_2 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Downlink to DNS Server_extra_node_2 01" .

