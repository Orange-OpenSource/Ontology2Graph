bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_ServerHallA a noria:Room ;
    rdfs:label "Server Hall A"@en ;
    rdfs:comment "Main server hall within the Main Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    bot:hasSubSpace bot:Site_MainDC . # Assuming bot:hasSubSpace can link a room to its parent site

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Dedicated room for network equipment within the Main Data Center."@en ;
    bot:hasSpace noria:Locus_RackB1 ;
    bot:hasSubSpace bot:Site_MainDC .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Server Hall A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasSubSpace noria:Room_ServerHallA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of additional servers in Server Hall A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en ;
    bot:hasSubSpace noria:Room_ServerHallA .

noria:Locus_RackB1 a noria:Locus ;
    rdfs:label "Rack B1"@en ;
    rdfs:comment "Location of network devices in Network Room B."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "1"@en ;
    bot:hasSubSpace noria:Room_NetworkRoomB .

