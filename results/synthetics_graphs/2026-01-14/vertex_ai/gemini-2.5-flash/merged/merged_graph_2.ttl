# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_DNS_Service_Restart a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNS_Service_Stopped ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_Service_Running .

noria:ActionPreCondition_DNS_Service_Stopped a noria:ActionPreCondition ;
    rdfs:label "DNS Service Stopped Pre-Condition"@en ;
    rdfs:comment "Condition: DNS service (named) is not running on the server."@en .

noria:ActionPostCondition_DNS_Service_Running a noria:ActionPostCondition ;
    rdfs:label "DNS Service Running Post-Condition"@en ;
    rdfs:comment "Outcome: DNS service (named) is running and responding to queries."@en .

noria:OperationPlan_WAN_Failover a noria:OperationPlan ;
    rdfs:label "WAN Link Failover Procedure"@en ;
    rdfs:comment "Procedure to activate the backup WAN link in case of primary link failure."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_Primary_WAN_Down ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Backup_WAN_Active .

noria:ActionPreCondition_Primary_WAN_Down a noria:ActionPreCondition ;
    rdfs:label "Primary WAN Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: Primary WAN link is detected as down or degraded."@en .

noria:ActionPostCondition_Backup_WAN_Active a noria:ActionPostCondition ;
    rdfs:label "Backup WAN Link Active Post-Condition"@en ;
    rdfs:comment "Outcome: Backup WAN link is active and routing traffic."@en .

noria:AnomalyPattern_High_DNSError_Rate a noria:AnomalyPattern ;
    rdfs:label "High DNS Error Rate Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential DNS resolution issue, characterized by a sudden increase in DNS query failures."@en ;
    folio:hasCause noria:TroubleTicket_DNS_Outage_TT001 . # Example of linking to a cause

