    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade ;
    dcterms:format "image/png" .

# =============================================================================
# Additional Connections for Density
# =============================================================================

# Link EventRecords to TroubleTickets via documentStatusHistory
noria:TroubleTicket_InternetOutage noria:documentStatusHistory noria:EventRecord_RouterCore01_InterfaceDown .
noria:TroubleTicket_IntranetSlow noria:documentStatusHistory noria:EventRecord_AppServer01_CPUHigh .

# Link ChangeRequest to OperationPlan
noria:ChangeRequest_RouterUpgrade pep:usedProcedure noria:OperationPlan_RouterInterfaceTroubleshoot .

# Link TroubleTicketNote to correlated execution (if applicable)
# For simplicity, let's assume a hypothetical execution record for the interface bring-up
noria:EventRecord_InterfaceBringUp a noria:EventRecord ;
    rdfs:label "RouterCore01 Interface Bring-Up Command"@en ;
    noria:loggingTime "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Command executed: 'interface GigabitEthernet0/0/0; no shutdown'"@en .

noria:TroubleTicketNote_TT001_Note2 noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_InterfaceBringUp .

# Link an alarm to a proposed repair action
noria:EventRecord_RouterCore01_InterfaceDown noria:alarmProposedRepairAction noria:OperationPlan_RouterInterfaceTroubleshoot .

# Link an alarm to a mitigating action
noria:EventRecord_RouterCore01_InterfaceDown noria:alarmMitigatedBy noria:EventRecord_InterfaceBringUp .

# Link resources to applications
noria:Resource_AppServer01 noria:resourceForApplication noria:Application_CorpIntranet .
noria:Resource_VirtualMachineDB01 noria:resourceForApplication noria:Application_CorpIntranet .
noria:Resource_RouterCore01 noria:resourceForApplication noria:Application_MonitoringSystem .
noria:Resource_SwitchAccess01 noria:resourceForApplication noria:Application_MonitoringSystem .

# Link agents to resources they manage
foaf:Agent_NetOpsTeam noria:agentManagesResource noria:Resource_RouterCore01 .
foaf:Agent_NetOpsTeam noria:agentManagesResource noria:Resource_SwitchAccess01 .
foaf:Agent_AppDevTeam noria:agentManagesResource noria:Resource_AppServer01 .
foaf:Agent_AppDevTeam noria:agentManagesResource noria:Resource_VirtualMachineDB01 .

# Link application modules to their support teams
noria:ApplicationModule_IntranetProd noria:applicationModuleSupportGroup foaf:Agent_AppDevTeam .
noria:ApplicationModule_IntranetProd noria:applicationModuleHotlineGroup foaf:Agent_AppDevTeam .

# Example of a virtual server status
noria:Resource_VirtualMachineDB01 noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

# Example of network interface optical power
noria:NetworkInterface_RouterCore01_Gi0_0_0 noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "0"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

# Example of a resource being a cluster controller for another
noria:Resource_AppServer01 noria:clusterController noria:Resource_VirtualMachineDB01 .


