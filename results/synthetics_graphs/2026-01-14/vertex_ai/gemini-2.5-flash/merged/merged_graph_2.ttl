# --- Operational Plans and Conditions ---

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Failover Procedure"@en, "Procédure de Basculement Serveur DNS"@fr ;
    rdfs:comment "Standard operating procedure for failing over DNS services to a secondary server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Database Performance Tuning Guide"@en, "Guide d'Optimisation Performance Base de Données"@fr ;
    rdfs:comment "Guide for optimizing database performance, including indexing and query tuning."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Secondary Server Active Check"@en, "Vérification Serveur DNS Secondaire Actif"@fr ;
    rdfs:comment "Verify that the secondary DNS server is operational and capable of handling queries before initiating failover."@en ;
    skos:example "Check DNS resolution from multiple clients to secondary DNS server."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored Confirmation"@en, "Confirmation Restauration Résolution DNS"@fr ;
    rdfs:comment "Confirm that DNS resolution is fully restored and services are accessible after failover."@en ;
    skos:example "Verify DNS resolution from internal and external clients. Monitor application logs for DNS errors."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Database Load Monitoring"@en, "Surveillance Charge Base de Données"@fr ;
    rdfs:comment "Monitor database load and performance metrics before applying optimizations."@en ;
    skos:example "Collect baseline CPU, memory, and I/O metrics for the database server."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Database Performance Improvement Confirmation"@en, "Confirmation Amélioration Performance Base de Données"@fr ;
    rdfs:comment "Confirm that database performance has improved after applying optimizations."@en ;
    skos:example "Compare post-optimization CPU, memory, and I/O metrics with baseline. Verify application response times."@en .

# --- Anomaly Patterns ---

noria:AnomalyPattern1 a noria:AnomalyPattern ;
    rdfs:label "High Latency DNS Anomaly"@en, "Anomalie Latence DNS Élevée"@fr ;
    rdfs:comment "Pattern indicating unusually high latency for DNS queries, potentially leading to service degradation."@en ;
    skos:example "Multiple EventRecords showing DNS query timeouts and slow responses from DNS servers."@en .

noria:AnomalyPattern2 a noria:AnomalyPattern ;
    rdfs:label "Web Server CPU Spike Anomaly"@en, "Anomalie Pic CPU Serveur Web"@fr ;
    rdfs:comment "Pattern indicating sudden and sustained spikes in CPU utilization on web servers, impacting application responsiveness."@en ;
    skos:example "EventRecords showing CPU utilization exceeding 90% for more than 5 minutes, correlated with slow application response times."@en .

# --- Additional Connections for Density ---

noria:TroubleTicket1 noria:troubleTicketImpacts noria:Resource1, noria:ApplicationModule1, noria:Service1 .
