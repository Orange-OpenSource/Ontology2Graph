# =============================================================================
# Resources
# =============================================================================

noria:Resource_AppServer01 a noria:Resource ;
    rdfs:label "Application Server 01"@en, "Serveur d'Application 01"@fr ;
    rdfs:comment "Primary server hosting critical business applications."@en ;
    noria:resourceLogisticId "AS01-DC01-RKA1-U23" ;
    noria:resourceHostName "appserver01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-AS01-XYZ789" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en, "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceLogisticId "CR01-DC01-RKA2-U10" ;
    noria:resourceHostName "routercore01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR01-ABC123" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam ;
    noria:locatedAtLocus noria:Locus_RackA2_U10 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_SwitchAccess01 a noria:Resource ;
    rdfs:label "Access Switch 01"@en, "Commutateur d'Accès 01"@fr ;
    rdfs:comment "Access layer switch for Server Room A."@en ;
    noria:resourceLogisticId "ASW01-DC01-RKA2-U11" ;
    noria:resourceHostName "switchaccess01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoCatalyst9300 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-ASW01-DEF456" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam ;
    noria:locatedAtLocus noria:Locus_RackA2_U10 ; # Sharing a rack unit for simplicity
    noria:resourceManagementIPAddress "10.0.0.2" .

noria:Resource_VirtualMachineDB01 a noria:Resource ;
    rdfs:label "Database VM 01"@en, "Machine Virtuelle Base de Données 01"@fr ;
    rdfs:comment "Virtual machine hosting the main database for the Intranet application."@en ;
    noria:resourceHostName "dbvm01.corp.example.com" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:clusterController noria:Resource_AppServer01 ; # Assuming AppServer01 is also a hypervisor
    noria:resourceManagementIPAddress "10.0.0.11" .

# =============================================================================
# Network Interfaces and Links
# =============================================================================

noria:NetworkInterface_AppServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "AppServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Application Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_AppServer01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface_RouterCore01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to the internet gateway."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal network switch."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

noria:NetworkInterface_SwitchAccess01_Gi0_1 a noria:NetworkInterface ;
    rdfs:label "SwitchAccess01 GigabitEthernet 0/1"@en ;
    rdfs:comment "Interface connecting Access Switch 01 to Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_SwitchAccess01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkLink_CoreToAccess a noria:NetworkLink ;
    rdfs:label "Core to Access Link"@en ;
    rdfs:comment "Physical link between Core Router 01 and Access Switch 01."@en ;
    noria:networkLinkId "NL-CR01-ASW01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_SwitchAccess01 ;
    noria:networkLinkInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps"@en ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam .

noria:NetworkInterface_AppServer01_Eth0 noria:networkInterfaceConnects noria:NetworkLink_ServerToSwitch .
noria:NetworkInterface_SwitchAccess01_Gi0_1 noria:networkInterfaceConnects noria:NetworkLink_CoreToAccess .
noria:NetworkInterface_RouterCore01_Gi0_0_1 noria:networkInterfaceConnects noria:NetworkLink_CoreToAccess .

noria:NetworkLink_ServerToSwitch a noria:NetworkLink ;
    rdfs:label "Server to Switch Link"@en ;
    rdfs:comment "Physical link between AppServer01 and Access Switch 01."@en ;
    noria:networkLinkId "NL-AS01-ASW01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_AppServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_SwitchAccess01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps"@en ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam .

# =============================================================================
# Applications and Application Modules
