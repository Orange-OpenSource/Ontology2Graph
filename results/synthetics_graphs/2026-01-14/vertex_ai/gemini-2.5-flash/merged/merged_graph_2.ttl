    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord1 .

noria:TroubleTicketNote2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Steps for TT-20240423-001"@en, "Étapes de Résolution pour TT-20240423-001"@fr ;
    rdfs:comment "DNS service restored after failover. Investigating root cause on primary server."@en ;
    dcterms:created "2024-04-23T11:05:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent5 ;
    dcterms:description "Failover completed. DNS resolution confirmed working. Primary server still under investigation. Closing incident, opening CR for permanent fix."@en ;
    dcterms:isPartOf noria:TroubleTicket1 ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> .

