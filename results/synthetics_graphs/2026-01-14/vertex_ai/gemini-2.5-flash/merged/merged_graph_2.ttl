# --- KOS Concepts (Knowledge Organization System) ---
# These are defined as skos:Concept and grouped under skos:ConceptScheme.
# While the prompt implies they are just URIs, defining them explicitly adds to graph density and completeness.

# Application Types
<https://w3id.org/noria/kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<https://w3id.org/noria/kos/application/type/infrastructure> a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en, "Application d'Infrastructure"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<https://w3id.org/noria/kos/application/type/service-platform> a skos:Concept ;
    skos:prefLabel "Service Platform Application"@en, "Application Plateforme de Service"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<https://w3id.org/noria/kos/application/type/business-application> a skos:Concept ;
    skos:prefLabel "Business Application"@en, "Application Métier"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

# Application Business Importance
<https://w3id.org/noria/kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

<https://w3id.org/noria/kos/application/business-importance/high> a skos:Concept ;
    skos:prefLabel "High Business Importance"@en, "Importance Métier Élevée"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

<https://w3id.org/noria/kos/application/business-importance/medium> a skos:Concept ;
    skos:prefLabel "Medium Business Importance"@en, "Importance Métier Moyenne"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

# Application Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en, "En Production"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:prefLabel "In Development"@en, "En Développement"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

# Application SLA Level
<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying Service Level Agreement levels for applications."@en .

<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ;
    skos:prefLabel "Gold SLA Level"@en, "Niveau de SLA Or"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# Service Types
