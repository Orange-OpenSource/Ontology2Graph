# =============================================================================
# Organizational Units and Persons (Agents)
# =============================================================================

<OrgUnitInfraDept> a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en, "Département Infrastructure IT"@fr ;
    rdfs:comment "Department overseeing all IT infrastructure components."@en .

<OrgUnitAppDevDept> a org:OrganizationalUnit ;
    rdfs:label "Application Development Department"@en, "Département Développement Applicatif"@fr ;
    rdfs:comment "Department responsible for developing and maintaining business applications."@en .

<OrgUnitCustomerService> a org:OrganizationalUnit ;
    rdfs:label "Customer Service Department"@en, "Département Service Client"@fr ;
    rdfs:comment "Department handling customer inquiries and support."@en .

<OrgUnitDNSAdmin> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    org:unitOf <OrgUnitInfraDept> ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for routine, phone for critical issues."@en .

<OrgUnitNOC> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en, "Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure."@en ;
    org:unitOf <OrgUnitInfraDept> ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call the hotline for network incidents."@en .

<OrgUnitAppSupportA> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team A"@en, "Équipe Support Applicatif A"@fr ;
    rdfs:comment "Team supporting critical business applications."@en ;
    org:unitOf <OrgUnitAppDevDept> ;
    noria:agentWorkingHours "08:30-18:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use ticketing system for all requests."@en .

<OrgUnitSOC> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    org:unitOf <OrgUnitInfraDept> ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate phone call for any security alert."@en .

<OrgUnitDBAdmin> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Admin Team"@en, "Équipe Admin Base de Données"@fr ;
    rdfs:comment "Team managing corporate database systems."@en ;
    org:unitOf <OrgUnitAppDevDept> ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit change requests via the dedicated portal."@en .

<PersonJohnDoe> a foaf:Person ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead administrator for DNS services."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    org:memberOf <OrgUnitDNSAdmin> .

<CorporateUserIdentifierJohnDoe> a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "JD001" ;
    foaf:holdsAccount <PersonJohnDoe> .

<PersonJaneSmith> a foaf:Person ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Network engineer in the NOC."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    org:memberOf <OrgUnitNOC> .

<PersonPeterJones> a foaf:Person ;
    rdfs:label "Peter Jones"@en, "Pierre Dubois"@fr ;
