# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_IT_Operations_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. For non-critical, open a ticket."@en .

foaf:Agent_Network_Admin_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Team managing network infrastructure, including routers, switches, and firewalls."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_App_Dev_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the core business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri" .

foaf:Agent_John_Doe a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_Jane_Smith a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Manager."@en ;
    foaf:mbox <mailto:jane.smith@example.com> .

noria:CorporateUserIdentifier_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_John_Doe .

noria:CorporateUserIdentifier_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_Jane_Smith .

