    noria:resourceProductModel noria:ProductModel_Juniper_MX480 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC123" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_Corporate_Internet_Access ;
    noria:locatedAtLocus noria:Locus_Rack_B2_U5 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_Core_Switch_01 a noria:Resource ;
    rdfs:label "Core Switch 01"@en ;
    rdfs:comment "Central switch for internal network traffic."@en ;
