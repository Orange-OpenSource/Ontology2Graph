noria:Application_CorpIntranet a noria:Application ;
    rdfs:label "Corporate Intranet Portal"@en, "Portail Intranet d'Entreprise"@fr ;
    rdfs:comment "Web application providing internal company information and tools."@en ;
    noria:applicationModelIdentifier "INTRANET-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "C-INTRA" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/business-application> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Employee Productivity"@en ;
    noria:applicationFunctionalSubDomain "Internal Communications"@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceForApplication noria:Resource_AppServer01, noria:Resource_VirtualMachineDB01 .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Network Monitoring System"@en, "Système de Supervision Réseau"@fr ;
    rdfs:comment "Application for real-time monitoring of network devices and services."@en ;
    noria:applicationModelIdentifier "NMS-PROD" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/service-platform> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Network Monitoring"@en ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam .

noria:ApplicationModule_IntranetProd a noria:ApplicationModule ;
    rdfs:label "Intranet Production Module"@en, "Module Intranet Production"@fr ;
    rdfs:comment "Production instance of the Corporate Intranet Portal."@en ;
    noria:applicationModuleOf noria:Application_CorpIntranet ;
    noria:applicationModuleName "INTRANET-V2_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam foaf:Agent_AppDevTeam ;
    noria:applicationModuleAdministrationLeader foaf:Agent_JaneSmith ;
    noria:applicationModuleSupportTeam foaf:Agent_AppDevTeam ;
    noria:applicationModuleSupportLeader foaf:Agent_JaneSmith .

noria:ApplicationModule_IntranetDev a noria:ApplicationModule ;
    rdfs:label "Intranet Development Module"@en, "Module Intranet Développement"@fr ;
    rdfs:comment "Development instance of the Corporate Intranet Portal."@en ;
    noria:applicationModuleOf noria:Application_CorpIntranet ;
    noria:applicationModuleName "INTRANET-V2_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Silver> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleAdministrationTeam foaf:Agent_AppDevTeam .

# =============================================================================
# Services
# =============================================================================

noria:Service_CorpInternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en, "Service Accès Internet Entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet connectivity to corporate users."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_CorpIntranet ; # The intranet relies on internet access
    seas:subSystemOf noria:Application_MonitoringSystem ; # Monitoring system is part of the service delivery
    seas:subSystemOf noria:Resource_RouterCore01 ;
    seas:subSystemOf noria:Resource_SwitchAccess01 .

noria:Service_DatabaseBackend a noria:Service ;
    rdfs:label "Database Backend Service"@en, "Service Backend Base de Données"@fr ;
    rdfs:comment "Backend service providing database functionality for various applications."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Resource_VirtualMachineDB01 ;
    seas:subSystemOf noria:Resource_AppServer01 .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_AppServer01_CPUHigh a noria:EventRecord ;
    rdfs:label "AppServer01 CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Application Server 01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "CPU utilization on appserver01.corp.example.com exceeded 90% for 5 minutes."@en .

noria:EventRecord_RouterCore01_InterfaceDown a noria:EventRecord ;
    rdfs:label "RouterCore01 Interface Down"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T10:10:15Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en .

noria:EventRecord_AppServer01_LoginFailure a noria:EventRecord ;
    rdfs:label "AppServer01 Login Failure"@en ;
    rdfs:comment "Security event: repeated failed login attempts on AppServer01."@en ;
    noria:loggingTime "2024-04-20T10:12:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_AppServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent noria:CorporateUserIdentifier_JohnDoe ; # Example of a user attempting login
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Minor> ;
    noria:logText "Failed login attempt for user 'jdoe' from IP 192.168.1.100."@en .

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TroubleTicket_InternetOutage a noria:TroubleTicket ;
    rdfs:label "Corporate Internet Access Outage"@en, "Panne Accès Internet Entreprise"@fr ;
    rdfs:comment "Critical incident: Corporate internet access is completely down, impacting all business operations."@en ;
    dcterms:identifier "TT-20240420-001" ;
    dcterms:created "2024-04-20T10:11:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <https://w3id.org/noria/kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <https://w3id.org/noria/kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <https://w3id.org/noria/kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <https://w3id.org/noria/kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios NMS"@en ;
    noria:troubleTicketCategory <https://w3id.org/noria/kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketCause "Core Router 01 uplink interface down."@en ;
    noria:problemResponsibility <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:10:30Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_NetOpsTeam ;
    noria:troubleTicketRelatedService noria:Service_CorpInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_RouterCore01 ;
    noria:troubleTicketImpacts noria:Application_CorpIntranet ;
    noria:troubleTicketImpacts noria:Resource_AppServer01 ;
    noria:troubleTicketTrigger noria:EventRecord_RouterCore01_InterfaceDown ;
    noria:documentHRef "https://itsm.example.com/tickets/TT-20240420-001" .

noria:TroubleTicket_IntranetSlow a noria:TroubleTicket ;
    rdfs:label "Intranet Performance Degradation"@en, "Dégradation Performance Intranet"@fr ;
    rdfs:comment "Users report slow response times for the Corporate Intranet Portal."@en ;
    dcterms:identifier "TT-20240420-002" ;
    dcterms:created "2024-04-20T10:08:00Z"^^xsd:dateTime ;
