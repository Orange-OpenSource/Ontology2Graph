# Resource Administrative State Scheme
<https://w3id.org/noria/kos/Resource/AdministrativeState> a skos:ConceptScheme ; rdfs:label "Resource Administrative State Scheme"@en .
<https://w3id.org/noria/kos/Resource/AdministrativeState/Up> a skos:Concept ; skos:prefLabel "Administrative State Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .
<https://w3id.org/noria/kos/Resource/AdministrativeState/Down> a skos:Concept ; skos:prefLabel "Administrative State Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .

# Resource Type Scheme
<https://w3id.org/noria/kos/Resource/type> a skos:ConceptScheme ; rdfs:label "Resource Type Scheme"@en .
<https://w3id.org/noria/kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<https://w3id.org/noria/kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<https://w3id.org/noria/kos/Resource/type/Switch> a skos:Concept ; skos:prefLabel "Switch Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<https://w3id.org/noria/kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

# Resource Lifecycle State Scheme
<https://w3id.org/noria/kos/Resource/LifecycleState> a skos:ConceptScheme ; rdfs:label "Resource Lifecycle State Scheme"@en .
<https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:prefLabel "In Production Lifecycle State"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .
<https://w3id.org/noria/kos/Resource/LifecycleState/Staging> a skos:Concept ; skos:prefLabel "Staging Lifecycle State"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .

# Agent Contact Method Scheme
<https://w3id.org/noria/kos/org/agent-contact-method> a skos:ConceptScheme ; rdfs:label "Agent Contact Method Scheme"@en .
<https://w3id.org/noria/kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email Contact Method"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .
<https://w3id.org/noria/kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone Contact Method"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .

# Notification Perceived Severity Scheme
<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ; rdfs:label "Notification Perceived Severity Scheme"@en .
<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .
<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .
<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:prefLabel "Minor Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_NetOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for managing network infrastructure and services."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

foaf:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en, "Équipe Développement Application"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre Opérations Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the Network Operations Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Application Development Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> .

noria:CorporateUserIdentifier_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

