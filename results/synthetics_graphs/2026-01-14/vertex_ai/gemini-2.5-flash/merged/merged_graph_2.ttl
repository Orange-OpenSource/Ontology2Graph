# =============================================================================
# Event Records
# =============================================================================

<EventRecordDNSDown> a noria:EventRecord ;
    rdfs:label "DNS Server Down Alert"@en ;
    rdfs:comment "Alert indicating that the Corporate DNS Server 01 is unreachable."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <ResourceDNS01> ;
    noria:logOriginatingManagementSystem <ApplicationInternalMonitoringSystem> ;
    noria:logOriginatingAgent <OrgUnitNOC> ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <OperationPlanDNSRestart> .

<EventRecordWebAppHighCPU> a noria:EventRecord ;
    rdfs:label "High CPU on Web App Server"@en ;
    rdfs:comment "Warning alert for high CPU utilization on Web Application Server 01."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <ResourceWebApp01> ;
    noria:logOriginatingManagementSystem <ApplicationInternalMonitoringSystem> ;
    noria:logOriginatingAgent <OrgUnitAppSupportA> ;
    noria:logText "WARNING: CPU utilization on webapp01.corp.example.com is 95%" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<EventRecordFirewallRuleChange> a noria:EventRecord ;
    rdfs:label "Firewall Rule Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Perimeter Firewall 01."@en ;
    noria:loggingTime "2024-04-19T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <ResourceFirewall01> ;
    noria:logOriginatingManagementSystem <ApplicationInternalMonitoringSystem> ;
    noria:logOriginatingAgent <PersonAliceBrown> ;
    noria:logText "INFO: Firewall rule 'Allow_SSH_to_DMZ' added by admin_soc" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

<EventRecordDBDiskSpace> a noria:EventRecord ;
    rdfs:label "Database Server Disk Space Alert"@en ;
    rdfs:comment "Alert indicating low disk space on Database Server 01."@en ;
    noria:loggingTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <ResourceDB01> ;
    noria:logOriginatingManagementSystem <ApplicationInternalMonitoringSystem> ;
    noria:logOriginatingAgent <OrgUnitDBAdmin> ;
    noria:logText "CRITICAL: Disk space on /var/lib/mysql on db01.corp.example.com is 98% full" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<EventRecordDNSRestartAttempt> a noria:EventRecord ;
    rdfs:label "DNS Service Restart Command Log"@en ;
    rdfs:comment "Log of the command executed to restart DNS service."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <ResourceDNS01> ;
    noria:logOriginatingManagementSystem <ApplicationInternalMonitoringSystem> ;
    noria:logOriginatingAgent <PersonJohnDoe> ;
    noria:logText "Command 'systemctl restart named' executed on dns01.corp.example.com" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

# =============================================================================
# Trouble Tickets
# =============================================================================

<TroubleTicketDNSOutage> a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "DNS server unreachable causing internet access issues for corporate users."@en ;
    dcterms:identifier "TT-20240420-001" ;
    dcterms:created "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ;
    noria:troubleTicketCause "DNS service process crashed on dns01.corp.example.com" ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <OrgUnitNOC> ;
    noria:troubleTicketRelatedService <ApplicationCorporateInternetAccess> ;
    noria:troubleTicketRelatedResource <ResourceDNS01> ;
    noria:troubleTicketImpacts <ApplicationCorporateInternetAccess>, <ResourceDNS01> ;
    noria:troubleTicketTrigger <EventRecordDNSDown> ;
    noria:documentStatusHistory <EventRecordDNSDown>, <EventRecordDNSRestartAttempt> ;
    dcterms:relation <EventRecordDNSRestartAttempt> ; # Explicit relation for actions
    pep:usedProcedure <OperationPlanDNSRestart> .

<TroubleTicketCustomerPortalSlow> a noria:TroubleTicket ;
    rdfs:label "Customer Portal Slow Performance"@en, "Performance Lente Portail Client"@fr ;
    rdfs:comment "Customers reporting slow loading times on the portal, likely due to high CPU on web server."@en ;
    dcterms:identifier "TT-20240420-002" ;
    dcterms:created "2024-04-20T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/DegradedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ApplicationIssue> ;
    noria:troubleTicketCause "High CPU utilization on webapp01.corp.example.com impacting response times." ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <OrgUnitAppSupportA> ;
    noria:troubleTicketRelatedService <ServiceECommercePlatform> ;
    noria:troubleTicketRelatedResource <ResourceWebApp01> ;
    noria:troubleTicketImpacts <ServiceECommercePlatform>, <ResourceWebApp01> ;
    noria:troubleTicketTrigger <EventRecordWebAppHighCPU> ;
    noria:documentStatusHistory <EventRecordWebAppHighCPU>, <EventRecordDBDiskSpace> ;
    dcterms:relation <EventRecordDBDiskSpace> . # Disk space alert also related to this performance issue

<TroubleTicketNoteDNSRestartAttempt> a noria:TroubleTicketNote ;
    rdfs:label "DNS Server Restart Attempt Note"@en ;
    rdfs:comment "Attempted to restart DNS service, but it failed to come up."@en ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:description "Attempted 'systemctl restart named' on dns01.corp.example.com. Service failed to start. Investigating logs."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution <EventRecordDNSRestartAttempt> ;
    dcterms:isPartOf <TroubleTicketDNSOutage> .

# =============================================================================
# Change Requests
# =============================================================================

<ChangeRequestFirewallUpdate> a noria:ChangeRequest ;
    rdfs:label "Firewall Rule Update for New Service"@en, "Mise à Jour Règle Pare-feu pour Nouveau Service"@fr ;
    rdfs:comment "Adding new firewall rules to allow traffic for an upcoming service."@en ;
    dcterms:identifier "CR-20240419-001" ;
    dcterms:created "2024-04-18T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-19T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-19T16:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-19T14:03:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-19T15:10:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact <ResourceFirewall01>, <ApplicationCorporateInternetAccess> ;
    noria:changeRequestOutageDuration "PT0H0M0S"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardOperatingProcedure> ;
    noria:changeRequestInitiatorParty <PersonAliceBrown> ;
    noria:changeRequestPilotParty <OrgUnitSOC> ;
    noria:changeRequestActorParty <PersonAliceBrown> ;
    noria:changeRequestIsRegulated false ;
    noria:documentStatusHistory <EventRecordFirewallRuleChange> ;
    pep:usedProcedure <OperationPlanFirewallDeployment> .

<ChangeRequestDBUpgrade> a noria:ChangeRequest ;
    rdfs:label "Database Server OS Upgrade"@en, "Mise à Niveau OS Serveur Base de Données"@fr ;
    rdfs:comment "Planned operating system upgrade for the corporate database server."@en ;
    dcterms:identifier "CR-20240501-001" ;
    dcterms:created "2024-04-15T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/PreventativeMaintenance> ;
    noria:changeRequestImpact <ResourceDB01>, <ApplicationCustomerPortal> ;
    noria:changeRequestOutageDuration "PT2H0M0S"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardOperatingProcedure> ;
    noria:changeRequestInitiatorParty <PersonBobWhite> ;
    noria:changeRequestPilotParty <OrgUnitDBAdmin> ;
    noria:changeRequestActorParty <PersonBobWhite> ;
    noria:changeRequestIsRegulated true .

# =============================================================================
# Procedural Elements
# =============================================================================

<OperationPlanDNSRestart> a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en, "Procédure de Redémarrage Serveur DNS"@fr ;
    rdfs:comment "Standard operating procedure for restarting a corporate DNS server."@en ;
    noria:operationPlanPreCondition <ActionPreConditionDNSServiceUnreachable> ;
    noria:operationPlanPostCondition <ActionPostConditionDNSServiceReachable> .

<ActionPreConditionDNSServiceUnreachable> a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en, "Service DNS Inaccessible"@fr ;
    rdfs:comment "Condition: DNS service is not responding to queries."@en .

<ActionPostConditionDNSServiceReachable> a noria:ActionPostCondition ;
    rdfs:label "DNS Service Reachable"@en, "Service DNS Accessible"@fr ;
    rdfs:comment "Outcome: DNS service is responding to queries and resolving names correctly."@en .

<OperationPlanFirewallDeployment> a noria:OperationPlan ;
    rdfs:label "Firewall Rule Deployment Procedure"@en, "Procédure de Déploiement Règle Pare-feu"@fr ;
    rdfs:comment "Procedure for deploying new firewall rules on perimeter firewalls."@en ;
    noria:operationPlanPreCondition <ActionPreConditionNewRuleApproved> ;
    noria:operationPlanPostCondition <ActionPostConditionTrafficVerified> .

<ActionPreConditionNewRuleApproved> a noria:ActionPreCondition ;
    rdfs:label "New Rule Set Approved"@en, "Nouvel Ensemble de Règles Approuvé"@fr ;
    rdfs:comment "Condition: The new set of firewall rules has been formally approved."@en .

<ActionPostConditionTrafficVerified> a noria:ActionPostCondition ;
    rdfs:label "Traffic Flow Verified"@en, "Flux de Trafic Vérifié"@fr ;
    rdfs:comment "Outcome: New traffic flows are correctly routed and filtered by the firewall."@en .

<AnomalyPatternHighCPUDiskSpace> a noria:AnomalyPattern ;
    rdfs:label "High CPU and Low Disk Space Anomaly"@en, "Anomalie CPU Élevé et Espace Disque Faible"@fr ;
    rdfs:comment "Pattern indicating a potential performance issue or resource exhaustion, e.g., high CPU on web server combined with low disk space on database server."@en ;
    folio:hasCause <TroubleTicketCustomerPortalSlow> .

<EventRecordWebAppHighCPU> folio:hasFailureMode <AnomalyPatternHighCPUDiskSpace> .
<EventRecordDBDiskSpace> folio:hasFailureMode <AnomalyPatternHighCPUDiskSpace> .


# =============================================================================
# Organizational Entities (Agents, Organizations, Corporate User Identifiers)
# =============================================================================

# Agents (Teams and Individuals)
foaf:Agent_NetOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing and monitoring network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical incidents, use emergency hotline."@en .

foaf:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/InternalChat> ;
    noria:agentInstructions "Submit change requests via internal portal. For urgent issues, contact team lead."@en .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Report all security incidents immediately via dedicated channel."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, member of the Network Operations Team."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    org:memberOf foaf:Agent_NetOpsTeam .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer, member of the Application Development Team."@en ;
    noria:agentWorkingHours "9:30-18:30 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/InternalChat> ;
    org:memberOf foaf:Agent_AppDevTeam .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
