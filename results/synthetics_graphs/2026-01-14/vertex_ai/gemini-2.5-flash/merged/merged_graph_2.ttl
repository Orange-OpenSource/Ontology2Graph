# =============================================================================
# Further Interconnections and Density
# =============================================================================

# Link EventRecord to OperationPlan if it represents an action guided by it
noria:EventRecord_Config_Change_EdgeRtr01
    pep:usedProcedure noria:OperationPlan_WAN_Failover . # Assuming this config change was part of a failover procedure

# Link TroubleTicketNote to a correlated execution (e.g., a procedure execution container)
noria:TroubleTicketNote_DNS_Investigation
    noria:troubleTicketNoteCorrelatedExecution noria:TroubleTicket_DNS_Outage_TT001 . # The TT itself is a ProcedureExecutionContainer

# Link a Resource to an AnomalyPattern if it's susceptible to it
noria:Resource_DNS_Server_01
    seas:hasProperty noria:AnomalyPattern_High_DNSError_Rate . # Conceptual link, not a direct property in NORIA, but can be used for density.

# Example of a virtual server status
noria:Resource_Virtual_Web_Server a noria:Resource ;
    rdfs:label "Virtual Web Server 01"@en ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/up> ;
    noria:resourceForApplication noria:Application_Web_Portal .

# Example of a cluster controller
noria:Resource_Hypervisor_Cluster_Controller a noria:Resource ;
    rdfs:label "Hypervisor Cluster Controller"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceHostName "vcenter.corp.example.com" .

noria:Resource_Virtual_Web_Server
    noria:clusterController noria:Resource_Hypervisor_Cluster_Controller .

# Example of a more complex application module relationship
noria:ApplicationModule_Corporate_Internet_Access_Dev a noria:ApplicationModule ;
    rdfs:label "Corporate Internet Access Development Module"@en ;
    noria:applicationModuleOf noria:Application_Corporate_Internet_Access ;
    noria:applicationModuleName "CORP-IA_DEV" ;
    noria:applicationModuleIdentifier "DEV-02" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleAdministrationTeam foaf:Agent_Network_Admin_Team .

noria:Application_Corporate_Internet_Access
    seas:subSystemOf noria:ApplicationModule_Corporate_Internet_Access_Prod,
                     noria:ApplicationModule_Corporate_Internet_Access_Dev .

# Example of a service composed of multiple application modules
noria:Service_Unified_Communications a noria:Service ;
    rdfs:label "Unified Communications Service"@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule_Corporate_DNS_Prod,
                     noria:ApplicationModule_Corporate_Internet_Access_Prod .

# Example of an agent managing an application module
foaf:Agent_Jane_Smith
    noria:agentManagesResource noria:ApplicationModule_Corporate_DNS_Prod .

# Example of a resource being part of a service (indirectly via application)
noria:Resource_DNS_Server_01
    seas:subSystemOf noria:Service_Critical_Infrastructure_Support .

# Example of a network interface with optical power thresholds
noria:NetworkInterface_EdgeRtr01_Gi0_0_1
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -5 .

# Example of a trouble ticket note correlated with an event record
noria:TroubleTicketNote_WAN_Investigation a noria:TroubleTicketNote ;
    rdfs:label "WAN Link Investigation Note"@en ;
    rdfs:comment "Confirmed primary WAN link down. Initiating failover procedure."@en ;
    dcterms:created "2023-10-27T10:08:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_John_Doe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_WAN_Link_Degradation_TT002 ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_Interface_Down_EdgeRtr01 .

# Example of a change request impacting a network link
noria:ChangeRequest_WAN_Link_Optimization_CR003 a noria:ChangeRequest ;
    rdfs:label "WAN Link Optimization - CR003"@en ;
    rdfs:comment "Planned optimization of routing metrics on WAN links."@en ;
    dcterms:identifier "CR-20231201-003" ;
    dcterms:created "2023-11-10T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2023-12-01T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2023-12-01T03:30:00Z"^^xsd:dateTime ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:NetworkLink_EdgeRtr01_ISP_A ;
    noria:changeRequestImpact noria:NetworkLink_EdgeRtr01_ISP_B ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent_John_Doe .

<kos/ChangeRequest/cause/Configuration> a skos:Concept ;
    rdfs:label "Configuration Change Cause"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .

# Example of an event record being mitigated by a procedure execution container (e.g., a change request)
noria:EventRecord_Interface_Down_EdgeRtr01
    noria:alarmMitigatedBy noria:ChangeRequest_Router_Firmware_CR001 . # Assuming the firmware upgrade fixed the instability causing interface flaps.

# Another event record for DNS service restored
noria:EventRecord_DNS_Service_Up a noria:EventRecord ;
    rdfs:label "DNS Service Up Event"@en ;
    rdfs:comment "Log entry indicating that the DNS service on DNS Server 01 has started."@en ;
    noria:loggingTime "2023-10-27T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS_Server_01 ;
    noria:logOriginatingManagementSystem noria:Application_NMS ;
    noria:logText "Service 'named' on dns01.corp.example.com is up." ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmMitigatedBy noria:TroubleTicket_DNS_Outage_TT001 .

noria:TroubleTicket_DNS_Outage_TT001
    noria:documentStatusHistory noria:EventRecord_DNS_Service_Up .

# Final state for DNS TT
noria:TroubleTicket_DNS_Outage_TT001
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    dcterms:modified "2023-10-27T10:25:00Z"^^xsd:dateTime .

# Example of a resource being decommissioned
noria:Resource_Old_Backup_Server a noria:Resource ;
    rdfs:label "Old Backup Server"@en ;
    rdfs:comment "Server scheduled for decommissioning."@en ;
    noria:resourceHostName "backup-old.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Decommissioned> ;
    noria:resourceManagedBy foaf:Agent_IT_Operations_Team .

# Example of a resource for multiple applications
noria:Resource_Shared_DB_Server a noria:Resource ;
    rdfs:label "Shared Database Server"@en ;
    rdfs:comment "Database server hosting multiple application databases."@en ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceForApplication noria:Application_Web_Portal ;
    noria:resourceForApplication noria:Application_Corporate_DNS . # Example of shared resource

# Example of an application module with a support group
noria:ApplicationModule_Corporate_DNS_Prod
    noria:applicationModuleSupportGroup foaf:Agent_IT_Operations_Team ; # Can be the same team or a different one
    noria:applicationModuleHotlineGroup foaf:Agent_IT_Operations_Team .

# Example of an agent with a corporate user identifier
foaf:Agent_John_Doe
    foaf:holdsAccount noria:CorporateUserIdentifier_JohnDoe .

foaf:Agent_Jane_Smith
    foaf:holdsAccount noria:CorporateUserIdentifier_JaneSmith .

# Example of a trouble ticket with a freeze item (represented by an event record)
noria:EventRecord_TT_Freeze_Start a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Start"@en ;
    noria:loggingTime "2023-10-27T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20231027-002 frozen due to external dependency." ;
    noria:logOriginatingManagementSystem noria:Application_NMS .

noria:TroubleTicket_WAN_Link_Degradation_TT002
    noria:troubleTicketFreezeItem noria:EventRecord_TT_Freeze_Start .

# Example of a trouble ticket with a characteristic (not explicitly defined as a class, but can be a blank node or literal)
noria:TroubleTicket_DNS_Outage_TT001
    noria:troubleTicketCharacteristic "Impacted Customer Segment: All Internal Users"@en .

# Example of a change request specification
<kos/ChangeRequest/specification/StandardRouterUpgrade> a skos:Concept ;
    rdfs:label "Standard Router Upgrade Specification"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> .

noria:ChangeRequest_Router_Firmware_CR001
    noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardRouterUpgrade> .

