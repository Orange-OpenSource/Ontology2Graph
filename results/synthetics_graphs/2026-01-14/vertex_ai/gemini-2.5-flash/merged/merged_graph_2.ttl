noria:Resource_DNS_Server_01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network resolution."@en ;
    noria:resourceManagedBy foaf:Agent_IT_Operations_Team ;
    noria:agentManagesResource foaf:Agent_IT_Operations_Team ; # Inverse property for density
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ789" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_Corporate_DNS ;
    noria:locatedAtLocus noria:Locus_Rack_A1_U10 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

