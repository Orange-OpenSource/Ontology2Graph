    seas:subSystemOf noria:AppMod_RoutingService .

# =============================================================================
# Event Records
# =============================================================================

noria:Event_NI_Down a noria:EventRecord ;
    rdfs:label "Network Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_NetworkInfra ;
    noria:logOriginatingAgent foaf:Agent_NetOpsTeam ; # Could be automated system, but here for example
    noria:logText "LINEPROTO-5-DOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_App_Error a noria:EventRecord ;
    rdfs:label "Application Error Log"@en ;
    rdfs:comment "Log entry indicating an error in the Corporate Intranet application."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_CorpIntranet ;
    noria:logText "Application error: Database connection failed for user 'jdoe'"@en ;
    dcterms:type <kos/Notification/EventType/ApplicationError> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_Security_Alert a noria:EventRecord ;
    rdfs:label "Security Alert: Unauthorized Access Attempt"@en ;
    rdfs:comment "Security Information and Event Management (SIEM) alert for an unauthorized access attempt."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_EdgeRouter01 ; # Assuming EdgeRouter01 is the point of detection
    noria:logOriginatingManagementSystem noria:App_SecurityMonitoring ; # A hypothetical security monitoring app
    noria:logText "Unauthorized access attempt detected from IP 203.0.113.42 on port 22"@en ;
    dcterms:type <kos/Notification/EventType/SecurityAlarm> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:App_SecurityMonitoring a noria:Application ;
    rdfs:label "Security Monitoring System"@en ;
    rdfs:comment "Application for monitoring security events."@en ;
    noria:applicationModelIdentifier "SIEM-01" ;
    noria:applicationShortIdentifier "SIEM" ;
    noria:applicationType <kos/application/type/Security> ;
    noria:elementManagedBy foaf:Agent_SecurityTeam .

noria:Event_Config_Change a noria:EventRecord ;
    rdfs:label "Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on a network device."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterEdge01 ;
    noria:logOriginatingManagementSystem noria:App_NetworkInfra ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jdoe (10.0.0.1)"@en ;
    dcterms:type <kos/Notification/EventType/ConfigurationChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TT_NetworkOutage_001 a noria:TroubleTicket ;
    rdfs:label "Critical Network Outage - Core Router Interface Down"@en ;
    rdfs:comment "Incident reported due to a critical network interface going down on Core Router 01, impacting internet connectivity."@en ;
    dcterms:identifier "TT-20240420-001" ;
    dcterms:created "2024-04-20T10:06:00Z"^^xsd:dateTime ;
    dcterms:description "Core Router 01 interface Gi0/0/1 went down, causing a loss of internet connectivity for all users."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:Event_NI_Down ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Physical link failure or misconfiguration on Gi0/0/1."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_NetOpsTeam, foaf:Agent_JohnDoe ;
    noria:troubleTicketRelatedService noria:Service_InternetConnectivity ;
    noria:troubleTicketRelatedResource noria:Resource_RouterCore01, noria:Resource_RouterEdge01 ;
    noria:troubleTicketImpacts noria:App_NetworkInfra, noria:Service_InternetConnectivity .

noria:TT_IntranetDB_002 a noria:TroubleTicket ;
    rdfs:label "Intranet Database Connection Issues"@en ;
    rdfs:comment "Users reporting intermittent issues connecting to the corporate intranet database."@en ;
    dcterms:identifier "TT-20240420-002" ;
