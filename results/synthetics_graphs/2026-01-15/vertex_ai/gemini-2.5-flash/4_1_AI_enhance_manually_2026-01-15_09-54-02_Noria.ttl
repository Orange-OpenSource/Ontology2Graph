# =============================================================================
# 1. Agents and Organizations
# =============================================================================

# Organizational Units (Teams)
org:ITOperationsTeam a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en, "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For critical incidents, use the dedicated hotline after creating a P1 ticket."@en .

org:NetworkEngineeringTeam a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en, "Équipe Ingénierie Réseau"@fr ;
    rdfs:comment "Team responsible for network design, implementation, and advanced troubleshooting."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent requests. For urgent issues, escalate through IT Operations."@en .

org:ApplicationSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "8:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

org:SecurityOperationsCenter a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and analyzing security events."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

# Individual Agents
foaf:JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    org:memberOf org:NetworkEngineeringTeam ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior IT Operator."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    org:memberOf org:ITOperationsTeam ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:AliceJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Application Support Specialist for CRM."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    org:memberOf org:ApplicationSupportTeam .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:JaneSmith .

# =============================================================================
# 2. Product Models
