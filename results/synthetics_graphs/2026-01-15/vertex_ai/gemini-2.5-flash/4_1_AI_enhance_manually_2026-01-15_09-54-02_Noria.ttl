    rdfs:comment "Type-1 hypervisor for virtualized environments."@en ;
    noria:productManufacturedBy org:VMware .

org:DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en .

org:CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems"@en .

org:PaloAltoNetworks a org:Organization ;
    rdfs:label "Palo Alto Networks"@en .

org:VMware a org:Organization ;
    rdfs:label "VMware Inc."@en .

# =============================================================================
# 3. Locations
# =============================================================================

bot:DataCenterParis a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:OfficeLyon a bot:Site ;
    rdfs:label "Lyon Office"@en, "Bureau de Lyon"@fr ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace bot:DataCenterParis .

noria:Room_NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B"@en, "Local Réseau B"@fr ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace bot:OfficeLyon .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical servers in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5 a noria:Locus ;
    rdfs:label "Rack B5"@en ;
    rdfs:comment "Location of network switches in Network Closet B."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room_NetworkClosetB .

# =============================================================================
# 4. Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy org:ITOperationsTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-10T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network in Paris DC."@en ;
    noria:resourceManagedBy org:NetworkEngineeringTeam ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-15T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Primary firewall protecting the corporate network."@en ;
    noria:resourceManagedBy org:SecurityOperationsCenter ;
    noria:resourceHostName "fw-perimeter-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_PaloAltoFW ;
    noria:resourceLogisticId "ASSET-FW-001" ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.5" .

noria:Resource_VMHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "ESXi host running multiple virtual machines."@en ;
    noria:resourceManagedBy org:ITOperationsTeam ;
    noria:resourceHostName "vmhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-VMH-001" ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
    noria:resourceSerialNumber "SN-VMH01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-06-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.20" .

noria:Resource_CRM_VM a noria:Resource ;
    rdfs:label "CRM Application Virtual Machine"@en ;
    rdfs:comment "Virtual machine hosting the CRM application."@en ;
    noria:resourceManagedBy org:ApplicationSupportTeam ;
    noria:resourceHostName "crm-app-vm.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # Represents the VM itself, not the underlying hardware
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-15T13:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_VMHost01 ;
    noria:resourceManagementIPAddress "10.0.1.50" .

# =============================================================================
# 5. Network Interfaces and Links
# =============================================================================

# Network Interfaces for DNS01
noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01.corp.example.com:eth0"@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Management interface for DNS01."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_DNS01_Eth1 a noria:NetworkInterface ;
    rdfs:label "dns01.corp.example.com:eth1"@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Data interface for DNS01."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# Network Interfaces for RouterCore01
noria:NI_RouterCore01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "router-core-01:Gi0/0/0"@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to ISP A."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NI_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "router-core-01:Gi0/0/1"@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Internal LAN interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# Network Interfaces for Firewall01
noria:NI_Firewall01_Eth0 a noria:NetworkInterface ;
    rdfs:label "fw-perimeter-01:eth0"@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceDescription "External interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_Firewall01_Eth1 a noria:NetworkInterface ;
    rdfs:label "fw-perimeter-01:eth1"@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceDescription "Internal interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# Network Links
noria:NL_CoreRouter_DNS01 a noria:NetworkLink ;
    rdfs:label "Link between Core Router and DNS01"@en ;
    noria:networkLinkId "NL-CR01-DNS01" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01, noria:Resource_DNS01 ;
    noria:networkLinkInstallationDate "2022-03-10T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gi0_0_1, noria:NI_DNS01_Eth1 .

noria:NL_Firewall_CoreRouter a noria:NetworkLink ;
    rdfs:label "Link between Firewall and Core Router"@en ;
    noria:networkLinkId "NL-FW01-CR01" ;
    noria:networkLinkTerminationResource noria:Resource_Firewall01, noria:Resource_RouterCore01 ;
    noria:networkLinkInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects noria:NI_Firewall01_Eth1, noria:NI_RouterCore01_Gi0_0_1 .

noria:NL_VMHost_CoreRouter a noria:NetworkLink ;
    rdfs:label "Link between VM Host and Core Router"@en ;
    noria:networkLinkId "NL-VMH01-CR01" ;
    noria:networkLinkTerminationResource noria:Resource_VMHost01, noria:Resource_RouterCore01 ;
    noria:networkLinkInstallationDate "2022-06-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gi0_0_1 . # Assuming VMHost has an interface connected to the same LAN as DNS01 and Firewall

# =============================================================================
# 6. Applications and Application Modules
# =============================================================================

noria:Application_CorporateDNS a noria:Application ;
    rdfs:label "Corporate DNS Service"@en, "Service DNS d'Entreprise"@fr ;
    rdfs:comment "Provides name resolution for all internal corporate services."@en ;
    noria:applicationModelIdentifier "CORP-DNS" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "DNS-CORP" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Name Resolution" ;
    noria:resourceForApplication noria:Resource_DNS01 .

noria:Application_CRMSystem a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en, "Système de Gestion de la Relation Client"@fr ;
    rdfs:comment "Manages customer interactions and data."@en ;
    noria:applicationModelIdentifier "CRM-PROD" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "CRM-SYS" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Management" ;
    noria:applicationFunctionalSubDomain "Sales & Support" ;
    noria:resourceForApplication noria:Resource_CRM_VM .

noria:Application_MonitoringPlatform a noria:Application ;
    rdfs:label "IT Monitoring Platform"@en, "Plateforme de Supervision IT"@fr ;
    rdfs:comment "Collects metrics and logs from IT infrastructure."@en ;
    noria:applicationModelIdentifier "IT-MON" ;
    noria:applicationNumericalIdentifier 3001 ;
    noria:applicationShortIdentifier "MON-PLAT" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Monitoring & Alerting" .

noria:ApplicationModule_CorporateDNS_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en ;
    rdfs:comment "Production instance of the Corporate DNS service."@en ;
    noria:applicationModuleOf noria:Application_CorporateDNS ;
    noria:applicationModuleName "CORP-DNS_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam org:ITOperationsTeam ;
    noria:applicationModuleAdministrationLeader foaf:JaneSmith ;
    noria:applicationModuleSupportTeam org:ITOperationsTeam ;
    noria:applicationModuleSupportLeader foaf:JaneSmith ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:ApplicationModule_CRMSystem_Prod a noria:ApplicationModule ;
    rdfs:label "CRM System Production Module"@en ;
    rdfs:comment "Production instance of the CRM application."@en ;
    noria:applicationModuleOf noria:Application_CRMSystem ;
    noria:applicationModuleName "CRM-PROD_LIVE" ;
    noria:applicationModuleIdentifier "LIVE" ;
    noria:applicationModuleAdministrationTeam org:ApplicationSupportTeam ;
    noria:applicationModuleAdministrationLeader foaf:AliceJohnson ;
    noria:applicationModuleSupportTeam org:ApplicationSupportTeam ;
    noria:applicationModuleSupportLeader foaf:AliceJohnson ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-03-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:ApplicationModule_MonitoringPlatform_Prod a noria:ApplicationModule ;
    rdfs:label "Monitoring Platform Production Module"@en ;
    rdfs:comment "Production instance of the IT Monitoring Platform."@en ;
    noria:applicationModuleOf noria:Application_MonitoringPlatform ;
    noria:applicationModuleName "MON-PLAT_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam org:ITOperationsTeam ;
    noria:applicationModuleAdministrationLeader foaf:JaneSmith ;
    noria:applicationModuleSupportTeam org:ITOperationsTeam ;
    noria:applicationModuleSupportLeader foaf:JaneSmith ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Silver> ;
    noria:applicationModuleSlaLevelDate "2022-05-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

# =============================================================================
# 7. Services
# =============================================================================

noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en, "Service d'Accès Internet d'Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_CorporateDNS, noria:Application_MonitoringPlatform ;
    seas:subSystemOf noria:ApplicationModule_CorporateDNS_Prod, noria:ApplicationModule_MonitoringPlatform_Prod .

noria:Service_BusinessCriticalDataFlow a noria:Service ;
    rdfs:label "Business Critical Data Flow Service"@en ;
    rdfs:comment "End-to-end data path for critical business applications like CRM."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Application_CRMSystem ;
    seas:subSystemOf noria:ApplicationModule_CRMSystem_Prod .

# =============================================================================
# 8. Trouble Tickets
# =============================================================================

noria:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Primary DNS server (dns01.corp.example.com) is unreachable, impacting all corporate services."@en ;
    dcterms:identifier "TT-20240423-001" ;
    dcterms:created "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Hardware failure on network interface eth1 of dns01.corp.example.com."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:ITOperationsTeam, foaf:JaneSmith ;
    noria:troubleTicketRelatedService noria:Application_CorporateDNS, noria:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01, noria:NI_DNS01_Eth1 ;
    noria:troubleTicketImpacts noria:Application_CorporateDNS, noria:Service_InternetAccess, noria:Resource_DNS01 .

noria:TroubleTicket_CRMSlowPerformance a noria:TroubleTicket ;
    rdfs:label "CRM Slow Performance Report"@en ;
    rdfs:comment "Users report slow response times for the CRM application during peak hours."@en ;
    dcterms:identifier "TT-20240422-002" ;
    dcterms:created "2024-04-22T14:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/User> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "APM Tool" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/PerformanceDegradation> ;
    noria:troubleTicketCause "High CPU utilization on CRM application VM."@en ;
