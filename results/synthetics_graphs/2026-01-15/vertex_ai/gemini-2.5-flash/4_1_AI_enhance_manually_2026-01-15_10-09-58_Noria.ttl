noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Service Down Alert"@en ;
    rdfs:comment "Alert generated by monitoring system indicating DNS service is down on dns01."@en ;
    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logText "DNS service 'named' stopped on dns01.corp.example.com" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan1 .

noria:EventRecord2 a noria:EventRecord ;
