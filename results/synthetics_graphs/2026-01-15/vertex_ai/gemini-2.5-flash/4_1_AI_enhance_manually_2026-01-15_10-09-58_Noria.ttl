# =============================================================================
# Knowledge Organization Systems (KOS) - Concept Schemes and Concepts
# =============================================================================

# Application Type
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying application types."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/business-critical> a skos:Concept ;
    skos:prefLabel "Business Critical Application"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/monitoring> a skos:Concept ;
    skos:prefLabel "Monitoring Application"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/database> a skos:Concept ;
    skos:prefLabel "Database Application"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/web-service> a skos:Concept ;
    skos:prefLabel "Web Service Application"@en ;
    skos:inScheme <kos/application/type> .

