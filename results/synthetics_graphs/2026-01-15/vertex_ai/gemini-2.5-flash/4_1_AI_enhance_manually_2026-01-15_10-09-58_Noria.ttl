# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email dns-admin@example.com for critical issues."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "WebOps Team"@en ;
    rdfs:comment "Team responsible for web application deployment and operations."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline +1-800-WEB-OPS for immediate assistance."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Database Admin Team"@en ;
    rdfs:comment "Team managing corporate database systems."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the internal portal for database requests."@en .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 monitoring and first-level support for network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "All network alerts are automatically routed to the NOC."@en .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for Corporate Intranet."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent6 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Customer Support Representative."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Sat)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en ;
    rdfs:comment "Department responsible for all IT infrastructure."@en ;
    org:hasMember foaf:Agent5 .

org:OrgUnit2 a org:OrganizationalUnit ;
    rdfs:label "Customer Support Department"@en ;
    rdfs:comment "Department handling customer inquiries and issues."@en ;
    org:hasMember foaf:Agent6 .

noria:CorporateUserIdentifier1 a noria:CorporateUserIdentifier ;
    rdfs:label "johndoe_cuid"@en ;
    foaf:accountName "johndoe"@en ;
    foaf:holdsAccount foaf:Agent5 .

noria:CorporateUserIdentifier2 a noria:CorporateUserIdentifier ;
    rdfs:label "janesmith_cuid"@en ;
    foaf:accountName "janesmith"@en ;
    foaf:holdsAccount foaf:Agent6 .

