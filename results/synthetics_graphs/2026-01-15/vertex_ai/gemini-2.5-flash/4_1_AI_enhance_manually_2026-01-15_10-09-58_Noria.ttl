    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "DNS Service Restarted Log"@en ;
    rdfs:comment "Log entry confirming DNS service restart on dns01."@en ;
    noria:loggingTime "2023-10-26T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingAgent foaf:Agent1 ;
