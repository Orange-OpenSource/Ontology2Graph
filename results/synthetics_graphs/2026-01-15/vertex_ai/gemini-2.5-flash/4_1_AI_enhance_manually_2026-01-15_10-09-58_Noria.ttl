# =============================================================================
# Operation Plans and Procedural Elements
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a corporate DNS server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down Detected"@en ;
    rdfs:comment "Condition: DNS service is not responding on primary DNS server."@en ;
    skos:example "Monitoring alert for DNS service failure."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS service is responding and accessible."@en ;
    skos:example "DNS queries are resolving successfully, monitoring alerts cleared."@en .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Web Server Software Upgrade Procedure"@en ;
    rdfs:comment "Procedure for upgrading software on a production web server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Approved"@en ;
    rdfs:comment "Condition: A scheduled maintenance window has been approved for the upgrade."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Web Application Functionality Verified"@en ;
    rdfs:comment "Outcome: Web application is fully functional after upgrade."@en ;
    skos:example "All application tests passed, user access confirmed."@en .

noria:AnomalyPattern1 a noria:AnomalyPattern ;
    rdfs:label "DNS Resolution Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a DNS resolution failure, characterized by high DNS query timeouts and service unavailability."@en ;
    skos:example "Multiple EventRecords showing 'DNS timeout' from various clients, combined with 'DNS service stopped' on the DNS server."@en .

