    noria:loggingTime "2023-10-25T03:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingAgent foaf:Agent5 ;
    noria:logText "Apache HTTP Server updated to version 2.4.58." .

