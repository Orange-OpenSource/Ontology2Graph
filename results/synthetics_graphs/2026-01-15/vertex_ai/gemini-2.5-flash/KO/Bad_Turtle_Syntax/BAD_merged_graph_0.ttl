noria:Resource_VirtualWebSrv01 a noria:Resource ;
    rdfs:label "Virtual Web Server 01"@en ;
    rdfs:comment "Virtual machine hosting a web application, part of a cluster."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "web01.app.example.com" ;
