    rdfs:comment "Database Administrator responsible for critical databases."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_0> .

foaf:Agent_SecurityTeam_extra_node_0 a foaf:Agent ;
