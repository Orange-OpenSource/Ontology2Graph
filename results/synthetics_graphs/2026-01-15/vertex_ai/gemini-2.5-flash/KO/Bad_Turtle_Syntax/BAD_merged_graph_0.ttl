    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationShortIdentifier "CWEB" ;
    noria:applicationModelIdentifier "CWEB-V2" ;
    noria:applicationFunctionalDomain "Marketing" ;
    noria:applicationFunctionalSubDomain "Digital Presence" ;
    noria:resourceForApplication noria:Resource_WebSrv01 ;
    noria:resourceForApplication noria:Resource_Hypervisor01 .

noria:ApplicationModule_CorporateWebsite_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate Website Production Module"@en ;
    rdfs:comment "Production instance of the Corporate Website application, serving global traffic."@en ;
    noria:applicationModuleOf noria:Application_CorporateWebsite ;
    noria:applicationModuleName "CWEB_PROD" ;
    noria:applicationModuleIdentifier "CWEB-PROD-001" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
