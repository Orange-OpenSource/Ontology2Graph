    noria:logOriginatingManagedObject noria:Resource_CoreRouter01_extra_node_1 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_1 ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical_extra_node_1> ;
    noria:logText "Interface eth1 on cr01.paris.example.com changed state to down."@en ;
