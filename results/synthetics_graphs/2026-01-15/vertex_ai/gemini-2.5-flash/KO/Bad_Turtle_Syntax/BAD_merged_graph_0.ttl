    noria:networkLinkId "LINK-LAN-001" ;
    noria:networkLinkType "ethernet" ;
    noria:networkLinkInstallationDate "2021-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreSwitch01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Ge001 .

# =============================================================================
# 6. Applications and Application Modules
