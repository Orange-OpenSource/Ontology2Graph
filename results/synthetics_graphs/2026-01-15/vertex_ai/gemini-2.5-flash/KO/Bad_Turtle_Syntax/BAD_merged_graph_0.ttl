    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationModelIdentifier "CIA-V1" ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Gateway" ;
    noria:resourceForApplication noria:Resource_RouterCore01 ;
    noria:resourceForApplication noria:Resource_CoreSwitch01 .

noria:ApplicationModule_CorpInternetAccess_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate Internet Access Production Module"@en, "Module Production Accès Internet Entreprise"@fr ;
