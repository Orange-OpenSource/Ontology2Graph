noria:NetworkInterface_RouterDC01_Eth0 a noria:NetworkInterface ;
    rdfs:label "RouterDC01 Ethernet0/0"@en ;
    rdfs:comment "Physical interface on RouterDC01 connected to the internal network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterDC01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterDC01_Eth1 a noria:NetworkInterface ;
    rdfs:label "RouterDC01 Ethernet0/1"@en ;
    rdfs:comment "Physical interface on RouterDC01 connected to the DMZ firewall."@en ;
    noria:networkInterfaceOf noria:Resource_RouterDC01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

noria:NetworkInterface_FirewallDMZ_Eth0 a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ Ethernet0/0"@en ;
    rdfs:comment "Physical interface on FirewallDMZ connected to RouterDC01."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_FirewallDMZ_Eth1 a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ Ethernet0/1"@en ;
    rdfs:comment "Physical interface on FirewallDMZ connected to the public internet."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_SwitchBO01_Uplink a noria:NetworkInterface ;
    rdfs:label "SwitchBO01 Uplink Port"@en ;
    rdfs:comment "Uplink interface on SwitchBO01 connecting to the WAN."@en ;
    noria:networkInterfaceOf noria:Resource_SwitchBO01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkLink_DC01_DMZ_Link a noria:NetworkLink ;
    rdfs:label "Data Center to DMZ Link"@en ;
    rdfs:comment "High-speed link between the core router and the DMZ firewall."@en ;
    noria:networkLinkId "LINK-DC01-DMZ" ;
    noria:networkLinkTerminationResource noria:Resource_RouterDC01 ;
    noria:networkLinkTerminationResource noria:Resource_FirewallDMZ ;
    noria:networkLinkInstallationDate "2021-08-01T16:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy foaf:Agent_NetworkAdmin ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterDC01_Eth1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_FirewallDMZ_Eth0 .

noria:NetworkLink_BO01_WAN_Link a noria:NetworkLink ;
    rdfs:label "Branch Office to WAN Link"@en ;
    rdfs:comment "WAN link connecting the Paris branch office to the corporate network."@en ;
    noria:networkLinkId "LINK-BO01-WAN" ;
    noria:networkLinkTerminationResource noria:Resource_SwitchBO01 ;
    noria:networkLinkInstallationDate "2023-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN" ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_SwitchBO01_Uplink .

