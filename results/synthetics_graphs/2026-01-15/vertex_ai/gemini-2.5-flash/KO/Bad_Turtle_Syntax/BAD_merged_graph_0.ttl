# Organizations
noria:Org_IT_Department_extra_node_1 a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department responsible for all IT operations."@en ;
    org:hasUnit noria:OrgUnit_WebOpsTeam_extra_node_1, noria:OrgUnit_DBATeam_extra_node_1, noria:OrgUnit_NetworkTeam_extra_node_1, noria:OrgUnit_SecurityTeam_extra_node_1 .

noria:OrgUnit_WebOpsTeam_extra_node_1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Web Operations Team"@en ;
    rdfs:comment "Team responsible for the deployment and operation of web applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en ;
    org:unitOf noria:Org_IT_Department_extra_node_1 .

noria:OrgUnit_DBATeam_extra_node_1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for managing and maintaining database systems."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "All database-related requests must go through the dedicated service portal."@en ;
    org:unitOf noria:Org_IT_Department_extra_node_1 .

noria:OrgUnit_NetworkTeam_extra_node_1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone_extra_node_1> ;
    noria:agentInstructions "For network outages, call the emergency number immediately. Otherwise, open a ticket."@en ;
    org:unitOf noria:Org_IT_Department_extra_node_1 .

noria:OrgUnit_SecurityTeam_extra_node_1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Report all security incidents via the dedicated security incident platform."@en ;
    org:unitOf noria:Org_IT_Department_extra_node_1 .

