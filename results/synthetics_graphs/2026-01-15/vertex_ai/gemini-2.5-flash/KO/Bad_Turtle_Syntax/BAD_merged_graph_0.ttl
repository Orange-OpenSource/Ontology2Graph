foaf:Agent_NetOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call emergency hotline for critical issues."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

foaf:Agent_DBA_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe (DBA)"@en ;
    rdfs:comment "Database Administrator responsible for critical databases."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

org:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department of the company."@en .

org:OrgUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Organizational unit for network operations."@en ;
    org:unitOf org:Org_ITDepartment ;
    org:member foaf:Agent_NetOpsTeam .

org:OrgUnit_AppSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support Unit"@en ;
    rdfs:comment "Organizational unit for application support."@en ;
    org:unitOf org:Org_ITDepartment ;
    org:member foaf:Agent_AppDevTeam .

noria:CorporateUserIdentifier_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount foaf:Agent_DBA_JohnDoe .

