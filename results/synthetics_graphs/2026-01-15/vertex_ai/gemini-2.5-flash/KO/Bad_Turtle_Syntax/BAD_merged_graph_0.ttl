# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_AdminTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "IT Operations Admin Team"@en, "Équipe d'Administration des Opérations IT"@fr ;
    rdfs:comment "Team responsible for the overall IT infrastructure and core services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod kos-org-contact:Email_extra_node_3 ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, direct phone for critical incidents."@en ;
