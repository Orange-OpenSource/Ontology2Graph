noria:NetworkInterface_DNS01_Eth0_extra_node_4 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server, connected to the management network."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01_extra_node_4 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_4> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_4> ;
    noria:networkInterfaceDescription "Management interface for DNS01" ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -20 .

noria:NetworkInterface_RouterCore01_Ge000_extra_node_4 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface from RouterCore01 to ISP, providing external internet access."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01_extra_node_4 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_4> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_4> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -15 ;
    noria:networkInterfaceDescription "ISP Uplink" .

noria:NetworkInterface_RouterCore01_Ge001_extra_node_4 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Internal network interface from RouterCore01 to corporate LAN, connecting to CoreSwitch01."@en ;
