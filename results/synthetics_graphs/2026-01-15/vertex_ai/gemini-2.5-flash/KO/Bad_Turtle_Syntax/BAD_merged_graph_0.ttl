noria:Resource_DNS01_extra_node_3 noria:virtualServerStatus kos-res-op:Running_extra_node_3 .
noria:Resource_WebSrv01_extra_node_3 noria:virtualServerStatus kos-res-op:Running_extra_node_3 .

noria:NetworkInterface_Router01_Gig0_0_1_extra_node_3 noria:networkInterfaceLaserTxOpticalPower -2 ;
