    noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer_InterfaceUp_extra_node_3 .

noria:ProcedureExecutionContainer_InterfaceUp_extra_node_3 a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution for bringing interface up"@en ;
    rdfs:comment "Container for actions taken to bring up the network interface."@en ;
    pep:hasMember noria:EventRecord_InterfaceUpCommand_extra_node_3 .

noria:EventRecord_InterfaceUpCommand_extra_node_3 a noria:EventRecord ;
    rdfs:label "Router Interface Up Command Log"@en ;
    noria:loggingTime "2024-04-20T09:28:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Router01_extra_node_3 ;
    noria:logOriginatingAgent foaf:Agent_NetworkTeam_extra_node_3 ;
    noria:logText "Command 'interface GigabitEthernet0/0/1;
     no shutdown' executed."@en ;
    

    pep:hasSimpleResult "Interface GigabitEthernet0/0/1 state changed to up."@en ;
    prov:wasAttributedTo foaf:Agent_NetworkTeam_extra_node_3 .

noria:ChangeRequest_DNSUpgrade_CR001_extra_node_3 a noria:ChangeRequest ;
    rdfs:label "DNS Software Upgrade - CR001"@en, "Mise à Jour Logiciel DNS - CR001"@fr ;
    dcterms:identifier "CR001" ;
    dcterms:created "2024-04-15T14:00:00Z"^^xsd:dateTime ;
    dcterms:description "Upgrade DNS server software to latest stable version for security patches and new features."@en ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory kos-cr-cat:InternalIntervention_extra_node_3 ;
    noria:changeRequestType kos-cr-type:Standard_extra_node_3 ;
    noria:changeRequestChangeCause kos-cr-cause:SoftwareUpgrade_extra_node_3 ;
    noria:changeRequestImpact noria:Resource_DNS01_extra_node_3, noria:Application_DNS_extra_node_3 ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    
    noria:changeRequestStatusCurrent kos-cr-status:Scheduled_extra_node_3 ;
    noria:changeRequestSpecification kos-cr-spec:StandardSoftwareUpgradeProcedure_extra_node_3 ;
    noria:changeRequestInitiatorParty foaf:Agent_AdminTeam_extra_node_3 ;
    noria:changeRequestPilotParty foaf:Agent_JohnDoe_extra_node_3 ;
    noria:changeRequestActorParty foaf:Agent_JohnDoe_extra_node_3 ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef "https://itsm.example.com/changes/CR001" .

noria:DocumentAttachment_CR001_Plan_extra_node_3 a noria:DocumentAttachment ;
    rdfs:label "DNS Upgrade Plan for CR001"@en ;
    rdfs:comment "Detailed plan for the DNS software upgrade, including rollback procedures."@en ;
    dcterms:isPartOf noria:ChangeRequest_DNSUpgrade_CR001_extra_node_3 ;
    dcterms:format "application/pdf" .

# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_RestartDNS_extra_node_3 a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en, "Procédure de Redémarrage du Service DNS"@fr ;
    rdfs:comment "Standard operating procedure for restarting the DNS service on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable_extra_node_3 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSRestored_extra_node_3 ;
    pep:hasInput noria:Resource_DNS01_extra_node_3 .

noria:OperationPlan_CheckCable_extra_node_3 a noria:OperationPlan ;
    rdfs:label "Network Cable Check Procedure"@en, "Procédure de Vérification de Câble Réseau"@fr ;
    rdfs:comment "Procedure to physically check and reseat network cables."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown_extra_node_3 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp_extra_node_3 .

noria:ActionPreCondition_DNSUnreachable_extra_node_3 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS server is not responding to queries or pings."@en ;
    skos:example "Ping to DNS server fails, DNS queries timeout."@en .

noria:ActionPostCondition_DNSRestored_extra_node_3 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS server is reachable and responding to queries."@en ;
    skos:example "Ping to DNS server succeeds, DNS queries resolve correctly."@en .

noria:ActionPreCondition_InterfaceDown_extra_node_3 a noria:ActionPreCondition ;
    rdfs:label "Network Interface Administratively Down"@en ;
    rdfs:comment "Condition: A network interface is reported as administratively down."@en ;
    skos:example "Router log shows 'LINEPROTO-5-UPDOWN: ... changed state to down'."@en .

noria:ActionPostCondition_InterfaceUp_extra_node_3 a noria:ActionPostCondition ;
    rdfs:label "Network Interface Operational"@en ;
    rdfs:comment "Outcome: The network interface is up and passing traffic."@en ;
    skos:example "Router log shows 'LINEPROTO-5-UPDOWN: ... changed state to up'."@en .

noria:AnomalyPattern_DNSFailure_extra_node_3 a noria:AnomalyPattern ;
    rdfs:label "DNS Service Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a DNS service failure, often correlated with network issues or resource overload."@en ;
    skos:example "Multiple DNS unreachable alerts from different monitoring points, combined with high CPU usage on the DNS server."@en ;
    folio:hasCause noria:TroubleTicket_DNSOutage_TT001_extra_node_3 .
