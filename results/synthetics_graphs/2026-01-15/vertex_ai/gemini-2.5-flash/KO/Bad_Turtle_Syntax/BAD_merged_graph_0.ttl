# =============================================================================
# Change Requests
# =============================================================================

noria:ChangeRequest_CR001 a noria:ChangeRequest ;
    rdfs:label "Firewall Rule Update for New Service"@en ;
    rdfs:comment "Request to add new firewall rules to allow traffic for a newly deployed internal service."@en ;
    dcterms:identifier "CR-20240419-001" ;
    dcterms:created "2024-04-18T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-19T16:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-19T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-19T16:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-19T15:20:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-19T15:45:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource_FirewallDMZ ;
    noria:changeRequestImpact noria:Service_InternetAccess ;
     # Impact on internet access security

    noria:changeRequestOutageDuration "PT0H0M0S"^^xsd:duration ;
     # No expected outage

    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkConfigurationUpdate> ;
    noria:changeRequestInitiatorParty foaf:Agent_AppDevTeam ;
    noria:changeRequestPilotParty foaf:Agent_NetworkAdmin ;
    noria:changeRequestActorParty foaf:Agent_NetworkAdmin ;
    noria:changeRequestIsRegulated false ;
    dcterms:relation noria:EventRecord_ConfigChange ;
     # Link to the event record of the change

    noria:documentHRef "https://changemanagement.example.com/CR-20240419-001" .

noria:ChangeRequest_CR002 a noria:ChangeRequest ;
    rdfs:label "Database Server OS Patching"@en ;
    rdfs:comment "Scheduled patching of the operating system on the Customer Portal database server."@en ;
    dcterms:identifier "CR-20240425-002" ;
    dcterms:created "2024-04-15T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-22T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-25T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/PreventativeMaintenance> ;
    noria:changeRequestImpact noria:Resource_DBServer01 ;
    noria:changeRequestImpact noria:ApplicationModule_CustomerPortal_Prod ;
    noria:changeRequestOutageDuration "PT0H30M0S"^^xsd:duration ;
     # Expected 30 min outage

    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent_ITOpsTeam ;
    noria:changeRequestPilotParty foaf:Agent_BobJohnson ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef "https://changemanagement.example.com/CR-20240425-002" .

# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_InterfaceTroubleshooting a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    noria:operationPlanPreCondition noria:PreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:PostCondition_InterfaceUp .

noria:PreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en ;
    skos:example "Check 'show interface status' command output for 'down' state."@en .

noria:PostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up' and traffic is flowing."@en ;
    skos:example "Verify 'show interface status' command output for 'up' state and ping connectivity."@en .

noria:OperationPlan_DBRestart a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting the database service on a server."@en ;
    noria:operationPlanPreCondition noria:PreCondition_DBErrors ;
    noria:operationPlanPostCondition noria:PostCondition_DBServiceRestored .

noria:PreCondition_DBErrors a noria:ActionPreCondition ;
    rdfs:label "Database Connection Errors Detected"@en ;
    rdfs:comment "Condition: Monitoring system reports high rate of database connection errors."@en .

noria:PostCondition_DBServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Database Service Restored"@en ;
    rdfs:comment "Expected outcome: Database service is running, and connection errors have ceased."@en .

noria:AnomalyPattern_HighTrafficLowLatency a noria:AnomalyPattern ;
    rdfs:label "High Traffic, Low Latency Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating an unusual combination of high network traffic with unexpectedly low latency, potentially suggesting a traffic bypass or misconfiguration."@en ;
    skos:example "Observed 10Gbps traffic on a link with 1ms latency, while historical data shows 5ms latency for similar traffic levels."@en .

noria:AnomalyPattern_DNSCachePoisoning a noria:AnomalyPattern ;
    rdfs:label "DNS Cache Poisoning Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating suspicious DNS query responses, potentially due to cache poisoning."@en ;
    skos:example "Multiple DNS queries for known legitimate domains returning incorrect IP addresses from internal DNS server."@en .

# =============================================================================
# Document Attachments
# =============================================================================

noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Data Center Network Diagram"@en ;
    rdfs:comment "PDF document containing the logical and physical network topology of the main data center."@en ;
    dcterms:isPartOf noria:TroubleTicket_TT001 ;
    dcterms:isPartOf noria:ChangeRequest_CR001 ;
    dcterms:format "application/pdf" ;
    dcterms:source "https://docs.example.com/network_diagram_dc01.pdf" .

noria:DocumentAttachment_PatchPlan a noria:DocumentAttachment ;
    rdfs:label "DB Server Patching Plan"@en ;
    rdfs:comment "Detailed plan for applying OS patches to the database server, including rollback procedures."@en ;
    dcterms:isPartOf noria:ChangeRequest_CR002 ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:source "https://docs.example.com/db_patch_plan.docx" .

# =============================================================================
# Further Interconnections for Density
# =============================================================================

# Link applications to resources they use
noria:Application_CustomerPortal noria:resourceForApplication noria:Resource_DBServer01 .
noria:Application_CustomerPortal noria:resourceForApplication noria:Resource_VirtualWebSrv01 .
noria:Application_MonitoringSystem noria:resourceForApplication noria:Resource_DNS01 .
noria:Application_MonitoringSystem noria:resourceForApplication noria:Resource_RouterDC01 .
noria:Application_MonitoringSystem noria:resourceForApplication noria:Resource_SwitchBO01 .
noria:Application_CorporateDNS noria:resourceForApplication noria:Resource_DNS01 .

# Link agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_ITOpsTeam noria:agentManagesResource noria:Resource_DNS01 .
foaf:Agent_ITOpsTeam noria:agentManagesResource noria:Resource_SwitchBO01 .
foaf:Agent_ITOpsTeam noria:agentManagesResource noria:Application_MonitoringSystem .
foaf:Agent_NetworkAdmin noria:agentManagesResource noria:Resource_RouterDC01 .
foaf:Agent_NetworkAdmin noria:agentManagesResource noria:NetworkLink_DC01_DMZ_Link .
foaf:Agent_AppDevTeam noria:agentManagesResource noria:Application_CustomerPortal .
foaf:Agent_SecurityTeam noria:agentManagesResource noria:Resource_FirewallDMZ .
foaf:Agent_BobJohnson noria:agentManagesResource noria:Resource_DBServer01 .

# Link TroubleTickets to EventRecords that are correlated
noria:TroubleTicket_TT001 dcterms:relation noria:EventRecord_ConfigChange . # Could be a previous config change that caused the issue
noria:TroubleTicket_TT002 dcterms:relation noria:EventRecord_ConfigChange . # Maybe a config change on firewall affected DB access

# Link EventRecords to procedures that mitigated them
noria:EventRecord_RouterDown noria:alarmMitigatedBy noria:TroubleTicket_TT001 . # The TT itself is a container for resolution actions
noria:EventRecord_DBError noria:alarmMitigatedBy noria:TroubleTicket_TT002 .

# Link ChangeRequests to related TroubleTickets (e.g., a CR to fix a recurring TT)
noria:ChangeRequest_CR002 dcterms:relation noria:TroubleTicket_TT002 . # Patching DB server to fix performance issue

# Link OperationPlans to AnomalyPatterns they might address
noria:OperationPlan_InterfaceTroubleshooting dcterms:relation noria:AnomalyPattern_HighTrafficLowLatency . # If high traffic causes interface issues
noria:OperationPlan_DBRestart dcterms:relation noria:AnomalyPattern_DNSCachePoisoning . # Unlikely, but for example, if DB issues are a symptom of a broader network problem.

# Example of a more complex relationship for a Service
noria:Service_InternetAccess seas:subSystemOf noria:ApplicationModule_MonitoringSystem_Main .
noria:Service_InternetAccess seas:subSystemOf noria:Application_CorporateDNS .

# Example of a resource being part of multiple applications/services
noria:Resource_FirewallDMZ noria:resourceForApplication noria:Application_CustomerPortal .
noria:Resource_FirewallDMZ noria:resourceForApplication noria:Application_CorporateDNS .

# Example of a resource having an observable property
noria:Resource_DNS01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Example of a NetworkInterface having a description
noria:NetworkInterface_RouterDC01_Eth0 noria:networkInterfaceDescription "Uplink to internal network segment 10.0.0.0/24" .

# Example of a NetworkLink having an origin and destination resource
noria:NetworkLink_DC01_DMZ_Link noria:networkLinkTerminationResourceOrigin noria:Resource_RouterDC01 .
noria:NetworkLink_DC01_DMZ_Link noria:networkLinkTerminationResourceDestination noria:Resource_FirewallDMZ .

# Example of a TroubleTicket having a characteristic (though noria:troubleTicketCharacteristic is an ObjectProperty, it's not explicitly defined as a class in the provided schema, so I'll use a blank node for a generic characteristic)
noria:TroubleTicket_TT001 noria:troubleTicketCharacteristic [
    rdfs:label "Impacted User Count" ;
    rdfs:comment "Estimated number of users affected by the outage." ;
    rdf:value "500"^^xsd:int
] .

# Example of a TroubleTicket freeze item (using EventRecord as per skos:example)
noria:TroubleTicket_TT001 noria:troubleTicketFreezeItem noria:EventRecord_TT001_FreezeStart .

noria:EventRecord_TT001_FreezeStart a noria:EventRecord ;
    rdfs:label "TT001 Freeze Start"@en ;
    rdfs:comment "Trouble ticket TT001 moved to 'Frozen' status due to external dependency."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "TT-20240420-001 status changed to Frozen" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:references noria:TroubleTicket_TT001 .

noria:TroubleTicket_TT001 noria:documentStatusHistory noria:EventRecord_TT001_FreezeStart .

# Example of a ChangeRequest being regulated
noria:ChangeRequest_CR002 noria:changeRequestIsRegulated true .

# Example of a ChangeRequest having an external ID
noria:ChangeRequest_CR001 noria:documentExternalId "JIRA-TASK-12345" .

# Example of an EventRecord being correlated to a TroubleTicketNote
noria:TroubleTicketNote_TT001_Note1 noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_RouterDown .



# =============================================================================
# KOS Concepts (Knowledge Organization System)
# These are defined as skos:Concept instances for use as property ranges.
# =============================================================================

<kos/application/type/infrastructure_extra_node_2> a skos:Concept ;
     rdfs:label "Infrastructure Application"@en .

<kos/application/type/business-critical_extra_node_2> a skos:Concept ;
     rdfs:label "Business Critical_extra_node_2 Application"@en .

<kos/application/type/monitoring_extra_node_2> a skos:Concept ;
     rdfs:label "Monitoring Application"@en .

<kos/application/type/database> a skos:Concept ;
     rdfs:label "Database Application"@en .


<kos/application/business-importance/high_extra_node_2> a skos:Concept ;
     rdfs:label "High Business Importance"@en .

<kos/application/business-importance/medium> a skos:Concept ;
     rdfs:label "Medium Business Importance"@en .

