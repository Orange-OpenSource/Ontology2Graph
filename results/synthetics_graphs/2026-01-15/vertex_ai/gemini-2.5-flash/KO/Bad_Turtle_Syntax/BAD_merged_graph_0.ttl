# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OperationPlan_DNS_Troubleshooting a noria:OperationPlan ;
    rdfs:label "DNS Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving DNS resolution issues."@en ;
    skos:example "Steps include checking server status, network connectivity, and DNS service health."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNS_Unreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_Resolved .

noria:ActionPreCondition_DNS_Unreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unreachable Pre-Condition"@en ;
    rdfs:comment "Condition where the DNS server is not responding to network requests."@en ;
    skos:example "Ping to DNS server IP fails, nslookup queries fail."@en .

noria:ActionPostCondition_DNS_Resolved a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Post-Condition"@en ;
    rdfs:comment "Condition where DNS resolution is fully functional."@en ;
    skos:example "Ping to DNS server IP succeeds, nslookup queries resolve correctly, all services dependent on DNS are operational."@en .

noria:OperationPlan_WebSrv_Upgrade a noria:OperationPlan ;
    rdfs:label "Web Server OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for performing an OS upgrade on web servers, including backup and rollback plans."@en ;
    skos:example "Includes pre-checks, upgrade execution, and post-validation steps."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebSrv_ReadyForUpgrade ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebSrv_UpgradedAndFunctional .

noria:ActionPreCondition_WebSrv_ReadyForUpgrade a noria:ActionPreCondition ;
    rdfs:label "Web Server Ready for Upgrade Pre-Condition"@en ;
    rdfs:comment "All prerequisites for OS upgrade are met, including backups and maintenance window approval."@en .

noria:ActionPostCondition_WebSrv_UpgradedAndFunctional a noria:ActionPostCondition ;
    rdfs:label "Web Server Upgraded and Functional Post-Condition"@en ;
    rdfs:comment "OS upgrade completed successfully, web server is operational and serving traffic."@en .

