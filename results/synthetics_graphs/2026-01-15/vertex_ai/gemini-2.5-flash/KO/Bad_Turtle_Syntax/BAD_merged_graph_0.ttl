# =============================================================================
# 7. Services
# =============================================================================

noria:Service_EnterpriseConnectivity a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en, "Service de Connectivité Entreprise"@fr ;
    rdfs:comment "End-to-end service providing network connectivity for the enterprise, composed of various network applications and resources."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_CorpInternetAccess .

noria:Service_PublicWebPresence a noria:Service ;
    rdfs:label "Public Web Presence Service"@en ;
    rdfs:comment "Service ensuring the availability of the corporate public website and related online services."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_CorporateWebsite .

# =============================================================================
# 8. Event Records
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Outage Log Entry"@en ;
    rdfs:comment "Log entry indicating a DNS server outage, detected by the monitoring system."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "DNS service on dns01.corp.example.com is unreachable. Process 'named' not running." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_DNS_Restart .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Event record for a critical network interface going down on Core Router 01, impacting connectivity."@en ;
    noria:loggingTime "2024-04-20T10:10:15Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Interface GigabitEthernet0/0/0 on router-core01 changed state to down." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:OperationPlan_InterfaceTroubleshoot .

noria:EventRecord_ConfigChange_JohnDoe a noria:EventRecord ;
    rdfs:label "Configuration Change by John Doe"@en ;
    rdfs:comment "Log entry for a configuration change made by John Doe on RouterCore01, recorded by the system."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Configuration changed: added static route 10.0.1.0/24 via 10.0.0.2." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord_TT_DNSOutage_StatusChange_InProgress a noria:EventRecord ;
    rdfs:label "DNS Outage TT Status Change to InProgress"@en ;
    rdfs:comment "Event recording the status change of DNS Outage Trouble Ticket to InProgress, managed by Jane Smith."@en ;
    noria:loggingTime "2024-04-20T10:16:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_JaneSmith ;
    noria:logText "Trouble Ticket TT-20240420-001 status changed to InProgress." .

noria:EventRecord_CR_RouterConfig_StatusChange_Approved a noria:EventRecord ;
    rdfs:label "Router Config CR Status Change to Approved"@en ;
    rdfs:comment "Event recording the status change of Router Configuration Change Request to Approved."@en ;
    noria:loggingTime "2024-04-18T16:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
     # Could be a Change Management System

    noria:logOriginatingAgent foaf:Agent_JaneSmith ;
    noria:logText "Change Request CR-20240415-001 status changed to Approved." .

# =============================================================================
# 9. Trouble Tickets
# =============================================================================

noria:TroubleTicket_DNSOutageTT a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "Critical incident regarding the corporate DNS server being unreachable, impacting all services."@en ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketRelatedService noria:Application_CorpInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty foaf:Agent_DNSAdminTeam ;
    noria:troubleTicketDescription "DNS server dns01.corp.example.com is down, impacting all internal and external services relying on DNS resolution."@en ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:documentExternalId "TT-20240420-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-20240420-001" ;
    noria:documentStatusHistory noria:EventRecord_TT_DNSOutage_StatusChange_InProgress ;
    noria:troubleTicketImpacts noria:Application_CorporateWebsite ;
     # DNS outage impacts website

    noria:troubleTicketImpacts noria:Service_PublicWebPresence .

noria:TroubleTicketNote_DNSOutage_Diag a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Diagnosis Note"@en ;
    rdfs:comment "Initial diagnosis steps for the DNS outage, performed by John Doe."@en ;
    dcterms:created "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JohnDoe ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutageTT ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:description "Checked named service status, found stopped. Attempted restart, failed. Investigating logs for root cause."@en .

noria:TroubleTicket_RouterInterfaceTT a noria:TroubleTicket ;
    rdfs:label "Router Interface Down Incident"@en ;
    rdfs:comment "Incident reported for a critical router interface going down, affecting enterprise connectivity."@en ;
    dcterms:created "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketRelatedService noria:Service_EnterpriseConnectivity ;
    noria:troubleTicketRelatedResource noria:Resource_RouterCore01 ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkOpsTeam ;
    noria:troubleTicketDescription "GigabitEthernet0/0/0 on router-core01 is down, impacting external connectivity for some services."@en ;
    noria:troubleTicketTrigger noria:EventRecord_InterfaceDown ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:10:15Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "TT-20240420-002" ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> .

# =============================================================================
# 10. Change Requests
# =============================================================================

noria:ChangeRequest_RouterConfigUpdate a noria:ChangeRequest ;
    rdfs:label "Router Configuration Update"@en, "Mise à jour Configuration Routeur"@fr ;
    rdfs:comment "Planned configuration update for RouterCore01 to optimize routing paths and improve network resilience."@en ;
    dcterms:created "2024-04-15T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-18T16:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-22T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-22T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource_RouterCore01 ;
    noria:changeRequestImpact noria:Service_EnterpriseConnectivity ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ;
     # 30 minutes

    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkConfigurationUpdate> ;
    noria:changeRequestInitiatorParty foaf:Agent_JohnDoe ;
    noria:changeRequestPilotParty foaf:Agent_NetworkOpsTeam ;
    noria:changeRequestActorParty foaf:Agent_NetworkOpsTeam ;
    noria:changeRequestIsRegulated false ;
    noria:documentExternalId "CR-20240415-001" ;
    noria:documentHRef "https://itsm.example.com/change/CR-20240415-001" ;
    noria:documentStatusHistory noria:EventRecord_CR_RouterConfig_StatusChange_Approved .

noria:ChangeRequest_WebSrvUpgrade a noria:ChangeRequest ;
    rdfs:label "Web Server OS Upgrade"@en ;
    rdfs:comment "Scheduled OS upgrade for WebSrv01 to apply security patches and improve performance."@en ;
    dcterms:created "2024-04-10T11:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-12T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-25T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/PreventativeMaintenance> ;
    noria:changeRequestImpact noria:Resource_WebSrv01 ;
    noria:changeRequestImpact noria:Application_CorporateWebsite ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ;
     # 1 hour

    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty foaf:Agent_AppSupportTeam ;
    noria:changeRequestPilotParty foaf:Agent_AppSupportTeam ;
    noria:changeRequestActorParty foaf:Agent_AppSupportTeam ;
    noria:changeRequestIsRegulated true ;
    noria:documentExternalId "CR-20240410-001" ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/OSPatching> .

# =============================================================================
# 11. Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_DNS_Restart a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the DNS service on a server, used during outages."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNS_ServiceStopped ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_ServiceRunning .

noria:ActionPreCondition_DNS_ServiceStopped a noria:ActionPreCondition ;
    rdfs:label "DNS Service Stopped Pre-Condition"@en ;
    rdfs:comment "Condition: The 'named' service is not running on the DNS server, indicating a service failure."@en ;
    skos:example "Check 'systemctl status named' output for 'inactive (dead)'."@en .

noria:ActionPostCondition_DNS_ServiceRunning a noria:ActionPostCondition ;
    rdfs:label "DNS Service Running Post-Condition"@en ;
    rdfs:comment "Outcome: The 'named' service is running and responding to queries, confirming restoration."@en ;
    skos:example "Verify 'systemctl status named' shows 'active (running)' and perform a 'dig example.com' query."@en .

noria:AnomalyPattern_HighDNSErrorRate a noria:AnomalyPattern ;
    rdfs:label "High DNS Error Rate Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential DNS service degradation or attack, characterized by a sudden increase in DNS query failures."@en ;
    skos:example "More than 50% DNS query failures over a 5-minute window for a specific DNS server."@en .

noria:OperationPlan_InterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Guide"@en ;
    rdfs:comment "Procedure to diagnose and resolve issues with a network interface, including physical checks and configuration verification."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition: A network interface is in an operational 'down' state, preventing traffic flow."@en ;
    skos:example "Check 'show interfaces' output for 'down' status."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-Condition"@en ;
    rdfs:comment "Outcome: The network interface is in an operational 'up' state, restoring connectivity."@en ;
    skos:example "Verify 'show interfaces' output for 'up' status and ping connected device."@en .

# =============================================================================
# Additional connections for density and completeness
# =============================================================================

# Connect agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_DNSAdminTeam
    noria:agentManagesResource noria:Resource_DNS01 .

foaf:Agent_NetworkOpsTeam
    noria:agentManagesResource noria:Resource_RouterCore01 ;
    noria:agentManagesResource noria:Resource_CoreSwitch01 .

foaf:Agent_AppSupportTeam
    noria:agentManagesResource noria:Resource_WebSrv01 ;
    noria:agentManagesResource noria:Resource_Hypervisor01 .

# Connect Application Modules to their support/hotline groups
noria:ApplicationModule_CorpInternetAccess_Prod
    noria:applicationModuleSupportGroup org:OrganizationalUnit_NetworkOps ;
    noria:applicationModuleHotlineGroup org:OrganizationalUnit_NetworkOps .

noria:ApplicationModule_CorporateWebsite_Prod
    noria:applicationModuleSupportGroup org:OrganizationalUnit_AppSupport ;
    noria:applicationModuleHotlineGroup org:OrganizationalUnit_AppSupport .

# Connect TroubleTicket to problem responsibility
noria:TroubleTicket_DNSOutageTT
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketCause "Misconfiguration of DNS service leading to process crash."@en .

noria:TroubleTicket_RouterInterfaceTT
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketCause "Physical fiber cut detected on ISP uplink."@en .

# Connect ChangeRequest to related parties with specific roles
noria:ChangeRequest_RouterConfigUpdate
    noria:changeRequestActorParty foaf:Agent_JohnDoe . # John Doe is also an actor for this change

noria:ChangeRequest_WebSrvUpgrade
    noria:changeRequestPilotParty foaf:Agent_JaneSmith . # Jane Smith pilots this upgrade

# Example of a DocumentAttachment
noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for Core Network"@en ;
    rdfs:comment "Detailed network diagram showing RouterCore01 and CoreSwitch01 connections."@en ;
    dcterms:created "2023-10-01T10:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:ChangeRequest_RouterConfigUpdate ;
    dcterms:format "application/pdf" ;
    dcterms:source "https://docs.example.com/network_diagram_core.pdf" .

noria:DocumentAttachment_DNSLogs a noria:DocumentAttachment ;
    rdfs:label "DNS Server Logs"@en ;
    rdfs:comment "Relevant log files from DNS01 during the outage."@en ;
    dcterms:created "2024-04-20T10:40:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutageTT ;
    dcterms:format "text/plain" ;
    dcterms:source "https://logs.example.com/dns01_outage_20240420.log" .


# =============================================================================
# KOS Concepts (Knowledge Organization System)
# These are defined as skos:Concept instances within their respective schemes.
# =============================================================================

# Application KOS
<https://w3id.org/noria/kos/application/type> a skos:ConceptScheme ;
     rdfs:label "Application Type Scheme"@en .

<https://w3id.org/noria/kos/application/type/infrastructure_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/type> ;
     rdfs:label "Infrastructure_extra_node_0 Application Type"@en ;
     rdfs:comment "Applications providing foundational IT services."@en .

<https://w3id.org/noria/kos/application/type/service-platform_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/type> ;
     rdfs:label "Service Platform Application Type"@en ;
     rdfs:comment "Applications acting as platforms for other services."@en .

<https://w3id.org/noria/kos/application/type/business_extra_node_0-application_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/type> ;
     rdfs:label "Business Application Type"@en ;
     rdfs:comment "Applications directly supporting business_extra_node_0 processes."@en .


<https://w3id.org/noria/kos/application/business_extra_node_0-importance> a skos:ConceptScheme ;
     rdfs:label "Application Business Importance Scheme"@en .

<https://w3id.org/noria/kos/application/business_extra_node_0-importance/high_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/business_extra_node_0-importance> ;
     rdfs:label "High_extra_node_0 Business Importance"@en ;
