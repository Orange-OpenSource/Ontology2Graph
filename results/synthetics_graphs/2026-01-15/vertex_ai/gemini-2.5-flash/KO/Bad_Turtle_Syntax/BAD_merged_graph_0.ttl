# =============================================================================
# Dynamic Elements (Trouble Tickets, Change Requests, Event Records)
# =============================================================================

noria:EventRecord_DNSOutage a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Alert"@en, "Alerte Serveur DNS Inaccessible"@fr ;
    rdfs:comment "Automated alert indicating that dns01.corp.example.com is unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN. Ping failed."@en ;
    noria:alarmSeverity kos-notif-sev:Critical ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartDNS ;
    folio:happenedAt noria:Resource_DNS01 .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en, "Alerte Interface Réseau Hors Service"@fr ;
    rdfs:comment "Alert indicating that GigabitEthernet0/0/1 on rtr01.dc01.example.com went down."@en ;
    noria:loggingTime "2024-04-20T08:59:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Router01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity kos-notif-sev:Major ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckCable ;
    folio:happenedAt noria:Resource_Router01 .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Network Monitoring System"@en, "Système de Surveillance Réseau"@fr ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType kos-app-type:Infrastructure ;
    noria:elementManagedBy foaf:Agent_NetworkTeam .

noria:TroubleTicket_DNSOutage_TT001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident - TT001"@en, "Incident Panne Serveur DNS - TT001"@fr ;
    dcterms:identifier "TT001" ;
    dcterms:created "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    dcterms:description "DNS server dns01.corp.example.com is unreachable, impacting all corporate services."@en ;
    noria:troubleTicketSeverity kos-tt-sev:Critical ;
    noria:troubleTicketType kos-tt-type:Failure ;
    noria:troubleTicketCriticity kos-tt-cat:InterruptedService ;
    noria:troubleTicketPriority kos-tt-prio:P1 ;
    noria:troubleTicketOrigin kos-tt-origin:Supervision ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutage ;
    noria:troubleTicketUrgency kos-tt-urg:ImmediateIntervention ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory kos-tt-tc:TotalBreakdown ;
    noria:troubleTicketCause "Network connectivity issue to DNS server."@en ;
    noria:problemResponsibility kos-tt-pr:ManagedBackboneNetworks ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent kos-tt-status:InProgress ;
    noria:troubleTicketRelatedParty foaf:Agent_AdminTeam, foaf:Agent_NetworkTeam ;
    noria:troubleTicketRelatedService noria:Service_CorpDNS ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01, noria:Resource_Router01 ;
    noria:troubleTicketImpacts noria:Service_CorpDNS, noria:Application_DNS, noria:Resource_DNS01, noria:Resource_Router01 ;
    noria:documentHRef "https://itsm.example.com/tickets/TT001" .

noria:TroubleTicketNote_TT001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for TT001"@en ;
    dcterms:created "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JohnDoe ;
    dcterms:description "Confirmed DNS server is not responding to pings. Suspect network issue. Escalated to Network Team."@en ;
    noria:troubleTicketNoteCommentType kos-tt-cmt:Internal ;
    noria:troubleTicketNoteOperationType kos-tt-op:Diagnosis ;
    noria:eventRelatedElement noria:TroubleTicket_DNSOutage_TT001 .

noria:TroubleTicketNote_TT001_Note2 a noria:TroubleTicketNote ;
    rdfs:label "Network Team Update for TT001"@en ;
    dcterms:created "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_NetworkTeam ;
    dcterms:description "Found interface GigabitEthernet0/0/1 on rtr01.dc01.example.com was administratively down. Brought it up. DNS server now reachable."@en ;
    noria:troubleTicketNoteCommentType kos-tt-cmt:Internal ;
    noria:troubleTicketNoteOperationType kos-tt-op:TestsAndMeasurements ;
    noria:eventRelatedElement noria:TroubleTicket_DNSOutage_TT001 ;
    noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer_InterfaceUp .

noria:ProcedureExecutionContainer_InterfaceUp a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution for bringing interface up"@en ;
    rdfs:comment "Container for actions taken to bring up the network interface."@en ;
    pep:hasMember noria:EventRecord_InterfaceUpCommand .

noria:EventRecord_InterfaceUpCommand a noria:EventRecord ;
    rdfs:label "Router Interface Up Command Log"@en ;
    noria:loggingTime "2024-04-20T09:28:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Router01 ;
    noria:logOriginatingAgent foaf:Agent_NetworkTeam ;
    noria:logText "Command 'interface GigabitEthernet0/0/1;
     no shutdown' executed."@en ;
    

    pep:hasSimpleResult "Interface GigabitEthernet0/0/1 state changed to up."@en ;
    prov:wasAttributedTo foaf:Agent_NetworkTeam .

noria:ChangeRequest_DNSUpgrade_CR001 a noria:ChangeRequest ;
    rdfs:label "DNS Software Upgrade - CR001"@en, "Mise à Jour Logiciel DNS - CR001"@fr ;
    dcterms:identifier "CR001" ;
    dcterms:created "2024-04-15T14:00:00Z"^^xsd:dateTime ;
    dcterms:description "Upgrade DNS server software to latest stable version for security patches and new features."@en ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory kos-cr-cat:InternalIntervention ;
    noria:changeRequestType kos-cr-type:Standard ;
    noria:changeRequestChangeCause kos-cr-cause:SoftwareUpgrade ;
    noria:changeRequestImpact noria:Resource_DNS01, noria:Application_DNS ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
     # 2 hours

    noria:changeRequestStatusCurrent kos-cr-status:Scheduled ;
    noria:changeRequestSpecification kos-cr-spec:StandardSoftwareUpgradeProcedure ;
    noria:changeRequestInitiatorParty foaf:Agent_AdminTeam ;
    noria:changeRequestPilotParty foaf:Agent_JohnDoe ;
    noria:changeRequestActorParty foaf:Agent_JohnDoe ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef "https://itsm.example.com/changes/CR001" .

noria:DocumentAttachment_CR001_Plan a noria:DocumentAttachment ;
    rdfs:label "DNS Upgrade Plan for CR001"@en ;
    rdfs:comment "Detailed plan for the DNS software upgrade, including rollback procedures."@en ;
    dcterms:isPartOf noria:ChangeRequest_DNSUpgrade_CR001 ;
    dcterms:format "application/pdf" .

# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_RestartDNS a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en, "Procédure de Redémarrage du Service DNS"@fr ;
    rdfs:comment "Standard operating procedure for restarting the DNS service on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSRestored ;
    pep:hasInput noria:Resource_DNS01 .

noria:OperationPlan_CheckCable a noria:OperationPlan ;
    rdfs:label "Network Cable Check Procedure"@en, "Procédure de Vérification de Câble Réseau"@fr ;
    rdfs:comment "Procedure to physically check and reseat network cables."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:ActionPreCondition_DNSUnreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS server is not responding to queries or pings."@en ;
    skos:example "Ping to DNS server fails, DNS queries timeout."@en .

noria:ActionPostCondition_DNSRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS server is reachable and responding to queries."@en ;
    skos:example "Ping to DNS server succeeds, DNS queries resolve correctly."@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Administratively Down"@en ;
    rdfs:comment "Condition: A network interface is reported as administratively down."@en ;
    skos:example "Router log shows 'LINEPROTO-5-UPDOWN: ... changed state to down'."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Operational"@en ;
    rdfs:comment "Outcome: The network interface is up and passing traffic."@en ;
    skos:example "Router log shows 'LINEPROTO-5-UPDOWN: ... changed state to up'."@en .

noria:AnomalyPattern_DNSFailure a noria:AnomalyPattern ;
    rdfs:label "DNS Service Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a DNS service failure, often correlated with network issues or resource overload."@en ;
    skos:example "Multiple DNS unreachable alerts from different monitoring points, combined with high CPU usage on the DNS server."@en ;
    folio:hasCause noria:TroubleTicket_DNSOutage_TT001 . # Linking an anomaly pattern to a specific trouble ticket as an example of its manifestation.

# =============================================================================
# Additional connections for density
# =============================================================================

noria:Resource_DNS01 noria:virtualServerStatus kos-res-op:Running .
noria:Resource_WebSrv01 noria:virtualServerStatus kos-res-op:Running .

noria:NetworkInterface_Router01_Gig0_0_1 noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_Router01_Gig0_0_2 noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:TroubleTicket_DNSOutage_TT001 noria:documentStatusHistory noria:EventRecord_TT001_StatusChange_InProgress .

noria:EventRecord_TT001_StatusChange_InProgress a noria:EventRecord ;
    rdfs:label "Trouble Ticket TT001 Status Change to InProgress"@en ;
    noria:loggingTime "2024-04-20T09:06:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_TicketingSystem ;
    noria:logText "Trouble Ticket TT001 status changed from Initialised to InProgress."@en ;
    dcterms:references noria:TroubleTicket_DNSOutage_TT001 .

noria:Application_TicketingSystem a noria:Application ;
    rdfs:label "ITSM Ticketing System"@en ;
    noria:applicationShortIdentifier "ITSM-TS" ;
    noria:applicationType kos-app-type:ITSM ;
    noria:elementManagedBy foaf:Agent_AdminTeam .

noria:ChangeRequest_DNSUpgrade_CR001 noria:documentStatusHistory noria:EventRecord_CR001_StatusChange_Scheduled .

noria:EventRecord_CR001_StatusChange_Scheduled a noria:EventRecord ;
    rdfs:label "Change Request CR001 Status Change to Scheduled"@en ;
    noria:loggingTime "2024-04-15T14:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_ChangeManagementSystem ;
    noria:logText "Change Request CR001 status changed from Draft to Scheduled."@en ;
    dcterms:references noria:ChangeRequest_DNSUpgrade_CR001 .

noria:Application_ChangeManagementSystem a noria:Application ;
    rdfs:label "Change Management System"@en ;
    noria:applicationShortIdentifier "CMS" ;
    noria:applicationType kos-app-type:ITSM ;
    noria:elementManagedBy foaf:Agent_AdminTeam .

noria:OperationPlan_RestartDNS pep:usedProcedure noria:OperationPlan_RestartDNS . # Self-referential for completeness, though usually points to another procedure.
noria:OperationPlan_RestartDNS noria:actionCorrelatedOperationPlan noria:OperationPlan_RestartDNS .

noria:AnomalyPattern_DNSFailure folio:hasControlMethod noria:OperationPlan_RestartDNS .

