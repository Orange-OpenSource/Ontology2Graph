    noria:networkLinkInstallationDate "2021-03-20T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_ISP_Router ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Ge000 .

noria:NetworkLink_CoreLAN a noria:NetworkLink ;
