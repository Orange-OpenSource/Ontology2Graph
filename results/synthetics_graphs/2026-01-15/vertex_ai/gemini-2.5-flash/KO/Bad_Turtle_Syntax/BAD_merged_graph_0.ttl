# =============================================================================
# Anomaly Patterns
# =============================================================================

noria:AnomalyPattern_DNS_Failure a noria:AnomalyPattern ;
    rdfs:label "DNS Service Failure Pattern"@en ;
    rdfs:comment "Pattern describing a complete failure of the DNS resolution service, typically involving server unreachability and widespread service impact."@en ;
    skos:example "Multiple critical alerts from monitoring system for DNS server, coupled with user reports of inability to access internal/external resources."@en .

noria:AnomalyPattern_HighCPU_Degradation a noria:AnomalyPattern ;
    rdfs:label "High CPU Performance Degradation Pattern"@en ;
    rdfs:comment "Pattern describing performance degradation due to sustained high CPU utilization on a critical server."@en ;
    skos:example "Repeated major alerts for CPU usage > 90% over extended periods, leading to slow application response times."@en .



