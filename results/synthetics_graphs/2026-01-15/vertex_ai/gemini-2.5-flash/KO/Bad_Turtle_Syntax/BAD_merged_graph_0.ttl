# =============================================================================
# 1. Agents and Organizations
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email dnsteam@example.com for non-urgent issues. Use hotline for critical incidents."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for network infrastructure maintenance and monitoring."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call 0800-NETOPS for any network-related incident."@en .

foaf:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing L2 support for critical business applications."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all application issues."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead engineer for the Corporate Internet Access application and web services."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Incident Manager for critical infrastructure and change coordinator."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:Organization_ITDept a org:Organization ;
    rdfs:label "IT Department"@en, "Département Informatique"@fr ;
    rdfs:comment "The main IT department of the company."@en .

org:Organization_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

org:Organization_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

org:Organization_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking equipment."@en .

org:OrganizationalUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Organizational unit for network operations."@en ;
    org:unitOf org:Organization_ITDept .

org:OrganizationalUnit_AppSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support Unit"@en ;
    rdfs:comment "Organizational unit for application support."@en ;
    org:unitOf org:Organization_ITDept .

noria:CorporateUserIdentifier_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CorporateUserIdentifier_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

# =============================================================================
# 2. Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing and virtualization."@en ;
    noria:productManufacturedBy org:Organization_Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch series."@en ;
    noria:productManufacturedBy org:Organization_Cisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi"@en ;
    rdfs:comment "Hypervisor software for virtual machines."@en .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "Modular router for service provider and enterprise applications."@en ;
    noria:productManufacturedBy org:Organization_Juniper .

# =============================================================================
# 3. Locations (Sites, Rooms, Locus)
# =============================================================================

bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the data center, hosting critical infrastructure."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Rack A1 within Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of network equipment in Rack A2 within Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasSpace noria:Room_ServerRoomA .

# =============================================================================
# 4. Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, running on Dell hardware, critical for name resolution."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "192.168.10.10" ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en, "Routeur Coeur 01"@fr ;
    rdfs:comment "Main router for the corporate backbone network, providing inter-VLAN routing and external connectivity."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en, "Serveur Web 01"@fr ;
    rdfs:comment "Virtual machine hosting the corporate website, running on Hypervisor01."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
     # The hypervisor model, not the VM OS

    noria:resourceLogisticId "VM-WEB-001" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-SN-WEB01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_Hypervisor01 ;
    noria:resourceManagementIPAddress "172.16.0.10" ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

noria:Resource_Hypervisor01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines, including WebSrv01, located in Rack A1."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupportTeam ;
    noria:resourceHostName "hypervisor01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "192.168.10.20" .

noria:Resource_ISP_Router a noria:Resource ;
    rdfs:label "ISP Edge Router"@en ;
    rdfs:comment "External router managed by the Internet Service Provider, connecting to our core network."@en ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceHostName "isp-edge-rtr.isp.com" .

noria:Resource_CoreSwitch01 a noria:Resource ;
    rdfs:label "Core Switch 01"@en ;
    rdfs:comment "Main switch for the corporate LAN, providing high-speed connectivity to servers and user devices."@en ;
    noria:resourceType <kos/Resource/type/Switch> ;
    noria:resourceHostName "core-sw01.corp.example.com" ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam .

# =============================================================================
# 5. Network Interfaces and Links
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server, connected to the management network."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Management interface for DNS01" ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -20 .

noria:NetworkInterface_RouterCore01_Ge000 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/0"@en ;
