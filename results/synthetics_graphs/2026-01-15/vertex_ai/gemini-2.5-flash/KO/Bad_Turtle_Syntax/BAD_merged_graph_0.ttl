    rdfs:comment "Database server hosting the Customer Portal application's data."@en ;
    noria:resourceManagedBy foaf:Agent_BobJohnson ;
    noria:resourceHostName "db01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U42 ;
    noria:resourceManagementIPAddress "10.0.0.20" .

noria:Resource_FirewallDMZ a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:comment "Firewall protecting the Demilitarized Zone (DMZ) where public-facing services reside."@en ;
