    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_Router01_Gig0_0_2_extra_node_3 noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:TroubleTicket_DNSOutage_TT001_extra_node_3 noria:documentStatusHistory noria:EventRecord_TT001_StatusChange_InProgress_extra_node_3 .

noria:EventRecord_TT001_StatusChange_InProgress_extra_node_3 a noria:EventRecord ;
    rdfs:label "Trouble Ticket TT001 Status Change to InProgress"@en ;
    noria:loggingTime "2024-04-20T09:06:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_TicketingSystem_extra_node_3 ;
    noria:logText "Trouble Ticket TT001 status changed from Initialised to InProgress_extra_node_3."@en ;
    dcterms:references noria:TroubleTicket_DNSOutage_TT001_extra_node_3 .

