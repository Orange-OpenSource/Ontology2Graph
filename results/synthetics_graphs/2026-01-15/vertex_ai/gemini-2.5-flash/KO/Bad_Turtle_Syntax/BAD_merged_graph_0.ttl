    rdfs:comment "Specific location for a server within Server Room A."@en ;
    noria:locusLine "Rack 12" ;
    noria:locusRow "U42" ;
    bot:containedIn noria:Room_ServerRoomA .

noria:Locus_Rack03_U10 a noria:Locus ;
    rdfs:label "Rack 03, Unit 10"@en ;
    rdfs:comment "Specific location for a network device within Network Closet B."@en ;
    noria:locusLine "Rack 03" ;
    noria:locusRow "U10" ;
    bot:containedIn noria:Room_NetworkClosetB .

