    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U42 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_SwitchBO01 a noria:Resource ;
    rdfs:label "Branch Office Switch 01"@en ;
    rdfs:comment "Access layer switch in the Paris branch office."@en ;
    rdfs:label "Commutateur Agence Paris 01"@fr ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:resourceHostName "switch-bo01.paris.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoCatalyst9300 ;
    noria:resourceType <kos/Resource/type/Switch> ;
