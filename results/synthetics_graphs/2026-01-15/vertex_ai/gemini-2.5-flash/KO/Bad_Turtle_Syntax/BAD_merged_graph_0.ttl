    dcterms:identifier "TT-20240420-001" ;
    dcterms:created "2024-04-20T10:06:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T12:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/NetworkOutage> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_RouterDown ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Router interface failure leading to loss of connectivity."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_ITOpsTeam ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkAdmin ;
    noria:troubleTicketRelatedService noria:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_RouterDC01 ;
    noria:troubleTicketImpacts noria:Service_InternetAccess ;
    noria:troubleTicketImpacts noria:Resource_RouterDC01 ;
    noria:documentHRef "https://ticketing.example.com/TT-20240420-001" .

noria:TroubleTicket_TT002 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Database Performance Issue"@en ;
    rdfs:comment "Report of slow performance and intermittent errors on the Customer Portal, traced to database connection issues."@en ;
    dcterms:identifier "TT-20240420-002" ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/ServerFailure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_DBError ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "AppDynamics" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/IsolatedCustomerSite> ;
     # Example of initial category

    noria:problemCategory <kos/TroubleTicket/trouble-category/SoftwareBug> ;
     # Example of final category after diagnosis

    noria:troubleTicketCause "Database connection pool exhaustion due to inefficient queries."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/Customer> ;
     # Assuming customer application code issue

    noria:troubleTicketDetectionDateTime "2024-04-20T10:10:30Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T16:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_CustomerSupport ;
    noria:troubleTicketRelatedParty foaf:Agent_AppDevTeam ;
    noria:troubleTicketRelatedService noria:Service_CustomerFacingWeb ;
    noria:troubleTicketRelatedResource noria:Resource_DBServer01 ;
    noria:troubleTicketImpacts noria:ApplicationModule_CustomerPortal_Prod ;
    noria:documentHRef "https://ticketing.example.com/TT-20240420-002" .

noria:TroubleTicket_TT003 a noria:TroubleTicket ;
    rdfs:label "DNS Server Unresponsive"@en ;
    rdfs:comment "Incident reported by monitoring system: Corporate DNS server is not responding."@en ;
    dcterms:identifier "TT-20240421-003" ;
    dcterms:created "2024-04-21T08:01:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-21T08:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
