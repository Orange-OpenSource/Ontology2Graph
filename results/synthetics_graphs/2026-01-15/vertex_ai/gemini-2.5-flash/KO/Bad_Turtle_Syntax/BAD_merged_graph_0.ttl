    noria:applicationModuleSlaLevelDate "2022-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam foaf:Agent_ITOpsTeam .

# =============================================================================
# Services
# =============================================================================

noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "End-to-end service providing internet access to all corporate users."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Application_CorporateDNS ;
     # DNS is a component of internet access

    seas:subSystemOf noria:Application_MonitoringSystem ;
     # Monitoring is a component

    seas:subSystemOf noria:Resource_RouterDC01 ;
    seas:subSystemOf noria:Resource_FirewallDMZ ;
    seas:subSystemOf noria:NetworkLink_DC01_DMZ_Link ;
    seas:subSystemOf noria:NetworkLink_BO01_WAN_Link ;
    noria:resourceManagedBy foaf:Agent_NetworkAdmin .

noria:Service_CustomerFacingWeb a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "Service providing the Customer Portal application to external users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_CustomerPortal ;
    seas:subSystemOf noria:ApplicationModule_CustomerPortal_Prod ;
    seas:subSystemOf noria:Resource_DBServer01 ;
    seas:subSystemOf noria:Resource_VirtualWebSrv01 ;
    seas:subSystemOf noria:Resource_FirewallDMZ ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_RouterDown a noria:EventRecord ;
    rdfs:label "RouterDC01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating that an interface on RouterDC01 went down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterDC01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_ITOpsTeam ;
     # Could be an automated script or a human action

    noria:logText "LINEPROTO-5-DOWN: Interface GigabitEthernet0/1, changed state to down" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_InterfaceTroubleshooting .

noria:EventRecord_DBError a noria:EventRecord ;
    rdfs:label "Database Connection Error Event"@en ;
    rdfs:comment "Log entry indicating a high number of database connection errors on DBServer01."@en ;
    noria:loggingTime "2024-04-20T10:10:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "ERROR: Too many connections to database 'customer_db'" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Event"@en ;
    rdfs:comment "Log entry detailing a configuration change applied to the DMZ Firewall."@en ;
    noria:loggingTime "2024-04-19T15:20:10Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_NetworkAdmin ;
    noria:logText "CONFIG_I: Configured from console by asmith (10.0.0.100) - added rule for new service" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_DNSFailure a noria:EventRecord ;
    rdfs:label "DNS Server Unresponsive Event"@en ;
    rdfs:comment "Monitoring alert indicating DNS01 is not responding to queries."@en ;
    noria:loggingTime "2024-04-21T08:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "DNS server dns01.corp.example.com unresponsive on port 53" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

