# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_HighCPU_WS01 a noria:EventRecord ;
    rdfs:label "High CPU Usage Alert on Web Server 01"@en ;
    rdfs:comment "Monitoring system detected sustained high CPU usage on web01.corp.example.com."@en ;
    noria:loggingTime "2024-04-20T14:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en .

noria:EventRecord_DBError_DB01 a noria:EventRecord ;
    rdfs:label "Database Connection Error on DB Server 01"@en ;
    rdfs:comment "Application logs show repeated database connection failures from db01.corp.example.com."@en ;
    noria:loggingTime "2024-04-20T14:35:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "ORA-01034: ORACLE not available. Repeated connection attempts failed."@en .

noria:EventRecord_InterfaceDown_CR01 a noria:EventRecord ;
    rdfs:label "Network Interface Down on Core Router 01"@en ;
    rdfs:comment "Core Router 01 interface eth1 went down unexpectedly."@en ;
    noria:loggingTime "2024-04-20T14:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "Interface eth1 on cr01.paris.example.com changed state to down."@en ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartInterface .

