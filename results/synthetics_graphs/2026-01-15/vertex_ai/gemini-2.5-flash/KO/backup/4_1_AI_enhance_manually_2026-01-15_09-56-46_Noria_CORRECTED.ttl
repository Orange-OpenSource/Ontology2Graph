noria:ChangeRequest_DNSUpgrade_CR001 a noria:ChangeRequest ;
  rdfs:label "DNS Software Upgrade - CR001"@en ;
  rdfs:label "Mise à Jour Logiciel DNS - CR001"@fr ;
  dcterms:description "Upgrade DNS server software to latest stable version for security patches and new features."@en ;
  dcterms:created "2024-04-15T14:00:00Z"^^xsd:dateTime ;
  dcterms:identifier "CR001" ;
  noria:changeRequestActorParty foaf:Agent_JohnDoe ;
  noria:changeRequestCategory kos-cr-cat:InternalIntervention ;
  noria:changeRequestChangeCause kos-cr-cause:SoftwareUpgrade ;
  noria:changeRequestImpact noria:Application_DNS ;
  noria:changeRequestImpact noria:Resource_DNS01 ;
  noria:changeRequestInitiatorParty foaf:Agent_AdminTeam ;
  noria:changeRequestIsRegulated false ;
  noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
  noria:changeRequestPilotParty foaf:Agent_JohnDoe ;
  noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
  noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
  noria:changeRequestSpecification kos-cr-spec:StandardSoftwareUpgradeProcedure ;
  noria:changeRequestStatusCurrent kos-cr-status:Scheduled ;
  noria:changeRequestType kos-cr-type:Standard ;
  noria:documentHRef "https://itsm.example.com/changes/CR001" ;
  noria:documentStatusHistory noria:EventRecord_CR001_StatusChange_Scheduled .

noria:CorporateUserIdentifier_JohnDoe a noria:CorporateUserIdentifier ;
  rdfs:label "John Doe's Corporate ID"@en ;
  rdfs:comment "Unique corporate user identifier for John Doe."@en ;
  foaf:accountName "jdoe"@en ;
  foaf:holdsAccount foaf:Agent_JohnDoe .

noria:DocumentAttachment_CR001_Plan a noria:DocumentAttachment ;
  rdfs:label "DNS Upgrade Plan for CR001"@en ;
  rdfs:comment "Detailed plan for the DNS software upgrade, including rollback procedures."@en ;
  dcterms:format "application/pdf" ;
  dcterms:isPartOf noria:ChangeRequest_DNSUpgrade_CR001 .

noria:EventRecord_CR001_StatusChange_Scheduled a noria:EventRecord ;
  rdfs:label "Change Request CR001 Status Change to Scheduled"@en ;
  dcterms:references noria:ChangeRequest_DNSUpgrade_CR001 ;
  noria:logOriginatingManagementSystem noria:Application_ChangeManagementSystem ;
  noria:logText "Change Request CR001 status changed from Draft to Scheduled."@en ;
  noria:loggingTime "2024-04-15T14:05:00Z"^^xsd:dateTime .

noria:EventRecord_DNSOutage a noria:EventRecord ;
  rdfs:label "Alerte Serveur DNS Inaccessible"@fr ;
  rdfs:label "DNS Server Unreachable Alert"@en ;
  rdfs:comment "Automated alert indicating that dns01.corp.example.com is unreachable."@en ;
  folio:happenedAt noria:Resource_DNS01 ;
  noria:alarmProposedRepairAction noria:OperationPlan_RestartDNS ;
  noria:alarmSeverity kos-notif-sev:Critical ;
  noria:logOriginatingManagedObject noria:Resource_DNS01 ;
  noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
  noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN. Ping failed."@en ;
  noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
  rdfs:label "Alerte Interface Réseau Hors Service"@fr ;
  rdfs:label "Network Interface Down Alert"@en ;
  rdfs:comment "Alert indicating that GigabitEthernet0/0/1 on rtr01.dc01.example.com went down."@en ;
  folio:happenedAt noria:Resource_Router01 ;
  noria:alarmProposedRepairAction noria:OperationPlan_CheckCable ;
  noria:alarmSeverity kos-notif-sev:Major ;
  noria:logOriginatingManagedObject noria:Resource_Router01 ;
  noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
  noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
  noria:loggingTime "2024-04-20T08:59:30Z"^^xsd:dateTime .

noria:EventRecord_InterfaceUpCommand a noria:EventRecord ;
  rdfs:label "Router Interface Up Command Log"@en ;
  noria:logOriginatingAgent foaf:Agent_NetworkTeam ;
  noria:logOriginatingManagedObject noria:Resource_Router01 ;
  noria:logText "Command 'interface GigabitEthernet0/0/1; no shutdown' executed."@en ;
  noria:loggingTime "2024-04-20T09:28:00Z"^^xsd:dateTime ;
  pep:hasSimpleResult "Interface GigabitEthernet0/0/1 state changed to up."@en ;
  prov:wasAttributedTo foaf:Agent_NetworkTeam .

noria:EventRecord_TT001_StatusChange_InProgress a noria:EventRecord ;
  rdfs:label "Trouble Ticket TT001 Status Change to InProgress"@en ;
  dcterms:references noria:TroubleTicket_DNSOutage_TT001 ;
  noria:logOriginatingManagementSystem noria:Application_TicketingSystem ;
  noria:logText "Trouble Ticket TT001 status changed from Initialised to InProgress."@en ;
  noria:loggingTime "2024-04-20T09:06:00Z"^^xsd:dateTime .

