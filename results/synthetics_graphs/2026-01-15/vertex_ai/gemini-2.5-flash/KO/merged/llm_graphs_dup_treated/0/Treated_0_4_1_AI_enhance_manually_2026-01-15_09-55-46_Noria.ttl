    noria:logOriginatingManagedObject noria:Resource_RouterCore01_extra_node_4 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_4 ;
    noria:logText "Interface GigabitEthernet0/0/0 on router-core01 changed state to down." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_4> ;
    noria:alarmProposedRepairAction noria:OperationPlan_InterfaceTroubleshoot_extra_node_4 .

