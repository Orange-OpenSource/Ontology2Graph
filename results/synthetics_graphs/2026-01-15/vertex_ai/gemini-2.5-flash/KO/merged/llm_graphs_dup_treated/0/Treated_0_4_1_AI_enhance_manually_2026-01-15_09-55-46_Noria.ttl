noria:Resource_ISP_Router_extra_node_4 a noria:Resource ;
    rdfs:label "ISP Edge Router"@en ;
    rdfs:comment "External router managed by the Internet Service Provider, connecting to our core network."@en ;
    noria:resourceType <kos/Resource/type/Router_extra_node_4> ;
    noria:resourceHostName "isp-edge-rtr.isp.com" .

noria:Resource_CoreSwitch01_extra_node_4 a noria:Resource ;
    rdfs:label "Core Switch 01"@en ;
    rdfs:comment "Main switch for the corporate LAN, providing high-speed connectivity to servers and user devices."@en ;
    noria:resourceType <kos/Resource/type/Switch_extra_node_4> ;
    noria:resourceHostName "core-sw01.corp.example.com" ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam_extra_node_4 .

