noria:EventRecord_DNSOutageLog_extra_node_4 a noria:EventRecord ;
    rdfs:label "DNS Server Outage Log Entry"@en ;
    rdfs:comment "Log entry indicating a DNS server outage, detected by the monitoring system."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01_extra_node_4 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_4 ;
    noria:logText "DNS service on dns01.corp.example.com is unreachable. Process 'named' not running." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_4> ;
    noria:alarmProposedRepairAction noria:OperationPlan_DNS_Restart_extra_node_4 .

noria:EventRecord_InterfaceDown_extra_node_4 a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Event record for a critical network interface going down on Core Router 01, impacting connectivity."@en ;
