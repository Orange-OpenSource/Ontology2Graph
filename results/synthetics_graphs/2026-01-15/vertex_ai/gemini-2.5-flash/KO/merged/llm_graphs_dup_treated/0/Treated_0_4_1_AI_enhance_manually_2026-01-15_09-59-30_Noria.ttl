# Application KOS
<https://w3id.org/noria/kos/application/type> a skos:ConceptScheme ;
     rdfs:label "Application Type Scheme"@en .

<https://w3id.org/noria/kos/application/type/infrastructure_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/type> ;
     rdfs:label "Infrastructure_extra_node_0 Application Type"@en ;
     rdfs:comment "Applications providing foundational IT services."@en .

<https://w3id.org/noria/kos/application/type/service-platform_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/type> ;
     rdfs:label "Service Platform Application Type"@en ;
     rdfs:comment "Applications acting as platforms for other services."@en .

<https://w3id.org/noria/kos/application/type/business_extra_node_0-application_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/type> ;
     rdfs:label "Business Application Type"@en ;
     rdfs:comment "Applications directly supporting business_extra_node_0 processes."@en .


<https://w3id.org/noria/kos/application/business_extra_node_0-importance> a skos:ConceptScheme ;
     rdfs:label "Application Business Importance Scheme"@en .

<https://w3id.org/noria/kos/application/business_extra_node_0-importance/high_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/business_extra_node_0-importance> ;
     rdfs:label "High_extra_node_0 Business Importance"@en ;
     rdfs:comment "Critical_extra_node_0 for business_extra_node_0 operations, significant impact if unavailable."@en .

<https://w3id.org/noria/kos/application/business_extra_node_0-importance/medium_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/business_extra_node_0-importance> ;
     rdfs:label "Medium Business Importance"@en ;
     rdfs:comment "Important for business_extra_node_0 operations, moderate impact if unavailable."@en .

<https://w3id.org/noria/kos/application/business_extra_node_0-importance/low> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/business_extra_node_0-importance> ;
     rdfs:label "Low Business Importance"@en ;
     rdfs:comment "Non-critical for business_extra_node_0 operations, minor impact if unavailable."@en .


<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
     rdfs:label "Application Module Status Scheme"@en .

<https://w3id.org/noria/kos/application/status/InProduction_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/status> ;
     rdfs:label "In Production"@en ;
     rdfs:label "En Production"@fr ;
     rdfs:comment "The application module is currently live and serving users."@en .

<https://w3id.org/noria/kos/application/status/Development_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/status> ;
     rdfs:label "Development_extra_node_0"@en ;
     rdfs:comment "The application module is under active development."@en .

<https://w3id.org/noria/kos/application/status/Decommissioned> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/status> ;
     rdfs:label "Decommissioned"@en ;
     rdfs:comment "The application module has been retired from service."@en .


<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
     rdfs:label "Application Module SLA Level Scheme"@en .

<https://w3id.org/noria/kos/application/sla-level/Gold_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
     rdfs:label "Gold_extra_node_0 SLA Level"@en ;
     rdfs:comment "Highest Service Level Agreement tier, indicating maximum availability and performance."@en .

<https://w3id.org/noria/kos/application/sla-level/Silver_extra_node_0> a skos:Concept ;
     skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
     rdfs:label "Silver_extra_node_0 SLA Level"@en ;
     rdfs:comment "Mid-tier Service Level Agreement, offering good availability and performance."@en .


# Service KOS
<https://w3id.org/noria/kos/service/type> a skos:ConceptScheme ;
     rdfs:label "Service Type Scheme"@en .

<https://w3id.org/noria/kos/service/type/CustomerFacingService_extra_node_0> a skos:Concept ;
