# =============================================================================
# Operational Procedures and Anomaly Patterns
# =============================================================================

noria:OperationPlan_RestartWebService a noria:OperationPlan ;
    rdfs:label "Restart Web Service Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the web service on application servers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_HighCPUDetected ;
    noria:operationPlanPostCondition noria:ActionPostCondition_CPUUsageNormal .

noria:OperationPlan_RestartInterface a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Procedure to administratively shut down and then bring up a network interface."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:ActionPreCondition_HighCPUDetected a noria:ActionPreCondition ;
    rdfs:label "High CPU Detected"@en ;
    rdfs:comment "Condition: CPU utilization consistently above 90% for 5 minutes."@en ;
    skos:example "Check 'top' or 'htop' output for CPU usage."@en .

noria:ActionPostCondition_CPUUsageNormal a noria:ActionPostCondition ;
    rdfs:label "CPU Usage Normal"@en ;
    rdfs:comment "Expected outcome: CPU utilization below 50% for 10 minutes."@en ;
    skos:example "Verify 'top' or 'htop' output shows normal CPU usage."@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down"@en ;
    rdfs:comment "Condition: Network interface reports operational status 'down'."@en ;
    skos:example "Check 'show interface status' on router."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up"@en ;
    rdfs:comment "Expected outcome: Network interface reports operational status 'up' and traffic flows."@en ;
    skos:example "Verify 'show interface status' and ping connectivity."@en .

noria:AnomalyPattern_HighCPU_WebPortal a noria:AnomalyPattern ;
    rdfs:label "High CPU on Web Portal Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential issue with the web portal due to excessive CPU usage on web servers."@en ;
    folio:hasCause noria:EventRecord_HighCPU_WS01 ;
    folio:hasEffect noria:TroubleTicket_CWP_Outage_001 .

noria:AnomalyPattern_DB_Unavailability a noria:AnomalyPattern ;
    rdfs:label "Database Unavailability Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a critical database issue, leading to application outages."@en ;
    folio:hasCause noria:EventRecord_DBError_DB01 ;
    folio:hasEffect noria:TroubleTicket_DB_Issue_002 .

# =============================================================================
# Document Attachments (Example)
# =============================================================================

noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Data Center Network Diagram"@en ;
    rdfs:comment "PDF document showing the logical and physical network topology of the Paris Data Center."@en ;
    dcterms:identifier "DOC-NET-DIAG-001" ;
    dcterms:created "2023-10-01T09:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TroubleTicket_Network_Outage_003 ;
    dcterms:isPartOf noria:ChangeRequest_CR01_FirmwareUpdate ;
    dcterms:format "application/pdf" .

noria:DocumentAttachment_ServerLogs a noria:DocumentAttachment ;
    rdfs:label "Web Server 01 Log Excerpt"@en ;
    rdfs:comment "Text file containing relevant log entries from web01.corp.example.com during the high CPU incident."@en ;
    dcterms:identifier "DOC-WS01-LOGS-001" ;
    dcterms:created "2024-04-20T14:40:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TroubleTicket_CWP_Outage_001 ;
    dcterms:format "text/plain" .

# =============================================================================
# Additional Connectivity and Density
# =============================================================================

# Link resources to applications they support
noria:Resource_WebServer01 noria:resourceForApplication noria:Application_CorporateWebPortal .
noria:Resource_DBServer01 noria:resourceForApplication noria:Application_CorporateWebPortal .
noria:Resource_CoreRouter01 noria:resourceForApplication noria:Application_MonitoringSystem . # Monitoring system uses the router for data collection
noria:Resource_AccessSwitch01 noria:resourceForApplication noria:Application_MonitoringSystem .

# Link agents to resources they manage
noria:OrgUnit_WebOpsTeam noria:agentManagesResource noria:Resource_WebServer01, noria:Resource_VirtualMachine_App01, noria:Resource_HypervisorHost01 .
noria:OrgUnit_DBATeam noria:agentManagesResource noria:Resource_DBServer01 .
noria:OrgUnit_NetworkTeam noria:agentManagesResource noria:Resource_CoreRouter01, noria:Resource_AccessSwitch01, noria:NetworkLink_LAN_WS01_AS01, noria:NetworkLink_LAN_DB01_AS01, noria:NetworkLink_LAN_AS01_CR01 .
noria:OrgUnit_SecurityTeam noria:agentManagesResource noria:Application_MonitoringSystem .

# Link application modules to resources
noria:ApplicationModule_CWP_Frontend seas:subSystemOf noria:Resource_WebServer01 .
noria:ApplicationModule_CWP_Backend seas:subSystemOf noria:Resource_WebServer01 .
noria:ApplicationModule_CWP_Database seas:subSystemOf noria:Resource_DBServer01 .

# Link trouble tickets to related events and parties
noria:TroubleTicket_CWP_Outage_001 dcterms:relation noria:EventRecord_DBError_DB01 . # CWP outage might be related to DB issues too
noria:TroubleTicket_CWP_Outage_001 noria:troubleTicketRelatedParty noria:OrgUnit_DBATeam . # DBA team might be involved in CWP outage
noria:TroubleTicket_DB_Issue_002 dcterms:relation noria:EventRecord_HighCPU_WS01 . # DB issue might be a symptom of web server overload
noria:TroubleTicket_Network_Outage_003 noria:troubleTicketRelatedParty noria:OrgUnit_WebOpsTeam . # WebOps team affected by network outage

# Link change requests to related events
noria:ChangeRequest_WS01_RAMUpgrade dcterms:relation noria:EventRecord_HighCPU_WS01 . # CR is a follow-up to the high CPU event
noria:ChangeRequest_CR01_FirmwareUpdate dcterms:relation noria:EventRecord_ConfigChange_CR01 . # CR is a follow-up to a previous config change or related to network stability

# Example of document status history
noria:TroubleTicket_CWP_Outage_001 noria:documentStatusHistory noria:EventRecord_TT_CWP_StatusChange_InProgress .
noria:EventRecord_TT_CWP_StatusChange_InProgress a noria:EventRecord ;
    rdfs:label "Trouble Ticket CWP-001 Status Change to InProgress"@en ;
    noria:loggingTime "2024-04-20T14:32:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Trouble Ticket TT-CWP-20240420-001 status changed to InProgress."@en ;
    dcterms:references noria:TroubleTicket_CWP_Outage_001 .

noria:TroubleTicket_CWP_Outage_001 noria:documentStatusHistory noria:EventRecord_TT_CWP_StatusChange_Resolved .
noria:EventRecord_TT_CWP_StatusChange_Resolved a noria:EventRecord ;
    rdfs:label "Trouble Ticket CWP-001 Status Change to Resolved"@en ;
    noria:loggingTime "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Trouble Ticket TT-CWP-20240420-001 status changed to Resolved."@en ;
    dcterms:references noria:TroubleTicket_CWP_Outage_001 .

# Example of correlated execution for a trouble ticket note
noria:TroubleTicketNote_CWP_001_Note2 noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer_RestartWebService .
noria:ProcedureExecutionContainer_RestartWebService a pep:ProcedureExecutionContainer ;
    rdfs:label "Web Service Restart Execution"@en ;
    rdfs:comment "Container for the execution records related to restarting the web service."@en ;
    dcterms:created "2024-04-20T14:38:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_Alice .

# Example of an action correlated operation plan
noria:Action_RestartWebService a pep:Action ;
     # Assuming pep:Action exists or can be inferred

    rdfs:label "Restart Web Service Action"@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_RestartWebService .

# Further linking of agents to their interests (resources they manage)
noria:Agent_Alice foaf:topic_interest noria:Resource_WebServer01, noria:Application_CorporateWebPortal .
noria:Agent_Bob foaf:topic_interest noria:Resource_DBServer01, noria:ApplicationModule_CWP_Database .
noria:Agent_Charlie foaf:topic_interest noria:Resource_CoreRouter01, noria:NetworkLink_LAN_AS01_CR01 .

# Example of a resource being part of a service
noria:Resource_WebServer01 seas:subSystemOf noria:Service_WebHostingPlatform .
noria:Resource_DBServer01 seas:subSystemOf noria:Service_WebHostingPlatform .

# Example of a resource being part of a larger system (e.g., a data center infrastructure)
noria:Resource_WebServer01 seas:subSystemOf noria:Site_ParisDC .
noria:Resource_DBServer01 seas:subSystemOf noria:Site_ParisDC .
noria:Resource_CoreRouter01 seas:subSystemOf noria:Site_ParisDC .

# Example of a network interface having routing priority metric
noria:NetworkInterface_CR01_Eth1 noria:networkInterfaceRoutingPriorityMetric 100 .

