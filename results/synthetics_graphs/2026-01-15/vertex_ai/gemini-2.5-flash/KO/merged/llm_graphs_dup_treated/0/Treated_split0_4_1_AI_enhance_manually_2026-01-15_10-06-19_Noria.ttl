# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizations
noria:Org_IT_Department a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department responsible for all IT operations."@en ;
    org:hasUnit noria:OrgUnit_WebOpsTeam, noria:OrgUnit_DBATeam, noria:OrgUnit_NetworkTeam, noria:OrgUnit_SecurityTeam .

noria:OrgUnit_WebOpsTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Web Operations Team"@en ;
    rdfs:comment "Team responsible for the deployment and operation of web applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en ;
    org:unitOf noria:Org_IT_Department .

noria:OrgUnit_DBATeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for managing and maintaining database systems."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "All database-related requests must go through the dedicated service portal."@en ;
    org:unitOf noria:Org_IT_Department .

noria:OrgUnit_NetworkTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For network outages, call the emergency number immediately. Otherwise, open a ticket."@en ;
    org:unitOf noria:Org_IT_Department .

noria:OrgUnit_SecurityTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report all security incidents via the dedicated security incident platform."@en ;
    org:unitOf noria:Org_IT_Department .

# Individual Agents
noria:Agent_Alice a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead WebOps Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    org:memberOf noria:OrgUnit_WebOpsTeam .

noria:Agent_Bob a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior DBA."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf noria:OrgUnit_DBATeam .

noria:Agent_Charlie a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Network Architect."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    org:memberOf noria:OrgUnit_NetworkTeam .

noria:Agent_Dave a foaf:Person, foaf:Agent ;
    rdfs:label "Dave Davis"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:dave.davis@example.com> ;
    org:memberOf noria:OrgUnit_SecurityTeam .

# Corporate User Identifiers
noria:CUid_Alice a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount noria:Agent_Alice .

noria:CUid_Bob a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount noria:Agent_Bob .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series Switch"@en ;
    rdfs:comment "Data center-class switch for high-density deployments."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480 Router"@en ;
    rdfs:comment "Modular router for enterprise and service provider applications."@en ;
    noria:productManufacturedBy noria:Org_Juniper .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Type-1 hypervisor for virtualizing servers."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:Org_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking hardware and services."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization software company."@en .

# =============================================================================
# Locations
# =============================================================================

noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris, France."@en ;
    noria:siteId "PARIS-DC-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    bot:containsZone noria:Room_ServerRoomA, noria:Room_NetworkRoomB .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Dedicated room for server racks within the Paris Data Center."@en ;
    bot:hasSubSpace noria:Locus_Rack12, noria:Locus_Rack13 .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Room housing core network equipment in the Paris Data Center."@en ;
    bot:hasSubSpace noria:Locus_NetworkRack01 .

noria:Locus_Rack12 a noria:Locus ;
    rdfs:label "Rack 12, Server Room A"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "12" .

noria:Locus_Rack13 a noria:Locus ;
    rdfs:label "Rack 13, Server Room A"@en ;
    rdfs:comment "Specific rack location for database servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "13" .

noria:Locus_NetworkRack01 a noria:Locus ;
    rdfs:label "Network Rack 01, Network Room B"@en ;
    rdfs:comment "Specific rack location for network devices."@en ;
    noria:locusLine "B" ;
    noria:locusRow "01" .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_WebServer01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server for corporate applications."@en ;
    noria:resourceLogisticId "ASSET-WS-001" ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WS-001-XYZ" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:OrgUnit_WebOpsTeam ;
    noria:locatedAtLocus noria:Locus_Rack12 ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
    noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:Resource_DBServer01 a noria:Resource ;
