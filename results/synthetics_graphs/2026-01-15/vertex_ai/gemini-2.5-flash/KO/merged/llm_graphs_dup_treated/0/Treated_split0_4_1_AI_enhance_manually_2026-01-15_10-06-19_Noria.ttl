noria:Resource_VirtualMachine_App01 a noria:Resource ;
    rdfs:label "Virtual Machine for App01"@en ;
    rdfs:comment "Virtual machine hosting a component of Application01."@en ;
    noria:resourceHostName "vm-app01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
     # The hypervisor model, not the VM itself, but it's a valid link.

    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-05-10T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:OrgUnit_WebOpsTeam ;
    noria:clusterController noria:Resource_HypervisorHost01 ;
     # Example of cluster controller

    noria:resourceManagementIPAddress "10.0.1.50" .

noria:Resource_HypervisorHost01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server running VMware ESXi, hosting virtual machines."@en ;
    noria:resourceHostName "hv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
