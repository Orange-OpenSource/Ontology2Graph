    noria:resourceSerialNumber "SN-DB-001-ABC" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:OrgUnit_DBATeam ;
    noria:locatedAtLocus noria:Locus_Rack13 ;
    noria:resourceManagementIPAddress "10.0.0.11" ;
    noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the data center network."@en ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceHostName "cr01.paris.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR-001-DEF" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-05-20T09:00:00Z"^^xsd:dateTime ;
