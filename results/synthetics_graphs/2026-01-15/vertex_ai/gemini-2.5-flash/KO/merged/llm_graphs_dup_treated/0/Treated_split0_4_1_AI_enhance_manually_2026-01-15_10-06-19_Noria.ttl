noria:Resource_AccessSwitch01 a noria:Resource ;
    rdfs:label "Access Switch 01"@en ;
    rdfs:comment "Access layer switch for Rack 12."@en ;
    noria:resourceLogisticId "ASSET-AS-001" ;
    noria:resourceHostName "as01-rack12.paris.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-AS-001-GHI" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InUse> ;
