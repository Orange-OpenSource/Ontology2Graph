    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InUse> ;
    noria:resourceManagedBy noria:OrgUnit_WebOpsTeam ;
    noria:locatedAtLocus noria:Locus_Rack12 ;
    noria:resourceManagementIPAddress "10.0.0.15" .

# =============================================================================
# Network Interfaces and Links
# =============================================================================

noria:NetworkInterface_WS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0 on Web Server 01"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer01 ;
    noria:networkInterfaceDescription "Management and application traffic interface."@en ;
