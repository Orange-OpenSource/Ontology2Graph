bot:Site_MainDC_extra_node_3 a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    noria:siteId "DC01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA_extra_node_3 a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server room within the main data center."@en ;
    bot:hasSpace bot:Site_MainDC_extra_node_3 .

noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en, "Baie A1, Unité 23"@fr ;
    rdfs:comment "Specific location for a resource within Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "23" ;
    bot:hasSpace noria:Room_ServerRoomA_extra_node_3 .

noria:Locus_RackA2_U10 a noria:Locus ;
    rdfs:label "Rack A2, Unit 10"@en, "Baie A2, Unité 10"@fr ;
    rdfs:comment "Specific location for another resource within Server Room A."@en ;
    noria:locusLine "A2" ;
    noria:locusRow "10" ;
    bot:hasSpace noria:Room_ServerRoomA_extra_node_3 .

