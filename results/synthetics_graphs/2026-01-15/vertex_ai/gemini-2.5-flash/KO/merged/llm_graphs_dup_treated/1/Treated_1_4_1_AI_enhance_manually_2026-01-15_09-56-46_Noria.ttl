    seas:subSystemOf noria:Application_NetworkInfrastructure ;
    noria:elementManagedBy foaf:Agent_NetworkTeam .

# =============================================================================
# Dynamic Elements (Trouble Tickets, Change Requests, Event Records)
# =============================================================================

noria:EventRecord_DNSOutage a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Alert"@en, "Alerte Serveur DNS Inaccessible"@fr ;
    rdfs:comment "Automated alert indicating that dns01.corp.example.com is unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01_extra_node_3 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_3 ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN. Ping failed."@en ;
    noria:alarmSeverity kos-notif-sev:Critical_extra_node_3 ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartDNS ;
    folio:happenedAt noria:Resource_DNS01_extra_node_3 .

noria:EventRecord_InterfaceDown_extra_node_3 a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en, "Alerte Interface Réseau Hors Service"@fr ;
    rdfs:comment "Alert indicating that GigabitEthernet0/0/1 on rtr01.dc01.example.com went down."@en ;
    noria:loggingTime "2024-04-20T08:59:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Router01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_3 ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity kos-notif-sev:Major_extra_node_3 ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckCable ;
    folio:happenedAt noria:Resource_Router01 .

noria:Application_MonitoringSystem_extra_node_3 a noria:Application ;
    rdfs:label "Network Monitoring System"@en, "Système de Surveillance Réseau"@fr ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType kos-app-type:Infrastructure ;
    noria:elementManagedBy foaf:Agent_NetworkTeam .

noria:TroubleTicket_DNSOutage_TT001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident - TT001"@en, "Incident Panne Serveur DNS - TT001"@fr ;
    dcterms:identifier "TT001" ;
    dcterms:created "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    dcterms:description "DNS server dns01.corp.example.com is unreachable, impacting all corporate services."@en ;
    noria:troubleTicketSeverity kos-tt-sev:Critical_extra_node_3 ;
