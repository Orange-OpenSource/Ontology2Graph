# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_RestartDNS a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en, "Procédure de Redémarrage du Service DNS"@fr ;
    rdfs:comment "Standard operating procedure for restarting the DNS service on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSRestored ;
    pep:hasInput noria:Resource_DNS01_extra_node_3 .

noria:OperationPlan_CheckCable a noria:OperationPlan ;
    rdfs:label "Network Cable Check Procedure"@en, "Procédure de Vérification de Câble Réseau"@fr ;
    rdfs:comment "Procedure to physically check and reseat network cables."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown_extra_node_3 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp_extra_node_3 .

noria:ActionPreCondition_DNSUnreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS server is not responding to queries or pings."@en ;
    skos:example "Ping to DNS server fails, DNS queries timeout."@en .

noria:ActionPostCondition_DNSRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS server is reachable and responding to queries."@en ;
    skos:example "Ping to DNS server succeeds, DNS queries resolve correctly."@en .

noria:ActionPreCondition_InterfaceDown_extra_node_3 a noria:ActionPreCondition ;
    rdfs:label "Network Interface Administratively Down"@en ;
    rdfs:comment "Condition: A network interface is reported as administratively down."@en ;
    skos:example "Router log shows 'LINEPROTO-5-UPDOWN: ... changed state to down'."@en .

noria:ActionPostCondition_InterfaceUp_extra_node_3 a noria:ActionPostCondition ;
    rdfs:label "Network Interface Operational"@en ;
    rdfs:comment "Outcome: The network interface is up and passing traffic."@en ;
    skos:example "Router log shows 'LINEPROTO-5-UPDOWN: ... changed state to up'."@en .

noria:AnomalyPattern_DNSFailure a noria:AnomalyPattern ;
    rdfs:label "DNS Service Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a DNS service failure, often correlated with network issues or resource overload."@en ;
    skos:example "Multiple DNS unreachable alerts from different monitoring points, combined with high CPU usage on the DNS server."@en ;
    folio:hasCause noria:TroubleTicket_DNSOutage_TT001 .
