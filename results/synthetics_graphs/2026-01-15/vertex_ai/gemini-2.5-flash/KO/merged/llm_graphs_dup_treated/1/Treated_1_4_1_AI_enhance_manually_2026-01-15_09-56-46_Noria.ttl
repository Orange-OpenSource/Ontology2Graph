@prefix kos-tt-cat: <https://w3id.org/noria/kos/TroubleTicket/category/> .
@prefix kos-tt-prio: <https://w3id.org/noria/kos/TroubleTicket/priority/> .
@prefix kos-tt-origin: <https://w3id.org/noria/kos/TroubleTicket/origin/> .
@prefix kos-tt-urg: <https://w3id.org/noria/kos/TroubleTicket/urgency/> .
@prefix kos-tt-tc: <https://w3id.org/noria/kos/TroubleTicket/trouble-category/> .
@prefix kos-tt-pr: <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/> .
@prefix kos-tt-status: <https://w3id.org/noria/kos/TroubleTicket/status/> .
@prefix kos-tt-cmt: <https://w3id.org/noria/kos/TroubleTicket/commentType/> .
@prefix kos-tt-op: <https://w3id.org/noria/kos/TroubleTicket/operationType/> .
@prefix kos-cr-cat: <https://w3id.org/noria/kos/ChangeRequest/category/> .
@prefix kos-cr-type: <https://w3id.org/noria/kos/ChangeRequest/type/> .
@prefix kos-cr-cause: <https://w3id.org/noria/kos/ChangeRequest/cause/> .
@prefix kos-cr-status: <https://w3id.org/noria/kos/ChangeRequest/status/> .
@prefix kos-cr-spec: <https://w3id.org/noria/kos/ChangeRequest/specification/> .
@prefix kos-res-op: <https://w3id.org/noria/kos/Resource/OperationalState/> .
@prefix kos-res-adm: <https://w3id.org/noria/kos/Resource/AdministrativeState/> .
@prefix kos-res-type: <https://w3id.org/noria/kos/Resource/type/> .
@prefix kos-res-lc: <https://w3id.org/noria/kos/Resource/LifecycleState/> .
@prefix kos-notif-sev: <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/> .
@prefix kos-org-contact: <https://w3id.org/noria/kos/org/agent-contact-method/> .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_AdminTeam a foaf:Agent ;
    rdfs:label "IT Operations Admin Team"@en, "Équipe d'Administration des Opérations IT"@fr ;
    rdfs:comment "Team responsible for the overall IT infrastructure and core services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod kos-org-contact:Email_extra_node_3 ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, direct phone for critical incidents."@en ;
    noria:agentManagesResource noria:Resource_DNS01_extra_node_3, noria:Resource_WebSrv01_extra_node_3, noria:Resource_Firewall01 .

foaf:Agent_NetworkTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe des Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri, on-call for critical issues"@en ;
    noria:agentPreferredContactMethod kos-org-contact:Phone_extra_node_3 ;
    noria:agentInstructions "Use dedicated network monitoring tools for initial diagnosis."@en ;
    noria:agentManagesResource noria:Resource_Router01, noria:Resource_Switch01 .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en, "Équipe de Développement Applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining the Corporate Web Portal application."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod kos-org-contact:Chat ;
    noria:agentManagesResource noria:Resource_WebSrv01_extra_node_3 .

foaf:Agent_JohnDoe_extra_node_3 a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual IT Administrator, member of the IT Operations Admin Team."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod kos-org-contact:Email_extra_node_3 .

noria:CorporateUserIdentifier_JohnDoe_extra_node_3 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Unique corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount foaf:Agent_JohnDoe_extra_node_3 .

org:OrgUnit_ITOps a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en, "Département des Opérations IT"@fr ;
    rdfs:comment "Main department for IT operations."@en ;
    org:hasMember foaf:Agent_AdminTeam, foaf:Agent_NetworkTeam, foaf:Agent_JohnDoe_extra_node_3 .

