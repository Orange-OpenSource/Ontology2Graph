# =============================================================================
# Applications
# =============================================================================

noria:Application_DNS a noria:Application ;
    rdfs:label "Corporate DNS Service Application"@en, "Application de Service DNS d'Entreprise"@fr ;
    rdfs:comment "Application providing DNS resolution for the corporate network."@en ;
    noria:applicationModelIdentifier "DNS-APP-V1" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CORP-DNS" ;
    noria:applicationType kos-app-type:Infrastructure ;
    noria:applicationBusinessImportance kos-app-bizimp:High ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "Name Resolution"@en ;
    noria:elementManagedBy foaf:Agent_AdminTeam .

noria:Application_WebPortal a noria:Application ;
    rdfs:label "Corporate Web Portal Application"@en, "Application du Portail Web d'Entreprise"@fr ;
    rdfs:comment "Main web application for internal corporate information."@en ;
    noria:applicationModelIdentifier "WEB-PORTAL-V2" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CORP-WEB" ;
    noria:applicationType kos-app-type:BusinessApplication ;
    noria:applicationBusinessImportance kos-app-bizimp:High ;
    noria:applicationFunctionalDomain "Employee Services"@en ;
    noria:applicationFunctionalSubDomain "Information Access"@en ;
    noria:elementManagedBy foaf:Agent_AppDevTeam .

noria:Application_NetworkInfrastructure a noria:Application ;
    rdfs:label "Core Network Infrastructure Application"@en, "Application d'Infrastructure Réseau Centrale"@fr ;
    rdfs:comment "Represents the core network services and devices as an application."@en ;
    noria:applicationModelIdentifier "NET-INFRA-V1" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "CORE-NET" ;
    noria:applicationType kos-app-type:Infrastructure ;
    noria:applicationBusinessImportance kos-app-bizimp:Critical_extra_node_3 ;
    noria:applicationFunctionalDomain "Network Management"@en ;
    noria:applicationFunctionalSubDomain "Routing and Switching"@en ;
    noria:elementManagedBy foaf:Agent_NetworkTeam .

