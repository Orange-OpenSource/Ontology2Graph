noria:Service_CorpDNS a noria:Service ;
    rdfs:label "Corporate DNS Resolution Service"@en, "Service de Résolution DNS d'Entreprise"@fr ;
    rdfs:comment "End-to-end service for DNS resolution, critical for all corporate operations."@en ;
