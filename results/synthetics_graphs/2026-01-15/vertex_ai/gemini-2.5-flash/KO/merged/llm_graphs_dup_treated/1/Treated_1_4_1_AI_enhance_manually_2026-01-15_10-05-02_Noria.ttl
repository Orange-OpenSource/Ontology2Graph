# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_InterfaceTroubleshooting a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    noria:operationPlanPreCondition noria:PreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:PostCondition_InterfaceUp .

noria:PreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en ;
    skos:example "Check 'show interface status' command output for 'down' state."@en .

noria:PostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up' and traffic is flowing."@en ;
    skos:example "Verify 'show interface status' command output for 'up' state and ping connectivity."@en .

noria:OperationPlan_DBRestart a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting the database service on a server."@en ;
    noria:operationPlanPreCondition noria:PreCondition_DBErrors ;
    noria:operationPlanPostCondition noria:PostCondition_DBServiceRestored .

noria:PreCondition_DBErrors a noria:ActionPreCondition ;
    rdfs:label "Database Connection Errors Detected"@en ;
    rdfs:comment "Condition: Monitoring system reports high rate of database connection errors."@en .

noria:PostCondition_DBServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Database Service Restored"@en ;
    rdfs:comment "Expected outcome: Database service is running, and connection errors have ceased."@en .

noria:AnomalyPattern_HighTrafficLowLatency a noria:AnomalyPattern ;
    rdfs:label "High Traffic, Low Latency Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating an unusual combination of high network traffic with unexpectedly low latency, potentially suggesting a traffic bypass or misconfiguration."@en ;
    skos:example "Observed 10Gbps traffic on a link with 1ms latency, while historical data shows 5ms latency for similar traffic levels."@en .

noria:AnomalyPattern_DNSCachePoisoning a noria:AnomalyPattern ;
    rdfs:label "DNS Cache Poisoning Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating suspicious DNS query responses, potentially due to cache poisoning."@en ;
    skos:example "Multiple DNS queries for known legitimate domains returning incorrect IP addresses from internal DNS server."@en .

# =============================================================================
# Document Attachments
# =============================================================================

noria:DocumentAttachment_NetworkDiagram_extra_node_2 a noria:DocumentAttachment ;
    rdfs:label "Data Center Network Diagram"@en ;
    rdfs:comment "PDF document containing the logical and physical network topology of the main data center."@en ;
    dcterms:isPartOf noria:TroubleTicket_TT001 ;
    dcterms:isPartOf noria:ChangeRequest_CR001 ;
    dcterms:format "application/pdf" ;
    dcterms:source "https://docs.example.com/network_diagram_dc01.pdf" .

noria:DocumentAttachment_PatchPlan a noria:DocumentAttachment ;
    rdfs:label "DB Server Patching Plan"@en ;
    rdfs:comment "Detailed plan for applying OS patches to the database server, including rollback procedures."@en ;
    dcterms:isPartOf noria:ChangeRequest_CR002 ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:source "https://docs.example.com/db_patch_plan.docx" .

