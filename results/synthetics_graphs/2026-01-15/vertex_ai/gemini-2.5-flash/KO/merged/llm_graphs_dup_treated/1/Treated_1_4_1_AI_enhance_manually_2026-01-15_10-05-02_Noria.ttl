    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_2> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterDC01_Eth1 a noria:NetworkInterface ;
    rdfs:label "RouterDC01 Ethernet0/1"@en ;
    rdfs:comment "Physical interface on RouterDC01 connected to the DMZ firewall."@en ;
    noria:networkInterfaceOf noria:Resource_RouterDC01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_2> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

noria:NetworkInterface_FirewallDMZ_Eth0 a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ Ethernet0/0"@en ;
