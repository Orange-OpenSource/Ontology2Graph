# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_ITOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    rdfs:label "Équipe Opérations IT"@fr ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Use the primary ticketing system for all incidents. For critical issues, follow up with a phone call to the on-call engineer."@en .

foaf:Agent_NetworkAdmin a foaf:Agent, foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Administrator, responsible for core network infrastructure."@en ;
    rdfs:label "Alice Smith, Administratrice Réseau Principale"@fr ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_2> .

foaf:Agent_AppDevTeam_extra_node_2 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the Customer Portal application."@en ;
    rdfs:label "Équipe de Développement d'Applications"@fr ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    rdfs:label "Centre d'Opérations de Sécurité (SOC)"@fr ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_2> .

foaf:Agent_BobJohnson a foaf:Agent, foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior System Administrator, specializing in database management."@en ;
    noria:agentWorkingHours "8:30-17:30 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_2> .

foaf:Agent_CustomerSupport a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "First-line support for customer inquiries and issues."@en ;
    noria:agentWorkingHours "8:00-20:00 (Mon-Sun)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_2> .

noria:CUid_AliceSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within the corporate IT systems."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount foaf:Agent_NetworkAdmin .

noria:CUid_BobJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Bob Johnson within the corporate IT systems."@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount foaf:Agent_BobJohnson .

org:Manufacturer_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server and networking hardware."@en .

org:Manufacturer_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking equipment."@en .

# =============================================================================
# Locations
# =============================================================================

bot:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

bot:Site_BranchOffice a bot:Site ;
    rdfs:label "Branch Office Paris"@en ;
    rdfs:comment "Regional office location in Paris."@en ;
    noria:siteId "BO-PAR" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA_extra_node_2 a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:containedIn bot:Site_MainDataCenter .

noria:Room_NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in the Branch Office."@en ;
    bot:containedIn bot:Site_BranchOffice .

noria:Locus_Rack12_U42 a noria:Locus ;
    rdfs:label "Rack 12, Unit 42"@en ;
    rdfs:comment "Specific location for a server within Server Room A."@en ;
    noria:locusLine "Rack 12" ;
    noria:locusRow "U42" ;
    bot:containedIn noria:Room_ServerRoomA_extra_node_2 .

noria:Locus_Rack03_U10 a noria:Locus ;
    rdfs:label "Rack 03, Unit 10"@en ;
    rdfs:comment "Specific location for a network device within Network Closet B."@en ;
    noria:locusLine "Rack 03" ;
    noria:locusRow "U10" ;
    bot:containedIn noria:Room_NetworkClosetB .

