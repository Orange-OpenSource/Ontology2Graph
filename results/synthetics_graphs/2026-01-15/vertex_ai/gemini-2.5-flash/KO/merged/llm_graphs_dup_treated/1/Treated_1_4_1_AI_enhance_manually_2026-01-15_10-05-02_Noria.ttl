noria:NetworkInterface_SwitchBO01_Uplink a noria:NetworkInterface ;
    rdfs:label "SwitchBO01 Uplink Port"@en ;
    rdfs:comment "Uplink interface on SwitchBO01 connecting to the WAN."@en ;
    noria:networkInterfaceOf noria:Resource_SwitchBO01 ;
