noria:Resource_DNS01_extra_node_2 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for the corporate network, located in the main data center."@en ;
    rdfs:label "Serveur DNS d'entreprise 01"@fr ;
