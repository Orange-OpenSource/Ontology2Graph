noria:NetworkInterface_RouterDC01_Eth0 a noria:NetworkInterface ;
    rdfs:label "RouterDC01 Ethernet0/0"@en ;
    rdfs:comment "Physical interface on RouterDC01 connected to the internal network."@en ;
