noria:OperationPlan:DNSFailoverProcedure_extra_node_1 a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard_extra_node_1 operating procedure for failing over to a secondary DNS server in case of primary failure."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition:DNSPrimaryDown_extra_node_1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition:DNSServiceRestored_extra_node_1 .

noria:OperationPlan:WebRestartProcedure_extra_node_1 a noria:OperationPlan ;
    rdfs:label "Web Server_extra_node_1 Restart Procedure"@en ;
    rdfs:comment "Procedure to restart the web server application in case of performance issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition:WebTrafficHigh_extra_node_1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition:WebPerformanceNormal_extra_node_1 .

noria:OperationPlan:FirewallUpdateProcedure_extra_node_1 a noria:OperationPlan ;
    rdfs:label "Firewall_extra_node_1 OS Update Procedure"@en ;
    rdfs:comment "Detailed steps for performing an OS update on the perimeter firewall."@en ;
    noria:operationPlanPostCondition noria:ActionPostCondition:FirewallUpdated_extra_node_1 .

noria:ActionPreCondition:DNSPrimaryDown_extra_node_1 a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server_extra_node_1 Down Condition"@en ;
    rdfs:comment "Condition where the primary DNS server is unresponsive or unreachable."@en .

noria:ActionPreCondition:WebTrafficHigh_extra_node_1 a noria:ActionPreCondition ;
    rdfs:label "High Web Traffic Condition"@en ;
    rdfs:comment "Condition where web server traffic or CPU usage exceeds predefined thresholds."@en .

noria:ActionPostCondition:DNSServiceRestored_extra_node_1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Condition"@en ;
    rdfs:comment "Condition where DNS resolution is fully functional after an incident."@en .

noria:ActionPostCondition:WebPerformanceNormal_extra_node_1 a noria:ActionPostCondition ;
    rdfs:label "Web Performance Normal Condition"@en ;
    rdfs:comment "Condition where web server response times and resource utilization return to normal levels."@en .

noria:ActionPostCondition:FirewallUpdated_extra_node_1 a noria:ActionPostCondition ;
    rdfs:label "Firewall_extra_node_1 OS Updated Successfully"@en ;
    rdfs:comment "Condition where the firewall OS update is completed and verified."@en .

noria:AnomalyPattern:DNSResolutionFailure_extra_node_1 a noria:AnomalyPattern ;
    rdfs:label "DNS Resolution Failure_extra_node_1 Pattern"@en ;
    rdfs:comment "Pattern indicating a widespread failure in DNS resolution, potentially due to primary DNS server outage."@en ;
    folio:hasCause noria:EventRecord:DNSDownAlert_extra_node_1 .

