# Agents and Organizations
# =============================================================================

foaf:Agent:AdminTeamDNS_extra_node_1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Email_extra_node_1 for non-urgent issues, hotline for critical outages."@en .

foaf:Agent:NetworkOps_extra_node_1 a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure_extra_node_1 and connectivity."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_1> ;
    noria:agentInstructions "Always use the dedicated NOC hotline."@en .

foaf:Agent:AppDevTeam_extra_node_1 a foaf:Agent ;
    rdfs:label "Application Development_extra_node_1 Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> .

foaf:Agent:SecurityTeam_extra_node_1 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring_extra_node_1 and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_1> .

foaf:Agent:UserJohnDoe_extra_node_1 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An end-user reporting an issue."@en .

foaf:Agent:UserJaneSmith_extra_node_1 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An end-user experiencing service degradation."@en .

org:OrganizationalUnit:ITOperations_extra_node_1 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Overall department for IT infrastructure_extra_node_1 and services."@en ;
    org:hasMember foaf:Agent:AdminTeamDNS_extra_node_1, foaf:Agent:NetworkOps_extra_node_1 .

org:OrganizationalUnit:ApplicationSupportL2_extra_node_1 a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support for business applications."@en ;
    org:hasMember foaf:Agent:AppDevTeam_extra_node_1 .

# Corporate User Identifiers
