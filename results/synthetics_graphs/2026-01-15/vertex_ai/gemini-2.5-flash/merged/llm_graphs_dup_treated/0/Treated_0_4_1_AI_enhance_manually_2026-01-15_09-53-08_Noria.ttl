noria:EventRecord:DNSDownAlert_extra_node_1 a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_1 Down Alert"@en ;
    rdfs:comment "Automated alert indicating that the primary DNS server is unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource:DNS01_extra_node_1 ;
    noria:logOriginatingManagementSystem noria:Application:MonitoringSystem_extra_node_1 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_1> ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%"@en ;
    noria:alarmProposedRepairAction noria:OperationPlan:DNSFailoverProcedure_extra_node_1 .

noria:EventRecord:WebHighCPU_extra_node_1 a noria:EventRecord ;
    rdfs:label "Web Server_extra_node_1 High CPU Usage"@en ;
    rdfs:comment "Alert indicating sustained high_extra_node_1 CPU usage on the web server."@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource:WebSrv01_extra_node_1 ;
    noria:logOriginatingManagementSystem noria:Application:MonitoringSystem_extra_node_1 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_1> ;
    noria:logText "WARNING: Host web01.customer.example.com CPU usage is 95% for 15 minutes."@en ;
    noria:alarmProposedRepairAction noria:OperationPlan:WebRestartProcedure_extra_node_1 .

noria:EventRecord:RouterLinkDown_extra_node_1 a noria:EventRecord ;
    rdfs:label "Router_extra_node_1 Core Link Down"@en ;
    rdfs:comment "Log entry indicating a network interface on the core router went down."@en ;
    noria:loggingTime "2024-04-10T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource:RouterCore01_extra_node_1 ;
    noria:logOriginatingManagementSystem noria:Application:LogManagement_extra_node_1 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_1> ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down"@en .

noria:EventRecord:FirewallConfigChange_extra_node_1 a noria:EventRecord ;
