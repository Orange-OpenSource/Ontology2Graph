    noria:resourceType <kos/Resource/type/Router_extra_node_0> ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_0> ;
    noria:resourceInstallationDate "2021-08-15T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_0 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_Firewall01_extra_node_0 a noria:Resource ;
    rdfs:label "Perimeter Firewall_extra_node_0 01"@en ;
    rdfs:comment "Primary firewall protecting the corporate network."@en ;
    noria:resourceManagedBy org:SecurityOperationsCenter_extra_node_0 ;
    noria:resourceHostName "fw-perimeter-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_PaloAltoFW_extra_node_0 ;
    noria:resourceLogisticId "ASSET-FW-001" ;
    noria:resourceType <kos/Resource/type/Firewall_extra_node_0> ;
    noria:resourceSerialNumber "SN-FW01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_0> ;
