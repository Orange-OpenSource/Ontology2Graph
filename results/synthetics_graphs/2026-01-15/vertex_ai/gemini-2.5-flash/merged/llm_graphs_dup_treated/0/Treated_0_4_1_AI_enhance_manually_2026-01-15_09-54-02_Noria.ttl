noria:NI_Firewall01_Eth1_extra_node_0 a noria:NetworkInterface ;
    rdfs:label "fw-perimeter-01:eth1"@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01_extra_node_0 ;
    noria:networkInterfaceDescription "Internal_extra_node_0 interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_0> .

# Network Links
noria:NL_CoreRouter_DNS01_extra_node_0 a noria:NetworkLink ;
    rdfs:label "Link between Core Router_extra_node_0 and DNS01"@en ;
    noria:networkLinkId "NL-CR01-DNS01" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01_extra_node_0, noria:Resource_DNS01_extra_node_0 ;
    noria:networkLinkInstallationDate "2022-03-10T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gi0_0_1_extra_node_0, noria:NI_DNS01_Eth1_extra_node_0 .

noria:NL_Firewall_CoreRouter_extra_node_0 a noria:NetworkLink ;
    rdfs:label "Link between Firewall_extra_node_0 and Core Router_extra_node_0"@en ;
    noria:networkLinkId "NL-FW01-CR01" ;
    noria:networkLinkTerminationResource noria:Resource_Firewall01_extra_node_0, noria:Resource_RouterCore01_extra_node_0 ;
    noria:networkLinkInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects noria:NI_Firewall01_Eth1_extra_node_0, noria:NI_RouterCore01_Gi0_0_1_extra_node_0 .

noria:NL_VMHost_CoreRouter_extra_node_0 a noria:NetworkLink ;
    rdfs:label "Link between VM Host and Core Router_extra_node_0"@en ;
    noria:networkLinkId "NL-VMH01-CR01" ;
    noria:networkLinkTerminationResource noria:Resource_VMHost01_extra_node_0, noria:Resource_RouterCore01_extra_node_0 ;
    noria:networkLinkInstallationDate "2022-06-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gi0_0_1_extra_node_0 . # Assuming VMHost has an interface connected to the same LAN as DNS01 and Firewall_extra_node_0

