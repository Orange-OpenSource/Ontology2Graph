# 12. Procedural Elements
# =============================================================================

noria:OperationPlan_DNSFailover_extra_node_0 a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard_extra_node_0 operating procedure for failing over primary DNS to secondary DNS in case of outage."@en ;
    skos:example "Steps include verifying primary DNS status, updating load balancer, verifying secondary DNS, and monitoring_extra_node_0 service restoration."@en .

noria:OperationPlan_RouterSoftwareUpgrade_extra_node_0 a noria:OperationPlan ;
    rdfs:label "Router_extra_node_0 Software Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading Cisco Nexus 9000 series router software."@en ;
    skos:example "Includes pre-checks, backup configuration, image transfer, upgrade command, post-checks."@en ;
    noria:actionCorrelatedOperationPlan noria:ChangeRequest_RouterUpgrade_extra_node_0 .

noria:ActionPreCondition_DNSPrimaryDown_extra_node_0 a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Unreachable"@en ;
    rdfs:comment "Condition: Primary DNS server (dns01.corp.example.com) is not responding to health checks."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_DNSFailover_extra_node_0 .

noria:ActionPostCondition_DNSServiceRestored_extra_node_0 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: All corporate services are able to resolve DNS names successfully."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_DNSFailover_extra_node_0 .

noria:AnomalyPattern_HighCPU_CRMSlow_extra_node_0 a noria:AnomalyPattern ;
    rdfs:label "High CPU leading to CRM Slow Performance"@en ;
    rdfs:comment "Pattern: Sustained high_extra_node_0 CPU utilization on CRM VM (e.g., >90% for 15 minutes) correlates with user reports of slow CRM performance."@en ;
    folio:hasCause noria:Resource_CRM_VM_extra_node_0 ;
    folio:hasEffect noria:Application_CRMSystem_extra_node_0 .

# Linking EventRecord to OperationPlan via pep:ProcedureExecutionContainer
# This is an example of how an EventRecord might be part of a procedure execution container,
# which itself might be related to an OperationPlan.
# For simplicity, I'll link the TroubleTicketNote to a hypothetical procedure execution container.
# The schema states: "a TroubleTicketNote is a context for (potentially) many *CorrectiveMaintenanceAction* to occur; hence it relates to a `pep:ProcedureExecutionContainer`"
# And "a `noria:TroubleTicketNote` to a `pep:ProcedureExecutionContainer` is akin to show off the materialization of a corrective maintenance action from the technical perspective."

# Let's create a hypothetical ProcedureExecutionContainer for the CRM CPU scale-up action.
noria:PEC_CRMScaledUp_extra_node_0 a pep:ProcedureExecutionContainer ;
    rdfs:label "CRM CPU Scale Up_extra_node_0 Execution"@en ;
    dcterms:description "Execution of CPU resource scaling for CRM VM."@en ;
    dcterms:created "2024-04-22T15:35:00Z"^^xsd:dateTime ;
    noria:troubleTicketNoteCorrelatedExecution noria:TroubleTicketNote_CRM_Diagnosis_extra_node_0 .

# And link the EventRecord_CRMVMScaledUp to this container (as ldp:member is forbidden, I'll use dcterms:relation as a general link)
dcterms:relation_extra_node_0 noria:PEC_CRMScaledUp_extra_node_0 noria:EventRecord_CRMVMScaledUp_extra_node_0 .

# Link the DNS outage trouble ticket to a procedure execution container for the failover
noria:PEC_DNSFailover_extra_node_0 a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS Failover Execution"@en ;
    dcterms:description "Execution of the DNS failover procedure."@en ;
    dcterms:created "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    dcterms:relation_extra_node_0 noria:TroubleTicket_DNSOutage_extra_node_0 .

# Link the EventRecord_DNSDown to the DNS outage trouble ticket's procedure execution container
dcterms:relation_extra_node_0 noria:PEC_DNSFailover_extra_node_0 noria:EventRecord_DNSDown_extra_node_0 .
dcterms:relation_extra_node_0 noria:PEC_DNSFailover_extra_node_0 noria:EventRecord_InterfaceDown_extra_node_0 .

# Link the OperationPlan to the ChangeRequest
noria:ChangeRequest_RouterUpgrade_extra_node_0 noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterSoftwareUpgrade_extra_node_0 .

# Ensure all entities are connected.
# I've tried to connect everything as I go. Let's do a quick check.
# - Agents/Orgs: Linked to Resources, AppModules, TroubleTickets, ChangeRequests.
# - ProductModels: Linked to Resources.
# - Locations: Linked to Resources.
# - Resources: Linked to Agents, ProductModels, Locations, NetworkInterfaces, Applications, TroubleTickets, ChangeRequests, EventRecords.
# - NetworkInterfaces: Linked to Resources, NetworkLinks.
# - NetworkLinks: Linked to NetworkInterfaces, Resources.
# - Applications: Linked to Resources, AppModules, Services, TroubleTickets, ChangeRequests, EventRecords.
# - AppModules: Linked to Applications, Agents, Services.
# - Services: Linked to Applications, AppModules, TroubleTickets, ChangeRequests.
# - TroubleTickets: Linked to Services, Applications, Resources, Agents, EventRecords, TroubleTicketNotes.
# - TroubleTicketNotes: Linked to TroubleTickets, Agents, EventRecords (via PEC).
# - EventRecords: Linked to Resources, Applications, Agents, TroubleTickets, TroubleTicketNotes (via PEC).
# - ChangeRequests: Linked to Resources, Applications, Services, Agents, OperationPlans.
# - OperationPlans: Linked to ChangeRequests, Pre/PostConditions.
# - Pre/PostConditions: Linked to OperationPlans.
# - AnomalyPatterns: Linked to Resources, Applications.
# - CorporateUserIdentifiers: Linked to foaf:Agent.

# All seems well connected.
