noria:Service_InternetAccess_extra_node_0 a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en, "Service d'Accès Internet d'Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService_extra_node_0> ;
    seas:subSystemOf noria:Application_CorporateDNS_extra_node_0, noria:Application_MonitoringPlatform_extra_node_0 ;
    seas:subSystemOf noria:ApplicationModule_CorporateDNS_Prod_extra_node_0, noria:ApplicationModule_MonitoringPlatform_Prod_extra_node_0 .

noria:Service_BusinessCriticalDataFlow_extra_node_0 a noria:Service ;
