# =============================================================================
# 1. Agents and Organizations
# =============================================================================

# Organizational Units (Teams)
org:ITOperationsTeam_extra_node_0 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en, "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure_extra_node_0 operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_0> ;
    noria:agentInstructions "For critical_extra_node_0 incidents, use the dedicated hotline after creating a P1_extra_node_0 ticket."@en .

org:NetworkEngineeringTeam_extra_node_0 a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en, "Équipe Ingénierie Réseau"@fr ;
    rdfs:comment "Team responsible for network design, implementation, and advanced troubleshooting."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> ;
    noria:agentInstructions "Contact via email for non-urgent requests. For urgent issues, escalate through IT Operations."@en .

org:ApplicationSupportTeam_extra_node_0 a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing support for business_extra_node_0 applications."@en ;
    noria:agentWorkingHours "8:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_0> .

org:SecurityOperationsCenter_extra_node_0 a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring_extra_node_0 and analyzing security events."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_0> .

# Individual Agents
foaf:JohnDoe_extra_node_0 a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com_extra_node_0> ;
    org:memberOf org:NetworkEngineeringTeam_extra_node_0 ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> .

foaf:JaneSmith_extra_node_0 a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior IT Operator."@en ;
    foaf:mbox <mailto:jane.smith@example.com_extra_node_0> ;
    org:memberOf org:ITOperationsTeam_extra_node_0 ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_0> .

foaf:AliceJohnson_extra_node_0 a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Application Support Specialist for CRM."@en ;
    foaf:mbox <mailto:alice.johnson@example.com_extra_node_0> ;
    org:memberOf org:ApplicationSupportTeam_extra_node_0 .

# Corporate User Identifiers
noria:CUid_JohnDoe_extra_node_0 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:JohnDoe_extra_node_0 .

noria:CUid_JaneSmith_extra_node_0 a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:JaneSmith_extra_node_0 .

