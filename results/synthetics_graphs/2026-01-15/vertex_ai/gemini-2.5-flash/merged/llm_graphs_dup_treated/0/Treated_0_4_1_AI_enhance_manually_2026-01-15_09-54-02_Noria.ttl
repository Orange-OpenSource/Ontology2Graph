    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_0 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server_extra_node_0> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_0> ;
    noria:resourceInstallationDate "2022-03-10T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_extra_node_0 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

