noria:NI_RouterCore01_Gi0_0_1_extra_node_0 a noria:NetworkInterface ;
    rdfs:label "router-core-01:Gi0/0/1"@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01_extra_node_0 ;
    noria:networkInterfaceDescription "Internal_extra_node_0 LAN interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_0> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_0> .

# Network Interfaces for Firewall01
noria:NI_Firewall01_Eth0_extra_node_0 a noria:NetworkInterface ;
    rdfs:label "fw-perimeter-01:eth0"@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01_extra_node_0 ;
    noria:networkInterfaceDescription "External interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_0> ;
