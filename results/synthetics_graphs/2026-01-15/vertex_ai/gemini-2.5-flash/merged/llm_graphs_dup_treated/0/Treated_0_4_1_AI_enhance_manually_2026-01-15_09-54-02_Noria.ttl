    noria:locatedAtLocus noria:Locus_RackA1_extra_node_0 ;
    noria:resourceManagementIPAddress "10.0.0.5" .

noria:Resource_VMHost01_extra_node_0 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "ESXi host running multiple virtual machines."@en ;
    noria:resourceManagedBy org:ITOperationsTeam_extra_node_0 ;
    noria:resourceHostName "vmhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_0 ;
    noria:resourceLogisticId "ASSET-VMH-001" ;
    noria:resourceType <kos/Resource/type/Hypervisor_extra_node_0> ;
