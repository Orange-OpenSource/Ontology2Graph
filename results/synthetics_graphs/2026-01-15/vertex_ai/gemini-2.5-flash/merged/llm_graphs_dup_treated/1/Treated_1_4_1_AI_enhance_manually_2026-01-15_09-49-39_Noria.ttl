# =============================================================================
# Network Interfaces
# =============================================================================

noria:DNS_Server_01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS Server 01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS_Server_01."@en ;
    noria:networkInterfaceOf noria:DNS_Server_01 ;
    noria:networkInterfaceDescription "Management and data interface" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> .

noria:Core_Router_DC01_Ge0_0_0 a noria:NetworkInterface ;
    rdfs:label "Core Router DC01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router DC01 to the internal network."@en ;
    noria:networkInterfaceOf noria:Core_Router_DC01 ;
    noria:networkInterfaceDescription "Internal_extra_node_1 LAN connection" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:Core_Router_DC01_Ge0_0_1 a noria:NetworkInterface ;
    rdfs:label "Core Router DC01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router DC01 to the external WAN."@en ;
    noria:networkInterfaceOf noria:Core_Router_DC01 ;
    noria:networkInterfaceDescription "External WAN connection" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:Access_Switch_BO01_Ge0_0_1 a noria:NetworkInterface ;
    rdfs:label "Access Switch BO01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Uplink interface for Access Switch BO01 to WAN."@en ;
    noria:networkInterfaceOf noria:Access_Switch_BO01 ;
    noria:networkInterfaceDescription "Uplink to WAN" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> .

noria:Firewall_DC01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Firewall DC01 Ethernet 0"@en ;
    rdfs:comment "Internal interface for Firewall DC01."@en ;
    noria:networkInterfaceOf noria:Firewall_DC01 ;
    noria:networkInterfaceDescription "Internal_extra_node_1 network segment" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> .

noria:Firewall_DC01_Eth1 a noria:NetworkInterface ;
    rdfs:label "Firewall DC01 Ethernet 1"@en ;
    rdfs:comment "External interface for Firewall DC01."@en ;
    noria:networkInterfaceOf noria:Firewall_DC01 ;
    noria:networkInterfaceDescription "External network segment (Internet)" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up_extra_node_1> .

# =============================================================================
# Network Links
# =============================================================================

noria:Link_DC01_Internal_LAN a noria:NetworkLink ;
    rdfs:label "DC01 Internal LAN Link"@en ;
    rdfs:comment "Internal network link within Data Center 01."@en ;
    noria:networkLinkId "LAN-DC01-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Core_Router_DC01 ;
    noria:networkLinkTerminationResourceDestination noria:Firewall_DC01 ;
    noria:networkLinkInstallationDate "2021-05-20T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy org:NetworkEngineeringTeam_extra_node_1 .

noria:Link_DC01_WAN_Uplink a noria:NetworkLink ;
    rdfs:label "DC01 WAN Uplink"@en ;
    rdfs:comment "Uplink from Data Center 01 to external WAN provider."@en ;
    noria:networkLinkId "WAN-DC01-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Core_Router_DC01 ;
    noria:networkLinkInstallationDate "2021-05-20T09:45:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 100Gbps" ;
    noria:resourceManagedBy org:NetworkEngineeringTeam_extra_node_1 .

noria:Link_BO01_WAN_Uplink a noria:NetworkLink ;
    rdfs:label "BO01 WAN Uplink"@en ;
    rdfs:comment "Uplink from Branch Office 01 to external WAN provider."@en ;
    noria:networkLinkId "WAN-BO01-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Access_Switch_BO01 ;
    noria:networkLinkInstallationDate "2022-07-10T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN 1Gbps" ;
    noria:resourceManagedBy org:NetworkEngineeringTeam_extra_node_1 .

# Connecting interfaces to links
noria:Core_Router_DC01_Ge0_0_0 noria:networkInterfaceConnects noria:Link_DC01_Internal_LAN .
noria:Firewall_DC01_Eth0 noria:networkInterfaceConnects noria:Link_DC01_Internal_LAN .
noria:Core_Router_DC01_Ge0_0_1 noria:networkInterfaceConnects noria:Link_DC01_WAN_Uplink .
noria:Access_Switch_BO01_Ge0_0_1 noria:networkInterfaceConnects noria:Link_BO01_WAN_Uplink .

# =============================================================================
# Applications
# =============================================================================

noria:CorporateInternetAccessApp a noria:Application ;
    rdfs:label "Corporate Internet Access"@en, "Accès Internet d'Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users and services."@en ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationType <kos/application/type/infrastructure_extra_node_1> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high_extra_node_1> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Gateway" .

noria:CorporateWebsiteApp a noria:Application ;
    rdfs:label "Corporate Website"@en, "Site Web d'Entreprise"@fr ;
    rdfs:comment "Hosts the public-facing corporate website."@en ;
    noria:applicationModelIdentifier "CWEB-APP" ;
    noria:applicationNumericalIdentifier 1002 ;
