# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_PSU_Replacement a noria:OperationPlan ;
    rdfs:label "Server PSU Replacement Procedure"@en, "Procédure Remplacement Alimentation Serveur"@fr ;
    rdfs:comment "Standard operating procedure for replacing a server power supply unit."@en ;
    noria:operationPlanPreCondition noria:PreCond_ServerOffline ;
    noria:operationPlanPostCondition noria:PostCond_ServerOnline .

noria:OperationPlan_Web_Optimization a noria:OperationPlan ;
    rdfs:label "Web Server Optimization Procedure"@en, "Procédure Optimisation Serveur Web"@fr ;
    rdfs:comment "Procedure for optimizing web server configuration for performance."@en ;
    noria:operationPlanPreCondition noria:PreCond_LowTrafficWindow ;
    noria:operationPlanPostCondition noria:PostCond_ImprovedWebPerformance .

noria:PreCond_ServerOffline a noria:ActionPreCondition ;
    rdfs:label "Server Offline Pre-Condition"@en ;
    rdfs:comment "Ensure the server is gracefully shut down and powered off before intervention."@en ;
    skos:example "Ping to server IP fails;
        power status is off."@en .

noria:PostCond_ServerOnline a noria:ActionPostCondition ;
    rdfs:label "Server Online Post-Condition"@en ;
    rdfs:comment "Verify server is powered on, operating system booted, and services are running."@en ;
    skos:example "Ping to server IP succeeds;
        DNS service responds to queries."@en .

noria:PreCond_LowTrafficWindow a noria:ActionPreCondition ;
    rdfs:label "Low Traffic Window Pre-Condition"@en ;
    rdfs:comment "Ensure the change is performed during a period of low website traffic to minimize user impact."@en ;
    skos:example "Website analytics show minimal active users."@en .

noria:PostCond_ImprovedWebPerformance a noria:ActionPostCondition ;
    rdfs:label "Improved Web Performance Post-Condition"@en ;
    rdfs:comment "Verify that website response times have improved after the optimization."@en ;
    skos:example "APM metrics show reduced average response time and CPU utilization."@en .

noria:AnomalyPattern_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a sustained period of abnormally high CPU utilization, potentially leading to performance degradation."@en ;
    skos:example "CPU usage > 90% for more than 15 minutes on a production server."@en .

noria:AnomalyPattern_NetworkLatencySpike a noria:AnomalyPattern ;
    rdfs:label "Network Latency Spike Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a sudden and significant increase in network latency between critical components."@en ;
    skos:example "Latency between Web_Server_01 and DNS_Server_01 exceeds 100ms for 5 minutes."@en .

# Linking Change Requests to Operation Plans
noria:CR_DNS_PSU_Replacement_20240320 noria:actionCorrelatedOperationPlan noria:OperationPlan_PSU_Replacement .
noria:CR_Web_Optimization_20240322 noria:actionCorrelatedOperationPlan noria:OperationPlan_Web_Optimization .

# =============================================================================
# SKOS Concept Schemes and Concepts
# =============================================================================

# Application Type Scheme
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "Defines types of applications within the IT landscape."@en .

<kos/application/type/infrastructure_extra_node_1> a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/service-platform> a skos:Concept ;
    skos:prefLabel "Service Platform Application"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/business-application_extra_node_1> a skos:Concept ;
    skos:prefLabel "Business Application"@en ;
    skos:inScheme <kos/application/type> .

# Application Business Importance Scheme
<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "Categorizes applications by their business impact."@en .

<kos/application/business-importance/high_extra_node_1> a skos:Concept ;
    skos:prefLabel "High Business Importance"@en ;
    skos:inScheme <kos/application/business-importance> .

