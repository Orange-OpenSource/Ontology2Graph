# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_CheckFiber a noria:OperationPlan ;
    rdfs:label "Fiber Optic Link Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving fiber optic link issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FiberDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FiberUp .

noria:ActionPreCondition_FiberDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'down' and administrative status is 'up'."@en ;
    skos:example "noria:NetworkInterface_Router01_Eth0 noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Down> ;
        noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> ." .

noria:ActionPostCondition_FiberUp a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Up Post-condition"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up'."@en ;
    skos:example "noria:NetworkInterface_Router01_Eth0 noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ." .

noria:AnomalyPattern_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential performance issue: CPU utilization consistently above 90% for an extended period."@en ;
    skos:example "EventRecord_AppServerHighCPU matches this pattern." .

