    rdfs:comment "Leading networking hardware manufacturer."@en .

noria:Org_DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company."@en .

noria:Org_PaloAltoNetworks a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "Cybersecurity company."@en .

# =============================================================================
# Locations (Site, Room, Locus)
# =============================================================================

noria:Site_DataCenterEast a bot:Site ;
    rdfs:label "East Data Center"@en ;
    rdfs:comment "Primary data center located in the eastern region."@en ;
    noria:siteId "DC-EAST-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA_extra_node_0 a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the East Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1_extra_node_0, noria:Locus_RackA2 .

noria:Locus_RackA1_extra_node_0 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical network equipment."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

