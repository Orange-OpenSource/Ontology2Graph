# Resources
# =============================================================================

noria:Resource:DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted on a physical machine."@en ;
    noria:resourceManagedBy foaf:Agent:AdminTeamDNS ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel:DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application:CorporateDNS ;
    noria:locatedAtLocus noria:Locus:RackA1 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

noria:Resource:WebSrv01 a noria:Resource ;
