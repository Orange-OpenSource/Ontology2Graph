# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord:DNSDownAlert a noria:EventRecord ;
    rdfs:label "DNS Server Down Alert"@en ;
    rdfs:comment "Automated alert indicating that the primary DNS server is unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource:DNS01 ;
    noria:logOriginatingManagementSystem noria:Application:MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%"@en ;
    noria:alarmProposedRepairAction noria:OperationPlan:DNSFailoverProcedure .

noria:EventRecord:WebHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Usage"@en ;
    rdfs:comment "Alert indicating sustained high CPU usage on the web server."@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource:WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application:MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logText "WARNING: Host web01.customer.example.com CPU usage is 95% for 15 minutes."@en ;
    noria:alarmProposedRepairAction noria:OperationPlan:WebRestartProcedure .

noria:EventRecord:RouterLinkDown a noria:EventRecord ;
    rdfs:label "Router Core Link Down"@en ;
    rdfs:comment "Log entry indicating a network interface on the core router went down."@en ;
    noria:loggingTime "2024-04-10T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource:RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application:LogManagement ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down"@en .

noria:EventRecord:FirewallConfigChange a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change"@en ;
    rdfs:comment "Log entry recording a configuration change on the perimeter firewall."@en ;
    noria:loggingTime "2024-04-09T15:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource:Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application:LogManagement ;
    noria:logOriginatingAgent foaf:Agent:SecurityTeam ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by security_admin (10.0.0.5)"@en .

noria:EventRecord:UserLoginFail a noria:EventRecord ;
    rdfs:label "Failed User Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt by a user on a system."@en ;
    noria:loggingTime "2024-04-10T08:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource:WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application:LogManagement ;
    noria:logOriginatingAgent noria:CorporateUserIdentifier:JohnDoeCUid ; # Assuming CUid can be an agent for logging purposes
    noria:logText "Failed login for user 'jdoe' from IP 203.0.113.42"@en .

