# =============================================================================
# Location
# =============================================================================

bot:Site:MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC-MIA-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room:ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated room within the Main Data Center for server racks."@en ;
    bot:hasSpace bot:Site:MainDataCenter .

noria:Locus:RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasSpace noria:Room:ServerRoomA .

noria:Locus:RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en ;
    bot:hasSpace noria:Room:ServerRoomA .

