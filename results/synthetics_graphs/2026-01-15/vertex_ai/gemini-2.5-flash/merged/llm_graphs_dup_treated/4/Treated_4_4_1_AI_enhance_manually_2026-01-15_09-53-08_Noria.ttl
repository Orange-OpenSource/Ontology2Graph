    rdfs:comment "Server hosting the customer-facing web portal."@en ;
    noria:resourceManagedBy foaf:Agent:AppDevTeam ;
    noria:resourceHostName "web01.customer.example.com" ;
    noria:resourceProductModel noria:ProductModel:DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application:CustomerPortal ;
    noria:locatedAtLocus noria:Locus:RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.100" .

noria:Resource:RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy foaf:Agent:NetworkOps ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel:JuniperMXSeries ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-11-20T08:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application:InternetAccessService ;
    noria:locatedAtLocus noria:Locus:RackA1 ;
    noria:resourceManagementIPAddress "172.16.0.1" .

noria:Resource:Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Firewall protecting the corporate network perimeter."@en ;
    noria:resourceManagedBy foaf:Agent:SecurityTeam ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel:CiscoCatalyst9k ; # Assuming Cisco also makes firewalls or this is a multi-function device
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
