    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink:LinkDNSWeb a noria:NetworkLink ;
    rdfs:label "Link between DNS01 and WebSrv01"@en ;
    rdfs:comment "Logical link representing network path between DNS and Web servers."@en ;
    noria:networkLinkId "LOG-LINK-DNS-WEB" ;
    noria:networkLinkTerminationResource noria:Resource:DNS01, noria:Resource:WebSrv01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"@en ;
    noria:resourceManagedBy foaf:Agent:NetworkOps .

noria:NetworkLink:LinkRouterFirewall a noria:NetworkLink ;
    rdfs:label "Link between Core Router and Firewall"@en ;
    rdfs:comment "Physical link connecting the core router to the perimeter firewall."@en ;
    noria:networkLinkId "PHY-LINK-RTR-FW" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource:RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource:Firewall01 ;
    noria:networkLinkInstallationDate "2021-11-20T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:resourceManagedBy foaf:Agent:NetworkOps .

noria:NetworkInterface:DNS01Eth0 noria:networkInterfaceConnects noria:NetworkLink:LinkDNSWeb .
noria:NetworkInterface:WebSrv01Eth0 noria:networkInterfaceConnects noria:NetworkLink:LinkDNSWeb .
noria:NetworkInterface:RouterCore01Ge000 noria:networkInterfaceConnects noria:NetworkLink:LinkRouterFirewall .
noria:NetworkInterface:Firewall01Int noria:networkInterfaceConnects noria:NetworkLink:LinkRouterFirewall .

