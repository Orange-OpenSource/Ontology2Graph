# =============================================================================
# Organizations and Agents
# =============================================================================

noria:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department responsible for all IT operations."@en ;
    org:hasUnit noria:OrgUnit_NetworkOps, noria:OrgUnit_AppDev, noria:OrgUnit_SecurityOps .

noria:OrgUnit_NetworkOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf noria:Org_ITDepartment ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email 'network-ops@example.com' for routine issues, call hotline for critical incidents."@en .

noria:OrgUnit_AppDev a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    org:unitOf noria:Org_ITDepartment ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

noria:OrgUnit_SecurityOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:unitOf noria:Org_ITDepartment ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

noria:Person_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    org:memberOf noria:OrgUnit_NetworkOps .

noria:Person_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf noria:OrgUnit_AppDev .

noria:Person_CharlieBrown a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "SOC Analyst."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    org:memberOf noria:OrgUnit_SecurityOps .

noria:Person_DavidClark a foaf:Person, foaf:Agent ;
    rdfs:label "David Clark"@en ;
    rdfs:comment "Field Technician."@en ;
    foaf:mbox <mailto:david.clark@example.com> ;
    org:memberOf noria:OrgUnit_NetworkOps .

noria:CorporateUserIdentifier_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "ASmith CUid"@en ;
    rdfs:comment "Corporate User ID for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount noria:Person_AliceSmith .

noria:CorporateUserIdentifier_BJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "BJohnson CUid"@en ;
    rdfs:comment "Corporate User ID for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount noria:Person_BobJohnson .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_CiscoASR1K a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "High-performance edge router series."@en ;
    noria:productManufacturedBy noria:Org_CiscoSystems .

noria:ProductModel_DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Versatile 2U rack server."@en ;
    noria:productManufacturedBy noria:Org_DellTechnologies .

noria:ProductModel_PaloAltoFirewall a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5200 Series"@en ;
    rdfs:comment "Next-generation firewall."@en ;
    noria:productManufacturedBy noria:Org_PaloAltoNetworks .

noria:Org_CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Leading networking hardware manufacturer."@en .

noria:Org_DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company."@en .

noria:Org_PaloAltoNetworks a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "Cybersecurity company."@en .

# =============================================================================
# Locations (Site, Room, Locus)
# =============================================================================

noria:Site_DataCenterEast a bot:Site ;
    rdfs:label "East Data Center"@en ;
    rdfs:comment "Primary data center located in the eastern region."@en ;
    noria:siteId "DC-EAST-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the East Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical network equipment."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

