    noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardProcedureA> ;
    noria:changeRequestInitiatorParty foaf:JaneSmith ;
    noria:changeRequestPilotParty foaf:JaneSmith ;
    noria:changeRequestActorParty org:ApplicationSupportTeam ;
    noria:changeRequestIsRegulated false ;
    dcterms:relation noria:TT_Web_Performance_20240321 .

# =============================================================================
# Event Records
# =============================================================================

noria:Event_DNS_Down_20240320 a noria:EventRecord ;
    rdfs:label "DNS Server Down Event"@en, "Événement Serveur DNS Hors Service"@fr ;
    rdfs:comment "Automated alert indicating DNS_Server_01 is unreachable."@en ;
    log:msg "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:loggingTime "2024-03-20T08:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:DNS_Server_01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemNagios ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    dcterms:relation noria:TT_DNS_Outage_20240320 .

noria:Event_DNS_Up_20240320 a noria:EventRecord ;
    rdfs:label "DNS Server Up Event"@en, "Événement Serveur DNS En Ligne"@fr ;
    rdfs:comment "Automated alert indicating DNS_Server_01 is reachable again."@en ;
    log:msg "OK: Host dns01.corp.example.com is UP" ;
    noria:loggingTime "2024-03-20T11:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:DNS_Server_01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemNagios ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmMitigatedBy noria:CR_DNS_PSU_Replacement_20240320 ;
    dcterms:relation noria:TT_DNS_Outage_20240320 .

noria:Event_Web_CPU_High_20240321 a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en, "Alerte CPU Élevé Serveur Web"@fr ;
    rdfs:comment "Alert indicating high CPU utilization on Web_Server_01."@en ;
    log:msg "WARNING: CPU utilization on web01.corp.example.com is 95%" ;
    noria:loggingTime "2024-03-21T13:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Web_Server_01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemAPM ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/thresholdExceeded> ;
    dcterms:relation noria:TT_Web_Performance_20240321 .

noria:Event_Firewall_Blocked_Attempt_20240323 a noria:EventRecord ;
    rdfs:label "Firewall Blocked Attempt Event"@en, "Événement Tentative Bloquée Pare-feu"@fr ;
    rdfs:comment "Security event: Firewall blocked an unauthorized access attempt."@en ;
    log:msg "FIREWALL: Blocked connection attempt from 1.2.3.4 to 10.0.0.20 on port 80" ;
    noria:loggingTime "2024-03-23T05:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Firewall_DC01 ;
    noria:logOriginatingManagementSystem noria:SIEMSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    dcterms:type <kos/Notification/EventType/securityAlert> ;
    noria:logOriginatingAgent noria:CUid_ExternalAttacker . # Example of external agent

noria:MonitoringSystemNagios a noria:Application ;
    rdfs:label "Nagios Monitoring System"@en ;
    rdfs:comment "Infrastructure monitoring application."@en ;
    noria:applicationType <kos/application/type/infrastructure> .

noria:MonitoringSystemAPM a noria:Application ;
    rdfs:label "APM Monitoring System"@en ;
    rdfs:comment "Application Performance Monitoring system."@en ;
    noria:applicationType <kos/application/type/service-platform> .

noria:SIEMSystem a noria:Application ;
    rdfs:label "SIEM System"@en ;
    rdfs:comment "Security Information and Event Management system."@en ;
    noria:applicationType <kos/application/type/service-platform> .

noria:CUid_ExternalAttacker a noria:CorporateUserIdentifier ; # Representing an external entity as a user account for logging purposes
    rdfs:label "External Attacker ID"@en ;
    rdfs:comment "Placeholder for an external entity identified in logs, not an internal employee."@en ;
    foaf:accountName "external_ip_1.2.3.4" .

# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_PSU_Replacement a noria:OperationPlan ;
    rdfs:label "Server PSU Replacement Procedure"@en, "Procédure Remplacement Alimentation Serveur"@fr ;
    rdfs:comment "Standard operating procedure for replacing a server power supply unit."@en ;
    noria:operationPlanPreCondition noria:PreCond_ServerOffline ;
    noria:operationPlanPostCondition noria:PostCond_ServerOnline .

noria:OperationPlan_Web_Optimization a noria:OperationPlan ;
    rdfs:label "Web Server Optimization Procedure"@en, "Procédure Optimisation Serveur Web"@fr ;
    rdfs:comment "Procedure for optimizing web server configuration for performance."@en ;
    noria:operationPlanPreCondition noria:PreCond_LowTrafficWindow ;
    noria:operationPlanPostCondition noria:PostCond_ImprovedWebPerformance .

noria:PreCond_ServerOffline a noria:ActionPreCondition ;
    rdfs:label "Server Offline Pre-Condition"@en ;
    rdfs:comment "Ensure the server is gracefully shut down and powered off before intervention."@en ;
    skos:example "Ping to server IP fails; power status is off."@en .

noria:PostCond_ServerOnline a noria:ActionPostCondition ;
    rdfs:label "Server Online Post-Condition"@en ;
    rdfs:comment "Verify server is powered on, operating system booted, and services are running."@en ;
    skos:example "Ping to server IP succeeds; DNS service responds to queries."@en .

noria:PreCond_LowTrafficWindow a noria:ActionPreCondition ;
    rdfs:label "Low Traffic Window Pre-Condition"@en ;
    rdfs:comment "Ensure the change is performed during a period of low website traffic to minimize user impact."@en ;
    skos:example "Website analytics show minimal active users."@en .

noria:PostCond_ImprovedWebPerformance a noria:ActionPostCondition ;
    rdfs:label "Improved Web Performance Post-Condition"@en ;
    rdfs:comment "Verify that website response times have improved after the optimization."@en ;
    skos:example "APM metrics show reduced average response time and CPU utilization."@en .

noria:AnomalyPattern_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a sustained period of abnormally high CPU utilization, potentially leading to performance degradation."@en ;
    skos:example "CPU usage > 90% for more than 15 minutes on a production server."@en .

noria:AnomalyPattern_NetworkLatencySpike a noria:AnomalyPattern ;
    rdfs:label "Network Latency Spike Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a sudden and significant increase in network latency between critical components."@en ;
    skos:example "Latency between Web_Server_01 and DNS_Server_01 exceeds 100ms for 5 minutes."@en .

# Linking Change Requests to Operation Plans
noria:CR_DNS_PSU_Replacement_20240320 noria:actionCorrelatedOperationPlan noria:OperationPlan_PSU_Replacement .
noria:CR_Web_Optimization_20240322 noria:actionCorrelatedOperationPlan noria:OperationPlan_Web_Optimization .

