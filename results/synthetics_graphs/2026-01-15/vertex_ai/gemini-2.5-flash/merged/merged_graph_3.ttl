noria:CR_DNS_PSU_Replacement_20240320 a noria:ChangeRequest ;
    rdfs:label "DNS Server PSU Replacement"@en, "Remplacement Alimentation Serveur DNS"@fr ;
    rdfs:comment "Emergency change to replace a faulty Power Supply Unit on DNS_Server_01."@en ;
    dcterms:identifier "CR-20240320-001" ;
    dcterms:created "2024-03-20T09:30:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-03-20T11:15:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-03-20T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-20T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-03-20T10:15:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-03-20T11:05:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Emergency> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/PreventativeMaintenance> ;
    noria:changeRequestImpact noria:DNS_Server_01, noria:CorporateInternetAccessApp ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/EmergencyProcedureB> ;
    noria:changeRequestInitiatorParty foaf:AliceJohnson ;
    noria:changeRequestPilotParty foaf:AliceJohnson ;
    noria:changeRequestActorParty org:ITOperationsTeam ;
    noria:changeRequestIsRegulated false ;
    dcterms:relation noria:TT_DNS_Outage_20240320 .

noria:CR_Web_Optimization_20240322 a noria:ChangeRequest ;
    rdfs:label "Web Server Configuration Optimization"@en, "Optimisation Configuration Serveur Web"@fr ;
    rdfs:comment "Planned change to optimize web server configuration to improve performance."@en ;
    dcterms:identifier "CR-20240322-002" ;
    dcterms:created "2024-03-22T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-03-22T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-03-25T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-25T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ; # Configuration change can be seen as a type of software change
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Web_Server_01, noria:Web_Server_02, noria:CorporateWebsiteApp ;
    noria:changeRequestOutageDuration "PT0H15M"^^xsd:duration ;
