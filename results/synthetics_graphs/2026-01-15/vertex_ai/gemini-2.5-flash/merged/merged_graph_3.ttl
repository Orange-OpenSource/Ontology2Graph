noria:TroubleTicket:TT001DNSOutage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Critical incident regarding the corporate DNS server being unreachable."@en ;
    dcterms:identifier "TT-20240410-001" ;
    dcterms:created "2024-04-10T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/ServiceInterruption> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord:DNSDownAlert ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/category/ServiceInterruption> ;
    noria:troubleTicketCause "Unidentified network connectivity issue affecting DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
    noria:troubleTicketDetectionDateTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-10T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent:AdminTeamDNS, foaf:Agent:NetworkOps ;
    noria:troubleTicketRelatedService noria:Application:CorporateDNS ;
    noria:troubleTicketRelatedResource noria:Resource:DNS01 ;
    noria:troubleTicketImpacts noria:Application:CorporateDNS, noria:Resource:DNS01 ;
    noria:documentHRef "https://itsm.example.com/tickets/TT-20240410-001" .

noria:TroubleTicket:TT002WebPerf a noria:TroubleTicket ;
