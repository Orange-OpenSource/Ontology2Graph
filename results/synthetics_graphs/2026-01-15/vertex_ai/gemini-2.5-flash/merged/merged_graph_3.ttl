noria:Resource_VirtualMachine01 a noria:Resource ;
    rdfs:label "Virtual Machine for WebApp"@en ;
    rdfs:comment "Virtual machine hosting the main web application."@en ;
    noria:resourceHostName "webapp-vm01.corp.example.com" ;
    noria:elementDistinguishedName "webapp-vm01.corp.example.com" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy noria:OrgUnit_AppDev ;
    noria:clusterController noria:Resource_AppServer01 ;
    noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:Resource_ISP_Router a noria:Resource ;
