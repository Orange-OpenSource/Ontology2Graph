noria:TroubleTicket:TT003RouterIssue a noria:TroubleTicket ;
    rdfs:label "Core Router Interface Down"@en ;
    rdfs:comment "Critical network incident: a core router interface is down, impacting multiple services."@en ;
    dcterms:identifier "TT-20240410-003" ;
    dcterms:created "2024-04-10T11:35:00Z"^^xsd:dateTime ;
