# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizational Units (Teams)
org:ITOperationsTeam a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en, "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via dedicated incident hotline for critical issues. Use ticketing system for non-urgent requests."@en .

org:NetworkEngineeringTeam a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en, "Équipe Ingénierie Réseau"@fr ;
    rdfs:comment "Specialized team for network design, implementation, and advanced troubleshooting."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for project requests. For urgent network issues, escalate via IT Operations."@en .

org:ApplicationSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "8:00-17:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit tickets through the application portal. Critical issues can be escalated via phone."@en .

org:SecurityOperationsCenter a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Monitors and analyzes security events, detects and responds to cyber threats."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate contact for any suspected security incident."@en .

org:CloudPlatformTeam a org:OrganizationalUnit ;
    rdfs:label "Cloud Platform Team"@en, "Équipe Plateforme Cloud"@fr ;
    rdfs:comment "Manages the organization's cloud infrastructure and services."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use cloud management portal for service requests. For outages, contact IT Operations."@en .

# Individual Agents
foaf:JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead Network Engineer."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact for complex network architecture queries."@en ;
    foaf:mbox <mailto:john.doe@example.com> .

foaf:JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Senior Application Support Specialist."@en ;
    noria:agentWorkingHours "8:00-17:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Primary contact for CRM application issues."@en ;
    foaf:mbox <mailto:jane.smith@example.com> .

foaf:AliceJohnson a foaf:Agent ;
    rdfs:label "Alice Johnson"@en, "Alice Dubois"@fr ;
    rdfs:comment "IT Operations Manager."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Managerial escalation point for all IT incidents."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:JaneSmith .

# =============================================================================
# Locations (Sites, Rooms, Loci)
# =============================================================================

bot:MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    rdfs:comment "Primary data center facility for the organization."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" ;
    wgs84_pos:lat "34.0522"^^xsd:float ;
    wgs84_pos:long "-118.2437"^^xsd:float .

bot:BranchOfficeSite a bot:Site ;
    rdfs:label "Branch Office Site"@en, "Site de Bureau Annexe"@fr ;
    rdfs:comment "Smaller office location with local network infrastructure."@en ;
    noria:siteId "BO01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Business Road" ;
    noria:sitePrincipalAddressCityName "Suburbia" ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "US" ;
    wgs84_pos:lat "34.0000"^^xsd:float ;
    wgs84_pos:long "-118.0000"^^xsd:float .

noria:ServerRoomDC01 a noria:Room ;
    rdfs:label "Server Room DC01"@en, "Salle Serveurs DC01"@fr ;
    rdfs:comment "Main server room within the primary data center."@en ;
    bot:hasSpace bot:MainDataCenter . # bot:hasSpace is inverse of bot:containsZone, but bot:containsZone is for Zone -> Space. Room is a Space. Site contains Space.
    # The schema says bot:containsZone is for Locus of a Room. So Room is contained by Site.
    # bot:containsZone is for Zone -> Space. bot:Site is a Space. bot:Room is a Space.
    # The schema says "The relationship to the Locus of a Room is available with the bot:containsZone property."
    # This implies bot:Room bot:containsZone noria:Locus.
    # And bot:Site bot:containsZone noria:Room.
    # Let's use bot:containsZone for Site -> Room and Room -> Locus.
bot:MainDataCenter bot:containsZone noria:ServerRoomDC01 .

noria:NetworkClosetBO01 a noria:Room ;
    rdfs:label "Network Closet BO01"@en, "Local Réseau BO01"@fr ;
    rdfs:comment "Network equipment closet in the branch office."@en ;
    bot:containsZone bot:BranchOfficeSite . # This is inverse of what I want. bot:Site contains noria:Room.
    # Correct: bot:BranchOfficeSite bot:containsZone noria:NetworkClosetBO01 .

noria:RackA1Locus a noria:Locus ;
    rdfs:label "Rack A1 Locus"@en, "Emplacement Rack A1"@fr ;
    rdfs:comment "Specific location for Rack A1 in Server Room DC01."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:containsZone noria:ServerRoomDC01 . # This is inverse. noria:Room contains noria:Locus.
    # Correct: noria:ServerRoomDC01 bot:containsZone noria:RackA1Locus .

noria:RackB2Locus a noria:Locus ;
    rdfs:label "Rack B2 Locus"@en, "Emplacement Rack B2"@fr ;
    rdfs:comment "Specific location for Rack B2 in Server Room DC01."@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" ;
    bot:containsZone noria:ServerRoomDC01 . # Correct: noria:ServerRoomDC01 bot:containsZone noria:RackB2Locus .

noria:RackC3Locus a noria:Locus ;
    rdfs:label "Rack C3 Locus"@en, "Emplacement Rack C3"@fr ;
    rdfs:comment "Specific location for Rack C3 in Server Room DC01."@en ;
    noria:locusLine "C" ;
    noria:locusRow "3" ;
    bot:containsZone noria:ServerRoomDC01 . # Correct: noria:ServerRoomDC01 bot:containsZone noria:RackC3Locus .

noria:RackBO01Locus a noria:Locus ;
    rdfs:label "Rack BO01 Locus"@en, "Emplacement Rack BO01"@fr ;
    rdfs:comment "Specific location for network equipment in Network Closet BO01."@en ;
    noria:locusLine "Main" ;
    noria:locusRow "1" ;
    bot:containsZone noria:NetworkClosetBO01 . # Correct: noria:NetworkClosetBO01 bot:containsZone noria:RackBO01Locus .

# Correcting the bot:containsZone usage based on the schema's example:
# "The relationship to the Locus of a Room is available with the bot:containsZone property."
# This means Room bot:containsZone Locus.
# And Site bot:containsZone Room.

bot:MainDataCenter bot:containsZone noria:ServerRoomDC01 .
bot:BranchOfficeSite bot:containsZone noria:NetworkClosetBO01 .
noria:ServerRoomDC01 bot:containsZone noria:RackA1Locus .
noria:ServerRoomDC01 bot:containsZone noria:RackB2Locus .
noria:ServerRoomDC01 bot:containsZone noria:RackC3Locus .
noria:NetworkClosetBO01 bot:containsZone noria:RackBO01Locus .


