    dcterms:created "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-22T18:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-22T20:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <https://w3id.org/noria/kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource_BackupStorage, noria:Service_DataBackup ;
    noria:changeRequestOutageDuration "PT0H15M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty noria:Person_AliceSmith ;
    noria:changeRequestPilotParty noria:Person_AliceSmith ;
    noria:changeRequestActorParty noria:OrgUnit_NetworkOps ;
    noria:changeRequestIsRegulated false ;
    dcterms:relation noria:TroubleTicket_BackupFailure .

# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_CheckFiber a noria:OperationPlan ;
    rdfs:label "Fiber Optic Link Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving fiber optic link issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FiberDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FiberUp .

noria:ActionPreCondition_FiberDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'down' and administrative status is 'up'."@en ;
    skos:example "noria:NetworkInterface_Router01_Eth0 noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Down> ; noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> ." .

noria:ActionPostCondition_FiberUp a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Up Post-condition"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up'."@en ;
    skos:example "noria:NetworkInterface_Router01_Eth0 noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ." .

noria:AnomalyPattern_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential performance issue: CPU utilization consistently above 90% for an extended period."@en ;
    skos:example "EventRecord_AppServerHighCPU matches this pattern." .

# =============================================================================
# Document Attachments
# =============================================================================

noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram v3.0"@en ;
    rdfs:comment "PDF document showing the current network topology."@en ;
    dcterms:identifier "DOC-NET-DIAG-V3" ;
    dcterms:isPartOf noria:TroubleTicket_RouterOutage, noria:ChangeRequest_RouterFirmwareUpgrade .

noria:DocumentAttachment_ServerLogs a noria:DocumentAttachment ;
    rdfs:label "AppServer01 Logs 2024-04-20"@en ;
    rdfs:comment "Compressed log files from AppServer01 during the performance degradation incident."@en ;
    dcterms:identifier "DOC-AS01-LOGS-20240420" ;
    dcterms:isPartOf noria:TroubleTicket_WebAppPerformance .

