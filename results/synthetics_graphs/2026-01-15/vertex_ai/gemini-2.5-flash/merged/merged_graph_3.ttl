    rdfs:comment "Warning alert for high CPU utilization on web01."@en ;
    noria:loggingTime "2023-10-26T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "DNS Service Restarted Log"@en ;
    rdfs:comment "Log entry confirming DNS service restart on dns01."@en ;
    noria:loggingTime "2023-10-26T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingAgent foaf:Agent1 ;
    noria:logText "DNS service 'named' started successfully on dns01.corp.example.com" .

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "Web Server Software Update Completed"@en ;
    rdfs:comment "Log entry indicating successful completion of a software update on web01."@en ;
    noria:loggingTime "2023-10-25T03:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingAgent foaf:Agent5 ;
    noria:logText "Apache HTTP Server updated to version 2.4.58." .

