noria:TT_DNS_Note_02 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Resolution Note"@en ;
    rdfs:comment "Replaced faulty power supply unit on DNS_Server_01. Server rebooted, DNS service restored."@en ;
    dcterms:created "2024-03-20T11:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:AliceJohnson ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TT_DNS_Outage_20240320 ;
    noria:troubleTicketNoteCorrelatedExecution noria:CR_DNS_PSU_Replacement_20240320 .

noria:TT_Web_Note_01 a noria:TroubleTicketNote ;
    rdfs:label "Web Performance Initial Customer Report"@en ;
    rdfs:comment "Customer reported slow website loading times, especially during peak hours."@en ;
    dcterms:created "2024-03-21T14:05:00Z"^^xsd:dateTime ;
    dcterms:creator <kos/TroubleTicket/origin/Customer> ; # Using the KOS concept as a placeholder for the agent
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
