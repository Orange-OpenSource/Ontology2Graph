# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan:DNSFailoverProcedure a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over to a secondary DNS server in case of primary failure."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition:DNSPrimaryDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition:DNSServiceRestored .

noria:OperationPlan:WebRestartProcedure a noria:OperationPlan ;
    rdfs:label "Web Server Restart Procedure"@en ;
    rdfs:comment "Procedure to restart the web server application in case of performance issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition:WebTrafficHigh ;
    noria:operationPlanPostCondition noria:ActionPostCondition:WebPerformanceNormal .

noria:OperationPlan:FirewallUpdateProcedure a noria:OperationPlan ;
    rdfs:label "Firewall OS Update Procedure"@en ;
    rdfs:comment "Detailed steps for performing an OS update on the perimeter firewall."@en ;
    noria:operationPlanPostCondition noria:ActionPostCondition:FirewallUpdated .

noria:ActionPreCondition:DNSPrimaryDown a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Down Condition"@en ;
    rdfs:comment "Condition where the primary DNS server is unresponsive or unreachable."@en .

noria:ActionPreCondition:WebTrafficHigh a noria:ActionPreCondition ;
    rdfs:label "High Web Traffic Condition"@en ;
    rdfs:comment "Condition where web server traffic or CPU usage exceeds predefined thresholds."@en .

noria:ActionPostCondition:DNSServiceRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Condition"@en ;
    rdfs:comment "Condition where DNS resolution is fully functional after an incident."@en .

noria:ActionPostCondition:WebPerformanceNormal a noria:ActionPostCondition ;
    rdfs:label "Web Performance Normal Condition"@en ;
    rdfs:comment "Condition where web server response times and resource utilization return to normal levels."@en .

noria:ActionPostCondition:FirewallUpdated a noria:ActionPostCondition ;
    rdfs:label "Firewall OS Updated Successfully"@en ;
    rdfs:comment "Condition where the firewall OS update is completed and verified."@en .

noria:AnomalyPattern:DNSResolutionFailure a noria:AnomalyPattern ;
    rdfs:label "DNS Resolution Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a widespread failure in DNS resolution, potentially due to primary DNS server outage."@en ;
    folio:hasCause noria:EventRecord:DNSDownAlert .

