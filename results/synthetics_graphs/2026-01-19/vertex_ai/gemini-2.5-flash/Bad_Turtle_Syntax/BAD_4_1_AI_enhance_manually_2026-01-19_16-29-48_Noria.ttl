:TT_CWP_Performance a noria:TroubleTicket ;
    rdfs:label "Corporate Web Portal Performance Degradation"@en ;
    rdfs:comment "Users reporting slow response times and intermittent errors on the Corporate Web Portal."@en ;
    dcterms:created "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/TotalBreakdown> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :Event_HighCPU_Web1 ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/category/TotalBreakdown> ;
    noria:troubleTicketCause "High CPU on web server due to unexpected traffic surge."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty :Team_AppSupport, :Team_ServerOps ;
    noria:troubleTicketRelatedService :App_CorporateWebPortal ;
    noria:troubleTicketRelatedResource :Server_Web1 ;
    noria:troubleTicketImpacts :AppModule_CWP_Frontend, :Server_Web1 .

:TT_Network_Outage a noria:TroubleTicket ;
    rdfs:label "Data Center Network Outage"@en ;
    rdfs:comment "Core router interface down, impacting all services in Paris DC."@en ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/TotalBreakdown> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :Event_NetworkInterfaceDown ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Zabbix NMS"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/category/TotalBreakdown> ;
    noria:troubleTicketCause "Physical link failure on core router interface."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty :Team_NetworkOps ;
    noria:troubleTicketRelatedService :Service_PublicWebAccess ;
    noria:troubleTicketRelatedResource :Router_Core1, :Link_Web1_Router1, :Link_DB1_Router1 ;
    noria:troubleTicketImpacts :App_CorporateWebPortal, :Server_Web1, :Server_DB1 .

:TTNote_CWP_Diagnosis a noria:TroubleTicketNote ;
    rdfs:label "CWP Diagnosis Note 1"@en ;
    rdfs:comment "Initial diagnosis: high CPU on web server, investigating root cause."@en ;
    dcterms:created "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    dcterms:creator :Person_Alice ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf :TT_CWP_Performance .

:TTNote_CWP_Resolution a noria:TroubleTicketNote ;
    rdfs:label "CWP Resolution Note"@en ;
