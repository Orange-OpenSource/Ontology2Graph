<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> ; rdfs:label "Software Upgrade Cause"@en .
<kos/ChangeRequest/status/Scheduled> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> ; rdfs:label "Scheduled Status"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> ; rdfs:label "Implemented Status"@en .
<kos/ChangeRequest/specification/RoutineMaintenance> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> ; rdfs:label "Routine Maintenance Specification"@en .

<kos/Resource/type/Server> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> ; rdfs:label "Server Resource Type"@en .
<kos/Resource/type/Router> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> ; rdfs:label "Router Resource Type"@en .
<kos/Resource/type/Switch> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> ; rdfs:label "Switch Resource Type"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> ; rdfs:label "Virtual Machine Resource Type"@en .
<kos/Resource/LifecycleState/InUse> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ; rdfs:label "In Use Lifecycle State"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ; rdfs:label "Up Operational State"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ; rdfs:label "Down Operational State"@en .
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ; rdfs:label "Enabled Administrative State"@en .
<kos/Resource/AdministrativeState/Disabled> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ; rdfs:label "Disabled Administrative State"@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ; rdfs:label "Critical Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ; rdfs:label "Major Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ; rdfs:label "Warning Perceived Severity"@en .

<kos/org/agent-contact-method/Email> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ; rdfs:label "Email Contact Method"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ; rdfs:label "Phone Contact Method"@en .

<kos/service/type/CustomerFacingService> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/service/type> ; rdfs:label "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/service/type> ; rdfs:label "Resource Facing Service"@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

:Org_IT_Operations a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The main IT Operations department responsible for all IT infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical issues, call the hotline. For non-critical, use the ticketing system."@en .

:Team_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf :Org_IT_Operations ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource :Router_Core1, :Switch_Dist1, :Link_WAN_DC1_DC2 ;
    noria:agentInstructions "Email for routine requests, phone for emergencies."@en .

:Team_ServerOps a org:OrganizationalUnit ;
    rdfs:label "Server Operations Team"@en ;
    rdfs:comment "Team responsible for managing server infrastructure."@en ;
    org:unitOf :Org_IT_Operations ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource :Server_Web1, :Server_DB1, :VM_App1 ;
    noria:agentInstructions "Use internal ticketing system for all requests."@en .

:Team_AppSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    org:unitOf :Org_IT_Operations ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via dedicated application support line."@en .

:Person_Alice a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead engineer for Network Operations."@en ;
    org:memberOf :Team_NetworkOps ;
    foaf:mbox "mailto:alice.smith@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

:Person_Bob a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Database administrator."@en ;
    org:memberOf :Team_ServerOps ;
    foaf:mbox "mailto:bob.johnson@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

:CUid_Alice_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate login for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount :Person_Alice .

# =============================================================================
# Product Models
# =============================================================================

:ProductModel_Dell_R740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy :Org_Dell .

:ProductModel_Cisco_ASR1K a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Enterprise-grade aggregation services router."@en ;
    noria:productManufacturedBy :Org_Cisco .

:ProductModel_VMware_ESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for virtual machines."@en ;
    noria:productManufacturedBy :Org_VMware .

:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

# =============================================================================
# Locations
# =============================================================================

:Site_DataCenter_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center location."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

:Room_ServerRoom_A a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace :Site_DataCenter_Paris .

:Locus_Rack_A1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for Server_Web1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "23" ;
    bot:hasSpace :Room_ServerRoom_A .

:Locus_Rack_A1_U24 a noria:Locus ;
    rdfs:label "Rack A1, Unit 24"@en ;
    rdfs:comment "Specific location for Server_DB1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "24" ;
    bot:hasSpace :Room_ServerRoom_A .

:Locus_Rack_B2_U10 a noria:Locus ;
    rdfs:label "Rack B2, Unit 10"@en ;
    rdfs:comment "Specific location for Router_Core1."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "10" ;
    bot:hasSpace :Room_ServerRoom_A .

# =============================================================================
# Resources
# =============================================================================

:Server_Web1 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server for corporate applications."@en ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Team_ServerOps ;
    noria:locatedAtLocus :Locus_Rack_A1_U23 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

:Server_DB1 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Primary database server for corporate applications."@en ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Team_ServerOps ;
    noria:locatedAtLocus :Locus_Rack_A1_U24 ;
    noria:resourceManagementIPAddress "10.0.0.20" .

:Router_Core1 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the data center network."@en ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceHostName "core-rtr01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_Cisco_ASR1K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Team_NetworkOps ;
    noria:locatedAtLocus :Locus_Rack_B2_U10 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

:VM_App1 a noria:Resource ;
    rdfs:label "Application Virtual Machine 01"@en ;
    rdfs:comment "Virtual machine hosting a component of the Corporate Web Portal."@en ;
    noria:resourceHostName "vm-app01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_VMware_ESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-03-10T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Team_ServerOps ;
    noria:clusterController :Server_Web1 ; # Assuming Web Server 01 is also a hypervisor host
    noria:resourceManagementIPAddress "10.0.0.30" .

# =============================================================================
# Network Interfaces and Links
# =============================================================================

:NI_Web1_Eth0 a noria:NetworkInterface ;
    rdfs:label "Web Server 01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for Web Server 01."@en ;
    noria:networkInterfaceOf :Server_Web1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

:NI_DB1_Eth0 a noria:NetworkInterface ;
    rdfs:label "DB Server 01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DB Server 01."@en ;
    noria:networkInterfaceOf :Server_DB1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

:NI_Router1_Gig0_0_0 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 Gig0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the server network."@en ;
    noria:networkInterfaceOf :Router_Core1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

:Link_Web1_Router1 a noria:NetworkLink ;
    rdfs:label "Link Web01 to Core Router 01"@en ;
    rdfs:comment "Ethernet link between Web Server 01 and Core Router 01."@en ;
    noria:networkLinkId "LINK-WEB1-RTR1-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Server_Web1 ;
    noria:networkLinkTerminationResourceDestination :Router_Core1 ;
    noria:resourceManagedBy :Team_NetworkOps .

:Link_DB1_Router1 a noria:NetworkLink ;
    rdfs:label "Link DB01 to Core Router 01"@en ;
