:CR_DB_Upgrade a noria:ChangeRequest ;
    rdfs:label "Database Software Upgrade"@en ;
    rdfs:comment "Planned upgrade of the database software on db01.corp.example.com to version 1.1."@en ;
    dcterms:created "2024-04-01T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-15T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-15T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-15T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-15T02:15:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-15T03:45:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact :Server_DB1, :AppModule_CWP_Backend ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ; # 1 hour planned outage
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RoutineMaintenance> ;
    noria:changeRequestInitiatorParty :Person_Bob ;
    noria:changeRequestPilotParty :Person_Bob ;
    noria:changeRequestActorParty :Person_Bob ;
    noria:changeRequestIsRegulated false ;
    noria:documentStatusHistory :Event_DB_Upgrade_Log .

# =============================================================================
# Procedural Elements
# =============================================================================

:OP_DB_UpgradeProcedure a noria:OperationPlan ;
    rdfs:label "Database Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading database software."@en ;
    noria:operationPlanPreCondition :PreCond_DB_Backup, :PreCond_App_Downtime ;
    noria:operationPlanPostCondition :PostCond_DB_VersionCheck, :PostCond_App_Functionality .

:PreCond_DB_Backup a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completed"@en ;
    rdfs:comment "Ensure a full backup of the database is completed before starting the upgrade."@en .

:PreCond_App_Downtime a noria:ActionPreCondition ;
    rdfs:label "Application Downtime Scheduled"@en ;
    rdfs:comment "Verify that application downtime is scheduled and communicated to users."@en .

:PostCond_DB_VersionCheck a noria:ActionPostCondition ;
    rdfs:label "Database Version Verified"@en ;
    rdfs:comment "Confirm the new database version is correctly reported after upgrade."@en .

:PostCond_App_Functionality a noria:ActionPostCondition ;
    rdfs:label "Application Functionality Restored"@en ;
    rdfs:comment "Verify that the application functions correctly after the database upgrade."@en .

:AnomalyPattern_HighCPU_DB a noria:AnomalyPattern ;
    rdfs:label "High CPU on Database Server Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential issue: sustained high CPU on DB server, correlated with slow query logs."@en ;
    skos:example "If (CPU > 90% for 10min) AND (DB_Slow_Queries_Count > 100 in 10min) THEN Anomaly."@en .

:CR_DB_Upgrade pep:usedProcedure :OP_DB_UpgradeProcedure .
:TT_CWP_Performance noria:troubleTicketCharacteristic :AnomalyPattern_HighCPU_DB . # Linking an anomaly pattern to a trouble ticket as a characteristic.

