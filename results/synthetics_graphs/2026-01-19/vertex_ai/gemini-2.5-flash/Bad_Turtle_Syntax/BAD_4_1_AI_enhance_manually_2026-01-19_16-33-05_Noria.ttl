# =============================================================================
# Procedural Elements (Operation Plans, Pre/Post Conditions, Anomaly Patterns)
# =============================================================================

:OP_RouterInterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving router interface issues."@en ;
    noria:operationPlanPreCondition :APC_RouterInterfaceDown ;
    noria:operationPlanPostCondition :APOC_RouterInterfaceUp .

:APC_RouterInterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Router Interface is Down"@en ;
    rdfs:comment "Condition: A router's network interface reports an operational status of 'down'."@en .

:APOC_RouterInterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Router Interface is Up"@en ;
    rdfs:comment "Expected outcome: The router's network interface reports an operational status of 'up' and traffic flows."@en .

:AP_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization on a server, potentially leading to performance degradation."@en ;
    folio:hasCause "Excessive process load or resource contention."@en .

:OP_AppServerCPUOptimization a noria:OperationPlan ;
    rdfs:label "Application Server CPU Optimization"@en ;
    rdfs:comment "Procedure to identify and mitigate high CPU usage on application servers."@en ;
    noria:operationPlanPreCondition :APC_HighCPULoad ;
    noria:operationPlanPostCondition :APOC_NormalCPULoad .

:APC_HighCPULoad a noria:ActionPreCondition ;
    rdfs:label "High CPU Load Detected"@en ;
    rdfs:comment "Condition: CPU utilization exceeds 90% for more than 15 minutes."@en .

:APOC_NormalCPULoad a noria:ActionPostCondition ;
    rdfs:label "Normal CPU Load Restored"@en ;
    rdfs:comment "Expected outcome: CPU utilization returns below 70% and remains stable."@en .

:OP_DBDiskCleanup a noria:OperationPlan ;
    rdfs:label "Database Disk Cleanup Procedure"@en ;
    rdfs:comment "Procedure for freeing up disk space on database servers."@en ;
    noria:operationPlanPreCondition :APC_DBDiskFull ;
    noria:operationPlanPostCondition :APOC_DBDiskSpaceFree .

:APC_DBDiskFull a noria:ActionPreCondition ;
    rdfs:label "Database Disk Full"@en ;
    rdfs:comment "Condition: Database server disk usage exceeds 95%."@en .

:APOC_DBDiskSpaceFree a noria:ActionPostCondition ;
    rdfs:label "Database Disk Space Freed"@en ;
    rdfs:comment "Expected outcome: Database server disk usage is below 80%."@en .

:AP_DBPerformanceIssue a noria:AnomalyPattern ;
    rdfs:label "Database Performance Issue Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating slow database queries or high I/O wait times."@en ;
    folio:hasCause "Inefficient queries, high load, or disk I/O bottlenecks."@en .

# =============================================================================
# Additional Connections for Density
# =============================================================================

# Link EventRecords to AnomalyPatterns
:Event_AppServerHighCPU folio:hasAnomalyPattern :AP_HighCPULoad .
:Event_DBDiskFull folio:hasAnomalyPattern :AP_DBPerformanceIssue .

# Link actions to procedures
:Event_CableReplacementAction pep:usedProcedure :OP_RouterInterfaceTroubleshoot .
:Event_DBDiskCleanupAction pep:usedProcedure :OP_DBDiskCleanup .

# Link TroubleTicketNotes to their correlated executions
:TTNote_DNSOutage_Resolution noria:troubleTicketNoteCorrelatedExecution :Event_CableReplacementAction .
:TTNote_DBDiskFull_Resolution noria:troubleTicketNoteCorrelatedExecution :Event_DBDiskCleanupAction .

# Link EventRecords to TroubleTickets/ChangeRequests as part of their history
:TT_DNSOutage_20240420 noria:documentStatusHistory :Event_RouterInterfaceDown . # Router interface down led to DNS outage.
:TT_WebPortalDegradation_20240420 noria:documentStatusHistory :Event_LoadBalancerHealthCheckFail . # LB health check failure related to web portal degradation.

# Link resources to applications they serve
:Resource_DNS01 noria:resourceForApplication :App_CorporateDNS .
:Resource_RouterCore01 noria:resourceForApplication :App_CorporateDNS, :App_WebPortal, :App_CorporateDB .
:Resource_AppServer01 noria:resourceForApplication :App_WebPortal .
:Resource_Firewall01 noria:resourceForApplication :App_CorporateDNS, :App_WebPortal, :App_CorporateDB .
:Resource_VMHost01 noria:resourceForApplication :App_WebPortal .
:Resource_VirtualMachine01 noria:resourceForApplication :App_WebPortal .
:Resource_DBServer01 noria:resourceForApplication :App_CorporateDB .
:Resource_LoadBalancer01 noria:resourceForApplication :App_WebPortal .

# Link agents to resources they manage (inverse of resourceManagedBy)
:Team_NetworkOps noria:agentManagesResource :Resource_DNS01, :Resource_RouterCore01, :Resource_VMHost01, :Resource_LoadBalancer01, :NL_ISP_Core01, :NL_Core01_Firewall01, :NL_Firewall01_AppServer01, :NL_VMHost01_WebVM01, :NL_AppServer01_DBServer01, :NL_LoadBalancer01_WebVM01 .
:Team_AppDev noria:agentManagesResource :Resource_AppServer01, :Resource_VirtualMachine01 .
:Team_SecurityOps noria:agentManagesResource :Resource_Firewall01 .
:Team_DBA noria:agentManagesResource :Resource_DBServer01 .

