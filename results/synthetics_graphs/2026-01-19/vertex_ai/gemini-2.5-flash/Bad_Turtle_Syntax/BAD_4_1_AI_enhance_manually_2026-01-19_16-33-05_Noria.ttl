:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy :Org_Dell .

:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series."@en ;
    noria:productManufacturedBy :Org_Cisco .

:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "Modular router for service providers."@en ;
    noria:productManufacturedBy :Org_Juniper .

:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi"@en ;
    rdfs:comment "Hypervisor for virtual machines."@en ;
    noria:productManufacturedBy :Org_VMware .

:Org_Dell a org:Organization ; rdfs:label "Dell Technologies"@en .
:Org_Cisco a org:Organization ; rdfs:label "Cisco Systems"@en .
:Org_Juniper a org:Organization ; rdfs:label "Juniper Networks"@en .
:Org_VMware a org:Organization ; rdfs:label "VMware Inc."@en .

# =============================================================================
# Locations (Site, Room, Locus)
# =============================================================================

:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    noria:siteId "PAR-DC-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace :Site_ParisDC .

:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1, Server Room A"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2, Server Room A"@en ;
    rdfs:comment "Specific rack location for network equipment."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en .

:Locus_RackB1 a noria:Locus ;
    rdfs:label "Rack B1, Server Room A"@en ;
    rdfs:comment "Specific rack location for application and database servers."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "1"@en .

:Room_ServerRoomA bot:containsZone :Locus_RackA1, :Locus_RackA2, :Locus_RackB1 .

