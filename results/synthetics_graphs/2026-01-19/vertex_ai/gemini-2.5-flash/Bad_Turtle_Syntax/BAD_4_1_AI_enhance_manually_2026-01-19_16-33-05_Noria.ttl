# Base URI for instances
@base <https://w3id.org/noria/instances/> .

# =============================================================================
# KOS Concepts (Knowledge Organization System)
# =============================================================================

# Application Types
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure"@en .
<kos/application/type/business-critical> a skos:Concept ; skos:prefLabel "Business Critical"@en .
<kos/application/type/service-platform> a skos:Concept ; skos:prefLabel "Service Platform"@en .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High"@en .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium"@en .
<kos/application/business-importance/low> a skos:Concept ; skos:prefLabel "Low"@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:prefLabel "Maintenance"@en .

# Application Module SLA Level
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; skos:prefLabel "Gold SLA"@en .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; skos:prefLabel "Silver SLA"@en .

# Service Types
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en .

# TroubleTicket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en .

# TroubleTicket Type
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:prefLabel "Failure"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:prefLabel "Assistance"@en .

# TroubleTicket Criticity
<kos/TroubleTicket/category/InterruptedService> a skos:Concept ; skos:prefLabel "Interrupted Service"@en .
<kos/TroubleTicket/category/DegradedService> a skos:Concept ; skos:prefLabel "Degraded Service"@en .

# TroubleTicket Priority
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en .

# TroubleTicket Origin
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision System"@en .

# TroubleTicket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; skos:prefLabel "Immediate Intervention"@en .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; skos:prefLabel "Deferred Intervention"@en .

# TroubleTicket Trouble Category
<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ; skos:prefLabel "Network Outage"@en .
<kos/TroubleTicket/trouble-category/ServerFailure> a skos:Concept ; skos:prefLabel "Server Failure"@en .

# TroubleTicket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ; skos:prefLabel "Network Team"@en .
<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ; skos:prefLabel "Application Team"@en .
<kos/TroubleTicket/problemResponsibility/DatabaseTeam> a skos:Concept ; skos:prefLabel "Database Team"@en .

# TroubleTicket Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:prefLabel "Customer Comment"@en .

# TroubleTicket Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis"@en .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; skos:prefLabel "Resolution"@en .

# ChangeRequest Category
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; skos:prefLabel "Internal Intervention"@en .
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; skos:prefLabel "Software Upgrade"@en .
<kos/ChangeRequest/category/NewFeatureDeployment> a skos:Concept ; skos:prefLabel "New Feature Deployment"@en .

# ChangeRequest Type
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:prefLabel "Emergency Change"@en .

# ChangeRequest Cause
<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ; skos:prefLabel "Preventative Maintenance"@en .
<kos/ChangeRequest/cause/ConfigurationChange> a skos:Concept ; skos:prefLabel "Configuration Change"@en .
<kos/ChangeRequest/cause/SecurityPatch> a skos:Concept ; skos:prefLabel "Security Patch"@en .

# ChangeRequest Status
<kos/ChangeRequest/status/Planned> a skos:Concept ; skos:prefLabel "Planned"@en .
<kos/ChangeRequest/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en .
<kos/ChangeRequest/status/Completed> a skos:Concept ; skos:prefLabel "Completed"@en .

# ChangeRequest Specification
<kos/ChangeRequest/specification/NetworkConfigUpdate> a skos:Concept ; skos:prefLabel "Network Configuration Update"@en .
<kos/ChangeRequest/specification/ApplicationDeployment> a skos:Concept ; skos:prefLabel "Application Deployment"@en .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Up"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down"@en .
<kos/Resource/OperationalState/Degraded> a skos:Concept ; skos:prefLabel "Degraded"@en .

# Resource Administrative State
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ; skos:prefLabel "Enabled"@en .
<kos/Resource/AdministrativeState/Disabled> a skos:Concept ; skos:prefLabel "Disabled"@en .

# Resource Type
<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server"@en .
<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router"@en .
<kos/Resource/type/Switch> a skos:Concept ; skos:prefLabel "Switch"@en .
<kos/Resource/type/Firewall> a skos:Concept ; skos:prefLabel "Firewall"@en .
<kos/Resource/type/LoadBalancer> a skos:Concept ; skos:prefLabel "Load Balancer"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine"@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; skos:prefLabel "Staging"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:prefLabel "Decommissioned"@en .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone"@en .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; skos:prefLabel "Ticketing System"@en .

# =============================================================================
# Organizations and Agents (Teams, Persons)
# =============================================================================

:Org_ITDept a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department responsible for all infrastructure and applications."@en ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via official IT support portal for all requests."@en .

:Team_NetworkOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf :Org_ITDept ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical issues, call the hotline. For routine, use ticketing system."@en .

:Team_AppDev a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    org:unitOf :Org_ITDept ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

:Team_SecurityOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:unitOf :Org_ITDept ;
    noria:agentWorkingHours "24/7 Monitoring"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

:Team_DBA a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database management."@en ;
    org:unitOf :Org_ITDept ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

:Person_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    org:memberOf :Team_NetworkOps ;
    foaf:mbox <mailto:alice.smith@example.com> .

:Person_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    org:memberOf :Team_AppDev ;
    foaf:mbox <mailto:bob.johnson@example.com> .

:Person_CharlieBrown a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "SOC Analyst."@en ;
    org:memberOf :Team_SecurityOps ;
    foaf:mbox <mailto:charlie.brown@example.com> .

:Person_DavidLee a foaf:Person, foaf:Agent ;
    rdfs:label "David Lee"@en ;
    rdfs:comment "Database Administrator."@en ;
    org:memberOf :Team_DBA ;
    foaf:mbox <mailto:david.lee@example.com> .

:CUid_AliceSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    foaf:accountName "asmith"@en ;
    foaf:holdsAccount :Person_AliceSmith .

:CUid_BobJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    foaf:accountName "bjohnson"@en ;
    foaf:holdsAccount :Person_BobJohnson .

# =============================================================================
# Product Models and Manufacturers
