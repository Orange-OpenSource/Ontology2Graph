# =============================================================================
# Network Interfaces
# =============================================================================

:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01."@en ;
    noria:networkInterfaceOf :Resource_DNS01 ;
    noria:networkInterfaceDescription "Management interface for DNS server."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

:NI_RouterCore01_Ge0_0_0 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface for RouterCore01."@en ;
    noria:networkInterfaceOf :Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to ISP."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

:NI_RouterCore01_Ge0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Internal network interface for RouterCore01."@en ;
    noria:networkInterfaceOf :Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Connects to internal LAN."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

:NI_AppServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "AppServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for AppServer01."@en ;
    noria:networkInterfaceOf :Resource_AppServer01 ;
    noria:networkInterfaceDescription "Application traffic interface."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

:NI_Firewall01_Eth0 a noria:NetworkInterface ;
