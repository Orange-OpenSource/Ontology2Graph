# =============================================================================
# Trouble Ticket Notes
# =============================================================================

:TTNote_DNSOutage_InitialDiag a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage - Initial Diagnosis"@en ;
    rdfs:comment "Initial diagnosis: Confirmed DNS server is not responding to pings. Checking network path."@en ;
    dcterms:created "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    dcterms:description "Ping to dns01.corp.example.com failed. Traceroute shows no path. Suspect physical link or router issue."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf :TT_DNSOutage_20240420 ;
    dcterms:creator :Person_AliceSmith .

:TTNote_DNSOutage_Resolution a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage - Resolution Step"@en ;
    rdfs:comment "Resolution: Identified faulty fiber optic cable on router-core-01. Replaced cable. DNS service restored."@en ;
    dcterms:created "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    dcterms:description "Replaced fiber optic cable connecting RouterCore01 to ISP. DNS service now reachable. Monitoring for stability."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ;
    dcterms:isPartOf :TT_DNSOutage_20240420 ;
    dcterms:creator :Person_AliceSmith ;
    noria:troubleTicketNoteCorrelatedExecution :Event_CableReplacementAction .

:TTNote_DBDiskFull_Resolution a noria:TroubleTicketNote ;
    rdfs:label "DB Disk Full - Resolution Step"@en ;
    rdfs:comment "Resolution: Disk space cleared on DB server. Monitoring for recurrence."@en ;
    dcterms:created "2024-04-20T12:45:00Z"^^xsd:dateTime ;
    dcterms:description "Executed standard disk cleanup procedure. Confirmed disk space is now sufficient."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ;
    dcterms:isPartOf :TT_DBDiskFull_20240420 ;
    dcterms:creator :Person_DavidLee ;
    noria:troubleTicketNoteCorrelatedExecution :Event_DBDiskCleanupAction .

