# =============================================================================
# Agents and Organizations
# =============================================================================

:DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for Corporate DNS server management and operations."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use ticketing system for all requests. For critical issues, call hotline."@en ;
    org:hasMember :JohnDoe ;
    org:unitOf :ITOperationsDept .

:WebOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "WebOps Team"@en ;
    rdfs:comment "Team responsible for Customer Web Portal deployment and maintenance."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate via PagerDuty for critical web service incidents."@en ;
    org:hasMember :JaneSmith ;
    org:unitOf :ITOperationsDept .

:DBAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Admin Team"@en ;
    rdfs:comment "Team responsible for internal database systems."@en ;
    noria:agentWorkingHours "08:30-17:30 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    org:unitOf :ITOperationsDept .

:NOC a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "First line of defense for network incidents, 24/7 monitoring."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    org:unitOf :NetworkEngineeringDept .

:IncidentResponseLead a foaf:Agent ;
    rdfs:label "Incident Response Lead"@en ;
    rdfs:comment "Individual leading major incident response efforts."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

:JohnDoe a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior DNS Administrator."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "tel:+1-555-123-4567" ;
    foaf:holdsAccount :JohnDoeCUid .

:JaneSmith a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead WebOps Engineer."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "tel:+1-555-987-6543" ;
    foaf:holdsAccount :JaneSmithCUid .

:JohnDoeCUid a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "jdoe-corp-id-123" .

:JaneSmithCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    foaf:accountName "jsmith" ;
    observable:accountLogin "jsmith" ;
    observable:accountIdentifier "jsmith-corp-id-456" .

:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Main department for IT service delivery and operations."@en .

:NetworkEngineeringDept a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Department"@en ;
    rdfs:comment "Department responsible for network design and architecture."@en ;
    org:unitOf :ITOperationsDept .

# =============================================================================
# Locations
# =============================================================================

:MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC-MAIN-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en ;
    bot:hasSpace :ServerRoomA .

:ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the primary data center."@en ;
    bot:hasZone :Rack1Unit10, :Rack2Unit5 .

:Rack1Unit10 a noria:Locus ;
    rdfs:label "Rack 1, Unit 10"@en ;
    rdfs:comment "Specific location for equipment in Server Room A."@en ;
    noria:locusLine "Rack 1"@en ;
    noria:locusRow "Unit 10"@en .

:Rack2Unit5 a noria:Locus ;
    rdfs:label "Rack 2, Unit 5"@en ;
    rdfs:comment "Specific location for equipment in Server Room A."@en ;
    noria:locusLine "Rack 2"@en ;
    noria:locusRow "Unit 5"@en .

:DRDataCenter a bot:Site ;
    rdfs:label "Disaster Recovery Data Center"@en ;
    rdfs:comment "Secondary data center for disaster recovery purposes."@en ;
    noria:siteId "DC-DR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Boulevard"@en ;
    noria:sitePrincipalAddressCityName "Gotham City"@en ;
    noria:sitePrincipalAddressPostalCode "20002"@en ;
    noria:sitePrincipalAddressCountry "US"@en ;
    bot:hasSpace :ServerRoomB .

:ServerRoomB a noria:Room ;
    rdfs:label "Server Room B"@en ;
    rdfs:comment "Server room within the disaster recovery data center."@en ;
    bot:hasZone :Rack5Unit1 .

:Rack5Unit1 a noria:Locus ;
    rdfs:label "Rack 5, Unit 1"@en ;
    rdfs:comment "Specific location for equipment in Server Room B."@en ;
    noria:locusLine "Rack 5"@en ;
    noria:locusRow "Unit 1"@en .

# =============================================================================
# Product Models
# =============================================================================

:DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model commonly used for enterprise applications."@en ;
    noria:productManufacturedBy :DellTechnologies .

:CiscoCatalyst9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Cisco enterprise-grade access layer switch."@en ;
    noria:productManufacturedBy :CiscoSystems .

:JuniperMX204 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Juniper universal routing platform for edge and core networks."@en ;
    noria:productManufacturedBy :JuniperNetworks .

:VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi"@en ;
    rdfs:comment "VMware's enterprise-class, type-1 hypervisor."@en ;
    noria:productManufacturedBy :VMwareInc .

:DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

:CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

:JuniperNetworks a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en .

:VMwareInc a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

