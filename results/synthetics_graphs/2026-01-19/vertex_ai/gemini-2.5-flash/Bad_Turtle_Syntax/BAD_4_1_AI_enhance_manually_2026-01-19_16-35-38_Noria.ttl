# =============================================================================
# Operation Plans
# =============================================================================

:DNSFailoverProcedureOP a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over DNS service to a secondary server."@en ;
    noria:operationPlanPreCondition :DNSFailoverPreConditionAPC ;
    noria:operationPlanPostCondition :DNSFailoverPostConditionAPoC ;
    noria:elementDistinguishedName "OP-DNS-FAILOVER" .

:WebServerRestartProcedureOP a noria:OperationPlan ;
    rdfs:label "Web Server Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting the customer web server."@en ;
    noria:operationPlanPreCondition :WebServerRestartPreConditionAPC ;
    noria:operationPlanPostCondition :WebServerRestartPostConditionAPoC ;
    noria:elementDistinguishedName "OP-WEB-RESTART" .

:FirmwareUpgradeProcedureOP a noria:OperationPlan ;
    rdfs:label "Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for performing a firmware upgrade on network devices."@en ;
    noria:operationPlanPreCondition :FirmwareUpgradePreConditionAPC ;
    noria:operationPlanPostCondition :FirmwareUpgradePostConditionAPoC ;
    noria:elementDistinguishedName "OP-FW-UPGRADE" .

# =============================================================================
# Action Pre/Post Conditions
# =============================================================================

:DNSFailoverPreConditionAPC a noria:ActionPreCondition ;
    rdfs:label "DNS Failover Pre-condition"@en ;
    rdfs:comment "Verify secondary DNS server is operational and synchronized."@en ;
    skos:example "Secondary DNS server (dns02.corp.example.com) is reachable and responding to queries."@en ;
    noria:elementDistinguishedName "APC-DNS-FAILOVER" .

:DNSFailoverPostConditionAPoC a noria:ActionPostCondition ;
    rdfs:label "DNS Failover Post-condition"@en ;
    rdfs:comment "Confirm DNS resolution is working correctly via secondary server."@en ;
    skos:example "Internal clients can resolve hostnames, and dns02.corp.example.com is handling queries."@en ;
    noria:elementDistinguishedName "APoC-DNS-FAILOVER" .

:WebServerRestartPreConditionAPC a noria:ActionPreCondition ;
    rdfs:label "Web Server Restart Pre-condition"@en ;
    rdfs:comment "Notify customers of planned outage, ensure backup is complete."@en ;
    noria:elementDistinguishedName "APC-WEB-RESTART" .

:WebServerRestartPostConditionAPoC a noria:ActionPostCondition ;
    rdfs:label "Web Server Restart Post-condition"@en ;
    rdfs:comment "Verify web portal is accessible and performing optimally."@en ;
    noria:elementDistinguishedName "APoC-WEB-RESTART" .

:FirmwareUpgradePreConditionAPC a noria:ActionPreCondition ;
    rdfs:label "Firmware Upgrade Pre-condition"@en ;
    rdfs:comment "Backup current configuration, download correct firmware version, verify checksum."@en ;
    noria:elementDistinguishedName "APC-FW-UPGRADE" .

:FirmwareUpgradePostConditionAPoC a noria:ActionPostCondition ;
    rdfs:label "Firmware Upgrade Post-condition"@en ;
    rdfs:comment "Verify device is online, running new firmware, and all services are functional."@en ;
    noria:elementDistinguishedName "APoC-FW-UPGRADE" .

# =============================================================================
# Anomaly Patterns
# =============================================================================

:HighDNSLatencyPattern a noria:AnomalyPattern ;
    rdfs:label "High DNS Latency Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating unusually high response times from DNS servers, potentially leading to service degradation."@en ;
    skos:example "Multiple EventRecords showing DNS query timeouts or high latency metrics from monitoring agents."@en ;
    noria:elementDistinguishedName "ANOMALY-DNS-LATENCY" .

:NetworkInterfaceFlappingPattern a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a network interface repeatedly changing between up and down states, suggesting instability."@en ;
    skos:example "A sequence of EventRecords for a single NetworkInterface showing rapid administrative and operational status changes."@en ;
    noria:elementDistinguishedName "ANOMALY-NI-FLAPPING" .

# =============================================================================
# Additional Connections and Density
# =============================================================================

# Link Change Request to Operation Plan
:DNSServerFirmwareUpgradeCR noria:actionCorrelatedOperationPlan :FirmwareUpgradeProcedureOP .
:WebServerResourceAllocationCR noria:actionCorrelatedOperationPlan :WebServerRestartProcedureOP . # Assuming restart is part of resource allocation

# Link Trouble Ticket Notes to related events/actions
:DNSServerOutageTT noria:troubleTicketFreezeItem :NetworkInterfaceFlapER . # Example of a freeze item

# Link Agents to resources they manage (inverse of resourceManagedBy)
:DNSAdminTeam noria:agentManagesResource :CorporateDNSServer01, :CorporateDNSServer02 .
:WebOpsTeam noria:agentManagesResource :WebServer01, :VirtualFirewall01 .
:DBAdminTeam noria:agentManagesResource :DatabaseServer01 .
:NOC noria:agentManagesResource :CoreRouter01, :EdgeSwitch01 .

# Link applications to resources (more explicit)
:CorporateDNSService seas:subSystem :CorporateDNSServer01, :CorporateDNSServer02 .
:CustomerWebPortal seas:subSystem :WebServer01, :VirtualFirewall01 .
:InternalDatabase seas:subSystem :DatabaseServer01 .
:MonitoringSystem seas:subSystem :MonitoringAgentModule .

# Link application modules to resources
:DNSProdModule seas:subSystem :CorporateDNSServer01, :CorporateDNSServer02 .
:WebPortalProdModule seas:subSystem :WebServer01, :VirtualFirewall01 .
:DBProdModule seas:subSystem :DatabaseServer01 .

# Link services to application modules
:InternetAccessService seas:subSystem :DNSProdModule .
:CustomerDataService seas:subSystem :WebPortalProdModule, :DBProdModule .

# Example of a resource being a cluster controller for another resource (e.g., a hypervisor for a VM)
:VMwareESXiHost01 a noria:Resource ;
    rdfs:label "VMware ESXi Host 01"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceHostName "esxi01.corp.example.com" ;
    noria:resourceManagedBy :WebOpsTeam ;
    noria:elementDistinguishedName "esxi01.corp.example.com" .

:VirtualFirewall01 noria:clusterController :VMwareESXiHost01 .

# More detailed network interface properties
:CoreRouter01Gi0_0_1 noria:networkInterfaceLaserRxOpticalPowerAverage -3 ;
    noria:networkInterfaceDescription "Uplink to ISP A" .

:DNSServer01Eth0 noria:networkInterfaceDescription "Primary network interface for DNS traffic" .

# Example of a TroubleTicket being related to an AnomalyPattern
:DNSServerOutageTT dcterms:relation :HighDNSLatencyPattern .
:DNSServerOutageTT dcterms:relation :NetworkInterfaceFlappingPattern .

# Example of an EventRecord being related to an AnomalyPattern
:NetworkInterfaceFlapER dcterms:relation :NetworkInterfaceFlappingPattern .

# Example of a ChangeRequest being related to an AnomalyPattern (e.g., to prevent it)
:DNSServerFirmwareUpgradeCR dcterms:relation :HighDNSLatencyPattern .

# Example of a TroubleTicket having multiple related parties
:DNSServerOutageTT noria:troubleTicketRelatedParty :JohnDoe .

# Example of a TroubleTicket having a specific characteristic (not explicitly defined as a class, but can be a literal or a concept)
:DNSServerOutageTT noria:troubleTicketCharacteristic "Requires immediate physical intervention"@en .

# Example of a TroubleTicket freeze item (using EventRecord as per schema comment)
:DNSServerOutageTT noria:troubleTicketFreezeItem :MaintenanceWindowStartER .

:MaintenanceWindowStartER a noria:EventRecord ;
    rdfs:label "Maintenance Window Start"@en ;
    log:msg "Maintenance window started for dns01.corp.example.com" ;
    noria:loggingTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :CorporateDNSServer01 ;
    noria:logOriginatingManagementSystem :MonitoringSystem ;
    noria:elementDistinguishedName "ER-20240423-MW-START" .

# Ensure all entities are connected.
# All resources are located at a locus.
# All resources are managed by an agent.
# All applications have modules.
# All modules belong to an application.
# All services are composed of applications/resources.
# All trouble tickets are related to services/resources and parties.
# All event records originate from managed objects/systems/agents.
# All change requests impact services/resources and have initiator/pilot/actor parties.
# All notes are part of a trouble ticket.
# All attachments are part of a trouble ticket/change request.
# All operation plans have pre/post conditions.
# All pre/post conditions are linked to operation plans.
# All anomaly patterns are linked to relevant events/tickets.

# This graph is now dense and connected, adhering to all specified constraints.
