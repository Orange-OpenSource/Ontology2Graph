# =============================================================================
# Event Records
# =============================================================================

:DNSServerDownAlertER a noria:EventRecord ;
    rdfs:label "DNS Server Down Alert"@en ;
    rdfs:comment "Alert: Corporate DNS Server 01 (10.0.0.10) is unreachable."@en ;
    log:msg "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:loggingTime "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :CorporateDNSServer01 ;
    noria:logOriginatingManagementSystem :MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction :DNSFailoverProcedureOP ;
    dcterms:relation :DNSServerOutageTT ;
    noria:elementDistinguishedName "ER-20240423-001" .

:NetworkInterfaceFlapER a noria:EventRecord ;
    rdfs:label "Network Interface Flap Alert"@en ;
    rdfs:comment "Alert: Network interface Gi0/0/0 on Core Router 01 is flapping."@en ;
    log:msg "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down" ;
    noria:loggingTime "2024-04-23T08:54:50Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :CoreRouter01 ;
    noria:logOriginatingManagementSystem :MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:relation :DNSServerOutageTT ;
    noria:elementDistinguishedName "ER-20240423-002" .

:WebServerHighCPUER a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert: CPU utilization on Web Server 01 exceeded 90% for 15 minutes."@en ;
    log:msg "WARNING: Host web01.customer.example.com CPU utilization 95%" ;
    noria:loggingTime "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :WebServer01 ;
    noria:logOriginatingManagementSystem :MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:relation :WebPortalSlowPerformanceTT ;
    noria:elementDistinguishedName "ER-20240423-003" .

:DNSServiceRestoredER a noria:EventRecord ;
    rdfs:label "DNS Service Restored Notification"@en ;
    rdfs:comment "Notification: Corporate DNS Service restored after failover to secondary server."@en ;
    log:msg "INFO: Corporate DNS Service restored via failover." ;
    noria:loggingTime "2024-04-23T11:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :CorporateDNSService ;
    noria:logOriginatingManagementSystem :MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    noria:alarmMitigatedBy :DNSServerOutageTT ;
    dcterms:relation :DNSServerOutageTT ;
    noria:elementDistinguishedName "ER-20240423-004" .

