# Base URI for instances
@base <https://w3id.org/noria/instances/> .

# =============================================================================
# KOS Concepts (Knowledge Organization System)
# These are defined as skos:Concept and used as ranges for various properties.
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application Type"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/service-platform> a skos:Concept ; rdfs:label "Service Platform Application Type"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/business-application> a skos:Concept ; rdfs:label "Business Application Type"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .

<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; rdfs:label "En Production"@fr ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "In Development"@en ; rdfs:label "En Développement"@fr ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned"@en ; rdfs:label "Hors Service"@fr ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; rdfs:label "Silver SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .

