    dcterms:creator :AliceSmith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf :TroubleTicket_DNSOutage_TT001 .

:TroubleTicketNote_TT001_2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Step for TT001"@en ;
    rdfs:comment "Restarted network interface ge-0/0/0 on cr01.dc01.example.com. DNS server now reachable."@en ;
    dcterms:created "2024-04-10T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator :AliceSmith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf :TroubleTicket_DNSOutage_TT001 ;
    noria:troubleTicketNoteCorrelatedExecution :EventRecord_InterfaceFlap_1 . # Linking to the event that might have been caused by the restart

:TroubleTicketNote_TT002_1 a noria:TroubleTicketNote ;
    rdfs:label "Customer Report for TT002"@en ;
    rdfs:comment "Customer reported 'website is very slow, sometimes times out'."@en ;
