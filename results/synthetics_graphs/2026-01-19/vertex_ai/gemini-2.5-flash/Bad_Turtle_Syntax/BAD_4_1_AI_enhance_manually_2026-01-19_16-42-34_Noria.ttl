################################################################################
# Event Records
################################################################################

:EventRecord_DNSOutage_1 a noria:EventRecord ;
    rdfs:label "DNS Server 01 Down Event"@en ;
    rdfs:comment "Log entry indicating that DNS Server 01 became unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :DNSServer01 ;
    noria:logOriginatingManagementSystem :NetworkMonitoringApp ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_InterfaceFlap_1 a noria:EventRecord ;
    rdfs:label "Core Router Interface Flap Event"@en ;
    rdfs:comment "Log entry indicating an interface on Core Router 01 flapped (went down and up)."@en ;
    noria:loggingTime "2024-04-10T08:59:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :CoreRouter01 ;
    noria:logOriginatingManagementSystem :NetworkMonitoringApp ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:EventRecord_LoginFailure_1 a noria:EventRecord ;
    rdfs:label "Failed Login Attempt on Web Server"@en ;
    rdfs:comment "Security log entry showing a failed login attempt on Web Server 01."@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :WebServer01 ;
    noria:logOriginatingManagementSystem :SecurityOpsCenter ; # Assuming SOC has a SIEM that generates events
    noria:logOriginatingAgent :DanaWhite ; # Dana might be investigating or triggering an alert
    noria:logText "Failed login for user 'admin' from IP 203.0.113.42" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:EventRecord_ConfigChange_1 a noria:EventRecord ;
    rdfs:label "Router Configuration Change Event"@en ;
    rdfs:comment "Log entry indicating a configuration change was applied to Core Router 01."@en ;
    noria:loggingTime "2024-04-05T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :CoreRouter01 ;
    noria:logOriginatingManagementSystem :NetworkMonitoringApp ; # Or a configuration management system
    noria:logOriginatingAgent :AliceSmith ;
    noria:logText "Configuration changed by Alice Smith via SSH from 10.0.0.5" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

