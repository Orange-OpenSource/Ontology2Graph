    dcterms:created "2024-04-11T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/IsolatedCustomerSite> ; # Example of a less severe category
    noria:troubleTicketCause "High CPU load due to unoptimized database queries."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-11T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService :CustomerFacingWebService ;
    noria:troubleTicketRelatedResource :WebServer01, :DBServer01 ;
    noria:troubleTicketRelatedParty :WebDevTeam, :ServerAdminTeam ;
