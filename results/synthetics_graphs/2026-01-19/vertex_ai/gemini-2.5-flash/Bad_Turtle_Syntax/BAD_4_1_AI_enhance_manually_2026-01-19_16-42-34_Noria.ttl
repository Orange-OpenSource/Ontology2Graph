################################################################################

:TroubleTicketNote_TT001_1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT001"@en ;
    rdfs:comment "Confirmed DNS server is not responding to pings. Checking network path from core router."@en ;
