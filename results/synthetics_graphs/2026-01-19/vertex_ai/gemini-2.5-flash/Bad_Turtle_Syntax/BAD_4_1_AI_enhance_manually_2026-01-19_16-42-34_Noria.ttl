<kos/ChangeRequest/specification/NetworkConfigurationUpdate> a skos:Concept ; rdfs:label "Network Configuration Update Specification"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> .

# KOS Concepts for Resource
<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Operational State Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Operational State Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ; rdfs:label "Administrative State Enabled"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Disabled> a skos:Concept ; rdfs:label "Administrative State Disabled"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router Resource Type"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server Resource Type"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
