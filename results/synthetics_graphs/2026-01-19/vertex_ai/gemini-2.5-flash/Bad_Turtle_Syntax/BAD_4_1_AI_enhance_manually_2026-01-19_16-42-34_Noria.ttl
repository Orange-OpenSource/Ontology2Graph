:TroubleTicket_DNSOutage_TT001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "DNS server dns01.corp.example.com is unreachable, impacting all internal services."@en ;
