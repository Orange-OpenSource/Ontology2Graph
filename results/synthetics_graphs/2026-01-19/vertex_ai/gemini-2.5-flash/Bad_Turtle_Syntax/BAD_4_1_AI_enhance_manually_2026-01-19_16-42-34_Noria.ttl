@prefix devopsprod: <http://w3id.org/devops-infra/product#> .

# Base URI for instances
@base <https://w3id.org/noria/data/> .

################################################################################
# KOS Concepts (Knowledge Organization System)
# These concepts are used as controlled vocabularies for various properties.
################################################################################

# KOS Concepts for Application
<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application Type"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/business-critical> a skos:Concept ; rdfs:label "Business Critical Application Type"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; rdfs:label "Monitoring Application Type"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production Status"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<kos/application/status/Development> a skos:Concept ; rdfs:label "Development Status"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; rdfs:label "Silver SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# KOS Concepts for Service
<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service Type"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service Type"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .

# KOS Concepts for TroubleTicket
<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure Type"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance Type"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .
<kos/TroubleTicket/category/NetworkOutage> a skos:Concept ; rdfs:label "Network Outage Category"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/category> .
<kos/TroubleTicket/category/ServerFailure> a skos:Concept ; rdfs:label "Server Failure Category"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/category> .
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention Urgency"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention Urgency"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> .
<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ; rdfs:label "Total Breakdown Trouble Category"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/trouble-category/IsolatedCustomerSite> a skos:Concept ; rdfs:label "Isolated Customer Site Trouble Category"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; rdfs:label "Managed Backbone Networks Responsibility"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/Customer> a skos:Concept ; rdfs:label "Customer Responsibility"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress Status"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved Status"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed Status"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment Type"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment Type"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation Type"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; rdfs:label "Tests and Measurements Operation Type"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .

# KOS Concepts for ChangeRequest
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention Category"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade Category"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change Type"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency Change Type"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; rdfs:label "Configuration Change Cause"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .
<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ; rdfs:label "Preventative Maintenance Change Cause"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .
