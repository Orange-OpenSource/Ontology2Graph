################################################################################
# Agents and Organizations
################################################################################

# Organizational Units (Teams/Departments)
:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en, "Département Opérations IT"@fr ;
    rdfs:comment "Department responsible for the day-to-day operations of IT infrastructure and applications."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, call the hotline immediately. For non-critical, use ticketing system."@en .

:NetworkOpsTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for managing and maintaining the corporate network infrastructure."@en ;
    org:unitOf :ITOperationsDept ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

:ServerAdminTeam a org:OrganizationalUnit ;
    rdfs:label "Server Administration Team"@en, "Équipe Administration Serveurs"@fr ;
    rdfs:comment "Team responsible for managing and maintaining physical and virtual servers."@en ;
    org:unitOf :ITOperationsDept ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

:WebDevTeam a org:OrganizationalUnit ;
    rdfs:label "Web Development Team"@en, "Équipe Développement Web"@fr ;
    rdfs:comment "Team responsible for developing and maintaining the Customer Portal application."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

:SecurityOpsCenter a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

# Individual Agents
:AliceSmith a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, member of Network Operations Team."@en ;
    org:memberOf :NetworkOpsTeam ;
    foaf:mbox <mailto:alice.smith@example.com> .

:BobJohnson a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Server Administrator, member of Server Administration Team."@en ;
    org:memberOf :ServerAdminTeam ;
    foaf:mbox <mailto:bob.johnson@example.com> .

:CharlieBrown a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Web Developer, member of Web Development Team."@en ;
    org:memberOf :WebDevTeam ;
    foaf:mbox <mailto:charlie.brown@example.com> .

:DanaWhite a foaf:Agent ;
    rdfs:label "Dana White"@en ;
    rdfs:comment "SOC Analyst, member of Security Operations Center."@en ;
    org:memberOf :SecurityOpsCenter ;
    foaf:mbox <mailto:dana.white@example.com> .

# Corporate User Identifiers
:AliceCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount :AliceSmith .

:BobCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount :BobJohnson .

################################################################################
# Locations
################################################################################

# Sites
:MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" ;
    wgs84_pos:lat "34.0522"^^xsd:float ;
    wgs84_pos:long "-118.2437"^^xsd:float .

:BranchOfficeLA a bot:Site ;
    rdfs:label "Los Angeles Branch Office"@en, "Bureau de Los Angeles"@fr ;
    noria:siteId "BO-LA" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Innovation Drive" ;
    noria:sitePrincipalAddressCityName "Los Angeles" ;
    noria:sitePrincipalAddressPostalCode "90012" ;
    noria:sitePrincipalAddressCountry "US" ;
    wgs84_pos:lat "34.0522"^^xsd:float ;
    wgs84_pos:long "-118.2437"^^xsd:float .

# Rooms
:ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server room in the main data center."@en ;
    bot:hasSpace :MainDataCenter . # bot:hasSpace is inverse of bot:containsZone, but bot:containsZone is for Zone -> Site. Room is a Space, Site is a Zone. So bot:hasSpace is correct.

:NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Network equipment room in the main data center."@en ;
    bot:hasSpace :MainDataCenter .

:OfficeServerRoom a noria:Room ;
    rdfs:label "Branch Office Server Room"@en ;
    rdfs:comment "Small server room at the Los Angeles branch office."@en ;
    bot:hasSpace :BranchOfficeLA .

# Loci (plural of Locus)
:Rack1_SR_A a noria:Locus ;
    rdfs:label "Rack 1 in Server Room A"@en ;
    rdfs:comment "Location of critical infrastructure servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace :ServerRoomA .

:Rack2_SR_A a noria:Locus ;
    rdfs:label "Rack 2 in Server Room A"@en ;
    rdfs:comment "Location of database and application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasSpace :ServerRoomA .

:CoreSwitchBay_NR_B a noria:Locus ;
    rdfs:label "Core Switch Bay in Network Room B"@en ;
    rdfs:comment "Location of core network switches."@en ;
    noria:locusLine "C" ;
    noria:locusRow "5" ;
    bot:hasSpace :NetworkRoomB .

:AccessSwitchBay_OSR a noria:Locus ;
    rdfs:label "Access Switch Bay in Office Server Room"@en ;
    rdfs:comment "Location of access switches at the branch office."@en ;
    noria:locusLine "B" ;
    noria:locusRow "3" ;
    bot:hasSpace :OfficeServerRoom .

################################################################################
# Product Models
################################################################################

:DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy :DellTechnologies .

:CiscoCatalyst9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch."@en ;
    noria:productManufacturedBy :CiscoSystems .

:JuniperMX204 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Compact, high-performance universal routing platform."@en ;
    noria:productManufacturedBy :JuniperNetworks .

:FortiGate100F a noria:ProductModel ;
    rdfs:label "FortiGate 100F"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy :Fortinet .

# Manufacturers (Organizations)
:DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

:CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

:JuniperNetworks a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en .

:Fortinet a org:Organization ;
    rdfs:label "Fortinet"@en ;
    rdfs:comment "American multinational corporation that develops and sells cybersecurity solutions, such as physical firewalls, antivirus software, intrusion prevention systems, and endpoint security components."@en .

################################################################################
# Resources
################################################################################

:DNSServer01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical for internal and external resolution."@en ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel :DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "DELL-SN-DNS01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :ServerAdminTeam ;
    noria:locatedAtLocus :Rack1_SR_A ;
    noria:resourceManagementIPAddress "10.0.0.10" .

:WebServer01 a noria:Resource ;
    rdfs:label "Customer Portal Web Server 01"@en, "Serveur Web Portail Client 01"@fr ;
    rdfs:comment "Frontend web server for the Customer Portal application."@en ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceHostName "web01.portal.example.com" ;
    noria:resourceProductModel :DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "DELL-SN-WEB01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :ServerAdminTeam ;
    noria:locatedAtLocus :Rack2_SR_A ;
    noria:resourceManagementIPAddress "10.0.0.20" .

:DBServer01 a noria:Resource ;
    rdfs:label "Customer Portal Database Server 01"@en, "Serveur Base de Données Portail Client 01"@fr ;
    rdfs:comment "Backend database server for the Customer Portal application."@en ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceHostName "db01.portal.example.com" ;
    noria:resourceProductModel :DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "DELL-SN-DB01" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-03-01T15:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :ServerAdminTeam ;
    noria:locatedAtLocus :Rack2_SR_A ;
    noria:resourceManagementIPAddress "10.0.0.30" .

:CoreRouter01 a noria:Resource ;
