    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkConfigurationUpdate> ;
    noria:changeRequestInitiatorParty :AliceSmith ;
    noria:changeRequestPilotParty :AliceSmith ;
    noria:changeRequestActorParty :NetworkOpsTeam ;
    noria:changeRequestIsRegulated true .

################################################################################
# Procedural Elements
################################################################################

# Operation Plans
:DNSServerFailoverPlan a noria:OperationPlan ;
    rdfs:label "DNS Server Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over DNS services to a secondary server in case of primary server failure."@en ;
    noria:operationPlanPreCondition :DNSServerDownPreCondition ;
    noria:operationPlanPostCondition :DNSServiceRestoredPostCondition .

:WebServerRestartPlan a noria:OperationPlan ;
    rdfs:label "Web Server Restart Procedure"@en ;
    rdfs:comment "Procedure to safely restart the web server process and associated services."@en ;
    noria:operationPlanPreCondition :HighCPULoadPreCondition ;
    noria:operationPlanPostCondition :CPULoadNormalPostCondition .

# Action Pre-Conditions
:DNSServerDownPreCondition a noria:ActionPreCondition ;
    rdfs:label "DNS Primary Server Down Pre-Condition"@en ;
    rdfs:comment "Condition: Primary DNS server (dns01.corp.example.com) is unresponsive to health checks."@en ;
    skos:example "Ping to dns01.corp.example.com fails; DNS queries to dns01.corp.example.com time out."@en .

:HighCPULoadPreCondition a noria:ActionPreCondition ;
    rdfs:label "High CPU Load Pre-Condition"@en ;
    rdfs:comment "Condition: Web server CPU utilization consistently above 80% for 5 minutes."@en ;
    skos:example "Monitoring alert for high CPU on web01.portal.example.com."@en .

# Action Post-Conditions
:DNSServiceRestoredPostCondition a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Post-Condition"@en ;
    rdfs:comment "Outcome: DNS resolution is functional, and primary DNS server is reachable or secondary is active."@en ;
    skos:example "Ping to dns01.corp.example.com succeeds (or secondary DNS is active); DNS queries resolve correctly."@en .

:CPULoadNormalPostCondition a noria:ActionPostCondition ;
    rdfs:label "CPU Load Normal Post-Condition"@en ;
    rdfs:comment "Outcome: Web server CPU utilization returns to normal levels (below 50%)."@en ;
    skos:example "Monitoring shows CPU on web01.portal.example.com below 50% for 10 minutes."@en .

# Anomaly Patterns
:RepeatedLoginFailurePattern a noria:AnomalyPattern ;
    rdfs:label "Repeated Login Failure Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating multiple failed login attempts from a single source IP within a short timeframe, potentially indicating a brute-force attack."@en ;
    folio:hasCause "Brute-force attack attempt"@en ;
    folio:hasEffect "Potential unauthorized access"@en .

# Linking actions to operation plans
:TroubleTicketNote_TT001_2 noria:actionCorrelatedOperationPlan :DNSServerFailoverPlan .
:ChangeRequest_WebServerUpgrade_CR001 noria:actionCorrelatedOperationPlan :WebServerRestartPlan . # Assuming restart is part of upgrade procedure

################################################################################
# Additional Connections for Density
################################################################################

# Link agents to resources they manage
:ServerAdminTeam noria:agentManagesResource :DNSServer01, :WebServer01, :DBServer01 .
:NetworkOpsTeam noria:agentManagesResource :CoreRouter01, :AccessSwitch01, :Link_DNSServer_CoreRouter, :Link_WebServer_CoreRouter, :Link_DBServer_CoreRouter, :Link_CoreRouter_AccessSwitch .
:SecurityOpsCenter noria:agentManagesResource :Firewall01 .

# Link applications to resources
:CorporateDNSServiceApp noria:resourceForApplication :DNSServer01 .
:CustomerPortalApp noria:resourceForApplication :WebServer01, :DBServer01 .

# Link application modules to resources (indirectly via application, or directly if module has dedicated resources)
