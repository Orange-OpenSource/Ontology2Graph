# --- KOS Concepts Declarations ---
# These SKOS Concept Schemes and Concepts are used to provide controlled vocabularies
# for various properties within the NORIA ontology, as indicated by the schema's
# owl:Restriction definitions.

# Application Type Scheme
noria:kos/application/type a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "Controlled vocabulary for application types."@en .

noria:kos/application/type/infrastructure a skos:Concept ;
    skos:prefLabel "Infrastructure"@en ;
    skos:altLabel "Infrastructure Application"@fr ;
    skos:inScheme noria:kos/application/type .

noria:kos/application/type/business a skos:Concept ;
    skos:prefLabel "Business Application"@en ;
    skos:altLabel "Application Métier"@fr ;
    skos:inScheme noria:kos/application/type .

