# --- Trouble Tickets ---
noria:TroubleTicket_DB_Outage a noria:TroubleTicket ;
    rdfs:label "Database Service Interruption"@en ;
    rdfs:comment "Critical incident: Database service for Corporate Web Portal is unavailable, impacting employee access."@en ;
    dcterms:identifier "TT-20240423-001" ;
    dcterms:created "2024-04-23T14:06:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity noria:kos/TroubleTicket/severity/Critical ;
    noria:troubleTicketType noria:kos/TroubleTicket/type/Failure ;
    noria:troubleTicketCriticity noria:kos/TroubleTicket/category/InterruptedService ;
    noria:troubleTicketPriority noria:kos/TroubleTicket/priority/P1 ;
    noria:troubleTicketOrigin noria:kos/TroubleTicket/origin/Supervision ;
    noria:troubleTicketTrigger noria:EventRecord_DB_HighCPU ;
    noria:troubleTicketUrgency noria:kos/TroubleTicket/urgency/ImmediateIntervention ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory noria:kos/TroubleTicket/trouble-category/TotalBreakdown ;
    noria:troubleTicketCause "High CPU load on DB server leading to service unresponsiveness."@en ;
    noria:problemResponsibility noria:kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks ; # Example, assuming DB issue was due to underlying network.
    noria:troubleTicketDetectionDateTime "2024-04-23T14:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T15:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent noria:kos/TroubleTicket/status/InProgress ;
    noria:troubleTicketRelatedParty noria:Agent_IT_Ops_Team, noria:Agent_App_Support_Team ;
    noria:troubleTicketRelatedService noria:ApplicationModule_CWP_Prod, noria:Service_EmployeeAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DBServer01 ;
    noria:troubleTicketImpacts noria:Application_CorpWebPortal, noria:Resource_DBServer01 ;
    noria:documentHRef "https://itsm.example.com/tickets/TT-20240423-001" ;
    noria:documentStatusHistory noria:EventRecord_TT_DB_StatusChange_InProgress, noria:EventRecord_TT_DB_StatusChange_Resolved ;
    noria:troubleTicketFreezeItem noria:EventRecord_TT_DB_Freeze_Start, noria:EventRecord_TT_DB_Freeze_End ;
    pep:member noria:EventRecord_DB_HighCPU .

noria:TroubleTicket_Network_Link_Down a noria:TroubleTicket ;
    rdfs:label "Core Router Uplink Down"@en ;
    rdfs:comment "Critical incident: Uplink on Core Router 01 is down, affecting external connectivity for the entire data center."@en ;
    dcterms:identifier "TT-20240423-002" ;
    dcterms:created "2024-04-23T14:11:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity noria:kos/TroubleTicket/severity/Critical ;
    noria:troubleTicketType noria:kos/TroubleTicket/type/Failure ;
    noria:troubleTicketCriticity noria:kos/TroubleTicket/category/InterruptedService ;
    noria:troubleTicketPriority noria:kos/TroubleTicket/priority/P1 ;
    noria:troubleTicketOrigin noria:kos/TroubleTicket/origin/Supervision ;
    noria:troubleTicketTrigger noria:EventRecord_Router_InterfaceDown ;
    noria:troubleTicketUrgency noria:kos/TroubleTicket/urgency/ImmediateIntervention ;
    noria:troubleTicketSupervisionTool "Zabbix" ;
    noria:troubleTicketCategory noria:kos/TroubleTicket/trouble-category/NetworkIssue ;
