# --- Event Records ---
noria:EventRecord_DB_HighCPU a noria:EventRecord ;
    rdfs:label "DB Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on the database server, potentially impacting application performance."@en ;
    noria:loggingTime "2024-04-23T14:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CPU utilization on db01.corp.example.com exceeded 90% for 5 minutes."@en ;
    dcterms:type noria:kos/Notification/EventType/thresholdCrossing ;
    noria:alarmSeverity noria:kos/Notification/Severity/PerceivedSeverity/Critical .

noria:EventRecord_Router_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a network interface on the core router went down, causing a loss of external connectivity."@en ;
    noria:loggingTime "2024-04-23T14:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Interface Gi0/0/0 on cr01.par.example.com changed state to down."@en ;
    dcterms:type noria:kos/Notification/EventType/stateChange ;
    noria:alarmSeverity noria:kos/Notification/Severity/PerceivedSeverity/Critical ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckFiberLink .

noria:EventRecord_UserLoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Multiple failed login attempts detected for a corporate user, potentially indicating a security breach."@en ;
    noria:loggingTime "2024-04-23T14:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent noria:Agent_John_Doe ; # John Doe's account was targeted
    noria:logText "User 'jdoe' failed to login 5 times from IP 192.168.1.100."@en ;
    dcterms:type noria:kos/Notification/EventType/thresholdCrossing ;
    noria:alarmSeverity noria:kos/Notification/Severity/PerceivedSeverity/Warning .

noria:EventRecord_DB_Patch_Success a noria:EventRecord ;
    rdfs:label "DB Patching Success Event"@en ;
    rdfs:comment "Event confirming successful application of patches on DB Server 01, post-maintenance."@en ;
    noria:loggingTime "2024-05-01T03:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Database server db01.corp.example.com patched successfully. Service restarted."@en ;
    dcterms:type noria:kos/Notification/EventType/stateChange ;
    noria:alarmSeverity noria:kos/Notification/Severity/PerceivedSeverity/Warning .

