# --- Agents and Organizations ---
noria:Agent_IT_Ops_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations, including server and application management."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone ;
    noria:agentInstructions "Call emergency line for critical issues. Use ticketing system for standard requests."@en .

noria:Agent_Network_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Team responsible for network design, implementation, and maintenance across all data centers and offices."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email ;
    noria:agentInstructions "Open a ticket for all network-related requests. For emergencies, use the dedicated hotline."@en .

noria:Agent_App_Support_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for critical business applications, including the Corporate Web Portal."@en ;
    noria:agentWorkingHours "8:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone ;
    noria:agentInstructions "Use ticketing system for non-urgent issues. Escalation via phone for P1/P2 incidents."@en .

noria:Agent_Security_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents and threats."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email ;
    noria:agentInstructions "Report all security events immediately via the dedicated security incident platform."@en .

noria:Agent_John_Doe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, specializing in core routing and switching."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en .

noria:Agent_Jane_Smith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer and Administrator for the Corporate Web Portal."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email ;
    noria:agentWorkingHours "8:30-17:30 (Mon-Fri)"@en .

noria:CorporateUserIdentifier_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Unique corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount noria:Agent_John_Doe .

noria:CorporateUserIdentifier_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Unique corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"@en ;
    foaf:holdsAccount noria:Agent_Jane_Smith .

# --- Locations ---
noria:Site_DC_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris, hosting critical infrastructure and applications."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_Office_London a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:comment "Main office building in London, serving as a regional hub."@en ;
    noria:siteId "OFF-LDN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddressStreet "456 Baker Street" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE" ;
    noria:sitePrincipalAddressCountry "UK" .

noria:Room_ServerRoom_Paris_A1 a noria:Room ;
    rdfs:label "Server Room A1, Paris DC"@en ;
    rdfs:comment "Main server room in Paris Data Center, housing racks for compute and storage."@en ;
    bot:hasSpace noria:Site_DC_Paris .

noria:Room_NetworkRoom_Paris_B2 a noria:Room ;
    rdfs:label "Network Room B2, Paris DC"@en ;
    rdfs:comment "Dedicated network equipment room in Paris Data Center."@en ;
    bot:hasSpace noria:Site_DC_Paris .

noria:Locus_Rack_A1_R12 a noria:Locus ;
    rdfs:label "Rack A1-R12"@en ;
    rdfs:comment "Location of application servers in Rack 12, Row A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "12" ;
    bot:hasSpace noria:Room_ServerRoom_Paris_A1 .

noria:Locus_Rack_B2_R05 a noria:Locus ;
    rdfs:label "Rack B2-R05"@en ;
