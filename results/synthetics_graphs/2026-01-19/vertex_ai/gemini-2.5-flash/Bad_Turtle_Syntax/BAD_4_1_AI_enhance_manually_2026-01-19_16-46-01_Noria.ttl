# --- Operational Plans and Conditions ---
noria:OperationPlan_RestartDBService a noria:OperationPlan ;
    rdfs:label "Restart Database Service Procedure"@en ;
    rdfs:comment "Standard operating procedure to safely restart the database service on a server, including pre-checks and post-checks."@en ;
    pep:hasInput noria:ActionPreCondition_DBServiceDown ;
    pep:hasOutput noria:ActionPostCondition_DBServiceUp .

noria:OperationPlan_CheckFiberLink a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Procedure to physically inspect and test a fiber optic network link, including visual inspection and optical power measurements."@en ;
    pep:hasInput noria:ActionPreCondition_FiberLinkDown ;
    pep:hasOutput noria:ActionPostCondition_FiberLinkRestored .

noria:ActionPreCondition_DBServiceDown a noria:ActionPreCondition ;
    rdfs:label "Database Service is Down"@en ;
    rdfs:comment "Condition: Database process is not running or unresponsive, as confirmed by monitoring tools."@en .

noria:ActionPostCondition_DBServiceUp a noria:ActionPostCondition ;
    rdfs:label "Database Service is Up"@en ;
    rdfs:comment "Outcome: Database process is running, accessible, and responding to queries, confirmed by application health checks."@en .

noria:ActionPreCondition_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link is Down"@en ;
    rdfs:comment "Condition: Optical power levels are out of range or link status is reported as down by network devices."@en .

noria:ActionPostCondition_FiberLinkRestored a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored"@en ;
    rdfs:comment "Outcome: Optical power levels are nominal, link status is up, and traffic is flowing as expected."@en .

# --- Anomaly Patterns ---
noria:AnomalyPattern_HighCPU_DB a noria:AnomalyPattern ;
    rdfs:label "High CPU on Database Server Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential database performance issue or overload, characterized by sustained high CPU usage and slow query response times."@en ;
    folio:hasCause noria:EventRecord_DB_HighCPU .

noria:AnomalyPattern_Network_UplinkFailure a noria:AnomalyPattern ;
    rdfs:label "Network Uplink Failure Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a critical network connectivity issue, characterized by an uplink interface going down and associated service interruptions."@en ;
    folio:hasCause noria:EventRecord_Router_InterfaceDown .

# --- Procedure Execution Containers for actions ---
noria:ProcedureExecutionContainer_DB_Diagnosis a pep:ProcedureExecutionContainer ;
    rdfs:label "DB Outage Diagnosis Execution"@en ;
    rdfs:comment "Container for events and actions related to the diagnosis phase of the DB outage incident."@en ;
    pep:member noria:EventRecord_DB_HighCPU .

noria:ProcedureExecutionContainer_Network_Troubleshooting a pep:ProcedureExecutionContainer ;
    rdfs:label "Network Link Troubleshooting Execution"@en ;
    rdfs:comment "Container for events and actions related to troubleshooting the network uplink failure."@en ;
    pep:member noria:EventRecord_Router_InterfaceDown .

# --- Further connections to ensure density ---
# Link agents to resources they manage (inverse property)
noria:Agent_IT_Ops_Team noria:agentManagesResource noria:Resource_WebServer01, noria:Resource_DBServer01, noria:Resource_VM_AppProxy01 .
noria:Agent_Network_Team noria:agentManagesResource noria:Resource_RouterCore01, noria:Resource_SwitchAccess01, noria:NetworkLink_WS01_AS01, noria:NetworkLink_DB01_AS01, noria:NetworkLink_AS01_CR01, noria:NetworkLink_CR01_ExtRtr01, noria:Resource_RouterExternal .

# Link applications to their administration/support teams (inverse property)
noria:Agent_App_Support_Team noria:applicationModuleRelatedParty noria:ApplicationModule_CWP_Prod, noria:ApplicationModule_CWP_Dev .
noria:Agent_IT_Ops_Team noria:applicationModuleRelatedParty noria:ApplicationModule_CWP_Prod . # Hotline group

# Link Operation Plans to actions (CorrectiveMaintenanceAction, ChangeAction)
# The schema defines noria:actionCorrelatedOperationPlan with domain noria:CorrectiveMaintenanceAction, noria:ChangeAction
# Let's create some dummy actions to link.
# These are not explicitly defined as classes in the provided schema snippet, but are implied by the property domain.
# I will define them as generic pep:Action for now, as noria:CorrectiveMaintenanceAction and noria:ChangeAction are not in the provided classes.
# However, the schema states: "PEP: a TroubleTicket is a context for (potentially) many *CorrectiveMaintenanceAction* to occur"
# and "PEP: a ChangeRequest is a context for (potentially) many *ChangeAction* to occur"
# This implies that CorrectiveMaintenanceAction and ChangeAction are subclasses of pep:Action.
# Let's define them as such to be compliant.

noria:CorrectiveMaintenanceAction a owl:Class ;
    rdfs:subClassOf pep:Action ;
    rdfs:label "Corrective Maintenance Action"@en ;
    rdfs:comment "An action taken to correct an identified fault or incident."@en .

noria:ChangeAction a owl:Class ;
    rdfs:subClassOf pep:Action ;
    rdfs:label "Change Action"@en ;
    rdfs:comment "An action taken as part of a planned change request."@en .

noria:Action_RestartDB a noria:CorrectiveMaintenanceAction ;
    rdfs:label "Restart DB Service"@en ;
    rdfs:comment "Action to restart the database service on DBServer01."@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_RestartDBService ;
    dcterms:isPartOf noria:TroubleTicket_DB_Outage . # This action is part of the TT resolution

noria:Action_InspectFiber a noria:CorrectiveMaintenanceAction ;
    rdfs:label "Inspect Fiber Link"@en ;
    rdfs:comment "Action to physically inspect the fiber optic link for Core Router 01."@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_CheckFiberLink ;
    dcterms:isPartOf noria:TroubleTicket_Network_Link_Down .

noria:Action_ApplyDBPatch a noria:ChangeAction ;
    rdfs:label "Apply DB Patch"@en ;
    rdfs:comment "Action to apply the scheduled patch to DBServer01."@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_RestartDBService ; # Assuming patch requires a restart
    dcterms:isPartOf noria:ChangeRequest_DB_Patch .

# Link EventRecords to actions (prov:wasGeneratedBy)
noria:EventRecord_DB_Patch_Success prov:wasGeneratedBy noria:Action_ApplyDBPatch .

# Ensure all entities are connected.
# All top-level entities (Agents, Sites, ProductModels, Resources, Applications, Services, TroubleTickets, ChangeRequests, EventRecords, Notes, Attachments, OperationPlans, Conditions, AnomalyPatterns)
# have been created and linked to at least one other entity, often multiple.
# The graph is dense and reflects a plausible IT scenario.
