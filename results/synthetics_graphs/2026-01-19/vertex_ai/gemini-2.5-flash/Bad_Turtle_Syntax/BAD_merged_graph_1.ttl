# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable, detected by monitoring."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%"@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on router-core01 went down, impacting connectivity."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
    prov:wasAttributedTo noria:Resource_RouterCore01 .

noria:EventRecord_UserLoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on the corporate web server, potentially a security concern."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_SIEMSystem ;
    noria:logOriginatingAgent noria:CUid_JohnDoe ;
    noria:logText "Authentication failed for user 'jdoe' from IP 192.168.1.100"@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_FirewallUpgradeStart a noria:EventRecord ;
    rdfs:label "Firewall Upgrade Start Event"@en ;
    rdfs:comment "Event marking the initiation of the firewall software upgrade procedure."@en ;
    noria:loggingTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_FirewallEdge01 ;
    noria:logOriginatingManagementSystem noria:Application_ChangeManagementSystem ;
    noria:logText "Firewall PA-5200 software upgrade initiated by automated script."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_CableReplacement a noria:EventRecord ;
    rdfs:label "Cable Replacement Action"@en ;
    rdfs:comment "Record of John Doe replacing a faulty Ethernet cable on the core router."@en ;
    noria:loggingTime "2024-04-20T10:08:00Z"^^xsd:dateTime ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logText "Replaced faulty Ethernet cable on Gi0/0/1 of router-core01. Link restored."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_MaintenanceFreeze a noria:EventRecord ;
    rdfs:label "Maintenance Freeze Event"@en ;
    rdfs:comment "Event indicating a trouble ticket was put on hold due to a scheduled maintenance window."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application_ChangeManagementSystem ;
    noria:logText "Trouble Ticket TT-20240420-002 put on freeze for external maintenance window."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

