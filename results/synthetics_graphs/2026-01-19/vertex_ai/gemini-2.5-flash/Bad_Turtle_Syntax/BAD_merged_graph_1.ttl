foaf:Agent1 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:comment "Team responsible for 24/7 network monitoring and initial incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_0> ;
    noria:agentInstructions "Contact via dedicated hotline for critical incidents. Use ticketing system for non-urgent issues."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team responsible for server infrastructure management."@en ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> ;
    noria:agentInstructions "Submit a ticket via the IT Service Portal. For emergencies, call the on-call engineer."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Team supporting critical business application 'Enterprise Portal'."@en ;
    noria:agentWorkingHours "8:30 AM - 6:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat_extra_node_0> ;
    noria:agentInstructions "Use internal chat for quick queries, ticketing system for issues."@en .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> ;
    noria:agentInstructions "All requests must go through the ticketing system."@en .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual engineer from NOC Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_0> .

foaf:Agent6 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead engineer for Server Administration Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> .

org:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Main department for IT infrastructure and application operations."@en ;
    org:hasMember foaf:Agent1, foaf:Agent2, foaf:Agent3, foaf:Agent4 .

