    noria:logOriginatingManagedObject noria:Resource_CoreRouter_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_0 ;
    noria:logOriginatingAgent foaf:Agent5 ;
    
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_0> .

noria:EventRecord_AppS01_CPUHigh a noria:EventRecord ;
