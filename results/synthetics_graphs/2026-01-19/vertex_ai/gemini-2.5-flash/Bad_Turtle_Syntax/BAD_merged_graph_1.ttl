# =============================================================================
# Agents and Organizations
# =============================================================================

noria:Agent_WebOpsTeam a foaf:Agent ;
    rdfs:label "WebOps Team"@en ;
    rdfs:comment "Team responsible for the operation and maintenance of web applications and their underlying infrastructure."@en ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "For critical issues, use the ticketing system and then call the on-call number."@en .

noria:Agent_DBATeam a foaf:Agent ;
    rdfs:label "DBA Team"@en ;
    rdfs:comment "Team responsible for database administration and support."@en ;
    noria:agentWorkingHours "8:30 AM - 5:30 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone_extra_node_1> ;
    noria:agentInstructions "Open a P1_extra_node_1 ticket for database outages, then contact the team lead."@en .

noria:Agent_NetworkTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone_extra_node_1> ;
    noria:agentInstructions "All network incidents must be reported via the dedicated network incident portal."@en .

noria:Agent_SecurityTeam_extra_node_1 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 Operations"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Report all suspected security breaches immediately."@en .

noria:Agent_AliceSmith a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Engineer in the WebOps Team."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_1> .

noria:Agent_BobJohnson a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Database Administrator in the DBA Team."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone_extra_node_1> .

noria:OrgUnit_ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department of the company."@en ;
    org:hasMember noria:Agent_AliceSmith, noria:Agent_BobJohnson ;
    org:unitMember noria:Agent_WebOpsTeam, noria:Agent_DBATeam, noria:Agent_NetworkTeam, noria:Agent_SecurityTeam_extra_node_1 .

noria:CorporateUserIdentifier_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "ASmith_CorpID"@en ;
    rdfs:comment "Corporate User ID for Alice Smith."@en ;
    foaf:accountName "asmith"@en ;
    foaf:holdsAccount noria:Agent_AliceSmith .

noria:CorporateUserIdentifier_BJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "BJohnson_CorpID"@en ;
    rdfs:comment "Corporate User ID for Bob Johnson."@en ;
    foaf:accountName "bjohnson"@en ;
    foaf:holdsAccount noria:Agent_BobJohnson .

# =============================================================================
# Locations
# =============================================================================

noria:Site_DataCenterA a bot:Site ;
    rdfs:label "Primary Data Center A"@en ;
    rdfs:comment "Main data center facility for corporate services."@en ;
    noria:siteId "DC-A-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en ;
    noria:sitePrincipalAddressStreet "Tech Avenue" .

noria:Room_ServerRoom1 a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "Main server room within Data Center A."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackB2 ;
    seas:subSystemOf noria:Site_DataCenterA .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Rack A1."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    seas:subSystemOf noria:Room_ServerRoom1 .

noria:Locus_RackB2 a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:comment "Location of database servers in Rack B2."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "2"@en ;
    seas:subSystemOf noria:Room_ServerRoom1 .

