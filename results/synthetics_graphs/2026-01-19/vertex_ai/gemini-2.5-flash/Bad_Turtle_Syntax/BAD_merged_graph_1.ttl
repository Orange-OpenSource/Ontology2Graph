    rdfs:comment "Enterprise-grade network switch."@en ;
    noria:productManufacturedBy noria:Org_Cisco_extra_node_1 .

noria:ProductModel_JuniperSRX3400 a noria:ProductModel ;
    rdfs:label "Juniper SRX3400"@en ;
    rdfs:comment "High-end security gateway and firewall."@en ;
    noria:productManufacturedBy noria:Org_Juniper .

noria:Org_Dell_extra_node_1 a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

noria:Org_Cisco_extra_node_1 a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:Org_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking and cybersecurity products."@en .

