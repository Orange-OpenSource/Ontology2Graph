noria:Resource_CoreRouter_01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate backbone network."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "cr01.dc1.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco_ASR9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "CISCO-CR01-SN12345" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_DC1_B_N1 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_AppServer_01 a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting the Enterprise Portal application."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "app01.dc1.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "DELL-APP01-SN67890" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_DC1_A_R1 ;
    noria:resourceManagementIPAddress "10.0.1.10" .

noria:Resource_DBServer_01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Primary database server for critical applications."@en ;
    noria:resourceManagedBy foaf:Agent4 ;
    noria:resourceHostName "db01.dc1.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "DELL-DB01-SN11223" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-20T14:35:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_DC1_A_R1 ;
    noria:resourceManagementIPAddress "10.0.1.11" .

noria:Resource_VirtualMachine_Web01 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting web services for Enterprise Portal."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "web01.dc1.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMware_ESXi ;
     # The hypervisor model, not the VM itself

    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_AppServer_01 ;
     # Assuming AppServer_01 is the hypervisor host

    noria:resourceManagementIPAddress "10.0.1.20" .

noria:Resource_MonitoringServer_01 a noria:Resource ;
    rdfs:label "Monitoring Server 01"@en ;
    rdfs:comment "Server running network and application monitoring tools."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "mon01.dc1.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "DELL-MON01-SN44556" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_DC1_A_R1 ;
    noria:resourceManagementIPAddress "10.0.1.50" .

