# =============================================================================
# Services
# =============================================================================

noria:Service_CorporateInternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
     # Assuming this KOS concept exists

    seas:subSystemOf noria:Application_EnterprisePortal, noria:Application_MonitoringSystem ;
     # Services can group applications

    noria:resourceManagedBy foaf:Agent1 .

noria:Service_EnterpriseDataPlatform a noria:Service ;
    rdfs:label "Enterprise Data Platform Service"@en ;
    rdfs:comment "Centralized data storage and processing service for business intelligence."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
     # Assuming this KOS concept exists

    seas:subSystemOf noria:Application_EnterprisePortal ;
    noria:resourceManagedBy foaf:Agent4 .

# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_RouterFailover a noria:OperationPlan ;
    rdfs:label "Core Router Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for initiating a failover on core routers."@en ;
    noria:operationPlanPreCondition noria:PreCondition_HighTrafficLoss ;
    noria:operationPlanPostCondition noria:PostCondition_TrafficRestored .

noria:PreCondition_HighTrafficLoss a noria:ActionPreCondition ;
    rdfs:label "High Traffic Loss Detected"@en ;
    rdfs:comment "Condition: Network monitoring system reports >50% packet loss on primary uplink."@en .

noria:PostCondition_TrafficRestored a noria:ActionPostCondition ;
    rdfs:label "Traffic Restored to Normal"@en ;
    rdfs:comment "Outcome: Packet loss returns to <5% and service is accessible."@en .

noria:AnomalyPattern_BGPFlap a noria:AnomalyPattern ;
    rdfs:label "BGP Flapping Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating unstable BGP routing sessions, often leading to intermittent connectivity issues."@en ;
    skos:example "Repeated BGP UP/DOWN events on a core router interface within a short period."@en .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_CR01_LinkDown a noria:EventRecord ;
    rdfs:label "Core Router 01 Link Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Core Router 01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent5 ;
     # Assuming John Doe was monitoring

    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_AppS01_CPUHigh a noria:EventRecord ;
    rdfs:label "Application Server 01 High CPU Alert"@en ;
    rdfs:comment "Alert from monitoring system about high CPU utilization on Application Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_AppServer_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CPU utilization on app01.dc1.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_WebVM01_ConfigChange a noria:EventRecord ;
    rdfs:label "Web Server VM 01 Configuration Change"@en ;
    rdfs:comment "Log entry detailing a configuration change applied to Web Server VM 01."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_VirtualMachine_Web01 ;
    noria:logOriginatingAgent foaf:Agent6 ;
     # Jane Smith applied the change

    noria:logText "Applied security patch to Apache configuration."@en .

noria:EventRecord_DB01_DiskFull a noria:EventRecord ;
    rdfs:label "Database Server 01 Disk Full Alert"@en ;
    rdfs:comment "Alert indicating that a disk on the database server is nearly full."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer_01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Disk /dev/sdb on db01.dc1.example.com is 95% full."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TroubleTicket_001 a noria:TroubleTicket ;
    rdfs:label "Corporate Internet Access Outage"@en ;
    rdfs:comment "Complete loss of internet access affecting all corporate users."@en ;
    dcterms:created "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-2024-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-2024-001" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
