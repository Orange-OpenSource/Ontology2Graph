noria:ChangeRequest_001 noria:documentStatusHistory noria:EventRecord_WebVM01_ConfigChange . # Example of a related event, not necessarily a status change

# Link more applications to services
noria:Service_CorporateInternetAccess seas:subSystemOf noria:Application_MonitoringSystem .

# Link more application modules to services
noria:Service_EnterpriseDataPlatform seas:subSystemOf noria:ApplicationModule_EnterprisePortal_Prod .

