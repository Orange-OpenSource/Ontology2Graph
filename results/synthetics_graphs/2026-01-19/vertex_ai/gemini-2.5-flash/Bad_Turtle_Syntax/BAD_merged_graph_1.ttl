# =============================================================================
# Operations, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_RouterRestart a noria:OperationPlan ;
    rdfs:label "Router Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a core network router."@en ;
    skos:example "Steps include: notify stakeholders, save configuration, execute restart command, verify connectivity."@en .

noria:ActionPreCondition_RouterUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Router Unresponsive Pre-Condition"@en ;
    rdfs:comment "Condition: Router is not responding to ping or management access."@en .

noria:ActionPostCondition_RouterOnline a noria:ActionPostCondition ;
    rdfs:label "Router Online Post-Condition"@en ;
    rdfs:comment "Condition: Router is online, all interfaces are up, and routing protocols converged."@en .

noria:OperationPlan_RouterRestart noria:operationPlanPreCondition noria:ActionPreCondition_RouterUnresponsive ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterOnline .

noria:AnomalyPattern_HighCPU a noria:AnomalyPattern ;
    rdfs:label "High CPU Utilization Anomaly"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization on a critical resource, potentially leading to performance degradation or outage."@en ;
    folio:hasCause "Software bug or misconfiguration"@en .

noria:OperationPlan_SecurityResponse a noria:OperationPlan ;
    rdfs:label "Security Incident Response Plan"@en ;
    rdfs:comment "Procedure for responding to detected security incidents, including containment, eradication, and recovery."@en .

noria:ActionPreCondition_IntrusionDetected a noria:ActionPreCondition ;
    rdfs:label "Intrusion Detected Pre-Condition"@en ;
    rdfs:comment "Condition: A security system has detected a confirmed intrusion or attack attempt."@en .

noria:ActionPostCondition_ThreatContained a noria:ActionPostCondition ;
    rdfs:label "Threat Contained Post-Condition"@en ;
    rdfs:comment "Condition: The security threat has been contained, and affected systems are isolated or patched."@en .

noria:OperationPlan_SecurityResponse noria:operationPlanPreCondition noria:ActionPreCondition_IntrusionDetected ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ThreatContained .

# =============================================================================
# Procedure Executions and Document Attachments
# =============================================================================

noria:CorrectiveAction_RouterInterfaceUp a pep:ProcedureExecution ;
    rdfs:label "Bring Router Interface Up Action"@en ;
    rdfs:comment "Action taken to bring the router interface back up."@en ;
    pep:madeBy foaf:Agent_JohnDoe ;
    pep:hasSimpleResult "Interface GigabitEthernet0/0/0 is now up."@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterRestart ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime .

noria:EventRecord_InterfaceDown noria:alarmMitigatedBy noria:CorrectiveAction_RouterInterfaceUp .
noria:TroubleTicket_WebsiteSlowness dcterms:relation noria:AnomalyPattern_HighCPU .
noria:TroubleTicket_SecurityIncident dcterms:relation noria:OperationPlan_SecurityResponse .
noria:TroubleTicketNote_SecurityAnalysis noria:troubleTicketNoteCorrelatedExecution noria:ChangeRequest_FirewallRuleUpdate .

