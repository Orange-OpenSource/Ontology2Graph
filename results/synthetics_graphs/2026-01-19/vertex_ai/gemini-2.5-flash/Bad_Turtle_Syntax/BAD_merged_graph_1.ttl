# Applications
# =============================================================================

noria:Application_EnterprisePortal a noria:Application ;
    rdfs:label "Enterprise Portal"@en ;
    rdfs:comment "Web-based portal for internal corporate services."@en ;
    noria:applicationModelIdentifier "EP-V2.0" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "EP" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Employee Self-Service"@en ;
    noria:resourceManagedBy foaf:Agent3 ;
    noria:resourceForApplication noria:Resource_AppServer_01, noria:Resource_DBServer_01, noria:Resource_VirtualMachine_Web01 .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "System for collecting and analyzing logs and metrics from IT infrastructure."@en ;
    noria:applicationModelIdentifier "CMS-V3.1" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "CMS" ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Performance and Event Management"@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceForApplication noria:Resource_MonitoringServer_01 .

