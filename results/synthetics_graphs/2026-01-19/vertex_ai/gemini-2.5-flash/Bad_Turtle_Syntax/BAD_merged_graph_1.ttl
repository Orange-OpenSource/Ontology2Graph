    noria:changeRequestActorParty foaf:Agent_DNSAdminTeam ;
    noria:changeRequestIsRegulated false ;
    noria:documentExternalId "CR-20240425-002" .

# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_DNSFailover a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over DNS services to a secondary server in case of primary failure."@en ;
    skos:example "Steps include verifying secondary server health, updating load balancer, and monitoring traffic after failover."@en .

noria:ActionPreCondition_DNSPrimaryDown a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Down Pre-condition"@en ;
    rdfs:comment "Condition: Primary DNS server is unresponsive or reporting critical errors, triggering failover procedure."@en .

noria:ActionPostCondition_DNSServiceRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Post-condition"@en ;
    rdfs:comment "Outcome: DNS resolution is functional, and secondary server is handling queries, confirming successful failover."@en .

noria:OperationPlan_DNSFailover noria:operationPlanPreCondition noria:ActionPreCondition_DNSPrimaryDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSServiceRestored .

noria:AnomalyPattern_HighDNSErrorRate a noria:AnomalyPattern ;
    rdfs:label "High DNS Error Rate Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential DNS service degradation, characterized by a sudden increase in DNS query failures and timeouts, often preceding an outage."@en ;
    folio:hasCause noria:TroubleTicket_DNSOutage . # Linking an anomaly pattern to a past trouble ticket cause.

noria:OperationPlan_FirewallUpgrade a noria:OperationPlan ;
    rdfs:label "Firewall Software Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for performing a software upgrade on Palo Alto firewalls, including pre-checks and post-checks."@en ;
    pep:usedProcedure noria:ChangeRequest_FirewallUpgrade . # A change request uses a procedure.

noria:ActionPreCondition_FirewallHealthCheck a noria:ActionPreCondition ;
    rdfs:label "Firewall Health Check Pre-condition"@en ;
    rdfs:comment "Condition: Firewall health metrics (CPU, memory, sessions) are within normal operating parameters before upgrade."@en .

noria:ActionPostCondition_FirewallUpgradeSuccess a noria:ActionPostCondition ;
    rdfs:label "Firewall Upgrade Success Post-condition"@en ;
    rdfs:comment "Outcome: Firewall is operational on new software version, traffic is flowing, and all services are functional."@en .

noria:OperationPlan_FirewallUpgrade noria:operationPlanPreCondition noria:ActionPreCondition_FirewallHealthCheck ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FirewallUpgradeSuccess .



