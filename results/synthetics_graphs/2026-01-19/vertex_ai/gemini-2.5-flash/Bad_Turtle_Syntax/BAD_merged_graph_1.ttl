    noria:troubleTicketRelatedService noria:Service_CorpDNSResolution ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketCause "Network connectivity issue to DNS server, likely a physical link failure."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring"@en ;
    noria:documentExternalId "TT-20240420-001" ;
    noria:documentHRef "https://itsm.example.com/tickets/TT-20240420-001" ;
    noria:documentStatusHistory noria:EventRecord_DNSOutageLog .

noria:TroubleTicket_RouterInterfaceDown a noria:TroubleTicket ;
    rdfs:label "Router Interface Down Incident"@en, "Incident d'interface routeur hors service"@fr ;
    rdfs:comment "Major incident: Core router interface went down, causing partial network disruption to internet access."@en ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <https://w3id.org/noria/kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <https://w3id.org/noria/kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_InterfaceDown ;
    noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkOpsTeam, foaf:Agent_JohnDoe ;
    noria:troubleTicketRelatedService noria:Service_CorpInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_RouterCore01 ;
    noria:troubleTicketCause "Physical cable fault on GigabitEthernet0/0/1, replaced by technician."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:documentExternalId "TT-20240420-002" ;
    noria:documentStatusHistory noria:EventRecord_InterfaceDown, noria:EventRecord_CableReplacement ;
    noria:troubleTicketFreezeItem noria:EventRecord_MaintenanceFreeze .

noria:TroubleTicketNote_RouterFix a noria:TroubleTicketNote ;
    rdfs:label "Router Interface Fix Note"@en ;
    rdfs:comment "Engineer John Doe replaced the faulty cable on RouterCore01 Gi0/0/1. Interface is now up and service restored."@en ;
    dcterms:isPartOf noria:TroubleTicket_RouterInterfaceDown ;
    dcterms:created "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JohnDoe ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer_RouterFix .

noria:ProcedureExecutionContainer_RouterFix a pep:ProcedureExecutionContainer ;
    rdfs:label "Router Fix Execution Container"@en ;
    rdfs:comment "Container for actions taken to fix the router interface, including cable replacement."@en ;
    dcterms:member noria:EventRecord_CableReplacement .

