noria:NetworkInterface_WS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "web01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface 0 on Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up_extra_node_1> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary network interface for web traffic."@en ;
    noria:networkInterfaceConnects noria:NetworkLink_WS01_LB01 .

noria:NetworkInterface_LB01_Eth1 a noria:NetworkInterface ;
    rdfs:label "lb01.corp.example.com:eth1"@en ;
    rdfs:comment "Ethernet interface 1 on Load Balancer 01, connected to web servers."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up_extra_node_1> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Interface facing web servers."@en ;
    noria:networkInterfaceConnects noria:NetworkLink_WS01_LB01 .

noria:NetworkInterface_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "db01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface 0 on DB Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up_extra_node_1> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up_extra_node_1> ;
    noria:networkInterfaceType "physical" ;
