# =============================================================================
# Network Interfaces and Links
# =============================================================================

noria:NetworkInterface_DNS01_Eth0_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server, connected to the internal network."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01_extra_node_3 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface_RouterCore01_Gi0_0_1_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Uplink interface for RouterCore01, connecting to the ISP."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01_extra_node_3 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterCore01_Gi0_0_2_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting RouterCore01 to FirewallEdge01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01_extra_node_3 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 .

noria:NetworkInterface_FirewallEdge01_Eth1_extra_node_3 a noria:NetworkInterface ;
    rdfs:label "FirewallEdge01 Ethernet 1"@en ;
    rdfs:comment "Interface connecting FirewallEdge01 to RouterCore01."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallEdge01_extra_node_3 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkLink_CoreRouter_Firewall_extra_node_3 a noria:NetworkLink ;
    rdfs:label "Link Core Router to Firewall"@en ;
    rdfs:comment "Direct 10 Gigabit Ethernet link between Core Router 01 and Edge Firewall 01."@en ;
    noria:networkLinkId "NL-CR-FW-001" ;
    noria:networkLinkType "Ethernet 10G"@en ;
    noria:networkLinkInstallationDate "2021-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01_extra_node_3 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_FirewallEdge01_extra_node_3 .

noria:NetworkInterface_RouterCore01_Gi0_0_2_extra_node_3 noria:networkInterfaceConnects noria:NetworkLink_CoreRouter_Firewall_extra_node_3 .
noria:NetworkInterface_FirewallEdge01_Eth1_extra_node_3 noria:networkInterfaceConnects noria:NetworkLink_CoreRouter_Firewall_extra_node_3 .

