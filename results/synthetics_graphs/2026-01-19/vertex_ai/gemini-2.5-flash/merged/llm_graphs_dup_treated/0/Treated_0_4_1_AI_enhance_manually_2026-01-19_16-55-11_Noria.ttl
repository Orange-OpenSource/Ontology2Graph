    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_3 ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DEL-R740-001" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U23_extra_node_3 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

noria:Resource_DNS02_extra_node_3 a noria:Resource ;
    rdfs:label "Corporate DNS Server 02"@en, "Serveur DNS d'entreprise 02"@fr ;
    rdfs:comment "Secondary DNS server for corporate network, providing redundancy for name resolution."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam_extra_node_3 ;
