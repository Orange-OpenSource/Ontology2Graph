noria:Application_CorpIntranet_extra_node_3 a noria:Application ;
    rdfs:label "Corporate Intranet"@en, "Intranet d'entreprise"@fr ;
    rdfs:comment "Internal web application for corporate communications and resources, essential for daily operations."@en ;
    noria:applicationModelIdentifier "CORP-INTRA" ;
    noria:applicationShortIdentifier "CI" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/BusinessApplication_extra_node_3> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Internal_extra_node_3 Communications"@en ;
    noria:applicationFunctionalSubDomain "Employee Portal"@en ;
    noria:elementManagedBy foaf:Agent_AppDevTeam_extra_node_3 .

noria:ApplicationModule_CorpIntranet_Prod_extra_node_3 a noria:ApplicationModule ;
    rdfs:label "Corporate Intranet Production Module"@en, "Module de Production Intranet d'entreprise"@fr ;
    rdfs:comment "Production instance of the Corporate Intranet application, serving live user traffic."@en ;
