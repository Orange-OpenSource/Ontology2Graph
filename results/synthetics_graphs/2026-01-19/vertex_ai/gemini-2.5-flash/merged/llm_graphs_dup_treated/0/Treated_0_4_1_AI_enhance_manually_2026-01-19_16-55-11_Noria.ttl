    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_3 ;
    noria:resourceLogisticId "LOG-DNS-002" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DEL-R740-002" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction_extra_node_3> ;
    noria:resourceInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2_U10_extra_node_3 ;
    noria:resourceManagementIPAddress "10.0.0.11" ;
    noria:clusterController noria:Resource_DNS01_extra_node_3 .
noria:Resource_RouterCore01_extra_node_3 a noria:Resource ;
    rdfs:label "Core Router 01"@en, "Routeur Cœur 01"@fr ;
    rdfs:comment "Main core router for the corporate network, handling high-volume traffic routing."@en ;
