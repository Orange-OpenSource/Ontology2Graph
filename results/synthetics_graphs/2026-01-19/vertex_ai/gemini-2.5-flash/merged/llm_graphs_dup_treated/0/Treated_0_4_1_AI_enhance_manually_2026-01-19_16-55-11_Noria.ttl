# =============================================================================
# Organizational Entities (Agents, Teams, Users)
# =============================================================================

foaf:Agent_DNSAdminTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for corporate DNS server management and operations."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_3> ;
    noria:agentInstructions "Use the ticketing system for all requests. For critical issues, call the on-call number."@en .

foaf:Agent_NetworkOpsTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for network infrastructure monitoring and maintenance."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone_extra_node_3> ;
    noria:agentInstructions "For network incidents, open a P1_extra_node_3 ticket and call the NOC immediately."@en .

foaf:Agent_AppDevTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "Application Development Team"@en, "Équipe Développement Application"@fr ;
    rdfs:comment "Team responsible for developing and maintaining the Corporate Intranet application."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Chat_extra_node_3> ;
    noria:agentInstructions "Contact via internal chat for non-urgent issues. Use ticketing for bugs."@en .

foaf:Agent_SecurityTeam_extra_node_3 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre des Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SIEMAlert_extra_node_3> ;
    noria:agentInstructions "All security alerts are automatically routed to the SIEM. Manual contact only for confirmed critical breaches."@en .

foaf:Agent_JohnDoe_extra_node_3 a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual member of the Network Operations Team, often involved in on-site interventions."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email_extra_node_3> .

org:Dept_ITOperations_extra_node_3 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en, "Département Opérations IT"@fr ;
    rdfs:comment "Main department overseeing all IT infrastructure and application operations."@en ;
    org:hasMember foaf:Agent_DNSAdminTeam_extra_node_3, foaf:Agent_NetworkOpsTeam_extra_node_3, foaf:Agent_JohnDoe_extra_node_3 .

org:Dept_AppDevelopment_extra_node_3 a org:OrganizationalUnit ;
    rdfs:label "Application Development Department"@en, "Département Développement Applications"@fr ;
    rdfs:comment "Department responsible for software development and maintenance."@en ;
    org:hasMember foaf:Agent_AppDevTeam_extra_node_3 .

noria:CUid_JohnDoe_extra_node_3 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe, used for system access."@en ;
    foaf:accountName "jdoe"@en ;
    observable:accountLogin "jdoe"@en ;
    observable:accountIdentifier "jdoe-corp-id-12345"@en .

foaf:Agent_JohnDoe_extra_node_3 foaf:holdsAccount noria:CUid_JohnDoe_extra_node_3 .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740_extra_node_3 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model commonly used for enterprise applications and virtualization, known for its reliability."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us_extra_node_3> .

noria:ProductModel_CiscoNexus9K_extra_node_3 a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch series from Cisco, ideal for core network infrastructure."@en ;
    noria:productManufacturedBy <https://www.cisco.com_extra_node_3> .

noria:ProductModel_PaloAltoFW_extra_node_3 a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5200 Series"@en ;
    rdfs:comment "Next-generation firewall for enterprise security, offering advanced threat prevention."@en ;
    noria:productManufacturedBy <https://www.paloaltonetworks.com_extra_node_3> .

# =============================================================================
# Location Information (Sites, Rooms, Loci)
# =============================================================================

bot:Site_DC_Paris_extra_node_3 a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center located in Paris, hosting critical IT infrastructure."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA_extra_node_3 a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Paris Data Center, housing racks of servers and network equipment."@en ;
    bot:containsZone noria:Locus_RackA1_U23_extra_node_3, noria:Locus_RackA2_U10_extra_node_3 .

bot:Site_DC_Paris_extra_node_3 bot:containsZone noria:Room_ServerRoomA_extra_node_3 .

noria:Locus_RackA1_U23_extra_node_3 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location within Server Room A for a resource, unit 23 in rack A1."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "23"@en ;
    bot:hasSpace noria:Room_ServerRoomA_extra_node_3 .

noria:Locus_RackA2_U10_extra_node_3 a noria:Locus ;
    rdfs:label "Rack A2, Unit 10"@en ;
    rdfs:comment "Specific location within Server Room A for a resource, unit 10 in rack A2."@en ;
    noria:locusLine "A2"@en ;
    noria:locusRow "10"@en ;
    bot:hasSpace noria:Room_ServerRoomA_extra_node_3 .

