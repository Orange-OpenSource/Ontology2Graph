    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false .

noria:Resource_WebSrv01_extra_node_3 noria:resourceForApplication noria:Application_CorpIntranet_extra_node_3 .

noria:Application_MonitoringSystem_extra_node_3 a noria:Application ;
    rdfs:label "Network Monitoring System"@en, "Système de Surveillance Réseau"@fr ;
    rdfs:comment "Application responsible for monitoring network devices and services, generating alerts."@en ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/Infrastructure> ;
    noria:elementManagedBy foaf:Agent_NetworkOpsTeam_extra_node_3 .

noria:Application_SIEMSystem_extra_node_3 a noria:Application ;
    rdfs:label "Security Information and Event Management System"@en, "Système de Gestion des Informations et Événements de Sécurité"@fr ;
