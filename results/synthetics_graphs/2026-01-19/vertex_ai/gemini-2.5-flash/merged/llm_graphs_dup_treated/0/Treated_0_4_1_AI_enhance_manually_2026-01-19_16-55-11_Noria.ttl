    noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer_RouterFix_extra_node_3 .

noria:ProcedureExecutionContainer_RouterFix_extra_node_3 a pep:ProcedureExecutionContainer ;
    rdfs:label "Router Fix Execution Container"@en ;
