    noria:troubleTicketRelatedService noria:Service_CorpInternetAccess_extra_node_3 ;
    noria:troubleTicketRelatedResource noria:Resource_RouterCore01_extra_node_3 ;
    noria:troubleTicketCause "Physical cable fault on GigabitEthernet0/0/1, replaced by technician."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
