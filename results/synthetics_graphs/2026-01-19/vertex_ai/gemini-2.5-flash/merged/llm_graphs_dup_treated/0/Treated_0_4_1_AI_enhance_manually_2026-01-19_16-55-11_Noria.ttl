    noria:applicationModuleAdministrationLeader foaf:Agent_AppDevTeam_extra_node_3 ;
    
    noria:applicationModuleSupportTeam foaf:Agent_AppDevTeam_extra_node_3 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold_extra_node_3> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:ApplicationModule_CorpIntranet_Dev_extra_node_3 a noria:ApplicationModule ;
    rdfs:label "Corporate Intranet Development Module"@en, "Module de Développement Intranet d'entreprise"@fr ;
    rdfs:comment "Development instance of the Corporate Intranet application, used for testing new features."@en ;
