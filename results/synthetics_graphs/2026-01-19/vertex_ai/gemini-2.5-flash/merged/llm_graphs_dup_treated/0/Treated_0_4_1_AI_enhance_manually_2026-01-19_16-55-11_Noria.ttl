noria:TroubleTicket_DNSOutage_extra_node_3 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident de panne du serveur DNS"@fr ;
    rdfs:comment "Critical incident: Corporate DNS server is unreachable, impacting all services relying on name resolution."@en ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Critical_extra_node_3> ;
    noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure_extra_node_3> ;
    noria:troubleTicketPriority <https://w3id.org/noria/kos/TroubleTicket/priority/P1_extra_node_3> ;
    noria:troubleTicketOrigin <https://w3id.org/noria/kos/TroubleTicket/origin/Supervision_extra_node_3> ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog_extra_node_3 ;
    noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status/InProgress_extra_node_3> ;
    noria:troubleTicketRelatedParty foaf:Agent_DNSAdminTeam_extra_node_3, foaf:Agent_NetworkOpsTeam_extra_node_3 ;
    noria:troubleTicketRelatedService noria:Service_CorpDNSResolution_extra_node_3 ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01_extra_node_3 ;
    noria:troubleTicketCause "Network connectivity issue to DNS server, likely a physical link failure."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring"@en ;
    noria:documentExternalId "TT-20240420-001" ;
    noria:documentHRef "https://itsm.example.com/tickets/TT-20240420-001" ;
    noria:documentStatusHistory noria:EventRecord_DNSOutageLog_extra_node_3 .

noria:TroubleTicket_RouterInterfaceDown_extra_node_3 a noria:TroubleTicket ;
    rdfs:label "Router Interface Down Incident"@en, "Incident d'interface routeur hors service"@fr ;
    rdfs:comment "Major incident: Core router interface went down, causing partial network disruption to internet access."@en ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Major_extra_node_3> ;
