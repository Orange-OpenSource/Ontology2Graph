    rdfs:comment "Core infrastructure service providing DNS resolution for all corporate systems, critical for network functionality."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/InfrastructureService_extra_node_3> ;
    noria:elementManagedBy foaf:Agent_DNSAdminTeam_extra_node_3 .

