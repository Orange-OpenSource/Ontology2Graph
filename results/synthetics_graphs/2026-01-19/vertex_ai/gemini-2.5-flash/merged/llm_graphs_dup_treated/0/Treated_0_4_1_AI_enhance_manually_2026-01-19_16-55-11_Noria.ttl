    noria:locatedAtLocus noria:Locus_RackA1_U23_extra_node_3 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_FirewallEdge01_extra_node_3 a noria:Resource ;
    rdfs:label "Edge Firewall 01"@en, "Pare-feu de Bordure 01"@fr ;
