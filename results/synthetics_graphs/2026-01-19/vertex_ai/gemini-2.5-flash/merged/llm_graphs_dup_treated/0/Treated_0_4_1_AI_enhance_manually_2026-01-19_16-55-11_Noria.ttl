noria:Resource_DNS01_extra_node_3 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS d'entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, located in Paris DC, providing critical name resolution."@en ;
