    noria:troubleTicketFreezeItem noria:EventRecord_MaintenanceFreeze_extra_node_3 .

noria:TroubleTicketNote_RouterFix_extra_node_3 a noria:TroubleTicketNote ;
    rdfs:label "Router Interface Fix Note"@en ;
    rdfs:comment "Engineer John Doe replaced the faulty cable on RouterCore01 Gi0/0/1. Interface is now up and service restored."@en ;
