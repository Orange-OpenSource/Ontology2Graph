# =============================================================================

noria:NetworkInterface_R01_Eth0 a noria:NetworkInterface ;
    rdfs:label "router01-ethernet0"@en ;
    rdfs:comment "Ethernet interface 0 on Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_Router01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to Firewall" ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -20 .

noria:NetworkInterface_R01_Eth1 a noria:NetworkInterface ;
    rdfs:label "router01-ethernet1"@en ;
    rdfs:comment "Ethernet interface 1 on Core Router 01."@en ;
