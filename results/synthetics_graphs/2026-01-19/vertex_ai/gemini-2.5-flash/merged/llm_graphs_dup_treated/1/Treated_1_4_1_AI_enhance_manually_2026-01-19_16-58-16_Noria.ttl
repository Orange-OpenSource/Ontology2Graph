# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_AdminTeam a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:comment "Team responsible for 24/7 network monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_2> ;
    noria:agentInstructions "Call emergency line for critical incidents."@en .

foaf:Agent_DevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_2> ;
    noria:agentInstructions "Open a ticket in Jira for non-critical issues."@en .

foaf:Agent_JohnDoe_extra_node_2 a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

foaf:Agent_JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

org:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "Main IT department of the company."@en .

org:OrgUnit_NOC a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "Sub-unit of IT Department, managing network infrastructure."@en ;
    org:unitOf org:Org_ITDepartment ;
    org:member foaf:Agent_AdminTeam .

org:OrgUnit_AppDev a org:OrganizationalUnit ;
    rdfs:label "Application Development Unit"@en ;
    rdfs:comment "Sub-unit of IT Department, developing applications."@en ;
    org:unitOf org:Org_ITDepartment ;
    org:member foaf:Agent_DevTeam .

noria:CUid_JohnDoe_extra_node_2 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe_extra_node_2 .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

