    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Internal_extra_node_2 LAN connection" ;
    noria:networkInterfaceRoutingPriorityMetric 10 ;
    noria:networkInterfaceLaserTxOpticalPower -1 ;
    noria:networkInterfaceLaserRxOpticalPower -2 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -20 .

