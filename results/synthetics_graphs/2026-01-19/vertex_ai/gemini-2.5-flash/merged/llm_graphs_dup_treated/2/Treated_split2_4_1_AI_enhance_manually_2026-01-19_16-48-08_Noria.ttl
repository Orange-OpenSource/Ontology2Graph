# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_RouterFailover a noria:OperationPlan ;
    rdfs:label "Core Router Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for initiating a failover on core routers."@en ;
    noria:operationPlanPreCondition noria:PreCondition_HighTrafficLoss ;
    noria:operationPlanPostCondition noria:PostCondition_TrafficRestored .

noria:PreCondition_HighTrafficLoss a noria:ActionPreCondition ;
    rdfs:label "High Traffic Loss Detected"@en ;
    rdfs:comment "Condition: Network monitoring system reports >50% packet loss on primary uplink."@en .

noria:PostCondition_TrafficRestored a noria:ActionPostCondition ;
    rdfs:label "Traffic Restored to Normal"@en ;
    rdfs:comment "Outcome: Packet loss returns to <5% and service is accessible."@en .

noria:AnomalyPattern_BGPFlap a noria:AnomalyPattern ;
    rdfs:label "BGP Flapping Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating unstable BGP routing sessions, often leading to intermittent connectivity issues."@en ;
    skos:example "Repeated BGP UP/DOWN events on a core router interface within a short period."@en .

