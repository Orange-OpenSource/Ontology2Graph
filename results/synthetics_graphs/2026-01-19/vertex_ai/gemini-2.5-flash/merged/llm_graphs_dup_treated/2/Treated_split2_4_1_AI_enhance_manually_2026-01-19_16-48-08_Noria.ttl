# =============================================================================
# Knowledge Organization System (KOS) Concepts
# These are defined as skos:Concept instances within their respective schemes.
# =============================================================================

# Application Types
<kos/application/type/infrastructure> a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<kos/application/type/business-critical> a skos:Concept ;
    skos:prefLabel "Business Critical Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<kos/application/type/monitoring> a skos:Concept ;
    skos:prefLabel "Monitoring Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ;
    skos:prefLabel "High Business Importance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:prefLabel "Medium Business Importance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

# Application Module Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:prefLabel "Development"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

# Resource Types
<kos/Resource/type/server> a skos:Concept ;
    skos:prefLabel "Server"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

<kos/Resource/type/router> a skos:Concept ;
    skos:prefLabel "Router"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

<kos/Resource/type/virtual-machine> a skos:Concept ;
    skos:prefLabel "Virtual Machine"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InUse> a skos:Concept ;
    skos:prefLabel "In Use"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:prefLabel "Decommissioned"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:prefLabel "Up"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:prefLabel "Down"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .

# Resource Administrative State
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ;
    skos:prefLabel "Enabled"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .

<kos/Resource/AdministrativeState/Disabled> a skos:Concept ;
    skos:prefLabel "Disabled"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .

# Trouble Ticket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:prefLabel "Major"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .

# Trouble Ticket Type
<kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:prefLabel "Failure"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:prefLabel "Assistance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .

# Trouble Ticket Priority
<kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:prefLabel "Priority 1"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .

<kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:prefLabel "Priority 2"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .

# Trouble Ticket Origin
<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:prefLabel "Supervision System"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:prefLabel "Customer Report"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:prefLabel "Immediate Intervention"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ;
    skos:prefLabel "Total Breakdown"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/trouble-category/PartialOutage> a skos:Concept ;
    skos:prefLabel "Partial Outage"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ;
    skos:prefLabel "Managed Backbone Networks"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .

# Trouble Ticket Status
<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:prefLabel "In Progress"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:prefLabel "Resolved"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:prefLabel "Internal Comment"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:prefLabel "Diagnosis"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .

# Change Request Category
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    skos:prefLabel "Internal Intervention"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .

# Change Request Type
<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:prefLabel "Standard Change"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .

# Change Request Cause
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:prefLabel "Software Upgrade"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .

# Change Request Status
<kos/ChangeRequest/status/Scheduled> a skos:Concept ;
    skos:prefLabel "Scheduled"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:prefLabel "Critical Severity"@en ;
    skos:inScheme <https://ww3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:prefLabel "Warning Severity"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:comment "Team responsible for 24/7 network monitoring and initial incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via dedicated hotline for critical incidents. Use ticketing system for non-urgent issues."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team responsible for server infrastructure management."@en ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the IT Service Portal. For emergencies, call the on-call engineer."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Team supporting critical business application 'Enterprise Portal'."@en ;
    noria:agentWorkingHours "8:30 AM - 6:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for quick queries, ticketing system for issues."@en .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "All requests must go through the ticketing system."@en .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual engineer from NOC Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent6 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead engineer for Server Administration Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Main department for IT infrastructure and application operations."@en ;
    org:hasMember foaf:Agent1, foaf:Agent2, foaf:Agent3, foaf:Agent4 .

org:Manufacturer1 a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

org:Manufacturer2 a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

org:Manufacturer3 a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of virtualization software."@en .

# =============================================================================
# Corporate User Identifiers
# =============================================================================

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "jdoe@example.com" ;
    foaf:holdsAccount foaf:Agent5 .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    observable:accountLogin "jsmith" ;
    observable:accountIdentifier "jsmith@example.com" ;
    foaf:holdsAccount foaf:Agent6 .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_Cisco_ASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "High-end aggregation services router."@en ;
    noria:productManufacturedBy org:Manufacturer1 .

noria:ProductModel_Dell_PowerEdge_R740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Versatile 2U rack server."@en ;
    noria:productManufacturedBy org:Manufacturer2 .

noria:ProductModel_VMware_ESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Type-1 hypervisor for virtual machines."@en ;
    noria:productManufacturedBy org:Manufacturer3 .

# =============================================================================
# Locations (Sites, Rooms, Loci)
# =============================================================================

bot:Site_DC1 a bot:Site ;
    rdfs:label "Main Data Center 1"@en ;
    noria:siteId "DC1-FRA-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Main Street"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site_HQ a bot:Site ;
    rdfs:label "Headquarters Office"@en ;
    noria:siteId "HQ-NYC-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Corporate Avenue"@en ;
    noria:sitePrincipalAddressCityName "New York"@en ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoom_DC1_A a noria:Room ;
    rdfs:label "Server Room A - DC1"@en ;
    rdfs:comment "Primary server room in Data Center 1."@en ;
    bot:hasSpace bot:Site_DC1 .

noria:Room_NetworkRoom_DC1_B a noria:Room ;
    rdfs:label "Network Room B - DC1"@en ;
    rdfs:comment "Network equipment room in Data Center 1."@en ;
    bot:hasSpace bot:Site_DC1 .

noria:Locus_Rack_DC1_A_R1 a noria:Locus ;
    rdfs:label "Rack R1 in Server Room A"@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoom_DC1_A .

noria:Locus_Rack_DC1_B_N1 a noria:Locus ;
    rdfs:label "Rack N1 in Network Room B"@en ;
    noria:locusLine "B" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_NetworkRoom_DC1_B .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_CoreRouter_01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate backbone network."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "cr01.dc1.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco_ASR9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "CISCO-CR01-SN12345" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_DC1_B_N1 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_AppServer_01 a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting the Enterprise Portal application."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "app01.dc1.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "DELL-APP01-SN67890" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_DC1_A_R1 ;
    noria:resourceManagementIPAddress "10.0.1.10" .

noria:Resource_DBServer_01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Primary database server for critical applications."@en ;
    noria:resourceManagedBy foaf:Agent4 ;
    noria:resourceHostName "db01.dc1.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "DELL-DB01-SN11223" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-20T14:35:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_DC1_A_R1 ;
    noria:resourceManagementIPAddress "10.0.1.11" .

noria:Resource_VirtualMachine_Web01 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting web services for Enterprise Portal."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "web01.dc1.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMware_ESXi ;
     # The hypervisor model, not the VM itself

    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_AppServer_01 ;
     # Assuming AppServer_01 is the hypervisor host

    noria:resourceManagementIPAddress "10.0.1.20" .

noria:Resource_MonitoringServer_01 a noria:Resource ;
    rdfs:label "Monitoring Server 01"@en ;
    rdfs:comment "Server running network and application monitoring tools."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "mon01.dc1.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "DELL-MON01-SN44556" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_DC1_A_R1 ;
    noria:resourceManagementIPAddress "10.0.1.50" .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_CR01_GE0_0_0 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on Core Router 01"@en ;
    noria:networkInterfaceDescription "Uplink to ISP A"@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:Resource_CoreRouter_01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_CR01_GE0_0_1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"@en ;
    noria:networkInterfaceDescription "Link to App Server VLAN"@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:Resource_CoreRouter_01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

noria:NetworkInterface_AppS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Application Server 01"@en ;
    noria:networkInterfaceDescription "Main network interface for application traffic."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:Resource_AppServer_01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_WebVM01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Web Server VM 01"@en ;
    noria:networkInterfaceDescription "Virtual network interface for web traffic."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceOf noria:Resource_VirtualMachine_Web01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_ISP_Uplink a noria:NetworkLink ;
    rdfs:label "ISP A Uplink"@en ;
    noria:networkLinkId "NL-ISP-A-001" ;
    noria:networkLinkType "fiber optic" ;
    noria:networkLinkInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter_01 ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_GE0_0_0 .

noria:NetworkLink_AppVLAN_Link a noria:NetworkLink ;
    rdfs:label "Core Router to App Server VLAN Link"@en ;
    noria:networkLinkId "NL-CR01-APP01-001" ;
    noria:networkLinkType "ethernet" ;
    noria:networkLinkInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter_01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_AppServer_01 ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_GE0_0_1 .

# =============================================================================
# Applications
# =============================================================================

noria:Application_EnterprisePortal a noria:Application ;
    rdfs:label "Enterprise Portal"@en ;
    rdfs:comment "Web-based portal for internal corporate services."@en ;
    noria:applicationModelIdentifier "EP-V2.0" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "EP" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Employee Self-Service"@en ;
    noria:resourceManagedBy foaf:Agent3 ;
    noria:resourceForApplication noria:Resource_AppServer_01, noria:Resource_DBServer_01, noria:Resource_VirtualMachine_Web01 .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "System for collecting and analyzing logs and metrics from IT infrastructure."@en ;
    noria:applicationModelIdentifier "CMS-V3.1" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "CMS" ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Performance and Event Management"@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceForApplication noria:Resource_MonitoringServer_01 .

# =============================================================================
# Application Modules
# =============================================================================

noria:ApplicationModule_EnterprisePortal_Prod a noria:ApplicationModule ;
    rdfs:label "Enterprise Portal Production Module"@en ;
