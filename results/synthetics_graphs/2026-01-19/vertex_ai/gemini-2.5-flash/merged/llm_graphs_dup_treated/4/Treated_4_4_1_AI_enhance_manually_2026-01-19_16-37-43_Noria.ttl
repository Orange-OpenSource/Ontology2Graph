    noria:loggingTime "2024-04-20T14:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Interface cr01.corp.example.com:eth5 changed state to down."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <https://w3id.org/noria/kos/Notification/EventType/stateChange> .

noria:EventRecord_ConfigChange_FW01 a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change applied to Firewall 01."@en ;
    noria:loggingTime "2024-04-19T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingAgent noria:Agent_SecurityTeam ;
    noria:logText "Rule added to allow new external IP range 203.0.113.0/24."@en ;
