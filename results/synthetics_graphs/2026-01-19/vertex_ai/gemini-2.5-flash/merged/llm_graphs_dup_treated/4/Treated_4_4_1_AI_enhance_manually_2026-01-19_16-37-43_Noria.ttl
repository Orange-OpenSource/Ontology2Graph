# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_RestartWebServer a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a web server instance."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebServerDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebServerUp .

noria:ActionPreCondition_WebServerDown a noria:ActionPreCondition ;
    rdfs:label "Web Server Unresponsive"@en ;
    rdfs:comment "Condition: Web server is not responding to health checks or user requests."@en .

noria:ActionPostCondition_WebServerUp a noria:ActionPostCondition ;
    rdfs:label "Web Server Restored"@en ;
    rdfs:comment "Expected outcome: Web server is responsive and serving traffic normally."@en .

noria:AnomalyPattern_HighCPUWeb a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU on Web Server"@en ;
    rdfs:comment "Pattern indicating a potential issue: CPU utilization above 90% for more than 15 minutes on a web server."@en ;
    folio:hasCause "Application bug or traffic surge"@en .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_HighCPU_WS01 a noria:EventRecord ;
    rdfs:label "High CPU Alert on Web Server 01"@en ;
    rdfs:comment "Alert generated by monitoring system indicating high CPU usage on web01."@en ;
    noria:loggingTime "2024-04-20T14:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 95% for 10 minutes."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <https://w3id.org/noria/kos/Notification/EventType/thresholdExceeded> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartWebServer .

noria:EventRecord_InterfaceDown_CR01 a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert on Core Router 01"@en ;
