@prefix time: <http://www.w3.org/2006/time#> .
@prefix gn: <https://www.geonames.org/ontology#> .

# =============================================================================
# KOS Concepts (used for properties with skos:Concept ranges)
# These are not defined as full skos:ConceptScheme, but as individual concepts
# as per the NORIA ontology's property range definitions.
# =============================================================================

<https://w3id.org/noria/kos/application/type/web-application> a skos:Concept ;
     rdfs:label "Web Application"@en .

<https://w3id.org/noria/kos/application/type/database-service> a skos:Concept ;
     rdfs:label "Database Service"@en .

<https://w3id.org/noria/kos/application/type/infrastructure> a skos:Concept ;
     rdfs:label "Infrastructure"@en .

