# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_WS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "web01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface 0 on Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary network interface for web traffic."@en ;
    noria:networkInterfaceConnects noria:NetworkLink_WS01_LB01 .

noria:NetworkInterface_LB01_Eth1 a noria:NetworkInterface ;
    rdfs:label "lb01.corp.example.com:eth1"@en ;
    rdfs:comment "Ethernet interface 1 on Load Balancer 01, connected to web servers."@en ;
    noria:networkInterfaceOf noria:Resource_LoadBalancer01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Interface facing web servers."@en ;
    noria:networkInterfaceConnects noria:NetworkLink_WS01_LB01 .

noria:NetworkInterface_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "db01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface 0 on DB Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary network interface for database traffic."@en ;
    noria:networkInterfaceConnects noria:NetworkLink_DB01_CR01 .

noria:NetworkInterface_CR01_Eth5 a noria:NetworkInterface ;
    rdfs:label "cr01.corp.example.com:eth5"@en ;
    rdfs:comment "Ethernet interface 5 on Core Router 01, connected to database servers."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Interface facing database servers."@en ;
    noria:networkInterfaceConnects noria:NetworkLink_DB01_CR01 .

noria:NetworkInterface_FW01_Eth0 a noria:NetworkInterface ;
    rdfs:label "fw01.corp.example.com:eth0"@en ;
    rdfs:comment "External interface of Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "External WAN interface."@en ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_WS01_LB01 a noria:NetworkLink ;
    rdfs:label "Link WebServer01-LoadBalancer01"@en ;
    rdfs:comment "Network link between Web Server 01 and Load Balancer 01."@en ;
    noria:networkLinkId "NL-WS01-LB01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_WebServer01, noria:Resource_LoadBalancer01 ;
