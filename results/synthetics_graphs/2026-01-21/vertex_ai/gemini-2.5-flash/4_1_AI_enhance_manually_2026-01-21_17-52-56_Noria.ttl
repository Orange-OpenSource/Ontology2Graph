noria:ActionPostCondition_DNSServiceUp a noria:ActionPostCondition ;
  rdfs:label "DNS Service Up Post-Condition"@en ;
  rdfs:comment "Expected outcome: DNS service is running and responding to queries, confirming restoration."@en ;
  skos:example "Verify 'systemctl status named' shows active and 'dig @localhost example.com' returns valid response."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
  rdfs:label "Network Interface Up Post-Condition"@en ;
  rdfs:comment "Expected outcome: The network interface is up and passing traffic, restoring connectivity."@en .

noria:ActionPreCondition_DNSServiceDown a noria:ActionPreCondition ;
  rdfs:label "DNS Service Down Pre-Condition"@en ;
  rdfs:comment "Condition: DNS service is not running or not responding on port 53, indicating a potential outage."@en ;
  skos:example "Check if 'systemctl status named' shows inactive or 'dig @localhost example.com' fails."@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
  rdfs:label "Network Interface Down Pre-Condition"@en ;
  rdfs:comment "Condition: A network interface is reported as administratively or operationally down, preventing traffic flow."@en .

noria:AnomalyPattern_HighCPUUsage a noria:AnomalyPattern ;
  rdfs:label "High CPU Usage Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating sustained high CPU utilization on a server, potentially leading to performance issues or system unresponsiveness."@en ;
  folio:hasCause "Excessive process load or software bug."@en .

noria:AnomalyPattern_NetworkCongestion a noria:AnomalyPattern ;
  rdfs:label "Network Congestion Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating high packet loss or latency on a network link, suggesting traffic overload or faulty network device."@en ;
  folio:hasCause "Traffic overload or faulty network device."@en .

noria:AnomalyPattern_SecurityBreachAttempt a noria:AnomalyPattern ;
  rdfs:label "Security Breach Attempt Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating attempts to breach network security, e.g., port scans, unauthorized access attempts, or suspicious login patterns."@en ;
  folio:hasCause "Malicious external actor or internal compromise."@en .

