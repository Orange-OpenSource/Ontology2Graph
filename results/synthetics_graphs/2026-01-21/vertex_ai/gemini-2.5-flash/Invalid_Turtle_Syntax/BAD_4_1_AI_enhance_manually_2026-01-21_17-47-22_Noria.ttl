    org:memberOf :OrgUnit_NetworkOps ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

:Person_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf :OrgUnit_AppDev .

:CorporateUserIdentifier_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "ASmith_CUid"@en ;
    rdfs:comment "Corporate User ID for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount :Person_AliceSmith .

:CorporateUserIdentifier_BJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "BJohnson_CUid"@en ;
