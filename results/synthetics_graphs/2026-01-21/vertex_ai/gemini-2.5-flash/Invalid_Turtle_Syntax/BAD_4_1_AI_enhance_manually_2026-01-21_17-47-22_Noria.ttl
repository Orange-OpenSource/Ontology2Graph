# =============================================================================
# Operational Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

:OperationPlan_CheckPhysicalLink a noria:OperationPlan ;
    rdfs:label "Check Physical Link Procedure"@en ;
    rdfs:comment "Standard operating procedure to diagnose physical network link issues."@en ;
    skos:example "Verify cable connections, check optical power levels, contact ISP."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_LinkDown ;
    noria:operationPlanPostCondition :ActionPostCondition_LinkUp .

:OperationPlan_RestartWebServer a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Procedure to restart the web server service or the entire VM."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_HighCPU ;
    noria:operationPlanPostCondition :ActionPostCondition_CPU_Normal .

:OperationPlan_RollbackDBSchema a noria:OperationPlan ;
    rdfs:label "Rollback Database Schema Procedure"@en ;
    rdfs:comment "Procedure to revert database schema to a previous stable version."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_DBError ;
    noria:operationPlanPostCondition :ActionPostCondition_DBOperational .

:ActionPreCondition_LinkDown a noria:ActionPreCondition ;
    rdfs:label "Network Link Down"@en ;
    rdfs:comment "Condition: A network interface reports an operational 'down' state."@en .

:ActionPostCondition_LinkUp a noria:ActionPostCondition ;
    rdfs:label "Network Link Up"@en ;
    rdfs:comment "Expected outcome: The network interface reports an operational 'up' state."@en .

:ActionPreCondition_HighCPU a noria:ActionPreCondition ;
    rdfs:label "High CPU Usage Detected"@en ;
    rdfs:comment "Condition: CPU utilization on a server exceeds a predefined threshold."@en .

:ActionPostCondition_CPU_Normal a noria:ActionPostCondition ;
    rdfs:label "CPU Usage Normal"@en ;
    rdfs:comment "Expected outcome: CPU utilization returns to normal levels."@en .

:ActionPreCondition_DBError a noria:ActionPreCondition ;
    rdfs:label "Database Error Detected"@en ;
    rdfs:comment "Condition: Database logs show critical errors or connectivity issues."@en .

:ActionPostCondition_DBOperational a noria:ActionPostCondition ;
    rdfs:label "Database Operational"@en ;
    rdfs:comment "Expected outcome: Database is accessible and functioning without errors."@en .

:AnomalyPattern_RepeatedLinkFlap a noria:AnomalyPattern ;
    rdfs:label "Repeated Link Flap Anomaly"@en ;
    rdfs:comment "Pattern indicating a recurring issue where a network link repeatedly goes up and down."@en ;
    skos:example "Multiple 'interface up/down' events within a short period."@en .

:AnomalyPattern_HighCPUUsage a noria:AnomalyPattern ;
    rdfs:label "High CPU Usage Anomaly"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization on a server."@en ;
    skos:example "CPU usage > 90% for more than 10 minutes."@en .

:AnomalyPattern_DBConnectionErrors a noria:AnomalyPattern ;
    rdfs:label "Database Connection Errors Anomaly"@en ;
    rdfs:comment "Pattern indicating frequent or sustained database connection failures."@en ;
    skos:example "Multiple 'connection refused' or 'SQLSTATE' errors in application logs."@en .

# Link EventRecord to OperationPlan via alarmProposedRepairAction
:EventRecord_InterfaceDown_RouterEdge01 noria:alarmProposedRepairAction :OperationPlan_CheckPhysicalLink .
:EventRecord_CPUHigh_WebServer01 noria:alarmProposedRepairAction :OperationPlan_RestartWebServer .
:EventRecord_DB_Error_CRM_DB noria:alarmProposedRepairAction :OperationPlan_RollbackDBSchema .

# Link TroubleTicket to ProcedureExecutionContainer for resolution actions
:ProcedureExecutionContainer_TT001_Resolution a pep:ProcedureExecutionContainer ;
    rdfs:label "Resolution Actions for TT001"@en ;
    rdfs:comment "Container for actions taken to resolve Trouble Ticket TT001."@en ;
    pep:usedProcedure :OperationPlan_CheckPhysicalLink .

:TroubleTicketNote_TT001_Note2 noria:troubleTicketNoteCorrelatedExecution :ProcedureExecutionContainer_TT001_Resolution .

:ProcedureExecutionContainer_TT002_Resolution a pep:ProcedureExecutionContainer ;
    rdfs:label "Resolution Actions for TT002"@en ;
    rdfs:comment "Container for actions taken to resolve Trouble Ticket TT002."@en ;
    pep:usedProcedure :OperationPlan_RestartWebServer .

:TroubleTicketNote_TT002_Note1 noria:troubleTicketNoteCorrelatedExecution :ProcedureExecutionContainer_TT002_Resolution .

