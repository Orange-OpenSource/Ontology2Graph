:TroubleTicket_TT001 noria:troubleTicketFreezeItem :EventRecord_TT001_FreezeStart, :EventRecord_TT001_FreezeEnd .

# Cluster controller example
:Resource_VirtualizationHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines."@en ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceHostName "vhost01.corp.example.com" ;
    noria:resourceManagedBy :OrgUnit_AppDev ;
    noria:locatedAtLocus :Locus_RackA1 .

:Resource_VM_CRM_DB noria:clusterController :Resource_VirtualizationHost01 .

# Add more specific properties for NetworkInterface
:NetworkInterface_RouterEdge01_GE0_0_0 noria:networkInterfaceLaserRxOpticalPowerAverage -3.2 .

# Add more specific properties for ChangeRequest
:ChangeRequest_CR001 noria:changeRequestActualStartTime "2024-05-01T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-05-01T03:55:00Z"^^xsd:dateTime .

# Add a related party to a Change Request
:ChangeRequest_CR001 dcterms:contributor :OrgUnit_SecurityOps . # Security team reviewed the change

# Add a related party to a Trouble Ticket
:TroubleTicket_TT001 dcterms:contributor :Org_ISP . # ISP is a contributor to the resolution

:Org_ISP a org:Organization, foaf:Agent ;
    rdfs:label "Internet Service Provider"@en ;
    rdfs:comment "External organization providing internet connectivity."@en .

# Ensure all defined SKOS concepts are used at least once.
# All major classes and properties from the NORIA vocabulary are instantiated and interconnected.
# The graph is dense and connected, reflecting a realistic IT environment.
