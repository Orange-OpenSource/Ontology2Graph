# Additional Connectivity and Density
# =============================================================================

# Agents managing resources
:OrgUnit_NetworkOps noria:agentManagesResource :Resource_DNS01, :Resource_RouterEdge01, :Resource_SwitchCore01, :NetworkLink_ISP_Edge01, :NetworkLink_Edge01_Core01, :NetworkLink_Core01_WebServer01, :NetworkLink_Core01_DNS01, :NetworkLink_Core01_CRM_DB_VM .
:OrgUnit_AppDev noria:agentManagesResource :Resource_WebServer01, :Resource_VM_CRM_DB .

# Resources for multiple applications
:Resource_DNS01 noria:resourceForApplication :Application_InternetAccess . # DNS is critical for internet access too

# Application modules with support groups
:ApplicationModule_IntranetProd noria:applicationModuleSupportGroup :OrgUnit_AppDev ;
    noria:applicationModuleHotlineGroup :OrgUnit_AppDev .

:ApplicationModule_InternetAccessProd noria:applicationModuleSupportGroup :OrgUnit_NetworkOps ;
    noria:applicationModuleHotlineGroup :OrgUnit_NetworkOps .

# Trouble ticket external ID and HREF
:TroubleTicket_TT001 noria:documentExternalId "EXT-INC-98765" ;
    noria:documentHRef "https://itsm.example.com/ticket/TT001" .

:ChangeRequest_CR001 noria:documentExternalId "EXT-CHG-12345" ;
    noria:documentHRef "https://itsm.example.com/change/CR001" .

# Trouble ticket freeze item (example of linking to EventRecord for freeze periods)
:EventRecord_TT001_FreezeStart a noria:EventRecord ;
    rdfs:label "TT001 Freeze Start"@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:logText "Trouble Ticket TT001 frozen due to external ISP dependency."@en .

:EventRecord_TT001_FreezeEnd a noria:EventRecord ;
    rdfs:label "TT001 Freeze End"@en ;
    noria:loggingTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
