# =============================================================================
# SKOS Concept Schemes and Concepts
# =============================================================================

# Application Type
<https://w3id.org/noria/kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "Defines types of applications within the IT landscape."@en .

<https://w3id.org/noria/kos/application/type/infrastructure> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Applications providing core infrastructure services."@en .

<https://w3id.org/noria/kos/application/type/service-platform> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Service Platform Application"@en ;
    rdfs:comment "Applications acting as platforms for other services."@en .

<https://w3id.org/noria/kos/application/type/business-application> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "Applications directly supporting business processes."@en .

# Application Business Importance
<https://w3id.org/noria/kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "Categorizes applications by their business criticality."@en .

<https://w3id.org/noria/kos/application/business-importance/high> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for business operations."@en .

<https://w3id.org/noria/kos/application/business-importance/medium> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application is important but not critical for immediate business operations."@en .

<https://w3id.org/noria/kos/application/business-importance/low> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "Low Business Importance"@en ;
    rdfs:comment "Application is non-critical for business operations."@en .

# Application Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "Defines the lifecycle status of an application module."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is live and serving users."@en .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Development"@en ;
    rdfs:comment "The application module is under active development."@en .

<https://w3id.org/noria/kos/application/status/Decommissioned> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "The application module has been retired and is no longer in use."@en .

# Application SLA Level
<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "Defines Service Level Agreement tiers for applications."@en .

<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest service level, maximum availability and performance."@en .

<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Standard service level with good availability."@en .

<https://w3id.org/noria/kos/application/sla-level/Bronze> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Bronze SLA Level"@en ;
    rdfs:comment "Basic service level, typically for non-critical systems."@en .

# Service Type
<https://w3id.org/noria/kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "Categorizes services by their nature (customer-facing, resource-facing)."@en .

<https://w3id.org/noria/kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "Service directly consumed by external customers."@en .

<https://w3id.org/noria/kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "Service consumed by internal systems or resources."@en .

# Trouble Ticket Severity
<https://w3id.org/noria/kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "Defines the criticality of a trouble ticket."@en .

<https://w3id.org/noria/kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Service completely unavailable or major business impact."@en .

<https://w3id.org/noria/kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Service degraded or significant business impact."@en .

<https://w3id.org/noria/kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Minor Severity"@en ;
    rdfs:comment "Minor service impact or low business impact."@en .

# Trouble Ticket Type
<https://w3id.org/noria/kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "Defines the type of issue reported in a trouble ticket."@en .

<https://w3id.org/noria/kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> ;
    rdfs:label "Failure Ticket"@en ;
    rdfs:comment "Ticket reporting a system or service failure."@en .

<https://w3id.org/noria/kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> ;
    rdfs:label "Assistance Ticket"@en ;
    rdfs:comment "Ticket requesting user assistance or information."@en .

# Trouble Ticket Category
<https://w3id.org/noria/kos/TroubleTicket/category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme"@en ;
    rdfs:comment "Defines the initial nature or technical impact category of a trouble ticket."@en .

<https://w3id.org/noria/kos/TroubleTicket/category/InterruptedService> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/category> ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "Service is completely unavailable to users."@en .

<https://w3id.org/noria/kos/TroubleTicket/category/DowngradingEquipment> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/category> ;
    rdfs:label "Downgrading Equipment"@en ;
    rdfs:comment "Equipment is operating below its expected performance or capacity."@en .

# Trouble Ticket Priority
<https://w3id.org/noria/kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "Defines the management priority of a trouble ticket."@en .

<https://w3id.org/noria/kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, requires immediate attention."@en .

<https://w3id.org/noria/kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, requires prompt attention."@en .

# Trouble Ticket Origin
<https://w3id.org/noria/kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "Defines the source of a trouble ticket."@en .

<https://w3id.org/noria/kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System"@en ;
    rdfs:comment "Ticket originated from an automated monitoring or supervision system."@en .

<https://w3id.org/noria/kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Ticket originated from a customer report."@en .

# Trouble Ticket Urgency
<https://w3id.org/noria/kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "Defines the urgency level for intervention on a trouble ticket."@en .

<https://w3id.org/noria/kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action to prevent further impact."@en .

<https://w3id.org/noria/kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Intervention can be scheduled for a later time."@en .

# Trouble Ticket Problem Responsibility
<https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    rdfs:comment "Defines the final area of responsibility for an incident."@en .

<https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility lies with the team managing backbone network infrastructure."@en .

<https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/Customer> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Customer Responsibility"@en ;
    rdfs:comment "Responsibility lies with the customer."@en .

# Trouble Ticket Status
<https://w3id.org/noria/kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "Defines the current activity status of a trouble ticket."@en .

<https://w3id.org/noria/kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

<https://w3id.org/noria/kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue described in the trouble ticket has been resolved."@en .

<https://w3id.org/noria/kos/TroubleTicket/status/Closed> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> ;
    rdfs:label "Closed"@en ;
    rdfs:comment "The trouble ticket has been closed after resolution and verification."@en .

# Trouble Ticket Comment Type
<https://w3id.org/noria/kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Comment Type Scheme"@en ;
    rdfs:comment "Defines the provenance or disclosure rules for comments on a trouble ticket."@en .

<https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team use only."@en .

<https://w3id.org/noria/kos/TroubleTicket/commentType/Customer> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> ;
    rdfs:label "Customer Comment"@en ;
    rdfs:comment "Comment visible to the customer."@en .

# Trouble Ticket Operation Type
<https://w3id.org/noria/kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Operation Type Scheme"@en ;
    rdfs:comment "Defines the type of operation described in a trouble ticket note."@en .

<https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Note describing diagnostic steps taken."@en .

<https://w3id.org/noria/kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> ;
    rdfs:label "Tests and Measurements"@en ;
    rdfs:comment "Note describing tests performed and their results."@en .

# Change Request Category
<https://w3id.org/noria/kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "Defines the nature of a change request."@en .

<https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request for internal system modifications."@en .

<https://w3id.org/noria/kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change request for upgrading software versions."@en .

# Change Request Type
<https://w3id.org/noria/kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "Defines the a priori impact and risk level of a change request."@en .

<https://w3id.org/noria/kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Pre-approved change with low risk and impact."@en .

<https://w3id.org/noria/kos/ChangeRequest/type/Emergency> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> ;
    rdfs:label "Emergency Change"@en ;
    rdfs:comment "Change required urgently to resolve a critical incident."@en .

# Change Request Cause
<https://w3id.org/noria/kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "Defines the reason for a change request."@en .

<https://w3id.org/noria/kos/ChangeRequest/cause/Configuration> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change due to modification of system configuration."@en .

<https://w3id.org/noria/kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> ;
    rdfs:label "Preventative Maintenance"@en ;
    rdfs:comment "Change performed to prevent future issues."@en .

# Change Request Status
<https://w3id.org/noria/kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "Defines the current status of a change request."@en .

<https://w3id.org/noria/kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "The change request has been approved for implementation."@en .

<https://w3id.org/noria/kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "The change request has been successfully implemented."@en .

# Change Request Specification
<https://w3id.org/noria/kos/ChangeRequest/specification> a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    rdfs:comment "Defines standard operation plan items for recurring activities."@en .

<https://w3id.org/noria/kos/ChangeRequest/specification/StandardProcedureA> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> ;
    rdfs:label "Standard Procedure A"@en ;
    rdfs:comment "Refers to a predefined standard operating procedure."@en .

# Resource Operational State
<https://w3id.org/noria/kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "Defines the operational status of a resource."@en .

<https://w3id.org/noria/kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Operational Up"@en ;
    rdfs:comment "The resource is functioning correctly."@en .

<https://w3id.org/noria/kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Operational Down"@en ;
    rdfs:comment "The resource is not functioning."@en .

# Resource Administrative State
<https://w3id.org/noria/kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "Defines the administrative status of a resource."@en .

<https://w3id.org/noria/kos/Resource/AdministrativeState/Up> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative Up"@en ;
    rdfs:comment "The resource is administratively enabled."@en .

<https://w3id.org/noria/kos/Resource/AdministrativeState/Down> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative Down"@en ;
    rdfs:comment "The resource is administratively disabled."@en .

# Resource Type
<https://w3id.org/noria/kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "Defines types of IT resources."@en .

<https://w3id.org/noria/kos/Resource/type/Router> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network device that forwards data packets between computer networks."@en .

<https://w3id.org/noria/kos/Resource/type/Server> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computer program or a device that provides functionality for other programs or devices, called 'clients'."@en .

<https://w3id.org/noria/kos/Resource/type/Switch> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network device that connects devices in a computer network by using packet switching to receive, process, and forward data to the destination device."@en .

<https://w3id.org/noria/kos/Resource/type/VirtualMachine> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Virtual Machine"@en ;
    rdfs:comment "An emulation of a computer system."@en .

# Resource Lifecycle State
<https://w3id.org/noria/kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "Defines the production state of a resource."@en .

<https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The resource is actively used in the production environment."@en .

<https://w3id.org/noria/kos/Resource/LifecycleState/Staging> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ;
    rdfs:label "Staging"@en ;
    rdfs:comment "The resource is in a testing or pre-production environment."@en .

# Agent Contact Method
<https://w3id.org/noria/kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "Defines preferred contact methods for agents."@en .

<https://w3id.org/noria/kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<https://w3id.org/noria/kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# Notification Severity Perceived Severity
<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Scheme"@en ;
    rdfs:comment "Defines the perceived severity of a notification or alarm."@en .

<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Perceived Severity"@en ;
    rdfs:comment "Highest perceived severity, indicating a severe impact."@en .

<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Major Perceived Severity"@en ;
    rdfs:comment "Significant perceived severity, indicating a notable impact."@en .

<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Minor Perceived Severity"@en ;
    rdfs:comment "Low perceived severity, indicating a minimal impact."@en .

