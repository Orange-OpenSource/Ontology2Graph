:NetworkInterface_WebServer01_Eth0 noria:networkInterfaceConnects :NetworkLink_Core01_WebServer01 .
:NetworkInterface_DNS01_Eth0 noria:networkInterfaceConnects :NetworkLink_Core01_DNS01 .
:NetworkInterface_VM_CRM_DB_Eth0 noria:networkInterfaceConnects :NetworkLink_Core01_CRM_DB_VM .

