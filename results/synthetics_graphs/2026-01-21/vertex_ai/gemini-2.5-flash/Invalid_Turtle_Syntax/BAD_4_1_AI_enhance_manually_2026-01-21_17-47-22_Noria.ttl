:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department of the company."@en ;
    org:hasUnit :OrgUnit_NetworkOps, :OrgUnit_AppDev, :OrgUnit_SecurityOps .

