# =============================================================================
# Services
# =============================================================================

:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en, "Service Accès Internet Entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet access to corporate users."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :AppModule_CorporateWebsite_Prod ; # Example: Website relies on this service
    seas:subSystemOf :AppModule_MonitoringSystem_Main ; # Monitoring system uses internet access
    noria:elementManagedBy :Agent_NetworkOpsTeam .

:Service_InternalNetworkConnectivity a noria:Service ;
    rdfs:label "Internal Network Connectivity Service"@en, "Service Connectivité Réseau Interne"@fr ;
    rdfs:comment "Provides internal network connectivity for all corporate applications and resources."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/ResourceFacingService> ;
    seas:subSystemOf :AppModule_DNSService_Primary ; # DNS service relies on internal connectivity
    seas:subSystemOf :AppModule_CorporateWebsite_Prod ; # Website relies on internal connectivity
    seas:subSystemOf :AppModule_DatabaseService_Prod ; # Database service relies on internal connectivity
    noria:elementManagedBy :Agent_NetworkOpsTeam .

:Service_CorporateApplications a noria:Service ;
    rdfs:label "Corporate Applications Service"@en, "Service Applications Entreprise"@fr ;
    rdfs:comment "Aggregated service for all internal and external corporate applications."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :Service_InternalNetworkConnectivity ;
    seas:subSystemOf :Application_CorporateWebsite ;
    seas:subSystemOf :Application_DatabaseService ;
    noria:elementManagedBy :Agent_AppDevTeam .

# =============================================================================
# Event Records
# =============================================================================

# Event Records
:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server 01 Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server 01 became unreachable."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DNSServer01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%" ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating an interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down" ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction :OperationPlan_InterfaceTroubleshooting .

:EventRecord_FirewallConfigChange a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Firewall 01."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Firewall01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:logOriginatingAgent :Agent_JaneSmith ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jsmith (10.0.0.1)" ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

:EventRecord_WebServerError a noria:EventRecord ;
    rdfs:label "Web Server Error Log"@en ;
    rdfs:comment "Log entry indicating an application error on Web Frontend Server 01."@en ;
    noria:loggingTime "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_WebFrontend01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:logText "ERROR: Application 'CorporateWebsite' encountered a database connection error." ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> .

:EventRecord_StorageCapacityWarning a noria:EventRecord ;
    rdfs:label "Storage Array Capacity Warning"@en ;
    rdfs:comment "Log entry indicating high storage utilization on Storage Array 01."@en ;
    noria:loggingTime "2024-04-19T08:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_StorageArray01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:logText "WARNING: Storage volume 'DATA_VOL01' at 85% capacity." ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> .

:EventRecord_DNSRestartCommand a noria:EventRecord ;
    rdfs:label "DNS Service Restart Command Executed"@en ;
    noria:loggingTime "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DNSServer01 ;
    noria:logOriginatingAgent :Agent_JohnDoe ;
    noria:logText "Command 'systemctl restart named' executed on dns01.corp.example.com" ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> ;
    pep:usedProcedure :OperationPlan_DNSRestart .

# =============================================================================
# Trouble Tickets
# =============================================================================

:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "DNS server dns01.corp.example.com is unreachable, impacting corporate services."@en ;
    dcterms:identifier "TT-20240420-001" ;
    dcterms:created "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Critical> ;
