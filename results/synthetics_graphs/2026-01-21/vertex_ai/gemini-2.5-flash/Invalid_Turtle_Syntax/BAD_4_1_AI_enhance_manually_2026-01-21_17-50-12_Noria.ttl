# Product Models
# =============================================================================

:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing and virtualization."@en ;
    noria:productManufacturedBy :Org_Dell .

:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series Switch"@en ;
    rdfs:comment "High-density data center switch."@en ;
    noria:productManufacturedBy :Org_Cisco .

:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480 Router"@en ;
    rdfs:comment "Modular router for enterprise and service provider applications."@en ;
    noria:productManufacturedBy :Org_Juniper .

:ProductModel_PaloAltoFirewall a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220 Firewall"@en ;
    rdfs:comment "Next-generation firewall for network security."@en ;
    noria:productManufacturedBy :Org_PaloAlto .

:ProductModel_HPStorage a noria:ProductModel ;
    rdfs:label "HP 3PAR StoreServ 8000"@en ;
    rdfs:comment "Enterprise-grade storage array for critical data."@en ;
    noria:productManufacturedBy :Org_HP .

:Org_Dell a org:Organization ; rdfs:label "Dell Technologies"@en .
:Org_Cisco a org:Organization ; rdfs:label "Cisco Systems"@en .
:Org_Juniper a org:Organization ; rdfs:label "Juniper Networks"@en .
:Org_PaloAlto a org:Organization ; rdfs:label "Palo Alto Networks"@en .
:Org_HP a org:Organization ; rdfs:label "Hewlett Packard Enterprise"@en .

# =============================================================================
# Locations
# =============================================================================

:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    noria:siteId "DC01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

:Site_BranchOfficeParis a bot:Site ;
    rdfs:label "Branch Office Paris"@en, "Bureau Annexe Paris"@fr ;
    noria:siteId "BO-PAR" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddress "45 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server room in the main data center."@en ;
    bot:hasSpace :Site_MainDataCenter .

:Room_NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B"@en, "Local Réseau B"@fr ;
    rdfs:comment "Network equipment closet in the branch office."@en ;
    bot:hasSpace :Site_BranchOfficeParis .

:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server in Rack A1, Unit 23."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "23" ;
    bot:hasSpace :Room_ServerRoomA .

:Locus_RackB5_U1 a noria:Locus ;
    rdfs:label "Rack B5, Unit 1"@en ;
    rdfs:comment "Specific location for a router in Rack B5, Unit 1."@en ;
    noria:locusLine "B5" ;
    noria:locusRow "1" ;
    bot:hasSpace :Room_ServerRoomA .

:Locus_WallMount_C1 a noria:Locus ;
    rdfs:label "Wall Mount C1"@en ;
    rdfs:comment "Location for a small switch in Network Closet B."@en ;
    noria:locusLine "C" ;
    noria:locusRow "1" ;
    bot:hasSpace :Room_NetworkClosetB .

:Locus_RackA1_U24 a noria:Locus ;
    rdfs:label "Rack A1, Unit 24"@en ;
    rdfs:comment "Specific location for a server in Rack A1, Unit 24."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "24" ;
    bot:hasSpace :Room_ServerRoomA .

# =============================================================================
# Resources
# =============================================================================

:Resource_DNSServer01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, hosted in DC01."@en ;
    noria:resourceManagedBy :Agent_DNSAdminTeam ;
    noria:agentManagesResource :Agent_DNSAdminTeam ; # Inverse property
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus :Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
    noria:resourceForApplication :Application_DNSService .

:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en, "Routeur Coeur 01"@fr ;
    rdfs:comment "Main router for the data center network."@en ;
    noria:resourceManagedBy :Agent_NetworkOpsTeam ;
    noria:agentManagesResource :Agent_NetworkOpsTeam ; # Inverse property
    noria:resourceHostName "cr01.dc01.example.com" ;
    noria:resourceProductModel :ProductModel_JuniperMX480 ;
    noria:resourceLogisticId "ASSET-CR-001" ;
