# =============================================================================
# Agents and Organizations
# =============================================================================

# Agents (Teams and Individuals)
:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for routine, phone for critical issues."@en .

:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use ticketing system for all requests, call hotline for P1/P2."@en .

:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en, "Équipe Développement Applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center"@en, "Centre Opérations Sécurité"@fr ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual member of the DNS Admin Team."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    foaf:mbox "mailto:john.doe@example.com" .

:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Individual member of the Network Operations Team."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    foaf:mbox "mailto:jane.smith@example.com" .

:Agent_AliceJohnson a foaf:Agent ;
    rdfs:label "Alice Johnson"@en, "Alice Dubois"@fr ;
    rdfs:comment "Individual member of the Application Development Team."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Chat> ;
    foaf:mbox "mailto:alice.johnson@example.com" .

# Organizations and Organizational Units
:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en, "Département Informatique"@fr ;
    rdfs:comment "Overall IT department of the company."@en .

:OrgUnit_InfrastructureOps a org:OrganizationalUnit ;
    rdfs:label "Infrastructure Operations"@en, "Opérations Infrastructure"@fr ;
    rdfs:comment "Unit responsible for IT infrastructure operations."@en ;
    org:unitOf :Org_ITDepartment ;
    org:hasMember :Agent_NetworkOpsTeam, :Agent_DNSAdminTeam .

:OrgUnit_ApplicationSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support"@en, "Support Applicatif"@fr ;
    rdfs:comment "Unit responsible for application support."@en ;
    org:unitOf :Org_ITDepartment ;
    org:hasMember :Agent_AppDevTeam, :Agent_AliceJohnson .

:OrgUnit_SecurityOps a org:OrganizationalUnit ;
    rdfs:label "Security Operations"@en, "Opérations Sécurité"@fr ;
    rdfs:comment "Unit responsible for cybersecurity operations."@en ;
    org:unitOf :Org_ITDepartment ;
    org:hasMember :Agent_SecurityTeam .

# Corporate User Identifiers
:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount :Agent_JohnDoe .

:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount :Agent_JaneSmith .

:CUid_AliceJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Johnson's Corporate ID"@en ;
    foaf:accountName "ajohnson" ;
    foaf:holdsAccount :Agent_AliceJohnson .

