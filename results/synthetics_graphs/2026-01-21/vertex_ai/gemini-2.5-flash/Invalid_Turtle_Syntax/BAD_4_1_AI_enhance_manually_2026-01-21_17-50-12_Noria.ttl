# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

# Operation Plans
:OperationPlan_InterfaceTroubleshooting a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition :ActionPostCondition_InterfaceUp .

:OperationPlan_DNSRestart a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Procedure to restart the DNS service on a server."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_DNSServiceNotResponding ;
    noria:operationPlanPostCondition :ActionPostCondition_DNSServiceResponding .

:OperationPlan_FirewallRuleAddition a noria:OperationPlan ;
    rdfs:label "Firewall Rule Addition Procedure"@en ;
    rdfs:comment "Standard procedure for adding new rules to the perimeter firewall."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_NewAppTrafficBlocked ;
    noria:operationPlanPostCondition :ActionPostCondition_NewAppTrafficFlowing .

:OperationPlan_DatabaseOptimization a noria:OperationPlan ;
    rdfs:label "Database Performance Optimization Procedure"@en ;
    rdfs:comment "Procedure to optimize database queries and performance."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_DatabaseSlow ;
    noria:operationPlanPostCondition :ActionPostCondition_DatabaseFast .

# Action Pre-Conditions
:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en .

:ActionPreCondition_DNSServiceNotResponding a noria:ActionPreCondition ;
    rdfs:label "DNS Service Not Responding"@en ;
    rdfs:comment "Condition: DNS queries to the server are failing."@en .

:ActionPreCondition_NewAppTrafficBlocked a noria:ActionPreCondition ;
    rdfs:label "New Application Traffic Blocked"@en ;
    rdfs:comment "Condition: Traffic for a newly deployed application is being blocked by the firewall."@en .

:ActionPreCondition_DatabaseSlow a noria:ActionPreCondition ;
    rdfs:label "Database Performance is Slow"@en ;
    rdfs:comment "Condition: Database queries are taking longer than expected."@en .

# Action Post-Conditions
:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up'."@en .

:ActionPostCondition_DNSServiceResponding a noria:ActionPostCondition ;
    rdfs:label "DNS Service Responding"@en ;
    rdfs:comment "Expected outcome: DNS queries to the server are successful."@en .

:ActionPostCondition_NewAppTrafficFlowing a noria:ActionPostCondition ;
    rdfs:label "New Application Traffic Flowing"@en ;
    rdfs:comment "Expected outcome: Traffic for the new application flows successfully through the firewall."@en .

:ActionPostCondition_DatabaseFast a noria:ActionPostCondition ;
    rdfs:label "Database Performance is Fast"@en ;
    rdfs:comment "Expected outcome: Database queries are responding within acceptable limits."@en .

# Anomaly Patterns
:AnomalyPattern_HighPacketLoss a noria:AnomalyPattern ;
    rdfs:label "High Packet Loss Anomaly"@en ;
    rdfs:comment "Pattern indicating high packet loss on a network link, potentially leading to service degradation."@en ;
    folio:hasCause "Network congestion or faulty hardware"@en .

:AnomalyPattern_DNSServiceFailure a noria:AnomalyPattern ;
    rdfs:label "DNS Service Failure Anomaly"@en ;
    rdfs:comment "Pattern indicating that a DNS server is not responding to queries, leading to name resolution failures."@en ;
    folio:hasCause "Service crash or network isolation"@en .

:AnomalyPattern_WebResponseTimeDegradation a noria:AnomalyPattern ;
    rdfs:label "Web Response Time Degradation Anomaly"@en ;
    rdfs:comment "Pattern indicating a significant increase in web application response times."@en ;
    folio:hasCause "Backend service overload or database bottleneck"@en .

# =============================================================================
# Document Attachments
# =============================================================================

:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram DC01"@en ;
    rdfs:comment "Diagram of the network topology in Main Data Center."@en ;
    dcterms:identifier "DOC-NET-DC01-V2.3" ;
    dcterms:created "2024-03-10T10:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf :TroubleTicket_BranchOfficeConnectivity ;
    dcterms:isPartOf :ChangeRequest_RouterOSUpgrade .

:DocumentAttachment_FirewallRuleset a noria:DocumentAttachment ;
    rdfs:label "Firewall Ruleset CR-20240419-001"@en ;
    rdfs:comment "Configuration file for the firewall rules implemented in CR-20240419-001."@en ;
    dcterms:identifier "DOC-FW-CR-20240419-001" ;
    dcterms:created "2024-04-19T15:35:00Z"^^xsd:dateTime ;
    dcterms:isPartOf :ChangeRequest_FirewallUpdate .

# =============================================================================
# Additional Interconnections for Density
# =============================================================================

# Link Trouble Tickets to Change Requests if a CR is opened to resolve a TT
:TroubleTicket_WebsiteSlow dcterms:relation :ChangeRequest_StorageExpansion . # Assume storage expansion might resolve website slowness

# Link Event Records to Trouble Tickets and Change Requests for status history
:TroubleTicket_DNSOutage noria:documentStatusHistory :EventRecord_DNSOutageLog .
:ChangeRequest_FirewallUpdate noria:documentStatusHistory :EventRecord_FirewallConfigChange .

# Link Application Modules to Resources they utilize
:AppModule_CorporateWebsite_Prod seas:subSystemOf :Resource_WebFrontend01, :Resource_StorageArray01 .
:AppModule_DNSService_Primary seas:subSystemOf :Resource_DNSServer01 .
:AppModule_MonitoringSystem_Main seas:subSystemOf :Resource_CoreRouter01, :Resource_Firewall01 .
:AppModule_DatabaseService_Prod seas:subSystemOf :Resource_StorageArray01 .

# Link Services to Resources indirectly via Application Modules
:Service_InternetAccess seas:subSystemOf :Resource_CoreRouter01, :Resource_Firewall01 .
:Service_InternalNetworkConnectivity seas:subSystemOf :Resource_CoreRouter01, :Resource_BranchSwitch01 .

# Example of a freeze item for a Trouble Ticket
:EventRecord_TTFreezeStart a noria:EventRecord ;
    rdfs:label "Trouble Ticket TT-20240420-001 Frozen"@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:logText "Trouble Ticket TT-20240420-001 status changed to Frozen due to external dependency."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

:TroubleTicket_DNSOutage noria:troubleTicketFreezeItem :EventRecord_TTFreezeStart .

# Example of a TroubleTicketCharacteristic (assuming it's a blank node or a specific class)
:TroubleTicket_DNSOutage noria:troubleTicketCharacteristic [
    a noria:Property ;
    rdfs:label "Customer Impact Level"@en ;
    rdfs:comment "High impact, all users affected."@en
] .

# Example of a ChangeRequestImpact with multiple entities
:ChangeRequest_RouterOSUpgrade noria:changeRequestImpact :Resource_CoreRouter01, :Service_InternalNetworkConnectivity .

