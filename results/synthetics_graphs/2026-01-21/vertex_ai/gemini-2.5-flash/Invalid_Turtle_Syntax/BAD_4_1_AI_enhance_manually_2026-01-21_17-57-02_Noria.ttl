    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

