    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN (ping failed)" ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan1 ;
