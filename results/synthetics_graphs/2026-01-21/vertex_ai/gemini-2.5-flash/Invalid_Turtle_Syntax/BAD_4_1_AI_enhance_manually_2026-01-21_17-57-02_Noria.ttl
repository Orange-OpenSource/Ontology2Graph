# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface1 a noria:NetworkInterface ;
    rdfs:label "DNS Server Eth0"@en, "Eth0 du Serveur DNS"@fr ;
    rdfs:comment "Ethernet interface for Primary DNS server connectivity to the internal network."@en ;
    noria:networkInterfaceOf noria:Resource1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface8 a noria:NetworkInterface ;
    rdfs:label "Backup DNS Eth0"@en, "Eth0 du DNS Secondaire"@fr ;
    rdfs:comment "Ethernet interface for Backup DNS server connectivity."@en ;
    noria:networkInterfaceOf noria:Resource10 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface2 a noria:NetworkInterface ;
    rdfs:label "Router1 Gi0/0/1"@en, "Gi0/0/1 du Routeur1"@fr ;
    rdfs:comment "Gigabit Ethernet interface connecting Core Router 1 to the internal network segment (VLAN 10)."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int .

noria:NetworkInterface3 a noria:NetworkInterface ;
    rdfs:label "Router1 Gi0/0/2"@en, "Gi0/0/2 du Routeur1"@fr ;
    rdfs:comment "Gigabit Ethernet interface connecting Core Router 1 to the Firewall Appliance (DMZ segment)."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "10"^^xsd:int .

noria:NetworkInterface4 a noria:NetworkInterface ;
    rdfs:label "Web Server Eth0"@en, "Eth0 du Serveur Web"@fr ;
    rdfs:comment "Ethernet interface for Web Application Server connectivity to the application network."@en ;
    noria:networkInterfaceOf noria:Resource3 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface5 a noria:NetworkInterface ;
    rdfs:label "Firewall Gi1/0"@en, "Gi1/0 du Pare-feu"@fr ;
    rdfs:comment "Gigabit Ethernet interface connecting Firewall to Core Router 1."@en ;
    noria:networkInterfaceOf noria:Resource5 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface6 a noria:NetworkInterface ;
    rdfs:label "Load Balancer Eth0"@en, "Eth0 du Répartiteur de Charge"@fr ;
    rdfs:comment "Ethernet interface for Load Balancer's external VIP."@en ;
    noria:networkInterfaceOf noria:Resource8 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface7 a noria:NetworkInterface ;
    rdfs:label "Storage Array FC0"@en, "FC0 de la Baie de Stockage"@fr ;
    rdfs:comment "Fibre Channel interface for Storage Array connectivity to database servers."@en ;
    noria:networkInterfaceOf noria:Resource9 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "0"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink1 a noria:NetworkLink ;
    rdfs:label "Primary DNS-Router Link"@en, "Lien DNS Principal-Routeur"@fr ;
    rdfs:comment "Internal network link between Primary DNS server and Core Router 1, carrying DNS traffic."@en ;
    noria:networkLinkId "LINK-DNS1-RTR-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource2 ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:networkInterfaceConnects noria:NetworkInterface1, noria:NetworkInterface2 .

noria:NetworkLink6 a noria:NetworkLink ;
    rdfs:label "Primary-Backup DNS Link"@en, "Lien DNS Principal-Secondaire"@fr ;
    rdfs:comment "WAN link for DNS zone transfers and synchronization between primary and backup DNS servers."@en ;
    noria:networkLinkId "LINK-DNS-SYNC-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource10 ;
    noria:networkLinkInstallationDate "2022-01-15T10:45:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN" ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:networkInterfaceConnects noria:NetworkInterface1, noria:NetworkInterface8 .

noria:NetworkLink2 a noria:NetworkLink ;
    rdfs:label "Router-Firewall Link"@en, "Lien Routeur-Pare-feu"@fr ;
    rdfs:comment "Critical link between Core Router 1 and Firewall Appliance, securing external access."@en ;
    noria:networkLinkId "LINK-RTR-FW-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource2 ;
    noria:networkLinkTerminationResourceDestination noria:Resource5 ;
    noria:networkLinkInstallationDate "2022-03-01T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:networkInterfaceConnects noria:NetworkInterface3, noria:NetworkInterface5 .

noria:NetworkLink3 a noria:NetworkLink ;
    rdfs:label "Web-DB Link"@en, "Lien Web-BDD"@fr ;
    rdfs:comment "Internal virtual link between Web Application Server and Database Server for application data exchange."@en ;
    noria:networkLinkId "LINK-WEB-DB-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource3 ;
    noria:networkLinkTerminationResourceDestination noria:Resource4 ;
    noria:networkLinkInstallationDate "2023-05-10T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:resourceManagedBy org:OrgUnit2 ;
    noria:networkInterfaceConnects noria:NetworkInterface4 . # Assuming DB server also has an interface, not explicitly defined here for brevity.

noria:NetworkLink4 a noria:NetworkLink ;
