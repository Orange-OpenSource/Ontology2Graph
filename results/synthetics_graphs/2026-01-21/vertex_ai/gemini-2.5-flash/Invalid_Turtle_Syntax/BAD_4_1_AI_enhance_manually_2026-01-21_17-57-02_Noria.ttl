bot:Site1 a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    rdfs:comment "Primary data center facility for corporate IT services, located in Metropolis."@en ;
    noria:siteId "DC-MAIN-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" ;
    wgs84_pos:lat "34.0522"^^xsd:float ;
    wgs84_pos:long "-118.2437"^^xsd:float .

noria:Room1 a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Dedicated room for server racks within the Main Data Center, climate-controlled and secured."@en ;
    bot:hasSpace noria:Locus1, noria:Locus3, noria:Locus4 ;
    seas:subSystemOf bot:Site1 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack 1, Unit 10"@en, "Baie 1, Unité 10"@fr ;
    rdfs:comment "Specific location for the Corporate DNS Server within Server Room A."@en ;
    noria:locusLine "Rack 1"@en ;
    noria:locusRow "Unit 10"@en ;
    seas:subSystemOf noria:Room1 .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack 2, Unit 5"@en, "Baie 2, Unité 5"@fr ;
    rdfs:comment "Location for Core Router 1 and Firewall Appliance."@en ;
    noria:locusLine "Rack 2"@en ;
    noria:locusRow "Unit 5"@en ;
    seas:subSystemOf noria:Room1 .

noria:Locus4 a noria:Locus ;
    rdfs:label "Rack 3, Unit 1-4"@en, "Baie 3, Unité 1-4"@fr ;
    rdfs:comment "Location for Web Application Server, Database Server, and Virtual Machine Host."@en ;
    noria:locusLine "Rack 3"@en ;
    noria:locusRow "Unit 1-4"@en ;
    seas:subSystemOf noria:Room1 .

bot:Site2 a bot:Site ;
    rdfs:label "Branch Office East"@en, "Bureau Régional Est"@fr ;
    rdfs:comment "Smaller office location with local network infrastructure and a backup DNS server."@en ;
    noria:siteId "BO-EAST-02" ;
    noria:siteType "branch office"@en ;
    noria:sitePrincipalAddress "456 Business Street"@en ;
    noria:sitePrincipalAddressCityName "Smallville"@en ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room2 a noria:Room ;
    rdfs:label "Network Closet"@en, "Local Réseau"@fr ;
    rdfs:comment "Small closet housing network equipment and local servers at Branch Office East."@en ;
    bot:hasSpace noria:Locus2 ;
    seas:subSystemOf bot:Site2 .

noria:Locus2 a noria:Locus ;
    rdfs:label "Wall Mount Rack, Unit 1"@en ;
    rdfs:comment "Location for the Backup DNS Server in the Network Closet."@en ;
    noria:locusLine "Wall Rack"@en ;
    noria:locusRow "Unit 1"@en ;
    seas:subSystemOf noria:Room2 .

