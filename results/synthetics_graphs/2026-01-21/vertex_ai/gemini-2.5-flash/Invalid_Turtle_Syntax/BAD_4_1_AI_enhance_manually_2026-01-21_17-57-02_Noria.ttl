# =============================================================================
# Operation Plans
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en, "Procédure de Basculement DNS"@fr ;
    rdfs:comment "Standard operating procedure for handling primary DNS server failures by activating the secondary DNS server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 ;
    pep:hasInput "Primary DNS server unreachability confirmed."@en ;
    pep:hasOutput "DNS resolution restored via secondary server."@en ;
    noria:elementManagedBy foaf:Agent1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Database Indexing Script Execution"@en, "Exécution Script d'Indexation Base de Données"@fr ;
    rdfs:comment "Procedure for optimizing database performance by running predefined indexing scripts during a maintenance window."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 ;
    pep:hasInput "Database load above threshold, slow query logs identified."@en ;
    pep:hasOutput "Database query times reduced, application performance improved."@en ;
    noria:elementManagedBy org:OrgUnit5 .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Storage Troubleshooting Guide"@en, "Guide de Dépannage Stockage"@fr ;
    rdfs:comment "Step-by-step guide for diagnosing and resolving performance issues on storage arrays."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition3 ;
    noria:operationPlanPostCondition noria:ActionPostCondition3 ;
    pep:hasInput "Storage latency high, IOPS low."@en ;
    pep:hasOutput "Storage performance within normal operating parameters."@en ;
    noria:elementManagedBy org:OrgUnit1 .

# =============================================================================
# Action Pre/Post Conditions
# =============================================================================

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "Secondary DNS Active and Healthy"@en, "DNS Secondaire Actif et Sain"@fr ;
    rdfs:comment "Condition: Secondary DNS server must be active, healthy, and responding to queries before initiating failover from primary."@en ;
    skos:example "Verify reachability and service health of dns02.corp.example.com." ;
    noria:elementManagedBy foaf:Agent1 .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored"@en, "Résolution DNS Rétablie"@fr ;
    rdfs:comment "Outcome: DNS resolution for corporate network is fully functional after failover, all internal services are reachable by hostname."@en ;
    skos:example "Confirm successful DNS resolution from multiple client machines and applications." ;
    noria:elementManagedBy foaf:Agent1 .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Database Load High"@en, "Charge Base de Données Élevée"@fr ;
    rdfs:comment "Condition: Database CPU or I/O utilization is consistently above 80% for more than 15 minutes, indicating performance issues."@en ;
    noria:elementManagedBy org:OrgUnit5 .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Database Query Time Reduced"@en, "Temps de Requête Base de Données Réduit"@fr ;
    rdfs:comment "Outcome: Average database query execution time is reduced by at least 30% and CPU utilization returns to normal levels."@en ;
    noria:elementManagedBy org:OrgUnit5 .

noria:ActionPreCondition3 a noria:ActionPreCondition ;
    rdfs:label "Storage Latency High"@en, "Latence Stockage Élevée"@fr ;
    rdfs:comment "Condition: Storage array latency consistently exceeds 20ms, impacting application responsiveness."@en ;
    noria:elementManagedBy org:OrgUnit1 .

noria:ActionPostCondition3 a noria:ActionPostCondition ;
    rdfs:label "Storage Latency Normal"@en, "Latence Stockage Normale"@fr ;
    rdfs:comment "Outcome: Storage array latency is consistently below 10ms, and IOPS are within expected range."@en ;
    noria:elementManagedBy org:OrgUnit1 .

# =============================================================================
# Anomaly Patterns
# =============================================================================

noria:AnomalyPattern1 a noria:AnomalyPattern ;
    rdfs:label "DNS Cache Poisoning Attempt"@en, "Tentative d'Empoisonnement du Cache DNS"@fr ;
    rdfs:comment "Pattern indicating a potential DNS cache poisoning attack, characterized by unusual DNS query responses, high traffic to DNS server, and unexpected DNS record changes."@en ;
    folio:hasCause "Malicious actor attempting to redirect traffic or disrupt services."@en ;
    noria:elementManagedBy foaf:Agent4 .

noria:AnomalyPattern2 a noria:AnomalyPattern ;
    rdfs:label "High Latency on Core Link"@en, "Latence Élevée sur Lien Cœur"@fr ;
    rdfs:comment "Pattern indicating network congestion or degradation on a core network link, characterized by increased ping times, packet loss, and bandwidth saturation."@en ;
    folio:hasCause "Over-utilization, faulty hardware, or misconfiguration."@en ;
    noria:elementManagedBy foaf:Agent2 .

noria:AnomalyPattern3 a noria:AnomalyPattern ;
    rdfs:label "Storage Controller Failure"@en, "Défaillance Contrôleur Stockage"@fr ;
    rdfs:comment "Pattern indicating a potential failure of a storage array controller, characterized by I/O errors, degraded performance, and controller status alerts."@en ;
    folio:hasCause "Hardware malfunction or firmware issue."@en ;
    noria:elementManagedBy org:OrgUnit1 .

