# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution for corporate services."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri (CET)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email to dns-support@example.com for non-critical issues. Pager for critical issues during off-hours."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en, "Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure, responding to alerts, and performing initial troubleshooting."@en ;
    noria:agentWorkingHours "24/7 rotational shifts"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline for immediate network issues. Use ticketing system for routine requests and escalations."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe de support applicatif"@fr ;
    rdfs:comment "Team responsible for maintaining and supporting business applications, including the Customer Portal and Internal CRM."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri (CET)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring, detecting, analyzing, and responding to cybersecurity incidents."@en ;
    noria:agentWorkingHours "24/7 rotational shifts"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

foaf:Person1 a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Senior Network Engineer, specialized in routing and switching, member of the Infrastructure Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri (CET)"@en .

foaf:Person2 a foaf:Person, foaf:Agent ;
    rdfs:label "Sarah Green"@en, "Sarah Verte"@fr ;
    rdfs:comment "DevOps Engineer, focusing on database performance and application deployment for the Customer Portal."@en ;
    foaf:mbox <mailto:sarah.green@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri (CET)"@en .

org:OrgUnit1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Infrastructure Team"@en, "Équipe Infrastructure"@fr ;
    rdfs:comment "Manages all core IT infrastructure components, including servers, routers, and firewalls."@en ;
    org:member foaf:Person1 ;
    noria:agentManagesResource noria:Resource2, noria:Resource5, noria:Resource6, noria:Resource8, noria:Resource9, noria:Resource10 .

org:OrgUnit2 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "DevOps Team A"@en, "Équipe DevOps A"@fr ;
    rdfs:comment "Responsible for the full lifecycle (development, deployment, operations) of the Customer Portal application."@en ;
    org:member foaf:Person2 ;
    noria:agentManagesResource noria:Resource3, noria:Resource4, noria:Resource7 ;
    noria:agentManagesResource noria:ApplicationModule2, noria:ApplicationModule5 .

org:OrgUnit3 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Customer Service Department"@en, "Service Client"@fr ;
    rdfs:comment "First line of contact for customer issues, responsible for initial triage and ticket creation."@en .

org:OrgUnit4 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Team"@en, "Équipe Sécurité"@fr ;
    rdfs:comment "Responsible for defining and enforcing security policies, and managing security infrastructure."@en ;
    noria:agentManagesResource noria:Resource5 .

org:OrgUnit5 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Admin Team"@en, "Équipe Administration Base de Données"@fr ;
    rdfs:comment "Specialized team managing all corporate database systems."@en ;
    noria:agentManagesResource noria:Resource4 .

noria:CorporateUserIdentifier1 a noria:CorporateUserIdentifier ;
    rdfs:label "jdoe_corp_id"@en ;
    rdfs:comment "Corporate user ID for John Doe, used for system access and logging."@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "jdoe_corp_id_123" ;
    foaf:holdsAccount foaf:Person1 .

noria:CorporateUserIdentifier2 a noria:CorporateUserIdentifier ;
    rdfs:label "sgreen_corp_id"@en ;
    rdfs:comment "Corporate user ID for Sarah Green."@en ;
    foaf:accountName "sgreen" ;
    observable:accountLogin "sgreen" ;
    observable:accountIdentifier "sgreen_corp_id_456" ;
    foaf:holdsAccount foaf:Person2 .

# =============================================================================
