# =============================================================================
# KOS Concept Schemes and Concepts
# =============================================================================

# --- Application KOS ---
<https://w3id.org/noria/kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Concept Scheme"@en ;
    rdfs:comment "Controlled vocabulary for types of applications."@en .
<https://w3id.org/noria/kos/application/type/infrastructure> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/type> ; rdfs:label "Infrastructure"@en .
<https://w3id.org/noria/kos/application/type/service-platform> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/type> ; rdfs:label "Service Platform"@en .
<https://w3id.org/noria/kos/application/type/business-application> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/type> ; rdfs:label "Business Application"@en .

<https://w3id.org/noria/kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Concept Scheme"@en ;
    rdfs:comment "Controlled vocabulary for business importance levels of applications."@en .
<https://w3id.org/noria/kos/application/business-importance/high> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ; rdfs:label "High"@en .
<https://w3id.org/noria/kos/application/business-importance/medium> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ; rdfs:label "Medium"@en .
<https://w3id.org/noria/kos/application/business-importance/low> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ; rdfs:label "Low"@en .

<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Status Concept Scheme"@en ;
    rdfs:comment "Controlled vocabulary for operational statuses of application modules."@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/status> ; rdfs:label "In Production"@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/status> ; rdfs:label "Development"@en .
<https://w3id.org/noria/kos/application/status/Staging> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/status> ; rdfs:label "Staging"@en .
<https://w3id.org/noria/kos/application/status/Decommissioned> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/status> ; rdfs:label "Decommissioned"@en .

<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Concept Scheme"@en ;
    rdfs:comment "Controlled vocabulary for Service Level Agreement levels of application modules."@en .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ; rdfs:label "Gold"@en .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ; rdfs:label "Silver"@en .
<https://w3id.org/noria/kos/application/sla-level/Bronze> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ; rdfs:label "Bronze"@en .

