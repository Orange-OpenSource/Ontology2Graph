# =============================================================================
# Procedural Elements (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition, noria:AnomalyPattern)
# =============================================================================

# Operation Plans
:OperationPlan_Router_Firmware_Upgrade_Procedure a noria:OperationPlan ;
    rdfs:label "Standard Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "A documented procedure for upgrading Cisco ASR series router firmware."@en ;
    noria:operationPlanPreCondition :PreCondition_Router_Reachability ;
    noria:operationPlanPostCondition :PostCondition_Router_Operational .

:OperationPlan_DB_Query_Optimization_Procedure a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries."@en ;
    noria:operationPlanPreCondition :PreCondition_DB_High_Load ;
    noria:operationPlanPostCondition :PostCondition_DB_Low_Load .

# Action Pre-Conditions
:PreCondition_Router_Reachability a noria:ActionPreCondition ;
    rdfs:label "Router Reachability Check"@en ;
    rdfs:comment "Verify that the router is reachable and has redundant paths before upgrade."@en .

:PreCondition_DB_High_Load a noria:ActionPreCondition ;
    rdfs:label "Database High Load Confirmation"@en ;
    rdfs:comment "Confirm that the database is experiencing high load before starting optimization."@en .

# Action Post-Conditions
:PostCondition_Router_Operational a noria:ActionPostCondition ;
    rdfs:label "Router Operational Verification"@en ;
    rdfs:comment "Verify router operational status, interface states, and routing after upgrade."@en .

:PostCondition_DB_Low_Load a noria:ActionPostCondition ;
    rdfs:label "Database Load Reduction Verification"@en ;
    rdfs:comment "Verify that database CPU and I/O load has decreased after optimization."@en .

# Anomaly Patterns
:AnomalyPattern_DNS_Network_Failure a noria:AnomalyPattern ;
    rdfs:label "DNS Network Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a DNS server is unreachable due to network issues, often correlated with interface flaps or link down events."@en ;
    folio:hasCause :EventRecord_Router_Interface_Flap ; # Simplified, linking to an event record as a cause.
    folio:hasEffect :TroubleTicket_DNS_Outage . # The effect is the outage.

:AnomalyPattern_DB_Performance_Degradation a noria:AnomalyPattern ;
    rdfs:label "Database Performance Degradation Pattern"@en ;
    rdfs:comment "Pattern indicating web application performance issues due to high database load."@en ;
    folio:hasCause :EventRecord_DB_High_CPU ;
    folio:hasEffect :TroubleTicket_WebApp_Performance .

# =============================================================================
# Additional Connections for Density
# =============================================================================

# Connect agents to resources they manage
:Agent_IT_Ops_Team noria:agentManagesResource :Resource_DNS_Server_01 .
:Agent_Network_Team noria:agentManagesResource :Resource_Router_Core_01, :NetworkLink_Internal_DC, :NetworkLink_External_ISP .
:Agent_App_Support_Team noria:agentManagesResource :Resource_VM_Web_App_01 .
:Agent_DB_Admin_Team noria:agentManagesResource :Resource_DB_Server_01 .

# Connect applications to resources
:Application_Corporate_DNS seas:subSystemOf :Resource_DNS_Server_01 .
:Application_WebApp_Portal seas:subSystemOf :Resource_VM_Web_App_01, :Resource_DB_Server_01 .
:Application_Core_Network seas:subSystemOf :Resource_Router_Core_01 .

# Connect application modules to resources (indirectly via application)
:ApplicationModule_DNS_Prod seas:subSystemOf :Resource_DNS_Server_01 .
:ApplicationModule_WebApp_Prod seas:subSystemOf :Resource_VM_Web_App_01, :Resource_DB_Server_01 .

# Connect TroubleTicket to EventRecord for status history
:TroubleTicket_DNS_Outage noria:documentStatusHistory :EventRecord_DNS_Down .
:TroubleTicket_WebApp_Performance noria:documentStatusHistory :EventRecord_DB_High_CPU .

# Connect ChangeRequest to EventRecord for status history (e.g., a log of the change execution)
:ChangeRequest_Router_Firmware_Upgrade noria:documentStatusHistory :EventRecord_Config_Change_Router .

# Connect OperationPlan to ChangeRequest
:ChangeRequest_Router_Firmware_Upgrade pep:usedProcedure :OperationPlan_Router_Firmware_Upgrade_Procedure .
:ChangeRequest_WebApp_DB_Optimization pep:usedProcedure :OperationPlan_DB_Query_Optimization_Procedure .

# Connect EventRecord to proposed repair action
:EventRecord_DNS_Down noria:alarmProposedRepairAction :OperationPlan_Router_Firmware_Upgrade_Procedure . # Example, might be a different procedure in reality.

# Connect EventRecord to mitigation
:EventRecord_DNS_Down noria:alarmMitigatedBy :TroubleTicket_DNS_Outage . # The TT is the container for the mitigation actions.

# Connect Network Interfaces to their operational status
:NetworkInterface_DNS_Eth0 noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .
:NetworkInterface_Router_Gi0_0_0 noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .
:NetworkInterface_Router_Gi0_0_1 noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .
:NetworkInterface_VM_Web_App_Eth0 noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# Example of network interface metrics
:NetworkInterface_Router_Gi0_0_1 noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

# Example of virtual server status
:Resource_VM_Web_App_01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Example of agent managing a service
:Agent_IT_Ops_Team noria:agentManagesResource :Service_Internet_Access .

# Example of agent managing an application module
:Agent_John_Doe noria:applicationModuleAdministrationLeader :ApplicationModule_DNS_Prod .
:Agent_Jane_Smith noria:applicationModuleAdministrationLeader :ApplicationModule_WebApp_Prod .

# Example of a corporate user identifier holding an account
:Agent_John_Doe foaf:holdsAccount :CUid_JohnDoe .
:Agent_Jane_Smith foaf:holdsAccount :CUid_JaneSmith .

# Example of an organizational unit having a member
:Agent_Network_Team org:hasMember :Agent_John_Doe .
:Agent_App_Support_Team org:hasMember :Agent_Jane_Smith .

# Example of a resource being part of a cluster (self-referential for simplicity)
