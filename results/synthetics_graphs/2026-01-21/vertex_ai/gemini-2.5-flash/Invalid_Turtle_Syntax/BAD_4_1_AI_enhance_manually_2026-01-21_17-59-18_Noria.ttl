# =============================================================================
# KOS Concepts (Knowledge Organization System)
# =============================================================================

# Application Types
<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/business-critical> a skos:Concept ; rdfs:label "Business Critical Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; rdfs:label "Monitoring Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/database> a skos:Concept ; rdfs:label "Database Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

# Application Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Staging> a skos:Concept ; rdfs:label "Staging"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

# Application SLA Level
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; rdfs:label "Silver SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# Service Types
<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .
<kos/service/type/InternalService> a skos:Concept ; rdfs:label "Internal Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .

# TroubleTicket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .

# TroubleTicket Type
