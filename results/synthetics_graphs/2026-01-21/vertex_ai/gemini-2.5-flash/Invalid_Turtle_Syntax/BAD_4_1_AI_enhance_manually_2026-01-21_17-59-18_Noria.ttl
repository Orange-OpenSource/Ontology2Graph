<kos/Notification/EventType/ConfigurationChange> a skos:Concept ; rdfs:label "Configuration Change Event"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/EventType> .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Informational> a skos:Concept ; rdfs:label "Informational Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email Contact Method"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone Contact Method"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; rdfs:label "Ticketing System Contact Method"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .

# =============================================================================
# Organizational Entities (foaf:Agent, org:Organization, noria:CorporateUserIdentifier)
# =============================================================================

# Agents (Teams and Individuals)
:Agent_IT_Ops_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For critical incidents, open a P1 ticket and call the on-call engineer."@en .

:Agent_Network_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team managing network infrastructure, including routers, switches, and firewalls."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for routine requests, ticketing system for incidents."@en .

:Agent_App_Support_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Sat"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

:Agent_DB_Admin_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database systems management and maintenance."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

:Agent_John_Doe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

:Agent_Jane_Smith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead Application Developer."@en ;
    foaf:mbox "mailto:jane.smith@example.com" .

# Corporate User Identifiers
:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount :Agent_John_Doe .

:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount :Agent_Jane_Smith .

# Organizations
:Org_ExampleCorp a org:Organization ;
    rdfs:label "Example Corporation"@en ;
    rdfs:comment "A fictional company operating various IT services."@en ;
    org:hasUnit :Agent_IT_Ops_Team, :Agent_Network_Team, :Agent_App_Support_Team, :Agent_DB_Admin_Team .

# =============================================================================
# Product Models
# =============================================================================

:ProductModel_Dell_R740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy :Org_Dell .

:ProductModel_Cisco_ASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Enterprise-class aggregation services router."@en ;
    noria:productManufacturedBy :Org_Cisco .

:ProductModel_Juniper_EX4600 a noria:ProductModel ;
    rdfs:label "Juniper EX4600 Switch"@en ;
    rdfs:comment "High-density 10GbE/40GbE data center switch."@en ;
    noria:productManufacturedBy :Org_Juniper .

:ProductModel_VMware_ESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor for virtualization."@en ;
    noria:productManufacturedBy :Org_VMware .

:Org_Dell a org:Organization ; rdfs:label "Dell Technologies"@en .
:Org_Cisco a org:Organization ; rdfs:label "Cisco Systems"@en .
:Org_Juniper a org:Organization ; rdfs:label "Juniper Networks"@en .
:Org_VMware a org:Organization ; rdfs:label "VMware Inc."@en .

# =============================================================================
# Location Entities (bot:Site, noria:Room, noria:Locus)
# =============================================================================

:Site_DC_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

:Room_ServerRoom_A a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace :Locus_Rack_A1, :Locus_Rack_A2 .

:Locus_Rack_A1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

:Locus_Rack_A2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of network equipment."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

# =============================================================================
# Structural Entities (noria:Resource, noria:NetworkInterface, noria:NetworkLink)
# =============================================================================

# Resources
:Resource_DNS_Server_01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, running on a physical machine."@en ;
    noria:resourceManagedBy :Agent_IT_Ops_Team ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication :Application_Corporate_DNS ;
    noria:locatedAtLocus :Locus_Rack_A1 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

:Resource_Router_Core_01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the data center, handling internal and external traffic."@en ;
    noria:resourceManagedBy :Agent_Network_Team ;
    noria:resourceHostName "cr01.dc-par-01.example.com" ;
    noria:resourceProductModel :ProductModel_Cisco_ASR1000 ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication :Application_Core_Network ;
    noria:locatedAtLocus :Locus_Rack_A2 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

:Resource_VM_Web_App_01 a noria:Resource ;
    rdfs:label "Web Application VM 01"@en ;
    rdfs:comment "Virtual machine hosting a critical web application."@en ;
    noria:resourceManagedBy :Agent_App_Support_Team ;
    noria:resourceHostName "webapp01.example.com" ;
    noria:resourceProductModel :ProductModel_VMware_ESXi ; # The hypervisor model, not the VM itself, but represents the underlying tech.
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication :Application_WebApp_Portal ;
    noria:locatedAtLocus :Locus_Rack_A1 ;
    noria:resourceManagementIPAddress "10.0.1.50" .

:Resource_DB_Server_01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Primary database server for the web application."@en ;
    noria:resourceManagedBy :Agent_DB_Admin_Team ;
    noria:resourceHostName "db01.example.com" ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceType <kos/Resource/type/Database> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-10T09:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication :Application_WebApp_Portal ;
    noria:locatedAtLocus :Locus_Rack_A1 ;
    noria:resourceManagementIPAddress "10.0.1.51" .

# Network Interfaces
:NetworkInterface_DNS_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0 on DNS Server 01"@en ;
    rdfs:comment "Primary network interface for DNS server."@en ;
    noria:networkInterfaceOf :Resource_DNS_Server_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

:NetworkInterface_Router_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on Core Router 01"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal network."@en ;
    noria:networkInterfaceOf :Resource_Router_Core_01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
