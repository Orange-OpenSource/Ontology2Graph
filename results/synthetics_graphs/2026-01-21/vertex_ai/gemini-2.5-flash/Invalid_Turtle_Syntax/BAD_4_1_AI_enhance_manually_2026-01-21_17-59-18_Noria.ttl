# TroubleTicket Priority
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .

# TroubleTicket Origin
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision System Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .

# TroubleTicket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> .

# TroubleTicket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/ManagedBackbone> a skos:Concept ; rdfs:label "Managed Backbone Responsibility"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ; rdfs:label "Internal IT Responsibility"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .

# TroubleTicket Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .

# TroubleTicket Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; rdfs:label "Resolution Operation"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .

# TroubleTicket Status
<kos/TroubleTicket/status/Initialised> a skos:Concept ; rdfs:label "Initialised"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .

# ChangeRequest Category
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .
<kos/ChangeRequest/category/NetworkExtension> a skos:Concept ; rdfs:label "Network Extension"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .

# ChangeRequest Type
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Normal> a skos:Concept ; rdfs:label "Normal Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .

