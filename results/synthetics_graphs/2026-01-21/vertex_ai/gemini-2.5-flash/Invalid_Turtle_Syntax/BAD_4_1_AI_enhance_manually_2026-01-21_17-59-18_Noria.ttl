# Event Records
:EventRecord_DNS_Down a noria:EventRecord ;
    rdfs:label "DNS Server 01 Down Alert"@en ;
    rdfs:comment "Alert indicating that Corporate DNS Server 01 is unreachable."@en ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:loggingTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DNS_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "Host dns01.corp.example.com is DOWN."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_Router_Interface_Flap a noria:EventRecord ;
    rdfs:label "Router Interface Flap Alert"@en ;
    rdfs:comment "Alert indicating that GigabitEthernet0/0/1 on Core Router 01 flapped."@en ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:loggingTime "2024-04-20T08:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Router_Core_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "Interface GigabitEthernet0/0/1 on cr01.dc-par-01.example.com changed state to down/up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:EventRecord_DB_High_CPU a noria:EventRecord ;
    rdfs:label "Database High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Database Server 01."@en ;
    dcterms:type <kos/Notification/EventType/ThresholdExceeded> ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "CPU utilization on db01.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:EventRecord_Config_Change_Router a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change made on Core Router 01."@en ;
    dcterms:type <kos/Notification/EventType/ConfigurationChange> ;
    noria:loggingTime "2024-04-19T23:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Router_Core_01 ;
    noria:logOriginatingAgent :Agent_John_Doe ;
    noria:logText "Configuration changed by jdoe: added static route for 192.168.5.0/24."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

