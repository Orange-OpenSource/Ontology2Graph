# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OpPlan_RestartInterface a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a network interface on a router."@en ;
    noria:operationPlanPreCondition noria:PreCond_InterfaceDown ;
    noria:operationPlanPostCondition noria:PostCond_InterfaceUp .

noria:PreCond_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: The network interface's operational status is 'down'."@en .

noria:PostCond_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Outcome: The network interface's operational status is 'up' and traffic is flowing."@en .

noria:OpPlan_CheckWebServerLoad a noria:OperationPlan ;
    rdfs:label "Check Web Server Load Procedure"@en ;
    rdfs:comment "Procedure to diagnose high CPU/load on a web server."@en ;
    noria:operationPlanPreCondition noria:PreCond_HighCPULoad ;
    noria:operationPlanPostCondition noria:PostCond_LoadNormalized .

noria:PreCond_HighCPULoad a noria:ActionPreCondition ;
    rdfs:label "High CPU Load on Server"@en ;
    rdfs:comment "Condition: Server CPU utilization exceeds threshold."@en .

noria:PostCond_LoadNormalized a noria:ActionPostCondition ;
    rdfs:label "Server Load Normalized"@en ;
    rdfs:comment "Outcome: Server CPU utilization returns to normal levels."@en .

noria:OpPlan_SecurityResponse a noria:OperationPlan ;
    rdfs:label "Security Incident Response Plan"@en ;
    rdfs:comment "Standard operating procedure for responding to security incidents."@en ;
    noria:operationPlanPreCondition noria:PreCond_SecurityAlert ;
    noria:operationPlanPostCondition noria:PostCond_ThreatContained .

noria:PreCond_SecurityAlert a noria:ActionPreCondition ;
    rdfs:label "Security Alert Triggered"@en ;
    rdfs:comment "Condition: A security alert with critical or major severity has been triggered."@en .

noria:PostCond_ThreatContained a noria:ActionPostCondition ;
    rdfs:label "Threat Contained"@en ;
    rdfs:comment "Outcome: The security threat has been contained and mitigated."@en .

noria:OpPlan_DeployConfig a noria:OperationPlan ;
    rdfs:label "Deploy Web Server Configuration"@en ;
    rdfs:comment "Procedure for deploying new configuration to web servers."@en ;
    noria:operationPlanPreCondition noria:PreCond_ConfigValidated ;
    noria:operationPlanPostCondition noria:PostCond_ConfigActive .

noria:PreCond_ConfigValidated a noria:ActionPreCondition ;
    rdfs:label "Configuration Validated"@en ;
    rdfs:comment "Condition: New configuration has passed validation tests."@en .

noria:PostCond_ConfigActive a noria:ActionPostCondition ;
    rdfs:label "Configuration Active"@en ;
    rdfs:comment "Outcome: New configuration is active and services are running normally."@en .

noria:OpPlan_HardwareReplace a noria:OperationPlan ;
    rdfs:label "Hardware Replacement Procedure"@en ;
    rdfs:comment "Standard operating procedure for replacing faulty hardware components."@en ;
    noria:operationPlanPreCondition noria:PreCond_FaultyHardware ;
    noria:operationPlanPostCondition noria:PostCond_HardwareReplaced .

noria:PreCond_FaultyHardware a noria:ActionPreCondition ;
    rdfs:label "Faulty Hardware Identified"@en ;
    rdfs:comment "Condition: Diagnostic tests confirm a hardware component is faulty."@en .

noria:PostCond_HardwareReplaced a noria:ActionPostCondition ;
    rdfs:label "Hardware Replaced and Verified"@en ;
    rdfs:comment "Outcome: Faulty hardware replaced, system operational, and verified."@en .

noria:OpPlan_PatchDeployment a noria:OperationPlan ;
    rdfs:label "Security Patch Deployment Procedure"@en ;
    rdfs:comment "Standard operating procedure for deploying security patches."@en ;
    noria:operationPlanPreCondition noria:PreCond_PatchAvailable ;
    noria:operationPlanPostCondition noria:PostCond_PatchApplied .

noria:PreCond_PatchAvailable a noria:ActionPreCondition ;
    rdfs:label "Security Patch Available"@en ;
    rdfs:comment "Condition: A validated security patch is available for deployment."@en .

noria:PostCond_PatchApplied a noria:ActionPostCondition ;
    rdfs:label "Security Patch Applied"@en ;
    rdfs:comment "Outcome: Security patch applied, system rebooted (if necessary), and services verified."@en .

noria:AnomalyPattern_WANOutage a noria:AnomalyPattern ;
    rdfs:label "WAN Outage Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a WAN outage: multiple critical interface down events on core routers, correlated with customer complaints about external connectivity."@en .

noria:AnomalyPattern_BruteForce a noria:AnomalyPattern ;
    rdfs:label "Brute Force Attack Pattern"@en ;
    rdfs:comment "Pattern indicating a brute force attack: multiple failed login attempts from a single or distributed source within a short period."@en .

noria:AnomalyPattern_HardwareFailure a noria:AnomalyPattern ;
    rdfs:label "Hardware Failure Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a hardware failure: repeated interface flapping, high error rates, or component specific alerts."@en .

noria:AnomalyPattern_AppError a noria:AnomalyPattern ;
    rdfs:label "Application Error Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating application errors: repeated 5xx HTTP responses, high error logs, or service unavailability."@en .

