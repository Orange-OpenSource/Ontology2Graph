    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.1" ;
    noria:resourceLogisticId "LOG-RC01-001" .

noria:Resource_SwitchDist01 a noria:Resource ;
    rdfs:label "Distribution Switch 01"@en ;
    rdfs:comment "Distribution layer switch for server farm."@en ;
    noria:resourceManagedBy noria:OrgUnit_NetworkOps ;
    noria:agentManagesResource noria:Resource_SwitchDist01 ;
