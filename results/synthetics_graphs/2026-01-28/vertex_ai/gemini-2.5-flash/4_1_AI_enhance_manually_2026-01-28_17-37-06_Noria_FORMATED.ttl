noria:Resource_VMwareVCenter a noria:Resource ;
    rdfs:label "VMware vCenter Server"@en ;
    rdfs:comment "Virtualization management platform."@en ;
    noria:resourceManagedBy noria:OrgUnit_NetworkOps ;
