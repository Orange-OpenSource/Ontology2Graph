noria:TroubleTicketNote_TT001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT001"@en ;
    rdfs:comment "Initial check shows no response from DNS01. Pinging 192.168.1.10 fails. Checking router CR01 for interface status."@en ;
