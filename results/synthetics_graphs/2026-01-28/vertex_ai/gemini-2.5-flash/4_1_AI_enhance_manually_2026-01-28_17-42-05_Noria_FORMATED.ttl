### Agents and Organizations
noria:Org_ITDept a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department responsible for all IT operations."@en ;
    org:hasUnit noria:OrgUnit_NetworkOps, noria:OrgUnit_AppDev, noria:OrgUnit_SecurityOps, noria:OrgUnit_DBATeam .

noria:OrgUnit_NetworkOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    org:unitOf noria:Org_ITDept ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for non-critical issues, phone for critical incidents."@en .

noria:OrgUnit_AppDev a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    org:unitOf noria:Org_ITDept ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

noria:OrgUnit_SecurityOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:unitOf noria:Org_ITDept ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

noria:OrgUnit_DBATeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database management."@en ;
    org:unitOf noria:Org_ITDept ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

noria:Agent_JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Network Engineer, member of Network Operations Team."@en ;
    org:memberOf noria:OrgUnit_NetworkOps ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    foaf:topic_interest noria:Resource_RouterCore1, noria:Application_DNSService .

noria:Agent_JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Lead, member of Application Development Team."@en ;
    org:memberOf noria:OrgUnit_AppDev ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    foaf:topic_interest noria:Application_CorpWebsite, noria:Resource_VMWeb01 .

noria:Agent_PeterJones a foaf:Person, foaf:Agent ;
    rdfs:label "Peter Jones"@en ;
    rdfs:comment "Database Administrator, member of Database Administration Team."@en ;
    org:memberOf noria:OrgUnit_DBATeam ;
    foaf:mbox <mailto:peter.jones@example.com> ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    foaf:topic_interest noria:Application_DatabaseService, noria:Resource_DBServer01 .

noria:Agent_ExternalCustomer a foaf:Agent ;
    rdfs:label "External Customer A"@en ;
    rdfs:comment "A representative of a key external customer."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    foaf:topic_interest noria:Service_CustomerPortal .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount noria:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount noria:Agent_JaneSmith .

### Product Models
noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    dcterms:description "A versatile server for various workloads."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of IT hardware."@en .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series."@en ;
    dcterms:description "High-density, high-performance data center switch."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    dcterms:description "Industry-leading bare-metal hypervisor."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

### Locations
noria:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the data center."@en ;
    bot:hasSubSpace noria:Locus_RackA1, noria:Locus_RackA2 .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

### Resources
noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted on a physical machine."@en ;
    noria:elementDistinguishedName "dns01.corp.example.com" ;
    noria:resourceManagedBy noria:OrgUnit_NetworkOps ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "192.168.1.10" ;
    noria:resourceForApplication noria:Application_DNSService, noria:Application_MonitoringSystem .

noria:Resource_RouterCore1 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Main router for the corporate backbone network."@en ;
    noria:elementDistinguishedName "cr01.corp.example.com" ;
    noria:resourceManagedBy noria:OrgUnit_NetworkOps ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR01-ABC" ;
