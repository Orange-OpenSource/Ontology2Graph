### Operation Plans, Pre/Post Conditions, Anomaly Patterns
noria:OperationPlan_CheckFiber a noria:OperationPlan ;
    rdfs:label "Check Fiber Optic Link Procedure"@en ;
    rdfs:comment "Standard operating procedure to diagnose fiber optic link issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FiberLinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FiberLinkRestored .

noria:ActionPreCondition_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'down' and no administrative shutdown is active."@en .

noria:ActionPostCondition_FiberLinkRestored a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored Post-Condition"@en ;
    rdfs:comment "Outcome: Network interface operational status is 'up' and traffic flow is normal."@en .

noria:AnomalyPattern_HighCPUUsage a noria:AnomalyPattern ;
    rdfs:label "High CPU Usage Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage on a server, potentially leading to performance degradation."@en ;
    folio:hasCause noria:OperationPlan_DiagnoseHighCPU .

noria:OperationPlan_DiagnoseHighCPU a noria:OperationPlan ;
    rdfs:label "Diagnose High CPU Usage Procedure"@en ;
    rdfs:comment "Procedure to identify root cause of high CPU utilization on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_HighCPUAlert ;
    noria:operationPlanPostCondition noria:ActionPostCondition_CPUUsageNormal .

noria:ActionPreCondition_HighCPUAlert a noria:ActionPreCondition ;
    rdfs:label "High CPU Alert Pre-Condition"@en ;
    rdfs:comment "Condition: Monitoring system reports CPU usage > 90% for 15 minutes."@en .

noria:ActionPostCondition_CPUUsageNormal a noria:ActionPostCondition ;
    rdfs:label "CPU Usage Normal Post-Condition"@en ;
    rdfs:comment "Outcome: CPU usage returns to normal levels (< 50%) for 30 minutes."@en .

### Document Attachments
noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram DC01"@en ;
    rdfs:comment "PDF document showing the network topology of Data Center 01."@en ;
    dcterms:isPartOf noria:ChangeRequest_CR001_RouterUpgrade ;
    dcterms:format "application/pdf" ;
    dcterms:source "https://docs.example.com/network_diagram_dc01.pdf" .

noria:DocumentAttachment_TroubleTicketScreenshot a noria:DocumentAttachment ;
    rdfs:label "Screenshot of DNS Outage"@en ;
    rdfs:comment "Screenshot from monitoring system showing DNS server unreachable."@en ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage_TT001 ;
    dcterms:format "image/png" ;
    dcterms:source "https://monitoring.example.com/screenshots/dns_outage_20240410.png" .
