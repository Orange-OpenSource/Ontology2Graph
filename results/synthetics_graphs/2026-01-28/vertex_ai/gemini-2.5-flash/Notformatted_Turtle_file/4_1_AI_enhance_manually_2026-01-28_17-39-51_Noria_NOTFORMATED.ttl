    rdfs:comment "Team responsible for managing and optimizing database systems."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Contact via internal chat for urgent database issues. Submit tickets for routine maintenance."@en ;
    org:unitOf :Org_ITDept .

