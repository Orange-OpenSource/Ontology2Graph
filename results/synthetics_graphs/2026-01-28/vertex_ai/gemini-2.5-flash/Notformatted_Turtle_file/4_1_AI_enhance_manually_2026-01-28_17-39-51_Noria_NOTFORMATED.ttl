    dcterms:isPartOf :TT_20240420_001 ;
    noria:troubleTicketNoteCorrelatedExecution :OpPlan_InterfaceTroubleshoot_Execution .

:TTN_20240420_002_01 a noria:TroubleTicketNote ;
    rdfs:label "DB Query Optimization for TT-20240420-002"@en ;
    rdfs:comment "First note on TT-20240420-002: Identified slow query 'SELECT * FROM large_table WHERE status = 'active''. Applied index to 'status' column. Performance improved."@en ;
