# =============================================================================
# Event Records
# =============================================================================

:Event_WebSrv01_CPUHigh a noria:EventRecord ;
    rdfs:label "WebSrv01 CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01, potentially impacting performance."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logText "CPU utilization on websrv01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:Event_CoreRtr01_InterfaceDown a noria:EventRecord ;
    rdfs:label "CoreRtr01 Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a network interface on Core Router 01 went down, causing a network outage."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_CoreRtr01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logText "Interface Gi0/0/1 on corertr01.corp.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction :OpPlan_InterfaceTroubleshoot .

:Event_Firewall01_LoginFail a noria:EventRecord ;
    rdfs:label "Firewall01 Failed Login Attempt"@en ;
    rdfs:comment "Security event: multiple failed login attempts on Firewall 01, indicating a potential brute-force attack."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Firewall01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logOriginatingAgent :Person_Charlie ; # Could be a user trying to log in, or a system account
    noria:logText "Multiple failed login attempts detected for user 'admin' on fw01.corp.example.com from IP 192.168.1.100."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:Event_DB01_DiskFull a noria:EventRecord ;
    rdfs:label "DB01 Disk Full Alert"@en ;
    rdfs:comment "Alert indicating that a disk on Database Server 01 is nearly full, risking service interruption."@en ;
    noria:loggingTime "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DB01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logText "Disk usage on /var/lib/mysql on db01.corp.example.com is at 95%."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:Event_LoadBalancer01_HealthCheckFail a noria:EventRecord ;
    rdfs:label "Load Balancer Health Check Failure"@en ;
    rdfs:comment "Alert indicating that a health check for a backend server failed on Load Balancer 01."@en ;
    noria:loggingTime "2024-04-20T10:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_LoadBalancer01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logText "Health check failed for backend server websrv01.corp.example.com on Load Balancer 01."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

