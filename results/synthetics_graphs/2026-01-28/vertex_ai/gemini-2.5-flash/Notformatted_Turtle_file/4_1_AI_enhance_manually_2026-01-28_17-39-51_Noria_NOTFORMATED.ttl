:Org_ITDept a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department of the company."@en ;
    org:hasUnit :Team_NetOps, :Team_AppDev, :Team_SecOps, :Team_DBA .

:Team_NetOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call emergency line for critical issues. Use ticketing system for standard requests."@en ;
    org:unitOf :Org_ITDept .

:Team_AppDev a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for non-critical issues, use ticketing system for bugs and feature requests."@en ;
    org:unitOf :Org_ITDept .

:Team_SecOps a org:OrganizationalUnit, foaf:Agent ;
