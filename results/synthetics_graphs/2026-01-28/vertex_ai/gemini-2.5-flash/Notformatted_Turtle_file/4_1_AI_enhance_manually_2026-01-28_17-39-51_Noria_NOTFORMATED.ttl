    dcterms:isPartOf :TT_20240420_002 .

:TTN_20240420_002_02 a noria:TroubleTicketNote ;
    rdfs:label "Disk Cleanup for TT-20240420-002"@en ;
    rdfs:comment "Second note on TT-20240420-002: Performed cleanup of old logs and temporary files on DB01. Disk usage now at 70%."@en ;
