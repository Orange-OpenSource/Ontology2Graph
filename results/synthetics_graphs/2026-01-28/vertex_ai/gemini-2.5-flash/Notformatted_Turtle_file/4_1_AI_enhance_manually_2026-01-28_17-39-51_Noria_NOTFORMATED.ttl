# =============================================================================
# KOS Concepts (Knowledge Organization System)
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Applications providing core infrastructure services."@en .

<kos/application/type/business-critical> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Critical Application"@en ;
    rdfs:comment "Applications essential for core business operations."@en .

<kos/application/type/monitoring> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "Applications used for system monitoring and alerting."@en .

<kos/application/type/database> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Database Application"@en ;
    rdfs:comment "Applications providing database services."@en .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

<kos/application/business-importance/high> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for business continuity."@en .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application supports important but not immediately critical business functions."@en .

<kos/application/business-importance/low> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Low Business Importance"@en ;
    rdfs:comment "Application supports non-critical business functions."@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Maintenance"@en ;
    rdfs:comment "The application module is undergoing maintenance and may be unavailable."@en .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Development"@en ;
    rdfs:comment "The application module is under active development."@en .

# TroubleTicket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Service is completely down or severely impacted, requiring immediate attention."@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant service degradation or partial outage."@en .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor"@en ;
    rdfs:comment "Minor issue, service still functional but with some impact."@en .

<kos/TroubleTicket/severity/Informational> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Informational"@en ;
    rdfs:comment "No immediate impact, for information purposes."@en .

# TroubleTicket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of trouble tickets."@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Indicates a system or component failure."@en .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Request for user assistance or information."@en .

<kos/TroubleTicket/type/Inquiry> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Inquiry"@en ;
    rdfs:comment "General question or request for information."@en .

# TroubleTicket Priority
<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A scheme for classifying the priority of trouble tickets."@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1 (Highest)"@en ;
    rdfs:comment "Highest priority, immediate resolution required."@en .

<kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2 (High)"@en ;
    rdfs:comment "High priority, urgent resolution."@en .

<kos/TroubleTicket/priority/P3> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 3 (Medium)"@en ;
    rdfs:comment "Medium priority, standard resolution time."@en .

<kos/TroubleTicket/priority/P4> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 4 (Low)"@en ;
    rdfs:comment "Low priority, non-urgent resolution."@en .

# TroubleTicket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Ticket initiated by a customer."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System Origin"@en ;
    rdfs:comment "Ticket initiated by an automated monitoring system."@en .

<kos/TroubleTicket/origin/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Internal Origin"@en ;
    rdfs:comment "Ticket initiated by an internal team member."@en .

# TroubleTicket Urgency
<kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A scheme for classifying the urgency of trouble tickets."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action."@en .

<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Action can be deferred."@en .

# TroubleTicket Category
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the category of trouble tickets."@en .

<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Network Outage"@en ;
    rdfs:comment "Category for network-related service interruptions."@en .

<kos/TroubleTicket/trouble-category/ServerFailure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Server Failure"@en ;
    rdfs:comment "Category for server hardware or software failures."@en .

<kos/TroubleTicket/trouble-category/SoftwareBug> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Software Bug"@en ;
    rdfs:comment "Category for issues caused by software defects."@en .

# TroubleTicket Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying the responsibility for a problem."@en .

<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Internal IT Department"@en ;
    rdfs:comment "Responsibility lies with the internal IT department."@en .

<kos/TroubleTicket/problemResponsibility/ExternalVendor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "External Vendor"@en ;
    rdfs:comment "Responsibility lies with an external vendor or service provider."@en .

# TroubleTicket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of trouble tickets."@en .

<kos/TroubleTicket/status/Initialised> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Initialised"@en ;
    rdfs:comment "Ticket has been created."@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Ticket is actively being worked on."@en .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "Ticket has been resolved."@en .

<kos/TroubleTicket/status/Closed> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Closed"@en ;
    rdfs:comment "Ticket has been closed."@en .

# TroubleTicket Note Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of comments in trouble ticket notes."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team members."@en .

<kos/TroubleTicket/commentType/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer Comment"@en ;
    rdfs:comment "Comment from or for the customer."@en .

# TroubleTicket Note Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of operation recorded in trouble ticket notes."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Operation related to diagnosing the problem."@en .

<kos/TroubleTicket/operationType/Resolution> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Resolution Operation"@en ;
    rdfs:comment "Operation related to resolving the problem."@en .

<kos/TroubleTicket/operationType/Communication> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Communication Operation"@en ;
    rdfs:comment "Operation related to communicating with stakeholders."@en .

# ChangeRequest Category
<kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the category of change requests."@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request for internal IT team intervention."@en .

<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change request for software version upgrade."@en .

<kos/ChangeRequest/category/HardwareReplacement> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Hardware Replacement"@en ;
    rdfs:comment "Change request for replacing hardware components."@en .

# ChangeRequest Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of change requests."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Pre-approved, low-risk change."@en .

<kos/ChangeRequest/type/Normal> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Normal Change"@en ;
    rdfs:comment "Requires assessment and authorization."@en .

<kos/ChangeRequest/type/Emergency> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Emergency Change"@en ;
    rdfs:comment "Urgent change to resolve a critical incident."@en .

# ChangeRequest Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying the cause of change requests."@en .

<kos/ChangeRequest/cause/Configuration> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change due to configuration modification."@en .

<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Preventative Maintenance"@en ;
    rdfs:comment "Change for preventative maintenance."@en .

<kos/ChangeRequest/cause/ProblemResolution> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Problem Resolution"@en ;
    rdfs:comment "Change to resolve an identified problem."@en .

# ChangeRequest Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the status of change requests."@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "Change request has been approved."@en .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "Change request has been implemented."@en .

<kos/ChangeRequest/status/Scheduled> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Scheduled"@en ;
    rdfs:comment "Change request is scheduled for implementation."@en .

# ChangeRequest Specification
<kos/ChangeRequest/specification> a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    rdfs:comment "A scheme for classifying the specification of change requests."@en .

<kos/ChangeRequest/specification/StandardOperationProcedure> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Standard Operation Procedure"@en ;
    rdfs:comment "Change follows a defined standard operating procedure."@en .

<kos/ChangeRequest/specification/CustomScript> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Custom Script"@en ;
    rdfs:comment "Change implemented via a custom script."@en .

