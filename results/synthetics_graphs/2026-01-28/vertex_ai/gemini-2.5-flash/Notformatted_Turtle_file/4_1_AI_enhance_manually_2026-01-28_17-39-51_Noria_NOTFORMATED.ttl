# =============================================================================
# Operations and Procedures
# =============================================================================

:OpPlan_InterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues, including physical checks and configuration verification."@en ;
    noria:operationPlanPreCondition :PreCond_InterfaceDown ;
    noria:operationPlanPostCondition :PostCond_InterfaceUp .

:PreCond_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Interface is Down"@en ;
    rdfs:comment "Condition: Network interface operational status is 'down' or 'degraded'."@en ;
    skos:example "Check 'show interface status' command output or monitoring system alerts."@en .

:PostCond_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Interface is Up and Stable"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up' and traffic flows normally, with no errors."@en ;
    skos:example "Verify 'show interface status', ping tests, and traffic counters."@en .

:OpPlan_DBQueryOptimization a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing slow database queries to improve application performance."@en ;
    noria:operationPlanPreCondition :PreCond_SlowDBQueries ;
    noria:operationPlanPostCondition :PostCond_DBPerformanceImproved .

:PreCond_SlowDBQueries a noria:ActionPreCondition ;
    rdfs:label "Slow Database Queries Detected"@en ;
    rdfs:comment "Condition: Application performance monitoring reports slow database query execution times or high database load."@en .

:PostCond_DBPerformanceImproved a noria:ActionPostCondition ;
    rdfs:label "Database Performance Improved"@en ;
    rdfs:comment "Expected outcome: Database query execution times are within acceptable thresholds and application response times are normal."@en .

:OpPlan_DiskCleanup a noria:OperationPlan ;
    rdfs:label "Server Disk Cleanup Procedure"@en ;
    rdfs:comment "Procedure for safely cleaning up disk space on servers to prevent storage exhaustion."@en ;
    noria:operationPlanPreCondition :PreCond_DiskSpaceLow ;
    noria:operationPlanPostCondition :PostCond_DiskSpaceFreed .

:PreCond_DiskSpaceLow a noria:ActionPreCondition ;
    rdfs:label "Low Disk Space Alert"@en ;
    rdfs:comment "Condition: Monitoring system reports disk usage above a critical threshold."@en .

:PostCond_DiskSpaceFreed a noria:ActionPostCondition ;
    rdfs:label "Sufficient Disk Space Available"@en ;
    rdfs:comment "Expected outcome: Disk usage is below the warning threshold after cleanup."@en .

# Procedure Execution Container for the interface troubleshoot
:OpPlan_InterfaceTroubleshoot_Execution a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Interface Troubleshooting for TT-20240420-001"@en ;
    rdfs:comment "Container for the actions taken during the troubleshooting of the network interface related to TT-20240420-001, including SFP replacement."@en ;
    pep:usedProcedure :OpPlan_InterfaceTroubleshoot ;
    noria:alarmMitigatedBy :TT_20240420_001 . # Linking the execution container to the TT it helped mitigate

:OpPlan_DBOptimization_Execution a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of DB Query Optimization for TT-20240420-002"@en ;
    rdfs:comment "Container for the actions taken during the database query optimization related to TT-20240420-002."@en ;
    pep:usedProcedure :OpPlan_DBQueryOptimization ;
    noria:alarmMitigatedBy :TT_20240420_002 .

# =============================================================================
# Anomaly Patterns
# =============================================================================

:AnomalyPattern_HighCPUNetworkOutage a noria:AnomalyPattern ;
    rdfs:label "High CPU leading to Network Outage Pattern"@en ;
    rdfs:comment "Anomaly pattern where sustained high CPU utilization on a core router precedes a network interface going down, indicating potential hardware or software issues."@en ;
    folio:hasCause :Event_WebSrv01_CPUHigh ; # Example of a potential cause event
    folio:hasEffect :Event_CoreRtr01_InterfaceDown . # Example of a resulting effect event

:AnomalyPattern_FailedLoginBruteForce a noria:AnomalyPattern ;
    rdfs:label "Brute Force Login Attempt Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating multiple failed login attempts from a single source IP within a short period, suggesting a brute-force attack."@en ;
    folio:hasCause :Event_Firewall01_LoginFail .

:AnomalyPattern_DiskFullPerformanceDegradation a noria:AnomalyPattern ;
    rdfs:label "Disk Full leading to Performance Degradation Pattern"@en ;
    rdfs:comment "Anomaly pattern where low disk space on a database server leads to performance degradation and slow queries."@en ;
    folio:hasCause :Event_DB01_DiskFull ;
    folio:hasEffect :TT_20240420_002 . # The trouble ticket itself can be an effect

