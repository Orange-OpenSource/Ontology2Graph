<https://w3id.org/noria/kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    rdfs:label "Decommissioned Lifecycle State"@en ;
    skos:prefLabel "État de Cycle de Vie Décommissionné"@fr .

# KOS Concepts for Resource Operational State
<https://w3id.org/noria/kos/Resource/OperationalState/Up> a skos:Concept ;
    rdfs:label "Operational State Up"@en ;
    skos:prefLabel "État Opérationnel Actif"@fr .

<https://w3id.org/noria/kos/Resource/OperationalState/Down> a skos:Concept ;
    rdfs:label "Operational State Down"@en ;
    skos:prefLabel "État Opérationnel Inactif"@fr .

# KOS Concepts for Resource Administrative State
<https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> a skos:Concept ;
    rdfs:label "Administrative State Enabled"@en ;
    skos:prefLabel "État Administratif Activé"@fr .

<https://w3id.org/noria/kos/Resource/AdministrativeState/Disabled> a skos:Concept ;
    rdfs:label "Administrative State Disabled"@en ;
    skos:prefLabel "État Administratif Désactivé"@fr .

# KOS Concepts for Notification Severity
<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    rdfs:label "Critical Perceived Severity"@en ;
    skos:prefLabel "Sévérité Perçue Critique"@fr .

<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    rdfs:label "Major Perceived Severity"@en ;
    skos:prefLabel "Sévérité Perçue Majeure"@fr .

<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ;
    rdfs:label "Minor Perceived Severity"@en ;
    skos:prefLabel "Sévérité Perçue Mineure"@fr .

# KOS Concepts for ChangeRequest Type
<https://w3id.org/noria/kos/ChangeRequest/type/Standard> a skos:Concept ;
    rdfs:label "Standard Change Type"@en ;
    skos:prefLabel "Type de Changement Standard"@fr .

<https://w3id.org/noria/kos/ChangeRequest/type/Emergency> a skos:Concept ;
    rdfs:label "Emergency Change Type"@en ;
    skos:prefLabel "Type de Changement d'Urgence"@fr .

# KOS Concepts for ChangeRequest Status
<https://w3id.org/noria/kos/ChangeRequest/status/Approved> a skos:Concept ;
    rdfs:label "Approved Change Status"@en ;
    skos:prefLabel "Statut de Changement Approuvé"@fr .

<https://w3id.org/noria/kos/ChangeRequest/status/Implemented> a skos:Concept ;
    rdfs:label "Implemented Change Status"@en ;
    skos:prefLabel "Statut de Changement Implémenté"@fr .

# KOS Concepts for ChangeRequest Cause
<https://w3id.org/noria/kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    rdfs:label "Software Upgrade Cause"@en ;
    skos:prefLabel "Cause Mise à Jour Logicielle"@fr .

<https://w3id.org/noria/kos/ChangeRequest/cause/Configuration> a skos:Concept ;
    rdfs:label "Configuration Change Cause"@en ;
    skos:prefLabel "Cause Changement de Configuration"@fr .

# KOS Concepts for Agent Contact Method
<https://w3id.org/noria/kos/org/agent-contact-method/Email> a skos:Concept ;
    rdfs:label "Email Contact Method"@en ;
    skos:prefLabel "Méthode de Contact Email"@fr .

<https://w3id.org/noria/kos/org/agent-contact-method/Phone> a skos:Concept ;
    rdfs:label "Phone Contact Method"@en ;
    skos:prefLabel "Méthode de Contact Téléphone"@fr .

# KOS Concepts for Service Type
<https://w3id.org/noria/kos/service/type/CustomerFacingService> a skos:Concept ;
    rdfs:label "Customer Facing Service"@en ;
    skos:prefLabel "Service Orienté Client"@fr .

<https://w3id.org/noria/kos/service/type/ResourceFacingService> a skos:Concept ;
    rdfs:label "Resource Facing Service"@en ;
    skos:prefLabel "Service Orienté Ressource"@fr .

################################################################################
# Agents and Organizations
# Entities representing people, teams, and corporate structures.
################################################################################

# Agents (Teams and Individuals)
foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email dnsteam@example.com for non-urgent issues. For critical issues, use the ticketing system and call the hotline."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always open a P1 ticket and call the NOC hotline."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for DNS Services."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource noria:Resource_DNS01 .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network Engineer, responsible for core routing."@en ;
    noria:agentWorkingHours "08:30-17:30 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentManagesResource noria:Resource_RouterCore01 .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe"@en ;
    observable:accountLogin "jdoe"@en ;
    observable:accountIdentifier "jdoe-corp-id-12345"@en ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith"@en ;
    observable:accountLogin "jsmith"@en ;
    observable:accountIdentifier "jsmith-corp-id-67890"@en ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

# Organizations
org:ExampleCorp a org:Organization ;
    rdfs:label "Example Corporation"@en ;
    rdfs:comment "The main organization."@en .

org:ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The Information Technology Department of Example Corp."@en ;
    org:unitOf org:ExampleCorp .

org:NOC a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "The Network Operations Center, part of the IT Department."@en ;
    org:unitOf org:ITDepartment ;
    org:member foaf:Agent_NetworkOpsTeam .

org:AppSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support"@en ;
    rdfs:comment "Application Support Unit, part of the IT Department."@en ;
    org:unitOf org:ITDepartment ;
    org:member foaf:Agent_AppDevTeam .

org:DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

org:CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

org:JuniperNetworks a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en .

################################################################################
# Product Models
# Definitions of hardware product models.
################################################################################

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing and virtualization."@en ;
    noria:productManufacturedBy org:DellTechnologies .

noria:ProductModel_CiscoASR1K a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "High-end router series for enterprise and service provider edge."@en ;
    noria:productManufacturedBy org:CiscoSystems .

noria:ProductModel_JuniperEX4600 a noria:ProductModel ;
    rdfs:label "Juniper EX4600 Switch"@en ;
    rdfs:comment "High-performance, compact 10/40GbE solution for data center top-of-rack and aggregation deployments."@en ;
    noria:productManufacturedBy org:JuniperNetworks .

################################################################################
# Locations
# Physical locations of resources.
################################################################################

bot:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@fr ;
    noria:sitePrincipalAddressCityName "Paris"@fr ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within Paris Data Center."@en ;
    bot:containsZone noria:Locus_RackA1 .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

################################################################################
# Resources
# Physical or virtual IT assets.
################################################################################

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ789" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
    noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main core router for the corporate network, located in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1K ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC123" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Web server hosting the corporate website."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB01-DEF456" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.20" .

noria:Resource_SwitchAccess01 a noria:Resource ;
    rdfs:label "Access Switch 01"@en ;
    rdfs:comment "Access layer switch for Server Room A."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "sw-acc01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperEX4600 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-SW01-GHI789" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.5" .

################################################################################
# Network Interfaces and Links
# Connectivity components of the IT infrastructure.
################################################################################

# Network Interfaces
noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Primary network interface for DNS services."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface_RouterCore01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to ISP A."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 .

noria:NetworkInterface_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Internal network interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Connection to internal LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkInterface_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Primary network interface for web services."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface_SwitchAccess01_Port1 a noria:NetworkInterface ;
    rdfs:label "SwitchAccess01 Port 1"@en ;
    rdfs:comment "Port 1 on Access Switch 01, connected to DNS01."@en ;
    noria:networkInterfaceOf noria:Resource_SwitchAccess01 ;
    noria:networkInterfaceDescription "Connection to DNS01."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

# Network Links
noria:NetworkLink_DNS01_Switch a noria:NetworkLink ;
    rdfs:label "DNS01 to Access Switch Link"@en ;
    rdfs:comment "Network link connecting DNS01 to Access Switch 01."@en ;
    noria:networkLinkId "NL-DNS01-SW01-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_SwitchAccess01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_SwitchAccess01_Port1 .

noria:NetworkLink_RouterCore01_ISP_Uplink a noria:NetworkLink ;
    rdfs:label "RouterCore01 ISP Uplink"@en ;
    rdfs:comment "Uplink from Core Router 01 to ISP A."@en ;
    noria:networkLinkId "NL-RTR01-ISP-01" ;
