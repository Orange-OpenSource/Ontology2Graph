<https://w3id.org/noria/kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    rdfs:label "Supervision Origin"@en ;
    skos:prefLabel "Origine Supervision"@fr .

# KOS Concepts for TroubleTicket Status
<https://w3id.org/noria/kos/TroubleTicket/status/InProgress> a skos:Concept ;
    rdfs:label "In Progress"@en ;
    skos:prefLabel "En Cours"@fr .

<https://w3id.org/noria/kos/TroubleTicket/status/Resolved> a skos:Concept ;
    rdfs:label "Resolved"@en ;
    skos:prefLabel "Résolu"@fr .

<https://w3id.org/noria/kos/TroubleTicket/status/Closed> a skos:Concept ;
    rdfs:label "Closed"@en ;
    skos:prefLabel "Fermé"@fr .

# KOS Concepts for TroubleTicket Comment Type
<https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    rdfs:label "Internal Comment"@en ;
    skos:prefLabel "Commentaire Interne"@fr .

<https://w3id.org/noria/kos/TroubleTicket/commentType/Customer> a skos:Concept ;
    rdfs:label "Customer Comment"@en ;
    skos:prefLabel "Commentaire Client"@fr .

# KOS Concepts for TroubleTicket Operation Type
<https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    rdfs:label "Diagnosis Operation"@en ;
    skos:prefLabel "Opération de Diagnostic"@fr .

<https://w3id.org/noria/kos/TroubleTicket/operationType/Repair> a skos:Concept ;
    rdfs:label "Repair Operation"@en ;
    skos:prefLabel "Opération de Réparation"@fr .

# KOS Concepts for Resource Type
<https://w3id.org/noria/kos/Resource/type/Server> a skos:Concept ;
    rdfs:label "Server Resource Type"@en ;
    skos:prefLabel "Type de Ressource Serveur"@fr .

<https://w3id.org/noria/kos/Resource/type/Router> a skos:Concept ;
    rdfs:label "Router Resource Type"@en ;
    skos:prefLabel "Type de Ressource Routeur"@fr .

<https://w3id.org/noria/kos/Resource/type/Switch> a skos:Concept ;
    rdfs:label "Switch Resource Type"@en ;
