################################################################################
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# Procedural elements for IT operations and incident diagnosis.
################################################################################

# Operation Plans
noria:OperationPlan_CheckFiber a noria:OperationPlan ;
    rdfs:label "Check Fiber Optic Link Procedure"@en ;
    rdfs:comment "Standard operating procedure to diagnose and troubleshoot fiber optic link issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FiberLinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FiberLinkRestored .

noria:OperationPlan_RestartDNS a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en ;
    rdfs:comment "Procedure to restart the DNS service on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSServiceUnresponsive ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSServiceRunning ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_RestartDNS . # Self-referential for completeness, or could point to a parent plan.

noria:OperationPlan_WebSrvOptimize a noria:OperationPlan ;
    rdfs:label "Web Server Performance Optimization Procedure"@en ;
    rdfs:comment "Procedure to optimize web server configuration and resource allocation."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebSrvHighCPU ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebSrvCPUOK .

# Action Pre-Conditions
noria:ActionPreCondition_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: Network interface operational status is 'down' and no administrative shutdown is active."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Down> AND noria:networkInterfaceAdministrativeStatus = <kos/Resource/AdministrativeState/Enabled>" .

noria:ActionPreCondition_DNSServiceUnresponsive a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unresponsive Pre-Condition"@en ;
    rdfs:comment "Condition: DNS server is unreachable or DNS queries are failing."@en ;
    skos:example "noria:Resource_DNS01.virtualServerStatus = <kos/Resource/OperationalState/Down> OR DNS queries fail." .

noria:ActionPreCondition_WebSrvHighCPU a noria:ActionPreCondition ;
    rdfs:label "Web Server High CPU Pre-Condition"@en ;
    rdfs:comment "Condition: Web server CPU utilization exceeds a predefined threshold."@en ;
    skos:example "noria:EventRecord_WebSrvHighCPU indicates CPU > 90%." .

# Action Post-Conditions
noria:ActionPostCondition_FiberLinkRestored a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored Post-Condition"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up'."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Up>" .

noria:ActionPostCondition_DNSServiceRunning a noria:ActionPostCondition ;
    rdfs:label "DNS Service Running Post-Condition"@en ;
    rdfs:comment "Expected outcome: DNS server is reachable and DNS queries are successful."@en ;
    skos:example "noria:Resource_DNS01.virtualServerStatus = <kos/Resource/OperationalState/Up> AND DNS queries succeed." .

noria:ActionPostCondition_WebSrvCPUOK a noria:ActionPostCondition ;
    rdfs:label "Web Server CPU Normal Post-Condition"@en ;
    rdfs:comment "Expected outcome: Web server CPU utilization returns to normal levels."@en ;
    skos:example "Web server CPU utilization < 50%." .

# Anomaly Patterns
noria:AnomalyPattern_DNSFailure a noria:AnomalyPattern ;
    rdfs:label "DNS Service Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a DNS service failure: DNS server unreachable combined with high DNS query timeouts."@en ;
    skos:example "Multiple noria:EventRecord instances showing 'DNS server unreachable' and 'DNS query timeout' from different monitoring points." .

noria:AnomalyPattern_NetworkLinkDegradation a noria:AnomalyPattern ;
    rdfs:label "Network Link Degradation Pattern"@en ;
    rdfs:comment "Pattern indicating a network link degradation: high error rates or low optical power on a network interface."@en ;
    skos:example "noria:networkInterfaceLaserRxOpticalPower below noria:networkInterfaceLaserRxLowPowerWarningThreshold." .
