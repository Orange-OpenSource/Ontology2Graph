################################################################################
# Event Records
# Logs and notifications from IT systems.
################################################################################

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Outage Log"@en ;
    rdfs:comment "Log entry indicating DNS server unreachability."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    log:time "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: DNS server dns01.corp.example.com is unreachable via ICMP."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on the core router went down."@en ;
    noria:loggingTime "2024-04-23T10:03:00Z"^^xsd:dateTime ;
    log:time "2024-04-23T10:03:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINK-3-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckFiber .

noria:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on the core router."@en ;
    noria:loggingTime "2024-04-22T15:30:00Z"^^xsd:dateTime ;
    log:time "2024-04-22T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JaneSmith ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jsmith (10.0.0.5)."@en ;
    pep:hasSimpleResult "Configuration applied successfully."@en .

noria:EventRecord_DNSAdminAction a noria:EventRecord ;
    rdfs:label "DNS Admin Action Log - Restart Service"@en ;
    rdfs:comment "Log entry for an action taken by DNS Admin Team to restart DNS service."@en ;
    noria:loggingTime "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    log:time "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Executed 'systemctl restart named' on dns01.corp.example.com."@en ;
    pep:hasSimpleResult "DNS service restarted."@en ;
    noria:alarmMitigatedBy noria:TroubleTicket_DNSOutage .

noria:EventRecord_WebSrvHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on the corporate web server."@en ;
    noria:loggingTime "2024-04-23T14:10:00Z"^^xsd:dateTime ;
    log:time "2024-04-23T14:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "ALERT: High CPU usage (95%) on web01.corp.example.com for last 5 minutes."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Minor> .

