Voici un graphe de connaissances complet, dense et connecté, modélisé en syntaxe Turtle, en respectant strictement le vocabulaire NORIA fourni.

@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix time: <http://www.w3.org/2006/time#> .

################################################################################
# KOS (Knowledge Organization System) Concepts
# These concepts are used as controlled vocabularies for various properties.
################################################################################

# KOS Concepts for Application Types
<https://w3id.org/noria/kos/application/type/infrastructure> a skos:Concept ;
    rdfs:label "Infrastructure Application"@en ;
    skos:prefLabel "Application d'Infrastructure"@fr .

<https://w3id.org/noria/kos/application/type/business-critical> a skos:Concept ;
    rdfs:label "Business Critical Application"@en ;
    skos:prefLabel "Application Critique Métier"@fr .

<https://w3id.org/noria/kos/application/type/monitoring> a skos:Concept ;
    rdfs:label "Monitoring Application"@en ;
    skos:prefLabel "Application de Supervision"@fr .

# KOS Concepts for Application Business Importance
<https://w3id.org/noria/kos/application/business-importance/high> a skos:Concept ;
    rdfs:label "High Business Importance"@en ;
    skos:prefLabel "Importance Métier Élevée"@fr .

<https://w3id.org/noria/kos/application/business-importance/medium> a skos:Concept ;
    rdfs:label "Medium Business Importance"@en ;
    skos:prefLabel "Importance Métier Moyenne"@fr .

# KOS Concepts for Application Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    rdfs:label "In Production"@en ;
    skos:prefLabel "En Production"@fr .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    rdfs:label "Development"@en ;
    skos:prefLabel "En Développement"@fr .

# KOS Concepts for TroubleTicket Severity
<https://w3id.org/noria/kos/TroubleTicket/severity/Critical> a skos:Concept ;
    rdfs:label "Critical Severity"@en ;
    skos:prefLabel "Sévérité Critique"@fr .

<https://w3id.org/noria/kos/TroubleTicket/severity/Major> a skos:Concept ;
    rdfs:label "Major Severity"@en ;
    skos:prefLabel "Sévérité Majeure"@fr .

<https://w3id.org/noria/kos/TroubleTicket/severity/Minor> a skos:Concept ;
    rdfs:label "Minor Severity"@en ;
    skos:prefLabel "Sévérité Mineure"@fr .

# KOS Concepts for TroubleTicket Type
<https://w3id.org/noria/kos/TroubleTicket/type/Failure> a skos:Concept ;
    rdfs:label "Failure Ticket"@en ;
    skos:prefLabel "Ticket de Panne"@fr .

<https://w3id.org/noria/kos/TroubleTicket/type/Assistance> a skos:Concept ;
    rdfs:label "Assistance Ticket"@en ;
    skos:prefLabel "Ticket d'Assistance"@fr .

# KOS Concepts for TroubleTicket Origin
<https://w3id.org/noria/kos/TroubleTicket/origin/Customer> a skos:Concept ;
    rdfs:label "Customer Origin"@en ;
