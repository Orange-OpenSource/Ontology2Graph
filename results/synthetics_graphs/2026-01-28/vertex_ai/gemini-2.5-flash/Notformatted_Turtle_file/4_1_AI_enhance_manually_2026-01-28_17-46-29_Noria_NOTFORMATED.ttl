:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy :Org_Dell .

:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series."@en ;
    noria:productManufacturedBy :Org_Cisco .

:ProductModel_JuniperMX a noria:ProductModel ;
    rdfs:label "Juniper MX Series"@en ;
    rdfs:comment "Edge routing platform."@en ;
    noria:productManufacturedBy :Org_Juniper .

:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi"@en ;
    rdfs:comment "Type-1 hypervisor for virtual machines."@en ;
    noria:productManufacturedBy :Org_VMware .

:ProductModel_PaloAltoFirewall a noria:ProductModel ;
