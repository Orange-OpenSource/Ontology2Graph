# =============================================================================
# Operations and Anomaly Patterns
# =============================================================================

:OpPlan_RouterInterfaceRestart a noria:OperationPlan ;
    rdfs:label "Router Interface Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a router interface."@en ;
    noria:operationPlanPreCondition :PreCond_InterfaceDown ;
    noria:operationPlanPostCondition :PostCond_InterfaceUp .

:PreCond_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Interface is Down"@en ;
    rdfs:comment "Condition: Network interface operational status is 'down'."@en .

:PostCond_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Interface is Up"@en ;
    rdfs:comment "Expected outcome: Network interface operational status is 'up' and traffic flows."@en .

:OpPlan_RouterUpgrade a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading router software."@en ;
    noria:operationPlanPreCondition :PreCond_BackupComplete ;
    noria:operationPlanPostCondition :PostCond_UpgradeSuccess .

:PreCond_BackupComplete a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup Complete"@en ;
    rdfs:comment "Condition: Router configuration backup must be completed before upgrade."@en .

:PostCond_UpgradeSuccess a noria:ActionPostCondition ;
    rdfs:label "Upgrade Successful and Verified"@en ;
    rdfs:comment "Expected outcome: Router software upgraded, services verified, and no regressions."@en .

:OpPlan_DBDiskExpansion a noria:OperationPlan ;
    rdfs:label "Database Disk Expansion Procedure"@en ;
    rdfs:comment "Procedure for adding disk space to a database server."@en ;
    noria:operationPlanPreCondition :PreCond_DBBackupComplete ;
    noria:operationPlanPostCondition :PostCond_DBSpaceIncreased .

:PreCond_DBBackupComplete a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete"@en ;
    rdfs:comment "Condition: Full database backup must be completed before disk expansion."@en .

:PostCond_DBSpaceIncreased a noria:ActionPostCondition ;
    rdfs:label "Database Space Increased and Verified"@en ;
    rdfs:comment "Expected outcome: Disk space increased, database operational, and performance maintained."@en .

:AnomalyPattern_HighCPU a noria:AnomalyPattern ;
    rdfs:label "High CPU Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization on a server, potentially leading to performance degradation or outage."@en ;
    skos:example "CPU > 90% for 15 minutes, followed by increased latency."@en ;
    folio:hasCause :Event_WebSrvHighCPU .

:AnomalyPattern_DiskFull a noria:AnomalyPattern ;
    rdfs:label "Disk Full Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating critical disk space usage, potentially leading to application failures."@en ;
    skos:example "Disk usage > 95% for 1 hour."@en ;
    folio:hasCause :Event_DBDiskFull .

# Example of linking an EventRecord to a proposed repair action (OperationPlan)
:Event_InterfaceDown noria:alarmProposedRepairAction :OpPlan_RouterInterfaceRestart .
:Event_DBDiskFull noria:alarmProposedRepairAction :OpPlan_DBDiskExpansion .

# Example of linking a TroubleTicket to an AnomalyPattern
:TT_WebSrvCPU_002 dcterms:relation :AnomalyPattern_HighCPU .
:TT_DBDiskFull_003 dcterms:relation :AnomalyPattern_DiskFull .

# Example of linking a ChangeRequest to an OperationPlan via an action
:Action_RouterUpgrade_Execute a pep:ProcedureExecution ;
    rdfs:label "Execute Router Upgrade"@en ;
    dcterms:created "2023-11-01T02:05:00Z"^^xsd:dateTime ;
    pep:usedProcedure :OpPlan_RouterUpgrade ;
    pep:madeBy :Team_NetworkOps ;
    pep:hasSimpleResult "Router software upgraded successfully." ;
    dcterms:isPartOf :CR_RouterUpgrade_001 .

:Action_DBExpansion_Execute a pep:ProcedureExecution ;
    rdfs:label "Execute DB Disk Expansion"@en ;
    dcterms:created "2023-11-15T22:30:00Z"^^xsd:dateTime ;
    pep:usedProcedure :OpPlan_DBDiskExpansion ;
    pep:madeBy :Team_DBA ;
    pep:hasSimpleResult "Database disk expanded successfully." ;
    dcterms:isPartOf :CR_DBExpansion_002 .

# Document Attachments
:Doc_RouterConfigBackup a noria:DocumentAttachment ;
    rdfs:label "Router Core 01 Config Backup"@en ;
    rdfs:comment "Configuration backup file for Core Router 01 before upgrade."@en ;
    dcterms:created "2023-10-31T23:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf :CR_RouterUpgrade_001 ;
    dcterms:format "application/octet-stream" .

:Doc_DBExpansionPlan a noria:DocumentAttachment ;
    rdfs:label "Database Disk Expansion Plan"@en ;
    rdfs:comment "Detailed plan for database disk space expansion."@en ;
    dcterms:created "2023-10-27T10:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf :CR_DBExpansion_002 ;
    dcterms:format "application/pdf" .

# Additional connections for density
:Resource_DNS01 noria:agentManagesResource :Team_NetworkOps .
:Resource_WebSrv01 noria:agentManagesResource :Team_AppDev .
:Resource_DB01 noria:agentManagesResource :Team_DBA .

:App_CorpInternetAccess noria:elementManagedBy :Team_NetworkOps .
:App_MainBusinessApp noria:elementManagedBy :Team_AppDev .
:App_CorporateDatabase noria:elementManagedBy :Team_DBA .

:Service_EnterpriseVPN noria:elementManagedBy :Team_NetworkOps .
:Service_DatabaseAccess noria:elementManagedBy :Team_DBA .

:TT_DNSOutage_001 noria:troubleTicketSupervisionTool "Nagios" .
:TT_WebSrvCPU_002 noria:troubleTicketSupervisionTool "Prometheus" .

:CR_RouterUpgrade_001 noria:documentExternalId "EXT-REF-SWUPG-001" .

# Link a TroubleTicket to a ChangeRequest if it was a result of a previous change or requires a change.
# For example, if the DNS outage was caused by a faulty previous change.
# Or if the high CPU requires a change to the application code.
:TT_WebSrvCPU_002 dcterms:relation :CR_DBExpansion_002 . # Example: High CPU might lead to a recommendation for DB expansion.

# Link an EventRecord to a TroubleTicketNote as a correlated execution
:Event_WebSrvHighCPU noria:alarmMitigatedBy :TTNote_WebSrvCPU_002_01 .

# Link a ChangeRequest to an EventRecord if the change itself generated logs
:CR_RouterUpgrade_001 dcterms:relation :Event_ConfigChange_Alice . # Alice's config change was part of the CR.

