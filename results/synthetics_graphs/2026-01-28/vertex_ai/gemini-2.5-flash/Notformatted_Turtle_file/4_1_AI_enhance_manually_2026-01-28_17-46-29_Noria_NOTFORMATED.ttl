    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ;
    noria:troubleTicketNoteCorrelatedExecution :Event_ConfigChange_Alice .

:TTNote_WebSrvCPU_002_01 a noria:TroubleTicketNote ;
