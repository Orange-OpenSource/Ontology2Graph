# =============================================================================
# Agents and Organizations
# =============================================================================

:Org_ITDept a org:Organization ;
    rdfs:label "IT Department"@en, "Département Informatique"@fr ;
    rdfs:comment "The main IT department responsible for all IT operations."@en ;
    org:hasUnit :Team_NetworkOps, :Team_AppDev, :Team_SecurityOps, :Team_DBA .

:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

:Org_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

:Team_NetworkOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call emergency hotline for critical network issues."@en ;
    org:unitOf :Org_ITDept .

:Team_AppDev a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development Team"@en, "Équipe Développement Applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for non-critical issues, use ticketing system for bugs."@en ;
    org:unitOf :Org_ITDept .

:Team_SecurityOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Team"@en, "Équipe Opérations Sécurité"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate escalation for critical security alerts."@en ;
    org:unitOf :Org_ITDept .

:Team_DBA a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en, "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Team responsible for database management and performance."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for urgent database issues."@en ;
    org:unitOf :Org_ITDept .

:Person_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    org:memberOf :Team_NetworkOps .

:Person_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf :Team_AppDev .

:Person_CarolWhite a foaf:Person, foaf:Agent ;
    rdfs:label "Carol White"@en ;
    rdfs:comment "Database Administrator."@en ;
    foaf:mbox <mailto:carol.white@example.com> ;
    org:memberOf :Team_DBA .

:CUid_AliceSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount :Person_AliceSmith .

:CUid_BobJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount :Person_BobJohnson .

