# =============================================================================
# Event Records
# =============================================================================

:Event_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DNS01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:Event_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2023-10-26T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:Event_ConfigChange_Alice a noria:EventRecord ;
    rdfs:label "Configuration Change by Alice Smith"@en ;
    rdfs:comment "Log entry for a configuration change performed by Alice Smith on Core Router 01."@en ;
    noria:loggingTime "2023-10-26T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_RouterCore01 ;
    noria:logOriginatingAgent :Person_AliceSmith ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by asmith (10.0.0.5)." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

:Event_WebSrvHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2023-10-26T11:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logText "ALERT: websrv01.corp.example.com CPU utilization > 90% for 5 minutes." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:Event_DBDiskFull a noria:EventRecord ;
    rdfs:label "Database Disk Full Warning"@en ;
    rdfs:comment "Warning indicating database server disk space is critically low."@en ;
    noria:loggingTime "2023-10-26T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DB01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logText "WARNING: db01.corp.example.com /data partition 95% full." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:Event_VMHostMemoryLeak a noria:EventRecord ;
    rdfs:label "VM Host Memory Leak Alert"@en ;
    rdfs:comment "Alert indicating a memory leak on VMware ESXi Host 01."@en ;
    noria:loggingTime "2023-10-26T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_VMHost01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logText "ALERT: vmhost01.corp.example.com memory usage steadily increasing, potential leak." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

# =============================================================================
# Trouble Tickets
# =============================================================================

:TT_DNSOutage_001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Critical incident: Corporate DNS server is unreachable, impacting internet access."@en ;
    dcterms:identifier "TT-20231026-001" ;
    dcterms:created "2023-10-26T09:01:00Z"^^xsd:dateTime ;
    dcterms:modified "2023-10-26T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network connectivity issue to DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2023-10-26T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2023-10-26T10:50:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2023-10-26T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketRelatedParty :Team_NetworkOps, :Person_AliceSmith ;
    noria:troubleTicketRelatedService :App_CorpInternetAccess, :Service_EnterpriseVPN ;
    noria:troubleTicketRelatedResource :Resource_DNS01, :Resource_RouterCore01 ;
    noria:troubleTicketTrigger :Event_DNSOutageLog ;
    noria:documentHRef "https://itsm.example.com/tt/TT-20231026-001" ;
    noria:documentStatusHistory :Event_TT_DNSOutage_StatusChange_Initial, :Event_TT_DNSOutage_StatusChange_InProgress, :Event_TT_DNSOutage_StatusChange_Resolved ;
    noria:troubleTicketImpacts :Resource_DNS01, :App_CorpInternetAccess .

:Event_TT_DNSOutage_StatusChange_Initial a noria:EventRecord ;
