# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Interface Troubleshooting"@en ;
    rdfs:comment "Standard operating procedure for troubleshooting DNS server network interfaces."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "Interface Down Condition"@en ;
    rdfs:comment "Condition: Network interface reports 'down' status."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "Interface Up and Pings Successful"@en ;
    rdfs:comment "Outcome: Network interface reports 'up' status and basic connectivity tests are successful."@en .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Database Performance Optimization"@en ;
    rdfs:comment "Procedure for identifying and resolving database performance bottlenecks."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "High Database Load Condition"@en ;
    rdfs:comment "Condition: Database server CPU/memory utilization is consistently high, and application response times are slow."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Database Load Normalized and Application Responsive"@en ;
    rdfs:comment "Outcome: Database server metrics return to normal, and application response times are restored."@en .

noria:AnomalyPattern1 a noria:AnomalyPattern ;
    rdfs:label "DNS Resolution Failure Pattern"@en ;
    rdfs:comment "Pattern indicating a DNS resolution failure: DNS server interface down, followed by client DNS query timeouts."@en ;
    folio:hasCause noria:EventRecord1 . # This anomaly pattern is caused by EventRecord1

# Example of linking an action to an operation plan (assuming a corrective action within a TT)
# This would typically be an instance of pep:ProcedureExecution or a subclass.
# For simplicity, let's assume a conceptual link here.
noria:TroubleTicketNote1 noria:troubleTicketNoteCorrelatedExecution noria:OperationPlan1 . # Conceptual link, in reality it would be a pep:ProcedureExecutionContainer

