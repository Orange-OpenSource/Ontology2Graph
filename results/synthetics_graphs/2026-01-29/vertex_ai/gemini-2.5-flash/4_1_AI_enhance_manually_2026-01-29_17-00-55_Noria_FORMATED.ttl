    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "Internet Connectivity"@en .

noria:Application2 a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:comment "Web application for customer self-service."@en ;
    noria:applicationType <kos/application/type/business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "CUST-PORTAL-APP" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CPORTAL" ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Self-Service"@en .

noria:Application3 a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "Application for monitoring network devices and services."@en ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationModelIdentifier "NMS-APP" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Network Performance Monitoring"@en .

noria:Resource1 noria:resourceForApplication noria:Application1 . # DNS server supports internet access
noria:Resource2 noria:resourceForApplication noria:Application1 . # Edge router supports internet access
noria:Resource3 noria:resourceForApplication noria:Application2 . # Web server supports customer portal
noria:Resource4 noria:resourceForApplication noria:Application2 . # DB server supports customer portal
noria:Resource5 noria:resourceForApplication noria:Application1 . # Branch office switch supports internet access
noria:Resource7 noria:resourceForApplication noria:Application1 . # Virtual DNS server supports internet access

