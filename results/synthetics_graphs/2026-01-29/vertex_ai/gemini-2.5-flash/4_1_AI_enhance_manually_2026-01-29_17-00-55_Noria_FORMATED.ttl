    noria:locusLine "Rack 12"@en ;
    noria:locusRow "Unit 23"@en ;
    bot:hasSpace noria:Room1 .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack 5, Unit 1"@en ;
    rdfs:comment "Specific location for router rtr-edge-01."@en ;
    noria:locusLine "Rack 5"@en ;
    noria:locusRow "Unit 1"@en ;
    bot:hasSpace noria:Room1 .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack 3, Unit 10"@en ;
    rdfs:comment "Specific location for webserver web01.corp.example.com."@en ;
    noria:locusLine "Rack 3"@en ;
    noria:locusRow "Unit 10"@en ;
    bot:hasSpace noria:Room1 .

noria:Locus4 a noria:Locus ;
    rdfs:label "Network Cabinet 1, Shelf 2"@en ;
    rdfs:comment "Location for switch sw-paris-01."@en ;
    noria:locusLine "Cabinet 1"@en ;
    noria:locusRow "Shelf 2"@en ;
    bot:hasSpace noria:Room2 .

# =============================================================================
# Resources
# =============================================================================

noria:Resource1 a noria:Resource ;
    rdfs:label "Corporate DNS Server"@en ;
    rdfs:comment "Primary DNS server for corporate network."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
