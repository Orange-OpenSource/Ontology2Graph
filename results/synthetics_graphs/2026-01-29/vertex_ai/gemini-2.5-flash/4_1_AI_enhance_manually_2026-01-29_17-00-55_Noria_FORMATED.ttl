    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ; # Assuming Configuration exists
    noria:changeRequestImpact noria:Resource5, noria:NetworkLink3, noria:ApplicationModule1 ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ; # 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RoutineMaintenance> ;
    noria:changeRequestInitiatorParty foaf:Agent2 ;
    noria:changeRequestPilotParty foaf:Agent2 ;
    noria:changeRequestActorParty foaf:Agent2 ;
    noria:changeRequestIsRegulated false .

# Document Attachments
noria:DocumentAttachment1 a noria:DocumentAttachment ;
    rdfs:label "Network Diagram DC01"@en ;
    rdfs:comment "PDF document showing the network topology of Data Center 01."@en ;
    dcterms:identifier "DOC-NET-DC01-V1.2" ;
    dcterms:created "2023-10-01T10:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TroubleTicket1, noria:ChangeRequest2 ;
