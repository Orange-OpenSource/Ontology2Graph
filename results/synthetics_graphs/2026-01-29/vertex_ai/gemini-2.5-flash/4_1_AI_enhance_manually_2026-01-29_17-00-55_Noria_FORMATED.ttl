    rdfs:comment "Regional office in Paris."@en ;
    noria:siteId "PAR01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

noria:Room1 a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within DC01."@en ;
    bot:hasSpace bot:Site1 .

noria:Room2 a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in Branch Office Paris."@en ;
    bot:hasSpace bot:Site2 .

noria:Locus1 a noria:Locus ;
