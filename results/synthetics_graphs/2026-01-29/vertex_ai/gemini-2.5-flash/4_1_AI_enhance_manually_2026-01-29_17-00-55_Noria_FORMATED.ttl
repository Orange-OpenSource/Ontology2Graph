# =============================================================================
# Dynamic Elements: Trouble Tickets, Event Records, Change Requests
# =============================================================================

# Trouble Tickets
noria:TroubleTicket1 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "DNS server unreachable causing internet access issues."@en ;
    dcterms:identifier "TT-20240320-001" ;
    dcterms:created "2024-03-20T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-03-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios NMS"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network interface down on primary DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-03-20T08:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-03-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent1, foaf:Agent2 ;
    noria:troubleTicketRelatedService noria:ApplicationModule1 ;
    noria:troubleTicketRelatedResource noria:Resource1 ;
    noria:troubleTicketImpacts noria:Application1, noria:Resource1, noria:NetworkLink2 .

noria:TroubleTicket2 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Slow Performance"@en ;
    rdfs:comment "Customers reporting slow loading times for the portal."@en ;
    dcterms:identifier "TT-20240320-002" ;
    dcterms:created "2024-03-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-03-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/DegradedPerformance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ; # Assuming DeferredIntervention exists
    noria:troubleTicketSupervisionTool "APM Tool"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DegradedPerformance> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/DatabaseIssue> ; # Assuming DatabaseIssue exists
    noria:troubleTicketCause "High database load impacting application response times."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ApplicationSupport> ; # Assuming ApplicationSupport exists
    noria:troubleTicketDetectionDateTime "2024-03-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent3, foaf:Agent4 ;
    noria:troubleTicketRelatedService noria:ApplicationModule2 ;
    noria:troubleTicketRelatedResource noria:Resource3, noria:Resource4 ;
    noria:troubleTicketImpacts noria:Application2, noria:Resource3, noria:Resource4 .

noria:TroubleTicketNote1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT-20240320-001"@en ;
    rdfs:comment "Confirmed network interface eth0 on dns01 is down. Attempting to bring it up."@en ;
    dcterms:created "2024-03-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent1 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket1 .

noria:TroubleTicketNote2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Update for TT-20240320-001"@en ;
    rdfs:comment "Interface eth0 on dns01 brought up. DNS resolution restored. Monitoring service stability."@en ;
    dcterms:created "2024-03-20T11:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent1 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ; # Assuming Resolution exists
    dcterms:isPartOf noria:TroubleTicket1 .

# Event Records
noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Server Interface Down Alert"@en ;
    rdfs:comment "Alert: Interface eth0 on dns01.corp.example.com is down."@en ;
    dcterms:identifier "EVT-20240320-001-A" ;
    noria:loggingTime "2024-03-20T08:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logText "LINEPROTO-5-DOWN: Interface eth0, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:troubleTicketTrigger noria:TroubleTicket1 .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "DNS Server Interface Up Alert"@en ;
    rdfs:comment "Alert: Interface eth0 on dns01.corp.example.com is up."@en ;
    dcterms:identifier "EVT-20240320-001-B" ;
    noria:loggingTime "2024-03-20T10:58:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logText "LINEPROTO-5-UP: Interface eth0, changed state to up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmMitigatedBy noria:TroubleTicket1 . # This event is part of the resolution of TT1

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "Database High Load Alert"@en ;
    rdfs:comment "Alert: CPU utilization on db01.corp.example.com is consistently above 90%."@en ;
    dcterms:identifier "EVT-20240320-002-A" ;
    noria:loggingTime "2024-03-20T09:50:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource4 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logText "CPU_UTILIZATION_HIGH: db01.corp.example.com CPU > 90% for 15 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:troubleTicketTrigger noria:TroubleTicket2 .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "User Login Failure"@en ;
    rdfs:comment "Failed login attempt for user 'jdoe' on web01.corp.example.com."@en ;
    dcterms:identifier "EVT-20240320-003-A" ;
    noria:loggingTime "2024-03-20T14:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logOriginatingAgent noria:CorporateUserIdentifier1 ; # Example of a user as originating agent
    noria:logText "AUTH_FAILED: User jdoe failed to login to web01."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

