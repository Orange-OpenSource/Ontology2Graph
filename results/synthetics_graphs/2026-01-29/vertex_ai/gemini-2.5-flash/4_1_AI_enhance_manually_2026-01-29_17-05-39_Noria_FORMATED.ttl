@prefix gn: <https://www.geonames.org/ontology#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .

# --- KOS Concepts (Knowledge Organization System) ---
# These are not part of the NORIA ontology itself but are used as values for certain properties.
# They are defined here as skos:Concept instances within specific skos:ConceptScheme.

# Application KOS
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/business> a skos:Concept ; skos:prefLabel "Business Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .

<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium Business Importance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:prefLabel "In Maintenance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; skos:prefLabel "Gold SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; skos:prefLabel "Silver SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# TroubleTicket KOS
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .

<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:prefLabel "Failure Ticket"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:prefLabel "Assistance Ticket"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .

<kos/TroubleTicket/category/ServiceInterruption> a skos:Concept ; skos:prefLabel "Service Interruption"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/category> .
<kos/TroubleTicket/category/PerformanceDegradation> a skos:Concept ; skos:prefLabel "Performance Degradation"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/category> .

<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision System Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer Origin"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; skos:prefLabel "Immediate Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> .

<kos/TroubleTicket/problemResponsibility/ManagedBackbone> a skos:Concept ; skos:prefLabel "Managed Backbone Responsibility"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .

<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis Operation"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .

# ChangeRequest KOS
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; skos:prefLabel "Software Upgrade"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:prefLabel "Approved"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; skos:prefLabel "Internal Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .
<kos/ChangeRequest/specification/NetworkConfigUpdate> a skos:Concept ; skos:prefLabel "Network Configuration Update"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> .

# Resource KOS
<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Firewall> a skos:Concept ; skos:prefLabel "Firewall Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine Resource"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

<kos/Resource/LifecycleState/InUse> a skos:Concept ; skos:prefLabel "In Use"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:prefLabel "Decommissioned"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .

<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Operational Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Operational Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .

<kos/Resource/AdministrativeState/Up> a skos:Concept ; skos:prefLabel "Administrative Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; skos:prefLabel "Administrative Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .

# Notification KOS
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning Perceived Severity"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .

<kos/Notification/EventType/stateChange> a skos:Concept ; skos:prefLabel "State Change Event"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/EventType> .
<kos/Notification/EventType/thresholdCrossing> a skos:Concept ; skos:prefLabel "Threshold Crossing Event"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/EventType> .

# Agent Contact Method KOS
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .

# Service KOS
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .

# --- Agents and Organizations ---

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'Administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution of related incidents."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email to dns-admin@example.com for non-critical issues. PagerDuty for critical alerts."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for network infrastructure management and incident response."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call the NOC hotline for any network-related incident."@en .

foaf:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing Level 2 support for critical business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all application issues."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual IT Administrator, member of the DNS Admin Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+1-555-123-4567" .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Lead Network Engineer, member of the Network Operations Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+1-555-987-6543" .

org:OrgUnit_ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en, "Département Informatique"@fr ;
    rdfs:comment "The main IT department of the organization."@en ;
    org:hasMember foaf:Agent_JohnDoe, foaf:Agent_JaneSmith ;
    org:unitOf <https://example.com/org/Corporate> .

org:OrgUnit_NOC a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en, "Centre d'Opérations Réseau"@fr ;
    rdfs:comment "The Network Operations Center, part of the Network Operations Team."@en ;
    org:hasMember foaf:Agent_NetworkOpsTeam ;
    org:unitOf org:OrgUnit_ITDepartment .

noria:CorporateUserIdentifier_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "EMP001" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

# --- Locations ---

bot:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" ;
    noria:sitePrincipalAddressStreet "Tech Avenue" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server room in the Main Data Center."@en ;
    bot:hasSpace bot:Site_MainDataCenter .

noria:Locus_Rack12_U24 a noria:Locus ;
    rdfs:label "Rack 12, Unit 24"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "Rack 12" ;
    noria:locusRow "U24" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_Rack12_U25 a noria:Locus ;
    rdfs:label "Rack 12, Unit 25"@en ;
    rdfs:comment "Specific location for another server in Server Room A."@en ;
    noria:locusLine "Rack 12" ;
    noria:locusRow "U25" ;
    bot:hasSpace noria:Room_ServerRoomA .

# --- Product Models ---

noria:ProductModel_DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing."@en ;
