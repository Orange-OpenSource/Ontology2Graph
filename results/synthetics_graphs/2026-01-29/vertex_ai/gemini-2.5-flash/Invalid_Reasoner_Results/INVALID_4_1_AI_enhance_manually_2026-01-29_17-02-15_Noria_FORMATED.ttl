# =============================================================================
# Operation Plans, Pre/Post Conditions, Anomaly Patterns
# =============================================================================

noria:OperationPlan_RouterOSUpgrade a noria:OperationPlan ;
    rdfs:label "Standard Router OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the operating system of network routers."@en ;
    skos:example "Includes pre-checks, backup, upgrade command, and post-checks."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterHealthCheck ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterOperational .

noria:OperationPlan_VLANConfigFix a noria:OperationPlan ;
    rdfs:label "VLAN Configuration Troubleshooting Guide"@en ;
    rdfs:comment "Procedure to diagnose and fix incorrect VLAN configurations on network interfaces."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:ActionPreCondition_RouterHealthCheck a noria:ActionPreCondition ;
    rdfs:label "Router Health Check Passed"@en ;
    rdfs:comment "All critical router metrics (CPU, memory, temperature) are within normal thresholds."@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "The operational status of a critical network interface is reported as 'down'."@en .

noria:ActionPostCondition_RouterOperational a noria:ActionPostCondition ;
    rdfs:label "Router Fully Operational After Upgrade"@en ;
    rdfs:comment "Router has rebooted, all interfaces are up, and routing protocols are converged."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "The operational status of the network interface is 'up' and traffic is flowing."@en .

noria:AnomalyPattern_HighCPUDegradation a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Utilization"@en ;
    rdfs:comment "Anomaly pattern indicating a prolonged period of high CPU usage on a server or VM, potentially leading to performance degradation."@en ;
    skos:example "CPU > 90% for more than 15 minutes."@en .

noria:AnomalyPattern_NetworkFlap a noria:AnomalyPattern ;
    rdfs:label "Repeated Network Interface Flapping"@en ;
    rdfs:comment "Anomaly pattern where a network interface repeatedly changes its operational state between up and down in a short period."@en ;
    skos:example "Interface status changes 3 times in 5 minutes."@en .

# Connecting Operation Plans to Change Requests and Trouble Tickets
noria:ChangeRequest_CR001 noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterOSUpgrade .
noria:TroubleTicket_TT001 noria:troubleTicketCharacteristic noria:AnomalyPattern_NetworkFlap .
noria:TroubleTicket_TT002 noria:troubleTicketCharacteristic noria:AnomalyPattern_HighCPUDegradation .

# Further connections for density
noria:ApplicationModule_CorpIntranet_Prod noria:applicationModuleAdministrationLeader foaf:Agent_JaneSmith .
noria:ApplicationModule_CorpIntranet_Prod noria:applicationModuleSupportLeader foaf:Agent_JohnDoe .

noria:TroubleTicket_TT001 noria:documentStatusHistory noria:EventRecord_ER001 .
noria:TroubleTicket_TT001 noria:documentStatusHistory noria:EventRecord_ER002 .
noria:TroubleTicket_TT002 noria:documentStatusHistory noria:EventRecord_ER003 .

noria:ChangeRequest_CR001 noria:documentStatusHistory noria:EventRecord_ER002 .
noria:ChangeRequest_CR002 noria:documentStatusHistory noria:EventRecord_ER004 .

noria:TroubleTicketNote_TT001_Note2 noria:troubleTicketNoteCorrelatedExecution noria:TroubleTicket_TT001 . # The note is part of the execution container of the ticket itself.

