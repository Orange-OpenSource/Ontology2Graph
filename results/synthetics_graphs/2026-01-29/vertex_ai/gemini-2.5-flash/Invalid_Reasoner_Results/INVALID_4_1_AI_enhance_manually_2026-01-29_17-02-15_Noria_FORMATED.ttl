    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-01-20T08:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_AdminTeam ;
    noria:locatedAtLocus noria:Locus_RackA1_U24 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_SwitchAccess01 a noria:Resource ;
    rdfs:label "Access Switch 01 - HQ"@en ;
    rdfs:comment "Access layer switch in the corporate headquarters, connecting user devices."@en ;
    noria:resourceLogisticId "ASSET-SW-HQ-001" ;
    noria:resourceHostName "switchaccess01.hq01.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-SW-HQ-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
