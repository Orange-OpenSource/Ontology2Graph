# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_AdminTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:comment "Team responsible for 24/7 network monitoring and initial incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via dedicated hotline for critical issues. Use ticketing system for non-urgent requests."@en .

foaf:Agent_AppDevTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_SecurityTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cybersecurity Operations Team"@en ;
    rdfs:comment "Team responsible for security monitoring, incident response, and vulnerability management."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, part of the NOC Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

foaf:Agent_JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer, part of the Application Development Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

# =============================================================================
# Locations
# =============================================================================

bot:Site_DC01 a bot:Site ;
    rdfs:label "Main Data Center (DC01)"@en ;
    rdfs:comment "Primary data center hosting critical infrastructure and applications."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

bot:Site_OfficeHQ a bot:Site ;
    rdfs:label "Corporate Headquarters Office"@en ;
    rdfs:comment "Main office building with local network infrastructure."@en ;
    noria:siteId "HQ01" ;
    noria:siteType "building" ;
    noria:sitePrincipalAddress "456 Business Blvd" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A - DC01"@en ;
    rdfs:comment "Main server room within Data Center DC01."@en ;
    bot:hasSpace bot:Site_DC01 .

noria:Room_NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B - OfficeHQ"@en ;
    rdfs:comment "Network equipment closet on the 2nd floor of the HQ office."@en ;
    bot:hasSpace bot:Site_OfficeHQ .

noria:Locus_RackA1_U24 a noria:Locus ;
    rdfs:label "Rack A1, Unit 24"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "24" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB3_U1 a noria:Locus ;
    rdfs:label "Rack B3, Unit 1"@en ;
    rdfs:comment "Location for a network switch in Network Closet B."@en ;
    noria:locusLine "B3" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_NetworkClosetB .

