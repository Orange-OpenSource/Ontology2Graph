# --- Event Records (noria:EventRecord) ---

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down, impacting internet access."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_DNSQueryFailure a noria:EventRecord ;
    rdfs:label "DNS Query Failure Alert"@en ;
    rdfs:comment "Alert from monitoring system indicating DNS query failures on DNS01, affecting internal name resolution."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "High rate of DNS query failures detected on dns01.corp.example.com"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent foaf:Agent_NetworkOpsTeam . # Monitoring system acting on behalf of NetworkOps

noria:EventRecord_CRMDBHighCPU a noria:EventRecord ;
    rdfs:label "CRM DB High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on CRM Database Server, potentially impacting CRM application performance."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CRMDBServer ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "CPU utilization on crmdb01.corp.example.com exceeded 90% for 15 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_ConfigChangeRouter a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
