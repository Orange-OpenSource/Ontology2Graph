# --- Operation Plans (noria:OperationPlan), Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition), Anomaly Patterns (noria:AnomalyPattern) ---

noria:OperationPlan_RouterUpgradeProcedure a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading Juniper MX series router software, ensuring minimal downtime."@en ;
    skos:example "Steps include: backup config, download image, install image, reboot, verify."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterConnectivityCheck ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterOperationalCheck .

noria:ActionPreCondition_RouterConnectivityCheck a noria:ActionPreCondition ;
    rdfs:label "Router Connectivity Pre-Check"@en ;
    rdfs:comment "Verify network connectivity to the router and its neighbors before starting any upgrade or maintenance."@en ;
    skos:example "Ping management IP, check BGP neighbor status, verify routing table."@en .

noria:ActionPostCondition_RouterOperationalCheck a noria:ActionPostCondition ;
    rdfs:label "Router Operational Post-Check"@en ;
    rdfs:comment "Verify router operational status and service functionality after upgrade or maintenance."@en ;
    skos:example "Check interface status, verify routing protocols, test application connectivity through router."@en .

noria:OperationPlan_CRMDBTune a noria:OperationPlan ;
    rdfs:label "CRM DB Performance Tuning Procedure"@en ;
    rdfs:comment "Procedure for optimizing CRM database performance, including index rebuilds and query optimization."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_CRMDBLoadCheck ;
    noria:operationPlanPostCondition noria:ActionPostCondition_CRMDBPerformanceOK .

noria:ActionPreCondition_CRMDBLoadCheck a noria:ActionPreCondition ;
    rdfs:label "CRM DB Load Pre-Check"@en ;
    rdfs:comment "Verify current database load and identify top resource-consuming queries before tuning."@en .

noria:ActionPostCondition_CRMDBPerformanceOK a noria:ActionPostCondition ;
    rdfs:label "CRM DB Performance Post-Check"@en ;
    rdfs:comment "Confirm CPU and I/O utilization are within normal limits and application response times are improved after tuning."@en .

noria:AnomalyPattern_HighDNSErrorRate a noria:AnomalyPattern ;
    rdfs:label "High DNS Error Rate Pattern"@en ;
    rdfs:comment "Pattern indicating a potential DNS server issue: high query failure rate combined with high CPU/memory usage."@en ;
    folio:hasCause "DNS server overload or misconfiguration"@en .

# --- Procedure Execution Containers (pep:ProcedureExecutionContainer) ---
# Linking Change Requests to their execution procedures

noria:CR001_Execution a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution container for CR001"@en ;
