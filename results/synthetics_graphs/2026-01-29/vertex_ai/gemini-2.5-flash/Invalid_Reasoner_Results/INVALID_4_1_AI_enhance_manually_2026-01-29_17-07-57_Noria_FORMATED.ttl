    rdfs:label "Resource Type: Server"@en .

<kos/Resource/type/Router> a skos:Concept ;
    rdfs:label "Resource Type: Router"@en .

<kos/Resource/type/Switch> a skos:Concept ;
    rdfs:label "Resource Type: Switch"@en .

<kos/Resource/type/Firewall> a skos:Concept ;
    rdfs:label "Resource Type: Firewall"@en .

<kos/Resource/type/VirtualMachine> a skos:Concept ;
    rdfs:label "Resource Type: Virtual Machine"@en .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ;
    rdfs:label "Lifecycle State: In Production"@en .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    rdfs:label "Lifecycle State: Decommissioned"@en .

<kos/Resource/AdministrativeState/up> a skos:Concept ;
    rdfs:label "Administrative State: Up"@en .

<kos/Resource/AdministrativeState/down> a skos:Concept ;
