    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jdoe (10.0.0.50)"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord_SFPReplacement a noria:EventRecord ;
    rdfs:label "SFP Module Replacement Log"@en ;
    rdfs:comment "Log entry detailing the replacement of an SFP module on router-core01 ge-0/0/1 by John Doe."@en ;
    noria:loggingTime "2024-04-20T10:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Replaced SFP module on ge-0/0/1. Interface status changed to up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord_DNSConfigUpdate a noria:EventRecord ;
    rdfs:label "DNS Configuration Update Log"@en ;
    rdfs:comment "Log entry for a successful DNS configuration update on dns01 by DNS Admin Team."@en ;
    noria:loggingTime "2024-04-20T11:50:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingAgent foaf:Agent_DNSAdminTeam ;
    noria:logText "DNS zone file updated for example.com, serial incremented."@en ;
