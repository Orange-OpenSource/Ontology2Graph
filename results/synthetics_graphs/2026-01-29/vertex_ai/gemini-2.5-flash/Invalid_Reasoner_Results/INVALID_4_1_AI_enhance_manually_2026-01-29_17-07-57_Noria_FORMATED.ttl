@prefix gn: <https://www.geonames.org/ontology#> . # Added as per schema

# --- Controlled Vocabularies (KOS) ---
# These SKOS concepts are referenced by NORIA properties.
# In a real-world scenario, these would typically be managed in separate SKOS concept schemes.
# For this exercise, they are defined inline to ensure completeness and connectivity.

<kos/application/type/infrastructure> a skos:Concept ;
    rdfs:label "Infrastructure Application Type"@en ;
    skos:example "DNS, DHCP, Monitoring systems."@en .

<kos/application/type/business> a skos:Concept ;
    rdfs:label "Business Application Type"@en ;
    skos:example "CRM, ERP, Billing systems."@en .

<kos/application/type/service-platform> a skos:Concept ;
    rdfs:label "Service Platform Application Type"@en ;
    skos:example "API Gateway, Message Queue."@en .

<kos/application/business-importance/high> a skos:Concept ;
    rdfs:label "High Business Importance"@en .

<kos/application/business-importance/medium> a skos:Concept ;
    rdfs:label "Medium Business Importance"@en .

<kos/application/business-importance/low> a skos:Concept ;
    rdfs:label "Low Business Importance"@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    rdfs:label "In Production"@en .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    rdfs:label "In Development"@en .

<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ;
    rdfs:label "In Maintenance"@en .

<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ;
    rdfs:label "SLA Level: Gold"@en .

<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ;
    rdfs:label "SLA Level: Silver"@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    rdfs:label "Critical Severity"@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    rdfs:label "Major Severity"@en .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    rdfs:label "Minor Severity"@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ;
    rdfs:label "Failure Type"@en .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    rdfs:label "Assistance Type"@en .

<kos/TroubleTicket/category/NetworkOutage> a skos:Concept ;
    rdfs:label "Network Outage Category"@en .

<kos/TroubleTicket/category/ServerIssue> a skos:Concept ;
    rdfs:label "Server Issue Category"@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ;
    rdfs:label "Priority 1"@en .

<kos/TroubleTicket/priority/P2> a skos:Concept ;
    rdfs:label "Priority 2"@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    rdfs:label "Origin: Supervision System"@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    rdfs:label "Origin: Customer"@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    rdfs:label "Urgency: Immediate Intervention"@en .

<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ;
