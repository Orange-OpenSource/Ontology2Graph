<kos/service/type/ResourceFacingService> a skos:Concept ;
    rdfs:label "Resource Facing Service"@en .

# --- Agents (foaf:Agent) and Organizations (org:OrganizationalUnit) ---

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email dnsteam@example.com for non-urgent issues. Call 555-DNS-CRIT for critical outages."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use ticketing system for all requests. Emergency hotline for P1 incidents."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the CRM application."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for Network Operations."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Product Owner for CRM Application."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:Org_ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "Overall IT department responsible for all IT services."@en ;
    org:hasMember foaf:Agent_JohnDoe, foaf:Agent_JaneSmith .

org:Org_NetworkDivision a org:OrganizationalUnit ;
    rdfs:label "Network Division"@en ;
    rdfs:comment "Division within IT Department focusing on network infrastructure."@en ;
    org:unitOf org:Org_ITDepartment ;
    org:hasMember foaf:Agent_NetworkOpsTeam, foaf:Agent_JohnDoe .

org:Org_AppDivision a org:OrganizationalUnit ;
    rdfs:label "Application Division"@en ;
    rdfs:comment "Division within IT Department focusing on business applications."@en ;
    org:unitOf org:Org_ITDepartment ;
    org:hasMember foaf:Agent_AppDevTeam, foaf:Agent_JaneSmith .

# --- Corporate User Identifiers (noria:CorporateUserIdentifier) ---

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for John Doe, used for system access."@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for Jane Smith, used for system access."@en ;
    foaf:accountName "jsmith"@en ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

# --- Product Models (noria:ProductModel) ---

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various infrastructure services."@en ;
    noria:productManufacturedBy <https://www.dell.com/> .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch series."@en ;
    noria:productManufacturedBy <https://www.cisco.com/> .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "Modular router for edge and core network deployments."@en ;
    noria:productManufacturedBy <https://www.juniper.net/> .

<https://www.dell.com/> a org:Organization ;
    rdfs:label "Dell Technologies"@en .

<https://www.cisco.com/> a org:Organization ;
    rdfs:label "Cisco Systems"@en .

<https://www.juniper.net/> a org:Organization ;
    rdfs:label "Juniper Networks"@en .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---

bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

bot:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary data center for disaster recovery operations."@en ;
    noria:siteId "DR01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "456 Backup Road"@en ;
    noria:sitePrincipalAddressCityName "Gotham"@en ;
    noria:sitePrincipalAddressPostalCode "20002"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Main Data Center (DC01)."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room within the Main Data Center (DC01)."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server in Server Room A, rack A1, unit 23."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "23"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5_U10 a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Specific location for a router in Network Room B, rack B5, unit 10."@en ;
    noria:locusLine "B5"@en ;
    noria:locusRow "10"@en ;
    bot:hasSpace noria:Room_NetworkRoomB .

# --- Resources (noria:Resource) ---

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, located in Main DC."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress "10.0.0.10"@en .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main core router in Main DC, managed by Network Operations team."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-core01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceLogisticId "ASSET-RTR-001"@en ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB5_U10 ;
    noria:resourceManagementIPAddress "10.0.0.1"@en .

noria:Resource_CRMDBServer a noria:Resource ;
    rdfs:label "CRM Database Server"@en ;
    rdfs:comment "Database server hosting the corporate CRM application data."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "crmdb01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-CRM-DB01"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-CRMDB01-DEF"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress "10.0.0.20"@en .

noria:Resource_WebProxy01 a noria:Resource ;
    rdfs:label "Corporate Web Proxy 01"@en ;
    rdfs:comment "Web proxy server for secure and filtered internet access."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "webproxy01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-07-01T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.30"@en .

noria:Resource_VirtualCenter01 a noria:Resource ;
    rdfs:label "Virtualization Management Center 01"@en ;
    rdfs:comment "VMware vCenter server managing virtual machines across hosts."@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "vcenter01.corp.example.com"@en ;
    noria:resourceManagementIPAddress "10.0.0.40"@en .

noria:Resource_VMHost01 a noria:Resource ;
    rdfs:label "VM Host Server 01"@en ;
    rdfs:comment "Physical host server for virtual machines."@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:clusterController noria:Resource_VirtualCenter01 ;
    noria:resourceHostName "vmhost01.corp.example.com"@en ;
    noria:resourceManagementIPAddress "10.0.0.50"@en .

noria:Resource_VirtualCRMAppServer a noria:Resource ;
    rdfs:label "Virtual CRM Application Server"@en ;
    rdfs:comment "Virtual machine hosting the CRM application logic."@en ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "vcrmapp01.corp.example.com"@en ;
    noria:clusterController noria:Resource_VirtualCenter01 ;
    noria:resourceManagementIPAddress "10.0.0.60"@en .

# --- Network Interfaces (noria:NetworkInterface) ---

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface 0 on DNS server 01, connected to internal LAN."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_RouterCore01_Ge0_0_0 a noria:NetworkInterface ;
    rdfs:label "router-core01.corp.example.com:ge-0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/0 on Core Router 01, connecting to internal network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterCore01_Ge0_0_1 a noria:NetworkInterface ;
    rdfs:label "router-core01.corp.example.com:ge-0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/1 on Core Router 01, connecting to ISP."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_CRMDB_Eth0 a noria:NetworkInterface ;
    rdfs:label "crmdb01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface 0 on CRM DB server, connected to internal LAN."@en ;
    noria:networkInterfaceOf noria:Resource_CRMDBServer ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_VMHost01_vSwitch0 a noria:NetworkInterface ;
    rdfs:label "vmhost01.corp.example.com:vSwitch0"@en ;
    rdfs:comment "Virtual switch interface on VM Host Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_VMHost01 ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_VirtualCRMAppServer_Eth0 a noria:NetworkInterface ;
    rdfs:label "vcrmapp01.corp.example.com:eth0"@en ;
    rdfs:comment "Virtual Ethernet interface 0 on Virtual CRM Application Server."@en ;
    noria:networkInterfaceOf noria:Resource_VirtualCRMAppServer ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links (noria:NetworkLink) ---

noria:NetworkLink_InternalLAN a noria:NetworkLink ;
    rdfs:label "Internal LAN Segment"@en ;
    rdfs:comment "Local Area Network segment connecting various internal resources."@en ;
    noria:networkLinkId "LAN-SEG-001"@en ;
    noria:networkLinkType "Ethernet LAN"@en ;
    noria:networkLinkInstallationDate "2021-03-20T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_DNS01, noria:Resource_CRMDBServer, noria:Resource_RouterCore01, noria:Resource_VMHost01, noria:Resource_VirtualCRMAppServer ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0, noria:NetworkInterface_CRMDB_Eth0, noria:NetworkInterface_RouterCore01_Ge0_0_0, noria:NetworkInterface_VMHost01_vSwitch0, noria:NetworkInterface_VirtualCRMAppServer_Eth0 ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam .

noria:NetworkLink_ISP_Uplink a noria:NetworkLink ;
    rdfs:label "ISP Uplink to Router Core 01"@en ;
    rdfs:comment "Fiber optic link connecting Core Router 01 to the Internet Service Provider."@en ;
    noria:networkLinkId "ISP-UPLINK-001"@en ;
    noria:networkLinkType "Fiber Optic WAN"@en ;
    noria:networkLinkInstallationDate "2021-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination <http://isp.example.com/router-edge01> ; # External resource
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Ge0_0_1 ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam .

