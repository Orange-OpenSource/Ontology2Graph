<https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; rdfs:label "Ticketing System"@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizations
:OrgITDept a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department responsible for all IT operations."@en ;
    org:hasUnit :TeamWebOps, :TeamNetOps, :TeamDBA, :TeamSecurity, :TeamInfra .

# Organizational Units (Teams)
:TeamWebOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "WebOps Team"@en ;
    rdfs:comment "Team responsible for web application deployment and operations."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For critical issues, open a P1 ticket and call the on-call engineer."@en ;
    org:unitOf :OrgITDept .

:TeamNetOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    noria:agentWorkingHours "24/7 On-Call" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call the NOC for network-related incidents."@en ;
    org:unitOf :OrgITDept .

:TeamDBA a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database systems."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket for all database requests. Urgent issues require a call after ticket submission."@en ;
    org:unitOf :OrgITDept .

:TeamSecurity a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7 On-Call" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Report all security incidents immediately via the dedicated security portal."@en ;
    org:unitOf :OrgITDept .

:TeamInfra a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Infrastructure Team"@en ;
    rdfs:comment "Team responsible for physical and virtual server infrastructure."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For server provisioning or maintenance, use the internal request system."@en ;
    org:unitOf :OrgITDept .

# Individual Agents
:AgentAlice a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Engineer in WebOps Team."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    org:memberOf :TeamWebOps .

:AgentBob a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Network Architect in NetOps Team."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    org:memberOf :TeamNetOps .

:AgentCharlie a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Database Specialist in DBA Team."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    foaf:phone "+1-555-111-2222" ;
    org:memberOf :TeamDBA .

# Corporate User Identifiers
:CUidAlice a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount :AgentAlice .

:CUidBob a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount :AgentBob .

# =============================================================================
# Product Models
# =============================================================================

:ProductModelDellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy :OrgDell .

:ProductModelCiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series for high-density deployments."@en ;
    noria:productManufacturedBy :OrgCisco .

:ProductModelJuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "Modular router for enterprise and service provider applications."@en ;
    noria:productManufacturedBy :OrgJuniper .

:ProductModelVMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi"@en ;
    rdfs:comment "Type-1 hypervisor for virtualized environments."@en ;
    noria:productManufacturedBy :OrgVMware .

:OrgDell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

:OrgCisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

:OrgJuniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

:OrgVMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

# =============================================================================
# Locations
# =============================================================================

# Sites
:SiteDC1 a bot:Site ;
    rdfs:label "Data Center 1"@en ;
    rdfs:comment "Primary corporate data center located in Paris."@en ;
    noria:siteId "DC1" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

:SiteDRC a bot:Site ;
    rdfs:label "Disaster Recovery Center"@en ;
    rdfs:comment "Secondary data center for disaster recovery, located in Lyon."@en ;
    noria:siteId "DRC" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

# Rooms
:RoomServerHallA a noria:Room ;
    rdfs:label "Server Hall A"@en ;
    rdfs:comment "Main server hall in Data Center 1."@en ;
    bot:hasSpace :LocusRackA1, :LocusRackA2, :LocusRackA3 ;
    seas:subSystemOf :SiteDC1 .

:RoomNetworkCore a noria:Room ;
    rdfs:label "Network Core Room"@en ;
    rdfs:comment "Room housing core network equipment in Data Center 1."@en ;
    bot:hasSpace :LocusRackN1 ;
    seas:subSystemOf :SiteDC1 .

# Loci (specific locations within rooms, e.g., racks)
:LocusRackA1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Hall A"@en ;
    rdfs:comment "Location for web servers and application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    seas:subSystemOf :RoomServerHallA .

:LocusRackA2 a noria:Locus ;
    rdfs:label "Rack A2 in Server Hall A"@en ;
    rdfs:comment "Location for database servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    seas:subSystemOf :RoomServerHallA .

:LocusRackA3 a noria:Locus ;
    rdfs:label "Rack A3 in Server Hall A"@en ;
    rdfs:comment "Location for virtualisation hosts."@en ;
    noria:locusLine "A" ;
    noria:locusRow "3" ;
    seas:subSystemOf :RoomServerHallA .

:LocusRackN1 a noria:Locus ;
    rdfs:label "Rack N1 in Network Core Room"@en ;
    rdfs:comment "Location for core routers and switches."@en ;
    noria:locusLine "N" ;
    noria:locusRow "1" ;
    seas:subSystemOf :RoomNetworkCore .

# =============================================================================
# Resources
# =============================================================================

:ResourceWebServer01 a noria:Resource ;
    rdfs:label "Corporate Web Server 01"@en ;
    rdfs:comment "Primary web server for customer-facing applications."@en ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel :ProductModelDellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :TeamWebOps ;
    noria:locatedAtLocus :LocusRackA1 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

:ResourceDBServer01 a noria:Resource ;
    rdfs:label "Corporate Database Server 01"@en ;
    rdfs:comment "Primary database server for critical business data."@en ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel :ProductModelDellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB-001-ABC" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-01T11:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :TeamDBA ;
    noria:locatedAtLocus :LocusRackA2 ;
    noria:resourceManagementIPAddress "10.0.0.20" .

:ResourceRouterCore01 a noria:Resource ;
