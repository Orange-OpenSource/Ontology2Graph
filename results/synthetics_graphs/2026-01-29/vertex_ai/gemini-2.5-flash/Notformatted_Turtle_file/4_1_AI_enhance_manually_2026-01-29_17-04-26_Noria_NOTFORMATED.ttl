# Add a TroubleTicketNote for the rollback
:TTNote005_1 a noria:TroubleTicketNote ;
    rdfs:label "Rollback Initiated for WebServer01"@en ;
    rdfs:comment "Initiated rollback procedure for WebServer01. Reverting to previous hardware configuration."@en ;
    dcterms:created "2024-05-01T02:45:00Z"^^xsd:dateTime ;
    dcterms:creator :TeamInfra ;
