# =============================================================================

:OperationPlanRestartWebServer a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a web server to clear transient issues."@en ;
    noria:operationPlanPreCondition :PreConditionWebServerHighCPU ;
    noria:operationPlanPostCondition :PostConditionWebServerNormalCPU .

:PreConditionWebServerHighCPU a noria:ActionPreCondition ;
    rdfs:label "Web Server High CPU Pre-Condition"@en ;
    rdfs:comment "Condition: Web server CPU utilization > 90% for 5 minutes."@en .

:PostConditionWebServerNormalCPU a noria:ActionPostCondition ;
    rdfs:label "Web Server Normal CPU Post-Condition"@en ;
    rdfs:comment "Outcome: Web server CPU utilization < 50% for 10 minutes, and application response times are normal."@en .

:OperationPlanFailoverWAN a noria:OperationPlan ;
    rdfs:label "WAN Link Failover Procedure"@en ;
    rdfs:comment "Procedure to switch traffic to a secondary WAN link in case of primary link failure."@en ;
    noria:operationPlanPreCondition :PreConditionWANLinkDown ;
    noria:operationPlanPostCondition :PostConditionWANTrafficRestored .

:PreConditionWANLinkDown a noria:ActionPreCondition ;
    rdfs:label "WAN Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: Primary WAN link operational status is 'down'."@en .

:PostConditionWANTrafficRestored a noria:ActionPostCondition ;
    rdfs:label "WAN Traffic Restored Post-Condition"@en ;
    rdfs:comment "Outcome: Network traffic successfully routed via secondary WAN link, and external services are reachable."@en .

:AnomalyPatternHighCPULoad a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential resource exhaustion or application bug, characterized by high CPU usage over an extended period."@en ;
    folio:hasCause "Resource Exhaustion" ;
    folio:hasEffect "Application Performance Degradation" .

:AnomalyPatternNetworkOutage a noria:AnomalyPattern ;
    rdfs:label "Network Link Failure Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a network connectivity issue, characterized by a network interface going down and loss of reachability."@en ;
    folio:hasCause "Physical Link Damage" ;
    folio:hasEffect "Service Unavailability" .

# Link EventRecord to AnomalyPattern (conceptual link, not directly in NORIA schema but good for density)
# Using dcterms:relation for this general correlation.
:EventRecordHighCPU dcterms:relation :AnomalyPatternHighCPULoad .
:EventRecordLinkDown dcterms:relation :AnomalyPatternNetworkOutage .

# Link TroubleTicket to OperationPlan (as a proposed action)
:TroubleTicket001 noria:troubleTicketCharacteristic :OperationPlanRestartWebServer . # Using characteristic as a placeholder for proposed action
:TroubleTicket002 noria:troubleTicketCharacteristic :OperationPlanFailoverWAN .

# Link ChangeRequest to OperationPlan (as a specification)
:ChangeRequest001 noria:changeRequestSpecification <https://w3id.org/noria/kos/ChangeRequest/specification/StandardOperatingProcedure> .
:ChangeRequest002 noria:changeRequestSpecification <https://w3id.org/noria/kos/ChangeRequest/specification/StandardOperatingProcedure> .

# Example of a DocumentAttachment
:DocAttachmentNetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram DC1"@en ;
    rdfs:comment "Diagram of the network topology in Data Center 1."@en ;
    dcterms:identifier "DIAG-NET-DC1-V2.pdf" ;
    dcterms:created "2023-10-01T09:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf" ;
    dcterms:source "https://docs.example.com/network/DC1_Diagram_V2.pdf" ;
    dcterms:isPartOf :ChangeRequest002 . # Attached to a change request for reference

# Example of document status history (using EventRecord)
:EventRecordTT001StatusChange1 a noria:EventRecord ;
    rdfs:label "TT001 Status Change: Initialised to InProgress"@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem :ApplicationMonitoringSystem ;
    noria:logText "Trouble Ticket TT-ECP-20240420-001 status changed from Initialised to InProgress."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

:TroubleTicket001 noria:documentStatusHistory :EventRecordTT001StatusChange1 .

# Example of an EventRecord being mitigated by a ProcedureExecutionContainer (e.g., a TroubleTicket or ChangeRequest)
:EventRecordHighCPU noria:alarmMitigatedBy :TroubleTicket001 .
:EventRecordLinkDown noria:alarmMitigatedBy :TroubleTicket002 .

# Example of a TroubleTicketNote correlated execution (e.g., a specific command execution)
:EventRecordCommandExecRestartWeb a noria:EventRecord ;
    rdfs:label "Command Execution: Restart Web Service"@en ;
    noria:loggingTime "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :ResourceWebServer01 ;
    noria:logOriginatingAgent :AgentAlice ;
    noria:logText "Executed 'systemctl restart apache2' on web01.corp.example.com."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> ;
    pep:hasSimpleResult "Service restarted successfully."@en .

:TTNote001_1 noria:troubleTicketNoteCorrelatedExecution :EventRecordCommandExecRestartWeb .

# Further connections for density
:AgentAlice noria:agentManagesResource :ResourceWebServer01, :ResourceVirtualApp01 .
:AgentBob noria:agentManagesResource :ResourceRouterCore01, :NetworkLinkWANISP_A, :NetworkLinkLAN1 .
:AgentCharlie noria:agentManagesResource :ResourceDBServer01 .

:TeamWebOps noria:agentManagesResource :ResourceWebServer01, :ResourceVirtualApp01, :AppModuleCustomerPortal, :AppModulePaymentGateway .
:TeamNetOps noria:agentManagesResource :ResourceRouterCore01, :NetworkLinkWANISP_A, :NetworkLinkLAN1 .
:TeamDBA noria:agentManagesResource :ResourceDBServer01, :AppModuleSQLCluster .
:TeamInfra noria:agentManagesResource :ResourceVMHost01, :AppModuleLogAggregator .

# Application module support groups
:AppModuleCustomerPortal noria:applicationModuleSupportGroup :TeamWebOps ;
    noria:applicationModuleHotlineGroup :TeamWebOps .

:AppModuleSQLCluster noria:applicationModuleSupportGroup :TeamDBA ;
    noria:applicationModuleHotlineGroup :TeamDBA .

# Additional resources for applications
:ResourceWebServer01 noria:resourceForApplication :ApplicationECommercePlatform .
:ResourceDBServer01 noria:resourceForApplication :ApplicationDatabaseService .
:ResourceRouterCore01 noria:resourceForApplication :ApplicationMonitoringSystem . # Router sends logs to monitoring system

# Connect services to application modules (as subsystems)
:ServiceCustomerFacingWeb seas:subSystemOf :AppModuleCustomerPortal .
:ServiceInternalDBAccess seas:subSystemOf :AppModuleSQLCluster .

# Connect application modules to resources (as subsystems)
:AppModuleCustomerPortal seas:subSystemOf :ResourceWebServer01 .
:AppModuleSQLCluster seas:subSystemOf :ResourceDBServer01 .
:AppModuleLogAggregator seas:subSystemOf :ResourceVMHost01 .

# Connect a ChangeRequest to an EventRecord (e.g., a CR was triggered by an event)
:ChangeRequest001 dcterms:relation :EventRecordHighCPU . # High CPU event led to RAM upgrade CR

# Connect a TroubleTicket to a ChangeRequest (e.g., a TT led to a CR)
:TroubleTicket001 dcterms:relation :ChangeRequest001 .

# Connect a ChangeRequest to an EventRecord (e.g., a CR execution generates events)
:EventRecordConfigChange noria:alarmMitigatedBy :ChangeRequest002 . # Config change event is part of CR execution

# Add more properties to existing entities for density
:ResourceWebServer01 noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .
:ResourceDBServer01 noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .
:ResourceVirtualApp01 noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

:NIRouterCore01Ge001 noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Down> . # Simulating the state after the EventRecordLinkDown

# Add a second network interface to a server for more complexity
:NIWebServer01Eth1 a noria:NetworkInterface ;
    rdfs:label "eth1 on WebServer01"@en ;
    rdfs:comment "Secondary network interface for WebServer01, for management traffic."@en ;
    noria:networkInterfaceOf :ResourceWebServer01 ;
    noria:networkInterfaceDescription "Management network segment."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

:NetworkLinkMgmt a noria:NetworkLink ;
    rdfs:label "Management Network Segment"@en ;
    rdfs:comment "Dedicated network segment for out-of-band management."@en ;
    noria:networkLinkId "MGMT-DC1" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :ResourceWebServer01 ;
    noria:networkLinkTerminationResourceDestination :ResourceRouterCore01 ; # Assuming router also has a management interface
    noria:resourceManagedBy :TeamNetOps .

:NIWebServer01Eth1 noria:networkInterfaceConnects :NetworkLinkMgmt .

# Add another EventRecord for a security incident
:EventRecordSecurityAlert a noria:EventRecord ;
    rdfs:label "Suspicious Login Attempt Alert"@en ;
    rdfs:comment "Alert from SIEM indicating multiple failed login attempts on a critical server."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :ResourceDBServer01 ;
    noria:logOriginatingManagementSystem :ApplicationMonitoringSystem ; # Assuming SIEM is part of monitoring
    noria:logText "Failed login attempts for user 'root' on db01.corp.example.com from IP 192.168.5.10."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> .

:TroubleTicket004 a noria:TroubleTicket ;
    rdfs:label "Security Incident: Brute Force Attack"@en ;
    rdfs:comment "Investigation into suspicious login attempts on the database server."@en ;
    dcterms:identifier "TT-SEC-20240420-004" ;
    dcterms:created "2024-04-20T11:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <https://w3id.org/noria/kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <https://w3id.org/noria/kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <https://w3id.org/noria/kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <https://w3id.org/noria/kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "SIEM" ;
    noria:troubleTicketCategory <https://w3id.org/noria/kos/TroubleTicket/trouble-category/ApplicationError> ; # Could be Security Incident category if available
    noria:troubleTicketCause "External brute force attack attempt."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <https://w3id.org/noria/kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty :TeamSecurity ;
    noria:troubleTicketRelatedResource :ResourceDBServer01 ;
    noria:troubleTicketImpacts :ResourceDBServer01, :ApplicationDatabaseService ;
    noria:troubleTicketTrigger :EventRecordSecurityAlert .

:TTNote004_1 a noria:TroubleTicketNote ;
    rdfs:label "Security Incident Initial Response"@en ;
    rdfs:comment "Blocked source IP 192.168.5.10 at firewall. Monitoring logs for further activity."@en ;
    dcterms:created "2024-04-20T11:10:00Z"^^xsd:dateTime ;
    dcterms:creator :TeamSecurity ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Resolution> ;
    dcterms:isPartOf :TroubleTicket004 .

# Another Change Request for a planned upgrade
:ChangeRequest003 a noria:ChangeRequest ;
    rdfs:label "Database Software Upgrade"@en ;
    rdfs:comment "Planned upgrade of database management system software."@en ;
    dcterms:identifier "CR-DB-20240501-003" ;
    dcterms:created "2024-04-28T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-15T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-15T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <https://w3id.org/noria/kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact :ResourceDBServer01, :AppModuleSQLCluster ;
    noria:changeRequestOutageDuration "PT4H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty :AgentCharlie ;
    noria:changeRequestPilotParty :AgentCharlie ;
    noria:changeRequestActorParty :TeamDBA ;
    noria:changeRequestIsRegulated false .

# Connect more agents to resources
:TeamSecurity noria:agentManagesResource :ResourceDBServer01 . # For security monitoring
:TeamInfra noria:agentManagesResource :ResourceVMHost01 .

# Add a virtual network interface
:NIVirtualApp01Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0 on VirtualApp01"@en ;
    rdfs:comment "Virtual network interface for Virtual Application Server 01."@en ;
    noria:networkInterfaceOf :ResourceVirtualApp01 ;
    noria:networkInterfaceDescription "Virtual LAN segment for application servers."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

# Connect virtual interface to a logical network link (e.g., a VLAN)
:NetworkLinkVLANApp a noria:NetworkLink ;
    rdfs:label "VLAN for Application Servers"@en ;
    rdfs:comment "Logical network segment for communication between application servers."@en ;
    noria:networkLinkId "VLAN-APP-DC1" ;
    noria:networkLinkType "VLAN" ;
    noria:networkLinkInstallationDate "2023-01-20T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :ResourceVirtualApp01 ;
    noria:networkLinkTerminationResourceDestination :ResourceDBServer01 ; # Example: App server connects to DB server
    noria:resourceManagedBy :TeamNetOps .

:NIVirtualApp01Eth0 noria:networkInterfaceConnects :NetworkLinkVLANApp .
:NIDBServer01Eth0 noria:networkInterfaceConnects :NetworkLinkVLANApp . # DB server also connects to this VLAN

# Add a document attachment to a TroubleTicket
:DocAttachmentScreenshotTT001 a noria:DocumentAttachment ;
    rdfs:label "Screenshot of ECP Slowdown"@en ;
    rdfs:comment "Screenshot showing high latency on the E-commerce Platform."@en ;
    dcterms:identifier "ECP-Slowdown-Screenshot-20240420.png" ;
    dcterms:created "2024-04-20T10:07:00Z"^^xsd:dateTime ;
    dcterms:format "image/png" ;
    dcterms:source "https://storage.example.com/attachments/ECP-Slowdown-Screenshot-20240420.png" ;
    dcterms:isPartOf :TroubleTicket001 .

# Add a document attachment to a TroubleTicketNote
:DocAttachmentLogSnippetTT001_1 a noria:DocumentAttachment ;
    rdfs:label "Log Snippet WebServer01 CPU"@en ;
    rdfs:comment "Snippet from web server logs showing CPU spikes."@en ;
    dcterms:identifier "WebServer01-CPU-Log-Snippet.txt" ;
    dcterms:created "2024-04-20T10:16:00Z"^^xsd:dateTime ;
    dcterms:format "text/plain" ;
    dcterms:source "https://storage.example.com/attachments/WebServer01-CPU-Log-Snippet.txt" ;
    dcterms:isPartOf :TTNote001_1 .

# Add more properties to existing entities for even more density
:TroubleTicket001 noria:documentHRef "https://itsm.example.com/ticket/TT-ECP-20240420-001"^^xsd:anyURI .
:ChangeRequest001 noria:documentHRef "https://itsm.example.com/change/CR-WEB-20240422-001"^^xsd:anyURI .

:AgentAlice foaf:mbox_sha1sum "9d3b0e7d6b1c2a3f4e5d6c7b8a9f0e1d2c3b4a5f" .
:AgentBob foaf:mbox_sha1sum "a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0" .

# Add a new resource type: Firewall
:ResourceFirewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Main firewall protecting the corporate network from external threats."@en ;
    noria:resourceLogisticId "ASSET-FW-001" ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel :ProductModelCiscoNexus9K ; # Using a switch model as a placeholder for a firewall product model
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW-001-JKL" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :TeamSecurity ;
    noria:locatedAtLocus :LocusRackN1 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

:ResourceFirewall01 noria:resourceForApplication :ApplicationMonitoringSystem, :ApplicationECommercePlatform . # Firewall protects all applications

# Add network interfaces for the firewall
:NIFirewall01Ext a noria:NetworkInterface ;
    rdfs:label "External Interface on Firewall01"@en ;
    noria:networkInterfaceOf :ResourceFirewall01 ;
    noria:networkInterfaceDescription "Interface connected to the internet via ISP A."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

:NIFirewall01Int a noria:NetworkInterface ;
    rdfs:label "Internal Interface on Firewall01"@en ;
    noria:networkInterfaceOf :ResourceFirewall01 ;
    noria:networkInterfaceDescription "Interface connected to the internal corporate network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

# Connect firewall interfaces to network links
:NIFirewall01Ext noria:networkInterfaceConnects :NetworkLinkWANISP_A .
:NIFirewall01Int noria:networkInterfaceConnects :NetworkLinkLAN1 .

# Update NetworkLinkWANISP_A to include Firewall as a termination resource
:NetworkLinkWANISP_A noria:networkLinkTerminationResource :ResourceFirewall01 .

# Add a new EventRecord for a firewall block
:EventRecordFirewallBlock a noria:EventRecord ;
    rdfs:label "Firewall Block Event"@en ;
    rdfs:comment "Log entry indicating a connection attempt blocked by the firewall."@en ;
    noria:loggingTime "2024-04-20T11:08:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :ResourceFirewall01 ;
    noria:logOriginatingManagementSystem :ApplicationMonitoringSystem ;
    noria:logText "Blocked connection from 192.168.5.10 to 10.0.0.20 (DBServer01) on port 3306."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

# Link the firewall block event to the security trouble ticket
:TroubleTicket004 dcterms:relation :EventRecordFirewallBlock .
:TTNote004_1 noria:troubleTicketNoteCorrelatedExecution :EventRecordFirewallBlock . # The block was part of the response

# Add a new Service for internal IT tools
:ServiceInternalITTools a noria:Service ;
    rdfs:label "Internal IT Tools Service"@en ;
    rdfs:comment "Service providing access to various internal tools for IT staff."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/InternalService> ;
    noria:elementManagedBy :TeamInfra .

# Connect the Monitoring System application to this internal service
:ApplicationMonitoringSystem seas:subSystemOf :ServiceInternalITTools .

# Add a new AnomalyPattern for database issues
:AnomalyPatternDBDeadlock a noria:AnomalyPattern ;
    rdfs:label "Database Deadlock Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating contention in the database, leading to connection errors and performance degradation."@en ;
    folio:hasCause "Application Query Contention" ;
    folio:hasEffect "Database Unresponsiveness" .

:EventRecordDBError dcterms:relation :AnomalyPatternDBDeadlock .
:TroubleTicket003 dcterms:relation :AnomalyPatternDBDeadlock .

# Add a new OperationPlan for database deadlock resolution
:OperationPlanResolveDBDeadlock a noria:OperationPlan ;
    rdfs:label "Resolve Database Deadlock Procedure"@en ;
    rdfs:comment "Procedure to identify and resolve database deadlocks."@en ;
    noria:operationPlanPreCondition :PreConditionDBDeadlockDetected ;
    noria:operationPlanPostCondition :PostConditionDBPerformanceRestored .

:PreConditionDBDeadlockDetected a noria:ActionPreCondition ;
    rdfs:label "Database Deadlock Detected Pre-Condition"@en ;
    rdfs:comment "Condition: Database logs show deadlock errors, and application reports connection failures."@en .

:PostConditionDBPerformanceRestored a noria:ActionPostCondition ;
    rdfs:label "Database Performance Restored Post-Condition"@en ;
    rdfs:comment "Outcome: Database connection errors cease, and application performance returns to normal."@en .

:TroubleTicket003 noria:troubleTicketCharacteristic :OperationPlanResolveDBDeadlock .

# Add a new Agent (Customer)
:AgentCustomerA a foaf:Agent, foaf:Person ;
    rdfs:label "Customer A Representative"@en ;
    rdfs:comment "Representative of a key customer reporting service issues."@en ;
    foaf:mbox <mailto:customer.a@example.com> .

:TroubleTicket001 noria:troubleTicketRelatedParty :AgentCustomerA . # Customer also related to the ticket

# Add a new CorporateUserIdentifier for a security analyst
:CUidSecurityAnalyst a noria:CorporateUserIdentifier ;
    rdfs:label "Security Analyst Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for a security analyst."@en ;
    foaf:accountName "sec_analyst" ;
    foaf:holdsAccount :AgentSecurityAnalyst .

:AgentSecurityAnalyst a foaf:Person, foaf:Agent ;
    rdfs:label "Sarah Connor"@en ;
    rdfs:comment "Security Analyst in Security Operations Team."@en ;
    foaf:mbox <mailto:sarah.connor@example.com> ;
    org:memberOf :TeamSecurity .

:TroubleTicket004 noria:troubleTicketRelatedParty :AgentSecurityAnalyst .

# Add a new ChangeRequest for a security policy update
:ChangeRequest004 a noria:ChangeRequest ;
    rdfs:label "Firewall Security Policy Update"@en ;
    rdfs:comment "Update firewall rules to enhance security posture."@en ;
    dcterms:identifier "CR-SEC-20240505-004" ;
    dcterms:created "2024-05-05T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-20T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-20T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <https://w3id.org/noria/kos/ChangeRequest/cause/ConfigurationChange> ;
    noria:changeRequestImpact :ResourceFirewall01 ;
    noria:changeRequestOutageDuration "PT0M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty :AgentSecurityAnalyst ;
    noria:changeRequestPilotParty :AgentSecurityAnalyst ;
    noria:changeRequestActorParty :TeamSecurity ;
    noria:changeRequestIsRegulated true .

# Link the security policy update to the firewall resource
:ResourceFirewall01 dcterms:relation :ChangeRequest004 .

# Add a new EventRecord for a successful change
:EventRecordCR002Success a noria:EventRecord ;
    rdfs:label "CR-NET-20240425-002 Completed Successfully"@en ;
    rdfs:comment "Log entry confirming successful completion of router firmware upgrade."@en ;
    noria:loggingTime "2024-05-10T02:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :ResourceRouterCore01 ;
    noria:logOriginatingManagementSystem :ApplicationMonitoringSystem ;
    noria:logText "Firmware upgrade on rtr-core01.corp.example.com completed without errors. New version: 19.4R1.8."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

:ChangeRequest002 noria:documentStatusHistory :EventRecordCR002Success ;
    noria:changeRequestActualStartTime "2024-05-10T01:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-05-10T02:25:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Completed> .

# Add a new EventRecord for a failed change
:EventRecordCR001Failure a noria:EventRecord ;
    rdfs:label "CR-WEB-20240422-001 Failed"@en ;
    rdfs:comment "Log entry indicating failure during RAM upgrade on WebServer01."@en ;
    noria:loggingTime "2024-05-01T02:35:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :ResourceWebServer01 ;
    noria:logOriginatingManagementSystem :ApplicationMonitoringSystem ;
    noria:logText "RAM upgrade on web01.corp.example.com failed. Server did not boot after upgrade attempt. Rolling back."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> .

:ChangeRequest001 noria:documentStatusHistory :EventRecordCR001Failure ;
    noria:changeRequestActualStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-05-01T02:35:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Failed> .

# Add a new TroubleTicket for the failed change
:TroubleTicket005 a noria:TroubleTicket ;
