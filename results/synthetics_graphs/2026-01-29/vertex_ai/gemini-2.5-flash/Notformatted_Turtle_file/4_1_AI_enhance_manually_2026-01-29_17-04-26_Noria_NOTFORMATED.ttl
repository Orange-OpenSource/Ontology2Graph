:EventRecordHighCPU a noria:EventRecord ;
    rdfs:label "High CPU Usage Alert"@en ;
    rdfs:comment "Alert indicating sustained high CPU utilization on WebServer01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :ResourceWebServer01 ;
    noria:logOriginatingManagementSystem :ApplicationMonitoringSystem ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction :OperationPlanRestartWebServer .

:EventRecordLinkDown a noria:EventRecord ;
    rdfs:label "Network Link Down Alert"@en ;
    rdfs:comment "Alert indicating that the WAN link to ISP A is down."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :NIRouterCore01Ge001 ;
    noria:logOriginatingManagementSystem :ApplicationMonitoringSystem ;
    noria:logText "Interface ge-0/0/1 on rtr-core01.corp.example.com changed state to down."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction :OperationPlanFailoverWAN .

:EventRecordDBError a noria:EventRecord ;
    rdfs:label "Database Connection Error"@en ;
    rdfs:comment "Log entry indicating a series of failed database connections."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :ResourceDBServer01 ;
    noria:logOriginatingManagementSystem :ApplicationMonitoringSystem ;
    noria:logText "Multiple connection failures to database 'customer_db' from application 'ECP_CustomerPortal'."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> .

:EventRecordConfigChange a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Log entry detailing a configuration change on Core Router 01."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :ResourceRouterCore01 ;
    noria:logOriginatingAgent :AgentBob ;
    noria:logText "Configuration committed by bjohnson from console. Added new static route."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

