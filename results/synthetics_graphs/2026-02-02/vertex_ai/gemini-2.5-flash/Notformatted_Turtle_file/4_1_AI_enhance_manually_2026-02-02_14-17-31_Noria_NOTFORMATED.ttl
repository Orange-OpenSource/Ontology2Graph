noria:EventRecord_DNS01_Down a noria:EventRecord ;
    rdfs:label "DNS01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating that the primary network interface on DNS01 went down."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-DOWN: Interface Ethernet0 on DNS01, changed state to down."@en ;
    noria:alarmSeverity kos:Notification/Severity/PerceivedSeverity/Critical ;
    dcterms:type kos:Notification/EventType/stateChange ;
    dcterms:identifier "EVT-DNS01-IFDOWN-20240420-0900" .

noria:EventRecord_DNS01_InterfaceUp_Action a noria:EventRecord ;
    rdfs:label "DNS01 Interface Up Action Log"@en ;
    rdfs:comment "Log entry for the action taken to bring up the DNS01 interface."@en ;
    noria:loggingTime "2024-04-20T09:38:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_ConfigurationManagement ;
    noria:logOriginatingAgent foaf:Agent_JaneSmith ;
    noria:logText "Command 'interface ethernet0; no shutdown' executed by jsmith."@en ;
    dcterms:type kos:Notification/EventType/configurationChange ;
    dcterms:identifier "EVT-DNS01-IFUP-ACTION-20240420-0938" ;
    noria:alarmMitigatedBy noria:TroubleTicket_DNSOutage001 .

noria:EventRecord_RouterEdge01_CPUHigh a noria:EventRecord ;
    rdfs:label "RouterEdge01 CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Edge Router 01."@en ;
    noria:loggingTime "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterEdge01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CPU utilization on edge-rtr01 exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity kos:Notification/Severity/PerceivedSeverity/Major ;
    dcterms:type kos:Notification/EventType/thresholdViolation ;
    dcterms:identifier "EVT-RTR01-CPUHIGH-20240419-1530" .

noria:EventRecord_SecurityAlert_SQLI a noria:EventRecord ;
    rdfs:label "SQL Injection Attempt Alert"@en ;
    rdfs:comment "Security alert detected an attempted SQL injection on the Customer Portal."@en ;
