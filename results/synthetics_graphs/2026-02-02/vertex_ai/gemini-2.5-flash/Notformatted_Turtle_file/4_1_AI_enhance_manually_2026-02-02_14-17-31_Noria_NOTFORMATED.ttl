    noria:logOriginatingAgent noria:CUid_MaliciousUser ; # Fictional malicious user
    noria:logText "SQL Injection attempt detected from IP 203.0.113.42 on /customer/login."@en ;
    noria:alarmSeverity kos:Notification/Severity/PerceivedSeverity/Critical ;
    dcterms:type kos:Notification/EventType/securityAlert ;
    dcterms:identifier "EVT-SEC-SQLI-20240420-1100" .

noria:CUid_MaliciousUser a noria:CorporateUserIdentifier ;
    rdfs:label "Malicious User ID"@en ;
    rdfs:comment "Fictional user ID for a malicious actor."@en ;
    foaf:accountName "malicious_actor" .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "Application responsible for monitoring network devices and services."@en ;
    noria:applicationType kos:application/type/service-platform ;
    noria:applicationBusinessImportance kos:application/business-importance/high .

noria:Application_ConfigurationManagement a noria:Application ;
    rdfs:label "Configuration Management System"@en ;
    rdfs:comment "Application for managing and deploying configurations to IT resources."@en ;
    noria:applicationType kos:application/type/service-platform ;
    noria:applicationBusinessImportance kos:application/business-importance/medium .

noria:Application_SIEMSystem a noria:Application ;
