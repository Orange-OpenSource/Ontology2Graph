@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

# Base URI for NORIA KOS concepts
@prefix kos: <https://w3id.org/noria/kos/> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, noria:CorporateUserIdentifier)
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for corporate DNS server management and operations."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email ;
    noria:agentInstructions "For critical issues, use the dedicated incident management system and call the on-call number."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for managing network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Phone ;
    noria:agentInstructions "Always open a trouble ticket first, then call the hotline for immediate intervention."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en, "Équipe Développement Application"@fr ;
    rdfs:comment "Team responsible for developing and maintaining the Customer Portal application."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 Monitoring"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual IT administrator, member of the DNS Admin Team."@en .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Individual network engineer, member of the Network Operations Team."@en .

org:OrgUnit_ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en, "Département Informatique"@fr ;
    rdfs:comment "The main IT department of the organization."@en ;
    org:hasMember foaf:Agent_JohnDoe, foaf:Agent_JaneSmith ;
    org:unitOf org:Org_ExampleCorp .

org:Org_ExampleCorp a org:Organization ;
    rdfs:label "ExampleCorp"@en, "Société Exemple"@fr ;
    rdfs:comment "A fictional corporation."@en .

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    rdfs:comment "Primary data center facility for ExampleCorp."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

bot:Site_BranchOffice a bot:Site ;
    rdfs:label "Branch Office Paris"@en, "Bureau Annexe Paris"@fr ;
    rdfs:comment "A smaller branch office location."@en ;
    noria:siteId "BO02" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace bot:Site_MainDataCenter . # bot:hasSpace is inverse of bot:containsZone, but noria:Room is subClassOf bot:Space, not bot:Zone. Let's use bot:hasSpace to link to the site.

noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server within Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "23" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5_U10 a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Specific location for a network device within Server Room A."@en ;
    noria:locusLine "B5" ;
    noria:locusRow "10" ;
    bot:hasSpace noria:Room_ServerRoomA .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various applications."@en ;
    noria:productManufacturedBy org:Org_Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch series."@en ;
    noria:productManufacturedBy org:Org_Cisco .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "Modular router for enterprise and service provider applications."@en ;
    noria:productManufacturedBy org:Org_Juniper .

org:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en .

org:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en .

org:Org_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en .

# =============================================================================
# Resources (noria:Resource, noria:NetworkInterface, noria:NetworkLink)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS d'entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, located in the main data center."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType kos:Resource/type/Server ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CoreInfra ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

noria:Resource_RouterEdge01 a noria:Resource ;
    rdfs:label "Edge Router 01"@en, "Routeur de Bordure 01"@fr ;
    rdfs:comment "Main edge router connecting the corporate network to the internet."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "edge-rtr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceType kos:Resource/type/Router ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_InternetAccess ;
    noria:locatedAtLocus noria:Locus_RackB5_U10 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_SwitchCore01 a noria:Resource ;
    rdfs:label "Core Switch 01"@en, "Commutateur Central 01"@fr ;
    rdfs:comment "Core switch in the data center, providing high-speed connectivity."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "core-sw01.dc01.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType kos:Resource/type/Switch ;
    noria:resourceSerialNumber "SN-SW01-DEF" ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2022-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CoreInfra ;
    noria:locatedAtLocus noria:Locus_RackB5_U10 ;
    noria:resourceManagementIPAddress "10.0.0.2" .

noria:Resource_VMWeb01 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en, "VM Serveur Web 01"@fr ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ; # Assuming VM runs on a physical server of this model
    noria:resourceType kos:Resource/type/VirtualMachine ;
    noria:resourceSerialNumber "VM-WEB01-GHI" ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2023-01-20T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ; # Assuming VM is on a host in this rack
    noria:resourceManagementIPAddress "10.0.1.100" .

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up ;
    noria:networkInterfaceConnects noria:NetworkLink_DNS01_SW01 .

noria:NetworkInterface_RouterEdge01_Ge0_0_0 a noria:NetworkInterface ;
    rdfs:label "RouterEdge01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Interface connecting Edge Router 01 to the internet uplink."@en ;
    noria:networkInterfaceOf noria:Resource_RouterEdge01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:NetworkLink_RouterEdge01_ISP .

noria:NetworkInterface_RouterEdge01_Ge0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterEdge01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Edge Router 01 to Core Switch 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterEdge01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up ;
    noria:networkInterfaceConnects noria:NetworkLink_RouterEdge01_SW01 .

noria:NetworkInterface_SWCore01_Eth1 a noria:NetworkInterface ;
    rdfs:label "CoreSW01 Ethernet 1"@en ;
    rdfs:comment "Interface connecting Core Switch 01 to DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_SwitchCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up ;
    noria:networkInterfaceConnects noria:NetworkLink_DNS01_SW01 .

noria:NetworkInterface_SWCore01_Eth2 a noria:NetworkInterface ;
    rdfs:label "CoreSW01 Ethernet 2"@en ;
    rdfs:comment "Interface connecting Core Switch 01 to Edge Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_SwitchCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up ;
    noria:networkInterfaceConnects noria:NetworkLink_RouterEdge01_SW01 .

noria:NetworkLink_DNS01_SW01 a noria:NetworkLink ;
    rdfs:label "Link DNS01 to CoreSW01"@en ;
    rdfs:comment "Physical link between DNS01 server and Core Switch 01."@en ;
    noria:networkLinkId "LINK-DNS01-SW01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_SwitchCore01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam .

noria:NetworkLink_RouterEdge01_SW01 a noria:NetworkLink ;
    rdfs:label "Link RouterEdge01 to CoreSW01"@en ;
    rdfs:comment "Physical link between Edge Router 01 and Core Switch 01."@en ;
    noria:networkLinkId "LINK-RTR01-SW01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterEdge01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_SwitchCore01 ;
    noria:networkLinkInstallationDate "2021-03-20T14:45:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 40Gbps" ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam .

noria:NetworkLink_RouterEdge01_ISP a noria:NetworkLink ;
    rdfs:label "Link RouterEdge01 to ISP"@en ;
    rdfs:comment "External link from Edge Router 01 to Internet Service Provider."@en ;
    noria:networkLinkId "LINK-RTR01-ISP" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterEdge01 ;
    noria:networkLinkInstallationDate "2021-03-20T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN" ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam .

# =============================================================================
# Applications (noria:Application, noria:ApplicationModule)
# =============================================================================

noria:Application_CoreInfra a noria:Application ;
    rdfs:label "Core Infrastructure Services"@en, "Services d'Infrastructure Core"@fr ;
    rdfs:comment "Critical infrastructure services like DNS, NTP, and Directory Services."@en ;
    noria:applicationType kos:application/type/infrastructure ;
    noria:applicationBusinessImportance kos:application/business-importance/high ;
    noria:applicationModelIdentifier "CORE-INFRA" ;
    noria:applicationShortIdentifier "CI" ;
    noria:applicationFunctionalDomain "Infrastructure Management" ;
    noria:applicationFunctionalSubDomain "Network Services" .

noria:Application_InternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en, "Accès Internet d'Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users and systems."@en ;
    noria:applicationType kos:application/type/infrastructure ;
    noria:applicationBusinessImportance kos:application/business-importance/high ;
    noria:applicationModelIdentifier "INTERNET-ACCESS" ;
    noria:applicationShortIdentifier "IA" ;
    noria:applicationFunctionalDomain "Network Connectivity" ;
    noria:applicationFunctionalSubDomain "WAN Services" .

noria:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal"@en, "Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their accounts and services."@en ;
    noria:applicationType kos:application/type/business-application ;
    noria:applicationBusinessImportance kos:application/business-importance/high ;
    noria:applicationModelIdentifier "CUSTOMER-PORTAL" ;
    noria:applicationShortIdentifier "CP" ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Self-Service" .

noria:ApplicationModule_DNS_Prod a noria:ApplicationModule ;
    rdfs:label "DNS Production Module"@en, "Module DNS Production"@fr ;
    rdfs:comment "Production instance of the DNS service within Core Infrastructure."@en ;
    noria:applicationModuleOf noria:Application_CoreInfra ;
    noria:applicationModuleName "CORE-INFRA_DNS_PROD" ;
    noria:applicationModuleIdentifier "DNS_PROD" ;
    noria:applicationModuleStatus kos:application/status/InProduction ;
    noria:applicationModuleSlaLevel kos:application/sla-level/Gold ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam foaf:Agent_DNSAdminTeam ;
    noria:applicationModuleSupportTeam foaf:Agent_DNSAdminTeam ;
    noria:applicationModuleAdministrationLeader foaf:Agent_JohnDoe .

noria:ApplicationModule_InternetAccess_Prod a noria:ApplicationModule ;
    rdfs:label "Internet Access Production Module"@en, "Module Accès Internet Production"@fr ;
    rdfs:comment "Production instance of the Corporate Internet Access."@en ;
    noria:applicationModuleOf noria:Application_InternetAccess ;
    noria:applicationModuleName "INTERNET-ACCESS_PROD" ;
    noria:applicationModuleIdentifier "IA_PROD" ;
    noria:applicationModuleStatus kos:application/status/InProduction ;
    noria:applicationModuleSlaLevel kos:application/sla-level/Gold ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam foaf:Agent_NetworkOpsTeam ;
    noria:applicationModuleSupportTeam foaf:Agent_NetworkOpsTeam ;
    noria:applicationModuleAdministrationLeader foaf:Agent_JaneSmith .

noria:ApplicationModule_CustomerPortal_Dev a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en, "Module Portail Client Développement"@fr ;
    rdfs:comment "Development instance of the Customer Portal application."@en ;
    noria:applicationModuleOf noria:Application_CustomerPortal ;
    noria:applicationModuleName "CUSTOMER-PORTAL_DEV" ;
    noria:applicationModuleIdentifier "CP_DEV" ;
    noria:applicationModuleStatus kos:application/status/Development ;
    noria:applicationModuleSlaLevel kos:application/sla-level/Bronze ;
    noria:applicationModuleSlaLevelDate "2023-03-15T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleAdministrationTeam foaf:Agent_AppDevTeam ;
    noria:applicationModuleSupportTeam foaf:Agent_AppDevTeam .

# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service_EnterpriseConnectivity a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en, "Service de Connectivité d'Entreprise"@fr ;
    rdfs:comment "End-to-end service providing network connectivity across the enterprise."@en ;
    noria:serviceType kos:service/type/CustomerFacingService ;
    seas:subSystemOf noria:Application_InternetAccess, noria:Application_CoreInfra . # A service can be composed of applications

noria:Service_DNSResolution a noria:Service ;
    rdfs:label "DNS Resolution Service"@en, "Service de Résolution DNS"@fr ;
    rdfs:comment "Core service for resolving domain names within the corporate network."@en ;
    noria:serviceType kos:service/type/ResourceFacingService ;
    seas:subSystemOf noria:Application_CoreInfra .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket, noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicket_DNSOutage001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "Primary DNS server unreachable causing internet access issues for users."@en ;
    noria:troubleTicketSeverity kos:TroubleTicket/severity/Critical ;
    noria:troubleTicketType kos:TroubleTicket/type/Failure ;
    noria:troubleTicketCriticity kos:TroubleTicket/category/InterruptedService ;
    noria:troubleTicketPriority kos:TroubleTicket/priority/P1 ;
    noria:troubleTicketOrigin kos:TroubleTicket/origin/Supervision ;
    noria:troubleTicketUrgency kos:TroubleTicket/urgency/ImmediateIntervention ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory kos:TroubleTicket/category/InterruptedService ;
    noria:troubleTicketCause "Network interface on DNS01 went down due to misconfiguration."@en ;
    noria:problemResponsibility kos:TroubleTicket/problemResponsibility/ManagedBackboneNetworks ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent kos:TroubleTicket/status/InProgress ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkOpsTeam, foaf:Agent_DNSAdminTeam ;
    noria:troubleTicketRelatedService noria:Application_CoreInfra, noria:Service_DNSResolution ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:Application_InternetAccess, noria:Resource_DNS01 ;
    noria:troubleTicketTrigger noria:EventRecord_DNS01_Down ;
    dcterms:identifier "TT-DNS-001" ;
    dcterms:created "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T09:45:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-2024-04-20-001" ;
    noria:documentHRef "https://itsm.example.com/tickets/TT-DNS-001" .

noria:TroubleTicketNote_DNSOutage001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note"@en ;
    rdfs:comment "Confirmed network interface ge-0/0/0 on dns01 is down. Investigating root cause."@en ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JaneSmith ;
    noria:troubleTicketNoteCommentType kos:TroubleTicket/commentType/Internal ;
    noria:troubleTicketNoteOperationType kos:TroubleTicket/operationType/Diagnosis ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage001 .

noria:TroubleTicketNote_DNSOutage001_Note2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Action Note"@en ;
    rdfs:comment "Interface ge-0/0/0 on dns01 reconfigured and brought up. DNS service restored."@en ;
    dcterms:created "2024-04-20T09:40:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JaneSmith ;
    noria:troubleTicketNoteCommentType kos:TroubleTicket/commentType/Internal ;
    noria:troubleTicketNoteOperationType kos:TroubleTicket/operationType/TestsAndMeasurements ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage001 ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_DNS01_InterfaceUp_Action .

noria:TroubleTicket_WebPortalIssue002 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Login Issue"@en, "Problème de Connexion Portail Client"@fr ;
    rdfs:comment "Users unable to log in to the customer portal. Affects production module."@en ;
    noria:troubleTicketSeverity kos:TroubleTicket/severity/Major ;
    noria:troubleTicketType kos:TroubleTicket/type/Assistance ;
    noria:troubleTicketCriticity kos:TroubleTicket/category/DowngradingEquipment ;
    noria:troubleTicketPriority kos:TroubleTicket/priority/P2 ;
    noria:troubleTicketOrigin kos:TroubleTicket/origin/Customer ;
    noria:troubleTicketUrgency kos:TroubleTicket/urgency/DeferredIntervention ;
    noria:troubleTicketSupervisionTool "Customer Feedback" ;
    noria:troubleTicketCategory kos:TroubleTicket/category/DowngradingEquipment ;
    noria:troubleTicketCause "Database connection pool exhaustion on web01."@en ;
