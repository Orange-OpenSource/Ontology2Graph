    rdfs:comment "System for collecting, analyzing, and presenting security alerts."@en ;
    noria:applicationType kos:application/type/service-platform ;
    noria:applicationBusinessImportance kos:application/business-importance/high .

# =============================================================================
# Operational Plans and Conditions (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:OperationPlan_RouterInterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving router interface issues."@en ;
    skos:example "Steps include checking cable, interface status, logs, and reconfiguring interface."@en ;
    noria:operationPlanPreCondition noria:PreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:PostCondition_InterfaceUp .

noria:PreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface on a critical router is reported as operationally down."@en .

noria:PostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface is brought back to an operational 'up' state, and traffic flows normally."@en .

noria:OperationPlan_DNSCacheClear a noria:OperationPlan ;
    rdfs:label "DNS Cache Clear Procedure"@en ;
    rdfs:comment "Procedure to clear DNS cache on a server to resolve stale DNS entries."@en ;
    noria:operationPlanPreCondition noria:PreCondition_StaleDNS ;
    noria:operationPlanPostCondition noria:PostCondition_DNSResolved .

noria:PreCondition_StaleDNS a noria:ActionPreCondition ;
    rdfs:label "Stale DNS Entry Detected"@en ;
    rdfs:comment "Condition: Users report incorrect IP resolution for a known hostname, indicating stale DNS cache."@en .

noria:PostCondition_DNSResolved a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Corrected"@en ;
    rdfs:comment "Expected outcome: DNS queries for the affected hostname return the correct IP address."@en .

# =============================================================================
# Anomaly Patterns (noria:AnomalyPattern)
# =============================================================================

noria:AnomalyPattern_NetworkLoop a noria:AnomalyPattern ;
    rdfs:label "Network Loop Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential network loop: high broadcast traffic, flapping interfaces, and high CPU on multiple switches."@en ;
    skos:example "Correlated events: EventRecord_SwitchCore01_CPUHigh, EventRecord_SwitchCore02_CPUHigh, EventRecord_LinkFlap."@en .

noria:AnomalyPattern_DDoSAttack a noria:AnomalyPattern ;
    rdfs:label "DDoS Attack Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a Distributed Denial of Service attack: sudden surge in traffic, multiple source IPs, service unavailability."@en ;
    skos:example "Correlated events: EventRecord_RouterEdge01_CPUHigh, EventRecord_ISP_TrafficSpike, TroubleTicket_InternetAccessOutage."@en .

