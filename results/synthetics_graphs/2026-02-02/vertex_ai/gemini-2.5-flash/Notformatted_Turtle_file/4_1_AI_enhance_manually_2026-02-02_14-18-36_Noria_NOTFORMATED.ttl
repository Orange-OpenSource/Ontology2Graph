    noria:applicationModuleOf :Application_CRMSystem ;
    noria:applicationModuleName "CRMAPP_PROD"@en ;
    noria:applicationModuleIdentifier "PROD-CRM-01"@en ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam :Agent_IT_Operations_Team ;
    noria:applicationModuleSupportTeam :Agent_App_Support_Team ;
    noria:applicationModuleSlaLevel <kos/application/sla-level/Gold> ;
    noria:applicationModuleHotlineEnabled true .

:Service_PublicFacingServices a noria:Service ;
    rdfs:label "Public Facing Services"@en ;
    rdfs:comment "A collection of services directly accessible by the public, including the corporate website."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :Application_CorporateWebsite . # Example of linking an application to a service

:Service_InternalITServices a noria:Service ;
    rdfs:label "Internal IT Services"@en ;
    rdfs:comment "Services supporting internal operations, like the CRM system and core network."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf :Application_CRMSystem, :Application_CorporateNetworkInfrastructure .

################################################################################
# Dynamic Elements (noria:EventRecord, noria:TroubleTicket, noria:ChangeRequest, noria:TroubleTicketNote, noria:DocumentAttachment)
################################################################################

:EventRecord_WebServerDown a noria:EventRecord ;
    rdfs:label "Web Server 01 Down Alert"@en ;
    rdfs:comment "Automated alert indicating Web Server 01 is unreachable."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_WebServer01 ;
    noria:logOriginatingManagementSystem :Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host web01.corp.example.com is DOWN!"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction :OperationPlan_RestartWebServer .

:EventRecord_RouterInterfaceFlap a noria:EventRecord ;
    rdfs:label "Router Interface Flap Alert"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 flapped (went down and up)."@en ;
