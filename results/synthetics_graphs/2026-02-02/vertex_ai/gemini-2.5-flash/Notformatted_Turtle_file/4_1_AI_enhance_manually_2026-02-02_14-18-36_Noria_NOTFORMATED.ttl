En tant qu'expert en modélisation de graphes de connaissances RDF/OWL et en syntaxe Turtle, je vais générer un graphe de connaissances complet, dense et connecté, en respectant scrupuleusement le vocabulaire NORIA fourni.

---

@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .

# Base URI for the generated instances
@base <https://w3id.org/noria/data/> .

################################################################################
# KOS Concepts (Knowledge Organization System)
# These are used as ranges for various properties to provide controlled vocabularies.
################################################################################

# Application Types
<kos/application/type/infrastructure> a skos:Concept ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application providing core infrastructure services."@en .

<kos/application/type/service-platform> a skos:Concept ;
    rdfs:label "Service Platform Application"@en ;
    rdfs:comment "An application acting as a platform for other services."@en .

<kos/application/type/business-application> a skos:Concept ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "An application directly supporting business operations."@en .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for business operations."@en .

<kos/application/business-importance/medium> a skos:Concept ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application is important but not critical for business operations."@en .

# Application Status
<kos/application/status/InProduction> a skos:Concept ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application module is currently live and operational."@en .

<kos/application/status/Development> a skos:Concept ;
    rdfs:label "Development"@en ;
    rdfs:comment "Application module is under development."@en .

# Application SLA Level
<kos/application/sla-level/Gold> a skos:Concept ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement tier."@en .

# Service Types
<kos/service/type/CustomerFacingService> a skos:Concept ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by external customers."@en .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that manages internal resources, not directly exposed to customers."@en .

# TroubleTicket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Incident causing severe impact, requiring immediate attention."@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Incident causing significant impact, but not critical."@en .

# TroubleTicket Type
<kos/TroubleTicket/type/Failure> a skos:Concept ;
    rdfs:label "Failure Ticket"@en ;
    rdfs:comment "Ticket reporting a system or service failure."@en .

# TroubleTicket Category
<kos/TroubleTicket/category/InterruptedService> a skos:Concept ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "Category for incidents where a service is completely unavailable."@en .

# TroubleTicket Priority
<kos/TroubleTicket/priority/P1> a skos:Concept ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority for incident resolution."@en .

# TroubleTicket Origin
<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    rdfs:label "Supervision Origin"@en ;
    rdfs:comment "Trouble ticket originated from monitoring or supervision systems."@en .

# TroubleTicket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Action required without delay."@en .

# TroubleTicket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ;
    rdfs:label "Managed Backbone Networks Responsibility"@en ;
    rdfs:comment "Responsibility lies with the team managing backbone network infrastructure."@en .

# TroubleTicket Status
<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Trouble ticket is currently being worked on."@en .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "Trouble ticket issue has been fixed."@en .

# TroubleTicket Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team members."@en .

# TroubleTicket Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Operation related to diagnosing the root cause of an issue."@en .

# ChangeRequest Category
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request for internal operational activities."@en .

# ChangeRequest Type
<kos/ChangeRequest/type/Standard> a skos:Concept ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk."@en .

# ChangeRequest Cause
<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ;
    rdfs:label "Preventative Maintenance Cause"@en ;
    rdfs:comment "Change initiated for preventative maintenance."@en .

# ChangeRequest Status
<kos/ChangeRequest/status/Approved> a skos:Concept ;
    rdfs:label "Approved Change"@en ;
    rdfs:comment "Change request has been approved."@en .

# ChangeRequest Specification
<kos/ChangeRequest/specification/StandardProcedureA> a skos:Concept ;
    rdfs:label "Standard Procedure A"@en ;
    rdfs:comment "Reference to a standard operating procedure for this change."@en .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ;
    rdfs:label "Operational Up"@en ;
    rdfs:comment "Resource is currently operating normally."@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    rdfs:label "Operational Down"@en ;
    rdfs:comment "Resource is currently not operating."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState/Up> a skos:Concept ;
    rdfs:label "Administrative Up"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Down> a skos:Concept ;
    rdfs:label "Administrative Down"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

# Resource Type
<kos/Resource/type/Router> a skos:Concept ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network device that forwards data packets between computer networks."@en .

<kos/Resource/type/Server> a skos:Concept ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computer program or a device that provides functionality for other programs or devices."@en .

<kos/Resource/type/Switch> a skos:Concept ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network device that connects devices in a computer network."@en .

<kos/Resource/type/VirtualMachine> a skos:Concept ;
    rdfs:label "Virtual Machine"@en ;
    rdfs:comment "An emulation of a computer system."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InProduction> a skos:Concept ;
    rdfs:label "In Production Lifecycle"@en ;
    rdfs:comment "Resource is in active production use."@en .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ;
    rdfs:label "Email Contact Method"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    rdfs:label "Phone Contact Method"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    rdfs:label "Critical Perceived Severity"@en ;
    rdfs:comment "The most severe level of alarm."@en .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    rdfs:label "Major Perceived Severity"@en ;
    rdfs:comment "A significant level of alarm."@en .

################################################################################
# Agents (foaf:Agent, org:OrganizationalUnit, noria:CorporateUserIdentifier)
################################################################################

:Agent_IT_Operations_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email to it-ops@example.com for general inquiries. Use ticketing system for incidents."@en .

:Agent_Network_Admin_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Team responsible for managing network devices and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call emergency hotline for critical network issues."@en ;
    noria:agentManagesResource :Resource_CoreRouter01, :Resource_EdgeSwitch01 .

:Agent_App_Support_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

:Agent_Security_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

:Agent_John_Doe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

:Agent_Jane_Smith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Manager for CRM System."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

:CorporateUserIdentifier_JDoe a noria:CorporateUserIdentifier ;
    rdfs:label "jdoe_cuid"@en ;
    rdfs:comment "Corporate User ID for John Doe."@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount :Agent_John_Doe .

################################################################################
# Locations (bot:Site, noria:Room, noria:Locus)
################################################################################

:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for the organization."@en ;
    noria:siteId "DC01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en ;
    noria:sitePrincipalAddressStreet "Tech Avenue"@en .

:Room_ServerRoom_A a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated room within the Main Data Center for server racks."@en ;
    bot:hasSpace :Site_MainDataCenter .

:Locus_Rack_A1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location within Server Room A for a server unit."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "23"@en ;
    bot:hasSpace :Room_ServerRoom_A .

:Locus_Rack_B5_U10 a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Specific location within Server Room A for a network device."@en ;
    noria:locusLine "B5"@en ;
    noria:locusRow "10"@en ;
    bot:hasSpace :Room_ServerRoom_A .

################################################################################
# Resources (noria:Resource, noria:ProductModel, noria:NetworkInterface, noria:NetworkLink)
################################################################################

:ProductModel_Dell_R740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Server model from Dell."@en ;
    noria:productManufacturedBy :Org_Dell .

:ProductModel_Cisco_ASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "High-end router model from Cisco."@en ;
    noria:productManufacturedBy :Org_Cisco .

:ProductModel_HP_ProCurve a noria:ProductModel ;
    rdfs:label "HP ProCurve 5400zl Switch"@en ;
    rdfs:comment "Modular switch model from HP."@en ;
    noria:productManufacturedBy :Org_HP .

:Org_Dell a org:Organization ;
    rdfs:label "Dell Inc."@en ;
    rdfs:comment "Multinational computer technology company."@en .

:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en ;
    rdfs:comment "American multinational technology conglomerate."@en .

:Org_HP a org:Organization ;
    rdfs:label "HP Inc."@en ;
    rdfs:comment "American multinational information technology company."@en .

:Resource_WebServer01 a noria:Resource ;
    rdfs:label "Corporate Web Server 01"@en ;
    rdfs:comment "Primary web server hosting the corporate website."@en ;
    noria:resourceLogisticId "WS01-DC01-A1-23"@en ;
    noria:resourceHostName "web01.corp.example.com"@en ;
    noria:resourceProductModel :ProductModel_Dell_R740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WS01-XYZ789"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_IT_Operations_Team ;
    noria:resourceForApplication :Application_CorporateWebsite ;
    noria:locatedAtLocus :Locus_Rack_A1_U23 ;
    noria:resourceManagementIPAddress "192.168.10.101" .

:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceLogisticId "CR01-DC01-B5-10"@en ;
    noria:resourceHostName "cr01.corp.example.com"@en ;
    noria:resourceProductModel :ProductModel_Cisco_ASR9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR01-ABC123"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_Network_Admin_Team ;
    noria:resourceForApplication :Application_CorporateNetworkInfrastructure ;
    noria:locatedAtLocus :Locus_Rack_B5_U10 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

:Resource_EdgeSwitch01 a noria:Resource ;
    rdfs:label "Edge Switch 01"@en ;
    rdfs:comment "Access layer switch connecting end-user devices."@en ;
    noria:resourceLogisticId "ES01-DC01-B5-11"@en ;
    noria:resourceHostName "es01.corp.example.com"@en ;
    noria:resourceProductModel :ProductModel_HP_ProCurve ;
    noria:resourceType <kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-ES01-DEF456"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-06-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_Network_Admin_Team ;
    noria:resourceForApplication :Application_CorporateNetworkInfrastructure ;
    noria:locatedAtLocus :Locus_Rack_B5_10 ; # Assuming it's in the same rack as the router for simplicity
    noria:resourceManagementIPAddress "10.0.0.2" .

:Resource_VirtualDBServer a noria:Resource ;
    rdfs:label "Virtual Database Server"@en ;
    rdfs:comment "Virtual machine hosting the database for the CRM application."@en ;
    noria:resourceHostName "db01.crm.example.com"@en ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceManagedBy :Agent_IT_Operations_Team ;
    noria:resourceForApplication :Application_CRMSystem ;
    noria:clusterController :Resource_WebServer01 ; # Example of cluster controller relationship
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

:NetworkInterface_CR01_GE0_0_0 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/0 on Core Router 01."@en ;
    noria:networkInterfaceOf :Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

:NetworkInterface_CR01_GE0_0_1 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/1 on Core Router 01, connected to the internet uplink."@en ;
    noria:networkInterfaceOf :Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -20 .

:NetworkInterface_WS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Ethernet interface 0 on Web Server 01."@en ;
    noria:networkInterfaceOf :Resource_WebServer01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

:NetworkLink_CR01_WS01 a noria:NetworkLink ;
    rdfs:label "Link CoreRouter01 to WebServer01"@en ;
    rdfs:comment "Direct network link between Core Router 01 and Web Server 01."@en ;
    noria:networkLinkId "NL-CR01-WS01-001"@en ;
    noria:networkLinkTerminationResourceOrigin :Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination :Resource_WebServer01 ;
    noria:networkLinkInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps"@en ;
    noria:resourceManagedBy :Agent_Network_Admin_Team .

:NetworkInterface_CR01_GE0_0_0 noria:networkInterfaceConnects :NetworkLink_CR01_WS01 .
:NetworkInterface_WS01_Eth0 noria:networkInterfaceConnects :NetworkLink_CR01_WS01 .

################################################################################
# Applications & Services (noria:Application, noria:ApplicationModule, noria:Service)
################################################################################

:Application_CorporateWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "The official public website of the corporation."@en ;
    noria:applicationModelIdentifier "CORPWEB"@en ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CW"@en ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Marketing and Sales"@en ;
    noria:applicationFunctionalSubDomain "Online Presence Management"@en .

:Application_CorporateNetworkInfrastructure a noria:Application ;
    rdfs:label "Corporate Network Infrastructure"@en ;
    rdfs:comment "The underlying network infrastructure supporting all corporate IT services."@en ;
    noria:applicationModelIdentifier "CORPNET"@en ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CNI"@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations"@en ;
    noria:applicationFunctionalSubDomain "Network Management"@en .

:Application_CRMSystem a noria:Application ;
