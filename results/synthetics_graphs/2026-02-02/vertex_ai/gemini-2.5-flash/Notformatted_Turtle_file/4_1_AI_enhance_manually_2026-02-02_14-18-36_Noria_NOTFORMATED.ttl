################################################################################
# Procedural Elements (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition, noria:AnomalyPattern)
################################################################################

:OperationPlan_RestartWebServer a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a web server."@en ;
    skos:example "Steps include checking logs, attempting graceful shutdown, forced shutdown, and verification."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_WebServerUnreachable ;
    noria:operationPlanPostCondition :ActionPostCondition_WebServerOperational .

:OperationPlan_DiagnoseNetworkIssue a noria:OperationPlan ;
    rdfs:label "Diagnose Network Connectivity Issue"@en ;
    rdfs:comment "Procedure for diagnosing network connectivity problems."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_NetworkConnectivityLoss ;
    noria:operationPlanPostCondition :ActionPostCondition_NetworkConnectivityRestored .

:ActionPreCondition_WebServerUnreachable a noria:ActionPreCondition ;
    rdfs:label "Web Server Unreachable"@en ;
    rdfs:comment "Condition: The web server does not respond to network requests (e.g., ping, HTTP)."@en ;
    skos:example "Ping to web01.corp.example.com fails; HTTP GET / returns connection refused."@en .

:ActionPreCondition_NetworkConnectivityLoss a noria:ActionPreCondition ;
    rdfs:label "Network Connectivity Loss"@en ;
    rdfs:comment "Condition: Loss of network connectivity to a critical resource or segment."@en ;
    skos:example "Traceroute fails, high packet loss, interface status is down."@en .

:ActionPostCondition_WebServerOperational a noria:ActionPostCondition ;
    rdfs:label "Web Server Operational"@en ;
    rdfs:comment "Expected outcome: The web server is reachable and serving content."@en ;
    skos:example "Ping to web01.corp.example.com succeeds; HTTP GET / returns 200 OK."@en .

:ActionPostCondition_NetworkConnectivityRestored a noria:ActionPostCondition ;
    rdfs:label "Network Connectivity Restored"@en ;
    rdfs:comment "Expected outcome: Network connectivity to the affected resource is re-established."@en ;
    skos:example "Ping to target resource succeeds, no packet loss, interface status is up."@en .

:AnomalyPattern_HighCPUUsage a noria:AnomalyPattern ;
    rdfs:label "High CPU Usage Anomaly"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization on a server, potentially leading to performance degradation or crash."@en ;
    folio:hasCause "Software bug or misconfiguration"@en .

:AnomalyPattern_NetworkLoop a noria:AnomalyPattern ;
    rdfs:label "Network Loop Anomaly"@en ;
    rdfs:comment "Pattern indicating a network loop, characterized by high broadcast traffic and network instability."@en ;
    folio:hasCause "Incorrect network cabling or spanning-tree misconfiguration"@en .

