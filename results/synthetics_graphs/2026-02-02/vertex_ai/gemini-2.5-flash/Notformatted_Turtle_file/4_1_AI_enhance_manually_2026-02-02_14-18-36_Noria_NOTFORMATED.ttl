    noria:applicationModelIdentifier "CRMAPP"@en ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "CRM"@en ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Service"@en ;
    noria:applicationFunctionalSubDomain "Customer Data Management"@en .

:ApplicationModule_CorporateWebsite_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate Website Production Module"@en ;
    rdfs:comment "The production instance of the corporate website."@en ;
    noria:applicationModuleOf :Application_CorporateWebsite ;
    noria:applicationModuleName "CORPWEB_PROD"@en ;
    noria:applicationModuleIdentifier "PROD-CW-01"@en ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam :Agent_IT_Operations_Team ;
    noria:applicationModuleAdministrationLeader :Agent_John_Doe ;
    noria:applicationModuleSupportTeam :Agent_App_Support_Team ;
    noria:applicationModuleSupportLeader :Agent_Jane_Smith ;
    noria:applicationModuleSlaLevel <kos/application/sla-level/Gold> ;
