# KOS concepts (Knowledge Organization System)
# These are used as ranges for certain properties and represent controlled vocabularies.

# Application Type
kos-app-type:Infrastructure a skos:Concept ; skos:prefLabel "Infrastructure"@en ; skos:altLabel "Infrastructure informatique"@fr .
kos-app-type:BusinessApplication a skos:Concept ; skos:prefLabel "Business Application"@en ; skos:altLabel "Application métier"@fr .
kos-app-type:MonitoringSystem a skos:Concept ; skos:prefLabel "Monitoring System"@en ; skos:altLabel "Système de supervision"@fr .
kos-app-type:DatabaseService a skos:Concept ; skos:prefLabel "Database Service"@en ; skos:altLabel "Service de base de données"@fr .
kos-app-type:AuthenticationService a skos:Concept ; skos:prefLabel "Authentication Service"@en ; skos:altLabel "Service d'authentification"@fr .

# Application Business Importance
kos-app-bizimp:High a skos:Concept ; skos:prefLabel "High"@en ; skos:altLabel "Élevée"@fr .
kos-app-bizimp:Medium a skos:Concept ; skos:prefLabel "Medium"@en ; skos:altLabel "Moyenne"@fr .
kos-app-bizimp:Low a skos:Concept ; skos:prefLabel "Low"@en ; skos:altLabel "Faible"@fr .

# Application Status
kos-app-status:InProduction a skos:Concept ; skos:prefLabel "In Production"@en ; skos:altLabel "En Production"@fr .
kos-app-status:Development a skos:Concept ; skos:prefLabel "Development"@en ; skos:altLabel "En Développement"@fr .
kos-app-status:Decommissioned a skos:Concept ; skos:prefLabel "Decommissioned"@en ; skos:altLabel "Hors service"@fr .
kos-app-status:Testing a skos:Concept ; skos:prefLabel "Testing"@en ; skos:altLabel "En Test"@fr .

# Application SLA Level
kos-app-sla:Platinum a skos:Concept ; skos:prefLabel "Platinum"@en ; skos:altLabel "Platine"@fr .
kos-app-sla:Gold a skos:Concept ; skos:prefLabel "Gold"@en ; skos:altLabel "Or"@fr .
kos-app-sla:Silver a skos:Concept ; skos:prefLabel "Silver"@en ; skos:altLabel "Argent"@fr .

# Service Type
kos-svc-type:CustomerFacingService a skos:Concept ; skos:prefLabel "Customer Facing Service"@en ; skos:altLabel "Service client"@fr .
kos-svc-type:ResourceFacingService a skos:Concept ; skos:prefLabel "Resource Facing Service"@en ; skos:altLabel "Service interne"@fr .

# TroubleTicket Severity
kos-tt-sev:Critical a skos:Concept ; skos:prefLabel "Critical"@en ; skos:altLabel "Critique"@fr .
kos-tt-sev:Major a skos:Concept ; skos:prefLabel "Major"@en ; skos:altLabel "Majeure"@fr .
kos-tt-sev:Minor a skos:Concept ; skos:prefLabel "Minor"@en ; skos:altLabel "Mineure"@fr .
kos-tt-sev:Warning a skos:Concept ; skos:prefLabel "Warning"@en ; skos:altLabel "Avertissement"@fr .

# TroubleTicket Type
kos-tt-type:Failure a skos:Concept ; skos:prefLabel "Failure"@en ; skos:altLabel "Panne"@fr .
kos-tt-type:Assistance a skos:Concept ; skos:prefLabel "Assistance"@en ; skos:altLabel "Assistance"@fr .
kos-tt-type:Maintenance a skos:Concept ; skos:prefLabel "Maintenance"@en ; skos:altLabel "Maintenance"@fr .

# TroubleTicket Priority
kos-tt-prio:P1 a skos:Concept ; skos:prefLabel "Priority 1"@en ; skos:altLabel "Priorité 1"@fr .
kos-tt-prio:P2 a skos:Concept ; skos:prefLabel "Priority 2"@en ; skos:altLabel "Priorité 2"@fr .
kos-tt-prio:P3 a skos:Concept ; skos:prefLabel "Priority 3"@en ; skos:altLabel "Priorité 3"@fr .

# TroubleTicket Origin
kos-tt-origin:Customer a skos:Concept ; skos:prefLabel "Customer"@en ; skos:altLabel "Client"@fr .
kos-tt-origin:Supervision a skos:Concept ; skos:prefLabel "Supervision"@en ; skos:altLabel "Supervision"@fr .
kos-tt-origin:Internal a skos:Concept ; skos:prefLabel "Internal"@en ; skos:altLabel "Interne"@fr .

# TroubleTicket Urgency
kos-tt-urg:ImmediateIntervention a skos:Concept ; skos:prefLabel "Immediate Intervention"@en ; skos:altLabel "Intervention Immédiate"@fr .
kos-tt-urg:DeferredIntervention a skos:Concept ; skos:prefLabel "Deferred Intervention"@en ; skos:altLabel "Intervention Différée"@fr .

# TroubleTicket Trouble Category
kos-tt-tc:TotalBreakdown a skos:Concept ; skos:prefLabel "Total Breakdown"@en ; skos:altLabel "Panne totale"@fr .
kos-tt-tc:ServiceDegradation a skos:Concept ; skos:prefLabel "Service Degradation"@en ; skos:altLabel "Dégradation de service"@fr .
kos-tt-tc:ConfigurationIssue a skos:Concept ; skos:prefLabel "Configuration Issue"@en ; skos:altLabel "Problème de configuration"@fr .

# TroubleTicket Problem Responsibility
kos-tt-pr:ManagedBackboneNetworks a skos:Concept ; skos:prefLabel "Managed Backbone Networks"@en ; skos:altLabel "Réseaux Backbone Gérés"@fr .
kos-tt-pr:CustomerEquipment a skos:Concept ; skos:prefLabel "Customer Equipment"@en ; skos:altLabel "Équipement Client"@fr .
kos-tt-pr:InternalIT a skos:Concept ; skos:prefLabel "Internal IT"@en ; skos:altLabel "IT Interne"@fr .

# TroubleTicket Status
kos-tt-status:Initialised a skos:Concept ; skos:prefLabel "Initialised"@en ; skos:altLabel "Initialisé"@fr .
kos-tt-status:InProgress a skos:Concept ; skos:prefLabel "In Progress"@en ; skos:altLabel "En cours"@fr .
kos-tt-status:Resolved a skos:Concept ; skos:prefLabel "Resolved"@en ; skos:altLabel "Résolu"@fr .
kos-tt-status:Closed a skos:Concept ; skos:prefLabel "Closed"@en ; skos:altLabel "Fermé"@fr .

# TroubleTicket Comment Type
kos-tt-cmt:Internal a skos:Concept ; skos:prefLabel "Internal"@en ; skos:altLabel "Interne"@fr .
kos-tt-cmt:Customer a skos:Concept ; skos:prefLabel "Customer"@en ; skos:altLabel "Client"@fr .
kos-tt-cmt:System a skos:Concept ; skos:prefLabel "System"@en ; skos:altLabel "Système"@fr .

# TroubleTicket Operation Type
kos-tt-op:Diagnosis a skos:Concept ; skos:prefLabel "Diagnosis"@en ; skos:altLabel "Diagnostic"@fr .
kos-tt-op:TestsAndMeasurements a skos:Concept ; skos:prefLabel "Tests and Measurements"@en ; skos:altLabel "Tests et Mesures"@fr .
kos-tt-op:CustomerCallBack a skos:Concept ; skos:prefLabel "Customer Call Back"@en ; skos:altLabel "Rappel Client"@fr .

# ChangeRequest Category
kos-cr-cat:InternalIntervention a skos:Concept ; skos:prefLabel "Internal Intervention"@en ; skos:altLabel "Intervention Interne"@fr .
kos-cr-cat:ThirdPartyIntervention a skos:Concept ; skos:prefLabel "Third Party Intervention"@en ; skos:altLabel "Intervention Tiers"@fr .

# ChangeRequest Type
kos-cr-type:Standard a skos:Concept ; skos:prefLabel "Standard Change"@en ; skos:altLabel "Changement Standard"@fr .
kos-cr-type:Normal a skos:Concept ; skos:prefLabel "Normal Change"@en ; skos:altLabel "Changement Normal"@fr .
kos-cr-type:Emergency a skos:Concept ; skos:prefLabel "Emergency Change"@en ; skos:altLabel "Changement d'Urgence"@fr .

# ChangeRequest Cause
kos-cr-cause:SoftwareUpgrade a skos:Concept ; skos:prefLabel "Software Upgrade"@en ; skos:altLabel "Mise à jour logicielle"@fr .
kos-cr-cause:ConfigurationChange a skos:Concept ; skos:prefLabel "Configuration Change"@en ; skos:altLabel "Changement de configuration"@fr .
kos-cr-cause:PreventativeMaintenance a skos:Concept ; skos:prefLabel "Preventative Maintenance"@en ; skos:altLabel "Maintenance Préventive"@fr .

# ChangeRequest Status
kos-cr-status:Planned a skos:Concept ; skos:prefLabel "Planned"@en ; skos:altLabel "Planifié"@fr .
kos-cr-status:InProgress a skos:Concept ; skos:prefLabel "In Progress"@en ; skos:altLabel "En cours"@fr .
kos-cr-status:Completed a skos:Concept ; skos:prefLabel "Completed"@en ; skos:altLabel "Terminé"@fr .
kos-cr-status:Failed a skos:Concept ; skos:prefLabel "Failed"@en ; skos:altLabel "Échoué"@fr .

# ChangeRequest Specification
kos-cr-spec:StandardProcedureA a skos:Concept ; skos:prefLabel "Standard Procedure A"@en ; skos:altLabel "Procédure Standard A"@fr .
kos-cr-spec:StandardProcedureB a skos:Concept ; skos:prefLabel "Standard Procedure B"@en ; skos:altLabel "Procédure Standard B"@fr .

# Resource Operational State
kos-res-op:Up a skos:Concept ; skos:prefLabel "Up"@en ; skos:altLabel "Actif"@fr .
kos-res-op:Down a skos:Concept ; skos:prefLabel "Down"@en ; skos:altLabel "Inactif"@fr .
kos-res-op:Degraded a skos:Concept ; skos:prefLabel "Degraded"@en ; skos:altLabel "Dégradé"@fr .

# Resource Administrative State
kos-res-adm:Up a skos:Concept ; skos:prefLabel "Up"@en ; skos:altLabel "Administratif Actif"@fr .
kos-res-adm:Down a skos:Concept ; skos:prefLabel "Down"@en ; skos:altLabel "Administratif Inactif"@fr .

# Resource Type
kos-res-type:Server a skos:Concept ; skos:prefLabel "Server"@en ; skos:altLabel "Serveur"@fr .
kos-res-type:Router a skos:Concept ; skos:prefLabel "Router"@en ; skos:altLabel "Routeur"@fr .
kos-res-type:Firewall a skos:Concept ; skos:prefLabel "Firewall"@en ; skos:altLabel "Pare-feu"@fr .
kos-res-type:Switch a skos:Concept ; skos:prefLabel "Switch"@en ; skos:altLabel "Commutateur"@fr .
kos-res-type:VirtualMachine a skos:Concept ; skos:prefLabel "Virtual Machine"@en ; skos:altLabel "Machine Virtuelle"@fr .

# Resource Lifecycle State
kos-res-lc:InUse a skos:Concept ; skos:prefLabel "In Use"@en ; skos:altLabel "En service"@fr .
kos-res-lc:Maintenance a skos:Concept ; skos:prefLabel "Maintenance"@en ; skos:altLabel "En maintenance"@fr .
kos-res-lc:Decommissioned a skos:Concept ; skos:prefLabel "Decommissioned"@en ; skos:altLabel "Hors service"@fr .

# Notification Severity Perceived Severity
kos-notif-sev:Critical a skos:Concept ; skos:prefLabel "Critical"@en ; skos:altLabel "Critique"@fr .
kos-notif-sev:Major a skos:Concept ; skos:prefLabel "Major"@en ; skos:altLabel "Majeure"@fr .
kos-notif-sev:Minor a skos:Concept ; skos:prefLabel "Minor"@en ; skos:altLabel "Mineure"@fr .
kos-notif-sev:Warning a skos:Concept ; skos:prefLabel "Warning"@en ; skos:altLabel "Avertissement"@fr .

# Agent Contact Method
kos-org-contact:Email a skos:Concept ; skos:prefLabel "Email"@en ; skos:altLabel "Courriel"@fr .
kos-org-contact:Phone a skos:Concept ; skos:prefLabel "Phone"@en ; skos:altLabel "Téléphone"@fr .
kos-org-contact:Chat a skos:Concept ; skos:prefLabel "Chat"@en ; skos:altLabel "Messagerie instantanée"@fr .

# =============================================================================
# Agents and Organizations
# =============================================================================

# Individual Agents
foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "IT Operations Engineer responsible for network infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos-org-contact:Email ;
    noria:agentInstructions "Contact via internal ticketing system for non-urgent issues."@en .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Application Support Lead for critical business applications."@en ;
    noria:agentWorkingHours "8:30-17:30 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos-org-contact:Phone ;
    noria:agentInstructions "For critical incidents, call directly. Otherwise, use ticketing system."@en .

foaf:Agent_AliceJohnson a foaf:Agent ;
    rdfs:label "Alice Johnson"@en, "Alice Durand"@fr ;
    rdfs:comment "Database Administrator."@en ;
    noria:agentWorkingHours "10:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos-org-contact:Email .

# Organizational Units (Teams)
org:Team_NetworkOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for managing the corporate network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod kos-org-contact:Phone ;
    noria:agentInstructions "Follow incident management procedure for escalation."@en ;
    org:hasMember foaf:Agent_JohnDoe .

org:Team_AppSupport a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing Level 2 support for business applications."@en ;
    noria:agentWorkingHours "8:00-20:00 (Mon-Sat)"@en ;
    noria:agentPreferredContactMethod kos-org-contact:Email ;
    noria:agentInstructions "All requests must be logged in the ITSM tool."@en ;
    org:hasMember foaf:Agent_JaneSmith .

org:Team_DBA a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en, "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos-org-contact:Email ;
    org:hasMember foaf:Agent_AliceJohnson .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

# =============================================================================
# Locations
# =============================================================================

bot:Site_DC_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "48.8699"^^xsd:float ;
    wgs84_pos:long "2.3333"^^xsd:float .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace bot:Site_DC_Paris . # bot:hasSpace is inverse of bot:containsZone, but noria:Room is subClassOf bot:Space, not bot:Zone. Let's use bot:containsZone from Site to Room.

bot:Site_DC_Paris bot:containsZone noria:Room_ServerRoomA .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1, Server Room A"@en ;
    rdfs:comment "Location of rack A1 within Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoomA . # bot:hasSpace is inverse of bot:containsZone.

noria:Room_ServerRoomA bot:containsZone noria:Locus_RackA1 .

