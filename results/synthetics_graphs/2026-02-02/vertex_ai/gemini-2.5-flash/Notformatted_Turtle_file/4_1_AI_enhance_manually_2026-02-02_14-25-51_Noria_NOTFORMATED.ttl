# =============================================================================
# Services
# =============================================================================

noria:Service_CorpIntranetAccess a noria:Service ;
    rdfs:label "Corporate Intranet Access Service"@en, "Service d'Accès Intranet d'Entreprise"@fr ;
    rdfs:comment "End-to-end service providing access to the corporate intranet for employees."@en ;
    noria:serviceType kos-svc-type:CustomerFacingService ;
    seas:subSystemOf noria:AppMod_Intranet_Prod ; # A service can be composed of application modules
    seas:subSystemOf noria:App_AuthService .

noria:Service_NetworkMonitoring a noria:Service ;
    rdfs:label "Network Monitoring Service"@en, "Service de Supervision Réseau"@fr ;
    rdfs:comment "Internal service for real-time monitoring of network infrastructure."@en ;
    noria:serviceType kos-svc-type:ResourceFacingService ;
    seas:subSystemOf noria:AppMod_Monitoring_Prod .

# =============================================================================
# Operational Plans, Pre/Post Conditions
# =============================================================================

noria:OpPlan_RouterRestart a noria:OperationPlan ;
    rdfs:label "Router Restart Procedure"@en, "Procédure de Redémarrage Routeur"@fr ;
    rdfs:comment "Standard operating procedure for restarting a network router."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterUnresponsive ;
    noria:operationPlanPostCondition noria:PostCond_RouterOnline .

noria:PreCond_RouterUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Router Unresponsive"@en ;
    rdfs:comment "Condition: Router is not responding to ping or management access."@en ;
    skos:example "Ping to router management IP fails; SSH/Telnet access fails."@en .

noria:PostCond_RouterOnline a noria:ActionPostCondition ;
    rdfs:label "Router Online and Functional"@en ;
    rdfs:comment "Expected outcome: Router is reachable, interfaces are up, and routing protocols are stable."@en ;
    skos:example "Ping to router management IP succeeds; SSH/Telnet access works; 'show ip interface brief' shows interfaces up."@en .

noria:OpPlan_AppModuleDeploy a noria:OperationPlan ;
    rdfs:label "Application Module Deployment Procedure"@en, "Procédure de Déploiement Module Applicatif"@fr ;
    rdfs:comment "Procedure for deploying a new version of an application module."@en ;
    noria:operationPlanPreCondition noria:PreCond_CodeReviewed ;
    noria:operationPlanPostCondition noria:PostCond_AppModuleRunning .

noria:PreCond_CodeReviewed a noria:ActionPreCondition ;
    rdfs:label "Code Reviewed and Approved"@en ;
    rdfs:comment "Condition: New application code has passed peer review and quality gates."@en .

noria:PostCond_AppModuleRunning a noria:ActionPostCondition ;
    rdfs:label "Application Module Running and Accessible"@en ;
    rdfs:comment "Expected outcome: New application module version is deployed, running, and accessible to users."@en .

# =============================================================================
# Dynamic Elements (Trouble Tickets, Change Requests, Event Records)
# =============================================================================

# Event Records
noria:EventRecord_RouterDown a noria:EventRecord ;
    rdfs:label "RouterCore01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity kos-notif-sev:Critical .

noria:EventRecord_WebSrvHighCPU a noria:EventRecord ;
    rdfs:label "WebSrv01 High CPU Alert"@en ;
    rdfs:comment "Alert from monitoring system about high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "CPU utilization on websrv01 exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity kos-notif-sev:Major .

noria:EventRecord_ConfigChange_JohnDoe a noria:EventRecord ;
    rdfs:label "RouterCore01 Configuration Change by John Doe"@en ;
    rdfs:comment "Log entry for a configuration change made by John Doe on Core Router 01."@en ;
    noria:loggingTime "2024-04-20T11:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jdoe (10.0.0.50)"@en ;
    noria:alarmSeverity kos-notif-sev:Minor .

# Trouble Tickets
noria:TroubleTicket_TT001 a noria:TroubleTicket ;
    rdfs:label "Intranet Access Interruption"@en, "Interruption Accès Intranet"@fr ;
    rdfs:comment "Users are unable to access the corporate intranet application."@en ;
    dcterms:identifier "TT-2024-04-20-001" ;
    dcterms:created "2024-04-20T09:35:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity kos-tt-sev:Critical ;
    noria:troubleTicketType kos-tt-type:Failure ;
    noria:troubleTicketPriority kos-tt-prio:P1 ;
    noria:troubleTicketOrigin kos-tt-origin:Supervision ;
    noria:troubleTicketUrgency kos-tt-urg:ImmediateIntervention ;
    noria:troubleTicketCategory kos-tt-tc:TotalBreakdown ;
    noria:troubleTicketCause "Network link failure affecting intranet servers."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent kos-tt-status:InProgress ;
    noria:troubleTicketRelatedService noria:Service_CorpIntranetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_RouterCore01, noria:Resource_WebSrv01 ;
    noria:troubleTicketRelatedParty org:Team_NetworkOps ;
    noria:troubleTicketTrigger noria:EventRecord_RouterDown ;
    pep:member noria:EventRecord_RouterDown . # EventRecord is a pep:ProcedureExecution, TT is a pep:ProcedureExecutionContainer

noria:TroubleTicket_TT002 a noria:TroubleTicket ;
    rdfs:label "Web Server Performance Degradation"@en, "Dégradation Performance Serveur Web"@fr ;
    rdfs:comment "Intranet application is slow due to high CPU on web server."@en ;
    dcterms:identifier "TT-2024-04-20-002" ;
    dcterms:created "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity kos-tt-sev:Major ;
    noria:troubleTicketType kos-tt-type:Assistance ;
    noria:troubleTicketPriority kos-tt-prio:P2 ;
    noria:troubleTicketOrigin kos-tt-origin:Supervision ;
    noria:troubleTicketUrgency kos-tt-urg:DeferredIntervention ;
    noria:troubleTicketCategory kos-tt-tc:ServiceDegradation ;
    noria:troubleTicketCause "Unexpected traffic spike causing high CPU load."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent kos-tt-status:InProgress ;
    noria:troubleTicketRelatedService noria:Service_CorpIntranetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_WebSrv01 ;
    noria:troubleTicketRelatedParty org:Team_AppSupport ;
    noria:troubleTicketTrigger noria:EventRecord_WebSrvHighCPU ;
    pep:member noria:EventRecord_WebSrvHighCPU .

# Trouble Ticket Notes
noria:TTNote_TT001_1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT001"@en ;
    rdfs:comment "Confirmed network interface down on RouterCore01. Investigating physical link."@en ;
    dcterms:created "2024-04-20T09:40:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JohnDoe ;
    noria:troubleTicketNoteCommentType kos-tt-cmt:Internal ;
    noria:troubleTicketNoteOperationType kos-tt-op:Diagnosis ;
    dcterms:isPartOf noria:TroubleTicket_TT001 .

noria:TTNote_TT001_2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Attempt for TT001"@en ;
    rdfs:comment "Attempted to restart RouterCore01. Interface came back up briefly then went down again. Suspect faulty cable."@en ;
    dcterms:created "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JohnDoe ;
    noria:troubleTicketNoteCommentType kos-tt-cmt:Internal ;
    noria:troubleTicketNoteOperationType kos-tt-op:TestsAndMeasurements ;
    dcterms:isPartOf noria:TroubleTicket_TT001 .

# Change Requests
noria:ChangeRequest_CR001 a noria:ChangeRequest ;
    rdfs:label "RouterCore01 Software Upgrade"@en, "Mise à Jour Logicielle Routeur Cœur 01"@fr ;
    rdfs:comment "Upgrade IOS-XE software on Core Router 01 to address security vulnerabilities."@en ;
    dcterms:identifier "CR-2024-04-25-001" ;
    dcterms:created "2024-04-15T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-25T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory kos-cr-cat:InternalIntervention ;
    noria:changeRequestType kos-cr-type:Normal ;
    noria:changeRequestChangeCause kos-cr-cause:SoftwareUpgrade ;
    noria:changeRequestImpact noria:Resource_RouterCore01 ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent kos-cr-status:Planned ;
    noria:changeRequestInitiatorParty foaf:Agent_JohnDoe ;
    noria:changeRequestPilotParty org:Team_NetworkOps ;
    noria:changeRequestActorParty org:Team_NetworkOps ;
    noria:changeRequestIsRegulated "true"^^xsd:boolean .

noria:ChangeRequest_CR002 a noria:ChangeRequest ;
    rdfs:label "Intranet Database Schema Update"@en, "Mise à Jour Schéma Base de Données Intranet"@fr ;
    rdfs:comment "Update database schema for Intranet application to support new features."@en ;
    dcterms:identifier "CR-2024-05-01-001" ;
    dcterms:created "2024-04-20T16:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory kos-cr-cat:InternalIntervention ;
    noria:changeRequestType kos-cr-type:Standard ;
    noria:changeRequestChangeCause kos-cr-cause:ConfigurationChange ;
    noria:changeRequestImpact noria:Resource_DBSrv01 ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ; # 1 hour
    noria:changeRequestStatusCurrent kos-cr-status:Planned ;
    noria:changeRequestInitiatorParty foaf:Agent_AliceJohnson ;
    noria:changeRequestPilotParty org:Team_DBA ;
    noria:changeRequestActorParty org:Team_DBA ;
    noria:changeRequestSpecification kos-cr-spec:StandardProcedureA .

# Document Attachments
noria:DocAttach_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Data Center Network Diagram"@en ;
    rdfs:comment "PDF document showing the logical and physical network topology of the Paris Data Center."@en ;
    dcterms:identifier "DIAG-DC-PAR-01-V2.pdf" ;
    dcterms:isPartOf noria:TroubleTicket_TT001 ;
    dcterms:isPartOf noria:ChangeRequest_CR001 .

# Anomaly Patterns
noria:AnomalyPattern_HighCPU_LowTraffic a noria:AnomalyPattern ;
    rdfs:label "High CPU with Low Traffic Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating high CPU usage on a server despite low network traffic, potentially indicating a software bug or resource leak."@en ;
    skos:example "If CPU > 80% AND Network_In < 10Mbps for 15 minutes, then trigger this anomaly."@en .

# Connecting more entities to ensure density and connectivity
noria:Resource_WebSrv01 noria:resourceForApplication noria:App_CorpIntranet .
noria:Resource_DBSrv01 noria:resourceForApplication noria:App_CorpIntranet .
noria:Resource_RouterCore01 noria:resourceForApplication noria:App_MonitoringSystem .
noria:Resource_FirewallEdge01 noria:resourceForApplication noria:App_MonitoringSystem .

org:Team_NetworkOps noria:agentManagesResource noria:Resource_RouterCore01, noria:Resource_FirewallEdge01 .
org:Team_DBA noria:agentManagesResource noria:Resource_DBSrv01 .
org:Team_AppSupport noria:agentManagesResource noria:Resource_WebSrv01 .

noria:TroubleTicket_TT001 noria:documentStatusHistory noria:EventRecord_RouterDown .
noria:TroubleTicket_TT002 noria:documentStatusHistory noria:EventRecord_WebSrvHighCPU .

noria:ChangeRequest_CR001 noria:documentStatusHistory noria:EventRecord_ConfigChange_JohnDoe .

noria:EventRecord_ConfigChange_JohnDoe noria:alarmMitigatedBy noria:ChangeRequest_CR001 .
noria:EventRecord_RouterDown noria:alarmProposedRepairAction noria:OpPlan_RouterRestart .

noria:TroubleTicket_TT001 noria:problemResponsibility kos-tt-pr:ManagedBackboneNetworks .
noria:TroubleTicket_TT002 noria:problemResponsibility kos-tt-pr:InternalIT .

noria:AppMod_Intranet_Prod noria:applicationModuleSupportGroup org:Team_AppSupport .
noria:AppMod_Intranet_Prod noria:applicationModuleHotlineGroup org:Team_AppSupport .

noria:AppMod_Monitoring_Prod noria:applicationModuleSupportGroup org:Team_NetworkOps .
noria:AppMod_Monitoring_Prod noria:applicationModuleHotlineGroup org:Team_NetworkOps .

# Example of a virtual machine resource and its relation to a physical server (cluster controller)
noria:Resource_VM_Intranet_Frontend a noria:Resource ;
    rdfs:label "Intranet Frontend VM"@en ;
    rdfs:comment "Virtual machine hosting the frontend of the corporate intranet."@en ;
    noria:resourceHostName "intranet-fe-vm01" ;
    noria:resourceType kos-res-type:VirtualMachine ;
    noria:resourceUsageState kos-res-lc:InUse ;
    noria:resourceManagedBy org:Team_AppSupport ;
    noria:clusterController noria:Resource_WebSrv01 ; # Assuming WebSrv01 is a hypervisor or part of a cluster managing this VM
    noria:resourceForApplication noria:App_CorpIntranet .

noria:NI_VM_Intranet_Frontend_Eth0 a noria:NetworkInterface ;
    rdfs:label "Intranet Frontend VM Ethernet0"@en ;
    noria:networkInterfaceOf noria:Resource_VM_Intranet_Frontend ;
    noria:networkInterfaceAdministrativeStatus kos-res-adm:Up ;
    noria:networkInterfaceOperationalStatus kos-res-op:Up ;
    noria:networkInterfaceType "virtual" .

noria:NL_Virtual_VM_WebSrv a noria:NetworkLink ;
    rdfs:label "Virtual Link VM-WebSrv"@en ;
    rdfs:comment "Virtual network link connecting the Intranet Frontend VM to the Web Server's virtual network."@en ;
    noria:networkLinkId "NL-VIRT-VM-WEB-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_VM_Intranet_Frontend ;
    noria:networkLinkTerminationResourceDestination noria:Resource_WebSrv01 ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:networkInterfaceConnects noria:NI_VM_Intranet_Frontend_Eth0 ;
    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0 . # Simplified, in reality it would connect to a virtual switch on the hypervisor.

# Another Event Record related to a Change Request
noria:EventRecord_CR001_Start a noria:EventRecord ;
    rdfs:label "CR001 Execution Start"@en ;
    rdfs:comment "Event marking the start of Change Request CR001 execution."@en ;
    noria:loggingTime "2024-04-25T02:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Starting software upgrade on RouterCore01 as per CR-2024-04-25-001."@en ;
    noria:alarmSeverity kos-notif-sev:Minor ;
    pep:member noria:ChangeRequest_CR001 .

noria:EventRecord_CR001_End a noria:EventRecord ;
    rdfs:label "CR001 Execution End"@en ;
    rdfs:comment "Event marking the successful completion of Change Request CR001 execution."@en ;
    noria:loggingTime "2024-04-25T03:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Software upgrade on RouterCore01 completed successfully. Router rebooted and is online."@en ;
    noria:alarmSeverity kos-notif-sev:Minor ;
    pep:member noria:ChangeRequest_CR001 .

noria:ChangeRequest_CR001 noria:changeRequestActualStartTime "2024-04-25T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-25T03:45:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent kos-cr-status:Completed .

# Example of an Anomaly Pattern being used in a Trouble Ticket context
noria:TroubleTicket_TT003 a noria:TroubleTicket ;
    rdfs:label "Unexplained High CPU on Web Server"@en ;
    rdfs:comment "Web server experiencing high CPU without corresponding traffic increase, matching an anomaly pattern."@en ;
    dcterms:identifier "TT-2024-04-21-003" ;
    dcterms:created "2024-04-21T08:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity kos-tt-sev:Major ;
    noria:troubleTicketType kos-tt-type:Failure ;
    noria:troubleTicketPriority kos-tt-prio:P2 ;
    noria:troubleTicketOrigin kos-tt-origin:Supervision ;
    noria:troubleTicketCause "Detected anomaly pattern: High CPU with Low Traffic."@en ;
    noria:troubleTicketStatusCurrent kos-tt-status:InProgress ;
    noria:troubleTicketImpacts noria:AnomalyPattern_HighCPU_LowTraffic ; # Linking TT to AnomalyPattern
    noria:troubleTicketRelatedResource noria:Resource_WebSrv01 .

# Example of a Service being managed by an Agent
noria:Service_CorpIntranetAccess noria:elementManagedBy org:Team_AppSupport .
noria:Service_NetworkMonitoring noria:elementManagedBy org:Team_NetworkOps .

# Example of an Agent managing a Service
org:Team_AppSupport noria:agentManagesResource noria:Service_CorpIntranetAccess .
org:Team_NetworkOps noria:agentManagesResource noria:Service_NetworkMonitoring .

# Adding more properties to existing entities for density
noria:Resource_WebSrv01 noria:virtualServerStatus kos-res-op:Up .
noria:NI_RouterCore01_Gig0_0_0 noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
