    rdfs:comment "Internal interface for Edge Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallEdge01 ;
    noria:networkInterfaceAdministrativeStatus kos-res-adm:Up ;
    noria:networkInterfaceOperationalStatus kos-res-op:Up ;
    noria:networkInterfaceType "physical" .

# Network Links
noria:NL_Uplink_DC a noria:NetworkLink ;
    rdfs:label "Data Center Uplink"@en, "Liaison Montante Centre de Données"@fr ;
    rdfs:comment "High-speed link connecting the data center to the internet backbone."@en ;
    noria:networkLinkId "NL-DC-UPLINK-001" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ;
    noria:networkLinkInstallationDate "2021-03-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic WAN" ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gig0_0_0 .

noria:NL_Internal_Core_FW a noria:NetworkLink ;
    rdfs:label "Internal Core-Firewall Link"@en, "Liaison Interne Cœur-Pare-feu"@fr ;
    rdfs:comment "Link between core router and edge firewall."@en ;
    noria:networkLinkId "NL-INT-CORE-FW-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_FirewallEdge01 ;
    noria:networkLinkInstallationDate "2021-03-01T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkInterfaceConnects noria:NI_RouterCore01_Gig0_0_1 ;
    noria:networkInterfaceConnects noria:NI_FirewallEdge01_Eth1 .

noria:NL_Internal_FW_WebSrv a noria:NetworkLink ;
    rdfs:label "Internal Firewall-WebSrv Link"@en, "Liaison Interne Pare-feu-Serveur Web"@fr ;
    rdfs:comment "Link between edge firewall and web server."@en ;
    noria:networkLinkId "NL-INT-FW-WEB-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_FirewallEdge01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_WebSrv01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkInterfaceConnects noria:NI_FirewallEdge01_Eth0 ; # This is a simplification, typically FW would connect to a switch, then switch to server.
    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0 .

noria:NL_Internal_WebSrv_DBSrv a noria:NetworkLink ;
    rdfs:label "Internal WebSrv-DBSrv Link"@en, "Liaison Interne Serveur Web-Serveur BD"@fr ;
    rdfs:comment "Link between web server and database server."@en ;
    noria:networkLinkId "NL-INT-WEB-DB-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DBSrv01 ;
    noria:networkLinkInstallationDate "2022-01-15T11:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0 ; # Another simplification, assuming direct link or shared switch.
    noria:networkInterfaceConnects noria:NI_DBSrv01_Eth0 .

# =============================================================================
# Applications and Application Modules
# =============================================================================

noria:App_CorpIntranet a noria:Application ;
    rdfs:label "Corporate Intranet Application"@en, "Application Intranet d'Entreprise"@fr ;
    rdfs:comment "Internal web application for corporate communications and tools."@en ;
    noria:applicationModelIdentifier "INTRA-APP-V2" ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "Intranet" ;
    noria:applicationType kos-app-type:BusinessApplication ;
    noria:applicationBusinessImportance kos-app-bizimp:High ;
    noria:applicationFunctionalDomain "Internal Communications" ;
    noria:applicationFunctionalSubDomain "Employee Portal" ;
    noria:elementManagedBy org:Team_AppSupport ;
    noria:resourceForApplication noria:Resource_WebSrv01, noria:Resource_DBSrv01 .

noria:App_MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en, "Système de Supervision Centralisé"@fr ;
    rdfs:comment "Application for collecting and analyzing logs and metrics from IT infrastructure."@en ;
    noria:applicationModelIdentifier "MON-SYS-V3" ;
    noria:applicationNumericalIdentifier "2001"^^xsd:int ;
    noria:applicationShortIdentifier "Monitor" ;
    noria:applicationType kos-app-type:MonitoringSystem ;
    noria:applicationBusinessImportance kos-app-bizimp:Medium ;
    noria:elementManagedBy org:Team_NetworkOps .

noria:App_AuthService a noria:Application ;
    rdfs:label "Authentication Service"@en, "Service d'Authentification"@fr ;
    rdfs:comment "Centralized authentication service for all corporate applications."@en ;
    noria:applicationModelIdentifier "AUTH-SVC-V1" ;
    noria:applicationNumericalIdentifier "3001"^^xsd:int ;
    noria:applicationShortIdentifier "Auth" ;
    noria:applicationType kos-app-type:AuthenticationService ;
    noria:applicationBusinessImportance kos-app-bizimp:High ;
    noria:elementManagedBy org:Team_NetworkOps .

