  rdfs:comment "Container for events related to the failover procedure initiated for Edge01."@en ;
  dcterms:created "2024-04-20T10:13:00Z"^^xsd:dateTime ;
  dcterms:creator org:NetworkAdminTeam_extra_node_5 ;
  dcterms:relation noria:TroubleTicketNote_TT001_Note1 ;
  pep:usedProcedure noria:OperationPlan_FailoverProcedure .

