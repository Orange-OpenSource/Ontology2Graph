noria:OperationPlan_CheckFiberLink a noria:OperationPlan ;
  rdfs:label "Procedure: Check Fiber Link"@en ;
  rdfs:comment "Standard operating procedure for diagnosing fiber optic link issues."@en ;
  noria:operationPlanPostCondition noria:PostCondition_LinkStatusKnown ;
  noria:operationPlanPreCondition noria:PreCondition_LinkDown ;
  skos:example "Steps include visual inspection, power meter readings, and loopback tests."@en .

noria:OperationPlan_FailoverProcedure a noria:OperationPlan ;
  rdfs:label "Procedure: Network Failover"@en ;
  rdfs:comment "Procedure to activate redundant network paths in case of primary link failure."@en ;
  noria:operationPlanPostCondition noria:PostCondition_TrafficRerouted ;
  noria:operationPlanPreCondition noria:PreCondition_PrimaryLinkFailed ;
  skos:example "Includes verifying alternate path, updating routing tables, and monitoring traffic."@en .

noria:OperationPlan_FirmwareUpgrade a noria:OperationPlan ;
  rdfs:label "Procedure: Router_extra_node_5 Firmware Upgrade"@en ;
  rdfs:comment "Detailed steps for upgrading router firmware, including backup and rollback."@en ;
  noria:operationPlanPostCondition noria:PostCondition_FirmwareUpdated ;
  noria:operationPlanPreCondition noria:PreCondition_MaintenanceWindow ;
  skos:example "Backup configuration, upload new image, reboot, verify."@en .

