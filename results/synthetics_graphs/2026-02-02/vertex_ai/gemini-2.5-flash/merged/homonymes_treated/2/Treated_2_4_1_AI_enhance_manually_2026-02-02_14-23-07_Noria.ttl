noria:AnomalyPattern_HighCPU_LowThroughput a noria:AnomalyPattern ;
  rdfs:label "High CPU, Low Throughput Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating a potential performance bottleneck or issue: high_extra_node_3 CPU usage on a network device coupled with unexpectedly low data throughput."@en ;
  skos:example "If Resource_X has CPU > 80% AND NetworkInterface_Y on Resource_X has Throughput < 10% of capacity, then AnomalyPattern_HighCPU_LowThroughput is detected."@en .

