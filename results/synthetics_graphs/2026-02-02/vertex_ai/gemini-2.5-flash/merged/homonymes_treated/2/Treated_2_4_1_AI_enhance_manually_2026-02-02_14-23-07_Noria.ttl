noria:ChangeRequest_CR001 a noria:ChangeRequest ;
  rdfs:label "Upgrade Core Router_extra_node_3 Firmware"@en ;
  rdfs:comment "Planned firmware upgrade for Core Router_extra_node_3 01 to address known vulnerabilities."@en ;
