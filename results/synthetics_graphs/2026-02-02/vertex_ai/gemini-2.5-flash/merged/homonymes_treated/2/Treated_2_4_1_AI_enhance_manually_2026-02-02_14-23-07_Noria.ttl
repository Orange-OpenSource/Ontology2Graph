  dcterms:identifier "CR-2024-03-25-001" ;
  noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterFirmwareUpgrade ;
  noria:changeRequestActorParty noria:OrgUnit_NetworkOpsTeam ;
  noria:changeRequestCategory <https://github.com/atextor/owl-cli/kos/ChangeRequest/category/InternalIntervention_extra_node_3> ;
  noria:changeRequestChangeCause <https://github.com/atextor/owl-cli/kos/ChangeRequest/cause/SoftwareUpgrade_extra_node_3> ;
  noria:changeRequestImpact noria:Application_CorpInternetAccess ;
  noria:changeRequestImpact noria:Resource_CoreRouter01 ;
  noria:changeRequestInitiatorParty noria:Agent_BobJohnson ;
  noria:changeRequestIsRegulated true ;
  noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ;
  noria:changeRequestPilotParty noria:OrgUnit_NetworkOpsTeam ;
  noria:changeRequestPlannedEndTime "2024-03-25T04:00:00Z"^^xsd:dateTime ;
  noria:changeRequestPlannedStartTime "2024-03-25T02:00:00Z"^^xsd:dateTime ;
  noria:changeRequestSpecification <https://github.com/atextor/owl-cli/kos/ChangeRequest/specification/StandardFirmwareUpgrade> ;
  noria:changeRequestStatusCurrent <https://github.com/atextor/owl-cli/kos/ChangeRequest/status/Scheduled_extra_node_3> ;
  noria:changeRequestType <https://github.com/atextor/owl-cli/kos/ChangeRequest/type/Standard_extra_node_3> ;
  noria:documentExternalId "EXT-CHG-12345" ;
  noria:documentHRef "https://itsm.example.com/cr/CR-2024-03-25-001" ;
  noria:documentStatusHistory noria:EventRecord_CR001_StatusChange_Approved .

