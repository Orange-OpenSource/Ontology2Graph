noria:ActionPostCondition_CPUStable a noria:ActionPostCondition ;
  rdfs:label "CPU Utilization Stabilized"@en ;
  rdfs:comment "Expected outcome: Server CPU utilization returns to normal levels (below 50%) and application responsiveness improves."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
  rdfs:label "Network Interface is Up_extra_node_2"@en ;
  rdfs:comment "Expected outcome: The network interface's operational status is 'up', link lights are green, and basic connectivity (ping) is restored."@en .

noria:ActionPreCondition_HighCPU a noria:ActionPreCondition ;
  rdfs:label "High CPU Utilization on Server"@en ;
  rdfs:comment "Condition: Server CPU utilization consistently above 80% for more than 5 minutes."@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
  rdfs:label "Network Interface is Down"@en ;
  rdfs:comment "Condition: The network interface's operational status is 'down' and no physical damage is observed."@en .

noria:AnomalyPattern_DNSFailure a noria:AnomalyPattern ;
  rdfs:label "DNS Server Unreachable Pattern"@en ;
  rdfs:comment "Pattern indicating a DNS server failure: DNS queries fail, server pings fail, and related network interface is down."@en ;
  folio:hasCause noria:TroubleTicket_DNSOutage ;
  seas:hasProperty noria:ActionPreCondition_InterfaceDown .

noria:AnomalyPattern_WebPerformanceDegradation a noria:AnomalyPattern ;
  rdfs:label "Web Performance Degradation Pattern"@en ;
  rdfs:comment "Pattern indicating web application performance issues: slow response times, high_extra_node_2 server CPU, and increased error rates."@en ;
  folio:hasCause noria:TroubleTicket_WebIssue ;
  seas:hasProperty noria:ActionPreCondition_HighCPU .

