<https://w3id.org/noria/instances/ActionPostCondition/DBServiceUp> a noria:ActionPostCondition ;
  rdfs:label "Database Service is Up and Running"@en ;
  rdfs:comment "Outcome: The database service process is running, accessible, and responding to queries without errors."@en .

<https://w3id.org/noria/instances/ActionPostCondition/DBUpgradeVerified> a noria:ActionPostCondition ;
  rdfs:label "Database Upgrade Verified"@en ;
  rdfs:comment "Outcome: The database software has been upgraded, and all post-upgrade functional and performance tests have passed."@en .

<https://w3id.org/noria/instances/ActionPostCondition/NetworkInterfaceRestored> a noria:ActionPostCondition ;
  rdfs:label "Network Interface Restored"@en ;
  rdfs:comment "Outcome: The network interface is operational, passing traffic, and error-free, with administrative and operational status 'up'."@en .

<https://w3id.org/noria/instances/ActionPreCondition/DBBackupCompleted> a noria:ActionPreCondition ;
  rdfs:label "Database Backup Completed"@en ;
  rdfs:comment "Condition: A full, verified backup of the database has been successfully completed and stored securely."@en .

<https://w3id.org/noria/instances/ActionPreCondition/DBServiceDown> a noria:ActionPreCondition ;
  rdfs:label "Database Service is Down"@en ;
  rdfs:comment "Condition: The database service process is not running or is unresponsive, as confirmed by monitoring tools."@en .

<https://w3id.org/noria/instances/ActionPreCondition/NetworkInterfaceFault> a noria:ActionPreCondition ;
  rdfs:label "Network Interface Fault Detected"@en ;
  rdfs:comment "Condition: Monitoring system reports a network interface as down or experiencing a high rate of errors/discards."@en .

