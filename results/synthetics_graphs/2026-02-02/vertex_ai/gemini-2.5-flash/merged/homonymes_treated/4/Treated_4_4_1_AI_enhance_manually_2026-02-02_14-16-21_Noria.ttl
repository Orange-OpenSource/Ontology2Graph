<https://w3id.org/noria/instances/Agent/SecurityTeam> a org:OrganizationalUnit, foaf:Agent ;
  rdfs:label "Centre d'Opérations de Sécurité (SOC)"@fr ;
  rdfs:label "Security Operations Center (SOC)"@en ;
  rdfs:comment "Team responsible for monitoring, detecting, analyzing, and responding to cybersecurity incidents."@en ;
  noria:agentInstructions "Automated alerts are sent directly to the SIEM. Manual contact is reserved for high-severity security incidents only."@en ;
  noria:agentPreferredContactMethod <https://w3id.org/noria/instances/kos/org/agent-contact-method/SIEMAlerts> ;
  noria:agentWorkingHours "24/7" .

<https://w3id.org/noria/instances/AnomalyPattern/BruteForceAttempt> a noria:AnomalyPattern ;
  rdfs:label "Brute Force Login Attempt Pattern"@en ;
  rdfs:comment "Pattern indicating multiple failed login attempts from a single source IP or against a single user account within a short timeframe."@en ;
  folio:hasCause <https://w3id.org/noria/instances/EventRecord/SecurityLoginFailure> ;
  skos:example "More than 5 failed login attempts for the same user from the same IP address within 60 seconds."@en .

<https://w3id.org/noria/instances/AnomalyPattern/HighCPUDegradation> a noria:AnomalyPattern ;
  rdfs:label "High CPU Degradation Pattern"@en ;
  rdfs:comment "Pattern indicating a sustained period of high CPU usage leading to performance degradation, often a precursor to service outage."@en ;
  folio:hasCause <https://w3id.org/noria/instances/TroubleTicket/TT-20240420-001> ;
  skos:example "CPU utilization consistently above 90% for more than 15 minutes, followed by a 50% increase in application response time."@en .

<https://w3id.org/noria/instances/AnomalyPattern/LinkFlap> a noria:AnomalyPattern ;
  rdfs:label "Network Link Flap Pattern"@en ;
  rdfs:comment "Pattern indicating a network link repeatedly going up and down in a short period, suggesting instability or physical fault."@en ;
  folio:hasCause <https://w3id.org/noria/instances/TroubleTicket/TT-20240420-002> ;
  skos:example "Interface status changes from up to down and back to up more than 3 times in 5 minutes, without manual intervention."@en .

