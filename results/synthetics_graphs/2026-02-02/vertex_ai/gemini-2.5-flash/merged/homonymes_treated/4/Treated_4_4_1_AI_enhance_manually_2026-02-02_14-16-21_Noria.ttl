<https://w3id.org/noria/instances/TroubleTicketNote/TTN-20240420-001-02> a noria:TroubleTicketNote ;
  rdfs:label "DB Admin Team update for TT-20240420-001"@en ;
  rdfs:comment "Update from DB Admin Team on the high CPU incident. Identified a long-running, unoptimized query from ERP module. Killed the process. CPU returned to normal. Recommending application team to optimize query."@en ;
  dcterms:description "Identified a long-running, unoptimized query from ERP module. Killed the process. CPU returned to normal. Recommending application team to optimize query."@en ;
  dcterms:created "2024-04-20T11:30:00Z"^^xsd:dateTime ;
  dcterms:creator <https://w3id.org/noria/instances/Agent/AliceJohnson> ;
  dcterms:isPartOf <https://w3id.org/noria/instances/TroubleTicket/TT-20240420-001> ;
  noria:troubleTicketNoteCommentType <https://w3id.org/noria/instances/kos/TroubleTicket/commentType/Internal> ;
