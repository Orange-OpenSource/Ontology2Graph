noria:AnomalyPattern_HighCPULowTraffic a noria:AnomalyPattern ;
  rdfs:label "High CPU, Low Traffic Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating a potential resource exhaustion or application loop: high_extra_node_1 CPU usage on a server with unexpectedly low network traffic."@en ;
  skos:example "If (CPU_Usage > 90%) AND (Network_Traffic_Out < 10Mbps) THEN Anomaly."@en .

noria:AnomalyPattern_InterfaceFlap a noria:AnomalyPattern ;
  rdfs:label "Network Interface Flap Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating an unstable network link: a network interface repeatedly changes between up and down states within a short period."@en ;
  skos:example "If (Interface_Status_Changes > 3 in 5 minutes) THEN Anomaly."@en .

