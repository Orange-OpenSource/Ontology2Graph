noria:APC_HighCPUDetected a noria:ActionPreCondition ;
  rdfs:label "High CPU Detected"@en ;
  rdfs:comment "Condition: CPU utilization above threshold for a sustained period."@en .

noria:APC_InterfaceDown a noria:ActionPreCondition ;
  rdfs:label "Network Interface Down Detected"@en ;
  rdfs:comment "Condition: Network interface operational status is 'down'."@en .

noria:APOC_CPUNormal a noria:ActionPostCondition ;
  rdfs:label "CPU Usage Normal"@en ;
  rdfs:comment "Expected outcome: CPU utilization returned to normal levels."@en .

noria:APOC_LinkStatusVerified a noria:ActionPostCondition ;
  rdfs:label "Network Link Status Verified"@en ;
  rdfs:comment "Expected outcome: Network link status confirmed (up or down with known cause)."@en .

noria:AP_ExcessiveCPUUsage a noria:AnomalyPattern ;
  rdfs:label "Excessive CPU Usage Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating an anomaly where CPU usage is consistently high without expected load."@en ;
  folio:hasCause noria:OP_RestartWebServer .

noria:AP_NetworkLinkFailure a noria:AnomalyPattern ;
  rdfs:label "Network Link Failure Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating a network link is down or unstable, causing connectivity issues."@en ;
  folio:hasCause noria:OP_CheckNetworkLink .

