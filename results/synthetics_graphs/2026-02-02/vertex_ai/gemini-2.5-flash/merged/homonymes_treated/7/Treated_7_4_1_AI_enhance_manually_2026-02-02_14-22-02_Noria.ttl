noria:ActionPostCondition_DBResponsive a noria:ActionPostCondition ;
  rdfs:label "Database Service Responsive"@en ;
  rdfs:comment "Expected outcome: Database service is responding to queries and application functions normally."@en .

noria:ActionPostCondition_HardwareOperational a noria:ActionPostCondition ;
  rdfs:label "Hardware Operational After Replacement"@en ;
  rdfs:comment "Expected outcome: New hardware component is installed, configured, and fully operational."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
  rdfs:label "Interface Operational State Up"@en ;
  rdfs:comment "Expected outcome: The network interface's operational status is 'up' and traffic is flowing."@en .

noria:ActionPostCondition_TrafficOptimized a noria:ActionPostCondition ;
  rdfs:label "Traffic Optimized"@en ;
  rdfs:comment "Expected outcome: Network link utilization is within acceptable limits, no packet loss."@en .

noria:ActionPreCondition_CongestionDetected a noria:ActionPreCondition ;
  rdfs:label "Network Congestion Detected"@en ;
  rdfs:comment "Condition: Network link utilization exceeds threshold with packet loss."@en .

noria:ActionPreCondition_DBUnresponsive a noria:ActionPreCondition ;
  rdfs:label "Database Service Unresponsive"@en ;
  rdfs:comment "Condition: Database service is not responding to queries."@en .

noria:ActionPreCondition_HardwareFault a noria:ActionPreCondition ;
  rdfs:label "Hardware Fault Detected"@en ;
  rdfs:comment "Condition: Diagnostic tests confirm a hardware component failure."@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
  rdfs:label "Interface Operational State Down"@en ;
  rdfs:comment "Condition: The network interface's operational status is 'down'."@en .

noria:AnomalyPattern_HardwareFailure a noria:AnomalyPattern ;
  rdfs:label "Hardware Failure Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating a physical hardware component failure."@en ;
  folio:hasCause noria:TroubleTicket_004 .

noria:AnomalyPattern_HighCPUUsage a noria:AnomalyPattern ;
  rdfs:label "High CPU Usage Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating sustained high CPU utilization on a server."@en ;
  folio:hasCause noria:TroubleTicket_002 .

noria:AnomalyPattern_LinkFlap a noria:AnomalyPattern ;
  rdfs:label "Network Link Flap Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating a network link repeatedly going up and down in a short period."@en ;
  folio:hasCause noria:TroubleTicket_001 .

noria:AnomalyPattern_NetworkCongestion a noria:AnomalyPattern ;
  rdfs:label "Network Congestion Anomaly Pattern"@en ;
  rdfs:comment "Pattern indicating high traffic utilization and packet loss on a network link."@en ;
  folio:hasCause noria:TroubleTicket_005 .

