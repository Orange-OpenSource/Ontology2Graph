<http://example.com/EventRecord_HighTrafficAlert> a noria:EventRecord ;
  rdfs:label "High Traffic Alert"@en ;
  rdfs:comment "Alert indicating high traffic utilization on the core switch link."@en ;
  noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
  noria:logOriginatingManagedObject noria:NetworkLink_CoreToAppSrv ;
  noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
  noria:logText "ALERT: Traffic utilization on NL-CA-001 exceeded 90% for 15 minutes."@en ;
  noria:loggingTime "2024-05-20T10:45:00Z"^^xsd:dateTime .

