<https://w3id.org/noria/instances/EventRecord/DBServerCPUSpike> a noria:EventRecord ;
  rdfs:label "DB Server CPU Spike Alert"@en ;
  rdfs:comment "Alert generated by the monitoring system due to sustained high CPU utilization on DBServer01."@en ;
  noria:alarmProposedRepairAction <https://w3id.org/noria/instances/OperationPlan/RestartDBService> ;
  noria:alarmSeverity <https://w3id.org/noria/instances/Notification/Severity/PerceivedSeverity/Critical> ;
  noria:logOriginatingAgent <https://w3id.org/noria/instances/Agent/ITOperationsTeam> ;
  noria:logOriginatingManagedObject <https://w3id.org/noria/instances/Resource/DBServer01> ;
  noria:logOriginatingManagementSystem <https://w3id.org/noria/instances/Application/MonitoringSystem> ;
  noria:logText "CPU utilization on dbserver01.corp.example.com exceeded 90% for 5 minutes. Threshold: 80%."@en ;
  noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime .

<https://w3id.org/noria/instances/EventRecord/DBUpgradeSuccess> a noria:EventRecord ;
