# =============================================================================
# Organizations and Agents
# =============================================================================

ex:OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company, acting as the overarching organization."@en ;
    org:hasUnit ex:NetworkOperationsDept ;
    org:hasUnit ex:ApplicationDevelopmentDept ;
    org:hasUnit ex:SecurityOperationsCenter ;
    org:hasUnit ex:CustomerServiceDept .

ex:NetworkOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Department"@en ;
    rdfs:comment "Responsible for the day-to-day operation and maintenance of the network infrastructure."@en ;
    org:unitOf ex:OrangeTelecom ;
    org:hasMember ex:JohnDoe ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. For routine requests, submit a ticket via the internal portal."^^xsd:string .

ex:ApplicationDevelopmentDept
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Department"@en ;
    rdfs:comment "Responsible for developing, deploying, and maintaining business applications."@en ;
    org:unitOf ex:OrangeTelecom ;
    org:hasMember ex:JaneSmith ;
    noria:agentWorkingHours "8:30 AM - 4:30 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/InternalChat> ;
    noria:agentInstructions "All application-related issues must be reported through the JIRA system."^^xsd:string .

ex:SecurityOperationsCenter
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Monitors and analyzes security events, responding to cyber threats and incidents."@en ;
    org:unitOf ex:OrangeTelecom ;
    org:hasMember ex:AliceJohnson ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SecurePhone> ;
    noria:agentInstructions "Immediate escalation for any detected security breach. Follow established incident response playbooks."^^xsd:string .

ex:CustomerServiceDept
    a org:OrganizationalUnit ;
    rdfs:label "Customer Service Department"@en ;
    rdfs:comment "Handles customer inquiries, complaints, and service requests."@en ;
    org:unitOf ex:OrangeTelecom ;
    noria:agentWorkingHours "8:00 AM - 8:00 PM (Mon-Sun)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Refer technical issues to the appropriate support teams. Prioritize customer satisfaction."^^xsd:string .

ex:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A senior network engineer in the Network Operations Department."@en ;
    org:memberOf ex:NetworkOperationsDept ;
    foaf:holdsAccount ex:jdoe_cuid ;
    noria:agentManagesResource ex:CoreRouter01 ;
    noria:agentManagesResource ex:Link_Router01_Server01 .

ex:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An application developer and team lead in the Application Development Department."@en ;
    org:memberOf ex:ApplicationDevelopmentDept ;
    foaf:holdsAccount ex:jsmith_cuid ;
    noria:agentManagesResource ex:CustomerPortalProdModule ;
    noria:agentManagesResource ex:VirtualMachine01 .

ex:AliceJohnson
    a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "A cybersecurity analyst in the Security Operations Center."@en ;
    org:memberOf ex:SecurityOperationsCenter ;
    foaf:holdsAccount ex:ajohnson_cuid ;
    noria:agentManagesResource ex:Firewall01 .

ex:jdoe_cuid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "The unique corporate identifier for John Doe, used for system access."@en ;
    foaf:accountName "jdoe"@en ;
    observable:accountLogin "jdoe"@en ;
    observable:accountIdentifier "JD001234"@en .

ex:jsmith_cuid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "The unique corporate identifier for Jane Smith, used for system access."@en ;
    foaf:accountName "jsmith"@en ;
    observable:accountLogin "jsmith"@en ;
    observable:accountIdentifier "JS005678"@en .

ex:ajohnson_cuid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Johnson's Corporate User ID"@en ;
    rdfs:comment "The unique corporate identifier for Alice Johnson, used for system access."@en ;
    foaf:accountName "ajohnson"@en ;
    observable:accountLogin "ajohnson"@en ;
    observable:accountIdentifier "AJ009012"@en .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "A multinational technology conglomerate that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

ex:DellTechnologies
    a org:Organization ;
    rdfs:label "Dell Technologies Inc."@en ;
    rdfs:comment "An American multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

ex:VMwareInc
    a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "A cloud computing and virtualization technology company, providing software and services."@en .

# =============================================================================
# Locations
# =============================================================================

ex:ParisDataCenter
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "The primary data center facility located in Paris, France."@en ;
    noria:siteId "PDC01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"@en ;
    bot:containsZone ex:ServerRoomA ;
    bot:containsZone ex:NetworkRoomB .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated room within the Paris Data Center housing various servers and storage equipment."@en ;
    bot:hasSubSpace ex:Rack12 ;
    bot:hasSubSpace ex:Rack13 .

ex:NetworkRoomB
    a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "A dedicated room within the Paris Data Center housing core networking equipment."@en ;
    bot:hasSubSpace ex:CoreRack01 .

ex:Rack12
    a noria:Locus ;
    rdfs:label "Rack 12 in Server Room A"@en ;
    rdfs:comment "A specific rack location within Server Room A, identified by its line and row coordinates."@en ;
    noria:locusLine "L"^^xsd:string ;
    noria:locusRow "12"^^xsd:string .

ex:Rack13
    a noria:Locus ;
    rdfs:label "Rack 13 in Server Room A"@en ;
    rdfs:comment "A specific rack location within Server Room A, identified by its line and row coordinates."@en ;
    noria:locusLine "L"^^xsd:string ;
    noria:locusRow "13"^^xsd:string .

ex:CoreRack01
    a noria:Locus ;
    rdfs:label "Core Network Rack 01"@en ;
    rdfs:comment "A specific rack location within Network Room B, housing core network devices."@en ;
    noria:locusLine "C"^^xsd:string ;
    noria:locusRow "01"^^xsd:string .

# =============================================================================
# Structural Elements (Hardware & Virtual)
# =============================================================================

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "A critical network router responsible for routing traffic within the core network infrastructure."@en ;
    noria:resourceHostName "core-router-01.paris.orange.com"^^xsd:string ;
    noria:resourceLogisticId "CR01-PDC01-001"^^xsd:string ;
    noria:resourceProductModel ex:CiscoASR9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "ABC123DEF456"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:InternetAccessService ;
    noria:locatedAtLocus ex:CoreRack01 ;
    noria:resourceManagementIPAddress ex:CoreRouter01_MgmtIP ;
    noria:elementManagedBy ex:NetworkOperationsDept ;
    seas:hasCommunicationConnectionPoint ex:Router01_GE0_0_1 ;
    seas:hasCommunicationConnectionPoint ex:Router01_GE0_0_2 .

ex:CoreRouter01_MgmtIP
    a observable:IPAddress ;
    rdfs:label "Core Router 01 Management IP Address"@en ;
    rdfs:comment "The IP address used for remote management of Core Router 01."@en ;
    observable:ipAddressValue "10.0.0.1"^^xsd:string .

ex:ServerHost01
    a noria:Resource ;
    rdfs:label "Server Host 01"@en ;
    rdfs:comment "A physical server hosting virtual machines for various applications."@en ;
    noria:resourceHostName "server-host-01.paris.orange.com"^^xsd:string ;
    noria:resourceLogisticId "SH01-PDC01-001"^^xsd:string ;
    noria:resourceProductModel ex:DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "GHI789JKL012"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalProdModule ;
    noria:locatedAtLocus ex:Rack12 ;
    noria:elementManagedBy ex:NetworkOperationsDept ;
    seas:hasCommunicationConnectionPoint ex:Server01_ETH0 ;
    seas:hasSubSystem ex:VirtualMachine01 .

ex:VirtualMachine01
    a noria:Resource ;
    rdfs:label "Virtual Machine 01 (Customer Portal)"@en ;
    rdfs:comment "A virtual server instance running the Customer Portal application module."@en ;
    noria:resourceHostName "vm-customerportal-01.paris.orange.com"^^xsd:string ;
    noria:resourceLogisticId "VM01-CP-PDC01"^^xsd:string ;
    noria:resourceType <kos/Resource/type/VirtualServer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-06-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalProdModule ;
    noria:elementManagedBy ex:ApplicationDevelopmentDept ;
    seas:hasCommunicationConnectionPoint ex:VM01_VETH0 ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Running> .

ex:Firewall01
    a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "A network firewall protecting the data center perimeter."@en ;
    noria:resourceHostName "fw-perimeter-01.paris.orange.com"^^xsd:string ;
    noria:resourceLogisticId "FW01-PDC01-001"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "PQR345STU678"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2019-11-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:CoreRack01 ;
    noria:elementManagedBy ex:SecurityOperationsCenter ;
    seas:hasCommunicationConnectionPoint ex:FW01_ETH0 .

ex:Router01_GE0_0_1
    a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Network interface GE0/0/1 on Core Router 01, connecting to Server Host 01."@en ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceDescription "Link to Server Host 01"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100^^xsd:int ;
    noria:networkInterfaceConnects ex:Link_Router01_Server01 .

ex:Router01_GE0_0_2
    a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigabitEthernet0/0/2"@en ;
    rdfs:comment "Network interface GE0/0/2 on Core Router 01, connecting to Firewall 01."@en ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceDescription "Uplink to Perimeter Firewall"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects ex:Link_Router01_Internet .

ex:Server01_ETH0
    a noria:NetworkInterface ;
    rdfs:label "Server Host 01 Ethernet0"@en ;
    rdfs:comment "Ethernet interface ETH0 on Server Host 01, connecting to Core Router 01."@en ;
    noria:networkInterfaceOf ex:ServerHost01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceDescription "Link to Core Router 01"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects ex:Link_Router01_Server01 .

ex:VM01_VETH0
    a noria:NetworkInterface ;
    rdfs:label "Virtual Machine 01 Virtual Ethernet0"@en ;
    rdfs:comment "Virtual Ethernet interface VETH0 on Virtual Machine 01."@en ;
    noria:networkInterfaceOf ex:VirtualMachine01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceDescription "Virtual interface for Customer Portal App"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

ex:FW01_ETH0
    a noria:NetworkInterface ;
    rdfs:label "Firewall 01 Ethernet0"@en ;
    rdfs:comment "Ethernet interface ETH0 on Firewall 01, connecting to Core Router 01."@en ;
    noria:networkInterfaceOf ex:Firewall01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceDescription "Link to Core Router 01"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects ex:Link_Router01_Internet .

ex:Link_Router01_Server01
    a noria:NetworkLink ;
    rdfs:label "Link between Core Router 01 and Server Host 01"@en ;
    rdfs:comment "A physical network link connecting Core Router 01 to Server Host 01."@en ;
    noria:networkLinkId "NL-CR01-SH01-001"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin ex:CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination ex:ServerHost01 ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:elementManagedBy ex:NetworkOperationsDept .

ex:Link_Router01_Internet
    a noria:NetworkLink ;
