# =============================================================================
# Procedural Elements
# =============================================================================

ex:RouterRestartProcedure
    a noria:OperationPlan ;
    rdfs:label "Router Interface Restart Procedure"@en ;
    rdfs:comment "A standardized procedure for restarting a network interface on a router to restore connectivity."@en ;
    noria:operationPlanPreCondition ex:CheckInterfaceStatusPreCondition ;
    noria:operationPlanPostCondition ex:InterfaceUpPostCondition .

ex:CheckInterfaceStatusPreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Check Interface Status Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Verify that the network interface is currently in a 'down' operational state."@en .

ex:InterfaceUpPostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Interface Up Post-Condition"@en ;
    rdfs:comment "Post-condition: Confirm that the network interface is in an 'up' operational state and traffic is flowing as expected."@en .

ex:NetworkOutageAnomaly
    a noria:AnomalyPattern ;
    rdfs:label "Network Outage Anomaly Pattern"@en ;
    rdfs:comment "A pattern describing a network outage, characterized by multiple critical alarms on core network devices and widespread service disruption."@en ;
    folio:hasCause "Hardware failure or misconfiguration"^^xsd:string ;
    folio:hasEffect "Service unavailability, customer impact"^^xsd:string .

# =============================================================================
# Additional Interconnections and Details
# =============================================================================

# Example of an action correlated with an operation plan
ex:Action_RouterInterfaceRestart
    a pep:Action ;
    rdfs:label "Action: Restart Router Interface"@en ;
    rdfs:comment "A specific action taken to restart the problematic router interface."@en ;
    noria:actionCorrelatedOperationPlan ex:RouterRestartProcedure ;
    pep:hasCommand "interface GigabitEthernet0/0/1; shutdown; no shutdown"^^xsd:string ;
    pep:madeBy ex:JohnDoe ;
    pep:atTime "2024-03-15T10:30:00Z"^^xsd:dateTime .

# Example of an EventRecord being mitigated by a ProcedureExecutionContainer
ex:ProcedureExecutionContainer_RouterFix
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution Container for Router Fix"@en ;
    rdfs:comment "A container for the execution steps taken to resolve the router interface issue."@en ;
    pep:ldp:member ex:Action_RouterInterfaceRestart ;
    pep:ldp:member ex:Event_RouterInterfaceUp ;
    noria:alarmMitigatedBy ex:ProcedureExecutionContainer_RouterFix .

ex:Event_RouterInterfaceUp
    a noria:EventRecord ;
    rdfs:label "Router Interface Up Event"@en ;
    rdfs:comment "An event indicating that the network interface on Core Router 01 has come back up after intervention."@en ;
    noria:loggingTime "2024-03-15T10:35:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to up"^^xsd:string ;
    noria:logOriginatingManagedObject ex:CoreRouter01 ;
    noria:logOriginatingManagementSystem ex:NMS_App ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    dcterms:type <kos/Notification/EventType/stateChange> .

# Example of a TroubleTicketNote correlated with an execution
ex:TT_Note_001_Resolution
    a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket 001 Resolution Note"@en ;
    rdfs:comment "Resolution note for Trouble Ticket TT-20240315-001, detailing the fix."@en ;
    dcterms:created "2024-03-15T10:40:00Z"^^xsd:dateTime ;
    dcterms:creator ex:JohnDoe ;
    dcterms:description "Interface GE0/0/1 on core-router-01 was administratively bounced. Connectivity restored. Customer Portal accessible."^^xsd:string ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ;
    dcterms:isPartOf ex:TT_20240315_001 ;
    noria:troubleTicketNoteCorrelatedExecution ex:ProcedureExecutionContainer_RouterFix .

# Update TT status to Resolved
ex:Event_TT_StatusChange_Resolved
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket Status Change to Resolved"@en ;
    rdfs:comment "An event recording the status change of Trouble Ticket TT-20240315-001 to 'Resolved'."@en ;
    noria:loggingTime "2024-03-15T10:41:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240315-001 status changed to Resolved."^^xsd:string ;
    noria:logOriginatingManagementSystem ex:NMS_App ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    dcterms:references ex:TT_20240315_001 .

# Link the resolved status event to the TT's history
ex:TT_20240315_001
    noria:documentStatusHistory ex:Event_TT_StatusChange_Resolved .

