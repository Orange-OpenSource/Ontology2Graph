ex:CR_20240315_002
    a noria:ChangeRequest ;
    rdfs:label "Change Request for Router Firmware Upgrade"@en ;
    rdfs:comment "A change request to upgrade the firmware of Core Router 01 to address known vulnerabilities and improve performance."@en ;
    dcterms:identifier "CR-20240315-002"^^xsd:string ;
    dcterms:created "2024-03-10T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-03-15T14:00:00Z"^^xsd:dateTime ;
    dcterms:description "Upgrade firmware on core-router-01 to version 7.2.1 to patch critical security vulnerabilities and enable new routing features. Requires a brief service interruption."^^xsd:string ;
    noria:documentExternalId "SEC-UPG-CR01-2024"^^xsd:string ;
    noria:documentHRef "http://itsm.example.com/changes/CR-20240315-002"^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-03-20T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-20T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact ex:CoreRouter01 ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RouterFirmwareUpgrade> ;
    noria:changeRequestInitiatorParty ex:JaneSmith ;
    noria:changeRequestPilotParty ex:JohnDoe ;
    noria:changeRequestActorParty ex:NetworkOperationsDept ;
    noria:changeRequestIsRegulated true^^xsd:boolean ;
    noria:documentStatusHistory ex:Event_CR_StatusChange_Planned .

ex:CR_Attachment_Plan
    a noria:DocumentAttachment ;
    rdfs:label "Router Firmware Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the firmware upgrade on Core Router 01."@en ;
    dcterms:created "2024-03-10T10:00:00Z"^^xsd:dateTime ;
    dcterms:title "CR-20240315-002_UpgradePlan.pdf"^^xsd:string ;
    dcterms:format "application/pdf"^^xsd:string ;
    dcterms:isPartOf ex:CR_20240315_002 .

ex:Event_TT_StatusChange_InProgress
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket Status Change to InProgress"@en ;
    rdfs:comment "An event recording the status change of Trouble Ticket TT-20240315-001 to 'InProgress'."@en ;
    noria:loggingTime "2024-03-15T10:16:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240315-001 status changed to InProgress."^^xsd:string ;
    noria:logOriginatingManagementSystem ex:NMS_App ; # Assuming NMS updates ITSM
    dcterms:type <kos/Notification/EventType/stateChange> ;
    dcterms:references ex:TT_20240315_001 .

ex:Event_CR_StatusChange_Planned
    a noria:EventRecord ;
