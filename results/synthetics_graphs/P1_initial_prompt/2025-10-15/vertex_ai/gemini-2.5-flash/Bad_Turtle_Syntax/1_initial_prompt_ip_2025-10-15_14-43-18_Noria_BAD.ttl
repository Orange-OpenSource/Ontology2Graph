    rdfs:comment "A physical network link connecting Core Router 01 to Firewall 01, providing internet access."@en ;
    noria:networkLinkId "NL-CR01-FW01-001"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin ex:CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination ex:Firewall01 ;
    noria:networkLinkInstallationDate "2019-11-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 40Gbps"^^xsd:string ;
    noria:elementManagedBy ex:NetworkOperationsDept .

ex:CiscoASR9K
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "Product model for Cisco's Aggregation Services Routers."@en ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:DellPowerEdgeR740
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740 Server"@en ;
    rdfs:comment "Product model for Dell's PowerEdge R740 rack server."@en ;
    noria:productManufacturedBy ex:DellTechnologies .

# =============================================================================
# Functional Elements (Applications & Services)
# =============================================================================

ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "The main web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CP-WEB"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001^^xsd:int ;
    noria:applicationShortIdentifier "CP"^^xsd:string ;
    noria:applicationType <kos/application/type/WebApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Customer Self-Service"^^xsd:string ;
    noria:elementManagedBy ex:ApplicationDevelopmentDept ;
    seas:hasSubSystem ex:CustomerPortalProdModule ;
    seas:hasSubSystem ex:CustomerPortalDevModule .

ex:CustomerPortalProdModule
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "The production instance of the Customer Portal application, serving live customer traffic."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CP_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ApplicationDevelopmentDept ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith ;
    noria:applicationModuleSupportTeam ex:ApplicationDevelopmentDept ;
    noria:applicationModuleSupportLeader ex:JaneSmith ;
    noria:applicationModuleSupportGroup ex:CustomerServiceDept ;
    noria:applicationModuleHotlineGroup ex:ApplicationDevelopmentDept ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true^^xsd:boolean ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:elementManagedBy ex:ApplicationDevelopmentDept .

ex:CustomerPortalDevModule
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en ;
    rdfs:comment "The development instance of the Customer Portal application, used for testing and new feature development."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CP_DEV"^^xsd:string ;
    noria:applicationModuleIdentifier "DEV"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ApplicationDevelopmentDept ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:elementManagedBy ex:ApplicationDevelopmentDept .

ex:InternetAccessService
    a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf ex:CustomerPortalProdModule ; # This service underpins the application module
    noria:elementManagedBy ex:NetworkOperationsDept .

ex:MonitoringService
    a noria:Service ;
    rdfs:label "Infrastructure Monitoring Service"@en ;
    rdfs:comment "Internal service responsible for collecting and analyzing operational metrics and logs from infrastructure components."@en ;
    noria:serviceType <kos/service/type/InternalService> ;
    seas:subSystemOf ex:ServerHost01 ; # This service runs on ServerHost01
    noria:elementManagedBy ex:NetworkOperationsDept .

ex:NMS_App
    a noria:Application ;
    rdfs:label "Network Monitoring System (NMS)"@en ;
    rdfs:comment "An application used to monitor the health and performance of network devices."@en ;
    noria:applicationType <kos/application/type/MonitoringSystem> ;
    noria:elementManagedBy ex:NetworkOperationsDept .

ex:APM_App
    a noria:Application ;
    rdfs:label "Application Performance Monitoring (APM)"@en ;
    rdfs:comment "An application used to monitor the performance and availability of business applications."@en ;
    noria:applicationType <kos/application/type/MonitoringSystem> ;
    noria:elementManagedBy ex:ApplicationDevelopmentDept .

# =============================================================================
# Dynamic Elements (Events & Tickets)
# =============================================================================

ex:Event_RouterDown
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "An event indicating that a network interface on Core Router 01 has gone down."@en ;
    noria:loggingTime "2024-03-15T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject ex:CoreRouter01 ;
    noria:logOriginatingManagementSystem ex:NMS_App ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction ex:RouterRestartProcedure ;
    dcterms:type <kos/Notification/EventType/stateChange> .

ex:Event_AppError
    a noria:EventRecord ;
    rdfs:label "Customer Portal Application Error Event"@en ;
    rdfs:comment "An event indicating a critical error within the Customer Portal application."@en ;
    noria:loggingTime "2024-03-15T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Application Error: Database connection timed out for Customer Portal."^^xsd:string ;
    noria:logOriginatingManagedObject ex:VirtualMachine01 ;
    noria:logOriginatingManagementSystem ex:APM_App ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/ApplicationError> .

ex:TT_20240315_001
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket for Customer Portal Outage"@en ;
    rdfs:comment "A trouble ticket opened due to the outage of the Customer Portal application, triggered by a router interface going down."@en ;
    dcterms:identifier "TT-20240315-001"^^xsd:string ;
    dcterms:created "2024-03-15T10:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-03-15T11:30:00Z"^^xsd:dateTime ;
    dcterms:title "Customer Portal inaccessible due to network issue"@en ;
    dcterms:description "Customers are unable to access the portal. Initial investigation points to a network connectivity problem affecting the application server."^^xsd:string ;
    noria:documentExternalId "CUST-INC-98765"^^xsd:string ;
    noria:documentHRef "http://itsm.example.com/tickets/TT-20240315-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Blocking> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger ex:Event_RouterDown ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "NMS_App"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network interface failure on core router leading to application server isolation."^^xsd:string ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-03-15T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-15T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-03-15T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty ex:JohnDoe ;
    noria:troubleTicketRelatedParty ex:JaneSmith ;
    noria:troubleTicketRelatedService ex:CustomerPortalProdModule ;
    noria:troubleTicketRelatedResource ex:CoreRouter01 ;
