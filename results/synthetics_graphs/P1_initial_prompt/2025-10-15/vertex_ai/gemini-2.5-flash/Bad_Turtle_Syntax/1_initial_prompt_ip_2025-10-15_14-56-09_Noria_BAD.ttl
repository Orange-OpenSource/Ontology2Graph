# =============================================================================
# Knowledge Graph Instances for TechCorp
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Organizational Units and Agents (Teams/Persons)
# -----------------------------------------------------------------------------

ex:TechCorp
    a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "The main organization for which the IT infrastructure is managed, providing various digital services."@en ;
    org:hasUnit ex:NOC_Team, ex:AppSupport_Team, ex:Infra_Team, ex:SOC_Team, ex:DevOps_Team ;
    .

ex:NOC_Team
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Team"@en ;
    rdfs:comment "Team responsible for 24/7 monitoring, incident response, and management of TechCorp's network infrastructure, ensuring connectivity and performance."@en ;
    org:unitOf ex:TechCorp ;
    org:hasMember ex:John_Doe ;
    noria:agentWorkingHours "24/7 Shift Rotation (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod ex:NOC_Team_Contact_Method_Phone ;
    noria:agentInstructions "For critical network issues (P1/P2), call the hotline immediately. For non-critical issues (P3/P4), use the ticketing system and assign to 'NOC-L1' queue."@en ;
    .

ex:AppSupport_Team
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting, maintaining, and troubleshooting business-critical applications, acting as L2 support."@en ;
    org:unitOf ex:TechCorp ;
    org:hasMember ex:Jane_Smith ;
    noria:agentWorkingHours "Mon-Fri, 9:00-17:00 CET"@en ;
    noria:agentPreferredContactMethod ex:AppSupport_Team_Contact_Method_Email ;
    noria:agentInstructions "Submit a ticket via the internal portal for all application-related issues. For urgent matters, escalate via chat to 'AppSupport-Urgent' channel."@en ;
    .

ex:Infra_Team
    a org:OrganizationalUnit ;
    rdfs:label "Infrastructure Team"@en ;
    rdfs:comment "Team responsible for the design, deployment, and maintenance of physical and virtual server infrastructure, storage, and virtualization platforms."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "Mon-Fri, 8:30-17:30 CET"@en ;
    noria:agentInstructions "All infrastructure changes must follow the Change Management process. For emergency changes, contact the on-call engineer."@en ;
    .

ex:SOC_Team
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center Team"@en ;
    rdfs:comment "Team dedicated to monitoring, detecting, analyzing, and responding to cybersecurity threats and incidents across TechCorp's IT assets."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "24/7 Security Monitoring and Incident Response"@en ;
    noria:agentPreferredContactMethod ex:SOC_Team_Contact_Method_SIEM ;
    noria:agentInstructions "Report all suspected security incidents via the dedicated security incident portal. Do not attempt to remediate without SOC guidance."@en ;
    .

ex:DevOps_Team
    a org:OrganizationalUnit ;
    rdfs:label "DevOps Team"@en ;
    rdfs:comment "Team focused on bridging development and operations, automating software delivery, and managing cloud-native applications."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "Mon-Fri, 9:00-18:00 CET"@en ;
    .

ex:John_Doe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A senior network engineer and shift leader in the NOC team, specializing in routing and switching."@en ;
    org:memberOf ex:NOC_Team ;
    foaf:mbox <mailto:john.doe@techcorp.com> ;
    foaf:phone "+1-555-123-4567" ;
    schema:jobTitle "Senior Network Engineer"@en ;
    vcard:hasEmail <mailto:john.doe@techcorp.com> ;
    vcard:hasTelephone <tel:+1-555-123-4567> ;
    foaf:holdsAccount ex:John_Doe_CUid ;
    .

ex:Jane_Smith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An application specialist and team lead in the Application Support team, with expertise in the Web Portal application."@en ;
    org:memberOf ex:AppSupport_Team ;
    foaf:mbox <mailto:jane.smith@techcorp.com> ;
    foaf:phone "+1-555-987-6543" ;
    schema:jobTitle "Application Support Lead"@en ;
    vcard:hasEmail <mailto:jane.smith@techcorp.com> ;
    vcard:hasTelephone <tel:+1-555-987-6543> ;
    foaf:holdsAccount ex:Jane_Smith_CUid ;
    .

ex:John_Doe_CUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for John Doe, used for system logins and access control."@en ;
