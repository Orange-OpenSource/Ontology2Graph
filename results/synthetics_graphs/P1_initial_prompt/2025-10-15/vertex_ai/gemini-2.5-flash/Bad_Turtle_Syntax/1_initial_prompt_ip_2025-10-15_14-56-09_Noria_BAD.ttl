# Change Request
ex:CR_WebPortal_Upgrade_003
    a noria:ChangeRequest ;
    rdfs:label "Web Portal Software Upgrade to v2.0"@en ;
    rdfs:comment "Change request for upgrading the Web Portal application to version 2.0, introducing new features and security patches."@en ;
    dcterms:identifier "CR-2024-04-25-003"@en ;
    dcterms:created "2024-04-25T09:00:00Z"^^xsd:dateTime ;
    noria:documentHRef <http://changemgmt.techcorp.com/CR-2024-04-25-003>^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-05-01T02:05:00Z"^^xsd:dateTime ; # Actual start after planned
    noria:changeRequestActualEndTime "2024-05-01T03:45:00Z"^^xsd:dateTime ; # Actual end before planned
    noria:changeRequestCategory ex:InternalIntervention_CRCategory ;
    noria:changeRequestType ex:Standard_CRType ;
    noria:changeRequestChangeCause ex:SoftwareUpgrade_CRCause ;
    noria:changeRequestOutageDuration "PT1H40M"^^xsd:duration ; # 1 hour 40 minutes actual outage
    noria:changeRequestStatusCurrent ex:Completed_CRStatus ; # Changed to completed for demonstration
    noria:changeRequestSpecification ex:StandardUpgrade_CRSpecification ;
    noria:changeRequestInitiatorParty ex:Jane_Smith ;
    noria:changeRequestPilotParty ex:Jane_Smith ;
    noria:changeRequestActorParty ex:DevOps_Team ; # DevOps team performs the upgrade
    noria:changeRequestIsRegulated false^^xsd:boolean ;
    noria:changeRequestImpact ex:WebPortal_Prod_Module, ex:Customer_Facing_Web_Service ;
    noria:documentStatusHistory ex:Event_CR_Status_Scheduled, ex:Event_CR_Status_InProgress, ex:Event_CR_Status_Completed ;
    .

ex:InternalIntervention_CRCategory
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
