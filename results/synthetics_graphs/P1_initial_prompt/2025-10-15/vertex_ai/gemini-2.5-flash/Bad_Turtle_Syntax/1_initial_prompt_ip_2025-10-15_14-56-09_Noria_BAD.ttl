    rdfs:comment "Event type indicating a detected security threat or incident."@en ;
    .

# Trouble Ticket for Security Incident
ex:TT_Security_Incident_003
    a noria:TroubleTicket ;
    rdfs:label "Security Incident - Brute Force Attack"@en ;
    rdfs:comment "Trouble ticket created by SOC team in response to a detected brute force attack on the Web Portal."@en ;
    dcterms:identifier "TT-2024-04-26-003"@en ;
    dcterms:created "2024-04-26T01:35:00Z"^^xsd:dateTime ;
    noria:documentHRef <http://ticketing.techcorp.com/TT-2024-04-26-003>^^xsd:anyURI ;
    noria:troubleTicketSeverity ex:Major_TTSeverity ;
    noria:troubleTicketType ex:Security_TTType ;
    noria:troubleTicketCriticity ex:PotentialSecurityBreach_TTCriticity ;
    noria:troubleTicketPriority ex:P2_TTPriority ;
    noria:troubleTicketOrigin ex:Supervision_TTOrigin ;
    noria:troubleTicketTrigger ex:Event_Security_BruteForce ;
    noria:troubleTicketUrgency ex:ImmediateIntervention_TTUrgency ;
    noria:troubleTicketSupervisionTool "SIEM-Guard"@en ;
    noria:troubleTicketCategory ex:CyberAttack_TTCategory ;
    noria:troubleTicketCause "Automated brute force attack originating from a compromised botnet IP."@en ;
    noria:problemResponsibility ex:IllDefined_ProblemResponsibility ; # Initial assessment, responsibility might be external
    noria:troubleTicketDetectionDateTime "2024-04-26T01:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent ex:InProgress_TTStatus ;
    noria:troubleTicketRelatedParty ex:SOC_Team ;
    noria:troubleTicketRelatedService ex:Customer_Facing_Web_Service ;
    noria:troubleTicketRelatedResource ex:App_Server_01 ;
    noria:troubleTicketImpacts ex:WebPortal_Prod_Module ;
    .

