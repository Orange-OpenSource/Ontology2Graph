    noria:troubleTicketSupervisionTool "NMS-Pro"@en ;
    noria:troubleTicketCategory ex:TotalBreakdown_TTCategory ;
    noria:troubleTicketCause "Physical fiber cut detected on core link between Router Core 01 and Access Switch 01."@en ;
