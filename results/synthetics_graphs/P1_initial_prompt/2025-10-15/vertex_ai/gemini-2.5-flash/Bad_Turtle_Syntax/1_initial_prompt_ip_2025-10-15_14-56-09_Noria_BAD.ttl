    noria:troubleTicketSeverity ex:Blocking_TTSeverity ;
    noria:troubleTicketType ex:Failure_TTType ;
    noria:troubleTicketCriticity ex:InterruptedService_TTCriticity ;
    noria:troubleTicketPriority ex:P1_TTPriority ;
    noria:troubleTicketOrigin ex:Supervision_TTOrigin ;
    noria:troubleTicketTrigger ex:Event_Link_Down_Router_Core_01 ;
