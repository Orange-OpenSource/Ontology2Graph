# Example of a corrective action (ProcedureExecution) related to a TroubleTicketNote
ex:CorrectiveAction_RestartApp
    a pep:ProcedureExecution ;
    rdfs:label "Restart Web Portal Application"@en ;
    rdfs:comment "Execution of the application restart procedure to resolve performance issues on Web Portal Production Module."@en ;
    pep:usedProcedure ex:App_Restart_Plan ;
    pep:madeBy ex:Jane_Smith ;
    pep:hasCommand "ssh app-server-01 'sudo systemctl restart webportal-prod-module'"@en ;
    pep:hasSimpleResult "Web Portal service restarted successfully. Initial checks show improved response times."@en ;
    log:time "2024-04-20T11:45:00Z"^^xsd:dateTime ;
    .

