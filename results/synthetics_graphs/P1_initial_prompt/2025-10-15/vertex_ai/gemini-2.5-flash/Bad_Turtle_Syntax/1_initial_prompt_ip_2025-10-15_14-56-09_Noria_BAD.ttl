# -----------------------------------------------------------------------------
# 2. Locations
# -----------------------------------------------------------------------------

ex:Main_Data_Center
    a bot:Site ;
    rdfs:label "TechCorp Main Data Center"@en ;
    rdfs:comment "The primary data center facility for TechCorp's IT infrastructure, located in Metropolis."@en ;
    noria:siteId "DC01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 TechCorp Avenue, Metropolis, 10001, US"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en ;
    bot:containsZone ex:Server_Room_A, ex:Network_Room_B ;
    .

ex:Server_Room_A
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated server room within the Main Data Center, housing application and database servers."@en ;
    bot:hasSubSpace ex:Rack_01, ex:Rack_02 ;
    .

ex:Network_Room_B
    a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "A dedicated network room within the Main Data Center, housing core network devices."@en ;
    bot:hasSubSpace ex:Rack_03 ;
    .

ex:Rack_01
    a noria:Locus ;
    rdfs:label "Rack 01 in Server Room A"@en ;
    rdfs:comment "Specific rack location 'A-1' for application servers within Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    .

ex:Rack_02
    a noria:Locus ;
    rdfs:label "Rack 02 in Server Room A"@en ;
    rdfs:comment "Specific rack location 'B-2' for database servers within Server Room A."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "2"@en ;
    .

ex:Rack_03
    a noria:Locus ;
    rdfs:label "Rack 03 in Network Room B"@en ;
    rdfs:comment "Specific rack location 'C-3' for core network equipment within Network Room B."@en ;
    noria:locusLine "C"@en ;
    noria:locusRow "3"@en ;
    .

