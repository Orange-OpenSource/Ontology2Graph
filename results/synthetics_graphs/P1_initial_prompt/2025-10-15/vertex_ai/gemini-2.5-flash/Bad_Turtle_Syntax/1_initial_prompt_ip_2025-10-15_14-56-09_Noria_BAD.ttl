# -----------------------------------------------------------------------------
# 8. Procedural Elements (Operation Plans, Pre/Post Conditions, Anomaly Patterns)
# -----------------------------------------------------------------------------

ex:Network_Troubleshooting_Plan
    a noria:OperationPlan ;
    rdfs:label "Network Link Troubleshooting Plan"@en ;
    rdfs:comment "A standardized procedure for diagnosing and resolving network link failures, including physical layer checks and routing verification."@en ;
    noria:operationPlanPreCondition ex:Link_Down_PreCondition ;
    noria:operationPlanPostCondition ex:Link_Up_PostCondition ;
    .

ex:Link_Down_PreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Network Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down', and no administrative shutdown was performed."@en ;
    .

ex:Link_Up_PostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Network Link Up Post-Condition"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up', traffic is flowing normally, and all dependent services are restored."@en ;
    .

ex:App_Restart_Plan
    a noria:OperationPlan ;
    rdfs:label "Application Restart Procedure"@en ;
    rdfs:comment "A procedure to gracefully restart a business application in case of unresponsiveness or performance degradation."@en ;
    noria:operationPlanPreCondition ex:App_Unresponsive_PreCondition ;
    noria:operationPlanPostCondition ex:App_Responsive_PostCondition ;
    .

ex:App_Unresponsive_PreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Application Unresponsive Pre-Condition"@en ;
    rdfs:comment "Condition: Application is not responding to health checks, user requests are timing out, or CPU/memory usage is abnormally high."@en ;
    .

ex:App_Responsive_PostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Application Responsive Post-Condition"@en ;
    rdfs:comment "Expected outcome: Application is responding to health checks, user requests are processed within SLA, and resource utilization is normal."@en ;
    .

ex:HighErrorRate_AnomalyPattern
    a noria:AnomalyPattern ;
    rdfs:label "High Application Error Rate Anomaly Pattern"@en ;
    rdfs:comment "A pattern indicating a sustained high rate of errors (e.g., HTTP 5xx responses) in an application, potentially leading to performance degradation or service outage."@en ;
    folio:hasConsequence ex:PerformanceDegradation_Consequence ;
    .

ex:PerformanceDegradation_Consequence
    a folio:Consequence ;
    rdfs:label "Performance Degradation"@en ;
    rdfs:comment "The consequence of a high error rate, leading to slow application response times and potential user dissatisfaction."@en ;
    .

ex:UnauthorizedAccess_AnomalyPattern
    a noria:AnomalyPattern ;
    rdfs:label "Unauthorized Access Attempt Anomaly Pattern"@en ;
    rdfs:comment "A pattern indicating multiple failed login attempts from an unusual IP address, potentially signaling a brute-force attack or unauthorized access."@en ;
    folio:hasConsequence ex:SecurityBreach_Consequence ;
    .

ex:SecurityBreach_Consequence
    a folio:Consequence ;
    rdfs:label "Potential Security Breach"@en ;
    rdfs:comment "The consequence of unauthorized access attempts, which could lead to data compromise or system takeover."@en ;
    .

