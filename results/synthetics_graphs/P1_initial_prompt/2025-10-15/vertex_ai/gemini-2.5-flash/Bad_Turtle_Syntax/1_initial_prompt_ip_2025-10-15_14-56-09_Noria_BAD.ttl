    observable:accountLogin "jdoe"@en ;
    observable:accountIdentifier "jdoe-tc-001"@en ;
    .

ex:Jane_Smith_CUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for Jane Smith, used for system logins and access control."@en ;
    foaf:accountName "jsmith"@en ;
    observable:accountLogin "jsmith"@en ;
    observable:accountIdentifier "jsmith-tc-002"@en ;
