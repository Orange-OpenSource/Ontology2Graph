    dcterms:creator ex:Jane_Smith ;
    dcterms:description "Restarted Web Portal application on app-server-01. Monitored for 5 minutes, performance restored to normal. Will continue monitoring for recurrence."@en ;
    dcterms:isPartOf ex:TT_App_Performance_002 ;
    noria:troubleTicketNoteCommentType ex:Internal_CommentType ;
    noria:troubleTicketNoteOperationType ex:CorrectiveAction_OperationType ;
    noria:troubleTicketNoteCorrelatedExecution ex:CorrectiveAction_RestartApp ;
