    .

# Example of a ChangeAction (subclass of pep:ProcedureExecution)
ex:CR_WebPortal_Upgrade_Action
    a pep:ChangeAction ;
    rdfs:label "Execute Web Portal Upgrade"@en ;
    rdfs:comment "The actual execution of the upgrade procedure for the Web Portal Production Module, performed by the DevOps team."@en ;
    pep:usedProcedure ex:App_Restart_Plan ; # Reusing for simplicity, could be a dedicated upgrade plan
    pep:madeBy ex:DevOps_Team ;
    pep:hasCommand "ansible-playbook webportal_upgrade.yml --tags v2.0"@en ;
    pep:hasSimpleResult "Web Portal upgraded to v2.0 successfully. All services verified."@en ;
    log:time "2024-05-01T03:00:00Z"^^xsd:dateTime ;
    dcterms:references ex:CR_WebPortal_Upgrade_003 ;
    noria:actionCorrelatedOperationPlan ex:App_Restart_Plan ; # Linking to an operation plan
    .

# Document Attachment for Change Request
ex:UpgradePlan_Attachment
    a noria:DocumentAttachment ;
    rdfs:label "Web Portal Upgrade Plan v2.0"@en ;
    rdfs:comment "Attachment: Detailed plan for the Web Portal v2.0 upgrade, including rollback procedures."@en ;
    dcterms:identifier "WEBPORTAL-UPGRADE-V2.0-PLAN.pdf"@en ;
    dcterms:format "application/pdf"@en ;
    dcterms:created "2024-04-22T14:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf ex:CR_WebPortal_Upgrade_003 ;
    .

# Event: Security Alert
ex:Event_Security_BruteForce
    a noria:EventRecord ;
    rdfs:label "Brute Force Attack Detected"@en ;
    rdfs:comment "An event indicating multiple failed login attempts against the Web Portal from a suspicious IP address, matching the Unauthorized Access Attempt Anomaly Pattern."@en ;
    noria:loggingTime "2024-04-26T01:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject ex:WebPortal_Prod_Module ;
    noria:logOriginatingManagementSystem ex:SIEM_System ;
    noria:logText "Multiple failed login attempts for user 'admin' from IP 103.20.10.5. Source IP blacklisted."@en ;
    noria:alarmSeverity ex:Major_AlarmSeverity ;
    dcterms:type ex:SecurityAlert_EventType ;
    .

ex:SIEM_System
    a noria:Application ;
    rdfs:label "Security Information and Event Management System"@en ;
    rdfs:comment "System responsible for collecting, analyzing, and correlating security events from various sources."@en ;
    noria:applicationShortIdentifier "SIEM"@en ;
    .

ex:SecurityAlert_EventType
    a skos:Concept ;
    skos:inScheme <kos/Notification/EventType> ;
