    noria:troubleTicketIsNotificationEnable true^^xsd:boolean ;
    noria:troubleTicketStatusCurrent ex:InProgress_TTStatus ;
    noria:troubleTicketRelatedParty ex:NOC_Team, ex:John_Doe ;
    noria:troubleTicketRelatedService ex:Customer_Facing_Web_Service ;
    noria:troubleTicketRelatedResource ex:Link_Core_Access, ex:Router_Core_01, ex:Switch_Access_01 ;
    noria:troubleTicketImpacts ex:WebPortal_Prod_Module ;
    noria:documentStatusHistory ex:Event_TT_Status_InProgress ;
    .

