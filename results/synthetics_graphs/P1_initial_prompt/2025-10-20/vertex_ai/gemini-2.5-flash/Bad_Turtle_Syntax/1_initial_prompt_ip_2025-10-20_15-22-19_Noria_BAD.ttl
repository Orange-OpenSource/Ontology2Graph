# --- Applications and Services ---

ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "The main web application for customer interaction, providing account management, service requests, and billing information."@en ;
    noria:applicationModelIdentifier "CPA-V1"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CPA"^^xsd:string ;
    noria:applicationType ex-kos:ApplicationType/WebApplication ;
    noria:applicationBusinessImportance ex-kos:BusinessImportance/Critical ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Customer Self-Service"@en ;
    noria:elementManagedBy ex:ApplicationSupportUnit .

ex:CustomerPortalProdModule
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "The live production instance of the Customer Portal Application, serving real customer traffic."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CPA_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-001"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ApplicationSupportUnit ;
    noria:applicationModuleAdministrationLeader ex:AliceAnalyst ;
    noria:applicationModuleSupportTeam ex:ApplicationSupportUnit ;
    noria:applicationModuleSupportLeader ex:AliceAnalyst ;
    noria:applicationModuleSlaLevel ex-kos:SlaLevel/Platinum ;
    noria:applicationModuleSlaLevelDate "2023-03-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus ex-kos:ApplicationStatus/InService .

ex:WebAccessService
    a noria:Service ;
    rdfs:label "Web Access Service"@en ;
    rdfs:comment "Provides external web access to the Customer Portal, acting as the entry point for all customer online interactions."@en ;
    noria:serviceType ex-kos:ServiceType/CustomerFacingService ;
    noria:elementManagedBy ex:ApplicationSupportUnit ;
    seas:subSystemOf ex:CustomerPortalProdModule . # The service is composed of the application module.

