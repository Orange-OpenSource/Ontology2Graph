# --- Events and Incidents ---

ex:NetworkInterfaceDownEvent
    a noria:EventRecord ;
    rdfs:label "Network Interface Down Event"@en ;
    rdfs:comment "An automated event record generated by the Network Monitoring System, indicating a critical change in the operational status of a network interface."@en ;
    noria:loggingTime "2024-03-15T14:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:logOriginatingManagedObject ex:CoreRouter01 ;
    noria:logOriginatingManagementSystem ex:NMSApplication ;
    noria:alarmSeverity ex-kos:PerceivedSeverity/Critical .

ex:NMSApplication
    a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "An application responsible for real-time monitoring of network devices, collecting metrics and generating alerts."@en ;
    noria:applicationShortIdentifier "NMS"^^xsd:string ;
    noria:applicationType ex-kos:ApplicationType/MonitoringSystem ;
    noria:elementManagedBy ex:NetworkOperationsUnit .

