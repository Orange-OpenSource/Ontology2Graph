# --- Change Management ---

ex:CR-2024-03-15-001
    a noria:ChangeRequest ;
    rdfs:label "Replace Faulty Network Card on Core Router 01"@en ;
    rdfs:comment "A change request initiated to replace a suspected faulty network interface card on Core Router 01, following repeated link failures and diagnostics."@en ;
    dcterms:identifier "CR-2024-03-15-001"^^xsd:string ;
    dcterms:created "2024-03-15T16:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CHG-54321"^^xsd:string ;
    noria:documentHRef <http://helpdesk.techcorp.com/changes/CR-2024-03-15-001> ;
    noria:changeRequestPlannedStartTime "2024-03-16T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-16T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory ex-kos:ChangeRequestCategory/InternalIntervention ;
    noria:changeRequestType ex-kos:ChangeRequestType/Standard ;
    noria:changeRequestChangeCause ex-kos:ChangeRequestCause/PreventativeMaintenance ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ; # 1 hour outage
    noria:changeRequestStatusCurrent ex-kos:ChangeRequestStatus/Scheduled ;
    noria:changeRequestImpact ex:CoreRouter01, ex:Link_WebFE_CoreRtr, ex:WebAccessService ;
    noria:changeRequestInitiatorParty ex:BobEngineer ;
    noria:changeRequestPilotParty ex:BobEngineer ;
    noria:changeRequestActorParty ex:NetworkOperationsUnit ;
    noria:changeRequestIsRegulated false .

