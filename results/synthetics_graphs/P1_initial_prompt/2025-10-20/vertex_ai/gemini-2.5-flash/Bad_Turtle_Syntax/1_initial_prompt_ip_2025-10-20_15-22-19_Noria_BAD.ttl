    a skos:Concept ;
    skos:prefLabel "Monitoring System"@en ;
    skos:inScheme <kos/application/type> .

# --- SKOS Concepts for Perceived Severity ---
ex-kos:PerceivedSeverity/Critical
    a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

ex:TT-2024-03-15-001
    a noria:TroubleTicket ;
    rdfs:label "Network Interface Down on Core Router 01 impacting Customer Portal"@en ;
    rdfs:comment "Trouble ticket automatically created in response to the critical network interface down event, indicating a service disruption."@en ;
    dcterms:identifier "TT-2024-03-15-001"^^xsd:string ;
    dcterms:created "2024-03-15T14:05:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-98765"^^xsd:string ;
    noria:documentHRef <http://helpdesk.techcorp.com/tickets/TT-2024-03-15-001> ;
    noria:troubleTicketSeverity ex-kos:TroubleTicketSeverity/Major ;
    noria:troubleTicketType ex-kos:TroubleTicketType/Failure ;
    noria:troubleTicketCriticity ex-kos:TroubleTicketCategory/InterruptedService ;
    noria:troubleTicketPriority ex-kos:TroubleTicketPriority/P1 ;
    noria:troubleTicketOrigin ex-kos:TroubleTicketOrigin/Supervision ;
    noria:troubleTicketTrigger ex:NetworkInterfaceDownEvent ;
    noria:troubleTicketUrgency ex-kos:TroubleTicketUrgency/ImmediateIntervention ;
    noria:troubleTicketSupervisionTool "NMS v2.0"^^xsd:string ;
    noria:troubleTicketCategory ex-kos:TroubleTicketCategory/NetworkFailure ;
    noria:troubleTicketCause "Physical link failure on GigabitEthernet0/0/1 of Core Router 01, possibly due to faulty SFP or cable."@en ;
    noria:problemResponsibility ex-kos:ProblemResponsibility/ManagedBackboneNetworks ;
    noria:troubleTicketDetectionDateTime "2024-03-15T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T16:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent ex-kos:TroubleTicketStatus/InProgress ;
    noria:troubleTicketRelatedParty ex:BobEngineer ;
    noria:troubleTicketRelatedService ex:WebAccessService ;
    noria:troubleTicketRelatedResource ex:CoreRouter01 ;
    noria:troubleTicketImpacts ex:WebFrontendServer01, ex:CustomerPortalProdModule .

ex:TTN-2024-03-15-001
    a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note"@en ;
    rdfs:comment "Engineer Bob Engineer performed initial diagnostics, confirmed link status 'down' via console, and initiated physical inspection of the cable and SFP module."@en ;
    dcterms:created "2024-03-15T14:15:00Z"^^xsd:dateTime ;
    dcterms:creator ex:BobEngineer ;
    noria:troubleTicketNoteCommentType ex-kos:CommentType/Internal ;
    noria:troubleTicketNoteOperationType ex-kos:OperationType/Diagnosis ;
    dcterms:isPartOf ex:TT-2024-03-15-001 .

ex:NetworkTroubleshootingPlan
    a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Plan"@en ;
    rdfs:comment "A standardized operating procedure for diagnosing and resolving network interface issues, including physical layer checks and configuration verification."@en ;
    noria:operationPlanPreCondition ex:InterfaceDownPreCondition ;
    noria:operationPlanPostCondition ex:InterfaceUpPostCondition .

ex:InterfaceDownPreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition: A network interface's operational status is reported as 'down' by monitoring systems, and connectivity tests fail."@en .

ex:InterfaceUpPostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Interface Up Post-Condition"@en ;
    rdfs:comment "Expected outcome: The network interface operational status is 'up', traffic flows normally, and all dependent services are restored."@en .

