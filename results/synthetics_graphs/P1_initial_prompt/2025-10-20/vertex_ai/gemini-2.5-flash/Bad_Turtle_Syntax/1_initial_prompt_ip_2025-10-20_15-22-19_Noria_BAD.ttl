# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix pep: <https://w3id.org/pep/> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .

# --- Example Data ---
@prefix ex: <http://example.com/data/> .
@prefix ex-kos: <http://example.com/kos/> . # For example KOS concepts

# =============================================================================
# Knowledge Graph Instances based on NORIA Schema
# =============================================================================

# --- Organization and People ---

ex:TechCorp
    a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "A leading technology company providing various IT services and managing a complex infrastructure."@en ;
    org:hasUnit ex:NetworkOperationsUnit, ex:ApplicationSupportUnit .

ex:NetworkOperationsUnit
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Responsible for the 24/7 management, monitoring, and maintenance of TechCorp's global network infrastructure."@en ;
    org:unitOf ex:TechCorp ;
    org:hasMember ex:BobEngineer ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri), on-call rotation for critical incidents."^^xsd:string ;
    noria:agentPreferredContactMethod ex-kos:ContactMethod/Email ;
    noria:agentInstructions "For critical network issues, use the dedicated hotline (ext. 4567) and create a P1 ticket in the ticketing system. For non-critical issues, email the team alias."@en .

ex:ApplicationSupportUnit
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Provides expert-level support for all critical business applications, ensuring high availability and performance."@en ;
    org:unitOf ex:TechCorp ;
    org:hasMember ex:AliceAnalyst ;
    noria:agentWorkingHours "8:30 AM - 4:30 PM (Mon-Fri), with extended support for business-critical applications."^^xsd:string ;
    noria:agentPreferredContactMethod ex-kos:ContactMethod/Phone ;
    noria:agentInstructions "All application issues must be reported via the internal helpdesk portal. For immediate assistance, call the support line (ext. 1234) and reference your ticket number."@en .

ex:AliceAnalyst
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Analyst"@en ;
    rdfs:comment "A dedicated application support analyst at TechCorp, specializing in customer-facing applications."@en ;
    foaf:mbox <mailto:alice.analyst@techcorp.com> ;
    foaf:holdsAccount ex:AliceCUid ;
    noria:agentInstructions "Contact via internal chat for urgent matters related to the Customer Portal. For other inquiries, use email."@en .

ex:BobEngineer
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Engineer"@en ;
    rdfs:comment "A senior network engineer at TechCorp, responsible for core routing and switching infrastructure."@en ;
    foaf:mbox <mailto:bob.engineer@techcorp.com> ;
    foaf:holdsAccount ex:BobCUid ;
    noria:agentInstructions "For network emergencies, call directly on his mobile. For planned changes, submit a change request through the change management system."@en .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for Alice Analyst, used for system access and authentication."@en ;
    foaf:accountName "a.analyst"^^xsd:string ;
    observable:accountLogin "a.analyst"^^xsd:string ;
    observable:accountIdentifier "CUID-AA-001"^^xsd:string .

ex:BobCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for Bob Engineer, granting access to network management tools."@en ;
    foaf:accountName "b.engineer"^^xsd:string ;
    observable:accountLogin "b.engineer"^^xsd:string ;
    observable:accountIdentifier "CUID-BE-002"^^xsd:string .

# --- SKOS Concepts for Agent Contact Method ---
ex-kos:ContactMethod/Email
    a skos:Concept ;
    skos:prefLabel "Email"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

ex-kos:ContactMethod/Phone
    a skos:Concept ;
    skos:prefLabel "Phone"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

# --- Location ---

ex:MainDataCenter
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "The primary data center facility for TechCorp, housing critical servers and network equipment."@en ;
    noria:siteId "DC-M-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Road, Suite 100"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    bot:containsZone ex:ServerRoomA .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated server room within the Main Data Center, optimized for high-density server racks."@en ;
    bot:containsZone ex:RackA1_U23, ex:RackA1_U24, ex:RackA1_U1 .

ex:RackA1_U23
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific physical location within Server Room A, unit 23 of rack A1."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "23"^^xsd:string .

ex:RackA1_U24
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 24"@en ;
    rdfs:comment "Specific physical location within Server Room A, unit 24 of rack A1."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "24"^^xsd:string .

ex:RackA1_U1
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 1"@en ;
    rdfs:comment "Specific physical location within Server Room A, unit 1 of rack A1, typically for networking equipment."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

# --- Infrastructure (Resources, Network Interfaces, Network Links, Product Models) ---

ex:DellProductModel
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Product model for Dell PowerEdge R740 servers, known for their reliability and performance."@en ;
    noria:productManufacturedBy ex:DellOrganization .

ex:DellOrganization
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "A multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

ex:CiscoProductModel
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9500"@en ;
    rdfs:comment "Product model for Cisco Catalyst 9500 series switches/routers, a high-performance enterprise-class platform."@en ;
    noria:productManufacturedBy ex:CiscoOrganization .

ex:CiscoOrganization
    a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "An American multinational digital communications technology conglomerate corporation."@en .

ex:WebFrontendServer01
    a noria:Resource ;
    rdfs:label "Web Frontend Server 01"@en ;
    rdfs:comment "A physical server dedicated to hosting the web frontend components of the Customer Portal Application, ensuring fast user interaction."@en ;
    noria:resourceHostName "web-fe-01.techcorp.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-WEB-001"^^xsd:string ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ-789"^^xsd:string ;
    noria:resourceProductModel ex:DellProductModel ;
    noria:resourceType ex-kos:ResourceType/Server ;
    noria:resourceUsageState ex-kos:LifecycleState/InProduction ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:ApplicationSupportUnit ;
    noria:locatedAtLocus ex:RackA1_U23 ;
    noria:resourceManagementIPAddress <http://192.168.10.101> ;
    bot:hasElement ex:MainDataCenter ;
    bot:hasElement ex:ServerRoomA ;
    noria:resourceForApplication ex:CustomerPortalApp .

ex:DatabaseServer01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "A physical server hosting the primary database for the Customer Portal Application, critical for data storage and retrieval."@en ;
    noria:resourceHostName "db-01.techcorp.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-DB-001"^^xsd:string ;
    noria:resourceSerialNumber "SN-DB-001-ABC-456"^^xsd:string ;
    noria:resourceProductModel ex:DellProductModel ;
    noria:resourceType ex-kos:ResourceType/Server ;
    noria:resourceUsageState ex-kos:LifecycleState/InProduction ;
    noria:resourceInstallationDate "2023-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:ApplicationSupportUnit ;
    noria:locatedAtLocus ex:RackA1_U24 ;
    noria:resourceManagementIPAddress <http://192.168.10.102> ;
    bot:hasElement ex:MainDataCenter ;
    bot:hasElement ex:ServerRoomA ;
    noria:resourceForApplication ex:CustomerPortalApp .

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "The primary core router for the data center, responsible for inter-VLAN routing and external connectivity."@en ;
    noria:resourceHostName "core-rtr-01.techcorp.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-RTR-001"^^xsd:string ;
    noria:resourceSerialNumber "SN-RTR-001-DEF-123"^^xsd:string ;
    noria:resourceProductModel ex:CiscoProductModel ;
    noria:resourceType ex-kos:ResourceType/Router ;
    noria:resourceUsageState ex-kos:LifecycleState/InProduction ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:NetworkOperationsUnit ;
    noria:locatedAtLocus ex:RackA1_U1 ;
    noria:resourceManagementIPAddress <http://10.0.0.1> ;
    bot:hasElement ex:MainDataCenter ;
    bot:hasElement ex:ServerRoomA .

ex:WebFrontendServer01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "Web Frontend Server 01 Ethernet 0"@en ;
    rdfs:comment "The primary Ethernet interface (eth0) on Web Frontend Server 01, connecting it to the data center network."@en ;
    noria:networkInterfaceOf ex:WebFrontendServer01 ;
    noria:networkInterfaceType ex-kos:NetworkInterfaceType/Physical ;
    noria:networkInterfaceAdministrativeStatus ex-kos:OperationalState/Up ;
    noria:networkInterfaceOperationalStatus ex-kos:OperationalState/Up ;
    noria:networkInterfaceConnects ex:Link_WebFE_CoreRtr .

ex:CoreRouter01_GigabitEthernet0_0_1
    a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/1 on Core Router 01, providing connectivity to the web frontend server segment."@en ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceType ex-kos:NetworkInterfaceType/Physical ;
    noria:networkInterfaceAdministrativeStatus ex-kos:OperationalState/Up ;
    noria:networkInterfaceOperationalStatus ex-kos:OperationalState/Up ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects ex:Link_WebFE_CoreRtr .

ex:Link_WebFE_CoreRtr
    a noria:NetworkLink ;
    rdfs:label "Link between Web Frontend Server 01 and Core Router 01"@en ;
    rdfs:comment "A physical 10 Gigabit Ethernet link connecting the Web Frontend Server 01 to the Core Router 01, crucial for application traffic."@en ;
    noria:networkLinkId "LINK-WEBFE-RTR-001"^^xsd:string ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin ex:WebFrontendServer01 ;
    noria:networkLinkTerminationResourceDestination ex:CoreRouter01 ;
    noria:resourceManagedBy ex:NetworkOperationsUnit .

