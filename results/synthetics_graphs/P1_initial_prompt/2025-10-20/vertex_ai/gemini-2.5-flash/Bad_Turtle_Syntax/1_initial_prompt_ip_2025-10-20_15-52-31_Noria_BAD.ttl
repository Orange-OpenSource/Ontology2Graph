# =============================================================================
# Procedural Elements
# =============================================================================

ex:NetworkTroubleshootingPlan
    a noria:OperationPlan ;
    rdfs:label "Standard Network Troubleshooting Plan"@en ;
    rdfs:comment "A predefined procedure for diagnosing and resolving common network issues."@en ;
    noria:operationPlanPreCondition ex:PreCondition_RouterReachable ;
    noria:operationPlanPostCondition ex:PostCondition_NetworkRestored .

ex:PreCondition_RouterReachable
    a noria:ActionPreCondition ;
    rdfs:label "Router Reachable Pre-Condition"@en ;
    rdfs:comment "Condition: The router must be reachable via its management IP address."@en .

ex:PostCondition_NetworkRestored
    a noria:ActionPostCondition ;
    rdfs:label "Network Restored Post-Condition"@en ;
    rdfs:comment "Outcome: Network connectivity is fully restored and stable."@en .

ex:RouterSoftwareUpgradeProcedure
    a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "A detailed procedure for upgrading router operating system software."@en ;
    noria:operationPlanPreCondition ex:PreCondition_RouterBackupComplete ;
    noria:operationPlanPostCondition ex:PostCondition_RouterVersionUpdated .

ex:PreCondition_RouterBackupComplete
    a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Complete Pre-Condition"@en ;
    rdfs:comment "Condition: A full backup of the router configuration must be completed before starting the upgrade."@en .

ex:PostCondition_RouterVersionUpdated
    a noria:ActionPostCondition ;
    rdfs:label "Router Software Version Updated Post-Condition"@en ;
    rdfs:comment "Outcome: The router's operating system software is successfully updated to the target version."@en .

ex:AnomalyPattern_HighInterfaceErrorRate
    a noria:AnomalyPattern ;
    rdfs:label "High Interface Error Rate Anomaly Pattern"@en ;
    rdfs:comment "Describes a pattern of unusually high error rates on network interfaces, indicating potential hardware or cabling issues."@en ;
    folio:hasCause "Faulty cable or transceiver"^^xsd:string .

ex:Event_HighErrorRateAlarm
    a noria:EventRecord ;
    rdfs:label "High Error Rate Alarm on Router A Interface"@en ;
    rdfs:comment "An alarm triggered by the monitoring system due to a high error rate detected on Router A's GE0/0/1 interface."@en ;
    noria:loggingTime "2024-04-21T09:00:00Z"^^xsd:dateTime ;
    noria:logText "Alarm: High error rate detected on Router A GE0/0/1. Threshold exceeded."^^xsd:string ;
    noria:logOriginatingManagedObject ex:RouterA_GE0_0_1 ;
    noria:logOriginatingManagementSystem ex:MonitoringDashboard ;
    noria:alarmSeverity ex:AlarmWarning ;
    noria:alarmProposedRepairAction ex:NetworkTroubleshootingPlan .

