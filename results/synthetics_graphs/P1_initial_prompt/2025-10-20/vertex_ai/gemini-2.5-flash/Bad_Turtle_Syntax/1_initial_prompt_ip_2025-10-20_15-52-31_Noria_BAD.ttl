# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/> .  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/> .  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/> .  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#> .  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# --- Example entities ---
@prefix ex: <http://example.com/noria-kg/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- SKOS Concept Schemes and Concepts for controlled vocabularies ---

# Application Type
ex:ApplicationTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of applications."@en .

ex:WebApplication
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Web Application"@en ;
    rdfs:comment "An application accessible via a web browser."@en .

ex:DatabaseApplication
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Database Application"@en ;
    rdfs:comment "An application primarily focused on data storage and retrieval."@en .

ex:MonitoringApplication
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "An application used for observing system performance and health."@en .

# Application Business Importance
ex:ApplicationBusinessImportanceScheme
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A controlled vocabulary for assessing the business importance of applications."@en .

ex:CriticalImportance
    a skos:Concept ;
    skos:inScheme ex:ApplicationBusinessImportanceScheme ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for core business operations."@en .

ex:HighImportance
    a skos:Concept ;
    skos:inScheme ex:ApplicationBusinessImportanceScheme ;
    rdfs:label "High"@en ;
    rdfs:comment "Application is important but not immediately critical for core business."@en .

# Application Module Status
ex:ApplicationModuleStatusScheme
    a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the operational status of application modules."@en .

ex:InProduction
    a skos:Concept ;
    skos:inScheme ex:ApplicationModuleStatusScheme ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

ex:InDevelopment
    a skos:Concept ;
    skos:inScheme ex:ApplicationModuleStatusScheme ;
    rdfs:label "In Development"@en ;
    rdfs:comment "The application module is under active development."@en .

# SLA Level
ex:SlaLevelScheme
    a skos:ConceptScheme ;
    rdfs:label "SLA Level Scheme"@en ;
    rdfs:comment "A controlled vocabulary for Service Level Agreement levels."@en .

ex:SlaGold
    a skos:Concept ;
    skos:inScheme ex:SlaLevelScheme ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "Highest service level, maximum availability and fastest response times."@en .

ex:SlaSilver
    a skos:Concept ;
    skos:inScheme ex:SlaLevelScheme ;
    rdfs:label "Silver SLA"@en ;
    rdfs:comment "Standard service level with good availability and response times."@en .

# Service Type
ex:ServiceTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of services."@en .

ex:CustomerFacingService
    a skos:Concept ;
    skos:inScheme ex:ServiceTypeScheme ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by external customers."@en .

ex:InternalService
    a skos:Concept ;
    skos:inScheme ex:ServiceTypeScheme ;
    rdfs:label "Internal Service"@en ;
    rdfs:comment "A service used internally by the organization."@en .

# Trouble Ticket Severity
ex:TroubleTicketSeverityScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the severity of trouble tickets."@en .

ex:SeverityCritical
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketSeverityScheme ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Service completely down or major business impact."@en .

ex:SeverityMajor
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketSeverityScheme ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant service degradation or partial outage."@en .

# Trouble Ticket Type
ex:TroubleTicketTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the type of trouble tickets."@en .

ex:FailureType
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketTypeScheme ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Indicates a system or component failure."@en .

ex:AssistanceType
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketTypeScheme ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Request for help or guidance."@en .

# Trouble Ticket Priority
ex:TroubleTicketPriorityScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the priority of trouble tickets."@en .

ex:PriorityP1
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketPriorityScheme ;
    rdfs:label "P1 - Urgent"@en ;
    rdfs:comment "Highest priority, immediate attention required."@en .

ex:PriorityP2
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketPriorityScheme ;
    rdfs:label "P2 - High"@en ;
    rdfs:comment "High priority, requires prompt attention."@en .

# Trouble Ticket Origin
ex:TroubleTicketOriginScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the origin of trouble tickets."@en .

ex:CustomerOrigin
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketOriginScheme ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Ticket initiated by a customer."@en .

ex:SupervisionOrigin
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketOriginScheme ;
    rdfs:label "Supervision System"@en ;
    rdfs:comment "Ticket initiated by an automated monitoring system."@en .

# Trouble Ticket Urgency
ex:TroubleTicketUrgencyScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the urgency of trouble tickets."@en .

ex:ImmediateIntervention
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketUrgencyScheme ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action."@en .

# Trouble Ticket Category
ex:TroubleTicketCategoryScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the category of trouble tickets."@en .

ex:NetworkOutageCategory
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketCategoryScheme ;
    rdfs:label "Network Outage"@en ;
    rdfs:comment "Category for issues related to network connectivity loss."@en .

ex:ApplicationPerformanceCategory
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketCategoryScheme ;
    rdfs:label "Application Performance Degradation"@en ;
    rdfs:comment "Category for issues related to slow application response."@en .

# Problem Responsibility
ex:ProblemResponsibilityScheme
    a skos:ConceptScheme ;
    rdfs:label "Problem Responsibility Scheme"@en ;
    rdfs:comment "A controlled vocabulary for assigning responsibility for problems."@en .

ex:InternalNetworkTeam
    a skos:Concept ;
    skos:inScheme ex:ProblemResponsibilityScheme ;
    rdfs:label "Internal Network Team"@en ;
    rdfs:comment "Responsibility lies with the internal network operations team."@en .

ex:ApplicationDevelopmentTeam
    a skos:Concept ;
    skos:inScheme ex:ProblemResponsibilityScheme ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Responsibility lies with the application development team."@en .

# Trouble Ticket Note Comment Type
ex:TroubleTicketNoteCommentTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the type of comments in trouble ticket notes."@en .

ex:InternalComment
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketNoteCommentTypeScheme ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team members."@en .

# Trouble Ticket Note Operation Type
ex:TroubleTicketNoteOperationTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the type of operations recorded in trouble ticket notes."@en .

ex:DiagnosisOperation
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketNoteOperationTypeScheme ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Operation related to diagnosing the root cause of an issue."@en .

ex:ResolutionOperation
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketNoteOperationTypeScheme ;
    rdfs:label "Resolution"@en ;
    rdfs:comment "Operation related to resolving the issue."@en .

# Change Request Category
ex:ChangeRequestCategoryScheme
    a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the category of change requests."@en .

ex:SoftwareUpgradeCategory
    a skos:Concept ;
    skos:inScheme ex:ChangeRequestCategoryScheme ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change request for upgrading software versions."@en .

# Change Request Type
ex:ChangeRequestTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the type of change requests."@en .

ex:StandardChange
    a skos:Concept ;
    skos:inScheme ex:ChangeRequestTypeScheme ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk."@en .

# Change Request Cause
ex:ChangeRequestCauseScheme
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the cause of change requests."@en .

ex:PreventativeMaintenanceCause
    a skos:Concept ;
    skos:inScheme ex:ChangeRequestCauseScheme ;
    rdfs:label "Preventative Maintenance"@en ;
    rdfs:comment "Change initiated for preventative maintenance."@en .

# Change Request Status
ex:ChangeRequestStatusScheme
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the status of change requests."@en .

ex:CR_Approved
    a skos:Concept ;
    skos:inScheme ex:ChangeRequestStatusScheme ;
    rdfs:label "Approved"@en ;
    rdfs:comment "Change request has been approved."@en .

ex:CR_Implemented
    a skos:Concept ;
    skos:inScheme ex:ChangeRequestStatusScheme ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "Change request has been successfully implemented."@en .

# Resource Type
ex:ResourceTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of IT resources."@en .

ex:RouterResource
    a skos:Concept ;
    skos:inScheme ex:ResourceTypeScheme ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network device that forwards data packets between computer networks."@en .

ex:SwitchResource
    a skos:Concept ;
    skos:inScheme ex:ResourceTypeScheme ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network device that connects devices in a computer network."@en .

ex:ServerResource
    a skos:Concept ;
    skos:inScheme ex:ResourceTypeScheme ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computer program or a device that provides functionality for other programs or devices."@en .

# Resource Lifecycle State
ex:ResourceLifecycleStateScheme
    a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the lifecycle state of IT resources."@en .

ex:InProductionState
    a skos:Concept ;
    skos:inScheme ex:ResourceLifecycleStateScheme ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Resource is actively used in production environment."@en .

ex:MaintenanceState
    a skos:Concept ;
    skos:inScheme ex:ResourceLifecycleStateScheme ;
    rdfs:label "In Maintenance"@en ;
    rdfs:comment "Resource is currently undergoing maintenance."@en .

# Resource Operational State
ex:ResourceOperationalStateScheme
    a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the operational state of IT resources."@en .

ex:OperationalUp
    a skos:Concept ;
    skos:inScheme ex:ResourceOperationalStateScheme ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource or interface is operational."@en .

ex:OperationalDown
    a skos:Concept ;
    skos:inScheme ex:ResourceOperationalStateScheme ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource or interface is not operational."@en .

# Resource Administrative State
ex:ResourceAdministrativeStateScheme
    a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the administrative state of IT resources."@en .

ex:AdministrativeUp
    a skos:Concept ;
    skos:inScheme ex:ResourceAdministrativeStateScheme ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource or interface is administratively enabled."@en .

ex:AdministrativeDown
    a skos:Concept ;
    skos:inScheme ex:ResourceAdministrativeStateScheme ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource or interface is administratively disabled."@en .

# Notification Severity
ex:NotificationSeverityScheme
    a skos:ConceptScheme ;
    rdfs:label "Notification Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the severity of notifications/alarms."@en .

ex:AlarmCritical
    a skos:Concept ;
    skos:inScheme ex:NotificationSeverityScheme ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Indicates a critical condition requiring immediate attention."@en .

ex:AlarmWarning
    a skos:Concept ;
    skos:inScheme ex:NotificationSeverityScheme ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Indicates a potential problem that may require attention."@en .

# Agent Contact Method
ex:AgentContactMethodScheme
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

ex:EmailContact
    a skos:Concept ;
    skos:inScheme ex:AgentContactMethodScheme ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

ex:PhoneContact
    a skos:Concept ;
    skos:inScheme ex:AgentContactMethodScheme ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# =============================================================================
# Organization and Agents
# =============================================================================

ex:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main corporate entity for Orange."@en ;
    org:hasUnit ex:NetworkOperationsUnit, ex:ApplicationSupportUnit .

ex:NetworkOperationsUnit
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Responsible for managing and maintaining the network infrastructure."@en ;
    org:unitOf ex:OrangeCorp ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:EmailContact ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. For non-critical, email the team alias."^^xsd:string .

ex:ApplicationSupportUnit
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Unit"@en ;
    rdfs:comment "Responsible for supporting business applications."@en ;
    org:unitOf ex:OrangeCorp ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentPreferredContactMethod ex:PhoneContact ;
    noria:agentInstructions "Always call the on-call number for production application issues."^^xsd:string .

ex:AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer in the Network Operations Unit."@en ;
    org:memberOf ex:NetworkOperationsUnit ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:EmailContact ;
    noria:agentInstructions "Email for routine requests, call for urgent matters."^^xsd:string .

ex:BobJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead Application Support Engineer."@en ;
    org:memberOf ex:ApplicationSupportUnit ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+33987654321" ;
    noria:agentWorkingHours "On-call rotation"^^xsd:string ;
    noria:agentPreferredContactMethod ex:PhoneContact ;
    noria:agentInstructions "Primary contact for CRM system issues."^^xsd:string .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    observable:accountLogin "asmith" ;
    observable:accountIdentifier "CUID-ASMITH-001" ;
    foaf:holdsAccount ex:AliceSmith .

ex:BobCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    observable:accountLogin "bjohnson" ;
    observable:accountIdentifier "CUID-BJOHNSON-001" ;
    foaf:holdsAccount ex:BobJohnson .

# =============================================================================
# Locations
# =============================================================================

ex:ParisDataCenter
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    bot:hasSpace ex:ServerRoomA1 .

ex:ServerRoomA1
    a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace ex:RackLocusR1C1 .

ex:RackLocusR1C1
    a noria:Locus ;
    rdfs:label "Rack Locus R1C1"@en ;
    rdfs:comment "Specific location within Server Room A1 for a server rack."@en ;
    noria:locusLine "R1"^^xsd:string ;
    noria:locusRow "C1"^^xsd:string .

# =============================================================================
# Product Models
# =============================================================================

ex:CiscoISR4KModel
    a noria:ProductModel ;
    rdfs:label "Cisco ISR 4000 Series Router"@en ;
    rdfs:comment "Product model for Cisco Integrated Services Router 4000 series."@en ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:HPProLiantModel
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Server"@en ;
    rdfs:comment "Product model for HP ProLiant DL380 series servers."@en ;
    noria:productManufacturedBy ex:HewlettPackard .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

ex:HewlettPackard
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of servers and IT solutions."@en .

# =============================================================================
# Resources
# =============================================================================

ex:RouterA
    a noria:Resource ;
    rdfs:label "Core Router A"@en ;
    rdfs:comment "A critical network router in the Paris Data Center."@en ;
    noria:resourceLogisticId "LOG-RA-001"^^xsd:string ;
    noria:resourceHostName "router-a.example.com"^^xsd:string ;
    noria:resourceProductModel ex:CiscoISR4KModel ;
    noria:resourceType ex:RouterResource ;
    noria:resourceSerialNumber "CISCO12345"^^xsd:string ;
    noria:resourceUsageState ex:InProductionState ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:RackLocusR1C1 ;
    noria:resourceManagedBy ex:NetworkOperationsUnit ;
    noria:resourceManagementIPAddress <http://192.168.10.1> .

ex:SwitchB
    a noria:Resource ;
    rdfs:label "Distribution Switch B"@en ;
    rdfs:comment "A distribution layer switch connected to Router A."@en ;
    noria:resourceLogisticId "LOG-SB-002"^^xsd:string ;
    noria:resourceHostName "switch-b.example.com"^^xsd:string ;
    noria:resourceProductModel ex:CiscoISR4KModel ; # Assuming Cisco also makes switches, or I could add another product model
    noria:resourceType ex:SwitchResource ;
    noria:resourceSerialNumber "CISCO67890"^^xsd:string ;
    noria:resourceUsageState ex:InProductionState ;
    noria:locatedAtLocus ex:RackLocusR1C1 ;
    noria:resourceManagedBy ex:NetworkOperationsUnit ;
    noria:resourceManagementIPAddress <http://192.168.10.2> .

ex:CRMServer01
    a noria:Resource ;
    rdfs:label "CRM Application Server 01"@en ;
