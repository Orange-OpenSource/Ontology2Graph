    noria:troubleTicketRelatedResource ex:RouterA ;
    noria:troubleTicketRelatedService ex:CustomerDataService ;
    noria:troubleTicketTrigger ex:Event_RouterA_InterfaceDown ;
    noria:documentStatusHistory ex:Event_TT_StatusChange_InProgress, ex:Event_TT_StatusChange_Resolved .

ex:Event_TT_StatusChange_InProgress
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket Status Change to InProgress"@en ;
