    noria:documentHRef <http://itsm.example.com/tickets/TT-20240420-001> ;
    noria:troubleTicketSeverity ex:SeverityCritical ;
    noria:troubleTicketType ex:FailureType ;
    noria:troubleTicketPriority ex:PriorityP1 ;
    noria:troubleTicketOrigin ex:SupervisionOrigin ;
    noria:troubleTicketUrgency ex:ImmediateIntervention ;
