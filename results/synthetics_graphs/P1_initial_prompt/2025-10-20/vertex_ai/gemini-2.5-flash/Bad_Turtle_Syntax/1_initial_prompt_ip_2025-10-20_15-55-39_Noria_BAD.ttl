    rdfs:label "Major Severity"@en ;
    rdfs:comment "Alarm severity: Major, significant impact, requires prompt attention."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<kos/TroubleTicket/severity/Blocking>
