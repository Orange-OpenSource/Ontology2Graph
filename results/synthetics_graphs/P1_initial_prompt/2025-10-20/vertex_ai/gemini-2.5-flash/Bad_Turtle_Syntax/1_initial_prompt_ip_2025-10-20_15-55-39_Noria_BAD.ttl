# =============================================================================
# SKOS Concept Schemes
# =============================================================================

<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    dcterms:title "Agent Contact Method"@en ;
    dcterms:description "A controlled vocabulary for preferred contact methods for agents."@en .

<kos/Resource/type>
    a skos:ConceptScheme ;
    dcterms:title "Resource Type"@en ;
    dcterms:description "A controlled vocabulary for types of IT resources."@en .

<kos/Resource/LifecycleState>
    a skos:ConceptScheme ;
    dcterms:title "Resource Lifecycle State"@en ;
    dcterms:description "A controlled vocabulary for the lifecycle states of IT resources."@en .

<kos/NetworkInterface/type>
    a skos:ConceptScheme ;
    dcterms:title "Network Interface Type"@en ;
    dcterms:description "A controlled vocabulary for types of network interfaces."@en .

<kos/Resource/AdministrativeState>
    a skos:ConceptScheme ;
    dcterms:title "Resource Administrative State"@en ;
    dcterms:description "A controlled vocabulary for the administrative states of IT resources or interfaces."@en .

<kos/Resource/OperationalState>
    a skos:ConceptScheme ;
    dcterms:title "Resource Operational State"@en ;
    dcterms:description "A controlled vocabulary for the operational states of IT resources or interfaces."@en .

<kos/application/type>
    a skos:ConceptScheme ;
    dcterms:title "Application Type"@en ;
    dcterms:description "A controlled vocabulary for types of applications."@en .

<kos/application/business-importance>
    a skos:ConceptScheme ;
    dcterms:title "Application Business Importance"@en ;
    dcterms:description "A controlled vocabulary for the business importance of applications."@en .

<https://w3id.org/noria/kos/application/sla-level>
    a skos:ConceptScheme ;
    dcterms:title "Application SLA Level"@en ;
    dcterms:description "A controlled vocabulary for Service Level Agreement levels of applications."@en .

<https://w3id.org/noria/kos/application/status>
    a skos:ConceptScheme ;
    dcterms:title "Application Status"@en ;
    dcterms:description "A controlled vocabulary for the operational status of application modules."@en .

<kos/service/type>
    a skos:ConceptScheme ;
    dcterms:title "Service Type"@en ;
    dcterms:description "A controlled vocabulary for types of services."@en .

<Notification/Severity/PerceivedSeverity>
    a skos:ConceptScheme ;
    dcterms:title "Perceived Severity"@en ;
    dcterms:description "A controlled vocabulary for the perceived severity of alarms."@en .

<kos/TroubleTicket/severity>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Severity"@en ;
    dcterms:description "A controlled vocabulary for the severity levels of trouble tickets."@en .

<kos/TroubleTicket/type>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Type"@en ;
    dcterms:description "A controlled vocabulary for the types of trouble tickets."@en .

<kos/TroubleTicket/priority>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Priority"@en ;
    dcterms:description "A controlled vocabulary for the priority levels of trouble tickets."@en .

<kos/TroubleTicket/origin>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Origin"@en ;
    dcterms:description "A controlled vocabulary for the origin of trouble tickets."@en .

<kos/TroubleTicket/urgency>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Urgency"@en ;
    dcterms:description "A controlled vocabulary for the urgency levels of trouble tickets."@en .

<kos/TroubleTicket/trouble-category>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Category"@en ;
    dcterms:description "A controlled vocabulary for the categories of trouble tickets."@en .

<kos/TroubleTicket/status>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Status"@en ;
    dcterms:description "A controlled vocabulary for the status of trouble tickets."@en .

<kos/TroubleTicket/commentType>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Comment Type"@en ;
    dcterms:description "A controlled vocabulary for the types of comments in trouble ticket notes."@en .

<kos/TroubleTicket/operationType>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Operation Type"@en ;
    dcterms:description "A controlled vocabulary for the types of operations recorded in trouble ticket notes."@en .

<kos/ChangeRequest/category>
    a skos:ConceptScheme ;
    dcterms:title "Change Request Category"@en ;
    dcterms:description "A controlled vocabulary for the categories of change requests."@en .

<kos/ChangeRequest/type>
    a skos:ConceptScheme ;
    dcterms:title "Change Request Type"@en ;
    dcterms:description "A controlled vocabulary for the types of change requests."@en .

<kos/ChangeRequest/cause>
    a skos:ConceptScheme ;
    dcterms:title "Change Request Cause"@en ;
    dcterms:description "A controlled vocabulary for the causes of change requests."@en .

<kos/ChangeRequest/status>
    a skos:ConceptScheme ;
    dcterms:title "Change Request Status"@en ;
    dcterms:description "A controlled vocabulary for the status of change requests."@en .

