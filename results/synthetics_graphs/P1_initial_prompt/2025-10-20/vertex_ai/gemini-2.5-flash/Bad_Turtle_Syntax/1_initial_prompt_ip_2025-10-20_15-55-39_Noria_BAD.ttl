    a noria:TroubleTicket ;
    rdfs:label "Customer Portal Unreachable Incident"@en ;
    rdfs:comment "Trouble ticket opened due to the Customer Portal being unreachable, triggered by a router interface down event."@en ;
    dcterms:created "2024-03-15T09:10:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-2024-001"^^xsd:string ;
    noria:documentHRef <http://ticketing.techcorp.com/INC-2024-001> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Blocking> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger ex:RouterInterfaceDownEvent ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "MonitoringSystemApp"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Core router interface went down, impacting network connectivity to web servers."^^xsd:string ;
    noria:troubleTicketDetectionDateTime "2024-03-15T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty ex:NetOpsTeam, ex:AppSupportTeam ;
    noria:troubleTicketRelatedService ex:E-commerceService ;
    noria:troubleTicketRelatedResource ex:CoreRouter01, ex:WebSrv01 ;
    dcterms:hasPart ex:TT20240315-001-Note1, ex:NetworkDiagramPDF .

ex:TT20240315-001-Note1
    a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket Note for INC-2024-001"@en ;
    rdfs:comment "Initial diagnosis note for the Customer Portal Unreachable incident."@en ;
    dcterms:created "2024-03-15T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator ex:AliceSmith ;
    dcterms:description "Confirmed CoreRouter01 Gi0/1 is down. Attempting to bring up interface. Customer impact confirmed."^^xsd:string ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

