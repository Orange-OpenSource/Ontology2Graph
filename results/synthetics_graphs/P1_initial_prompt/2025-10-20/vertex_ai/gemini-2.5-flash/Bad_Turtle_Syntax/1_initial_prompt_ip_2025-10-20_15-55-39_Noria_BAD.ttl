<kos/application/business-importance/Critical>
    a skos:Concept ;
    rdfs:label "Critical Business Importance"@en ;
    rdfs:comment "Business importance: Critical, high impact on business if unavailable."@en ;
    skos:inScheme <kos/application/business-importance> .

<https://w3id.org/noria/kos/application/sla-level/Platinum>
    a skos:Concept ;
    rdfs:label "Platinum SLA Level"@en ;
    rdfs:comment "Service Level Agreement: Platinum tier, highest priority."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<https://w3id.org/noria/kos/application/sla-level/Bronze>
    a skos:Concept ;
    rdfs:label "Bronze SLA Level"@en ;
    rdfs:comment "Service Level Agreement: Bronze tier, lowest priority."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<https://w3id.org/noria/kos/application/status/InProduction>
    a skos:Concept ;
    rdfs:label "In Production Status"@en ;
    rdfs:comment "Application module status: Currently live in production."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/status/Development>
    a skos:Concept ;
