<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    rdfs:label "Priority 1 (P1)"@en ;
    rdfs:comment "Trouble ticket priority: Highest priority, critical impact."@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/origin/Supervision>
    a skos:Concept ;
    rdfs:label "Origin: Supervision"@en ;
