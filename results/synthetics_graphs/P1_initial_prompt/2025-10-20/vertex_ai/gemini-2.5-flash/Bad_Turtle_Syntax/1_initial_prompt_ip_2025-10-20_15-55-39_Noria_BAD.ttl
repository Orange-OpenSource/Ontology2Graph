ex:RouterInterfaceRecoveryPlan
    a noria:OperationPlan ;
    rdfs:label "Router Interface Recovery Plan"@en ;
    rdfs:comment "Standard operating procedure for recovering a downed router interface."@en ;
    noria:operationPlanPreCondition ex:InterfaceDownPreCondition ;
    noria:operationPlanPostCondition ex:InterfaceUpPostCondition .

ex:DBPatchingProcedure
    a noria:OperationPlan ;
    rdfs:label "Database Patching Procedure"@en ;
    rdfs:comment "Standard operating procedure for applying OS patches to database servers."@en ;
    noria:operationPlanPreCondition ex:DBPatchPreCondition ;
    noria:operationPlanPostCondition ex:DBPatchPostCondition .

ex:InterfaceDownPreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition: A critical network interface is reported as 'down'."@en .

ex:InterfaceUpPostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-Condition"@en ;
    rdfs:comment "Expected outcome: The network interface is successfully brought back 'up' and traffic is flowing."@en .

ex:DBPatchPreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Database Patching Pre-Condition"@en ;
    rdfs:comment "Condition: Database server is in maintenance window and backups are verified."@en .

ex:DBPatchPostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Database Patching Post-Condition"@en ;
    rdfs:comment "Expected outcome: Database server OS is patched, services are restarted, and application connectivity is verified."@en .

ex:NetworkCongestionAnomaly
    a noria:AnomalyPattern ;
    rdfs:label "Network Congestion Anomaly Pattern"@en ;
    rdfs:comment "A pattern indicating network congestion, characterized by high interface utilization and packet drops."@en ;
    folio:hasCause "High traffic volume or misconfiguration"^^xsd:string .
