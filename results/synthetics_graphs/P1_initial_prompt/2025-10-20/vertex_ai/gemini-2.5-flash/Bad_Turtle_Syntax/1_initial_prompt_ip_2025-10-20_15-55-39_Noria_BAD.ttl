# =============================================================================
# Organizational Entities
# =============================================================================

ex:TechCorp
    a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "The main organization operating the IT infrastructure and services."@en ;
    org:hasUnit ex:NetOpsTeam, ex:AppSupportTeam, ex:SecurityTeam .

ex:NetOpsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical network issues, use the dedicated hotline."^^xsd:string ;
    org:hasMember ex:AliceSmith .

ex:AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting critical business applications."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Pager> ;
    noria:agentInstructions "Escalate via ticketing system for L2 support."^^xsd:string ;
    org:hasMember ex:BobJohnson .

ex:SecurityTeam
    a org:OrganizationalUnit ;
    rdfs:label "Cyber Security Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 SOC Coverage"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SecureChat> ;
    noria:agentInstructions "All security alerts must be reported immediately."^^xsd:string ;
    org:hasMember ex:CharlieBrown .

ex:AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, member of the Network Operations Team."@en ;
    foaf:mbox <mailto:alice.smith@techcorp.com> ;
    foaf:holdsAccount ex:AliceCUid ;
    noria:agentManagesResource ex:CoreRouter01, ex:EdgeSwitch01 .

ex:BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead Application Support Engineer, member of the Application Support Team."@en ;
    foaf:mbox <mailto:bob.johnson@techcorp.com> ;
    foaf:holdsAccount ex:BobCUid ;
    noria:agentManagesResource ex:WebSrv01, ex:DBServer01 .

ex:CharlieBrown
    a foaf:Person ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Security Analyst, member of the Cyber Security Operations Center."@en ;
    foaf:mbox <mailto:charlie.brown@techcorp.com> ;
    foaf:holdsAccount ex:CharlieCUid .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within TechCorp's IT systems."@en ;
    foaf:accountName "asmith"@en ;
    observable:accountIdentifier "asmith-12345"@en .

ex:BobCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Bob Johnson within TechCorp's IT systems."@en ;
    foaf:accountName "bjohnson"@en ;
    observable:accountIdentifier "bjohnson-67890"@en .

ex:CharlieCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Charlie Brown's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Charlie Brown within TechCorp's IT systems."@en ;
    foaf:accountName "cbrown"@en ;
    observable:accountIdentifier "cbrown-54321"@en .

# =============================================================================
# Location Entities
# =============================================================================

ex:MainDataCenter
    a bot:Site ;
    rdfs:label "TechCorp Main Data Center"@en ;
    rdfs:comment "The primary data center facility for TechCorp's operations."@en ;
    noria:siteId "DC-MIA-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Way"@en ;
    noria:sitePrincipalAddressCityName "Miami"@en ;
    noria:sitePrincipalAddressPostalCode "33101"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    bot:containsZone ex:ServerRoomA .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A specific server room within the Main Data Center."@en ;
    bot:containsZone ex:Rack12Locus .

ex:Rack12Locus
    a noria:Locus ;
    rdfs:label "Rack 12 Location"@en ;
    rdfs:comment "Specific location within Server Room A, corresponding to Rack 12."@en ;
    noria:locusLine "L"^^xsd:string ;
    noria:locusRow "12"^^xsd:string .

# =============================================================================
# Infrastructure Entities (Product Models, Resources, Network Interfaces, Links)
# =============================================================================

ex:HewlettPackardEnterprise
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

ex:HPProLiantDL380
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Product model for HP ProLiant DL380 Gen10 servers."@en ;
    noria:productManufacturedBy ex:HewlettPackardEnterprise .

ex:CiscoCatalyst9k
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300 Series"@en ;
    rdfs:comment "Product model for Cisco Catalyst 9300 series switches."@en ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server hosting the Customer Portal application."@en ;
    noria:resourceHostName "websrv01.techcorp.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-WS01-2023"^^xsd:string ;
    noria:resourceProductModel ex:HPProLiantDL380 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WS01-XYZ"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalApp ;
    noria:locatedAtLocus ex:Rack12Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> ;
    noria:resourceManagedBy ex:AppSupportTeam .

ex:DBServer01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Database server supporting the Customer Portal application."@en ;
    noria:resourceHostName "dbserver01.techcorp.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-DB01-2023"^^xsd:string ;
    noria:resourceProductModel ex:HPProLiantDL380 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB01-ABC"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalApp ;
    noria:locatedAtLocus ex:Rack12Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.11> ;
    noria:resourceManagedBy ex:AppSupportTeam .

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the data center network."@en ;
    noria:resourceHostName "corerouter01.techcorp.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-CR01-2022"^^xsd:string ;
    noria:resourceProductModel ex:CiscoCatalyst9k ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR01-DEF"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack12Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> ;
    noria:resourceManagedBy ex:NetOpsTeam .

ex:EdgeSwitch01
    a noria:Resource ;
    rdfs:label "Edge Switch 01"@en ;
    rdfs:comment "Edge switch connecting servers to the core network."@en ;
    noria:resourceHostName "edgeswitch01.techcorp.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-ES01-2022"^^xsd:string ;
    noria:resourceProductModel ex:CiscoCatalyst9k ;
    noria:resourceType <kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-ES01-GHI"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T09:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack12Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.2> ;
    noria:resourceManagedBy ex:NetOpsTeam .

ex:WebSrv01Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface on Web Server 01."@en ;
    noria:networkInterfaceOf ex:WebSrv01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects ex:LinkWebDB .

ex:DBServer01Eth0
    a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface on Database Server 01."@en ;
    noria:networkInterfaceOf ex:DBServer01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects ex:LinkWebDB .

ex:CoreRouter01Gi0_1
    a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 01, connected to the Edge Switch."@en ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
