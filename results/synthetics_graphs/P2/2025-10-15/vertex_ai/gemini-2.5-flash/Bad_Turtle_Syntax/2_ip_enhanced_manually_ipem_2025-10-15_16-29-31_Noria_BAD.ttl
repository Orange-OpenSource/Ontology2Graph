noria:Service/E2ECustomerService
    a noria:Service ;
    rdfs:label "End-to-End Customer Service"@en ;
    rdfs:comment "An end-to-end service encompassing customer portal and billing."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule/CustomerPortal_Prod ; # Service composed of application modules
    seas:subSystemOf noria:ApplicationModule/BillingService_Dev . # Example of a service using a dev module for testing

noria:Service/InternalNetworkService
    a noria:Service ;
    rdfs:label "Internal Network Connectivity Service"@en ;
    rdfs:comment "Service providing internal network connectivity for applications."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Resource/Router01 ;
    seas:subSystemOf noria:Resource/Server05 .

noria:Resource/Server05 noria:resourceForApplication noria:Application/CustomerPortal .
noria:Resource/VirtualMachine01 noria:resourceForApplication noria:Application/BillingService .

