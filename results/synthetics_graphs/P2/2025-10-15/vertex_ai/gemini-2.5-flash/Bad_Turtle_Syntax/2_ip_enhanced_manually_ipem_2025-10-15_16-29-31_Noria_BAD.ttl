# --- Organizational Entities (foaf:Agent, org:Organization, org:OrganizationalUnit, noria:CorporateUserIdentifier) ---

foaf:Person/john.doe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee of the organization."@en ;
    foaf:name "John Doe"^^xsd:string ;
    foaf:mbox "john.doe@example.com"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string .

foaf:Person/jane.smith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Another employee, team lead."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    foaf:mbox "jane.smith@example.com"^^xsd:string ;
    noria:agentWorkingHours "08:30-17:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call directly for urgent issues."^^xsd:string .

org:Organization/OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company."@en ;
    dcterms:identifier "ORG-001"^^xsd:string .

