# --- Agents and Organizations ---

:Org_IT_Operations
    a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The main IT operations department responsible for infrastructure."@en ;
    noria:agentWorkingHours "08:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for all issues."^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
.

:Org_Network_Team
    a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team managing network infrastructure."@en ;
    org:unitOf :Org_IT_Operations ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentInstructions "For critical network issues, use emergency hotline."^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
.

:Org_App_Support
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    org:unitOf :Org_IT_Operations ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Submit a ticket for application-related problems."^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
.

:Person_Alice_Smith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer Lead."@en ;
    foaf:mbox "mailto:alice.smith@example.com"^^xsd:anyURI ;
    org:memberOf :Org_Network_Team ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Direct contact for team escalations."^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
.

:Person_Bob_Johnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    foaf:mbox "mailto:bob.johnson@example.com"^^xsd:anyURI ;
    org:memberOf :Org_App_Support ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Available via internal chat for quick queries."^^xsd:string ;
