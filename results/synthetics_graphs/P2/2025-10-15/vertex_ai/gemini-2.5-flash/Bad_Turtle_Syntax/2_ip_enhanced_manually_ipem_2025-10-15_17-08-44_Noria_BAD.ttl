    rdfs:label "Standard Router Software Upgrade Procedure"@en ;
    rdfs:comment "A documented procedure for upgrading router software."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_RouterReadyForUpgrade ;
    noria:operationPlanPostCondition :ActionPostCondition_RouterUpgradeSuccess ;
.

:OperationPlan_DBPatch
    a noria:OperationPlan ;
    rdfs:label "Database Patching Procedure"@en ;
    rdfs:comment "A documented procedure for applying patches to database servers."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_DBBackupComplete ;
    noria:operationPlanPostCondition :ActionPostCondition_DBServiceRestored ;
.

:OperationPlan_QueryOptimization
    a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_PerformanceIssueConfirmed ;
    noria:operationPlanPostCondition :ActionPostCondition_PerformanceRestored ;
.

:AnomalyPattern_HighCPU_DB
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Anomaly Pattern on DB Server"@en ;
    rdfs:comment "Pattern indicating unusually high CPU usage on database servers, potentially leading to performance issues."@en ;
    folio:hasCause "Excessive query load or inefficient queries"^^xsd:string ;
    folio:hasEffect "Database performance degradation, application slowdown"^^xsd:string ;
.

