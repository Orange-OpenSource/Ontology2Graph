# Core Organizational Entities
noria-data:Org_OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "A major telecommunications company."@en ;
    noria:elementDistinguishedName "OrangeTelecom"^^xsd:string .

noria-data:OrgUnit_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and managing network infrastructure."@en ;
    org:unitOf noria-data:Org_OrangeTelecom ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Contact via internal ticketing system for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Phone ;
    noria:elementDistinguishedName "NetworkOps"^^xsd:string .

noria-data:OrgUnit_AppSupport
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for various applications."@en ;
    org:unitOf noria-data:Org_OrangeTelecom ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00"^^xsd:string ;
    noria:agentInstructions "Email for non-critical issues, phone for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:elementDistinguishedName "AppSupport"^^xsd:string .

noria-data:OrgUnit_SecurityTeam
    a org:OrganizationalUnit ;
    rdfs:label "Cyber Security Operations"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    org:unitOf noria-data:Org_OrangeTelecom ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Use dedicated security incident platform."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:elementDistinguishedName "SecurityTeam"^^xsd:string .

noria-data:Agent_AliceSmith
    a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, Team Lead for Network Operations."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00"^^xsd:string ;
    noria:agentInstructions "Escalate to Alice for P1 network incidents."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Phone ;
    noria:elementDistinguishedName "AliceSmith"^^xsd:string .

noria-data:Agent_BobJohnson
    a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer, part of Application Support."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00"^^xsd:string ;
    noria:agentInstructions "Bob handles database-related application issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:elementDistinguishedName "BobJohnson"^^xsd:string .

noria-data:Agent_CharlieBrown
    a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Junior Network Engineer."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00"^^xsd:string ;
    noria:agentInstructions "Contact Charlie for routine network checks."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:ContactMethod_Email ;
    noria:elementDistinguishedName "CharlieBrown"^^xsd:string .

noria-data:CorporateUserIdentifier_Alice
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Unique corporate identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    foaf:holdsAccount noria-data:Agent_AliceSmith ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "CU-ASMITH-001"^^xsd:string ;
    noria:elementDistinguishedName "CU-ASMITH-001"^^xsd:string .

noria-data:CorporateUserIdentifier_Bob
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Unique corporate identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    foaf:holdsAccount noria-data:Agent_BobJohnson ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "CU-BJOHNS-002"^^xsd:string ;
    noria:elementDistinguishedName "CU-BJOHNS-002"^^xsd:string .

# Location Entities
noria-data:Site_ParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string ;
    noria:elementDistinguishedName "DC-PAR-01"^^xsd:string .

noria-data:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room within the Paris Data Center."@en ;
    bot:hasSpace noria-data:Site_ParisDC ;
    noria:elementDistinguishedName "SR-PAR-A"^^xsd:string .

noria-data:Locus_Rack12A
    a noria:Locus ;
    rdfs:label "Rack 12A in Server Room A"@en ;
    rdfs:comment "Specific location for equipment in Server Room A."@en ;
    bot:hasSpace noria-data:Room_ServerRoomA ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "12"^^xsd:string ;
    noria:elementDistinguishedName "LOC-R12A"^^xsd:string .

noria-data:Locus_Rack15B
    a noria:Locus ;
    rdfs:label "Rack 15B in Server Room A"@en ;
    rdfs:comment "Another specific location for equipment in Server Room A."@en ;
    bot:hasSpace noria-data:Room_ServerRoomA ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "15"^^xsd:string ;
    noria:elementDistinguishedName "LOC-R15B"^^xsd:string .

