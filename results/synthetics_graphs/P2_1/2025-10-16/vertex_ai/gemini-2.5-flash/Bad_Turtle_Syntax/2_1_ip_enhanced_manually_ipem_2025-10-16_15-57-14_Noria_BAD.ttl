    .

# Loci
noria:locus/DC_A_R101_Rack_A1
    a noria:Locus ;
    rdfs:label "Rack A1 in Data Center A - Room 101"@en ;
    rdfs:comment "Specific location for equipment within Room 101, Data Center A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasZone noria:room/DataCenter_A_Room_101 ;
    .

noria:locus/Office_B_Closet_Shelf_2
    a noria:Locus ;
    rdfs:label "Shelf 2 in Office B - Server Closet"@en ;
    rdfs:comment "Location for small servers on Shelf 2 in Office B's server closet."@en ;
    noria:locusLine "Shelf"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:hasZone noria:room/Office_B_Server_Closet ;
    .

# Sites (bot:Site)
bot:site/DataCenter_A
    a bot:Site ;
