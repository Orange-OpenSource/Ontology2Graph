# Organizational Units and Agents
org:unit/AdminTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Admin Team"@en ;
    rdfs:comment "Team responsible for administration of applications."@en ;
    noria:agentManagesResource noria:resource/Router_Core_01 ;
    noria:agentManagesResource noria:resource/VM_CRM_DB ;
    .

org:unit/SupportL2
    a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support Team"@en ;
    rdfs:comment "Team providing second-level technical support."@en ;
    .

org:unit/SupportL1
    a org:OrganizationalUnit ;
    rdfs:label "Level 1 Support Group"@en ;
    rdfs:comment "First point of contact for user support."@en ;
    .

org:unit/Hotline
    a org:OrganizationalUnit ;
    rdfs:label "Hotline Support Group"@en ;
    rdfs:comment "Dedicated team for urgent issues."@en ;
    .

org:company/Cisco
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Leading networking hardware manufacturer."@en ;
    .

org:company/Dell
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company."@en ;
    .

foaf:person/john.doe
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Employee in the IT department."@en ;
    foaf:accountName "john.doe"@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    .

foaf:person/jane.smith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Employee in the IT department."@en ;
    foaf:accountName "jane.smith"@en ;
    noria:agentWorkingHours "8:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    .

foaf:person/alice.wonder
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Wonder"@en ;
    rdfs:comment "Leader of the Application Admin Team."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    .

foaf:person/bob.builder
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Builder"@en ;
    rdfs:comment "Leader of the Level 2 Support Team."@en ;
    noria:agentWorkingHours "8:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    .

foaf:person/charlie.chaplin
    a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Chaplin"@en ;
    rdfs:comment "Initiator of the OS upgrade change request."@en ;
    .

foaf:person/diana.prince
    a foaf:Person, foaf:Agent ;
    rdfs:label "Diana Prince"@en ;
    rdfs:comment "Pilot for the OS upgrade change request."@en ;
    .

foaf:person/eve.adams
    a foaf:Person, foaf:Agent ;
