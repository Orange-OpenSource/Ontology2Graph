# Procedure Execution Containers and Procedures (PEP)
noria:procedureExecutionContainer/FixNetworkIssue
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Network Issue Fix Execution"@en ;
    rdfs:comment "Container for actions taken to resolve a network issue."@en ;
    .

noria:procedure/RestartInterface
    a pep:Procedure ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a network interface."@en ;
    .

noria:procedureExecution/FiberRepairExecution
    a pep:ProcedureExecution ;
    rdfs:label "Fiber Repair Execution"@en ;
    rdfs:comment "Execution of the fiber repair procedure."@en ;
    pep:usedProcedure noria:procedure/RestartInterface ;
    pep:hasInput "Fiber cut detected"^^xsd:string ;
    pep:hasOutput "Fiber repaired, link restored"^^xsd:string ;
    .

noria:procedureExecutionContainer/FixNetworkIssue
    pep:member noria:procedureExecution/FiberRepairExecution ;
    .

noria:procedureExecution/OSUpgradeExecution
    a pep:ProcedureExecution ;
    rdfs:label "OS Upgrade Execution"@en ;
    rdfs:comment "Execution of the OS upgrade procedure on Web Server 01."@en ;
    pep:usedProcedure noria:operationPlan/ApplySecurityPatch ;
    pep:hasInput "Web Server 01 requires OS patch"^^xsd:string ;
    pep:hasOutput "OS patched, server rebooted successfully"^^xsd:string ;
    .

