# Corporate User Identifiers
noria:cuid/john.doe
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for employee John Doe within the organization."@en ;
    foaf:accountName "john.doe"@en ;
    .

noria:cuid/jane.smith
    a noria:CorporateUserIdentifier ;
