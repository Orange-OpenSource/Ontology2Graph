# Applications
noria:application/CRM_Suite
    a noria:Application ;
    rdfs:label "CRM Suite Application"@en ;
    rdfs:comment "Core application for managing customer relationships and sales processes."@en ;
    noria:applicationModelIdentifier "CRM-2023-A"@en ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CRM_S"@en ;
    noria:applicationFunctionalDomain "Market and Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Customer Data Management"@en ;
    noria:applicationType <kos/application/type/CRM> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    .

noria:application/NetworkMonitor
    a noria:Application ;
    rdfs:label "Network Monitoring Application"@en ;
    rdfs:comment "Application for real-time monitoring of network devices and services."@en ;
    noria:applicationModelIdentifier "NMS-v3.1"@en ;
    noria:applicationNumericalIdentifier "2005"^^xsd:int ;
    noria:applicationShortIdentifier "NetMon"@en ;
    noria:applicationFunctionalDomain "Resource Development, Management and Operations"@en ;
    noria:applicationFunctionalSubDomain "Network Performance Monitoring"@en ;
    noria:applicationType <kos/application/type/Monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Medium> ;
    .

# Application Modules
noria:applicationModule/CRM_Prod
    a noria:ApplicationModule ;
    rdfs:label "CRM Production Module"@en ;
    rdfs:comment "Production instance of the CRM Suite application."@en ;
    noria:applicationModuleOf noria:application/CRM_Suite ;
    noria:applicationModuleName "CRM_S_PROD"@en ;
    noria:applicationModuleIdentifier "CRM-PROD-01"^^xsd:string ;
    noria:applicationModuleAdministrationTeam org:unit/AdminTeam ;
    noria:applicationModuleAdministrationLeader foaf:person/alice.wonder ;
    noria:applicationModuleSupportTeam org:unit/SupportL2 ;
    noria:applicationModuleSupportLeader foaf:person/bob.builder ;
    noria:applicationModuleSupportGroup org:unit/SupportL1 ;
    noria:applicationModuleHotlineGroup org:unit/Hotline ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-15T09:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Production> ;
    .

noria:applicationModule/NetMon_Dev
    a noria:ApplicationModule ;
    rdfs:label "Network Monitor Development Module"@en ;
    rdfs:comment "Development instance of the Network Monitoring application."@en ;
    noria:applicationModuleOf noria:application/NetworkMonitor ;
    noria:applicationModuleName "NetMon_DEV"@en ;
    noria:applicationModuleIdentifier "NMS-DEV-01"^^xsd:string ;
    noria:applicationModuleAdministrationTeam org:unit/AdminTeam ;
    noria:applicationModuleAdministrationLeader foaf:person/alice.wonder ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Silver> ;
    noria:applicationModuleSlaLevelDate "2023-03-01T10:30:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "false"^^xsd:boolean ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    .

# Services
noria:service/CustomerInternetAccess
    a noria:Service ;
    rdfs:label "Customer Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity to end customers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:applicationModule/CRM_Prod ;
    .

noria:service/InternalVPN
    a noria:Service ;
    rdfs:label "Internal VPN Service"@en ;
    rdfs:comment "Secure VPN access for internal employees."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    .

# Rooms
noria:room/DataCenter_A_Room_101
    a noria:Room ;
    rdfs:label "Data Center A - Room 101"@en ;
    rdfs:comment "Main server room in Data Center A."@en ;
    .

noria:room/Office_B_Server_Closet
    a noria:Room ;
    rdfs:label "Office B - Server Closet"@en ;
