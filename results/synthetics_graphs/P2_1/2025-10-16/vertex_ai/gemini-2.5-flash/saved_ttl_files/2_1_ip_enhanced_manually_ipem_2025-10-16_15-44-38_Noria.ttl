# --- Agents and Organizations ---

<agent/john_doe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A senior network engineer responsible for core infrastructure."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for routine issues, direct call for critical incidents."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    .

<agent/jane_smith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead application support specialist for the CRM system."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use internal chat for urgent matters, otherwise email."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    .

<org/network_operations>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for the maintenance and monitoring of the network infrastructure."@en ;
    org:unitOf <org/example_corp> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "Follow incident response plan for all network alerts."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Pager> ;
    noria:agentManagesResource <resource/core_router_01> ;
    .

<org/application_support_l2>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support team for critical business applications."@en ;
    org:unitOf <org/example_corp> ;
    noria:agentWorkingHours "08:00-20:00 (Mon-Sun)"^^xsd:string ;
    noria:agentInstructions "Escalate to L3 for unresolved issues after 4 hours."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    .

<org/example_corp>
    a org:Organization ;
    rdfs:label "Example Corporation"@en ;
    rdfs:comment "A leading telecommunications provider."@en ;
    .

<org/vendor_tech_solutions>
    a org:Organization ;
    rdfs:label "Vendor Tech Solutions Inc."@en ;
    rdfs:comment "Manufacturer of high-performance network equipment."@en ;
    .

# --- Location Elements ---

<site/datacenter_paris>
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "Data Center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Republique"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Republique"^^xsd:string ;
    bot:hasSpace <room/server_room_a> ;
    .

<room/server_room_a>
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasZone <locus/rack_a1_u1> ;
    .

<locus/rack_a1_u1>
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 1"@en ;
    rdfs:comment "Specific location within Server Room A for a network device."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "U1"^^xsd:string ;
    .

<locus/rack_b2_u5>
    a noria:Locus ;
    rdfs:label "Rack B2, Unit 5"@en ;
    rdfs:comment "Specific location within Server Room A for a virtual server host."@en ;
    noria:locusLine "B2"^^xsd:string ;
    noria:locusRow "U5"^^xsd:string ;
    .

