# --- Event Records ---

<eventrecord/router_interface_down_20240320>
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Critical alert indicating a network interface on Core Router 01 went down."@en ;
    noria:logOriginatingManagedObject <resource/core_router_01> ;
    noria:logOriginatingManagementSystem <application/monitoring_platform> ;
    noria:logOriginatingAgent <agent/john_doe> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."^^xsd:string ;
    noria:loggingTime "2024-03-20T10:30:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <operationplan/interface_troubleshooting> ;
    noria:alarmMitigatedBy <pep/execution_interface_reset_success> ;
    .

<eventrecord/vm_cpu_spike_20240320>
    a noria:EventRecord ;
    rdfs:label "VM CPU Spike Warning"@en ;
    rdfs:comment "Warning alert for high CPU utilization on CRM Database VM."@en ;
    noria:logOriginatingManagedObject <resource/virtual_machine_crm_db> ;
    noria:logOriginatingManagementSystem <application/monitoring_platform> ;
    noria:logText "CPU utilization on crmdb01 exceeded 90% for 5 minutes."^^xsd:string ;
    noria:loggingTime "2024-03-20T11:45:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmMonitoredAttribute <property/cpu_utilization> ;
    .

<eventrecord/tt_freeze_20240320_001>
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Event"@en ;
    rdfs:comment "Event marking a freeze period for TT-20240320-001 due to external dependency."@en ;
    noria:loggingTime "2024-03-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Ticket frozen awaiting ISP A technician arrival."^^xsd:string ;
    .

<eventrecord/tt_status_change_inprogress>
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket Status Change to InProgress"@en ;
    rdfs:comment "Event recording the status change of TT-20240320-001 to InProgress."@en ;
    noria:loggingTime "2024-03-20T10:35:00Z"^^xsd:dateTime ;
    noria:logText "Status changed from Initialised to InProgress."^^xsd:string ;
    .

<eventrecord/cr_status_change_completed>
    a noria:EventRecord ;
