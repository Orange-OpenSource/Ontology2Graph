# --- Operation Plans ---

<operationplan/interface_troubleshooting>
    a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    noria:operationPlanPreCondition <actionprecondition/interface_down_alert> ;
    noria:operationPlanPostCondition <actionpostcondition/interface_restored> ;
    .

<operationplan/crm_db_optimization>
    a noria:OperationPlan ;
    rdfs:label "CRM DB Performance Optimization"@en ;
    rdfs:comment "Procedure to optimize CRM database performance in case of high load."@en ;
    noria:operationPlanPreCondition <actionprecondition/high_cpu_load> ;
    noria:operationPlanPostCondition <actionpostcondition/cpu_load_normalized> ;
    .

# --- Action Pre/Post Conditions ---

<actionprecondition/interface_down_alert>
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Alert Received"@en ;
