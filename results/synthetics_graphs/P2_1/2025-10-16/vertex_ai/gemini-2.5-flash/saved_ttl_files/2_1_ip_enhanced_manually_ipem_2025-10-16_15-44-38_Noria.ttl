# --- Network Interfaces ---

<networkinterface/cr01_ge0_0_1>
    a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"@en ;
    rdfs:comment "Uplink interface for core router to external network."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-1"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int ;
    noria:networkInterfaceDescription "Uplink to ISP A"^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceOf <resource/core_router_01> ;
    noria:networkInterfaceConnects <networklink/isp_a_uplink> ;
    .

<networkinterface/vh01_eth0>
    a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Virtual Host 01"@en ;
    rdfs:comment "Management interface for the virtual host."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Management Network"^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceOf <resource/virtual_host_01> ;
    .

