    .

<actionpostcondition/interface_restored>
    a noria:ActionPostCondition ;
    rdfs:label "Interface Operational Status Up"@en ;
    rdfs:comment "Outcome: The network interface's operational status is reported as 'Up'."@en ;
    .

<actionprecondition/high_cpu_load>
