    rdfs:label "High CPU Load on Database Server"@en ;
    rdfs:comment "Condition: CPU utilization on the database server exceeds 90% for a sustained period."@en ;
    .

<actionpostcondition/cpu_load_normalized>
    a noria:ActionPostCondition ;
    rdfs:label "CPU Load Normalized"@en ;
    rdfs:comment "Outcome: CPU utilization on the database server has returned to normal levels (below 70%)."@en ;
    .

