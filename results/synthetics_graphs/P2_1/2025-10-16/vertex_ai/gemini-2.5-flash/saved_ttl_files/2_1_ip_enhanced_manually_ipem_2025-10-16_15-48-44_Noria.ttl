    noria:applicationFunctionalSubDomain "Performance Monitoring"^^xsd:string ;
    noria:applicationType <kos/application/type/MonitoringSystem> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
.

noria:app_module_CustomerPortal_Prod
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "The production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf noria:app_CustomerPortal ;
    noria:applicationModuleName "CPORTAL_PROD"^^xsd:string ;
