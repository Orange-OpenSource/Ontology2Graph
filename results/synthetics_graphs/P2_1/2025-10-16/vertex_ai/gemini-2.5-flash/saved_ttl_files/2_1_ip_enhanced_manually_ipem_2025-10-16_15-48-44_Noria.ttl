# --- Organizational Entities ---
noria:org_OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company."@en ;
    org:hasUnit noria:team_DevOps_Core ;
    org:hasUnit noria:team_NOC_L2 ;
.

noria:team_DevOps_Core
    a org:OrganizationalUnit ;
    rdfs:label "DevOps Core Team"@en ;
    rdfs:comment "Team responsible for core application development and operations."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal ticketing system for non-critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

noria:team_NOC_L2
    a org:OrganizationalUnit ;
    rdfs:label "NOC L2 Support Team"@en ;
    rdfs:comment "Network Operations Center Level 2 Support Team, handling critical network incidents."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Call emergency hotline for P1 incidents."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

noria:agent_Alice
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead DevOps Engineer for Customer Portal."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Email for general queries, direct message for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    foaf:member noria:team_DevOps_Core ;
.

noria:agent_Bob
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Network Engineer, NOC L2."@en ;
    noria:agentWorkingHours "Shift-based (24/7)"^^xsd:string ;
    noria:agentInstructions "On-call for network incidents."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    foaf:member noria:team_NOC_L2 ;
.

noria:cuid_alice_devops
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice's Corporate ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within the organization."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    foaf:holdsAccount noria:agent_Alice ;
.

# --- Location Entities ---
noria:datacenter_paris
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center location in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Republique"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Republique"^^xsd:string ;
    bot:containsZone noria:server_room_A01 ;
.

noria:server_room_A01
    a noria:Room ;
    rdfs:label "Server Room A01"@en ;
    rdfs:comment "A dedicated server room within the Paris Data Center."@en ;
    bot:hasSpace noria:rack_R12_U42 ;
.

noria:rack_R12_U42
    a noria:Locus ;
    rdfs:label "Rack R12, Unit 42"@en ;
    rdfs:comment "Specific location within Server Room A01 for a physical server."@en ;
    noria:locusLine "R12"^^xsd:string ;
    noria:locusRow "U42"^^xsd:string ;
    bot:containedIn noria:server_room_A01 ;
.

# --- Product Models ---
noria:model_Cisco_ASR9K
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series"@en ;
    rdfs:comment "High-end router series from Cisco."@en ;
    noria:productManufacturedBy <https://www.cisco.com/organization> ;
.

noria:model_Dell_PowerEdge
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell PowerEdge R740 rack server model."@en ;
    noria:productManufacturedBy <https://www.dell.com/organization> ;
.

# --- Resources ---
noria:router_edge_01
    a noria:Resource ;
    rdfs:label "Edge Router 01"@en ;
    rdfs:comment "Main edge router for the Paris Data Center."@en ;
    noria:resourceLogisticId "LOG-RTR-PAR-01"^^xsd:string ;
    noria:resourceHostName "rtr-edge-par01"^^xsd:string ;
    noria:resourceSerialNumber "CISCO12345ABC"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://www.example.com/ip/10.0.0.1> ;
    noria:resourceManagedBy noria:team_NOC_L2 ;
    noria:resourceProductModel noria:model_Cisco_ASR9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus noria:rack_R12_U42 ;
    noria:resourceForApplication noria:app_CustomerPortal ;
    noria:clusterController noria:router_core_01 ;
.

noria:router_core_01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Core router managing network traffic within the data center."@en ;
    noria:resourceHostName "rtr-core-par01"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy noria:team_NOC_L2 ;
.

noria:server_web_01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Physical server hosting virtual machines for the Customer Portal."@en ;
    noria:resourceLogisticId "LOG-SRV-WEB-01"^^xsd:string ;
    noria:resourceHostName "srv-web-par01"^^xsd:string ;
    noria:resourceSerialNumber "DELL67890XYZ"^^xsd:string ;
    noria:resourceInstallationDate "2023-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://www.example.com/ip/10.0.0.10> ;
    noria:resourceManagedBy noria:team_DevOps_Core ;
    noria:resourceProductModel noria:model_Dell_PowerEdge ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus noria:rack_R12_U42 ;
    noria:resourceForApplication noria:app_CustomerPortal ;
.

noria:vm_portal_prod_01
    a noria:Resource ;
    rdfs:label "Customer Portal VM Prod 01"@en ;
    rdfs:comment "Virtual machine running a production instance of the Customer Portal."@en ;
    noria:resourceHostName "vm-portal-prod-01"^^xsd:string ;
    noria:resourceSerialNumber "VM-UUID-12345"^^xsd:string ;
    noria:resourceInstallationDate "2023-05-10T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://www.example.com/ip/10.0.1.100> ;
    noria:resourceManagedBy noria:team_DevOps_Core ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> ;
    noria:resourceForApplication noria:app_CustomerPortal ;
.

# --- Network Interfaces ---
noria:ni_router_edge_01_ge001
    a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Edge Router 01"@en ;
    rdfs:comment "Physical interface connecting Edge Router 01 to the core network."@en ;
    noria:networkInterfaceDescription "Uplink to Core Network"^^xsd:string ;
    noria:networkInterfaceType <http://www.example.com/kos/networkInterfaceType/physical> ;
    noria:networkInterfaceOf noria:router_edge_01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int ;
    noria:structuralObservableOf noria:router_edge_01 ;
.

noria:ni_server_web_01_eth0
    a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Web Server 01"@en ;
    rdfs:comment "Network interface for Web Server 01."@en ;
    noria:networkInterfaceDescription "Main network interface for VM traffic"^^xsd:string ;
    noria:networkInterfaceType <http://www.example.com/kos/networkInterfaceType/virtual> ;
    noria:networkInterfaceOf noria:server_web_01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:structuralObservableOf noria:server_web_01 ;
.

# --- Network Links ---
noria:link_router_server_fiber
    a noria:NetworkLink ;
    rdfs:label "Fiber Link between Edge Router and Web Server"@en ;
    rdfs:comment "High-speed fiber optic link connecting the edge router to the web server."@en ;
    noria:networkLinkId "LINK-PAR-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 10Gbps"^^xsd:string ;
    noria:networkLinkTerminationResource noria:router_edge_01 ;
    noria:networkLinkTerminationResource noria:server_web_01 ;
    noria:networkLinkTerminationResourceOrigin noria:router_edge_01 ;
    noria:networkLinkTerminationResourceDestination noria:server_web_01 ;
    noria:networkInterfaceConnects noria:ni_router_edge_01_ge001 ;
.

# --- Applications and Services ---
noria:app_CustomerPortal
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "The main web application for customer interaction."@en ;
