    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
.

noria:app_module_CustomerPortal_Dev
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en ;
    rdfs:comment "The development instance of the Customer Portal application."@en ;
    noria:applicationModuleOf noria:app_CustomerPortal ;
    noria:applicationModuleName "CPORTAL_DEV"^^xsd:string ;
