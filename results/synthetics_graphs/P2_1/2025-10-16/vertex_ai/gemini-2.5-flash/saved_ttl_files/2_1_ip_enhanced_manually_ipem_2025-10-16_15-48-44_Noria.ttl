.

noria:service_WebAccess
    a noria:Service ;
    rdfs:label "Customer Web Access Service"@en ;
    rdfs:comment "End-to-end service providing customer access to the portal."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:app_module_CustomerPortal_Prod ;
.

# --- Event Records ---
noria:event_router_down
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
