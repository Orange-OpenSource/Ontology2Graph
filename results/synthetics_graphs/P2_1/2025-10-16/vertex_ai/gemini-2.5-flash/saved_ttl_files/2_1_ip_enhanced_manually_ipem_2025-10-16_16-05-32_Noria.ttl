# =============================================================================
# Agent and Organization related entities
# =============================================================================

org:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation"^^xsd:string ;
    rdfs:comment "The main telecommunications company."^^xsd:string ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via official channels for all inquiries."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

org:NetworkOperationsUnit
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"^^xsd:string ;
    rdfs:comment "A unit responsible for managing network infrastructure."^^xsd:string ;
    org:unitOf org:OrangeCorp ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Use emergency hotline for critical incidents."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

org:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"^^xsd:string ;
    rdfs:comment "Team dedicated to supporting critical business applications."^^xsd:string ;
    org:unitOf org:OrangeCorp ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"^^xsd:string ;
    noria:agentInstructions "Submit a ticket via the ITSM portal."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

foaf:JohnDoe
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"^^xsd:string ;
    rdfs:comment "A network engineer in the Network Operations Unit."^^xsd:string ;
    org:memberOf org:NetworkOperationsUnit ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Reach out via internal chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

foaf:JaneSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"^^xsd:string ;
    rdfs:comment "Lead of the Application Support Team."^^xsd:string ;
    org:memberOf org:ApplicationSupportTeam ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "For escalations, contact directly."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

noria:JohnDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"^^xsd:string ;
    rdfs:comment "Unique identifier for John Doe within the corporate IT system."^^xsd:string ;
    foaf:accountName "jdoe_netops"^^xsd:string ;
    foaf:holdsAccount foaf:JohnDoe ;
.

# =============================================================================
# Location related entities
# =============================================================================

bot:DataCenterParis
    a bot:Site ;
    rdfs:label "Paris Data Center"^^xsd:string ;
    rdfs:comment "Primary data center located in Paris."^^xsd:string ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string ;
.

noria:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"^^xsd:string ;
    rdfs:comment "A dedicated server room within the Paris Data Center."^^xsd:string ;
    bot:hasSpace bot:DataCenterParis ; # Assuming bot:hasSpace can link a Room to a Site
.

noria:RackL06
    a noria:Locus ;
    rdfs:label "Rack L06 in Server Room A"^^xsd:string ;
    rdfs:comment "Specific location for equipment within Server Room A."^^xsd:string ;
    noria:locusLine "L"^^xsd:string ;
    noria:locusRow "06"^^xsd:string ;
    bot:hasSpace noria:ServerRoomA ; # Assuming bot:hasSpace can link a Locus to a Room
.

# =============================================================================
# Structural elements: Resources, Network Interfaces, Network Links
# =============================================================================

noria:CiscoRouterModel
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9000 Series"^^xsd:string ;
    rdfs:comment "Product model for Cisco Catalyst 9000 series routers."^^xsd:string ;
    noria:productManufacturedBy <https://www.cisco.com/organization> ; # Dummy URI for Cisco
.

noria:DellServerModel
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"^^xsd:string ;
    rdfs:comment "Product model for Dell PowerEdge R740 servers."^^xsd:string ;
    noria:productManufacturedBy <https://www.dell.com/organization> ; # Dummy URI for Dell
.

noria:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"^^xsd:string ;
    rdfs:comment "A critical core network router in the Paris Data Center."^^xsd:string ;
    noria:resourceLogisticId "CR01-PAR-DC"^^xsd:string ;
    noria:resourceHostName "router-core-01.paris.noria.net"^^xsd:string ;
    noria:resourceProductModel noria:CiscoRouterModel ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "ABC12345DEF"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkOperationsUnit ;
    noria:locatedAtLocus noria:RackL06 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> ; # Dummy URI for IP address
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> ; # Example usage, even if it's a physical router
.

noria:WebServer01
    a noria:Resource ;
    rdfs:label "Web Server 01"^^xsd:string ;
    rdfs:comment "Server hosting the main web application."^^xsd:string ;
    noria:resourceLogisticId "WS01-PAR-DC"^^xsd:string ;
    noria:resourceHostName "web-server-01.paris.noria.net"^^xsd:string ;
    noria:resourceProductModel noria:DellServerModel ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "GHI67890JKL"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:ApplicationSupportTeam ;
    noria:locatedAtLocus noria:RackL06 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> ;
.

noria:ClusterController01
    a noria:Resource ;
    rdfs:label "Cluster Controller 01"^^xsd:string ;
    rdfs:comment "Manages the Kubernetes cluster for web services."^^xsd:string ;
    noria:resourceHostName "k8s-ctrl-01.paris.noria.net"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy org:ApplicationSupportTeam ;
.

noria:WebServer02
    a noria:Resource ;
    rdfs:label "Web Server 02"^^xsd:string ;
    rdfs:comment "Another server in the web application cluster."^^xsd:string ;
    noria:resourceHostName "web-server-02.paris.noria.net"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy org:ApplicationSupportTeam ;
    noria:clusterController noria:ClusterController01 ;
.

noria:RouterInterfaceGE0_0_1
    a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"^^xsd:string ;
    rdfs:comment "Uplink interface for Core Router 01."^^xsd:string ;
    noria:networkInterfaceOf noria:CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to ISP A"^^xsd:string ;
    noria:networkInterfaceType <http://example.com/kos/networkInterfaceType/Physical> ; # Dummy URI for networkInterfaceType
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int ;
.

noria:ServerInterfaceETH0
    a noria:NetworkInterface ;
    rdfs:label "eth0 on Web Server 01"^^xsd:string ;
    rdfs:comment "Primary network interface for Web Server 01."^^xsd:string ;
    noria:networkInterfaceOf noria:WebServer01 ;
    noria:networkInterfaceDescription "Main network interface"^^xsd:string ;
    noria:networkInterfaceType <http://example.com/kos/networkInterfaceType/Virtual> ; # Dummy URI
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
.

noria:WANLinkParisLondon
    a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-London"^^xsd:string ;
    rdfs:comment "High-capacity WAN link connecting Paris and London data centers."^^xsd:string ;
    noria:networkLinkId "WAN-PL-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2021-06-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Optical Fiber"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria:CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination <http://example.com/resource/LondonCoreRouter01> ; # Dummy URI for remote router
