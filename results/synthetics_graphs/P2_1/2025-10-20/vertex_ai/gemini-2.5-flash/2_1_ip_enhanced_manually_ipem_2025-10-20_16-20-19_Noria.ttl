<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:prefLabel "Email Contact Method"@en ;
    skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ;
.

# --- Organizational Entities ---

<Agent/JohnDoe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A fictional employee responsible for network operations."@en ;
    foaf:name "John Doe"^^xsd:string ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

<Agent/JaneSmith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A fictional employee leading the application development team."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

<OrgUnit/NetworkOperations>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf <Org/GlobalITSolutions> ;
    org:hasMember <Agent/JohnDoe> ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentInstructions "For critical issues, call the hotline."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

<OrgUnit/ApplicationDevelopment>
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core applications."@en ;
    org:unitOf <Org/GlobalITSolutions> ;
    org:hasMember <Agent/JaneSmith> ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit change requests via the portal."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

<Org/GlobalITSolutions>
    a org:Organization ;
    rdfs:label "Global IT Solutions Inc."@en ;
    rdfs:comment "The main IT organization."@en ;
    org:hasUnit <OrgUnit/NetworkOperations> , <OrgUnit/ApplicationDevelopment> ;
.

<Org/CiscoSystems>
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en ;
.

<Org/DellTechnologies>
    a org:Organization ;
    rdfs:label "Dell Technologies Inc."@en ;
    rdfs:comment "Manufacturer of computer hardware."@en ;
.

# --- Location Entities ---

<Site/MainDataCenter>
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for critical infrastructure."@en ;
    noria:siteId "DC-MIA-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "33101"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Miami"^^xsd:string ;
    noria:sitePrincipalAddressCountry "USA"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string ;
.

<Room/ServerRoomA>
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A secure room within the Main Data Center housing critical servers."@en ;
    bot:hasSpace <Locus/Rack12A> ;
    bot:hasElement <Resource/WebServer01> ;
.

<Locus/Rack12A>
    a noria:Locus ;
    rdfs:label "Rack 12A"@en ;
    rdfs:comment "Specific rack location within Server Room A."@en ;
    noria:locusLine "L"^^xsd:string ;
    noria:locusRow "12"^^xsd:string ;
    bot:hasElement <Resource/WebServer01> ;
.

# --- Product Model ---

<ProductModel/CiscoRouter3800>
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 3800 Series Router"@en ;
    rdfs:comment "Product model for a high-performance network router."@en ;
    noria:productManufacturedBy <Org/CiscoSystems> ;
.

<ProductModel/DellPowerEdgeR740>
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740 Server"@en ;
    rdfs:comment "Product model for a versatile 2U rack server."@en ;
    noria:productManufacturedBy <Org/DellTechnologies> ;
.

# --- Structural Elements ---

<Resource/Router01>
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary router for the corporate network."@en ;
    noria:resourceLogisticId "RTR-COR-001-SN456789"^^xsd:string ;
    noria:resourceHostName "router01.example.com"^^xsd:string ;
    noria:resourceProductModel <ProductModel/CiscoRouter3800> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN456789ABC"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <OrgUnit/NetworkOperations> ;
    noria:agentManagesResource <Agent/JohnDoe> ;
    noria:resourceManagementIPAddress <observable:IPAddress/192.168.1.1> ;
    noria:clusterController <Resource/ClusterController01> ;
    noria:locatedAtLocus <Locus/Rack12A> ;
    noria:resourceForApplication <Application/NetworkMonitoring> ;
.

<Resource/WebServer01>
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Server hosting the main web application."@en ;
    noria:resourceLogisticId "SRV-WEB-001-SN123456"^^xsd:string ;
    noria:resourceHostName "webserver01.example.com"^^xsd:string ;
    noria:resourceProductModel <ProductModel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN123456XYZ"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <OrgUnit/ApplicationDevelopment> ;
    noria:agentManagesResource <Agent/JaneSmith> ;
    noria:resourceManagementIPAddress <observable:IPAddress/10.0.0.10> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> ;
.

<Resource/ClusterController01>
    a noria:Resource ;
    rdfs:label "Cluster Controller 01"@en ;
    rdfs:comment "Manages a cluster of resources."@en ;
    noria:resourceHostName "cluster-ctrl01.example.com"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy <OrgUnit/NetworkOperations> ;
.

<observable:IPAddress/192.168.1.1>
    a observable:IPAddress ;
    rdfs:label "IP Address 192.168.1.1"@en ;
    observable:ipAddressValue "192.168.1.1"^^xsd:string ;
.

<observable:IPAddress/10.0.0.10>
    a observable:IPAddress ;
    rdfs:label "IP Address 10.0.0.10"@en ;
    observable:ipAddressValue "10.0.0.10"^^xsd:string ;
.

<NetworkInterface/Router01-Eth0>
    a noria:NetworkInterface ;
    rdfs:label "Router01 Ethernet 0/0/0"@en ;
    rdfs:comment "Main uplink interface for Router01."@en ;
    noria:networkInterfaceOf <Resource/Router01> ;
    noria:networkInterfaceDescription "Uplink to ISP A"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int ;
.

<NetworkInterface/WebServer01-Eth0>
    a noria:NetworkInterface ;
    rdfs:label "WebServer01 Ethernet 0"@en ;
    rdfs:comment "Network interface for WebServer01."@en ;
    noria:networkInterfaceOf <Resource/WebServer01> ;
    noria:networkInterfaceDescription "Connection to internal LAN"^^xsd:string ;
    noria:networkInterfaceType "virtual"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
.

<NetworkLink/Link-R01-W01>
    a noria:NetworkLink ;
    rdfs:label "Link between Router01 and WebServer01"@en ;
    rdfs:comment "Logical link connecting the core router to the web server."@en ;
    noria:networkLinkId "NL-R01-W01-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:networkLinkTerminationResource <Resource/Router01> , <Resource/WebServer01> ;
    noria:networkLinkTerminationResourceOrigin <Resource/Router01> ;
    noria:networkLinkTerminationResourceDestination <Resource/WebServer01> ;
    noria:networkInterfaceConnects <NetworkInterface/Router01-Eth0> ;
.

# --- Functional Elements ---

<Application/WebAppService>
    a noria:Application ;
    rdfs:label "Customer Web Application Service"@en ;
    rdfs:comment "The main web application providing services to customers."@en ;
    noria:applicationModelIdentifier "CWA-V1.0"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CWA"^^xsd:string ;
    noria:applicationType <kos/application/type/Web> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Online Portal Management"^^xsd:string ;
    noria:elementManagedBy <OrgUnit/ApplicationDevelopment> ;
.

<Application/NetworkMonitoring>
    a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "Application for monitoring network health and performance."@en ;
    noria:applicationModelIdentifier "NMS-V2.5"^^xsd:string ;
    noria:applicationNumericalIdentifier "2002"^^xsd:int ;
    noria:applicationShortIdentifier "NMS"^^xsd:string ;
    noria:applicationType <kos/application/type/Database> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Medium> ;
    noria:applicationFunctionalDomain "IT Operations Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Network Performance Monitoring"^^xsd:string ;
    noria:elementManagedBy <OrgUnit/NetworkOperations> ;
.

<ApplicationModule/WebAppService-Prod>
    a noria:ApplicationModule ;
    rdfs:label "Customer Web App Production Module"@en ;
    rdfs:comment "Production instance of the Customer Web Application Service."@en ;
    noria:applicationModuleOf <Application/WebAppService> ;
    noria:applicationModuleName "CWA_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-001"^^xsd:string ;
    noria:applicationModuleAdministrationTeam <OrgUnit/ApplicationDevelopment> ;
    noria:applicationModuleAdministrationLeader <Agent/JaneSmith> ;
    noria:applicationModuleSupportTeam <OrgUnit/NetworkOperations> ;
    noria:applicationModuleSupportLeader <Agent/JohnDoe> ;
    noria:applicationModuleSupportGroup <OrgUnit/NetworkOperations> ;
    noria:applicationModuleHotlineGroup <OrgUnit/NetworkOperations> ;
    noria:applicationModuleSlaLevel <kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleStatus <kos/application/status/Production> ;
.

<Service/CustomerFacingPortal>
    a noria:Service ;
    rdfs:label "Customer Facing Portal Service"@en ;
    rdfs:comment "End-to-end service for customer interactions, composed of multiple application modules."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <ApplicationModule/WebAppService-Prod> ;
    noria:elementManagedBy <OrgUnit/ApplicationDevelopment> ;
.

# --- Dynamic Elements (Documentation & Events) ---

<Property/Router01Eth0OperationalStatus>
    a noria:StructuralObservable ;
    rdfs:label "Router01 Eth0 Operational Status Property"@en ;
    rdfs:comment "Represents the operational status property of Router01's Ethernet 0/0/0 interface."@en ;
    noria:structuralElementObservable <NetworkInterface/Router01-Eth0> ;
    noria:structuralObservableOf <NetworkInterface/Router01-Eth0> ;
    noria:structuralElementObservableData "up"^^xsd:string ;
.

<EventRecord/RouterDownAlarm>
    a noria:EventRecord ;
    rdfs:label "Router01 Down Alarm"@en ;
    rdfs:comment "Critical alarm indicating Router01's main interface went down."@en ;
    noria:loggingTime "2024-03-25T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject <Resource/Router01> ;
    noria:logOriginatingManagementSystem <Application/NetworkMonitoring> ;
    noria:logOriginatingAgent <Agent/JohnDoe> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction <OperationPlan/RouterInterfaceTroubleshoot> ;
    noria:alarmMonitoredAttribute <Property/Router01Eth0OperationalStatus> ;
    noria:alarmMitigatedBy <ProcedureExecutionContainer/RouterRepairExecution> ;
.

<EventRecord/WebServerLogEntry>
    a noria:EventRecord ;
    rdfs:label "Web Server Access Log"@en ;
    rdfs:comment "A log entry from the web server indicating a successful access."@en ;
    noria:loggingTime "2024-03-25T10:10:30Z"^^xsd:dateTime ;
    noria:logText "GET /index.html HTTP/1.1 200 OK"^^xsd:string ;
    noria:logOriginatingManagedObject <Resource/WebServer01> ;
    noria:logOriginatingManagementSystem <Application/WebAppService> ;
    noria:logOriginatingAgent <Agent/JaneSmith> ;
.

<EventRecord/InterventionLog1>
    a noria:EventRecord ;
    rdfs:label "Intervention Log for TT-2024-001"@en ;
    rdfs:comment "Log entry detailing an intervention related to TT-2024-001."@en ;
    noria:loggingTime "2024-03-25T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Network team dispatched to site for fiber repair."^^xsd:string ;
    noria:logOriginatingAgent <Agent/JohnDoe> ;
    noria:logOriginatingManagedObject <Resource/Router01> ;
    noria:logOriginatingManagementSystem <Application/NetworkMonitoring> ;
.

<EventRecord/FreezeLog1>
    a noria:EventRecord ;
    rdfs:label "Freeze Log for TT-2024-001"@en ;
    rdfs:comment "Log entry indicating a freeze period for TT-2024-001."@en ;
    noria:loggingTime "2024-03-25T12:00:00Z"^^xsd:dateTime ;
    noria:logText "Trouble ticket frozen due to external dependency."^^xsd:string ;
    noria:logOriginatingManagedObject <Resource/Router01> ;
    noria:logOriginatingManagementSystem <Application/NetworkMonitoring> ;
.

<EventRecord/StatusChangeLog1>
    a noria:EventRecord ;
    rdfs:label "Status Change Log for TT-2024-001"@en ;
    rdfs:comment "Log entry for status change of TT-2024-001."@en ;
    noria:loggingTime "2024-03-25T10:06:00Z"^^xsd:dateTime ;
    noria:logText "Status changed from 'New' to 'InProgress'."^^xsd:string ;
    noria:logOriginatingManagedObject <Resource/Router01> ;
    noria:logOriginatingManagementSystem <Application/NetworkMonitoring> ;
.

<EventRecord/CRStatusLog1>
    a noria:EventRecord ;
    rdfs:label "CR-2024-005 Status Change Log"@en ;
    rdfs:comment "Log entry for status change of CR-2024-005."@en ;
    noria:loggingTime "2024-04-05T09:00:00Z"^^xsd:dateTime ;
    noria:logText "Change Request approved for execution."^^xsd:string ;
    noria:logOriginatingManagedObject <Resource/Router01> ;
    noria:logOriginatingManagementSystem <Application/NetworkMonitoring> ;
    noria:logOriginatingAgent <Agent/JohnDoe> ;
.

<EventRecord/RouterUpLog>
    a noria:EventRecord ;
    rdfs:label "Router01 Interface Up Log"@en ;
    rdfs:comment "Log entry indicating Router01's main interface came back up after repair."@en ;
    noria:loggingTime "2024-03-25T13:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to up"^^xsd:string ;
    noria:logOriginatingManagedObject <Resource/Router01> ;
    noria:logOriginatingManagementSystem <Application/NetworkMonitoring> ;
    noria:logOriginatingAgent <Agent/JohnDoe> ;
.

<TroubleTicket/TT-2024-001>
    a noria:TroubleTicket ;
    rdfs:label "Network Outage on Router01"@en ;
    rdfs:comment "Trouble ticket opened due to critical network outage detected on Router01."@en ;
