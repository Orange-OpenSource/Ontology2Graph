    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> ;
.

<kos/TroubleTicket/trouble-category/NetworkOutage>
    a skos:Concept ;
    skos:prefLabel "Network Outage Category"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> ;
.

<kos/TroubleTicket/problemResponsibility/NetworkTeam>
    a skos:Concept ;
    skos:prefLabel "Network Team Responsibility"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> ;
.

<kos/TroubleTicket/status/InProgress>
    a skos:Concept ;
    skos:prefLabel "In Progress Status"@en ;
