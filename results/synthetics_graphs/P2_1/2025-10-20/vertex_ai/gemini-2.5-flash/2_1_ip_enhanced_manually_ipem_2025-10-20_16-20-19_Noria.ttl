@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/data/> .

# --- Helper KOS Concepts (not part of the schema, but needed for ranges) ---
# These concepts are created to satisfy the rdfs:range restrictions on various ObjectProperties
# that point to skos:Concept within specific skos:inScheme.

<kos/application/type/Web>
    a skos:Concept ;
    skos:prefLabel "Web Application Type"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
.

<kos/application/type/Database>
    a skos:Concept ;
    skos:prefLabel "Database Application Type"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
.

<kos/application/business-importance/High>
    a skos:Concept ;
    skos:prefLabel "High Business Importance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
.

<kos/application/business-importance/Medium>
    a skos:Concept ;
    skos:prefLabel "Medium Business Importance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
.

<kos/application/sla-level/Gold>
    a skos:Concept ;
    skos:prefLabel "Gold SLA Level"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
.

<kos/application/status/Production>
