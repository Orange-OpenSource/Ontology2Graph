# --- External Class Instances ---

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe" ;
    rdfs:comment "A sample agent, John Doe, an IT engineer." ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "A sample agent, Jane Smith, a network administrator." ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Always use the ticketing system first."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Phone .

foaf:Agent_AliceJohnson a foaf:Agent ;
    rdfs:label "Alice Johnson" ;
    rdfs:comment "A sample agent, Alice Johnson, an application developer." ;
    noria:agentWorkingHours "10:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use internal chat for quick questions, email for formal requests."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email .

org:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department" ;
    rdfs:comment "The main IT department of the company." .

org:OrgUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Organizational unit responsible for network operations." ;
    noria:agentWorkingHours "24/7 On-call"^^xsd:string ;
    noria:agentInstructions "Escalate to L2 via dedicated hotline."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Phone ;
    noria:agentManagesResource noria:Resource_RouterA ;
    noria:agentManagesResource noria:Resource_Firewall .

org:OrgUnit_AppSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support Team" ;
    rdfs:comment "Organizational unit responsible for application support." ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit tickets through the portal."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email ;
    noria:agentManagesResource noria:Resource_ServerA ;
    noria:agentManagesResource noria:Resource_VirtualServer1 .

org:OrgUnit_SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Security Operations Team" ;
    rdfs:comment "Organizational unit responsible for cybersecurity operations." ;
    noria:agentWorkingHours "24/7 Monitoring"^^xsd:string ;
    noria:agentInstructions "Report all security incidents immediately."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email .

bot:Site_MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center" ;
    rdfs:comment "The primary data center facility." ;
    noria:siteId "DC01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Techville"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

