pep:ProcedureExecutionContainer_CR456Exec a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution Container for CR456" ;
    rdfs:comment "Container for all procedure executions related to Change Request CR456." .

pep:ProcedureExecutionContainer_TT124Exec a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution Container for TT124" ;
    rdfs:comment "Container for all procedure executions related to Trouble Ticket TT124." .

