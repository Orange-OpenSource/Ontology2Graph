# --- foaf:Agent and org:Organization/OrganizationalUnit Instances ---

noria-inst:Agent_JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A key IT operations engineer responsible for network infrastructure."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent issues, otherwise email."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email .

noria-inst:Agent_JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead application support specialist, managing critical business applications."@en ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Always use the ticketing system for tracking, follow up with a call for P1 issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Phone .

noria-inst:Org_ITOperations
    a org:Organization ;
    rdfs:label "Global IT Operations Department"@en ;
    rdfs:comment "The central department overseeing all IT infrastructure and application operations."@en .

noria-inst:OrgUnit_NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team responsible for the design, implementation, and maintenance of the corporate network."@en ;
    noria:agentWorkingHours "24/7 On-Call Rotation"^^xsd:string ;
    noria:agentInstructions "Escalate critical network alerts to the on-call engineer immediately."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Phone ;
    org:unitOf noria-inst:Org_ITOperations .

noria-inst:OrgUnit_AppSupport
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team dedicated to supporting and maintaining business-critical applications."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "All application issues must be logged in the CRM system before any action is taken."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email ;
    org:unitOf noria-inst:Org_ITOperations .

noria-inst:OrgUnit_SecurityTeam
    a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring, detecting, and responding to cybersecurity threats."@en ;
    noria:agentWorkingHours "24/7 SOC Coverage"^^xsd:string ;
    noria:agentInstructions "Any detected intrusion or anomaly must be reported to the SOC lead within 15 minutes."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email ;
    org:unitOf noria-inst:Org_ITOperations .

# --- Location related Instances ---

noria-inst:Site_MainDC
    a bot:Site ;
    rdfs:label "Main Data Center Site"@en ;
    rdfs:comment "The primary data center facility housing critical IT infrastructure."@en ;
    noria:siteId "DC-MIA-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "33101"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Miami"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

noria-inst:Room_ServerHallA
    a noria:Room ;
    rdfs:label "Server Hall A"@en ;
    rdfs:comment "The main server hall within the primary data center, containing numerous racks."@en ;
    bot:hasSpace noria-inst:Locus_RackA12 .

noria-inst:Locus_RackA12
    a noria:Locus ;
    rdfs:label "Rack A12 in Server Hall A"@en ;
    rdfs:comment "Specific location of rack A12 within Server Hall A, used for network equipment."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "12"^^xsd:string .

noria-inst:Room_NOC
    a noria:Room ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "The central monitoring and control room for network operations."@en .

# --- Product Model Instances ---

noria-inst:ProductModel_CiscoNexus9K
    a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch series from Cisco Systems."@en ;
    noria:productManufacturedBy noria-inst:Org_CiscoSystems .

noria-inst:ProductModel_HPProLiantDL380
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Popular enterprise-grade rack server from Hewlett Packard Enterprise."@en ;
    noria:productManufacturedBy noria-inst:Org_HPE .

noria-inst:Org_CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Leading manufacturer of networking hardware and software."@en .

noria-inst:Org_HPE
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Global enterprise IT company specializing in servers, storage, and networking."@en .

# --- Resource Instances ---

noria-inst:Resource_CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router in the data center, handling critical network traffic."@en ;
    noria:resourceLogisticId "LOG-CR01-DC01"^^xsd:string ;
    noria:resourceHostName "cr01.dc01.example.com"^^xsd:string ;
    noria:resourceSerialNumber "ABC12345DEF6"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.1"^^xsd:string ;
    noria:resourceProductModel noria-inst:ProductModel_CiscoNexus9K ;
    noria:resourceType noria-kos:Resource/type/Router ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/InProduction ;
    noria:resourceManagedBy noria-inst:OrgUnit_NetworkTeam ;
    noria:locatedAtLocus noria-inst:Locus_RackA12 ;
    noria:resourceForApplication noria-inst:App_MonitoringPlatform .

noria-inst:Resource_AppServer02
    a noria:Resource ;
    rdfs:label "Application Server 02"@en ;
    rdfs:comment "Server hosting the CRM application backend services."@en ;
    noria:resourceLogisticId "LOG-AS02-DC01"^^xsd:string ;
    noria:resourceHostName "appserver02.dc01.example.com"^^xsd:string ;
    noria:resourceSerialNumber "GHI78901JKL2"^^xsd:string ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.10"^^xsd:string ;
    noria:resourceProductModel noria-inst:ProductModel_HPProLiantDL380 ;
    noria:resourceType noria-kos:Resource/type/Server ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/InProduction ;
    noria:resourceManagedBy noria-inst:OrgUnit_AppSupport ;
    noria:locatedAtLocus noria-inst:Locus_RackA12 ;
    noria:resourceForApplication noria-inst:App_CRMSystem ;
    noria:clusterController noria-inst:Resource_VirtualizationHost05 .

noria-inst:Resource_Firewall03
    a noria:Resource ;
    rdfs:label "Perimeter Firewall 03"@en ;
    rdfs:comment "Security appliance protecting the data center perimeter."@en ;
    noria:resourceLogisticId "LOG-FW03-DC01"^^xsd:string ;
    noria:resourceHostName "fw03.dc01.example.com"^^xsd:string ;
    noria:resourceSerialNumber "MNO34567PQR8"^^xsd:string ;
    noria:resourceInstallationDate "2021-09-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.5"^^xsd:string ;
    noria:resourceProductModel noria-inst:ProductModel_CiscoNexus9K ; # Reusing for example
    noria:resourceType noria-kos:Resource/type/Router ; # Using router type as a proxy for network appliance
    noria:resourceUsageState noria-kos:Resource/LifecycleState/InProduction ;
    noria:resourceManagedBy noria-inst:OrgUnit_SecurityTeam ;
    noria:locatedAtLocus noria-inst:Locus_RackA12 .

noria-inst:Resource_VirtualizationHost05
    a noria:Resource ;
    rdfs:label "Virtualization Host 05"@en ;
    rdfs:comment "Host server managing virtual machines, including application servers."@en ;
    noria:resourceLogisticId "LOG-VH05-DC01"^^xsd:string ;
    noria:resourceHostName "vh05.dc01.example.com"^^xsd:string ;
    noria:resourceSerialNumber "STU90123VWX4"^^xsd:string ;
    noria:resourceInstallationDate "2023-01-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.20"^^xsd:string ;
    noria:resourceProductModel noria-inst:ProductModel_HPProLiantDL380 ;
    noria:resourceType noria-kos:Resource/type/Server ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/InProduction ;
    noria:resourceManagedBy noria-inst:OrgUnit_AppSupport .

# --- Network Interface Instances ---

noria-inst:NI_CoreRouter01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "Core Router 01 Ethernet 0/0/1"@en ;
    rdfs:comment "Physical interface on Core Router 01 connected to the internal network segment."@en ;
    noria:networkInterfaceDescription "Uplink to internal network segment A"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-8"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-7"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-12"^^xsd:int ;
    noria:networkInterfaceAdministrativeStatus noria-kos:Resource/AdministrativeState/Enabled ;
    noria:networkInterfaceOperationalStatus noria-kos:Resource/OperationalState/Up ;
    noria:networkInterfaceOf noria-inst:Resource_CoreRouter01 .

noria-inst:NI_AppServer02_Eth1
    a noria:NetworkInterface ;
    rdfs:label "Application Server 02 Ethernet 1"@en ;
    rdfs:comment "Virtual interface on Application Server 02 for application traffic."@en ;
