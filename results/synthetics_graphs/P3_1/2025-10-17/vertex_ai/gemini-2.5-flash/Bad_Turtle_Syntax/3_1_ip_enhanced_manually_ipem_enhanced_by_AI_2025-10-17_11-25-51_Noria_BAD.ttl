# --- Event Records ---

noria-inst:Event_RouterDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 1 went down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0, changed state to down."^^xsd:string ;
    noria:logOriginatingManagedObject noria-inst:Resource_Router_Core1 ;
    noria:logOriginatingManagementSystem noria-inst:Application_NetworkMonitor ;
    noria:alarmSeverity noria-inst:AlarmSeverity_Critical ;
    noria:alarmProposedRepairAction noria-inst:Procedure_RestartInterface ;
    noria:logOriginatingAgent noria-inst:Group_SecurityIncidentResponse ;
    dcterms:relation noria-inst:Event_HighCPULoad .

noria-inst:Event_DBError a noria:EventRecord ;
    rdfs:label "Database Connection Error Event"@en ;
    rdfs:comment "Log entry indicating a database connection error on DB Server 1."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Database connection pool exhausted for CRM application."^^xsd:string ;
    noria:logOriginatingManagedObject noria-inst:Resource_Server_DB1 ;
    noria:logOriginatingManagementSystem noria-inst:AppMod_CRM_Production ;
    noria:alarmSeverity noria-inst:AlarmSeverity_Major ;
    dcterms:relation noria-inst:Event_LoginAttempt .

noria-inst:Event_LoginAttempt a noria:EventRecord ;
    rdfs:label "Failed Login Attempt Event"@en ;
    rdfs:comment "Security log entry for multiple failed login attempts on a web server."@en ;
    noria:loggingTime "2024-04-20T10:12:00Z"^^xsd:dateTime ;
    noria:logText "Multiple failed login attempts detected for user 'unknown' on web-server-crm-01."^^xsd:string ;
    noria:logOriginatingManagedObject noria-inst:Resource_Server_Web1 ;
    noria:logOriginatingManagementSystem noria-inst:OrgUnit_SecurityOps ;
    noria:alarmSeverity noria-inst:AlarmSeverity_Warning .

noria-inst:Event_TTFreeze_001 a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Event"@en ;
    rdfs:comment "Event indicating a temporary freeze on TT-20240420-001 due to external dependency."@en ;
    noria:loggingTime "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:logText "Trouble ticket frozen awaiting vendor response for hardware replacement."^^xsd:string ;
    noria:logOriginatingManagementSystem noria-inst:AppMod_NMS_Production ;
    noria:alarmSeverity noria-inst:AlarmSeverity_Warning .

noria-inst:Event_CRStatusChange_Approved a noria:EventRecord ;
