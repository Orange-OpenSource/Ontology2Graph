# --- Anomaly Patterns ---

noria-inst:AnomalyPattern_HighCPU_LowTraffic a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Traffic Anomaly Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating a potential network loop or misconfiguration: high CPU utilization on a router with unexpectedly low traffic throughput."@en ;
    folio:hasCause noria-inst:AnomalyCause_NetworkLoop ;
    folio:hasEffect noria-inst:AnomalyEffect_ServiceDegradation .

noria-inst:AnomalyPattern_DBDeadlock a noria:AnomalyPattern ;
    rdfs:label "Database Deadlock Anomaly Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating recurring database deadlocks, leading to application slowdowns or freezes."@en ;
    folio:hasCause noria-inst:AnomalyCause_PoorQueryOptimization ;
    folio:hasEffect noria-inst:AnomalyEffect_ApplicationFreeze .
