# --- Knowledge Organization System (KOS) Concepts ---

noria-inst:AppType_CRM a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Customer Relationship Management Application Type"@en ;
    rdfs:comment "Represents a CRM application type within the NORIA application type taxonomy."@en ;
    skos:prefLabel "CRM Application"@en ;
    skos:altLabel "Customer Relationship Management System"@en .

noria-inst:AppType_ERP a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Enterprise Resource Planning Application Type"@en ;
    rdfs:comment "Represents an ERP application type within the NORIA application type taxonomy."@en .

noria-inst:AppType_Monitoring a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Monitoring Application Type"@en ;
    rdfs:comment "Represents a system monitoring application type within the NORIA application type taxonomy."@en ;
    skos:prefLabel "Monitoring System"@en ;
    skos:altLabel "Observability Platform"@en .

noria-inst:AppType_Database a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Database Application Type"@en ;
    rdfs:comment "Represents a database management system application type."@en .

noria-inst:BizImp_Critical a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "Critical Business Importance"@en ;
    rdfs:comment "Indicates an application is critical for business operations."@en .

noria-inst:BizImp_High a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Indicates an application has high business importance."@en ;
    skos:prefLabel "High Business Impact"@en ;
    skos:altLabel "Tier 2 Criticality"@en .

noria-inst:SLA_Gold a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement tier, ensuring maximum availability and performance."@en ;
    skos:prefLabel "Premium Service Level"@en ;
    skos:altLabel "24/7 Support SLA"@en .

noria-inst:SLA_Silver a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Standard Service Level Agreement tier, offering good availability and performance."@en .

noria-inst:AppModStatus_Production a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production Status"@en ;
    rdfs:comment "The application module is currently live and serving users."@en ;
    skos:prefLabel "Live Environment"@en ;
    skos:altLabel "Operational Status"@en .

noria-inst:AppModStatus_Development a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Development Status"@en ;
    rdfs:comment "The application module is under active development."@en .

noria-inst:ServiceType_CustomerFacing a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by external customers."@en ;
    skos:prefLabel "External Service"@en ;
    skos:altLabel "Public Service"@en .

noria-inst:ServiceType_ResourceFacing a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations, not directly exposed to customers."@en .

noria-inst:TTSeverity_Critical a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Indicates a critical impact on service, requiring immediate attention."@en ;
    skos:prefLabel "Critical Incident Severity"@en ;
    skos:altLabel "Severity 1"@en .

noria-inst:TTSeverity_Major a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Indicates a major impact on service, requiring urgent attention."@en ;
    skos:prefLabel "Major Incident Severity"@en ;
    skos:altLabel "Severity 2"@en .

noria-inst:TTType_Failure a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> ;
    rdfs:label "Failure Ticket Type"@en ;
    rdfs:comment "Trouble ticket type for system failures."@en .

noria-inst:TTType_Assistance a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> ;
    rdfs:label "Assistance Ticket Type"@en ;
    rdfs:comment "Trouble ticket type for user assistance requests."@en ;
    skos:prefLabel "Support Request"@en ;
    skos:altLabel "Helpdesk Ticket"@en .

noria-inst:TTCriticity_InterruptedService a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/category> ;
    rdfs:label "Interrupted Service Criticity"@en ;
    rdfs:comment "Criticity level indicating a complete service interruption."@en .

noria-inst:TTCriticity_DegradedService a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/category> ;
    rdfs:label "Degraded Service Criticity"@en ;
    rdfs:comment "Criticity level indicating a partial service degradation."@en .

noria-inst:TTPriority_P1 a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority for trouble tickets."@en ;
    skos:prefLabel "Highest Priority"@en ;
    skos:altLabel "Critical Priority"@en .

noria-inst:TTPriority_P2 a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority for trouble tickets."@en .

noria-inst:TTOrigin_Customer a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Trouble ticket originated by a customer."@en ;
    skos:prefLabel "External Origin"@en ;
    skos:altLabel "Client Reported"@en .

noria-inst:TTOrigin_Supervision a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System Origin"@en ;
    rdfs:comment "Trouble ticket originated by an automated monitoring or supervision system."@en .

noria-inst:TTUrgency_Immediate a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention Urgency"@en ;
    rdfs:comment "Urgency level requiring immediate intervention."@en ;
    skos:prefLabel "Urgent Intervention"@en ;
    skos:altLabel "Emergency Response"@en .

noria-inst:TTCategory_TotalBreakdown a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> ;
    rdfs:label "Total Breakdown Category"@en ;
    rdfs:comment "Category for incidents involving a total system breakdown."@en ;
    skos:prefLabel "Complete System Failure"@en ;
    skos:altLabel "Full Outage"@en .

noria-inst:TTCategory_SecurityBreach a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> ;
    rdfs:label "Security Breach Category"@en ;
    rdfs:comment "Category for incidents involving security breaches or intrusion attempts."@en ;
    skos:prefLabel "Cybersecurity Incident Category"@en ;
    skos:altLabel "Data Breach Event"@en ;
    skos:definition "This category encompasses all incidents related to unauthorized access, use, disclosure, disruption, modification, or destruction of information systems, data, or networks."@en .

noria-inst:TTCategory_ApplicationFailure a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> ;
    rdfs:label "Application Failure Category"@en ;
    rdfs:comment "Category for incidents related to application software failures."@en .

noria-inst:ProblemResp_ManagedBackbone a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Responsibility"@en ;
    rdfs:comment "Responsibility for the problem lies with the managed backbone network team."@en ;
    skos:prefLabel "Internal Network Team Responsibility"@en ;
    skos:altLabel "Core Network Fault"@en .

noria-inst:ProblemResp_ExternalThreat a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "External Threat Responsibility"@en ;
    rdfs:comment "Responsibility for the problem lies with an external malicious actor."@en ;
    skos:prefLabel "External Malicious Actor Responsibility"@en ;
    skos:altLabel "Third-Party Attack"@en ;
    skos:definition "This responsibility indicates that the root cause of the problem originates from an external entity attempting to compromise the system, such as a hacker or a denial-of-service attack."@en .

noria-inst:ProblemResp_ApplicationTeam a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Application Team Responsibility"@en ;
    rdfs:comment "Responsibility for the problem lies with the application development or support team."@en .

