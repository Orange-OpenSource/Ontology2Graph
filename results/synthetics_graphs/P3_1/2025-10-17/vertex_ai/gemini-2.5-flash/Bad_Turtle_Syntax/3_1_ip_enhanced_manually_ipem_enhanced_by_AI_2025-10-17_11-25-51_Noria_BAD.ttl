    noria:alarmSeverity noria-inst:AlarmSeverity_Major .

noria-inst:Action_RouterRestart a noria:EventRecord ;
    rdfs:label "Router Interface Restart Action"@en ;
    rdfs:comment "An action taken to restart a router interface."@en ;
    noria:loggingTime "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    noria:logText "Executed 'shutdown' then 'no shutdown' on ge-0/0/0 of core-router-nyc-01."^^xsd:string ;
    noria:logOriginatingAgent noria-inst:Person_AliceSmith ;
    noria:actionCorrelatedOperationPlan noria-inst:OperationPlan_InterfaceRecovery .

noria-inst:Action_CRMDeploy a noria:EventRecord ;
    rdfs:label "CRM Feature Deployment Action"@en ;
    rdfs:comment "An action taken to deploy a new CRM feature."@en ;
    noria:loggingTime "2024-05-10T01:15:00Z"^^xsd:dateTime ;
    noria:logText "Deployed 'Customer 360 View' feature to CRM Production Module."^^xsd:string ;
    noria:logOriginatingAgent noria-inst:Person_BobJohnson ;
    noria:actionCorrelatedOperationPlan noria-inst:OperationPlan_CRMDeployment .

noria-inst:Action_DBPatch a noria:EventRecord ;
    rdfs:label "Database Patch Application Action"@en ;
    rdfs:comment "Action taken to apply a security patch to the CRM database."@en ;
    noria:loggingTime "2024-05-15T00:30:00Z"^^xsd:dateTime ;
    noria:logText "Applied Oracle CPU patch to db-server-crm-01. Database restarted successfully."^^xsd:string ;
    noria:logOriginatingAgent noria-inst:Person_BobJohnson ;
    noria:actionCorrelatedOperationPlan noria-inst:OperationPlan_DBPatch .

# --- Procedures and Actions ---

noria-inst:Procedure_RestartInterface a pep:Procedure ;
    rdfs:label "Network Interface Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a faulty network interface."@en .

noria-inst:Procedure_DBTroubleshoot a pep:Procedure ;
    rdfs:label "Database Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving database connectivity issues."@en .

noria-inst:ActionPreCond_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Interface is Down"@en ;
    rdfs:comment "Condition that the network interface must be in a 'down' state to execute a restart procedure."@en .

noria-inst:ActionPostCond_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Interface is Up"@en ;
    rdfs:comment "Expected outcome: the network interface is in an 'up' state after executing the procedure."@en .

noria-inst:ActionPreCond_DBErrorDetected a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Database Error Detected"@en ;
    rdfs:comment "Condition that a database error must be detected before initiating troubleshooting."@en .

noria-inst:ActionPostCond_DBConnectionRestored a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Database Connection Restored"@en ;
    rdfs:comment "Expected outcome: database connectivity is restored."@en .

noria-inst:ActionPreCond_CodeReviewed a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Code Reviewed"@en ;
    rdfs:comment "Code must be reviewed and approved before deployment."@en .

noria-inst:ActionPostCond_FeatureLive a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Feature Live"@en ;
    rdfs:comment "New feature is live and accessible to users."@en .

noria-inst:ActionPreCond_DBBackup a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Database Backup Completed"@en ;
    rdfs:comment "Ensures a full database backup is completed before applying patches."@en .

noria-inst:ActionPostCond_DBPatched a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Database Patched and Verified"@en ;
    rdfs:comment "Confirms that the database patch has been successfully applied and verified."@en .

noria-inst:OperationPlan_InterfaceRecovery a noria:OperationPlan ;
    rdfs:label "Interface Recovery Operation Plan"@en ;
    rdfs:comment "An operation plan detailing steps to recover a failed network interface."@en ;
    noria:operationPlanPreCondition noria-inst:ActionPreCond_InterfaceDown ;
    noria:operationPlanPostCondition noria-inst:ActionPostCond_InterfaceUp .

noria-inst:OperationPlan_DBConnectionFix a noria:OperationPlan ;
    rdfs:label "Database Connection Fix Operation Plan"@en ;
    rdfs:comment "An operation plan for resolving database connection issues."@en ;
    noria:operationPlanPreCondition noria-inst:ActionPreCond_DBErrorDetected ;
    noria:operationPlanPostCondition noria-inst:ActionPostCond_DBConnectionRestored .

noria-inst:OperationPlan_CRMDeployment a noria:OperationPlan ;
    rdfs:label "CRM Feature Deployment Plan"@en ;
    rdfs:comment "Operation plan for deploying new features to the CRM application."@en ;
    noria:operationPlanPreCondition noria-inst:ActionPreCond_CodeReviewed ;
    noria:operationPlanPostCondition noria-inst:ActionPostCond_FeatureLive .

noria-inst:OperationPlan_DBPatch a noria:OperationPlan ;
    rdfs:label "Database Patching Operation Plan"@en ;
    rdfs:comment "Operation plan for applying database security patches, including pre-checks, patch application, and post-checks."@en ;
    noria:operationPlanPreCondition noria-inst:ActionPreCond_DBBackup ;
    noria:operationPlanPostCondition noria-inst:ActionPostCond_DBPatched .

noria-inst:PEC_InterfaceRestart a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution Container for Interface Restart"@en ;
    rdfs:comment "Container for the execution of the interface restart procedure."@en ;
    dcterms:identifier "PEC-INT-RST-001"^^xsd:string .

noria-inst:PEC_DBFixExecution a pep:ProcedureExecutionContainer ;
    rdfs:label "Database Fix Execution Container"@en ;
    rdfs:comment "Container for the execution of the database connection fix procedure."@en ;
    dcterms:identifier "PEC-DB-FIX-001"^^xsd:string .

noria-inst:PEC_NetworkIntervention_Phase1 a pep:ProcedureExecutionContainer ;
    rdfs:label "Network Intervention Phase 1"@en ;
    rdfs:comment "Initial phase of network intervention for TT-NetworkOutage-001, involving diagnosis and initial restart attempts."@en ;
    dcterms:identifier "PEC-NET-INT-P1-001"^^xsd:string ;
    pep:hasMember noria-inst:Action_RouterRestart .

noria-inst:PEC_NetworkIntervention_Phase2 a pep:ProcedureExecutionContainer ;
    rdfs:label "Network Intervention Phase 2"@en ;
    rdfs:comment "Second phase of network intervention for TT-NetworkOutage-001, involving vendor escalation."@en ;
    dcterms:identifier "PEC-NET-INT-P2-001"^^xsd:string ;
    pep:hasMember noria-inst:Event_TTFreeze_001 .

# --- Trouble Tickets ---

noria-inst:TT_NetworkOutage_001 a noria:TroubleTicket ;
    rdfs:label "Network Outage in NYC Data Center"@en ;
    rdfs:comment "Trouble ticket opened due to a critical network outage affecting multiple services in the NYC data center."@en ;
    dcterms:identifier "TT-20240420-001"^^xsd:string ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    dcterms:title "Critical Network Outage"^^xsd:string ;
    dcterms:description "Core router interface went down, causing widespread service disruption."^^xsd:string ;
    noria:documentExternalId "CUST-INC-9876"^^xsd:string ;
    noria:documentHRef <https://ticketing.globaltech.com/tt/20240420-001> ;
    noria:troubleTicketSeverity noria-inst:TTSeverity_Critical ;
    noria:troubleTicketType noria-inst:TTType_Failure ;
    noria:troubleTicketCriticity noria-inst:TTCriticity_InterruptedService ;
    noria:troubleTicketPriority noria-inst:TTPriority_P1 ;
    noria:troubleTicketOrigin noria-inst:TTOrigin_Customer ;
    noria:troubleTicketTrigger noria-inst:Event_RouterDown ;
    noria:troubleTicketUrgency noria-inst:TTUrgency_Immediate ;
    noria:troubleTicketSupervisionTool "NMS-PRO-V2"^^xsd:string ;
    noria:troubleTicketCategory noria-inst:TTCategory_TotalBreakdown ;
    noria:problemCategory noria-inst:TTCategory_TotalBreakdown ;
    noria:troubleTicketCause "Hardware failure on network interface."^^xsd:string ;
    noria:problemResponsibility noria-inst:ProblemResp_ManagedBackbone ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true^^xsd:boolean ;
    noria:troubleTicketStatusCurrent noria-inst:TTStatus_InProgress ;
    noria:troubleTicketRelatedParty noria-inst:Person_AliceSmith, noria-inst:Group_SupportTeamL1 ;
    noria:troubleTicketRelatedService noria-inst:Service_CustomerInternetAccess ;
    noria:troubleTicketRelatedResource noria-inst:Resource_Router_Core1 ;
    noria:troubleTicketImpacts noria-inst:Application_CRM_Suite, noria-inst:Service_CustomerInternetAccess ;
    noria:troubleTicketCharacteristic noria-inst:TTChar_HighImpact ;
    noria:troubleTicketFreezeItem noria-inst:Event_TTFreeze_001 ;
    noria:troubleTicketPartyIntervention noria-inst:PEC_NetworkIntervention_Phase1, noria-inst:PEC_NetworkIntervention_Phase2 ;
    dcterms:abstract "A severe network outage was reported in the NYC Data Center, directly impacting the Customer Internet Access Service and subsequently the CRM Suite. The root cause was identified as a hardware failure on a critical interface of Core Router 1. Immediate intervention by the Network Operations Center was initiated, involving diagnosis, attempted interface restarts, and eventual vendor escalation for hardware replacement. The incident was classified as P1 Critical due to its widespread business impact."@en .

noria-inst:TT_DBConnectivity_002 a noria:TroubleTicket ;
    rdfs:label "CRM Database Connectivity Issue"@en ;
    rdfs:comment "Trouble ticket opened for intermittent database connectivity issues affecting the CRM application."@en ;
    dcterms:identifier "TT-20240420-002"^^xsd:string ;
    dcterms:created "2024-04-20T10:20:00Z"^^xsd:dateTime ;
