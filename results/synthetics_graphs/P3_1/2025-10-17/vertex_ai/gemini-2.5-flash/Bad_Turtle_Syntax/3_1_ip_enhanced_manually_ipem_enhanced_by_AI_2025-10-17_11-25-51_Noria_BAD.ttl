    noria:logText "Change Request CR-20240501-001 status changed to Approved by Change Advisory Board."^^xsd:string ;
    noria:logOriginatingManagementSystem noria-inst:Application_ERP_Finance ;
    noria:logOriginatingAgent noria-inst:Person_BobJohnson .

noria-inst:Event_HighCPULoad a noria:EventRecord ;
    rdfs:label "High CPU Load Alert"@en ;
    rdfs:comment "Alert indicating sustained high CPU load on a database server."@en ;
    noria:loggingTime "2024-04-20T10:55:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on db-server-crm-01 exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject noria-inst:Resource_Server_DB1 ;
    noria:logOriginatingManagementSystem noria-inst:AppMod_NMS_Production ;
    noria:alarmSeverity noria-inst:AlarmSeverity_Warning ;
    noria:alarmMonitoredAttribute <http://example.com/cpu_utilization> .

noria-inst:Event_DBFixCompleted a noria:EventRecord ;
    rdfs:label "Database Fix Completed Event"@en ;
    rdfs:comment "Event indicating the completion of the database connection fix."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
