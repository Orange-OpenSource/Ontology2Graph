    noria:logOriginatingManagementSystem noria-inst:AppMod_CRM_Production ;
    noria:alarmSeverity noria-inst:AlarmSeverity_Warning ;
    noria:alarmMitigatedBy noria-inst:PEC_DBFixExecution .

noria-inst:Event_FirewallAlert a noria:EventRecord ;
