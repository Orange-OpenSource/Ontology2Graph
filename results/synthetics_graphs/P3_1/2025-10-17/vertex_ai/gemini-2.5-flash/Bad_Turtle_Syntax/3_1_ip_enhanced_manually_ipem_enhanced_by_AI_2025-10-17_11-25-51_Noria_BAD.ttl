# --- Organizational Entities ---

noria-inst:Org_GlobalTech a org:Organization ;
    rdfs:label "GlobalTech Solutions Inc."@en ;
    rdfs:comment "A leading global technology company providing IT services and infrastructure."@en .

noria-inst:Org_CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Multinational technology conglomerate that develops, manufactures, and sells networking hardware."@en .

noria-inst:Org_DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies Inc."@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria-inst:OrgUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "The team responsible for 24/7 monitoring and management of network infrastructure."@en ;
    org:unitOf noria-inst:Org_GlobalTech .

noria-inst:OrgUnit_AppDev a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team focused on developing and maintaining critical business applications."@en ;
    org:unitOf noria-inst:Org_GlobalTech .

noria-inst:OrgUnit_SecurityOps a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Specialized unit for cybersecurity monitoring, incident response, and threat intelligence."@en ;
    org:unitOf noria-inst:Org_GlobalTech .

noria-inst:OrgUnit_ITSupport a org:OrganizationalUnit ;
    rdfs:label "IT Support Department"@en ;
    rdfs:comment "General IT support department for all internal users."@en ;
    org:unitOf noria-inst:Org_GlobalTech .

noria-inst:Person_AliceSmith a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Senior Network Engineer at GlobalTech Solutions."@en ;
    foaf:mbox <mailto:alice.smith@globaltech.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
