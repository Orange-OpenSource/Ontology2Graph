# =============================================================================
# KOS Concepts (Knowledge Organization System)
# =============================================================================

noria:kos/agent-contact-method/Email
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via email."@en .

noria:kos/agent-contact-method/Phone
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via phone."@en .

noria:kos/application/type/ServicePlatform
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "An application acting as a service platform."@en .

noria:kos/application/type/Infrastructure
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
