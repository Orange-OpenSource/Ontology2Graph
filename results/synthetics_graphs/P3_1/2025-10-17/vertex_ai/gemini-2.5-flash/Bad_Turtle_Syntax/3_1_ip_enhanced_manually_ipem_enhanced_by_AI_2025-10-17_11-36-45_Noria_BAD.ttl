# =============================================================================
# Additional Classes for Property Domains (not explicitly defined in schema)
# =============================================================================

noria:CorrectiveMaintenanceAction
    a owl:Class ;
    rdfs:label "Corrective Maintenance Action"@en ;
    rdfs:comment "An action taken to restore a failed item to a specified condition, often in response to a trouble ticket."@en ;
    rdfs:subClassOf pep:ProcedureExecution ;
    rdfs:isDefinedBy noria: .

noria:ChangeAction
    a owl:Class ;
    rdfs:label "Change Action"@en ;
    rdfs:comment "An action taken as part of a change request, implementing a planned modification."@en ;
    rdfs:subClassOf pep:ProcedureExecution ;
    rdfs:isDefinedBy noria: .

# =============================================================================
# Organization related entities
# =============================================================================

noria:instance/Organization/GlobalNetSolutions
    a org:Organization ;
    rdfs:label "GlobalNet Solutions Inc."@en ;
    rdfs:comment "A global IT service provider managing complex network infrastructures and applications."@en ;
    dcterms:identifier "GNS-HQ-2024"^^xsd:string ;
    foaf:homepage <https://www.globalnetsolutions.com>^^xsd:anyURI .

noria:instance/OrganizationalUnit/NOC
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "The team responsible for monitoring and managing the network infrastructure 24/7."@en ;
    org:unitOf noria:instance/Organization/GlobalNetSolutions ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "For critical issues, call hotline immediately. For non-critical, use ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/agent-contact-method/Phone .

noria:instance/OrganizationalUnit/AppSupport
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team dedicated to supporting and maintaining business-critical applications."@en ;
    org:unitOf noria:instance/Organization/GlobalNetSolutions ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Submit tickets via portal for L2 support."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/agent-contact-method/Email .

noria:instance/Person/AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer at GlobalNet Solutions."@en ;
    foaf:mbox <mailto:alice.smith@globalnetsolutions.com>^^xsd:anyURI ;
    foaf:phone "+1-555-123-4567"^^xsd:string ;
    org:memberOf noria:instance/OrganizationalUnit/NOC ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/agent-contact-method/Email .

noria:instance/Person/BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer for Core Banking App."@en ;
    foaf:mbox <mailto:bob.johnson@globalnetsolutions.com>^^xsd:anyURI ;
    org:memberOf noria:instance/OrganizationalUnit/AppSupport ;
    noria:agentWorkingHours "10:00-19:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "For production issues, escalate to L3 support."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/agent-contact-method/Phone .

noria:instance/CorporateUserIdentifier/ASmithID
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Unique corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "CU-AS-7890"^^xsd:string ;
    foaf:holdsAccount noria:instance/Person/AliceSmith .

# =============================================================================
# Location related entities
# =============================================================================

noria:instance/Site/ParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris, France."@en ;
    noria:siteId "PAR-DC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string ;
    wgs84_pos:lat "48.8718"^^xsd:decimal ;
    wgs84_pos:long "2.3314"^^xsd:decimal .

noria:instance/Room/ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated server room within the Paris Data Center."@en ;
    bot:hasSpace noria:instance/Site/ParisDC .

noria:instance/Locus/Rack12
    a noria:Locus ;
    rdfs:label "Rack 12 in Server Room A"@en ;
    rdfs:comment "Specific location of equipment within Server Room A, identified as Rack 12."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "12"^^xsd:string ;
    bot:containsZone noria:instance/Room/ServerRoomA .

noria:instance/Locus/Rack15
    a noria:Locus ;
    rdfs:label "Rack 15 in Server Room A"@en ;
    rdfs:comment "Specific location of equipment within Server Room A, identified as Rack 15."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "15"^^xsd:string ;
    bot:containsZone noria:instance/Room/ServerRoomA .

