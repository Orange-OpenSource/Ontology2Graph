# --- Agents (foaf:Agent, org:Organization, org:OrganizationalUnit) ---

<agent/john_doe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A key technical lead responsible for network operations."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    noria:agentManagesResource <resource/router_core_01>, <resource/server_app_01> .

<agent/jane_smith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Support Engineer."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+33987654321" ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call for immediate application issues."^^xsd:string ;
    noria:agentManagesResource <application/crm_suite>, <application_module/crm_prod_module> .

<org/network_operations_team>
    a org:OrganizationalUnit, foaf:Group ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for the 24/7 operation and maintenance of the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use ticketing system for all requests, call hotline for P1 incidents."^^xsd:string ;
    noria:agentManagesResource <resource/router_core_01>, <network_link/wan_link_paris_lyon> .

<org/application_support_department>
    a org:OrganizationalUnit, foaf:Group ;
    rdfs:label "Application Support Department"@en ;
    rdfs:comment "Department overseeing all application-related support and administration."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit all application support requests via the internal portal."^^xsd:string ;
    noria:agentManagesResource <application/crm_suite> .

<org/acme_corp>
    a org:Organization ;
    rdfs:label "ACME Corporation"@en ;
    rdfs:comment "A leading global technology company."@en ;
    noria:agentWorkingHours "Global Business Hours"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Refer to corporate guidelines for contact protocols."^^xsd:string .

<org/tech_solutions_inc>
    a org:Organization ;
    rdfs:label "Tech Solutions Inc."@en ;
    rdfs:comment "A technology vendor specializing in network hardware."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri, EST)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact sales for new inquiries, support for existing products."^^xsd:string .

