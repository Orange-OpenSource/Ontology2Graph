    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated room within the Paris Data Center housing critical servers."@en ;
    bot:hasElement <resource/server_app_01> ;
    bot:containsZone <locus/rack_a1_u1> .

<locus/rack_a1_u1>
