# =============================================================================
# Knowledge Organization Systems (KOS) Concepts
# =============================================================================

<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via electronic mail."@en .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via telephone."@en .

<kos/application/type/ServicePlatform>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "An application acting as a platform for various services."@en .

<kos/application/type/Infrastructure>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application managing core infrastructure components."@en .

<kos/application/business-importance/High>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for core business operations."@en .

<kos/application/business-importance/Medium>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application supports important but not critical business functions."@en .

<kos/application/sla-level/Gold>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement tier with maximum availability and performance guarantees."@en .

<kos/application/sla-level/Silver>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Standard Service Level Agreement tier with good availability and performance."@en .

<kos/application/status/InProduction>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

<kos/application/status/Maintenance>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Under Maintenance"@en ;
    rdfs:comment "The application module is temporarily offline for maintenance."@en .

<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed or perceived by end-customers."@en .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations, not directly exposed to customers."@en .

<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Significant impact on service, affecting multiple users or critical functions."@en .

<kos/TroubleTicket/severity/Minor>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor Severity"@en ;
    rdfs:comment "Limited impact on service, affecting a single user or non-critical function."@en .

<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure Ticket"@en ;
    rdfs:comment "Ticket reporting a system or service failure."@en .

<kos/TroubleTicket/type/Assistance>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance Ticket"@en ;
    rdfs:comment "Ticket requesting user assistance or support."@en .

<kos/TroubleTicket/category/InterruptedService>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "Service is completely unavailable."@en .

<kos/TroubleTicket/category/DegradedPerformance>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Degraded Performance"@en ;
    rdfs:comment "Service is available but performing below expected levels."@en .

<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1 (Critical)"@en ;
    rdfs:comment "Highest priority, requiring immediate attention."@en .

<kos/TroubleTicket/priority/P3>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 3 (Normal)"@en ;
    rdfs:comment "Normal priority, to be addressed within standard timelines."@en .

<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Trouble ticket initiated by an external customer."@en .

<kos/TroubleTicket/origin/Supervision>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System Origin"@en ;
    rdfs:comment "Trouble ticket automatically generated by a monitoring or supervision system."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action to prevent further impact."@en .

<kos/TroubleTicket/urgency/DeferredIntervention>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Can be scheduled for later intervention without critical impact."@en .

<kos/TroubleTicket/trouble-category/TotalBreakdown>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Complete failure of a system or component."@en .

<kos/TroubleTicket/trouble-category/ConfigurationError>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Configuration Error"@en ;
    rdfs:comment "Issue caused by incorrect configuration settings."@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility lies with the team managing core network infrastructure."@en .

<kos/TroubleTicket/problemResponsibility/Customer>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Customer Responsibility"@en ;
    rdfs:comment "The problem is attributed to the customer's equipment or actions."@en .

<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team members only."@en .

<kos/TroubleTicket/commentType/CustomerFacing>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer-Facing Comment"@en ;
    rdfs:comment "Comment visible and relevant to the customer."@en .

<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Operation related to diagnosing the root cause of an issue."@en .

<kos/TroubleTicket/operationType/TestsAndMeasurements>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Tests and Measurements Operation"@en ;
    rdfs:comment "Operation involving performing tests and taking measurements."@en .

<kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request for internal system modifications."@en .

<kos/ChangeRequest/category/CustomerRequested>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Customer Requested Change"@en ;
    rdfs:comment "Change request initiated by a customer."@en .

<kos/ChangeRequest/type/Standard>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Pre-approved change with low risk and impact."@en .

<kos/ChangeRequest/type/Emergency>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Emergency Change"@en ;
    rdfs:comment "Urgent change required to resolve a critical incident."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change caused by the need to upgrade software."@en .

<kos/ChangeRequest/cause/ConfigurationChange>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change caused by modification of system configuration."@en .

<kos/ChangeRequest/status/Approved>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved Status"@en ;
    rdfs:comment "Change request has been approved and is awaiting implementation."@en .

<kos/ChangeRequest/status/Implemented>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented Status"@en ;
