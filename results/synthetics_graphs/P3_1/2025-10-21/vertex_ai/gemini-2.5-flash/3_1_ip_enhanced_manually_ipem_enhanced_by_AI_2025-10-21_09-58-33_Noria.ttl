    noria:operationPlanPostCondition <action_post_condition/interface_restored_confirmation> ;
    noria:elementProperty <noria:Property/troubleshooting_steps> .

<operation_plan/app_restart_procedure>
    a noria:OperationPlan ;
    rdfs:label "Application Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting critical application modules."@en ;
    noria:operationPlanPreCondition <action_pre_condition/app_error_alert> ;
    noria:operationPlanPostCondition <action_post_condition/app_service_up_confirmation> ;
    noria:elementProperty <noria:Property/restart_log_check> .

