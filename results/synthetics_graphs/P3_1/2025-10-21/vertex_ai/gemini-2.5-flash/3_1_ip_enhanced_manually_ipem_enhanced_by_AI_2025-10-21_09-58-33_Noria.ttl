    noria:elementProperty <noria:Property/service_health_ok> .

<noria:Property/link_state_up>
    a noria:Property ;
    rdfs:label "Link State Up Property"@en ;
    rdfs:comment "A property indicating that a network link's operational state is up."@en .

<noria:Property/service_health_ok>
    a noria:Property ;
    rdfs:label "Service Health OK Property"@en ;
    rdfs:comment "A property indicating that a service's health status is normal."@en .

<noria:Property/troubleshooting_steps>
    a noria:Property ;
    rdfs:label "Troubleshooting Steps Property"@en ;
    rdfs:comment "A property representing the sequence of steps involved in a troubleshooting procedure."@en .

<noria:Property/restart_log_check>
    a noria:Property ;
    rdfs:label "Restart Log Check Property"@en ;
    rdfs:comment "A property representing the verification of logs after a system restart."@en .
