# =============================================================================
# Instances of core classes
# =============================================================================

# foaf:Agent (Person)
foaf-inst:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A key technical expert responsible for network operations."@en ;
    foaf:name "John Doe" ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod kos-inst:ContactMethod_Email ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."@en .

foaf-inst:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead developer for the core application services."@en ;
    foaf:name "Jane Smith" ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod kos-inst:ContactMethod_Chat ;
    noria:agentInstructions "Use internal chat for quick questions, email for detailed discussions."@en .

foaf-inst:AliceJohnson
    a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Customer support representative."@en ;
    foaf:name "Alice Johnson" ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    noria:agentWorkingHours "8:00-16:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod kos-inst:ContactMethod_Phone ;
    noria:agentInstructions "Direct phone line for customer inquiries."@en .

# org:Organization
org-inst:TechSolutionsInc
    a org:Organization ;
    rdfs:label "Tech Solutions Inc."@en ;
    rdfs:comment "A leading technology company providing IT services."@en ;
    org:hasUnit org-inst:NetworkOperationsUnit ;
    org:hasUnit org-inst:ApplicationDevelopmentUnit ;
    org:hasUnit org-inst:CustomerSupportUnit .

# org:OrganizationalUnit
org-inst:NetworkOperationsUnit
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Responsible for managing and maintaining the company's network infrastructure."@en ;
    org:unitOf org-inst:TechSolutionsInc ;
    org:member foaf-inst:JohnDoe ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod kos-inst:ContactMethod_Phone ;
    noria:agentInstructions "For critical network issues, call the hotline. For routine tasks, use the ticketing system."@en .

org-inst:ApplicationDevelopmentUnit
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Develops and maintains core business applications."@en ;
    org:unitOf org-inst:TechSolutionsInc ;
    org:member foaf-inst:JaneSmith ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod kos-inst:ContactMethod_Chat ;
    noria:agentInstructions "Contact via internal chat for urgent development queries."@en .

org-inst:CustomerSupportUnit
    a org:OrganizationalUnit ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "Provides first-line support to customers."@en ;
    org:unitOf org-inst:TechSolutionsInc ;
    org:member foaf-inst:AliceJohnson ;
    noria:agentWorkingHours "8:00-20:00 Mon-Sun"@en ;
    noria:agentPreferredContactMethod kos-inst:ContactMethod_Phone ;
    noria:agentInstructions "All customer inquiries should be directed to the support hotline."@en .

# bot:Site
bot-inst:MainDataCenter
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for Tech Solutions Inc."@en ;
    noria:siteId "DC-EAST-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

bot-inst:BranchOffice
    a bot:Site ;
    rdfs:label "Branch Office West"@en ;
    rdfs:comment "Regional office with local IT infrastructure."@en ;
    noria:siteId "BO-WEST-02"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Innovation Drive"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Beverly Hills"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Innovation Drive"^^xsd:string .

# noria:Room
noria-inst:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the data center."@en ;
    bot:hasSpace noria-inst:RackA1Locus ;
    bot:hasSpace noria-inst:RackA2Locus ;
    bot:hasSpace noria-inst:RackA3Locus ;
    bot:hasSpace noria-inst:RackB1Locus ;
    bot:hasSpace noria-inst:RackB2Locus ;
    bot:hasSpace noria-inst:RackB3Locus ;
    bot:hasSpace noria-inst:RackC1Locus ;
    bot:hasSpace noria-inst:RackC2Locus ;
    bot:hasSpace noria-inst:RackC3Locus ;
    bot:hasSpace noria-inst:RackD1Locus ;
    bot:hasSpace noria-inst:RackD2Locus ;
    bot:hasSpace noria-inst:RackD3Locus ;
    bot:hasSpace noria-inst:RackE1Locus ;
    bot:hasSpace noria-inst:RackE2Locus ;
    bot:hasSpace noria-inst:RackE3Locus ;
    bot:hasSpace noria-inst:RackF1Locus ;
    bot:hasSpace noria-inst:RackF2Locus ;
    bot:hasSpace noria-inst:RackF3Locus ;
    bot:hasSpace noria-inst:RackG1Locus ;
    bot:hasSpace noria-inst:RackG2Locus ;
    bot:hasSpace noria-inst:RackG3Locus ;
