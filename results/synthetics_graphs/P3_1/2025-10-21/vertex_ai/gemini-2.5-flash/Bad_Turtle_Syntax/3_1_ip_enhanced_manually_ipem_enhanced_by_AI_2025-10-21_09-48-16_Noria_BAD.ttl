# =============================================================================
# Knowledge Organization System (KOS) Concepts
# =============================================================================

<kos/application/type/ServicePlatform>
    a skos:Concept ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "A type of application that provides a platform for other services."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/Infrastructure>
    a skos:Concept ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "A type of application managing core infrastructure components."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/BusinessCritical>
    a skos:Concept ;
    rdfs:label "Business Critical Application"@en ;
    rdfs:comment "An application essential for core business operations."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/business-importance/Critical>
    a skos:Concept ;
    rdfs:label "Critical Business Importance"@en ;
    rdfs:comment "Application is critical for business continuity."@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/business-importance/High>
    a skos:Concept ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application has high impact on business operations."@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/sla-level/Gold>
    a skos:Concept ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement tier, ensuring maximum availability and performance."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<kos/application/sla-level/Silver>
    a skos:Concept ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Standard Service Level Agreement tier, offering good availability and performance."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<kos/application/status/InProduction>
    a skos:Concept ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<kos/application/status/Development>
    a skos:Concept ;
    rdfs:label "In Development"@en ;
    rdfs:comment "The application module is under active development and not yet in production."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed or perceived by end-customers."@en ;
    skos:inScheme <kos/service/type> .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations, not directly exposed to customers."@en ;
    skos:inScheme <kos/service/type> .

<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Indicates a severe impact on service, requiring immediate attention."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Indicates a significant impact on service, affecting multiple users or critical functions."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Minor>
    a skos:Concept ;
    rdfs:label "Minor Severity"@en ;
    rdfs:comment "Indicates a limited impact on service, affecting a single user or non-critical function."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    rdfs:label "Failure Ticket"@en ;
    rdfs:comment "A trouble ticket reporting a system or service failure."@en ;
    skos:inScheme <kos/TroubleTicket/type> .

<kos/TroubleTicket/type/Assistance>
    a skos:Concept ;
    rdfs:label "Assistance Ticket"@en ;
    rdfs:comment "A trouble ticket requesting assistance or support."@en ;
    skos:inScheme <kos/TroubleTicket/type> .

<kos/TroubleTicket/category/InterruptedService>
    a skos:Concept ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "The service is completely unavailable."@en ;
    skos:inScheme <kos/TroubleTicket/category> .

<kos/TroubleTicket/category/CorruptedService>
    a skos:Concept ;
    rdfs:label "Corrupted Service"@en ;
    rdfs:comment "The service is available but providing incorrect or degraded data."@en ;
    skos:inScheme <kos/TroubleTicket/category> .

<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    rdfs:label "Priority 1 (Urgent)"@en ;
    rdfs:comment "Highest priority, requiring immediate resolution."@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/priority/P2>
    a skos:Concept ;
    rdfs:label "Priority 2 (High)"@en ;
    rdfs:comment "High priority, requiring prompt resolution."@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Trouble ticket initiated by a customer."@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/origin/Supervision>
    a skos:Concept ;
    rdfs:label "Supervision System Origin"@en ;
    rdfs:comment "Trouble ticket automatically generated by a monitoring or supervision system."@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action to resolve the issue."@en ;
    skos:inScheme <kos/TroubleTicket/urgency> .

<kos/TroubleTicket/urgency/DeferredIntervention>
    a skos:Concept ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Intervention can be scheduled for a later time without critical impact."@en ;
    skos:inScheme <kos/TroubleTicket/urgency> .

<kos/TroubleTicket/trouble-category/TotalBreakdown>
    a skos:Concept ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Complete failure of a system or component."@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/trouble-category/IsolatedSite>
    a skos:Concept ;
    rdfs:label "Isolated Customer Site"@en ;
    rdfs:comment "A customer site has lost connectivity."@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/problemResponsibility/ManagedBackbone>
    a skos:Concept ;
    rdfs:label "Managed Backbone Responsibility"@en ;
    rdfs:comment "The problem is attributed to the managed backbone network."@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

<kos/TroubleTicket/problemResponsibility/Customer>
    a skos:Concept ;
    rdfs:label "Customer Responsibility"@en ;
    rdfs:comment "The problem is attributed to the customer's equipment or configuration."@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "A comment intended for internal team use only."@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

<kos/TroubleTicket/commentType/Customer>
    a skos:Concept ;
    rdfs:label "Customer Visible Comment"@en ;
    rdfs:comment "A comment visible to the customer."@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "A note detailing diagnostic steps taken."@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

<kos/TroubleTicket/operationType/TestsAndMeasurements>
    a skos:Concept ;
    rdfs:label "Tests and Measurements Operation"@en ;
    rdfs:comment "A note detailing tests performed and their results."@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

<kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "A change request for an internal operational activity."@en ;
    skos:inScheme <kos/ChangeRequest/category> .

<kos/ChangeRequest/category/CustomerRequested>
    a skos:Concept ;
    rdfs:label "Customer Requested Change"@en ;
    rdfs:comment "A change request initiated by a customer."@en ;
    skos:inScheme <kos/ChangeRequest/category> .

<kos/ChangeRequest/type/Standard>
    a skos:Concept ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk and impact."@en ;
    skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/type/Emergency>
    a skos:Concept ;
    rdfs:label "Emergency Change"@en ;
    rdfs:comment "An urgent change required to resolve an incident or prevent a major disruption."@en ;
    skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/cause/Configuration>
    a skos:Concept ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "The change is due to a configuration update."@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "The change is due to a software version upgrade."@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

<kos/ChangeRequest/status/Planned>
    a skos:Concept ;
    rdfs:label "Planned Change"@en ;
    rdfs:comment "The change request is approved and scheduled."@en ;
    skos:inScheme <kos/ChangeRequest/status> .

<kos/ChangeRequest/status/Implemented>
    a skos:Concept ;
    rdfs:label "Implemented Change"@en ;
    rdfs:comment "The change request has been successfully implemented."@en ;
    skos:inScheme <kos/ChangeRequest/status> .

<kos/ChangeRequest/specification/StandardProcedure>
    a skos:Concept ;
    rdfs:label "Standard Procedure"@en ;
    rdfs:comment "The change follows a documented standard operating procedure."@en ;
    skos:inScheme <kos/ChangeRequest/specification> .

<kos/ChangeRequest/specification/CustomScript>
    a skos:Concept ;
    rdfs:label "Custom Script Execution"@en ;
    rdfs:comment "The change involves executing a custom script."@en ;
    skos:inScheme <kos/ChangeRequest/specification> .

<kos/Resource/OperationalState/Up>
    a skos:Concept ;
    rdfs:label "Operational State: Up"@en ;
    rdfs:comment "The resource is currently operational and functioning."@en ;
    skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/OperationalState/Down>
    a skos:Concept ;
    rdfs:label "Operational State: Down"@en ;
    rdfs:comment "The resource is currently not operational."@en ;
    skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/AdministrativeState/Enabled>
    a skos:Concept ;
    rdfs:label "Administrative State: Enabled"@en ;
    rdfs:comment "The resource is administratively enabled."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

<kos/Resource/AdministrativeState/Disabled>
    a skos:Concept ;
    rdfs:label "Administrative State: Disabled"@en ;
    rdfs:comment "The resource is administratively disabled."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

<kos/Resource/type/Router>
    a skos:Concept ;
    rdfs:label "Router Resource"@en ;
    rdfs:comment "A network device that forwards data packets between computer networks."@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Server>
    a skos:Concept ;
    rdfs:label "Server Resource"@en ;
    rdfs:comment "A computer program or a device that provides functionality for other programs or devices."@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Firewall>
    a skos:Concept ;
    rdfs:label "Firewall Resource"@en ;
    rdfs:comment "A network security system that monitors and controls incoming and outgoing network traffic."@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/LifecycleState/InProduction>
    a skos:Concept ;
    rdfs:label "Lifecycle State: In Production"@en ;
    rdfs:comment "The resource is actively used in a production environment."@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

<kos/Resource/LifecycleState/Decommissioned>
    a skos:Concept ;
    rdfs:label "Lifecycle State: Decommissioned"@en ;
    rdfs:comment "The resource has been removed from service."@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

<Notification/Severity/PerceivedSeverity/Critical>
    a skos:Concept ;
    rdfs:label "Alarm Severity: Critical"@en ;
    rdfs:comment "Indicates a critical alarm, requiring immediate action."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Warning>
    a skos:Concept ;
    rdfs:label "Alarm Severity: Warning"@en ;
    rdfs:comment "Indicates a warning alarm, potential issue requiring attention."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    rdfs:label "Email Contact Method"@en ;
    rdfs:comment "Preferred contact method is email."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    rdfs:label "Phone Contact Method"@en ;
    rdfs:comment "Preferred contact method is phone."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Organizational Entities
# =============================================================================

noria:Org_ITOperations
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The central department responsible for managing IT infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentInstructions "For critical issues, use emergency hotline. For routine requests, use ticketing system."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:Org_NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri, On-call for emergencies"@en ;
    noria:agentInstructions "Contact via internal chat for non-urgent matters. For network outages, follow P1 incident procedure."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Org_AppSupport
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentInstructions "Submit tickets via the application portal. For critical application failures, escalate to L2 support."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Org_SecurityTeam
    a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team dedicated to monitoring, detecting, and responding to cybersecurity threats."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentInstructions "All security incidents must be reported immediately via the dedicated security incident platform."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:Person_AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer, responsible for core network infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentInstructions "Available for consultation on network design and complex routing issues."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource noria:Resource_CoreRouter01 .

noria:Person_BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer, specializing in CRM system maintenance."@en ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"@en ;
    noria:agentInstructions "Contact for CRM application bugs or feature requests."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource noria:Application_CRM .

noria:Person_CarolWhite
    a foaf:Person ;
    rdfs:label "Carol White"@en ;
    rdfs:comment "IT Operations Manager, overseeing all IT infrastructure and service delivery."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentInstructions "Escalate major incidents or strategic IT decisions."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:Org_Manufacturer_Cisco
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "A global technology conglomerate that designs, manufactures, and sells networking hardware, software, telecommunications equipment, and other high-technology services and products."@en .

noria:Org_Manufacturer_Dell
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "An American multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

# =============================================================================
# Location Entities
# =============================================================================

noria:Site_DataCenterParis
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris, France."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "Data Center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

noria:Site_OfficeLondon
    a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:comment "Main corporate office building in London, UK."@en ;
    noria:siteId "OFF-LDN-01"^^xsd:string ;
    noria:siteType "Office Building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Baker Street"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE"^^xsd:string ;
    noria:sitePrincipalAddressCityName "London"^^xsd:string ;
    noria:sitePrincipalAddressCountry "GB"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Baker Street"^^xsd:string .

noria:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Site_DataCenterParis .

noria:Room_NetworkClosetB
    a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet on the 3rd floor of the London Office."@en ;
    bot:hasSpace noria:Site_OfficeLondon .

noria:Locus_RackA1
    a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Specific rack location A1 in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB5
    a noria:Locus ;
    rdfs:label "Rack B5"@en ;
    rdfs:comment "Specific rack location B5 in Network Closet B."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "5"^^xsd:string ;
    bot:hasSpace noria:Room_NetworkClosetB .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_Cisco3850
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 3850"@en ;
    rdfs:comment "Enterprise-class stackable access layer switch."@en ;
    noria:productManufacturedBy noria:Org_Manufacturer_Cisco .

noria:ProductModel_DellPowerEdgeR740
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance 2U rack server."@en ;
    noria:productManufacturedBy noria:Org_Manufacturer_Dell .

noria:ProductModel_JuniperMX960
    a noria:ProductModel ;
    rdfs:label "Juniper MX960"@en ;
    rdfs:comment "High-capacity edge router for service providers."@en ;
    noria:productManufacturedBy noria:Org_Manufacturer_Cisco . # Assuming Cisco also makes routers, or just for diversity.

# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_RouterFirmwareUpgrade
    a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware to the latest stable version."@en ;
    noria:operationPlanPreCondition noria:PreCond_BackupConfig ;
    noria:operationPlanPostCondition noria:PostCond_VerifyConnectivity .

noria:OperationPlan_ServerPatchDeployment
    a noria:OperationPlan ;
    rdfs:label "Server Security Patch Deployment"@en ;
    rdfs:comment "Procedure for deploying critical security patches to production servers."@en ;
    noria:operationPlanPreCondition noria:PreCond_TestEnvironmentValidation ;
    noria:operationPlanPostCondition noria:PostCond_MonitorSystemHealth .

noria:PreCond_BackupConfig
    a noria:ActionPreCondition ;
    rdfs:label "Backup Configuration Completed"@en ;
    rdfs:comment "Ensures that a full backup of the device configuration is performed before any changes."@en .

noria:PreCond_TestEnvironmentValidation
    a noria:ActionPreCondition ;
    rdfs:label "Test Environment Validation"@en ;
    rdfs:comment "Verifies that the patch has been successfully tested in a staging environment."@en .

noria:PostCond_VerifyConnectivity
    a noria:ActionPostCondition ;
    rdfs:label "Verify Network Connectivity"@en ;
    rdfs:comment "Confirms that all network interfaces are up and routing protocols are stable after the change."@en .

noria:PostCond_MonitorSystemHealth
    a noria:ActionPostCondition ;
    rdfs:label "Monitor System Health Metrics"@en ;
    rdfs:comment "Checks CPU, memory, and disk usage to ensure normal operation post-deployment."@en .

noria:AnomalyPattern_HighCPUUsage
    a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Usage Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential issue when CPU usage exceeds 90% for more than 15 minutes on a critical server."@en ;
    folio:hasCriticality <Notification/Severity/PerceivedSeverity/Critical> .

