    noria:productManufacturedBy <https://www.vmware.com/> .

# =============================================================================
# Locations
# =============================================================================

bot:Site1 a bot:Site ;
    rdfs:label "Main Data Center Paris"@en ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "48.869"^^xsd:float ;
    wgs84_pos:long "2.337"^^xsd:float .

bot:Site2 a bot:Site ;
    rdfs:label "Secondary Data Center Lyon"@en ;
    rdfs:comment "Secondary data center facility located in Lyon."@en ;
    noria:siteId "DC-LYN-02" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "45 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "45.749"^^xsd:float ;
    wgs84_pos:long "4.848"^^xsd:float .

noria:Room1 a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "Main server room in DC-PAR-01."@en ;
    bot:hasSpace bot:Site1 .

noria:Room2 a noria:Room ;
    rdfs:label "Network Room B2"@en ;
    rdfs:comment "Network equipment room in DC-PAR-01."@en ;
    bot:hasSpace bot:Site1 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack R01, Unit 10"@en ;
    rdfs:comment "Location of DNS server in Server Room A1."@en ;
    noria:locusLine "R01" ;
    noria:locusRow "10" .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack N05, Unit 22"@en ;
    rdfs:comment "Location of Core Router 1 in Network Room B2."@en ;
    noria:locusLine "N05" ;
    noria:locusRow "22" .

noria:Locus3 a noria:Locus ;
