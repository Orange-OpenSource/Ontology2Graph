    dcterms:isPartOf noria:TroubleTicket2 .

noria:TroubleTicketNote3 a noria:TroubleTicketNote ;
    rdfs:label "Resolution steps for TT1"@en ;
    rdfs:comment "ISP technician on site, fiber repair in progress. Service expected to be restored within 1 hour."@en ;
    dcterms:created "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent2 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket1 .

# =============================================================================
# Change Requests
# =============================================================================

noria:ChangeRequest1 a noria:ChangeRequest ;
    rdfs:label "DNS Server Software Upgrade"@en ;
    rdfs:comment "Planned upgrade of DNS server software to version 9.18.1."@en ;
    dcterms:created "2024-04-15T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-18T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-26T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource1, noria:ApplicationModule2 ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RoutineMaintenance> ;
    noria:changeRequestInitiatorParty foaf:Agent1 ;
    noria:changeRequestPilotParty foaf:Agent1 ;
    noria:changeRequestActorParty foaf:Agent4 ;
    noria:changeRequestIsRegulated "false"^^xsd:boolean ;
    noria:documentHRef <http://itsm.example.com/cr/CR20240415-001> .

noria:ChangeRequest2 a noria:ChangeRequest ;
    rdfs:label "Core Router Configuration Change"@en ;
    rdfs:comment "Emergency configuration change on cr-par-01 to re-route traffic due to link failure."@en ;
    dcterms:created "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-20T10:38:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-20T10:42:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Emergency> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource2, noria:NetworkLink2, noria:ApplicationModule1 ;
    noria:changeRequestOutageDuration "PT0H5M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestInitiatorParty foaf:Agent2 ;
    noria:changeRequestPilotParty foaf:Agent2 ;
    noria:changeRequestActorParty foaf:Agent2 ;
    noria:changeRequestIsRegulated "true"^^xsd:boolean ;
    noria:documentHRef <http://itsm.example.com/cr/CR20240420-001> .

# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the DNS server software, including pre-checks, upgrade steps, and post-validation."@en ;
    noria:operationPlanPreCondition noria:PreCondition1 ;
    noria:operationPlanPostCondition noria:PostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Emergency Network Reroute Procedure"@en ;
    rdfs:comment "Procedure for quickly rerouting network traffic in case of a critical link failure."@en ;
    noria:operationPlanPreCondition noria:PreCondition2 ;
    noria:operationPlanPostCondition noria:PostCondition2 .

noria:AnomalyPattern1 a noria:AnomalyPattern ;
    rdfs:label "High CPU with Low Traffic Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential issue: high CPU usage on a server while network traffic remains low, suggesting a process loop or resource contention."@en ;
    skos:example "If CPU > 90% AND Network_In < 10Mbps, then potential anomaly."@en .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Server Health Check Passed"@en ;
    rdfs:comment "All DNS services are running, disk space is sufficient, and no critical alerts are active."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Operational After Upgrade"@en ;
    rdfs:comment "DNS resolution is functional, new software version is reported, and no errors in logs."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Critical Network Link Down"@en ;
    rdfs:comment "Primary network link is confirmed to be down, impacting critical services."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Traffic Rerouted Successfully"@en ;
    rdfs:comment "Traffic is flowing through the backup link, and affected services are restored."@en .

# =============================================================================
# Cross-linking and additional details
# =============================================================================

# Link EventRecord to ChangeRequest for mitigation
noria:EventRecord6 a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry confirming configuration change on cr-par-01."@en ;
    noria:loggingTime "2024-04-20T10:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingAgent foaf:Agent2 ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by vty0 (10.0.0.50) for emergency reroute."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    noria:alarmMitigatedBy noria:ChangeRequest2 .

# Link TroubleTicket to OperationPlan (as proposed repair action)
noria:TroubleTicket1 noria:alarmProposedRepairAction noria:OperationPlan2 .

# Link ChangeRequest to OperationPlan
noria:ChangeRequest1 noria:actionCorrelatedOperationPlan noria:OperationPlan1 .
noria:ChangeRequest2 noria:actionCorrelatedOperationPlan noria:OperationPlan2 .

# Link EventRecord to TroubleTicketNote
noria:TroubleTicketNote1 dcterms:relation noria:EventRecord2 .
noria:TroubleTicketNote3 dcterms:relation noria:EventRecord6 .

# Link DocumentAttachment (example)
noria:DocumentAttachment1 a noria:DocumentAttachment ;
    rdfs:label "Fiber Cut Report"@en ;
    rdfs:comment "PDF report from ISP detailing the fiber cut incident."@en ;
    dcterms:created "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TroubleTicket1 ;
    dcterms:format "application/pdf" .

noria:DocumentAttachment2 a noria:DocumentAttachment ;
    rdfs:label "Upgrade Plan Document"@en ;
    rdfs:comment "Detailed plan for DNS server software upgrade."@en ;
    dcterms:created "2024-04-16T10:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:ChangeRequest1 ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" .

# Corporate User Identifier example
noria:CUid1 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "johndoe" ;
    observable:accountIdentifier "JD001" .

foaf:Agent4 foaf:holdsAccount noria:CUid1 .

# Additional Resource for Application
noria:Resource1 noria:resourceForApplication noria:Application2 .
noria:Resource2 noria:resourceForApplication noria:Application1 .
noria:Resource3 noria:resourceForApplication noria:Application3 .
noria:Resource4 noria:resourceForApplication noria:Application4 .

# Example of a virtual server status
noria:Resource5 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Example of network interface optical power
noria:NetworkInterface3 noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-1"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

# Example of document status history
noria:EventRecord7 a noria:EventRecord ;
    rdfs:label "TT1 Status Change: InProgress"@en ;
    rdfs:comment "Trouble Ticket TT1 status changed to InProgress."@en ;
    noria:loggingTime "2024-04-20T10:16:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "TT20240420-001 status changed to InProgress."@en ;
    dcterms:references noria:TroubleTicket1 .

noria:EventRecord8 a noria:EventRecord ;
    rdfs:label "TT1 Status Change: Resolved"@en ;
    rdfs:comment "Trouble Ticket TT1 status changed to Resolved."@en ;
    noria:loggingTime "2024-04-20T13:35:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "TT20240420-001 status changed to Resolved."@en ;
    dcterms:references noria:TroubleTicket1 .

noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord7, noria:EventRecord8 .

noria:EventRecord9 a noria:EventRecord ;
    rdfs:label "CR2 Status Change: Implemented"@en ;
    rdfs:comment "Change Request CR2 status changed to Implemented."@en ;
    noria:loggingTime "2024-04-20T10:43:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "CR20240420-001 status changed to Implemented."@en ;
    dcterms:references noria:ChangeRequest2 .

noria:ChangeRequest2 noria:documentStatusHistory noria:EventRecord9 .

# Example of troubleTicketPartyIntervention
noria:TroubleTicket1 noria:troubleTicketPartyIntervention <http://example.com/intervention/TT1_NOC_Initial> .
<http://example.com/intervention/TT1_NOC_Initial> a noria:EventRecord ;
    rdfs:label "NOC Initial Intervention for TT1"@en ;
    rdfs:comment "NOC team started investigation and contacted ISP."@en ;
    noria:loggingTime "2024-04-20T10:18:00Z"^^xsd:dateTime ;
    noria:logOriginatingAgent foaf:Agent2 ;
    noria:logText "NOC team initiated troubleshooting for link failure."@en .

# Example of troubleTicketFreezeItem
noria:EventRecord10 a noria:EventRecord ;
    rdfs:label "TT1 Freeze Start"@en ;
    rdfs:comment "Trouble Ticket TT1 frozen due to external ISP dependency."@en ;
    noria:loggingTime "2024-04-20T10:50:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "TT20240420-001 frozen. Waiting for ISP action."@en .

noria:EventRecord11 a noria:EventRecord ;
    rdfs:label "TT1 Freeze End"@en ;
    rdfs:comment "Trouble Ticket TT1 unfrozen as ISP technician arrived."@en ;
    noria:loggingTime "2024-04-20T11:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "TT20240420-001 unfrozen. ISP technician on site."@en .

noria:TroubleTicket1 noria:troubleTicketFreezeItem noria:EventRecord10, noria:EventRecord11 .

# Example of troubleTicketCharacteristic
noria:TroubleTicket1 noria:troubleTicketCharacteristic <http://example.com/tt_char/impacted_customers_count_100> .
<http://example.com/tt_char/impacted_customers_count_100> a noria:Property ;
    rdfs:label "Impacted Customers Count"@en ;
    rdfs:comment "Number of customers impacted by the incident."@en ;
    rdf:value "100"^^xsd:int .

# Example of troubleTicketNoteCorrelatedExecution
noria:ProcedureExecutionContainer1 a pep:ProcedureExecutionContainer ;
    rdfs:label "ISP Fiber Repair Execution"@en ;
    rdfs:comment "Container for events related to the ISP's fiber repair procedure."@en .

noria:EventRecord12 a noria:EventRecord ;
    rdfs:label "ISP Repair Start Log"@en ;
    rdfs:comment "Log from ISP system indicating start of fiber repair."@en ;
    noria:loggingTime "2024-04-20T12:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://example.com/isp_oss> ;
    noria:logText "Fiber repair initiated on segment X-Y."@en .

noria:EventRecord13 a noria:EventRecord ;
    rdfs:label "ISP Repair Complete Log"@en ;
    rdfs:comment "Log from ISP system indicating completion of fiber repair."@en ;
    noria:loggingTime "2024-04-20T13:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://example.com/isp_oss> ;
    noria:logText "Fiber repair completed. Link restored."@en .

noria:ProcedureExecutionContainer1 ldp:member noria:EventRecord12, noria:EventRecord13 .
noria:TroubleTicketNote3 noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer1 .

# Example of agentManagesResource
foaf:Agent1 noria:agentManagesResource noria:Resource1 .
foaf:Agent2 noria:agentManagesResource noria:Resource2, noria:NetworkLink1, noria:NetworkLink2, noria:NetworkLink3 .
foaf:Agent4 noria:agentManagesResource noria:Resource3, noria:Resource4 .

# Example of elementManagedBy for Application
noria:Application1 noria:elementManagedBy org:OrgUnit1 .
noria:Application3 noria:elementManagedBy org:OrgUnit2 .

# Example of elementDistinguishedName
noria:Resource1 noria:elementDistinguishedName "dns01.corp.example.com" .
noria:ApplicationModule1 noria:functionalElementDistinguishedName "CIA_PROD" .

# Example of structuralElementObservableData
noria:NetworkInterface2 noria:structuralElementObservableData "100"^^xsd:int . # routing priority metric

# Example of structuralElementObservable (as a class instance)
<http://example.com/ni/ge-0-0-0/status_observable> a noria:StructuralObservable ;
    rdfs:label "Operational Status of ge-0/0/0"@en ;
    rdfs:comment "Observable representing the operational status of NetworkInterface2."@en ;
    noria:structuralObservableOf noria:NetworkInterface2 ;
    rdf:value <kos/Resource/OperationalState/Up> .

noria:NetworkInterface2 noria:structuralElementObservable <http://example.com/ni/ge-0-0-0/status_observable> .

# Example of a more complex AnomalyPattern
noria:AnomalyPattern2 a noria:AnomalyPattern ;
    rdfs:label "Database Connection Storm Anomaly"@en ;
    rdfs:comment "Pattern indicating a database connection storm: high rate of database connection errors from multiple application instances, potentially leading to service outage."@en ;
    skos:example "If (EventRecord.logText contains 'Connection timed out' AND EventRecord.logOriginatingManagedObject is noria:ApplicationModule) count > 100 in 1 minute, then anomaly."@en .

# Link EventRecord5 to AnomalyPattern2 as a potential match
noria:EventRecord5 dcterms:relation noria:AnomalyPattern2 .

# Example of a CUid for an agent
noria:CUid2 a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith, a member of Application Support Team A."@en ;
    foaf:accountName "janesmith" ;
    observable:accountIdentifier "JS002" .

foaf:Agent3 foaf:holdsAccount noria:CUid2 .

# Example of a site with geographical coordinates
bot:Site1 wgs84_pos:lat "48.8566"^^xsd:float ;
    wgs84_pos:long "2.3522"^^xsd:float .

# Example of a room containing a locus
noria:Room1 bot:containsZone noria:Locus1, noria:Locus3, noria:Locus4 .
noria:Room2 bot:containsZone noria:Locus2 .

# Example of a resource for multiple applications
noria:Resource4 noria:resourceForApplication noria:Application3, noria:Application4 .

# Example of a service composed of multiple application modules
noria:Service3 a noria:Service ;
    rdfs:label "Internal Monitoring and Alerting Service"@en ;
    rdfs:comment "Service providing monitoring and alerting capabilities for internal IT teams."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:ApplicationModule4 .

# Example of a TroubleTicket related to a Service
noria:TroubleTicket4 a noria:TroubleTicket ;
    rdfs:label "Monitoring System Alert Delay"@en ;
    rdfs:comment "Minor incident: Alerts from Monitoring System X are delayed by several minutes."@en ;
    dcterms:created "2024-04-21T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Internal> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Service3, noria:ApplicationModule4 ;
    noria:troubleTicketRelatedParty foaf:Agent4 .

# Example of a ChangeRequest impacting a Service
noria:ChangeRequest3 a noria:ChangeRequest ;
    rdfs:label "Monitoring System Upgrade"@en ;
    rdfs:comment "Planned upgrade of Monitoring System X to improve performance."@en ;
    dcterms:created "2024-04-19T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Service3, noria:ApplicationModule4 ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent4 .

# Example of an EventRecord related to a Security Incident
noria:EventRecord14 a noria:EventRecord ;
    rdfs:label "Unauthorized Access Attempt"@en ;
    rdfs:comment "Multiple failed login attempts detected on web01.corp.example.com from an unknown IP address."@en ;
    noria:loggingTime "2024-04-20T03:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "SECURITY_ALERT: Failed login attempts from 203.0.113.42 on web01."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logOriginatingAgent <http://example.com/malicious_actor_ip_203.0.113.42> .

<http://example.com/malicious_actor_ip_203.0.113.42> a foaf:Agent ;
    rdfs:label "Unknown Malicious Actor (IP 203.0.113.42)"@en ;
    rdfs:comment "An unknown agent identified by an IP address, suspected of malicious activity."@en .

noria:TroubleTicket5 a noria:TroubleTicket ;
    rdfs:label "Web Server Unauthorized Access Incident"@en ;
    rdfs:comment "Security incident: Unauthorized access attempts detected on Web Server Frontend 01."@en ;
    dcterms:created "2024-04-20T03:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord14 ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent5 ;
    noria:troubleTicketRelatedResource noria:Resource3 .

# Example of a NetworkInterface with optical power averages
noria:NetworkInterface3 noria:networkInterfaceLaserRxOpticalPowerAverage "-4"^^xsd:int .

# Example of a NetworkInterface with description
noria:NetworkInterface1 noria:networkInterfaceDescription "Primary management interface for DNS server."@en .
