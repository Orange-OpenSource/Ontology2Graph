    rdfs:comment "Application log showing a connection error to the database from Customer Portal."@en ;
    noria:loggingTime "2024-04-20T10:12:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Application3 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
