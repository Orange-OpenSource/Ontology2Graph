    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Successful Login by John Doe"@en ;
    rdfs:comment "Audit log entry for John Doe's successful login to esxi01."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource4 ;
    noria:logOriginatingAgent foaf:Agent4 ;
    noria:logText "User 'johndoe' logged in successfully from 192.168.1.50."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord5 a noria:EventRecord ;
