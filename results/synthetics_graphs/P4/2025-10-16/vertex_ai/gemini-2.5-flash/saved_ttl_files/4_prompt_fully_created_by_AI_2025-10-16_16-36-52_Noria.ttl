    dcterms:type <https://w3id.org/noria/kos/Notification/EventType/TicketUpdate> .

# Add more properties to trouble ticket notes
noria:TroubleTicketNote_TT001_Note1
    dcterms:description "The database server's primary data partition reached 98% capacity, causing write failures and application crashes. Initiated log rotation and temporary file deletion."@en .

noria:TroubleTicketNote_TT001_Note2
    dcterms:description "Communicated to the customer via email and phone about the ongoing e-commerce platform outage. Provided an estimated time to restore (ETR) of 2 hours, pending database recovery."@en .

noria:TroubleTicketNote_TT002_Note1
    dcterms:description "Physical inspection of the fiber optic cable and SFP module on Core Router 01's GigabitEthernet 0/0/0 interface. No visible damage. Proceeding to check interface configuration and optical power levels."@en .

# Add more properties to change requests
noria:ChangeRequest_CR001
    dcterms:description "This change request is to expand the storage capacity of the primary database server for the E-commerce Platform to accommodate anticipated data growth and prevent future disk full incidents."@en .

noria:ChangeRequest_CR002
    dcterms:description "Upgrade the operating system of Core Router 01 to the latest stable version to address known security vulnerabilities and improve network performance."@en .

noria:ChangeRequest_CR003
    dcterms:description "Deploy new features including a redesigned product page and an enhanced search functionality to the production E-commerce Platform. Requires a brief service window."@en .

