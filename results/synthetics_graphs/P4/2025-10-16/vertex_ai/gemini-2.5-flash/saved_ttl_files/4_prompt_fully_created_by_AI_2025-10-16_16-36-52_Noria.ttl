<http://example.com/webserver01/cpu_load> a noria:StructuralObservable ;
    rdfs:label "Web Server 01 CPU Load"@en ;
    rdfs:comment "Current CPU load percentage for Web Server 01."@en ;
    noria:structuralObservableOf noria:Resource_WebServer01 ;
    noria:structuralElementObservableData "75"^^xsd:int .

noria:Resource_DBServer01
    seas:hasProperty <http://example.com/dbserver01/disk_free> .

<http://example.com/dbserver01/disk_free> a noria:StructuralObservable ;
    rdfs:label "DB Server 01 Disk Free Space"@en ;
    rdfs:comment "Available disk space in GB for DB Server 01."@en ;
    noria:structuralObservableOf noria:Resource_DBServer01 ;
    noria:structuralElementObservableData "50"^^xsd:int .

