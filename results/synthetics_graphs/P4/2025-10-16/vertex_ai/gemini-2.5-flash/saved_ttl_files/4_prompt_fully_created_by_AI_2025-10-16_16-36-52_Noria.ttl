# =============================================================================

# More resources and their connections
noria:Resource_Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Firewall protecting the corporate network from external threats."@en ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Using a switch model as a placeholder for a firewall product model
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1 ;
    noria:resourceManagementIPAddress <http://fw01.corp.example.com/mgmt-ip> ;
    observable:ipAddress "10.0.0.1"^^xsd:string .

noria:NetworkInterface_Firewall01_Ext a noria:NetworkInterface ;
    rdfs:label "Firewall01 External Interface"@en ;
    rdfs:comment "External interface of Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceDescription "Connected to ISP uplink."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkLink_ISP_Firewall a noria:NetworkLink ;
    rdfs:label "ISP to Firewall Link"@en ;
    rdfs:comment "External link from ISP to Firewall 01."@en ;
    noria:resourceManagedBy foaf:Agent_NetAdmin ;
    noria:networkLinkId "WAN-ISP-FW-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ; # Simplified, assuming core router is the ISP demarcation point
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01 ;
    noria:networkLinkInstallationDate "2022-03-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkInterfaceConnects noria:NetworkInterface_CoreRouter01_Ge0_0_0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_Firewall01_Ext .

# Link applications to resources more explicitly
noria:Application_EcommercePlatform
    noria:resourceForApplication noria:Resource_Firewall01 . # Firewall protects the e-commerce platform

noria:Application_MonitoringSystem
    noria:resourceForApplication noria:Resource_WebServer01 ;
    noria:resourceForApplication noria:Resource_DBServer01 ;
    noria:resourceForApplication noria:Resource_CoreRouter01 ;
    noria:resourceForApplication noria:Resource_Firewall01 .

noria:Application_SecurityPlatform
    noria:resourceForApplication noria:Resource_Firewall01 ;
    noria:resourceForApplication noria:Resource_WebServer01 .

# More events
noria:EventRecord_Firewall_BlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en ;
    rdfs:comment "Alert indicating a high volume of blocked traffic by the firewall."@en ;
    noria:loggingTime "2023-10-26T17:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_SecurityPlatform ;
    noria:logText "Firewall fw01.corp.example.com blocked 1000+ connection attempts from external IPs in 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_WebServer01_ServiceRestart a noria:EventRecord ;
    rdfs:label "Web Server 01 Service Restart"@en ;
    rdfs:comment "Log entry indicating a web service restart on Web Server 01."@en ;
    noria:loggingTime "2023-10-26T14:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Apache service restarted by user 'johndoe'."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Indeterminate> .

# More trouble tickets
noria:TroubleTicket_TT004 a noria:TroubleTicket ;
    rdfs:label "Suspicious Activity on Firewall"@en ;
    rdfs:comment "Security incident: High volume of blocked traffic detected by firewall, potentially a DDoS attempt."@en ;
    dcterms:identifier "TT004" ;
    dcterms:created "2023-10-26T17:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedResource noria:Resource_Firewall01 ;
    noria:troubleTicketRelatedParty foaf:Agent_SecurityTeam ;
    noria:troubleTicketTrigger noria:EventRecord_Firewall_BlockedTraffic ;
    noria:troubleTicketDetectionDateTime "2023-10-26T17:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ; # Can lead to total breakdown
    noria:troubleTicketImpacts noria:Application_EcommercePlatform ;
    noria:troubleTicketImpacts noria:Resource_Firewall01 ;
    noria:troubleTicketSupervisionTool "SIEM" ;
    noria:documentHRef <https://ticketing.example.com/TT004> .

# More change requests
noria:ChangeRequest_CR003 a noria:ChangeRequest ;
    rdfs:label "E-commerce Platform Feature Deployment"@en ;
    rdfs:comment "Deployment of new features for the E-commerce platform."@en ;
    dcterms:identifier "CR003" ;
    dcterms:created "2023-10-28T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2023-11-15T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2023-11-15T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:ApplicationModule_EcommercePlatform_Prod ;
    noria:changeRequestImpact noria:Resource_WebServer01 ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent_DevTeam ;
    noria:changeRequestPilotParty foaf:Agent_DevTeam ;
    noria:changeRequestActorParty foaf:Agent_OpsTeam ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef <https://changemanagement.example.com/CR003> .

# Link agents to resources they manage
foaf:Agent_OpsTeam
    noria:agentManagesResource noria:Resource_WebServer01 ;
    noria:agentManagesResource noria:Resource_VirtualMachine_CRM_App .

foaf:Agent_NetAdmin
    noria:agentManagesResource noria:Resource_CoreRouter01 ;
    noria:agentManagesResource noria:Resource_EdgeSwitch01 ;
    noria:agentManagesResource noria:Resource_LoadBalancer01 ;
    noria:agentManagesResource noria:NetworkLink_WAN_Paris_Lyon .

foaf:Agent_DBAdmin
    noria:agentManagesResource noria:Resource_DBServer01 .

foaf:Agent_SecurityTeam
    noria:agentManagesResource noria:Resource_Firewall01 .

# Link applications to their modules
noria:Application_EcommercePlatform
    seas:subSystem noria:ApplicationModule_EcommercePlatform_Prod ;
    seas:subSystem noria:ApplicationModule_EcommercePlatform_Dev .

noria:Application_InternalCRM
    seas:subSystem noria:ApplicationModule_InternalCRM_Prod .

# Link services to their components
noria:Service_PublicWebAccess
    seas:subSystem noria:Application_EcommercePlatform ;
    seas:subSystem noria:Resource_LoadBalancer01 .

noria:Service_CorporateVPN
    seas:subSystem noria:Resource_CoreRouter01 ;
    seas:subSystem noria:Resource_EdgeSwitch01 ;
    seas:subSystem noria:NetworkLink_WAN_Paris_Lyon .

# Add more properties to existing entities for density
noria:Resource_WebServer01
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_WebServer01_Eth0
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -8 .

noria:NetworkInterface_CoreRouter01_Ge0_0_0
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:TroubleTicket_TT001
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketCause "Database disk full, leading to service crash."@en .

noria:TroubleTicket_TT002
    noria:problemCategory <kos/TroubleTicket/trouble-category/PerformanceDegradation> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketCause "Fiber cut on WAN link between Paris and Lyon."@en .

noria:ChangeRequest_CR001
    noria:changeRequestSpecification <kos/ChangeRequest/specification/DiskExpansionProcedure> .

<kos/ChangeRequest/specification/DiskExpansionProcedure> a skos:Concept ; rdfs:label "Disk Expansion Procedure"@en .
<https://w3id.org/noria/kos/application/sla-level/Platinum> a skos:Concept ; rdfs:label "Platinum SLA Level"@en .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA Level"@en .

