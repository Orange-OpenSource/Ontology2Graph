# Add more event records for a richer history
noria:EventRecord_DBServer01_DiskCleaned a noria:EventRecord ;
    rdfs:label "DB Server 01 Disk Cleaned"@en ;
    rdfs:comment "Log entry indicating successful disk cleanup on DB Server 01."@en ;
    noria:loggingTime "2023-10-26T17:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Disk /var/lib/mysql on db01.corp.example.com is now 45% full after cleanup."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Indeterminate> ;
    noria:alarmMitigatedBy noria:TroubleTicket_TT001 . # This event helped mitigate the TT001 issue

noria:EventRecord_CoreRouter01_InterfaceUp a noria:EventRecord ;
    rdfs:label "Core Router 01 Interface Up"@en ;
    rdfs:comment "Log entry indicating an interface on Core Router 01 came back up."@en ;
    noria:loggingTime "2023-10-26T16:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_NetAdmin ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Indeterminate> ;
    noria:alarmMitigatedBy noria:TroubleTicket_TT002 . # This event helped mitigate the TT002 issue

# Link more events to trouble tickets
noria:TroubleTicket_TT001
    dcterms:relation noria:EventRecord_WebServer01_CPUHigh . # High CPU might be a symptom of DB issues

noria:TroubleTicket_TT004
    dcterms:relation noria:EventRecord_SecurityAlert_SQLInjection .

# Add a procedural element for anomaly detection
noria:AnomalyPattern_HighCPUDetection a noria:AnomalyPattern ;
    rdfs:label "High CPU Anomaly Pattern"@en ;
    rdfs:comment "Pattern detecting sustained high CPU usage on servers, indicating potential performance issues or attacks."@en ;
    folio:hasCause "Excessive resource consumption"@en ;
    folio:hasEffect "Service degradation or outage"@en .

noria:Application_MonitoringSystem
    seas:monitors noria:AnomalyPattern_HighCPUDetection . # Monitoring system is configured to detect this pattern

noria:EventRecord_WebServer01_CPUHigh
    dcterms:conformsTo noria:AnomalyPattern_HighCPUDetection . # This event conforms to the anomaly pattern

