noria:Resource_VirtualMachine_CRM_App a noria:Resource ;
    rdfs:label "Virtual Machine CRM App"@en ;
    rdfs:comment "Virtual machine hosting the CRM application."@en ;
    noria:resourceManagedBy foaf:Agent_OpsTeam ;
    noria:resourceHostName "crm-vm01.corp.example.com" ;
