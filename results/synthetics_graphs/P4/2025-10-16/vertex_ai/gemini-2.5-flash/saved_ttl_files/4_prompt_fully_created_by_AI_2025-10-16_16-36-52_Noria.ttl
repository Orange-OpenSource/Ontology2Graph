noria:TroubleTicket_TT001
    noria:documentStatusHistory noria:EventRecord_TT001_StatusChange_InProgress ;
    noria:documentStatusHistory noria:EventRecord_TT001_StatusChange_Resolved .

noria:EventRecord_TT001_StatusChange_InProgress a noria:EventRecord ;
