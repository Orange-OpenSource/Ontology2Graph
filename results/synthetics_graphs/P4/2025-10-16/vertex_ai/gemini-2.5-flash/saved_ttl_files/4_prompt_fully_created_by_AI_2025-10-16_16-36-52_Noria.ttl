noria:ChangeRequest_CR001
    noria:documentStatusHistory noria:EventRecord_CR001_StatusChange_Approved ;
    noria:documentStatusHistory noria:EventRecord_CR001_StatusChange_Implemented .

noria:EventRecord_CR001_StatusChange_Approved a noria:EventRecord ;
