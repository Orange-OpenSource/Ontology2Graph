# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (for properties with skos:inScheme restrictions)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure"@en .
<kos/application/type/business-application> a skos:Concept ; rdfs:label "Business Application"@en .
<kos/application/type/monitoring-system> a skos:Concept ; rdfs:label "Monitoring System"@en .
<kos/application/type/database-management> a skos:Concept ; rdfs:label "Database Management"@en .
<kos/application/type/security-platform> a skos:Concept ; rdfs:label "Security Platform"@en .

<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High"@en .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium"@en .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low"@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; rdfs:label "En Production"@fr .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en ; rdfs:label "En Développement"@fr .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; rdfs:label "Maintenance"@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor"@en .
<kos/TroubleTicket/severity/Warning> a skos:Concept ; rdfs:label "Warning"@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance"@en .
<kos/TroubleTicket/type/Maintenance> a skos:Concept ; rdfs:label "Maintenance"@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision"@en .
<kos/TroubleTicket/origin/Internal> a skos:Concept ; rdfs:label "Internal"@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en .
<kos/TroubleTicket/status/Initialised> a skos:Concept ; rdfs:label "Initialised"@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention"@en .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention"@en .

<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ; rdfs:label "Total Breakdown"@en .
<kos/TroubleTicket/trouble-category/IsolatedCustomerSite> a skos:Concept ; rdfs:label "Isolated Customer Site"@en .
<kos/TroubleTicket/trouble-category/PerformanceDegradation> a skos:Concept ; rdfs:label "Performance Degradation"@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; rdfs:label "Managed Backbone Networks"@en .
<kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> a skos:Concept ; rdfs:label "Contract Application Hosting Services"@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer"@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis"@en .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; rdfs:label "Tests and Measurements"@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention"@en .
<kos/ChangeRequest/category/CustomerIntervention> a skos:Concept ; rdfs:label "Customer Intervention"@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency"@en .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; rdfs:label "Configuration"@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented"@en .
<kos/ChangeRequest/status/Scheduled> a skos:Concept ; rdfs:label "Scheduled"@en .

<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server"@en .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router"@en .
<kos/Resource/type/Switch> a skos:Concept ; rdfs:label "Switch"@en .
<kos/Resource/type/LoadBalancer> a skos:Concept ; rdfs:label "Load Balancer"@en .
<kos/Resource/type/Firewall> a skos:Concept ; rdfs:label "Firewall"@en .
<kos/Resource/type/DatabaseServer> a skos:Concept ; rdfs:label "Database Server"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine"@en .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ; rdfs:label "In Production"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned"@en .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; rdfs:label "Staging"@en .

<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Up"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Down"@en .
<kos/Resource/OperationalState/Degraded> a skos:Concept ; rdfs:label "Degraded"@en .

<kos/Resource/AdministrativeState/Up> a skos:Concept ; rdfs:label "Up"@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Down"@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning"@en .
<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ; rdfs:label "Indeterminate"@en .

<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone"@en .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; rdfs:label "Ticketing System"@en .

<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_OpsTeam a foaf:Agent ;
    rdfs:label "Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate critical issues via hotline, use ticketing system for all other issues."@en .

foaf:Agent_DevTeam a foaf:Agent ;
    rdfs:label "Development Team"@en ;
    rdfs:comment "Team responsible for application development and maintenance."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_NetAdmin a foaf:Agent ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Team managing network infrastructure."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_DBAdmin a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing database servers and services."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the Operations Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Development Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit_ITOperations a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Main department for IT infrastructure and service management."@en ;
    org:hasMember foaf:Agent_OpsTeam .

org:OrgUnit_NetworkServices a org:OrganizationalUnit ;
    rdfs:label "Network Services Division"@en ;
    rdfs:comment "Specialized division for network architecture and support."@en ;
    org:hasMember foaf:Agent_NetAdmin .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series Switch"@en ;
    rdfs:comment "Data center-grade network switch."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480 Router"@en ;
    rdfs:comment "High-capacity edge router for service providers."@en ;
    noria:productManufacturedBy <https://www.juniper.net> .

noria:ProductModel_F5BigIP a noria:ProductModel ;
    rdfs:label "F5 BIG-IP iSeries Load Balancer"@en ;
    rdfs:comment "Application delivery controller and load balancer."@en ;
    noria:productManufacturedBy <https://www.f5.com> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com> .

# =============================================================================
# Locations
# =============================================================================

bot:Site_DC_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@fr ;
    noria:sitePrincipalAddressCityName "Paris"@fr ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site_Office_Lyon a bot:Site ;
    rdfs:label "Lyon Office Building"@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès"@fr ;
    noria:sitePrincipalAddressCityName "Lyon"@fr ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoom_A a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack_A1 .

noria:Room_NetworkCloset_B a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace noria:Locus_Rack_B3 .

noria:Locus_Rack_A1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical servers in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_Rack_B3 a noria:Locus ;
    rdfs:label "Rack B3"@en ;
    rdfs:comment "Location of edge network devices in Network Closet B."@en ;
    noria:locusLine "B" ;
    noria:locusRow "3" .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_WebServer01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server for the E-commerce platform."@en ;
    noria:resourceManagedBy foaf:Agent_OpsTeam ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1 ;
    noria:resourceManagementIPAddress <http://web01.corp.example.com/mgmt-ip> ; # Example URI for IP address
    observable:ipAddress "10.0.0.10"^^xsd:string .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Primary database server for the E-commerce platform."@en ;
    noria:resourceManagedBy foaf:Agent_DBAdmin ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/DatabaseServer> ;
    noria:resourceSerialNumber "SN-DB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1 ;
    noria:resourceManagementIPAddress <http://db01.corp.example.com/mgmt-ip> ;
    observable:ipAddress "10.0.0.20"^^xsd:string .

noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent_NetAdmin ;
    noria:resourceHostName "cr01.paris.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_A1 ;
    noria:resourceManagementIPAddress <http://cr01.paris.example.com/mgmt-ip> ;
    observable:ipAddress "172.16.0.1"^^xsd:string .

noria:Resource_EdgeSwitch01 a noria:Resource ;
    rdfs:label "Edge Switch 01"@en ;
    rdfs:comment "Edge switch for Lyon office network."@en ;
    noria:resourceManagedBy foaf:Agent_NetAdmin ;
    noria:resourceHostName "es01.lyon.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-ES-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-10T14:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack_B3 ;
    noria:resourceManagementIPAddress <http://es01.lyon.example.com/mgmt-ip> ;
    observable:ipAddress "192.168.1.1"^^xsd:string .

noria:Resource_LoadBalancer01 a noria:Resource ;
    rdfs:label "Load Balancer 01"@en ;
    rdfs:comment "Load balancer for external web traffic."@en ;
    noria:resourceManagedBy foaf:Agent_NetAdmin ;
    noria:resourceHostName "lb01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_F5BigIP ;
    noria:resourceType <kos/Resource/type/LoadBalancer> ;
    noria:resourceSerialNumber "SN-LB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
