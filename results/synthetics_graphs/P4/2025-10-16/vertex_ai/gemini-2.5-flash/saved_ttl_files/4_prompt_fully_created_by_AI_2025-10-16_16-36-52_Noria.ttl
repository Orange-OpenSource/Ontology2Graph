# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan_DiskCleanup a noria:OperationPlan ;
    rdfs:label "Database Disk Cleanup Procedure"@en ;
    rdfs:comment "Standard operating procedure for clearing temporary files and logs on database servers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DiskFull ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DiskSpaceFreed .

noria:ActionPreCondition_DiskFull a noria:ActionPreCondition ;
    rdfs:label "Disk Full Condition"@en ;
    rdfs:comment "Condition where a server's disk partition is above 90% utilization."@en ;
    skos:example "Disk usage > 90% on critical partition."@en .

noria:ActionPostCondition_DiskSpaceFreed a noria:ActionPostCondition ;
    rdfs:label "Disk Space Freed"@en ;
    rdfs:comment "Expected outcome: disk utilization reduced below 80%."@en ;
    skos:example "Disk usage < 80% after cleanup."@en .

noria:OperationPlan_InterfaceTroubleshooting a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Guide"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues with network interfaces."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Condition"@en ;
    rdfs:comment "Condition where a network interface's operational status is 'down'."@en ;
    skos:example "Interface operational status is 'down'."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up"@en ;
    rdfs:comment "Expected outcome: network interface operational status is 'up'."@en ;
    skos:example "Interface operational status is 'up'."@en .

# =============================================================================
# Connections between Dynamic and Procedural Elements
# =============================================================================

noria:TroubleTicketNote_TT001_Note1
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_UserLogin_JohnDoe . # Example: John Doe's login is part of the diagnosis procedure.

noria:EventRecord_DBServer01_DiskFull
    noria:alarmProposedRepairAction noria:OperationPlan_DiskCleanup .

noria:EventRecord_CoreRouter01_InterfaceDown
    noria:alarmProposedRepairAction noria:OperationPlan_InterfaceTroubleshooting .

