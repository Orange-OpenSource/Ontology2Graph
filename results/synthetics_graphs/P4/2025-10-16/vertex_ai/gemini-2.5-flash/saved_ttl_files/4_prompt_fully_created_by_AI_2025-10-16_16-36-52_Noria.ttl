<https://w3id.org/noria/kos/Notification/EventType/TicketUpdate> a skos:Concept ; rdfs:label "Ticket Update Event Type"@en .

noria:EventRecord_TT001_StatusChange_Resolved
    dcterms:title "Trouble Ticket Status Update" ;
    dcterms:type <https://w3id.org/noria/kos/Notification/EventType/TicketUpdate> .

noria:EventRecord_CR001_StatusChange_Approved
    dcterms:title "Change Request Status Update" ;
    dcterms:type <https://w3id.org/noria/kos/Notification/EventType/TicketUpdate> .

noria:EventRecord_CR001_StatusChange_Implemented
