<https://w3id.org/noria/kos/Notification/EventType/MaintenanceActivity> a skos:Concept ; rdfs:label "Maintenance Activity Event Type"@en .

noria:EventRecord_CoreRouter01_InterfaceUp
    dcterms:title "Network Interface Restored" ;
    dcterms:type <https://w3id.org/noria/kos/Notification/EventType/StateChange> .

noria:EventRecord_TT001_StatusChange_InProgress
    dcterms:title "Trouble Ticket Status Update" ;
