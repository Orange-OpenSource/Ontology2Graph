# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_WebServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebServer01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to internal network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_DBServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DB Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to database network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_CoreRouter01_Ge0_0_0 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to WAN."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "WAN uplink to ISP A."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_CoreRouter01_Ge0_0_1 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface from Core Router 01 to internal network."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Internal LAN segment."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_EdgeSwitch01_Fa0_1 a noria:NetworkInterface ;
    rdfs:label "EdgeSwitch01 FastEthernet 0/1"@en ;
    rdfs:comment "Uplink interface from Edge Switch 01 to Core Router."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeSwitch01 ;
