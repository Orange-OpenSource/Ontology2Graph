# --- Document Attachments ---
noria:DocAttachment_DNSReport a noria:DocumentAttachment ;
    rdfs:label "DNS Server Health Report"@en ;
    rdfs:comment "PDF report detailing the health status of the DNS server prior to the outage."@en ;
    dcterms:identifier "DOC-DNS-001" ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage ;
    dcterms:format "application/pdf" ;
    dcterms:source <http://docs.example.com/reports/DNS_Health_Report_20231025.pdf> .

noria:DocAttachment_UpgradePlan a noria:DocumentAttachment ;
    rdfs:label "Router Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the Edge Router software upgrade."@en ;
    dcterms:identifier "DOC-CR-001" ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:source <http://docs.example.com/plans/EdgeRouter_Upgrade_Plan_V1.docx> .

# --- Procedural Elements ---
noria:OperationPlan_RestartDNSService a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the DNS service on a server."@en ;
    skos:example "Steps: 1. SSH to server. 2. Check service status. 3. Restart service. 4. Verify service status."@en ;
    noria:operationPlanPreCondition noria:PreCond_DNSServiceDown ;
    noria:operationPlanPostCondition noria:PostCond_DNSServiceUp .

noria:OperationPlan_CheckFiberLink a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Procedure for diagnosing issues on a fiber optic network link."@en ;
    skos:example "Steps: 1. Check optical power levels. 2. Inspect fiber cables. 3. Test with loopback."@en ;
    noria:operationPlanPreCondition noria:PreCond_InterfaceDown ;
    noria:operationPlanPostCondition noria:PostCond_LinkStatusKnown .

noria:OperationPlan_SoftwareUpgrade a noria:OperationPlan ;
    rdfs:label "Network Device Software Upgrade Procedure"@en ;
    rdfs:comment "Standard procedure for upgrading software on network devices."@en ;
    skos:example "Steps: 1. Backup configuration. 2. Download new image. 3. Install image. 4. Reboot. 5. Verify operation."@en ;
    noria:operationPlanPreCondition noria:PreCond_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:PostCond_SoftwareUpgraded .

# --- Action Pre/Post Conditions ---
noria:PreCond_DNSServiceDown a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down Pre-Condition"@en ;
    rdfs:comment "Condition: DNS service is not running or unreachable."@en .

noria:PostCond_DNSServiceUp a noria:ActionPostCondition ;
    rdfs:label "DNS Service Up Post-Condition"@en ;
    rdfs:comment "Outcome: DNS service is running and responsive."@en .

noria:PreCond_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition: A network interface reports an operational 'down' status."@en .

noria:PostCond_LinkStatusKnown a noria:ActionPostCondition ;
    rdfs:label "Link Status Known Post-Condition"@en ;
    rdfs:comment "Outcome: The cause of the link status (e.g., cable fault, administrative shutdown) is identified."@en .

noria:PreCond_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Pre-Condition"@en ;
    rdfs:comment "Condition: The change is scheduled within an approved maintenance window."@en .

noria:PostCond_SoftwareUpgraded a noria:ActionPostCondition ;
    rdfs:label "Software Upgraded Post-Condition"@en ;
    rdfs:comment "Outcome: Device software is successfully upgraded and verified."@en .

# --- Anomaly Patterns ---
noria:AnomalyPattern_BruteForce a noria:AnomalyPattern ;
    rdfs:label "Brute Force Attack Pattern"@en ;
    rdfs:comment "Pattern indicating multiple failed login attempts from a single source IP within a short period."@en ;
    skos:example "Detect 5+ failed login attempts from the same IP to the same host within 60 seconds."@en .

# --- Additional connections for density ---
foaf:Agent1 noria:agentManagesResource noria:Resource_DNS01, noria:Resource_VirtualHost01 .
foaf:Agent2 noria:agentManagesResource noria:Resource_CoreSwitch01, noria:Resource_EdgeRouter01 .
foaf:Agent3 noria:agentManagesResource noria:Resource_WebSrv01, noria:Resource_VirtualMachine_AppDB .
