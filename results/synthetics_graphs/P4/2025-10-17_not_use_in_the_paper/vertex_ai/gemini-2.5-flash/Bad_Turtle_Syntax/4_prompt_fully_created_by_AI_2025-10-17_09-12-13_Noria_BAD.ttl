    noria:resourceManagementIPAddress <http://ip.example.com/10.0.0.21> ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# --- Network Interfaces ---
noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Management interface for DNS01" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Application Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Application traffic interface for WebSrv01" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_CoreSwitch01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CoreSwitch01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Uplink interface from CoreSwitch01 to EdgeRouter01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreSwitch01 ;
    noria:networkInterfaceDescription "Uplink to Edge Router 01" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

noria:NI_CoreSwitch01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "CoreSwitch01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting DNS01 to CoreSwitch01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreSwitch01 ;
    noria:networkInterfaceDescription "Connection to DNS Server 01" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_CoreSwitch01_Gi0_0_3 a noria:NetworkInterface ;
    rdfs:label "CoreSwitch01 GigabitEthernet 0/0/3"@en ;
    rdfs:comment "Interface connecting WebSrv01 to CoreSwitch01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreSwitch01 ;
    noria:networkInterfaceDescription "Connection to Web Server 01" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_CoreSwitch01_Gi0_0_4 a noria:NetworkInterface ;
    rdfs:label "CoreSwitch01 GigabitEthernet 0/0/4"@en ;
    rdfs:comment "Interface connecting VirtualHost01 to CoreSwitch01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreSwitch01 ;
    noria:networkInterfaceDescription "Connection to ESXi Host 01" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_EdgeRouter01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "EdgeRouter01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Downlink interface from EdgeRouter01 to CoreSwitch01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouter01 ;
    noria:networkInterfaceDescription "Downlink to Core Switch 01" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-6"^^xsd:int ;
