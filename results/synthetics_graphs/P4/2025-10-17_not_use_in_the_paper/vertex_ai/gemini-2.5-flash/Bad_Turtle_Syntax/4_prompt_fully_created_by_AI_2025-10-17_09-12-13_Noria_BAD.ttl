# --- Event Records ---
noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    dcterms:type <kos/Notification/EventType/OperationalAlarm> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartDNSService ;
    noria:alarmMitigatedBy noria:TroubleTicket_DNSOutage .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Network Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface went down on CoreSwitch01."@en ;
    noria:loggingTime "2023-10-26T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreSwitch01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckFiberLink .

noria:EventRecord_LoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt Log"@en ;
    rdfs:comment "Security log entry for a failed login attempt on WebSrv01."@en ;
    noria:loggingTime "2023-10-26T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent noria:CUid_JohnDoe ; # Example of a user attempting to log in
    noria:logText "Failed login for user 'jdoe' from IP 192.168.1.100."@en ;
    dcterms:type <kos/Notification/EventType/SecurityAlarm> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Configuration Change Log"@en ;
    rdfs:comment "Log entry indicating a configuration change on EdgeRouter01."@en ;
    noria:loggingTime "2023-10-25T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_EdgeRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent5 ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by vty0 (10.0.0.5)."@en ;
    dcterms:type <kos/Notification/EventType/ConfigurationChange> ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade .

noria:EventRecord_DNSServiceRestarted a noria:EventRecord ;
    rdfs:label "DNS Service Restarted Log"@en ;
    rdfs:comment "Log entry confirming the DNS service restart."@en ;
    noria:loggingTime "2023-10-26T10:18:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent4 ;
    noria:logText "DNS service 'named' restarted successfully."@en ;
    dcterms:type <kos/Notification/EventType/ServiceOperation> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    pep:usedProcedure noria:OperationPlan_RestartDNSService .

noria:EventRecord_RouterUpgradeStart a noria:EventRecord ;
    rdfs:label "Router Upgrade Started Log"@en ;
    rdfs:comment "Log entry indicating the start of the router software upgrade."@en ;
    noria:loggingTime "2023-11-01T02:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_EdgeRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent5 ;
    noria:logText "Software upgrade initiated on Edge Router 01."@en ;
    dcterms:type <kos/Notification/EventType/ConfigurationChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    pep:usedProcedure noria:OperationPlan_SoftwareUpgrade ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade .

noria:EventRecord_RouterUpgradeEnd a noria:EventRecord ;
    rdfs:label "Router Upgrade Completed Log"@en ;
    rdfs:comment "Log entry indicating the completion of the router software upgrade."@en ;
    noria:loggingTime "2023-11-01T03:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_EdgeRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent5 ;
    noria:logText "Software upgrade completed successfully on Edge Router 01. System rebooted."@en ;
    dcterms:type <kos/Notification/EventType/ConfigurationChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    pep:usedProcedure noria:OperationPlan_SoftwareUpgrade ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade .

# --- Trouble Tickets ---
noria:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "Critical DNS Outage"@en, "Panne DNS Critique"@fr ;
    rdfs:comment "Incident reported due to primary DNS server being unreachable, impacting corporate internet access."@en ;
    dcterms:identifier "TT-20231026-001" ;
    dcterms:created "2023-10-26T09:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkFailure> ;
    noria:troubleTicketCause "Unidentified software crash on DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2023-10-26T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2023-10-26T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2023-10-26T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent1, foaf:Agent2 ;
    noria:troubleTicketRelatedService noria:Application_DNSInfrastructure, noria:Service_InternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:Application_DNSInfrastructure, noria:Service_InternetAccess, noria:Resource_DNS01 ;
    noria:documentHRef <http://ticketing.example.com/TT-20231026-001> ;
    noria:documentStatusHistory noria:EventRecord_DNSOutageLog, noria:EventRecord_DNSServiceRestarted ;
    ldp:member noria:TroubleTicketNote_DNSInvestigation, noria:TroubleTicketNote_DNSResolution .

noria:TroubleTicket_CustomerPortalSlowness a noria:TroubleTicket ;
    rdfs:label "Customer Portal Slowness"@en, "Lenteur Portail Client"@fr ;
    rdfs:comment "Customers reporting slow response times on the main portal application."@en ;
    dcterms:identifier "TT-20231026-002" ;
    dcterms:created "2023-10-26T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/DegradedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Customer Feedback"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ApplicationPerformance> ;
    noria:troubleTicketCause "Unconfirmed, possibly database contention."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2023-10-26T09:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2023-10-26T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedParty foaf:Agent3 ;
    noria:troubleTicketRelatedService noria:AppModule_CustomerPortal_Prod ;
    noria:troubleTicketRelatedResource noria:Resource_WebSrv01, noria:Resource_VirtualMachine_AppDB ;
