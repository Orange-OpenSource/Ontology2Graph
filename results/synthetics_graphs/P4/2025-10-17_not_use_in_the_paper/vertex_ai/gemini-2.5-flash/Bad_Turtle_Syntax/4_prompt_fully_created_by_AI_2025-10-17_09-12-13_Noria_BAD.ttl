    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://ip.example.com/10.0.0.30> .

noria:Resource_VirtualMachine_AppDB a noria:Resource ;
    rdfs:label "Application Database VM"@en, "VM Base de Données Application"@fr ;
    rdfs:comment "Virtual machine hosting the database for the Customer Portal application."@en ;
    noria:resourceManagedBy foaf:Agent3 ;
    noria:resourceHostName "appdb01.app.example.com" ;
