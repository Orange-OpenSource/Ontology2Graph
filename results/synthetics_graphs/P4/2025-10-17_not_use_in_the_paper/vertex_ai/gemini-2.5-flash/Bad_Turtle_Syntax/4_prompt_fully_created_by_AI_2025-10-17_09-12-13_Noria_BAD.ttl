    dcterms:creator foaf:Agent4 ;
    dcterms:description "Restarted DNS service. Server now responding. Monitoring for stability."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/CorrectiveAction> ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage ;
