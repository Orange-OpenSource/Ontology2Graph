    noria:documentHRef <http://ticketing.example.com/TT-20231026-002> .

# --- Trouble Ticket Notes ---
noria:TroubleTicketNote_DNSInvestigation a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Investigation Note"@en ;
    rdfs:comment "Initial investigation steps for the DNS outage."@en ;
