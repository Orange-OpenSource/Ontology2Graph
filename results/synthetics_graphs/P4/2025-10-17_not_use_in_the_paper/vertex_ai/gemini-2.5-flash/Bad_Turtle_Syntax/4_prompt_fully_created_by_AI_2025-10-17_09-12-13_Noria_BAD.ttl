    noria:resourceHostName "websrv01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-R740-002" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://ip.example.com/10.0.0.20> ;
    noria:resourceForApplication noria:Application_CustomerPortal .

noria:Resource_CoreSwitch01 a noria:Resource ;
    rdfs:label "Core Network Switch 01"@en, "Commutateur Réseau Central 01"@fr ;
    rdfs:comment "Primary core switch in Paris DC, managed by NOC."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "coresw01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel2 ;
    noria:resourceLogisticId "ASSET-CSW-001" ;
    noria:resourceType <kos/Resource/type/NetworkDevice> ;
    noria:resourceSerialNumber "SN-C9300-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-11-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://ip.example.com/10.0.0.1> .

noria:Resource_EdgeRouter01 a noria:Resource ;
    rdfs:label "Edge Router 01"@en, "Routeur de Bordure 01"@fr ;
    rdfs:comment "Edge router connecting Paris DC to external networks."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "edger01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel4 ;
    noria:resourceLogisticId "ASSET-ER-001" ;
    noria:resourceType <kos/Resource/type/NetworkDevice> ;
    noria:resourceSerialNumber "SN-MX480-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-10-20T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://ip.example.com/10.0.0.5> .

noria:Resource_VirtualHost01 a noria:Resource ;
    rdfs:label "VMware ESXi Host 01"@en, "Hôte VMware ESXi 01"@fr ;
    rdfs:comment "Physical server acting as a virtualization host."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "esxi01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel3 ;
    noria:resourceLogisticId "ASSET-ESXI-001" ;
