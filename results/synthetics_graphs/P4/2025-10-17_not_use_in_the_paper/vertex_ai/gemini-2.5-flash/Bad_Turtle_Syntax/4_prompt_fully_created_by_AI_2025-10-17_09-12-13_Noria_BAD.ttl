# --- Network Links ---
noria:NL_CoreSwitch01_EdgeRouter01 a noria:NetworkLink ;
    rdfs:label "CoreSwitch01 to EdgeRouter01 Link"@en ;
    rdfs:comment "High-speed fiber link between core switch and edge router in Paris DC."@en ;
    noria:networkLinkId "NL-DC-001" ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:networkLinkTerminationResource noria:Resource_CoreSwitch01, noria:Resource_EdgeRouter01 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreSwitch01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeRouter01 ;
    noria:networkLinkInstallationDate "2021-11-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 10Gbps"@en ;
    noria:networkInterfaceConnects noria:NI_CoreSwitch01_Gi0_0_1, noria:NI_EdgeRouter01_Gi0_0_0 .

noria:NL_DNS01_CoreSwitch01 a noria:NetworkLink ;
    rdfs:label "DNS01 to CoreSwitch01 Link"@en ;
    rdfs:comment "Ethernet link connecting DNS server to core switch."@en ;
    noria:networkLinkId "NL-DC-002" ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:networkLinkTerminationResource noria:Resource_DNS01, noria:Resource_CoreSwitch01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps"@en ;
    noria:networkInterfaceConnects noria:NI_DNS01_Eth0, noria:NI_CoreSwitch01_Gi0_0_2 .

noria:NL_WebSrv01_CoreSwitch01 a noria:NetworkLink ;
    rdfs:label "WebSrv01 to CoreSwitch01 Link"@en ;
    rdfs:comment "Ethernet link connecting Web server to core switch."@en ;
    noria:networkLinkId "NL-DC-003" ;
    noria:resourceManagedBy foaf:Agent3 ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv01, noria:Resource_CoreSwitch01 ;
    noria:networkLinkInstallationDate "2022-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps"@en ;
    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0, noria:NI_CoreSwitch01_Gi0_0_3 .

noria:NL_VirtualHost01_CoreSwitch01 a noria:NetworkLink ;
    rdfs:label "VirtualHost01 to CoreSwitch01 Link"@en ;
    rdfs:comment "Ethernet link connecting ESXi host to core switch."@en ;
    noria:networkLinkId "NL-DC-004" ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:networkLinkTerminationResource noria:Resource_VirtualHost01, noria:Resource_CoreSwitch01 ;
    noria:networkLinkInstallationDate "2022-02-10T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps"@en ;
    noria:networkInterfaceConnects noria:NI_VirtualHost01_vSwitch0, noria:NI_CoreSwitch01_Gi0_0_4 .

# --- Applications ---
noria:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal"@en, "Portail Client"@fr ;
    rdfs:comment "Main web application for customer interaction and self-service."@en ;
    noria:applicationModelIdentifier "CP-V2" ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CUSTPORT" ;
