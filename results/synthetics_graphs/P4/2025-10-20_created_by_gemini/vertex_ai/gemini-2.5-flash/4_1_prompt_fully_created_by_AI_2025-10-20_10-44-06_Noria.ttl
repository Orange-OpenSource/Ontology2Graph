# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OperationPlan_RouterFirmwareUpgradeProcedure a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en, "Procédure de Mise à Jour Firmware Routeur"@fr ;
    rdfs:comment "Standard operating procedure for upgrading router firmware, including pre-checks and post-checks."@en .

noria:ActionPreCondition_RouterReachabilityCheck a noria:ActionPreCondition ;
    rdfs:label "Router Reachability Check"@en, "Vérification Accessibilité Routeur"@fr ;
    rdfs:comment "Verify router is reachable via ping and SSH before starting upgrade."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_RouterFirmwareUpgradeProcedure .

noria:ActionPostCondition_RouterServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Router Service Restored"@en, "Service Routeur Rétabli"@fr ;
    rdfs:comment "Confirm all network services routed through the device are operational after upgrade."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_RouterFirmwareUpgradeProcedure .

noria:OperationPlan_DNSFailoverProcedure a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en, "Procédure de Basculement DNS"@fr ;
    rdfs:comment "Procedure to manually trigger DNS failover to a secondary server in case of primary server failure."@en .

noria:ActionPreCondition_PrimaryDNSDown a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Down"@en, "Serveur DNS Principal Hors Service"@fr ;
    rdfs:comment "Condition: Primary DNS server is confirmed to be down and unresponsive."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_DNSFailoverProcedure .

noria:ActionPostCondition_DNSResolutionWorking a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Working"@en, "Résolution DNS Fonctionnelle"@fr ;
    rdfs:comment "Confirm DNS resolution is working correctly via secondary server after failover."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_DNSFailoverProcedure .

# Linking Change Request to Operation Plan
noria:ChangeRequest_RouterUpgrade_001 noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterFirmwareUpgradeProcedure .

# Linking Event Record to Proposed Repair Action (Operation Plan)
noria:EventRecord_DNSOutageLog noria:alarmProposedRepairAction noria:OperationPlan_DNSFailoverProcedure .

# Linking Event Record to Mitigation (Trouble Ticket as ProcedureExecutionContainer)
noria:EventRecord_DNSOutageLog noria:alarmMitigatedBy noria:TroubleTicket_DNS_CRITICAL_001 .
