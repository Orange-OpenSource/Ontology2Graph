# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizations
org:InternalITDept a org:OrganizationalUnit ;
    rdfs:label "Internal IT Department"@en, "Département IT Interne"@fr ;
    rdfs:comment "The main internal IT department responsible for overall infrastructure."@en .

org:NetworkOperationsCenter a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en, "Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "Team responsible for 24/7 network monitoring and initial incident response."@en ;
    org:unitOf org:InternalITDept .

org:ServerAdminTeam a org:OrganizationalUnit ;
