# =============================================================================
# Services
# =============================================================================

noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en, "Service d'Accès Internet d'Entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet access to all corporate users."@en ;
    noria:serviceType <kos/service/type/customer-facing> ;
    seas:subSystemOf noria:Application_CorpDNS ; # DNS is a component of internet access
    seas:subSystemOf noria:Application_WebPortal ; # Web portal relies on internet access
    seas:subSystemOf noria:Resource_RouterCore1_PAR ;
    seas:subSystemOf noria:Resource_FirewallDMZ_PAR .

noria:Service_InternalVPN a noria:Service ;
    rdfs:label "Internal VPN Service"@en, "Service VPN Interne"@fr ;
    rdfs:comment "Service providing secure internal network access for remote employees."@en ;
    noria:serviceType <kos/service/type/resource-facing> ;
    seas:subSystemOf noria:Resource_FirewallDMZ_PAR . # Firewall is a key component of VPN

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en, "Log Serveur DNS Inaccessible"@fr ;
    rdfs:comment "Log entry indicating that the primary DNS server became unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01_PAR ;
    noria:logOriginatingManagementSystem noria:Application_LogManagement ;
    noria:logText "CRITICAL: DNS server dns01.corp.example.com is unreachable via ICMP."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_RouterConfigChange a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en, "Log Changement Configuration Routeur"@fr ;
    rdfs:comment "Log entry detailing a configuration change on RouterCore1."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1_PAR ;
    noria:logOriginatingManagementSystem noria:Application_LogManagement ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by JohnDoe (10.0.1.100) from vty0. Changed interface GigabitEthernet0/0/1 description to 'ISP Uplink - NEW'."@en ;
    noria:loggingTime "2024-04-19T14:30:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_WebSrvHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en, "Alerte CPU Élevée Serveur Web"@fr ;
    rdfs:comment "Alert indicating sustained high CPU utilization on the web server."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01_PAR ;
    noria:logOriginatingManagementSystem noria:Application_LogManagement ;
    noria:logText "WARNING: CPU utilization on websrv01.corp.example.com exceeded 90% for 15 minutes."@en ;
    noria:loggingTime "2024-04-21T11:05:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_FirewallBlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en, "Alerte Trafic Bloqué Pare-feu"@fr ;
    rdfs:comment "Alert indicating a significant amount of traffic blocked by the DMZ firewall."@en ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ_PAR ;
    noria:logOriginatingManagementSystem noria:Application_LogManagement ;
    noria:logText "ALERT: High volume of denied connections from external IP 203.0.113.42 to DMZ."@en ;
    noria:loggingTime "2024-04-22T08:15:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DNSOutageResolvedLog a noria:EventRecord ;
    rdfs:label "DNS Server Reachable Log"@en, "Log Serveur DNS Accessible"@fr ;
    rdfs:comment "Log entry indicating that the primary DNS server became reachable again."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01_PAR ;
    noria:logOriginatingManagementSystem noria:Application_LogManagement ;
    noria:logText "INFO: DNS server dns01.corp.example.com is now reachable."@en ;
    noria:loggingTime "2024-04-20T09:35:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

