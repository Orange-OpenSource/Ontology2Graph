# --- Network Interfaces (noria:NetworkInterface) ---
noria:NI_WebServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for WebServer01."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to internal LAN."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_DBServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DBServer01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to internal LAN."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_CoreRouter01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting CoreRouter01 to WebServer01's segment."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to Web/App VLAN."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NI_CoreRouter01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting CoreRouter01 to EdgeRouter01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Inter-router link to Edge Router."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NI_EdgeRouter01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "EdgeRouter01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting EdgeRouter01 to CoreRouter01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouter01 ;
    noria:networkInterfaceDescription "Inter-router link to Core Router."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NI_EdgeRouter01_WAN a noria:NetworkInterface ;
    rdfs:label "EdgeRouter01 WAN Interface"@en ;
    rdfs:comment "Interface connecting EdgeRouter01 to the Internet Service Provider."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouter01 ;
    noria:networkInterfaceDescription "WAN uplink to ISP."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
