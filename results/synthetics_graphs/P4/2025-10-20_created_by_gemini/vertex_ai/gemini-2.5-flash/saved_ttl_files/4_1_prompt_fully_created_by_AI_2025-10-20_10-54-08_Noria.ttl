# --- Operation Plans (noria:OperationPlan) ---
noria:OP_RouterReboot a noria:OperationPlan ;
    rdfs:label "Standard Router Reboot Procedure"@en ;
    rdfs:comment "Procedure for safely rebooting a network router."@en ;
    skos:example "Steps include: notify stakeholders, save configuration, execute reboot command, verify connectivity."@en ;
    noria:operationPlanPreCondition noria:APC_RouterConnectivityCheck ;
    noria:operationPlanPostCondition noria:APOC_RouterConnectivityRestored .

noria:OP_DBFailover a noria:OperationPlan ;
    rdfs:label "Database Failover Procedure"@en ;
    rdfs:comment "Procedure for initiating a failover to a secondary database server."@en ;
    skos:example "Steps include: verify secondary health, initiate failover, update application configurations, verify application connectivity."@en ;
    noria:operationPlanPreCondition noria:APC_DBSecondaryHealthy ;
    noria:operationPlanPostCondition noria:APOC_DBServiceRestored .

noria:OP_SecurityAudit a noria:OperationPlan ;
    rdfs:label "Annual Security Audit Procedure"@en ;
    rdfs:comment "Procedure for conducting the annual security audit of IT systems."@en ;
    noria:operationPlanPreCondition noria:APC_AuditScopeDefined ;
    noria:operationPlanPostCondition noria:APOC_AuditReportGenerated .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:APC_RouterConnectivityCheck a noria:ActionPreCondition ;
    rdfs:label "Router Connectivity Check"@en ;
    rdfs:comment "Pre-condition: Verify current network connectivity and routing tables before reboot."@en .

noria:APOC_RouterConnectivityRestored a noria:ActionPostCondition ;
    rdfs:label "Router Connectivity Restored"@en ;
    rdfs:comment "Post-condition: Confirm network connectivity and routing tables are stable after reboot."@en .

noria:APC_DBSecondaryHealthy a noria:ActionPreCondition ;
    rdfs:label "Database Secondary Healthy Check"@en ;
    rdfs:comment "Pre-condition: Ensure the secondary database server is healthy and synchronized."@en .

noria:APOC_DBServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Database Service Restored"@en ;
    rdfs:comment "Post-condition: Confirm database service is fully restored and accessible by applications."@en .

noria:APC_AuditScopeDefined a noria:ActionPreCondition ;
    rdfs:label "Audit Scope Defined"@en ;
    rdfs:comment "Pre-condition: The scope and objectives of the security audit must be clearly defined."@en .

noria:APOC_AuditReportGenerated a noria:ActionPostCondition ;
    rdfs:label "Audit Report Generated"@en ;
    rdfs:comment "Post-condition: A comprehensive security audit report has been generated and reviewed."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
noria:DocAttach_TT001_Screenshot a noria:DocumentAttachment ;
    rdfs:label "Screenshot of Error Message"@en ;
    rdfs:comment "Screenshot showing the database connection error message on the web server."@en ;
    dcterms:created "2023-10-27T14:33:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TT_20231027_001 .

noria:DocAttach_CR001_Plan a noria:DocumentAttachment ;
    rdfs:label "Router Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the Core Router software upgrade."@en ;
    dcterms:created "2023-10-20T10:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:CR_20231101_001 .

noria:DocAttach_AuditReport_2023 a noria:DocumentAttachment ;
    rdfs:label "2023 Annual Security Audit Report"@en ;
    rdfs:comment "Official report detailing findings and recommendations from the 2023 security audit."@en ;
    dcterms:created "2023-11-15T14:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:CR_20231201_003 .

# --- Anomaly Patterns (noria:AnomalyPattern) ---
noria:AnomalyPattern_HighCPU_DBError a noria:AnomalyPattern ;
    rdfs:label "High CPU followed by DB Error Pattern"@en ;
    rdfs:comment "Pattern indicating a potential issue: Web server CPU spike immediately followed by database connection errors."@en ;
    skos:example "This pattern often precedes a full application outage."@en .

noria:AnomalyPattern_RepeatedLoginFailures a noria:AnomalyPattern ;
    rdfs:label "Repeated Login Failures Pattern"@en ;
    rdfs:comment "Pattern indicating a potential security breach: multiple failed login attempts from unusual sources."@en ;
    skos:example "This pattern is a strong indicator of a brute-force attack."@en .

