    rdfs:comment "Application delivery controller and load balancer."@en ;
    noria:productManufacturedBy org:F5 .

noria:ProductModel_PaloAltoFirewall a noria:ProductModel ;
    rdfs:label "Palo Alto Networks Firewall PA-5000 Series"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy org:PaloAlto .

org:Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

org:Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

org:VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

org:F5 a org:Organization ;
    rdfs:label "F5 Networks"@en ;
    rdfs:comment "Provider of application delivery networking technology."@en .

org:PaloAlto a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "Provider of cybersecurity solutions."@en .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
bot:Site_DataCenterParis a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace bot:Site_DataCenterParis .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Dedicated room for core network equipment."@en ;
    bot:hasSpace bot:Site_DataCenterParis .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Rack A1 within Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Locus_RackB2 a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:comment "Location of network equipment in Rack B2 within Network Room B."@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" ;
    bot:containsZone noria:Room_NetworkRoomB .

noria:Locus_RackC3 a noria:Locus ;
    rdfs:label "Rack C3"@en ;
    rdfs:comment "Location of security appliances in Rack C3 within Network Room B."@en ;
    noria:locusLine "C" ;
    noria:locusRow "3" ;
    bot:containsZone noria:Room_NetworkRoomB .

# --- Resources (noria:Resource) ---
noria:Resource_WebServer01 a noria:Resource ;
