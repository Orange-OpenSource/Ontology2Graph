    rdfs:comment "Log entry indicating a restart of the database server."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application002 ;
    noria:logOriginatingAgent foaf:Agent003 ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:logText "System reboot initiated by DB Admin Team."@en .

noria:EventRecord005 a noria:EventRecord ;
    rdfs:label "Network Interface Up Log"@en ;
    rdfs:comment "Interface ge-0/0/0 on cr01.corp.example.com came back up."@en ;
    noria:loggingTime "2024-04-20T11:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource004 ;
    noria:logOriginatingManagementSystem noria:Application002 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ; # Clearing an alarm can be a warning
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/0, changed state to up."@en .

