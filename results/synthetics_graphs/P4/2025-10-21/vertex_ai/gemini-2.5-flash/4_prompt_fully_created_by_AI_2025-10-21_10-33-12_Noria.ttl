# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (SKOS)
# =============================================================================

# Application KOS
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/business> a skos:Concept ; skos:prefLabel "Business Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring System"@en ; skos:inScheme <kos/application/type> .
<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/low> a skos:Concept ; skos:prefLabel "Low"@en ; skos:inScheme <kos/application/business-importance> .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:prefLabel "En Production"@fr ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en ; skos:prefLabel "En Développement"@fr ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; skos:prefLabel "Gold SLA"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; skos:prefLabel "Silver SLA"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# TroubleTicket KOS
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:prefLabel "Failure"@en ; skos:inScheme <kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:prefLabel "Assistance"@en ; skos:inScheme <kos/TroubleTicket/type> .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en ; skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en ; skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; skos:prefLabel "Immediate Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; skos:prefLabel "Deferred Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .
<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ; skos:prefLabel "Total Breakdown"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/trouble-category/IsolatedCustomerSite> a skos:Concept ; skos:prefLabel "Isolated Customer Site"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; skos:prefLabel "Managed Backbone Networks"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/Customer> a skos:Concept ; skos:prefLabel "Customer"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:prefLabel "Customer Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis"@en ; skos:inScheme <kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; skos:prefLabel "Resolution"@en ; skos:inScheme <kos/TroubleTicket/operationType> .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ; skos:prefLabel "Closed"@en ; skos:inScheme <kos/TroubleTicket/status> .

# ChangeRequest KOS
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; skos:prefLabel "Internal Intervention"@en ; skos:inScheme <kos/ChangeRequest/category> .
<kos/ChangeRequest/category/ThirdPartyIntervention> a skos:Concept ; skos:prefLabel "Third Party Intervention"@en ; skos:inScheme <kos/ChangeRequest/category> .
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change"@en ; skos:inScheme <kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:prefLabel "Emergency Change"@en ; skos:inScheme <kos/ChangeRequest/type> .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; skos:prefLabel "Software Upgrade"@en ; skos:inScheme <kos/ChangeRequest/cause> .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; skos:prefLabel "Configuration Change"@en ; skos:inScheme <kos/ChangeRequest/cause> .
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:prefLabel "Approved"@en ; skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; skos:prefLabel "Implemented"@en ; skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/specification/PatchDeployment> a skos:Concept ; skos:prefLabel "Patch Deployment"@en ; skos:inScheme <kos/ChangeRequest/specification> .

# Resource KOS
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Up"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; skos:prefLabel "Up"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; skos:prefLabel "Down"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:prefLabel "Decommissioned"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/DatabaseServer> a skos:Concept ; skos:prefLabel "Database Server"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/LoadBalancer> a skos:Concept ; skos:prefLabel "Load Balancer"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Firewall> a skos:Concept ; skos:prefLabel "Firewall"@en ; skos:inScheme <kos/Resource/type> .

# Service KOS
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en ; skos:inScheme <kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en ; skos:inScheme <kos/service/type> .

# Notification KOS
<kos/Notification/EventType/stateChange> a skos:Concept ; skos:prefLabel "State Change"@en ; skos:inScheme <kos/Notification/EventType> .
<kos/Notification/EventType/thresholdCrossing> a skos:Concept ; skos:prefLabel "Threshold Crossing Alert"@en ; skos:inScheme <kos/Notification/EventType> .
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Agent Contact Method KOS
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; skos:prefLabel "Ticketing System"@en ; skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Agents and Organizations (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent001 a foaf:Agent ;
    rdfs:label "E-commerce Platform Admin Team"@en, "Équipe Admin Plateforme E-commerce"@fr ;
    rdfs:comment "Team responsible for the overall E-commerce platform management and operations."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en, "9H-18H (lun-ven)"@fr ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all non-critical issues. For critical issues, use emergency hotline."@en .

foaf:Agent002 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en, "Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to alerts."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate phone call for P1/Critical incidents. Email for P2/Major."@en .

foaf:Agent003 a foaf:Agent ;
    rdfs:label "Database Admin Team"@en, "Équipe Admin Base de Données"@fr ;
    rdfs:comment "Specialized team managing all database instances."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Create a ticket in the DB support queue."@en .

foaf:Agent004 a foaf:Agent ;
    rdfs:label "Jean Dupont"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead engineer for the E-commerce Backend Module."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent005 a foaf:Agent ;
    rdfs:label "Sophie Martin"@en, "Sophie Martin"@fr ;
    rdfs:comment "Customer Support Representative who reported an issue."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:OrganizationalUnit001 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en, "Département Opérations IT"@fr ;
    rdfs:comment "Main department overseeing all IT infrastructure and application operations."@en ;
    org:hasMember foaf:Agent001, foaf:Agent002, foaf:Agent003 .

org:OrganizationalUnit002 a org:OrganizationalUnit ;
    rdfs:label "Customer Service Department"@en, "Département Service Client"@fr ;
    rdfs:comment "Department handling customer inquiries and initial incident reports."@en ;
    org:hasMember foaf:Agent005 .

