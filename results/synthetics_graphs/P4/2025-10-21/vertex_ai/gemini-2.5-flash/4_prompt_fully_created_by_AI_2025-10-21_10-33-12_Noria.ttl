# Add more network interfaces and links for completeness
noria:NetworkInterface008 a noria:NetworkInterface ;
    rdfs:label "eth0 on vhost01"@en ;
    rdfs:comment "Management interface for Virtualization Host 01."@en ;
    noria:networkInterfaceOf noria:Resource006 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkLink006 a noria:NetworkLink ;
    rdfs:label "Link VHOST01-CR01"@en ;
    rdfs:comment "Internal network link connecting Virtualization Host 01 to Core Router 01."@en ;
    noria:networkLinkId "NL-VHOST01-CR01-001" ;
    noria:resourceManagedBy foaf:Agent002 ;
    noria:networkLinkTerminationResource noria:Resource006, noria:Resource004 ;
