    noria:locusRow "5"@en .

noria:Locus004 a noria:Locus ;
    rdfs:label "Rack R3-A01, Unit 1"@en ;
    rdfs:comment "Location for Virtualization Host 01."@en ;
    noria:locusLine "R3"@en ;
    noria:locusRow "1"@en .

noria:Locus005 a noria:Locus ;
    rdfs:label "Rack R3-A01, Unit 2"@en ;
    rdfs:comment "Location for Virtualization Host 02."@en ;
    noria:locusLine "R3"@en ;
    noria:locusRow "2"@en .

noria:Locus006 a noria:Locus ;
    rdfs:label "Rack N1-B02, Unit 1"@en ;
