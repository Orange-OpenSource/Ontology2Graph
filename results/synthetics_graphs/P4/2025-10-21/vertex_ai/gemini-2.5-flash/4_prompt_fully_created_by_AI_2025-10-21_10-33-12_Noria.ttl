    noria:logOriginatingManagedObject noria:Resource004 ;
    noria:logOriginatingManagementSystem noria:Application002 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/0, changed state to down."@en .

noria:EventRecord003 a noria:EventRecord ;
