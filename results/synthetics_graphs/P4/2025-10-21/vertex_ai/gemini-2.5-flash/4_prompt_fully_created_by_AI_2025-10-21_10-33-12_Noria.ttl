# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site001 a bot:Site ;
    rdfs:label "Main Data Center Paris"@en, "Centre de Données Principal Paris"@fr ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room001 a noria:Room ;
    rdfs:label "Server Room A01"@en, "Salle Serveurs A01"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus001, noria:Locus002, noria:Locus003, noria:Locus004, noria:Locus005 ;
    seas:subSystemOf bot:Site001 .

noria:Room002 a noria:Room ;
    rdfs:label "Network Equipment Room B02"@en, "Salle Équipements Réseau B02"@fr ;
    rdfs:comment "Dedicated room for network infrastructure."@en ;
    bot:hasSpace noria:Locus006, noria:Locus007 ;
    seas:subSystemOf bot:Site001 .

