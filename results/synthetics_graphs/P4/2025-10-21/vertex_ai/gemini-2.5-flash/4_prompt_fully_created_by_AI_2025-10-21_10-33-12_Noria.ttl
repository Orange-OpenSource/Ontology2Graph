    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application002 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:type <kos/Notification/EventType/thresholdCrossing> ;
    noria:logText "CPU usage on db01 at 95%."@en .

noria:EventRecord002 a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Interface ge-0/0/0 on cr01.corp.example.com went down."@en ;
