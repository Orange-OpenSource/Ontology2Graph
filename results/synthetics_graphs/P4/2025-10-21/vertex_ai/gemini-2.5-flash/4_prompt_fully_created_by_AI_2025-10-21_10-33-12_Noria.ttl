    noria:troubleTicketDetectionDateTime "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent005, foaf:Agent001, foaf:Agent003 ;
