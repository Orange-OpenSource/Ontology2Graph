# =============================================================================
# Operational Plans and Conditions (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:OperationPlan001 a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the E-commerce database service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition001 ;
    noria:operationPlanPostCondition noria:ActionPostCondition001 .

noria:ActionPreCondition001 a noria:ActionPreCondition ;
    rdfs:label "High CPU on DB Server"@en ;
    rdfs:comment "Condition: Database server CPU utilization is consistently above 90%."@en .

noria:ActionPostCondition001 a noria:ActionPostCondition ;
    rdfs:label "DB Service Restored, CPU Normal"@en ;
    rdfs:comment "Outcome: Database service is running, and CPU utilization is below 50%."@en .

noria:OperationPlan002 a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Guide"@en ;
    rdfs:comment "Procedure for diagnosing and resolving flapping network interfaces."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition002 ;
    noria:operationPlanPostCondition noria:ActionPostCondition002 .

noria:ActionPreCondition002 a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down/Flapping"@en ;
    rdfs:comment "Condition: A network interface is reported as down or is intermittently losing connectivity."@en .

noria:ActionPostCondition002 a noria:ActionPostCondition ;
    rdfs:label "Network Interface Stable and Up"@en ;
    rdfs:comment "Outcome: The network interface is stable, operational, and traffic is flowing normally."@en .

noria:OperationPlan003 a noria:OperationPlan ;
    rdfs:label "E-commerce Backend Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the E-commerce backend application."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition003 ;
    noria:operationPlanPostCondition noria:ActionPostCondition003 .

noria:ActionPreCondition003 a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Approved"@en ;
    rdfs:comment "Condition: A maintenance window has been approved, and all necessary backups are complete."@en .

noria:ActionPostCondition003 a noria:ActionPostCondition ;
    rdfs:label "Backend Upgraded, Functionality Verified"@en ;
    rdfs:comment "Outcome: E-commerce backend is upgraded to the new version, and all critical functionalities are verified."@en .

# =============================================================================
# Anomaly Patterns (noria:AnomalyPattern)
# =============================================================================

noria:AnomalyPattern001 a noria:AnomalyPattern ;
    rdfs:label "Database Connection Exhaustion"@en ;
    rdfs:comment "Pattern indicating that the database server is running out of available connections, leading to application errors."@en ;
    skos:example "High CPU on DB server + 'connection refused' errors from application logs."@en .

noria:AnomalyPattern002 a noria:AnomalyPattern ;
    rdfs:label "Network Link Flap"@en ;
    rdfs:comment "Pattern indicating intermittent loss and restoration of a network link, often due to physical layer issues."@en ;
    skos:example "Repeated 'interface up/down' events on a network device."@en .

# =============================================================================
# Document Attachments (noria:DocumentAttachment)
# =============================================================================

noria:DocumentAttachment001 a noria:DocumentAttachment ;
    rdfs:label "Screenshot of DB CPU Usage"@en ;
    rdfs:comment "Screenshot showing high CPU usage on db01 at the time of the incident."@en ;
    dcterms:created "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TroubleTicket001 ;
    dcterms:format "image/png" ;
    dcterms:source <http://monitoring.example.com/screenshots/db01_cpu_20240420.png> .

noria:DocumentAttachment002 a noria:DocumentAttachment ;
    rdfs:label "Upgrade Plan for ECOMM Backend"@en ;
    rdfs:comment "Detailed plan for the E-commerce backend software upgrade."@en ;
    dcterms:created "2024-04-26T10:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:ChangeRequest001 ;
    dcterms:format "application/pdf" ;
    dcterms:source <http://confluence.example.com/docs/ECOMM_Backend_Upgrade_Plan_v3.pdf> .

# =============================================================================
# Connectivity and Density Enhancements
# =============================================================================

# Link resources to applications they serve
noria:Resource001 noria:resourceForApplication noria:Application001 .
noria:Resource002 noria:resourceForApplication noria:Application001 .
noria:Resource003 noria:resourceForApplication noria:Application001 .
noria:Resource004 noria:resourceForApplication noria:Application003 .
noria:Resource005 noria:resourceForApplication noria:Application003 .

# Link trouble tickets to event records that are correlated
noria:TroubleTicket001 dcterms:relation noria:EventRecord001 . # High CPU alert is related to the outage
noria:TroubleTicket002 dcterms:relation noria:EventRecord005 . # Interface up event is related to the resolution

# Link change requests to related parties with specific roles
noria:ChangeRequest001 noria:changeRequestRelatedParty foaf:Agent001, foaf:Agent004 .
noria:ChangeRequest002 noria:changeRequestRelatedParty foaf:Agent002 .

# Link operation plans to anomaly patterns they address
noria:OperationPlan001 dcterms:references noria:AnomalyPattern001 .
noria:OperationPlan002 dcterms:references noria:AnomalyPattern002 .

# Link event records to potential repair actions
noria:EventRecord001 noria:alarmProposedRepairAction noria:OperationPlan001 .
noria:EventRecord002 noria:alarmProposedRepairAction noria:OperationPlan002 .

# Link event records to the procedure execution container that mitigated them
noria:EventRecord003 noria:alarmMitigatedBy noria:TroubleTicket001 . # The outage was mitigated by actions within TT001
noria:EventRecord002 noria:alarmMitigatedBy noria:TroubleTicket002 . # The flapping was mitigated by actions within TT002

# Link document status history (example)
noria:TroubleTicket001 noria:documentStatusHistory noria:EventRecord004 . # DB restart is a status change for the TT

# Add more properties to existing entities for density
noria:NetworkInterface001 noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -8 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -3 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -15 .

noria:NetworkInterface003 noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -6 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -12 .

noria:Resource006 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Add more agents and organizational units
foaf:Agent006 a foaf:Agent ;
    rdfs:label "Network Engineer Team"@en ;
    rdfs:comment "Team responsible for network device configuration and maintenance."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit change requests for network modifications."@en .

org:OrganizationalUnit003 a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Department"@en ;
    rdfs:comment "Department focused on network design and implementation."@en ;
    org:hasMember foaf:Agent006 ;
    seas:subSystemOf org:OrganizationalUnit001 .

noria:Resource004 noria:resourceManagedBy foaf:Agent006 . # Network Engineer Team manages core router
noria:Resource005 noria:resourceManagedBy foaf:Agent006 . # Network Engineer Team manages edge router

noria:ApplicationModule002 noria:applicationModuleSupportGroup org:OrganizationalUnit002 . # Customer service can be L1 support

noria:ChangeRequest002 noria:changeRequestActorParty foaf:Agent006 . # Network Engineer Team acts on network changes

# Add more resources and link them
noria:Resource008 a noria:Resource ;
    rdfs:label "Load Balancer 01"@en ;
    rdfs:comment "Distributes traffic to web servers for the E-commerce platform."@en ;
    noria:resourceManagedBy foaf:Agent001 ;
    noria:resourceHostName "lb01.ecommerce.corp"@en ;
    noria:resourceProductModel noria:ProductModel002 ; # Using a switch model as a generic network device
    noria:resourceType <kos/Resource/type/LoadBalancer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication noria:Application001 .

noria:NetworkInterface007 a noria:NetworkInterface ;
    rdfs:label "port1 on lb01"@en ;
    rdfs:comment "Interface for Load Balancer 01."@en ;
    noria:networkInterfaceOf noria:Resource008 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkLink005 a noria:NetworkLink ;
    rdfs:label "Link LB01-WEB01"@en ;
    rdfs:comment "Link from Load Balancer to Web Server 01."@en ;
    noria:networkLinkId "NL-LB01-WEB01-001" ;
    noria:resourceManagedBy foaf:Agent001 ;
    noria:networkLinkTerminationResource noria:Resource008, noria:Resource002 ;
    noria:networkLinkInstallationDate "2023-05-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"@en ;
    noria:networkInterfaceConnects noria:NetworkInterface007, noria:NetworkInterface005 .

noria:ApplicationModule001 noria:resourceForApplication noria:Resource008 . # Frontend module uses the load balancer

# Add another event record and link it to a trouble ticket
noria:EventRecord006 a noria:EventRecord ;
    rdfs:label "Load Balancer Health Check Failure"@en ;
    rdfs:comment "Health check failed for web01.ecommerce.corp on lb01.ecommerce.corp."@en ;
    noria:loggingTime "2024-04-20T10:18:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource008 ;
    noria:logOriginatingManagementSystem noria:Application002 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/thresholdCrossing> ;
    noria:logText "Load balancer detected web01 as unhealthy."@en .

noria:TroubleTicket001 dcterms:relation noria:EventRecord006 . # Load balancer issue is related to the E-commerce outage

# Add a change request for a new feature
noria:ChangeRequest003 a noria:ChangeRequest ;
    rdfs:label "Implement New Payment Gateway"@en ;
    rdfs:comment "Integrate a new payment gateway into the E-commerce platform for expanded options."@en ;
    dcterms:identifier "CR-20240601-001" ;
    dcterms:created "2024-05-10T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-06-01T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-06-01T17:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ; # New feature often involves software changes
    noria:changeRequestImpact noria:ApplicationModule002 ;
    noria:changeRequestOutageDuration "PT0S"^^xsd:duration ; # No expected outage
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent004 ;
    noria:changeRequestPilotParty foaf:Agent004 ;
    noria:changeRequestActorParty foaf:Agent001 ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef <http://changemanagement.example.com/CR-20240601-001> .

# Add a procedural element for a new feature deployment
noria:OperationPlan004 a noria:OperationPlan ;
    rdfs:label "Payment Gateway Integration Procedure"@en ;
    rdfs:comment "Procedure for integrating and testing the new payment gateway."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition004 ;
    noria:operationPlanPostCondition noria:ActionPostCondition004 .

noria:ActionPreCondition004 a noria:ActionPreCondition ;
    rdfs:label "New Gateway API Credentials Ready"@en ;
    rdfs:comment "Condition: API credentials for the new payment gateway are provisioned and tested."@en .

noria:ActionPostCondition004 a noria:ActionPostCondition ;
    rdfs:label "New Gateway Live and Functional"@en ;
    rdfs:comment "Outcome: New payment gateway is live, processing transactions, and verified by QA."@en .

noria:ChangeRequest003 dcterms:references noria:OperationPlan004 . # CR references the OP for implementation

# Add a CUid for an agent
noria:CUid001 a noria:CorporateUserIdentifier ;
    rdfs:label "jdupont"@en ;
    rdfs:comment "Corporate User ID for Jean Dupont."@en ;
    foaf:accountName "jdupont"@en ;
    foaf:holdsAccount foaf:Agent004 .

# Add more details to existing resources
noria:Resource001 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
noria:Resource002 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
noria:Resource003 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Add a cluster controller relationship
noria:Resource006 noria:clusterController noria:Resource009 .

noria:Resource009 a noria:Resource ;
    rdfs:label "vCenter Server"@en ;
    rdfs:comment "Centralized management server for VMware vSphere environments."@en ;
    noria:resourceManagedBy foaf:Agent001 ;
    noria:resourceHostName "vcenter.corp.example.com"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
