    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:ApplicationModule002, noria:Resource003 ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/PatchDeployment> ;
    noria:changeRequestInitiatorParty foaf:Agent004 ;
    noria:changeRequestPilotParty foaf:Agent004 ;
    noria:changeRequestActorParty foaf:Agent001 ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef <http://changemanagement.example.com/CR-20240501-001> .

