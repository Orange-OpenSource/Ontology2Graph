# Add a procedural element for anomaly detection
:AnomalyPattern_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization on a server, potentially leading to performance issues."@en ;
    skos:example "CPU usage > 90% for 15 minutes."@en .

:OP_Diagnose_High_CPU a noria:OperationPlan ;
    rdfs:label "Diagnose High CPU Load"@en ;
    rdfs:comment "Procedure to investigate and resolve high CPU load on a server."@en ;
    noria:operationPlanPreCondition :AnomalyPattern_HighCPULoad ;
    noria:operationPlanPostCondition :PostCond_CPULoad_Normal .

:PostCond_CPULoad_Normal a noria:ActionPostCondition ;
    rdfs:label "CPU Load Normalized"@en ;
    rdfs:comment "Outcome: CPU utilization returned to normal operating levels."@en .

# Link an event record to an anomaly pattern
:Event_High_CPU_Web_Server a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert for high CPU usage on the web server."@en ;
    dcterms:identifier "EVT-20240320-009"@en ;
    noria:loggingTime "2024-03-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem :App_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logText "CPU usage on web01.corp.example.com at 95% for 20 minutes."@en ;
    dcterms:conformsTo :AnomalyPattern_HighCPULoad . # Using dcterms:conformsTo as a proxy for "matches pattern"

# Link a trouble ticket to the high CPU event
:TT_High_CPU_Web_Server_20240320 a noria:TroubleTicket ;
    rdfs:label "Web Server High CPU Incident"@en ;
    rdfs:comment "Incident opened due to sustained high CPU load on the corporate web server."@en ;
    dcterms:identifier "TT-20240320-004"@en ;
    dcterms:created "2024-03-20T11:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedResource :Resource_Web_Server_01 ;
    noria:troubleTicketRelatedService :App_Corporate_Web_Portal ;
    noria:troubleTicketRelatedParty :Agent_IT_Ops_Team ;
    noria:troubleTicketTrigger :Event_High_CPU_Web_Server .

# Add a specific action to an operation plan
:Action_Restart_WebServer a pep:Action ; # Assuming pep:Action is a valid class for specific actions
    rdfs:label "Restart Web Server Service"@en ;
    rdfs:comment "Action to restart the web server software service."@en ;
    pep:isPerformedBy :Agent_John_Doe .

:OP_Diagnose_High_CPU pep:hasStep :Action_Restart_WebServer .

# Link an event record to a procedure execution (as it is a specialization of pep:ProcedureExecution)
:Event_Restart_WebServer_Log a noria:EventRecord ;
    rdfs:label "Web Server Service Restart Log"@en ;
    rdfs:comment "Log entry confirming the restart of the web server service."@en ;
    dcterms:identifier "EVT-20240320-010"@en ;
    noria:loggingTime "2024-03-20T11:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingAgent :Agent_John_Doe ;
    noria:logText "Web server service 'apache2' restarted successfully."@en ;
    pep:isExecutedAs :Action_Restart_WebServer . # Link the event record as an execution of the action.

# Link the trouble ticket to the operation plan that was followed
:TT_High_CPU_Web_Server_20240320 noria:troubleTicketPartyIntervention :OP_Diagnose_High_CPU . # Using this property as a general link to intervention.

