# --- Network Links ---
:NL_DNS_to_Switch a noria:NetworkLink ;
    rdfs:label "Link: DNS Server 01 to Access Switch 01"@en ;
    rdfs:comment "Physical Ethernet link between DNS Server 01 and Access Switch 01."@en ;
    noria:networkLinkId "NL-DNS-SW-001"@en ;
    noria:networkLinkType "Ethernet 1Gbps"@en ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_Network_Admin ;
    noria:networkInterfaceConnects :NI_DNS_Server_Eth0, :NI_Switch_Eth1_0_1 .

:NL_Web_to_Switch a noria:NetworkLink ;
    rdfs:label "Link: Web Server 01 to Access Switch 01"@en ;
    rdfs:comment "Physical Ethernet link between Web Server 01 and Access Switch 01."@en ;
    noria:networkLinkId "NL-WEB-SW-001"@en ;
    noria:networkLinkType "Ethernet 1Gbps"@en ;
    noria:networkLinkInstallationDate "2022-02-01T11:45:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_Network_Admin ;
    noria:networkInterfaceConnects :NI_Web_Server_Eth0, :NI_Switch_Eth1_0_2 .

:NL_Switch_to_Router a noria:NetworkLink ;
    rdfs:label "Link: Access Switch 01 to Core Router 01"@en ;
    rdfs:comment "Uplink from Access Switch 01 to Core Router 01."@en ;
    noria:networkLinkId "NL-SW-RTR-001"@en ;
    noria:networkLinkType "Fiber Optic 10Gbps"@en ;
    noria:networkLinkInstallationDate "2022-03-10T10:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_Network_Admin ;
    noria:networkInterfaceConnects :NI_Switch_Eth1_0_1, :NI_Router_GigE0_0_0 . # This is a simplification, usually switch uplink connects to a specific port.

:NL_Router_to_ISP a noria:NetworkLink ;
    rdfs:label "Link: Core Router 01 to ISP"@en ;
    rdfs:comment "External link from Core Router 01 to Internet Service Provider."@en ;
    noria:networkLinkId "NL-RTR-ISP-001"@en ;
    noria:networkLinkType "MPLS VPN 100Gbps"@en ;
