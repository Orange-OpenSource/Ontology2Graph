# --- Agents and Organizational Units ---
:Agent_IT_Ops_Team a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7 (Shift-based)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. For non-critical, open a ticket in the ITSM system."@en .

:Agent_Network_Admin a foaf:Agent ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via internal chat for urgent matters, otherwise use ticketing system."@en .

:Agent_App_Dev_Team a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the core business application."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Escalate issues through the L2 support team."@en .

:Agent_Database_Admin a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "All database-related requests must go through the ticketing system."@en .

:Agent_Security_Team a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 (Shift-based)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate notification for critical security alerts."@en .

:Agent_John_Doe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the IT Operations Team."@en .

:Agent_Jane_Smith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Network Administration Team."@en .

:OrgUnit_IT_Department a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department of the organization."@en ;
    org:hasMember :Agent_John_Doe, :Agent_Jane_Smith .

:OrgUnit_L2_Support a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support"@en ;
    rdfs:comment "Second-line support team for complex IT issues."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"@en .

:OrgUnit_L1_Helpdesk a org:OrganizationalUnit ;
    rdfs:label "Level 1 Helpdesk"@en ;
    rdfs:comment "First point of contact for all IT-related queries and issues."@en ;
    noria:agentWorkingHours "24/7"@en .

