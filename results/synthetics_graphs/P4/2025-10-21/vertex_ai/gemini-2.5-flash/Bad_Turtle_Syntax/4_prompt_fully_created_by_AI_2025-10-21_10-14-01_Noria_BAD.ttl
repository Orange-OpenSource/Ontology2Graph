    noria:logOriginatingManagementSystem :App_Monitoring_System ; # Assuming monitoring system also handles security events or forwards them.
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "Detected 'UNION SELECT' pattern in web request to /login.php from IP 203.0.113.42."@en ;
    noria:logOriginatingAgent <http://example.com/user/malicious_actor> . # Example of an external agent.

# --- Operation Plans, Pre/Post Conditions ---
:OP_DNS_Troubleshooting a noria:OperationPlan ;
    rdfs:label "DNS Service Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving DNS service outages."@en ;
    skos:example "Check service status, verify network configuration, inspect logs, restart service."@en ;
    noria:operationPlanPreCondition :PreCond_DNS_Service_Down ;
    noria:operationPlanPostCondition :PostCond_DNS_Service_Up .

:PreCond_DNS_Service_Down a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS server is not responding to queries on port 53."@en .

:PostCond_DNS_Service_Up a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS server is responding to queries, and name resolution is functional."@en .

:OP_Router_Firmware_Upgrade a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for safely upgrading router firmware, including backup and rollback plans."@en ;
    skos:example "Download firmware, backup configuration, perform upgrade, verify connectivity, restore config if needed."@en ;
    noria:operationPlanPreCondition :PreCond_Router_Maintenance_Window ;
    noria:operationPlanPostCondition :PostCond_Router_Firmware_Updated .

:PreCond_Router_Maintenance_Window a noria:ActionPreCondition ;
    rdfs:label "Scheduled Maintenance Window"@en ;
    rdfs:comment "Condition: Upgrade must be performed during a pre-approved maintenance window."@en .

:PostCond_Router_Firmware_Updated a noria:ActionPostCondition ;
    rdfs:label "Router Firmware Successfully Updated"@en ;
    rdfs:comment "Outcome: Router firmware is updated to the target version, and all network services are operational."@en .

