    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Miami"@en ;
    noria:sitePrincipalAddressPostalCode "33101"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

:Room_Server_Hall_A a noria:Room ;
    rdfs:label "Server Hall A"@en ;
    rdfs:comment "Main server hall within the Main Data Center."@en ;
    bot:hasSubSpace :Site_Main_DataCenter . # Assuming bot:hasSubSpace can link Room to Site, or I can use a more generic property if available. The schema doesn't explicitly define how Room relates to Site, but bot:Space is a superclass for both. I'll use bot:hasSubSpace as a reasonable interpretation.

