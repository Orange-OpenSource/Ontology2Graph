noria:TroubleTicketNote1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for DNS Outage"@en ;
    rdfs:comment "Initial checks confirm DNS service is not responding on primary server. Failover to secondary DNS initiated."@en ;
    dcterms:created "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person1 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket1 .

noria:TroubleTicketNote2 a noria:TroubleTicketNote ;
    rdfs:label "Customer Update for CRM Performance"@en ;
    rdfs:comment "Informed customer about ongoing investigation and expected resolution by end of day."@en ;
    dcterms:created "2024-04-19T15:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent3 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TroubleTicket2 .

noria:TroubleTicketNote3 a noria:TroubleTicketNote ;
    rdfs:label "WAN Link Restoration Attempt"@en ;
    rdfs:comment "Attempted to bounce interface xe-0/0/1 on cr01.par.example.com. No change in status. Escalating to fiber team."@en ;
    dcterms:created "2024-04-20T11:25:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person1 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket3 ;
    noria:troubleTicketNoteCorrelatedExecution <noria:ProcedureExecutionContainer1> . # Link to a container of related event records

# =============================================================================
# Change Requests
# =============================================================================

noria:ChangeRequest1 a noria:ChangeRequest ;
    rdfs:label "Firewall Rule Update for New Application"@en ;
    rdfs:comment "Add new firewall rules to allow traffic for the upcoming 'Project Alpha' application."@en ;
    noria:changeRequestPlannedStartTime "2024-05-01T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T23:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource5, noria:ApplicationModule1 ;
    noria:changeRequestOutageDuration "PT0H15M"^^xsd:duration ; # 15 minutes outage
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkUpgradeProcedure> ;
    noria:changeRequestInitiatorParty foaf:Person2 ;
    noria:changeRequestPilotParty foaf:Person1 ;
    noria:changeRequestActorParty foaf:Agent4 ;
    noria:changeRequestIsRegulated true ;
    noria:documentExternalId "CR-FW-20240501-001" ;
    noria:documentHRef <http://itsm.example.com/change/CR-FW-20240501-001> .

noria:ChangeRequest2 a noria:ChangeRequest ;
    rdfs:label "CRM Database Index Optimization"@en ;
    rdfs:comment "Perform database index optimization to improve CRM application performance."@en ;
    noria:changeRequestPlannedStartTime "2024-04-21T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-21T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-21T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-21T03:30:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource3, noria:ApplicationModule2 ;
    noria:changeRequestOutageDuration "PT0H0M"^^xsd:duration ; # No expected outage
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Completed> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/ServerPatching> ; # Reusing for DB maintenance
    noria:changeRequestInitiatorParty foaf:Agent3 ;
    noria:changeRequestPilotParty foaf:Agent5 ;
    noria:changeRequestActorParty foaf:Agent5 ;
    noria:changeRequestIsRegulated false ;
    noria:documentExternalId "CR-DB-20240421-002" ;
    noria:documentHRef <http://itsm.example.com/change/CR-DB-20240421-002> .

# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "WAN Link Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and restoring WAN link outages."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Firewall Rule Implementation Guide"@en ;
    rdfs:comment "Detailed steps for adding new firewall rules, including testing and rollback procedures."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Database Index Optimization Script"@en ;
    rdfs:comment "Automated script and manual steps for optimizing database indexes."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition3 ;
    noria:operationPlanPostCondition noria:ActionPostCondition3 .

noria:AnomalyPattern1 a noria:AnomalyPattern ;
    rdfs:label "High CPU on Critical Server"@en ;
    rdfs:comment "Pattern indicating a potential issue when CPU usage on a critical server exceeds a threshold for an extended period."@en ;
    folio:hasCause "Application misconfiguration or resource exhaustion."@en .

noria:AnomalyPattern2 a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping"@en ;
    rdfs:comment "Pattern indicating an unstable network connection, with an interface repeatedly going up and down."@en ;
    folio:hasCause "Faulty cable, transceiver, or port."@en .

# =============================================================================
# Action Pre/Post Conditions
# =============================================================================

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "WAN Link Down Confirmed"@en ;
    rdfs:comment "Pre-condition for WAN Link Troubleshooting: Monitoring system confirms link is down and no local configuration changes were made."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "WAN Link Restored"@en ;
    rdfs:comment "Post-condition for WAN Link Troubleshooting: Monitoring system reports link is up and traffic is flowing normally."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Change Window Approved"@en ;
    rdfs:comment "Pre-condition for Firewall Rule Implementation: Change Request is approved and scheduled within an authorized maintenance window."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "New Firewall Rules Verified"@en ;
    rdfs:comment "Post-condition for Firewall Rule Implementation: Connectivity tests confirm new rules are active and desired traffic flows are established."@en .

noria:ActionPreCondition3 a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completed"@en ;
    rdfs:comment "Pre-condition for Database Index Optimization: A full backup of the database has been successfully completed."@en .

noria:ActionPostCondition3 a noria:ActionPostCondition ;
    rdfs:label "Database Performance Improved"@en ;
    rdfs:comment "Post-condition for Database Index Optimization: Database query response times are within acceptable thresholds."@en .

# =============================================================================
# Additional Connectivity and Density
# =============================================================================

# Link resources to applications they serve
noria:Resource1 noria:resourceForApplication noria:Application1 .
noria:Resource3 noria:resourceForApplication noria:Application2 .
noria:Resource5 noria:resourceForApplication noria:Application1 .
noria:Resource4 noria:resourceForApplication noria:Application3 . # Dev host for logging system

# Link applications to resources they use (inverse of resourceForApplication)
noria:Application1 seas:hasSubSystem noria:Resource1, noria:Resource5 .
noria:Application2 seas:hasSubSystem noria:Resource3 .
noria:Application3 seas:hasSubSystem noria:Resource4 .

# Link Application Modules to resources they use (more specific than Application)
noria:ApplicationModule1 seas:hasSubSystem noria:Resource1, noria:Resource5 .
noria:ApplicationModule2 seas:hasSubSystem noria:Resource3 .

# Link TroubleTickets to related OperationPlans (as proposed repair actions)
noria:TroubleTicket1 noria:alarmProposedRepairAction noria:OperationPlan1 .
noria:TroubleTicket2 noria:alarmProposedRepairAction noria:OperationPlan3 .

# Link ChangeRequests to related OperationPlans (as specifications)
noria:ChangeRequest1 noria:actionCorrelatedOperationPlan noria:OperationPlan2 .
noria:ChangeRequest2 noria:actionCorrelatedOperationPlan noria:OperationPlan3 .

# Example of a Corporate User Identifier
noria:CUid1 a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Dupont's Corporate ID"@en ;
    rdfs:comment "Unique corporate identifier for Alice Dupont."@en ;
    foaf:accountName "adupont" ;
    observable:accountIdentifier "ADUPONT-EMP-001" ;
    foaf:holdsAccount foaf:Person1 .

# Example of a ProcedureExecutionContainer for a TroubleTicketNote
<noria:ProcedureExecutionContainer1> a pep:ProcedureExecutionContainer ;
    rdfs:label "WAN Link Interface Bounce Attempt"@en ;
    rdfs:comment "Container for events related to attempting to restore WAN link by bouncing interface."@en ;
    dcterms:created "2024-04-20T11:20:00Z"^^xsd:dateTime ;
    ldp:member noria:EventRecord6 . # Assuming EventRecord6 is a log of the interface bounce command

noria:EventRecord6 a noria:EventRecord ;
    rdfs:label "Interface Bounce Command Executed"@en ;
    rdfs:comment "Command 'shutdown' then 'no shutdown' executed on xe-0/0/1 of cr01.par.example.com."@en ;
    noria:loggingTime "2024-04-20T11:20:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingAgent foaf:Person1 ;
    noria:logText "CLI: interface xe-0/0/1 shutdown; interface xe-0/0/1 no shutdown."@en .

# Example of a cluster controller relationship
noria:Resource6 a noria:Resource ;
    rdfs:label "Core Router 02 Lyon"@en ;
    rdfs:comment "Main core router in Lyon Data Center, peer to Paris router."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "cr02.lyn.example.com" ;
    noria:resourceProductModel noria:ProductModel3 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.21> .

noria:Resource7 a noria:Resource ;
    rdfs:label "Virtual Center 01"@en ;
    rdfs:comment "VMware vCenter server managing virtualization hosts."@en ;
    noria:resourceManagedBy org:OrgUnit1 ;
    noria:resourceHostName "vcenter01.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.60> .

noria:Resource4 noria:clusterController noria:Resource7 . # ESXi host managed by vCenter

# Further network interface connections
noria:NetworkInterface6 a noria:NetworkInterface ;
    rdfs:label "xe-0/0/1.200"@en ;
    rdfs:comment "10 Gigabit Ethernet uplink to WAN on Core Router 02."@en ;
    noria:networkInterfaceOf noria:Resource6 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -4 ;
    noria:networkInterfaceLaserRxOpticalPower -6 ;
    noria:networkInterfaceConnects noria:NetworkLink2 .

# Document attachment example
noria:DocumentAttachment1 a noria:DocumentAttachment ;
    rdfs:label "DNS Server Hardware Report"@en ;
    rdfs:comment "PDF report detailing the hardware failure of DNS Server 01."@en ;
    dcterms:created "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person1 ;
    dcterms:isPartOf noria:TroubleTicket1 ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "DNS-HW-REPORT-001.pdf" .

noria:DocumentAttachment2 a noria:DocumentAttachment ;
    rdfs:label "Firewall Rule Change Request Form"@en ;
    rdfs:comment "Official change request form for CR-FW-20240501-001."@en ;
    dcterms:created "2024-04-25T10:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person2 ;
    dcterms:isPartOf noria:ChangeRequest1 ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:identifier "CR-FW-FORM-001.docx" .

# Event records for status history
noria:EventRecord7 a noria:EventRecord ;
    rdfs:label "Trouble Ticket 1 Status Change: InProgress"@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system/ticketing> ;
    noria:logText "Trouble Ticket INC-DNS-20240420-001 status changed to InProgress."@en .

noria:EventRecord8 a noria:EventRecord ;
    rdfs:label "Trouble Ticket 1 Status Change: Resolved"@en ;
    noria:loggingTime "2024-04-20T11:50:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system/ticketing> ;
    noria:logText "Trouble Ticket INC-DNS-20240420-001 status changed to Resolved."@en .

noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord7, noria:EventRecord8 .

noria:EventRecord9 a noria:EventRecord ;
    rdfs:label "Change Request 1 Status Change: Approved"@en ;
    noria:loggingTime "2024-04-26T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system/change-management> ;
    noria:logText "Change Request CR-FW-20240501-001 status changed to Approved."@en .

noria:ChangeRequest1 noria:documentStatusHistory noria:EventRecord9 .

# Example of a CUid for a person
noria:CUid2 a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Martin's Corporate ID"@en ;
    rdfs:comment "Unique corporate identifier for Bob Martin."@en ;
    foaf:accountName "bmartin" ;
    observable:accountIdentifier "BMARTIN-EMP-002" ;
    foaf:holdsAccount foaf:Person2 .

# Example of a TroubleTicketFreezeItem
noria:EventRecord10 a noria:EventRecord ;
    rdfs:label "Trouble Ticket 2 Freeze Start"@en ;
    noria:loggingTime "2024-04-19T16:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system/ticketing> ;
    noria:logText "Trouble Ticket INC-CRM-20240419-002 frozen due to external dependency."@en .

noria:EventRecord11 a noria:EventRecord ;
    rdfs:label "Trouble Ticket 2 Freeze End"@en ;
    noria:loggingTime "2024-04-19T17:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system/ticketing> ;
    noria:logText "Trouble Ticket INC-CRM-20240419-002 unfrozen."@en .

noria:TroubleTicket2 noria:troubleTicketFreezeItem noria:EventRecord10, noria:EventRecord11 .

# Example of a noria:troubleTicketPartyIntervention
# This property is an ObjectProperty but its range is not explicitly defined as a class in the provided schema.
# It's typically used to link to a specific intervention record or event.
# For density, I'll link it to an EventRecord that describes an intervention.
noria:TroubleTicket1 noria:troubleTicketPartyIntervention noria:EventRecord12 .

noria:EventRecord12 a noria:EventRecord ;
    rdfs:label "DNS Admin Team Intervention"@en ;
    rdfs:comment "DNS Admin Team started investigation on DNS server."@en ;
    noria:loggingTime "2024-04-20T10:08:00Z"^^xsd:dateTime ;
    noria:logOriginatingAgent foaf:Agent1 ;
    noria:logText "DNS Admin Team acknowledged TT and started troubleshooting."@en .

# Example of a noria:alarmMitigatedBy
noria:EventRecord13 a noria:EventRecord ;
    rdfs:label "DNS Server Restarted"@en ;
    rdfs:comment "DNS Server 01 was restarted, resolving the CPU high issue."@en ;
    noria:loggingTime "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingAgent foaf:Person1 ;
    noria:logText "Server restart command issued."@en .

noria:TroubleTicket1 noria:alarmMitigatedBy <noria:ProcedureExecutionContainer2> .

<noria:ProcedureExecutionContainer2> a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS Server Restart Procedure Execution"@en ;
    dcterms:created "2024-04-20T10:40:00Z"^^xsd:dateTime ;
    ldp:member noria:EventRecord13 .

# Example of noria:alarmMonitoredAttribute
noria:EventRecord14 a noria:EventRecord ;
    rdfs:label "CPU Usage Snapshot"@en ;
    rdfs:comment "Snapshot of CPU usage on DNS server at the time of alert."@en ;
    noria:loggingTime "2024-04-20T10:04:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logText "CPU_USAGE: { 'core1': 95, 'core2': 92, 'core3': 88, 'core4': 90 }"@en ;
    noria:alarmMonitoredAttribute <http://example.com/attribute/cpuUsage> . # Assuming a URI for the attribute

# Example of noria:virtualServerStatus
noria:Resource8 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy org:OrgUnit2 ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel4 ; # Running on ESXi host
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/up> ;
    seas:subSystemOf noria:Resource4 . # VM is a subsystem of the ESXi host

noria:Resource9 a noria:Resource ;
    rdfs:label "Web Server VM 02"@en ;
    rdfs:comment "Secondary virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy org:OrgUnit2 ;
    noria:resourceHostName "web02.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel4 ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/degraded> ;
    seas:subSystemOf noria:Resource4 .

# Link web servers to the Corporate Internet Access application
noria:Resource8 noria:resourceForApplication noria:Application1 .
noria:Resource9 noria:resourceForApplication noria:Application1 .

# Example of noria:applicationModuleSupportGroup and noria:applicationModuleHotlineGroup
noria:ApplicationModule1 noria:applicationModuleSupportGroup org:OrgUnit3 ;
    noria:applicationModuleHotlineGroup foaf:Agent2 .

# Example of noria:changeRequestRelatedParty (general)
noria:ChangeRequest1 dcterms:contributor foaf:Agent3 . # Application team might be a contributor to the change request

# Example of noria:elementDistinguishedName and noria:functionalElementDistinguishedName
noria:Resource1 noria:elementDistinguishedName "dns01.corp.example.com" .
noria:Application1 noria:functionalElementDistinguishedName "Corporate Internet Access" .

# Example of noria:structuralElementObservableData
noria:NetworkInterface1 noria:structuralElementObservableData "100"^^xsd:int . # Routing metric
noria:NetworkInterface2 noria:structuralElementObservableData "-3"^^xsd:int . # Tx power

# Example of noria:structuralElementObservable (linking to a class instance)
# This would require defining a class for "CPU Usage" as a StructuralObservable.
# For simplicity and to stay within the provided schema, I'll stick to direct data properties or existing object properties.
# If I were to create one:
# noria:CPUUsageObservable1 a noria:StructuralObservable ;
#     rdfs:label "CPU Usage Percentage"@en ;
#     noria:hasValue "95"^^xsd:int .
# noria:Resource1 noria:structuralElementObservable noria:CPUUsageObservable1 .

# To maximize density, ensure all created entities are linked.
# All Resources are linked to ProductModel, Agent, Location, and potentially Application.
# All NetworkInterfaces are linked to Resource and NetworkLink.
# All NetworkLinks are linked to Resources/Interfaces and Agent.
# All Applications are linked to type, importance, domain.
# All ApplicationModules are linked to Application, Agents/OrgUnits, and status.
# All Services are linked to type and ApplicationModules.
# All EventRecords are linked to time, originating object/system/agent, and text.
# All TroubleTickets are linked to severity, type, origin, related service/resource/party, and event records.
# All TroubleTicketNotes are linked to TroubleTicket, creator, type.
# All ChangeRequests are linked to planned times, category, type, cause, impact, status, and parties.
# All OperationPlans are linked to pre/post conditions.
# All AnomalyPatterns are described.
# All ActionPre/PostConditions are linked to OperationPlans.
# All Agents/OrgUnits are described and linked to managed resources/applications.
# All ProductModels are linked to manufacturers.
# All Locations are described and linked to sites/rooms.

# This graph is now quite dense and interconnected, covering various aspects of the NORIA vocabulary.
