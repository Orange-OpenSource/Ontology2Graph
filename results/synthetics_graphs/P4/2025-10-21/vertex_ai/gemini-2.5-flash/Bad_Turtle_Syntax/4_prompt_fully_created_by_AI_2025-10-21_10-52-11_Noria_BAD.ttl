noria:Service3 a noria:Service ;
    rdfs:label "Security Monitoring Service"@en ;
    rdfs:comment "Internal service for continuous monitoring of security events and incidents."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:ApplicationModule4 .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Server CPU High Alert"@en ;
    rdfs:comment "CPU utilization on dns01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application3 ; # CLS as monitoring system
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "CPU_HIGH: dns01.corp.example.com CPU usage 95%."@en .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "WAN Link Down Alert"@en ;
    rdfs:comment "WAN link between Paris and Lyon data centers went down."@en ;
    noria:loggingTime "2024-04-20T11:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ; # Core Router 01 Paris
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "LINK_DOWN: Interface xe-0/0/1 on cr01.par.example.com is down."@en ;
    noria:alarmProposedRepairAction <noria:OperationPlan1> . # Link to a repair plan

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "Failed Login Attempt - CRM DB"@en ;
    rdfs:comment "Multiple failed login attempts detected on CRM database server."@en ;
    noria:loggingTime "2024-04-20T12:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ; # Database Server 01
    noria:logOriginatingManagementSystem noria:Application4 ; # IDS as security monitoring
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logText "SECURITY_ALERT: 5 failed login attempts for user 'admin' on db01.crm.example.com."@en ;
    noria:logOriginatingAgent foaf:Agent4 . # SOC team might be the 'agent' here, or an automated system.

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Configuration Change - Firewall"@en ;
    rdfs:comment "A new firewall rule was added to fw01.corp.example.com."@en ;
    noria:loggingTime "2024-04-19T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource5 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logOriginatingAgent foaf:Person1 ; # Alice Dupont made the change
    noria:logText "CONFIG_CHANGE: Rule 'Allow_SSH_to_Dev' added by Alice Dupont."@en .

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "Virtual Machine Provisioned"@en ;
    rdfs:comment "New virtual machine 'dev-web-01' provisioned on esxi01.dev.example.com."@en ;
    noria:loggingTime "2024-04-18T09:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource4 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logOriginatingAgent foaf:Person2 ;
    noria:logText "VM_PROVISION: VM 'dev-web-01' created by Bob Martin."@en .

