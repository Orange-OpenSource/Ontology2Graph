    dcterms:title "Resource Type Concept Scheme"@en ;
    rdfs:comment "Defines types of IT resources."@en .

<kos/Resource/type/Server> a skos:Concept ;
    skos:prefLabel "Server"@en ;
    skos:altLabel "Serveur"@fr ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Router> a skos:Concept ;
    skos:prefLabel "Router"@en ;
    skos:altLabel "Routeur"@fr ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Switch> a skos:Concept ;
    skos:prefLabel "Switch"@en ;
    skos:altLabel "Commutateur"@fr ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/VirtualMachine> a skos:Concept ;
    skos:prefLabel "Virtual Machine"@en ;
    skos:altLabel "Machine Virtuelle"@fr ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Firewall> a skos:Concept ;
    skos:prefLabel "Firewall"@en ;
    skos:altLabel "Pare-feu"@fr ;
    skos:inScheme <kos/Resource/type> .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    dcterms:title "Resource Lifecycle State Concept Scheme"@en ;
    rdfs:comment "Defines lifecycle states for IT resources."@en .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:altLabel "En Production"@fr ;
    skos:inScheme <kos/Resource/LifecycleState> .

<kos/Resource/LifecycleState/Staging> a skos:Concept ;
    skos:prefLabel "Staging"@en ;
    skos:altLabel "Pré-production"@fr ;
    skos:inScheme <kos/Resource/LifecycleState> .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:prefLabel "Decommissioned"@en ;
    skos:altLabel "Hors Service"@fr ;
    skos:inScheme <kos/Resource/LifecycleState> .

# Notification Severity / Perceived Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    dcterms:title "Notification Perceived Severity Concept Scheme"@en ;
    rdfs:comment "Defines perceived severity levels for notifications and alarms."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:altLabel "Critique"@fr ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:prefLabel "Major"@en ;
    skos:altLabel "Majeur"@fr ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:altLabel "Mineur"@fr ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:prefLabel "Warning"@en ;
    skos:altLabel "Avertissement"@fr ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ;
    skos:prefLabel "Indeterminate"@en ;
    skos:altLabel "Indéterminé"@fr ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ;
