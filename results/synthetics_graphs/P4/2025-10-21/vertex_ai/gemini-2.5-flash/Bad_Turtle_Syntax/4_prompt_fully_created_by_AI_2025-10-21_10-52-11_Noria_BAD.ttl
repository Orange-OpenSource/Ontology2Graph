    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Hardware failure on primary DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ; # Assuming a KOS for TT status
    noria:troubleTicketRelatedParty foaf:Agent1, foaf:Agent2 ;
    noria:troubleTicketRelatedService noria:Application1 ;
    noria:troubleTicketRelatedResource noria:Resource1 ;
    noria:troubleTicketImpacts noria:Application1, noria:Resource1 ;
    noria:troubleTicketTrigger noria:EventRecord1 ;
    noria:documentExternalId "INC-DNS-20240420-001" ;
    noria:documentHRef <http://itsm.example.com/ticket/INC-DNS-20240420-001> .

