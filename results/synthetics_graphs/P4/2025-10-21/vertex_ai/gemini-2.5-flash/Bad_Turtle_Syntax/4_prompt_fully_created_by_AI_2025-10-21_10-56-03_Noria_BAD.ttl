noria:ProcedureExecutionContainer1 a pep:ProcedureExecutionContainer ;
    rdfs:label "Troubleshooting steps for Core Router Interface"@en ;
    dcterms:description "Execution of steps from 'Core Router Interface Troubleshooting Procedure'."@en ;
    pep:usedProcedure noria:OperationPlan1 .

noria:ProcedureExecutionContainer2 a pep:ProcedureExecutionContainer ;
    rdfs:label "Interface Reseat and Verification"@en ;
    dcterms:description "Physical reseating of fiber and verification of interface status."@en ;
    pep:usedProcedure noria:OperationPlan1 .

noria:ProcedureExecutionContainer3 a pep:ProcedureExecutionContainer ;
    rdfs:label "Firewall Rule Implementation"@en ;
