# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (Knowledge Organization System)
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ;
    dcterms:title "NORIA Application Types"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of applications within the NORIA ontology."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Applications that provide core infrastructure services."@en .

<kos/application/type/business> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "Applications directly supporting business operations."@en .

<kos/application/type/monitoring> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "Applications used for monitoring IT systems and services."@en .

<kos/application/type/security> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Security Application"@en ;
    rdfs:comment "Applications focused on IT security."@en .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ;
    dcterms:title "NORIA Application Business Importance"@en ;
    rdfs:comment "A controlled vocabulary for classifying the business importance of applications."@en .

<kos/application/business-importance/high> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for core business functions."@en .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application supports important but not critical business functions."@en .

<kos/application/business-importance/low> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Low Business Importance"@en ;
    rdfs:comment "Application supports non-critical business functions."@en .

# Application Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    dcterms:title "NORIA Application Module Status"@en ;
    rdfs:comment "A controlled vocabulary for classifying the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently active and serving users."@en .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Development"@en ;
    rdfs:comment "The application module is under development or testing."@en .

<https://w3id.org/noria/kos/application/status/Decommissioned> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "The application module has been retired from service."@en .

# Service Types
<kos/service/type> a skos:ConceptScheme ;
    dcterms:title "NORIA Service Types"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of services."@en .

<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "Services directly consumed by external customers."@en .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "Services that manage or provide resources for other services."@en .

<kos/service/type/InternalService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Internal Service"@en ;
    rdfs:comment "Services used internally within the organization."@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Severity"@en ;
    rdfs:comment "A controlled vocabulary for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Service completely unavailable or major business impact."@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant service degradation or moderate business impact."@en .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor"@en ;
    rdfs:comment "Small service impact or minor inconvenience."@en .

<kos/TroubleTicket/severity/Warning> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Potential issue detected, no immediate impact."@en .

# Trouble Ticket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Type"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of trouble tickets."@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Indicates a system or service failure."@en .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Request for help or support."@en .

<kos/TroubleTicket/type/Maintenance> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Maintenance"@en ;
    rdfs:comment "Related to scheduled or unscheduled maintenance activities."@en .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Category"@en ;
    rdfs:comment "A controlled vocabulary for classifying the technical impact or nature of trouble tickets."@en .

<kos/TroubleTicket/trouble-category/InterruptedService> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "Service is completely unavailable."@en .

<kos/TroubleTicket/trouble-category/CorruptedService> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Corrupted Service"@en ;
    rdfs:comment "Service is available but data or functionality is compromised."@en .

<kos/TroubleTicket/trouble-category/DowngradingEquipment> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Downgrading Equipment"@en ;
    rdfs:comment "Equipment is operating below its expected performance."@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Priority"@en ;
    rdfs:comment "A controlled vocabulary for classifying the priority of trouble tickets."@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate action required."@en .

<kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, urgent action required."@en .

<kos/TroubleTicket/priority/P3> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 3"@en ;
    rdfs:comment "Medium priority, action required within service levels."@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Origin"@en ;
    rdfs:comment "A controlled vocabulary for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Ticket initiated by an external customer."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision"@en ;
    rdfs:comment "Ticket initiated by an automated monitoring system."@en .

<kos/TroubleTicket/origin/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Internal"@en ;
    rdfs:comment "Ticket initiated by an internal employee or team."@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Urgency"@en ;
    rdfs:comment "A controlled vocabulary for classifying the urgency of trouble tickets."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action to prevent further damage or restore service."@en .

<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Action can be scheduled for a later time without critical impact."@en .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Problem Responsibility"@en ;
    rdfs:comment "A controlled vocabulary for classifying the responsibility for a problem."@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility lies with the team managing core network infrastructure."@en .

<kos/TroubleTicket/problemResponsibility/ContractApplicationHosting> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Contract Application Hosting"@en ;
    rdfs:comment "Responsibility lies with a third-party application hosting provider."@en .

# Trouble Ticket Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Comment Type"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type of comments in trouble tickets."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team members only."@en .

<kos/TroubleTicket/commentType/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer Comment"@en ;
    rdfs:comment "Comment visible to the customer."@en .

# Trouble Ticket Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Operation Type"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type of operations performed during trouble ticket resolution."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Operation related to diagnosing the root cause of the problem."@en .

<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Tests and Measurements"@en ;
    rdfs:comment "Operation involving testing and measuring system parameters."@en .

# Change Request Category
<kos/ChangeRequest/category> a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Category"@en ;
    rdfs:comment "A controlled vocabulary for classifying the category of change requests."@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change performed by internal teams."@en .

<kos/ChangeRequest/category/ThirdPartyIntervention> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Third Party Intervention"@en ;
    rdfs:comment "Change performed by external vendors or partners."@en .

# Change Request Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Type"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type of change requests based on impact and risk."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Pre-approved, low-risk, frequently performed changes."@en .

<kos/ChangeRequest/type/Normal> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Normal Change"@en ;
    rdfs:comment "Changes requiring assessment and authorization."@en .

<kos/ChangeRequest/type/Emergency> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Emergency Change"@en ;
    rdfs:comment "Changes required to resolve critical incidents, with expedited approval."@en .

# Change Request Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Cause"@en ;
    rdfs:comment "A controlled vocabulary for classifying the cause or reason for change requests."@en .

<kos/ChangeRequest/cause/Configuration> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change related to system configuration."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change related to upgrading software versions."@en .

# Change Request Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Status"@en ;
    rdfs:comment "A controlled vocabulary for classifying the current status of change requests."@en .

<kos/ChangeRequest/status/Planned> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Planned"@en ;
    rdfs:comment "Change is planned but not yet started."@en .

<kos/ChangeRequest/status/InProgress> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Change implementation is currently underway."@en .

<kos/ChangeRequest/status/Completed> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Completed"@en ;
    rdfs:comment "Change implementation has been successfully completed."@en .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Operational State"@en ;
    rdfs:comment "A controlled vocabulary for classifying the operational state of resources."@en .

<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is fully operational."@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

<kos/Resource/OperationalState/Degraded> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Degraded"@en ;
    rdfs:comment "Resource is operational but with reduced performance or functionality."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Administrative State"@en ;
    rdfs:comment "A controlled vocabulary for classifying the administrative state of resources."@en .

<kos/Resource/AdministrativeState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative Up"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative Down"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

# Resource Type
<kos/Resource/type> a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Type"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of IT resources."@en .

<kos/Resource/type/Server> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A physical or virtual server."@en .

<kos/Resource/type/Router> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router device."@en .

<kos/Resource/type/Switch> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network switch device."@en .

<kos/Resource/type/Firewall> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Firewall"@en ;
    rdfs:comment "A network security firewall device."@en .

<kos/Resource/type/VirtualMachine> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Virtual Machine"@en ;
    rdfs:comment "A virtualized computing instance."@en .

<kos/Resource/type/LoadBalancer> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Load Balancer"@en ;
    rdfs:comment "A network device distributing traffic across multiple servers."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Lifecycle State"@en ;
    rdfs:comment "A controlled vocabulary for classifying the lifecycle state of resources."@en .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Resource is actively used in production."@en .

<kos/Resource/LifecycleState/Staging> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Staging"@en ;
    rdfs:comment "Resource is in a pre-production or testing environment."@en .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "Resource has been retired from service."@en .

# Event Type
<kos/Notification/EventType> a skos:ConceptScheme ;
    dcterms:title "NORIA Event Record Type"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of event records."@en .

<kos/Notification/EventType/StateChange> a skos:Concept ;
    skos:inScheme <kos/Notification/EventType> ;
    rdfs:label "State Change Event"@en ;
    rdfs:comment "Event indicating a change in the operational state of an entity."@en .

<kos/Notification/EventType/ThresholdExceeded> a skos:Concept ;
    skos:inScheme <kos/Notification/EventType> ;
    rdfs:label "Threshold Exceeded Event"@en ;
    rdfs:comment "Event indicating a monitored metric has crossed a defined threshold."@en .

<kos/Notification/EventType/SecurityAlert> a skos:Concept ;
    skos:inScheme <kos/Notification/EventType> ;
    rdfs:label "Security Alert Event"@en ;
    rdfs:comment "Event indicating a potential security incident."@en .

# Perceived Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    dcterms:title "NORIA Perceived Severity"@en ;
    rdfs:comment "A controlled vocabulary for classifying the perceived severity of alarms."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Highest severity, immediate attention required."@en .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "High severity, significant impact."@en .

<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Minor Severity"@en ;
    rdfs:comment "Low severity, minor impact."@en .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning Severity"@en ;
    rdfs:comment "Potential issue, no immediate impact."@en .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    dcterms:title "NORIA Agent Contact Method"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Ticketing System"@en ;
    rdfs:comment "Preferred contact method is through the ticketing system."@en .

# Application SLA Level
<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
    dcterms:title "NORIA Application SLA Level"@en ;
    rdfs:comment "A controlled vocabulary for classifying the Service Level Agreement (SLA) level of application modules."@en .

<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest SLA level with maximum availability and performance guarantees."@en .

<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Medium SLA level with good availability and performance guarantees."@en .

<https://w3id.org/noria/kos/application/sla-level/Bronze> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Bronze SLA Level"@en ;
    rdfs:comment "Basic SLA level with standard availability and performance."@en .

# Change Request Specification
<kos/ChangeRequest/specification> a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Specification"@en ;
    rdfs:comment "A controlled vocabulary for classifying the specification or procedure associated with change requests."@en .

<kos/ChangeRequest/specification/StandardOperatingProcedure-001> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Standard Operating Procedure 001"@en ;
    rdfs:comment "A standard operating procedure for routine changes."@en .

<kos/ChangeRequest/specification/EmergencyMaintenance-002> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Emergency Maintenance Procedure 002"@en ;
    rdfs:comment "A procedure for handling emergency maintenance activities."@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "8:00 am - 12:00 am / 1:00 pm - 5:30 pm (Mon --> Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use the Ticketing system + hotline phone number for national L2 and L3 issues."@en ;
    foaf:mbox <mailto:dns-admin@example.com> .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, call directly. For minor issues, use ticketing system."@en ;
    foaf:mbox <mailto:noc@example.com> .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second level support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon --> Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate from L1 tickets. Ensure all relevant logs are attached."@en ;
    foaf:mbox <mailto:app-support-l2@example.com> .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report all security incidents via dedicated portal."@en ;
    foaf:mbox <mailto:soc@example.com> .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "Database Admin Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon --> Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For urgent database issues, open a P1 ticket and call the on-call DBA."@en ;
    foaf:mbox <mailto:dba-team@example.com> .

foaf:Agent6 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual IT Administrator."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon --> Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    foaf:mbox <mailto:john.doe@example.com> .

foaf:Agent7 a foaf:Agent ;
    rdfs:label "Project Manager IT"@en ;
    rdfs:comment "Manages IT projects and coordinates changes."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    foaf:mbox <mailto:pm.it@example.com> .

org:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en ;
    rdfs:comment "Department responsible for all IT infrastructure."@en ;
    org:hasMember foaf:Agent1, foaf:Agent2, foaf:Agent5 ;
    org:hasSubOrganization org:OrgUnit3 .

org:OrgUnit2 a org:OrganizationalUnit ;
    rdfs:label "Business Applications Department"@en ;
    rdfs:comment "Department responsible for business-critical applications."@en ;
    org:hasMember foaf:Agent3 .

org:OrgUnit3 a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Department"@en ;
    rdfs:comment "Department responsible for the organization's cybersecurity posture."@en ;
    org:hasMember foaf:Agent4 .

org:OrgUnit4 a org:OrganizationalUnit ;
    rdfs:label "IT Project Management Office"@en ;
    rdfs:comment "Office responsible for overseeing IT projects."@en ;
    org:hasMember foaf:Agent7 .

