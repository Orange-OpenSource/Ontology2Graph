# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "Core Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving core router interface issues."@en ;
    skos:example "Steps include checking physical connection, interface status, logs, and attempting soft/hard reset."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "Interface Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition: A network interface is reported as 'down' by monitoring systems."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "Interface Up Post-Condition"@en ;
    rdfs:comment "Post-condition: The network interface is 'up' and traffic is flowing normally."@en .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "CRM Database Performance Tuning Guide"@en ;
    rdfs:comment "Procedure for optimizing CRM database performance, including query optimization and resource allocation."@en ;
    skos:example "Steps include analyzing SQL queries, checking index usage, and adjusting server parameters."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "CRM Slow Performance Pre-Condition"@en ;
    rdfs:comment "Pre-condition: CRM application users report slow response times, and database metrics show high latency."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "CRM Performance Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: CRM application response times are within acceptable limits, and database latency is normalized."@en .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "DNS Server CPU Troubleshooting"@en ;
    rdfs:comment "Procedure to investigate and resolve high CPU utilization on DNS servers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition3 ;
    noria:operationPlanPostCondition noria:ActionPostCondition3 .

noria:ActionPreCondition3 a noria:ActionPreCondition ;
    rdfs:label "High DNS CPU Pre-Condition"@en ;
    rdfs:comment "Pre-condition: DNS server CPU utilization consistently above 80%."@en .

noria:ActionPostCondition3 a noria:ActionPostCondition ;
    rdfs:label "Normal DNS CPU Post-Condition"@en ;
    rdfs:comment "Post-condition: DNS server CPU utilization returns to normal operating levels (below 50%)."@en .

noria:OperationPlan4 a noria:OperationPlan ;
    rdfs:label "CRM Application Deployment Procedure"@en ;
    rdfs:comment "Standard procedure for deploying new versions of the CRM application."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition4 ;
    noria:operationPlanPostCondition noria:ActionPostCondition4 .

noria:ActionPreCondition4 a noria:ActionPreCondition ;
    rdfs:label "Code Ready for Deployment Pre-Condition"@en ;
    rdfs:comment "Pre-condition: New CRM application code has passed all testing in development and staging environments."@en .

noria:ActionPostCondition4 a noria:ActionPostCondition ;
    rdfs:label "Application Deployed Successfully Post-Condition"@en ;
    rdfs:comment "Post-condition: New CRM application version is running in production without errors and accessible to users."@en .

