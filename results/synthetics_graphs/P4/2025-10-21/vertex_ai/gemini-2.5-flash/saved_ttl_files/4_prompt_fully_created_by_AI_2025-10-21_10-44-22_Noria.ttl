    rdfs:comment "Log entry for a configuration change performed by Jane Smith on Edge Router 01."@en ;
    noria:loggingTime "2024-03-14T16:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Router_Edge01 ;
