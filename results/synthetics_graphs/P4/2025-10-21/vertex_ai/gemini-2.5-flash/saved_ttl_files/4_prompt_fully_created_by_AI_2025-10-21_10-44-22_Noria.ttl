    noria:logOriginatingManagedObject noria:Resource_Router_Edge01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_CRM_HighCPU_Alert a noria:EventRecord ;
    rdfs:label "CRM VM High CPU Alert"@en ;
