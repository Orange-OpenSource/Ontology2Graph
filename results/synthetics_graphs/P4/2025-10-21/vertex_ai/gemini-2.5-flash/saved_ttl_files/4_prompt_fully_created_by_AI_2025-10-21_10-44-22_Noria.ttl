    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "DNS service unresponsive on dns01.corp.example.com. Error code 503."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_Interface_Down_Log a noria:EventRecord ;
    rdfs:label "Network Interface Down Log"@en ;
