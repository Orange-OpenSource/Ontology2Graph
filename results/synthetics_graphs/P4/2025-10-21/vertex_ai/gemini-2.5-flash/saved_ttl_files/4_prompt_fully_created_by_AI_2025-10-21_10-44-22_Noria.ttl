    noria:logOriginatingManagedObject noria:Resource_VM_CRM_Prod ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "CPU utilization on crm-prod-vm01 exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:Event_Security_LoginFail a noria:EventRecord ;
    rdfs:label "Failed Login Attempt Alert"@en ;
    rdfs:comment "Security alert for multiple failed login attempts on a critical server."@en ;
    noria:loggingTime "2024-03-15T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logOriginatingAgent <http://example.com/malicious_actor_ip/192.168.1.100> ; # Example of an external agent
    noria:logText "Multiple failed login attempts detected for user 'admin' on dns01.corp.example.com from 192.168.1.100."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_Config_Change a noria:EventRecord ;
