    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestIsRegulated "true"^^xsd:boolean .

# =============================================================================
# Procedural Elements
# =============================================================================

noria:OP_DNS_Troubleshooting a noria:OperationPlan ;
    rdfs:label "DNS Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving DNS service outages."@en ;
    skos:example "Steps include checking server status, network connectivity, and DNS service logs."@en .

noria:OP_Interface_Restart a noria:OperationPlan ;
    rdfs:label "Network Interface Restart Procedure"@en ;
    rdfs:comment "Procedure for administratively bouncing a network interface on a router."@en ;
    skos:example "Commands: 'shutdown', 'no shutdown'."@en .

noria:OP_CRM_DB_Upgrade a noria:OperationPlan ;
    rdfs:label "CRM Database Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the CRM application's database backend."@en ;
    skos:example "Includes backup, schema migration, and post-upgrade verification."@en .

noria:AP_DNS_Unresponsive a noria:AnomalyPattern ;
    rdfs:label "DNS Service Unresponsive Pattern"@en ;
    rdfs:comment "Pattern indicating that DNS queries are failing or timing out from multiple sources."@en ;
    folio:hasCause "DNS service process crashed or network connectivity issue."@en .

noria:AP_High_CPU_Load a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Pattern"@en ;
    rdfs:comment "Pattern indicating that a server or VM is experiencing prolonged high CPU utilization."@en ;
    folio:hasCause "Application bug, resource contention, or malicious process."@en .

noria:PreCond_DNS_PingFail a noria:ActionPreCondition ;
    rdfs:label "DNS Server Ping Failure"@en ;
    rdfs:comment "Condition: DNS server IP address is not reachable via ping."@en ;
    noria:operationPlanPreCondition noria:OP_DNS_Troubleshooting .

noria:PostCond_DNS_ServiceRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS queries are successfully resolved, and service is operational."@en ;
    noria:operationPlanPostCondition noria:OP_DNS_Troubleshooting .

noria:PreCond_Interface_Down_Status a noria:ActionPreCondition ;
    rdfs:label "Network Interface Operational Status Down"@en ;
    rdfs:comment "Condition: Network interface reports operational status as 'down'."@en ;
    noria:operationPlanPreCondition noria:OP_Interface_Restart .

noria:PostCond_Interface_Up_Status a noria:ActionPostCondition ;
    rdfs:label "Network Interface Operational Status Up"@en ;
    rdfs:comment "Outcome: Network interface reports operational status as 'up'."@en ;
    noria:operationPlanPostCondition noria:OP_Interface_Restart .

# Example of linking an EventRecord to a ProcedureExecutionContainer (TroubleTicket)
noria:Event_DNS_Failure_Log dcterms:relation noria:TT_20240315_001 .
noria:Event_Interface_Down_Log dcterms:relation noria:TT_20240315_002 .
noria:Event_CRM_HighCPU_Alert dcterms:relation noria:TT_20240315_003 .

# Example of linking a TroubleTicketNote to a correlated execution (if it were a specific action)
# For simplicity, we'll link it to the TT itself as TT is a ProcedureExecutionContainer
noria:TTN_20240315_001_01 noria:troubleTicketNoteCorrelatedExecution noria:TT_20240315_001 .

# Example of linking a ChangeRequest to its related event
noria:CR_20240314_001 dcterms:relation noria:Event_Config_Change .

# Example of an alarm being mitigated by a procedure execution (represented by a TroubleTicket or ChangeRequest)
noria:Event_Interface_Down_Log noria:alarmMitigatedBy noria:TT_20240315_002 . # The TT represents the container of actions to mitigate the alarm

# Example of an action (implicitly part of a CR) being guided by an OperationPlan
# This would typically be a pep:ProcedureExecution, but we can link the CR to the OP directly for simplicity
noria:CR_20240316_002 noria:actionCorrelatedOperationPlan noria:OP_CRM_DB_Upgrade .
