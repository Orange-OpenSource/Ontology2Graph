# === Agents (foaf:Agent) =====================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    rdfs:label "Équipe d'administration DNS"@fr ;
    rdfs:comment "Équipe responsable de la gestion et de la résolution des serveurs DNS."@fr ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email to dns-support@example.com for non-critical issues."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to incidents."@en ;
    rdfs:label "Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "Équipe 24/7 surveillant l'infrastructure réseau et répondant aux incidents."@fr ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline for critical network outages."@en .

