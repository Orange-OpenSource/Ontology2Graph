# === Operation Plans (noria:OperationPlan) ===================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading DNS server software."@en ;
    rdfs:label "Procédure de mise à niveau du serveur DNS"@fr ;
    noria:operationPlanPreCondition noria:PreCondition1 ;
    noria:operationPlanPostCondition noria:PostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Core Router Firmware Update Procedure"@en ;
    rdfs:comment "Standard operating procedure for updating core router firmware."@en ;
    rdfs:label "Procédure de mise à jour du firmware du routeur cœur"@fr ;
    noria:operationPlanPreCondition noria:PreCondition2 ;
    noria:operationPlanPostCondition noria:PostCondition2 .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Database Migration Procedure"@en ;
    rdfs:comment "Detailed procedure for migrating a production database to a new platform."@en ;
    rdfs:label "Procédure de migration de base de données"@fr ;
    noria:operationPlanPreCondition noria:PreCondition3 ;
    noria:operationPlanPostCondition noria:PostCondition3 .

noria:OperationPlan4 a noria:OperationPlan ;
    rdfs:label "Firewall Rule Deployment Procedure"@en ;
    rdfs:comment "Procedure for adding or modifying firewall rules in the DMZ."@en ;
    rdfs:label "Procédure de déploiement de règles de pare-feu"@fr .

noria:OperationPlan5 a noria:OperationPlan ;
    rdfs:label "CI/CD Agent Deployment Procedure"@en ;
    rdfs:comment "Procedure for deploying and configuring new build agents for the CI/CD pipeline."@en ;
    rdfs:label "Procédure de déploiement d'agent CI/CD"@fr .

noria:OperationPlan6 a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving issues with network interfaces."@en ;
    rdfs:label "Guide de dépannage des interfaces réseau"@fr .

noria:OperationPlan7 a noria:OperationPlan ;
    rdfs:label "Application Performance Troubleshooting"@en ;
    rdfs:comment "Procedure for diagnosing and resolving application performance issues."@en ;
    rdfs:label "Dépannage des performances applicatives"@fr .

noria:OperationPlan8 a noria:OperationPlan ;
    rdfs:label "Database Connectivity Check"@en ;
    rdfs:comment "Procedure to verify database connectivity and listener status."@en ;
    rdfs:label "Vérification de la connectivité de la base de données"@fr .

noria:OperationPlan9 a noria:OperationPlan ;
    rdfs:label "Log System Recovery Procedure"@en ;
    rdfs:comment "Steps to recover the centralized log management system after a failure."@en ;
    rdfs:label "Procédure de récupération du système de logs"@fr .

noria:OperationPlan10 a noria:OperationPlan ;
    rdfs:label "Microservice Scaling Procedure"@en ;
    rdfs:comment "Procedure for dynamically scaling microservice instances based on load."@en ;
    rdfs:label "Procédure de mise à l'échelle des microservices"@fr .

# === Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) =

noria:PreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Upgrade Pre-check"@en ;
    rdfs:comment "Verify current DNS service health, backup configuration, and network reachability before upgrade."@en ;
    rdfs:label "Vérification préalable de la mise à niveau DNS"@fr .

noria:PostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Verified"@en ;
    rdfs:comment "Confirm DNS service is running, resolving queries correctly, and accessible from all clients after upgrade."@en ;
    rdfs:label "Service DNS vérifié"@fr .

noria:PreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Router Update Pre-check"@en ;
    rdfs:comment "Verify current router configuration, routing table stability, and redundant path availability before firmware update."@en ;
    rdfs:label "Vérification préalable de la mise à jour du routeur"@fr .

noria:PostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Router Connectivity Verified"@en ;
    rdfs:comment "Confirm all interfaces are up, routing protocols converged, and traffic flows correctly after firmware update."@en ;
    rdfs:label "Connectivité du routeur vérifiée"@fr .

noria:PreCondition3 a noria:ActionPreCondition ;
    rdfs:label "DB Migration Pre-check"@en ;
    rdfs:comment "Verify source database health, perform full backup, and ensure target platform readiness before migration."@en ;
    rdfs:label "Vérification préalable de la migration de la base de données"@fr .

noria:PostCondition3 a noria:ActionPostCondition ;
    rdfs:label "DB Data Integrity Verified"@en ;
    rdfs:comment "Confirm all data migrated successfully, applications connect to new database, and data integrity checks pass."@en ;
    rdfs:label "Intégrité des données de la base de données vérifiée"@fr .

