# --- Operation Plans ---
<operationPlan/StandardServerReboot> a noria:OperationPlan ;
    rdfs:label "Standard Server Reboot Procedure"@en ;
    rdfs:comment "A documented procedure for safely rebooting a production server."@en ;
    skos:example "Steps include: notify stakeholders, check service dependencies, initiate graceful shutdown, verify restart, monitor services."@en ;
    noria:operationPlanPreCondition <actionPreCondition/ServerReachable> ;
    noria:operationPlanPostCondition <actionPostCondition/ServiceRestored> .

<operationPlan/NetworkInterfaceTroubleshooting> a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving issues with network interfaces."@en ;
    skos:example "Steps include: check cable, verify configuration, test connectivity, check logs, replace hardware."@en ;
    noria:operationPlanPreCondition <actionPreCondition/InterfaceDown> ;
    noria:operationPlanPostCondition <actionPostCondition/InterfaceUp> .

<operationPlan/DatabaseBackupProcedure> a noria:OperationPlan ;
    rdfs:label "Database Daily Backup Procedure"@en ;
    rdfs:comment "Automated and manual steps for ensuring daily backups of critical databases."@en ;
    skos:example "Steps include: verify backup job status, check log files for errors, test restore process periodically."@en ;
    noria:operationPlanPreCondition <actionPreCondition/DBOperational> ;
    noria:operationPlanPostCondition <actionPostCondition/BackupSuccessful> .

# --- Action Pre/Post Conditions ---
<actionPreCondition/ServerReachable> a noria:ActionPreCondition ;
    rdfs:label "Server Reachable Pre-condition"@en ;
    rdfs:comment "Condition that the server must be reachable via ping/SSH before proceeding with an operation."@en .

<actionPostCondition/ServiceRestored> a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-condition"@en ;
    rdfs:comment "Condition that the affected service must be fully operational after an intervention."@en ;
    skos:example "Customer portal accessible, DNS resolution working, CRM backend responsive."@en .

<actionPreCondition/InterfaceDown> a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-condition"@en ;
    rdfs:comment "Condition that a specific network interface is reported as down."@en .

<actionPostCondition/InterfaceUp> a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-condition"@en ;
    rdfs:comment "Condition that the network interface is operational and traffic is flowing."@en .

<actionPreCondition/DBOperational> a noria:ActionPreCondition ;
    rdfs:label "Database Operational Pre-condition"@en ;
    rdfs:comment "Condition that the database system is running and accessible."@en .

<actionPostCondition/BackupSuccessful> a noria:ActionPostCondition ;
    rdfs:label "Backup Successful Post-condition"@en ;
    rdfs:comment "Condition that the database backup completed without errors and is verifiable."@en .

# --- Additional Connectivity and Density ---

# Link agents to resources they manage (inverse of noria:resourceManagedBy)
<agent/DNSAdminTeam> noria:agentManagesResource <resource/dns01> .
<agent/NetworkOpsCenter> noria:agentManagesResource <resource/core-router01>, <resource/edge-router01>, <networkLink/cr01-er01-link> .
<agent/AppSupportL2> noria:agentManagesResource <resource/webserver01> .
<agent/DatabaseAdminTeam> noria:agentManagesResource <resource/dbserver01> .
<agent/SecurityOpsCenter> noria:agentManagesResource <resource/firewall01>, <networkLink/web01-fw01-link> .
<agent/CloudInfraTeam> noria:agentManagesResource <resource/kafka-broker01> .

# Link applications to resources they use (inverse of noria:resourceForApplication)
<application/CorporateInternetAccess> seas:hasSubSystem <resource/dns01>, <resource/core-router01>, <resource/edge-router01>, <resource/firewall01> .
<application/CustomerPortal> seas:hasSubSystem <resource/webserver01> .
<application/InternalCRM> seas:hasSubSystem <resource/dbserver01> .
<application/LogManagementSystem> seas:hasSubSystem <resource/kafka-broker01> .

# Link application modules to resources they use
<applicationModule/CustomerPortalProd> seas:hasSubSystem <resource/webserver01> .
<applicationModule/CRMBackend> seas:hasSubSystem <resource/dbserver01> .
<applicationModule/LogAggProd> seas:hasSubSystem <resource/kafka-broker01> .

# Link services to application modules they use
<service/ECommerceService> seas:hasSubSystem <applicationModule/CustomerPortalProd>, <applicationModule/CRMBackend> .
<service/VPNService> seas:hasSubSystem <application/CorporateInternetAccess> .
<service/DataAnalyticsService> seas:hasSubSystem <applicationModule/LogAggProd> .

# Link trouble tickets to related parties (individuals)
<troubleTicket/DNSOutageTT> noria:troubleTicketRelatedParty <agent/AliceSmith> .
<troubleTicket/CustomerPortalSlowdownTT> noria:troubleTicketRelatedParty <agent/BobJohnson> .
<troubleTicket/DBDiskFullTT> noria:troubleTicketRelatedParty <agent/CarolWhite> .

# Link change requests to related parties (individuals)
<changeRequest/WebserverOSUpgrade> noria:changeRequestActorParty <agent/BobJohnson> .
<changeRequest/FirewallRuleUpdate> noria:changeRequestActorParty <agent/DavidGreen> .
<changeRequest/CRMDBMigration> noria:changeRequestActorParty <agent/CarolWhite> .

# Example of document status history for a TroubleTicket
<troubleTicket/DNSOutageTT> noria:documentStatusHistory <eventRecord/DNSOutageStatusChange1>, <eventRecord/DNSOutageStatusChange2> .

<eventRecord/DNSOutageStatusChange1> a noria:EventRecord ;
    rdfs:label "DNS Outage Status: InProgress"@en ;
    rdfs:comment "Status change for DNS Outage TT to InProgress."@en ;
    noria:loggingTime "2024-04-20T09:06:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "TroubleTicket TT-2024-001 status changed to InProgress."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> .

<eventRecord/DNSOutageStatusChange2> a noria:EventRecord ;
    rdfs:label "DNS Outage Status: Resolved"@en ;
    rdfs:comment "Status change for DNS Outage TT to Resolved."@en ;
    noria:loggingTime "2024-04-20T10:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "TroubleTicket TT-2024-001 status changed to Resolved."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> .

# Example of a TroubleTicketNote correlated execution
<troubleTicketNote/DNSOutageNote1> noria:troubleTicketNoteCorrelatedExecution <pep/PowerCycleAction> .

<pep/PowerCycleAction> a pep:ProcedureExecutionContainer ;
    rdfs:label "Power Cycle Rack A1"@en ;
    rdfs:comment "Execution container for the power cycle action on Rack A1, which hosts dns01."@en ;
    dcterms:created "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    pep:hasProcedure <operationPlan/StandardServerReboot> .

# Example of an alarm being mitigated by a procedure execution
<eventRecord/InterfaceDownAlarm> noria:alarmMitigatedBy <pep/InterfaceResetExecution> .

<pep/InterfaceResetExecution> a pep:ProcedureExecutionContainer ;
    rdfs:label "Interface Reset on CR01"@en ;
    rdfs:comment "Execution container for the administrative reset of interface ge-0/0/1 on core-router01."@en ;
    dcterms:created "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    pep:hasProcedure <operationPlan/NetworkInterfaceTroubleshooting> .

# Example of a resource being a cluster controller
<resource/virtual-center-01> a noria:Resource ;
    rdfs:label "VMware vCenter Server 01"@en ;
    rdfs:comment "Centralized management platform for VMware ESXi hosts and virtual machines."@en ;
    noria:resourceManagedBy <agent/CloudInfraTeam> ;
    noria:resourceHostName "vcenter01.corp.example.com" ;
    noria:resourceProductModel <productModel/VMwareESXi> ; # vCenter manages ESXi, so this is a bit of a stretch, but for connectivity.
    noria:resourceType <kos/Resource/type/management-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.50> .

<resource/vm-app-prod> a noria:Resource ;
    rdfs:label "Virtual Machine for Production Application"@en ;
    rdfs:comment "A virtual machine hosting a production application."@en ;
    noria:resourceManagedBy <agent/AppSupportL2> ;
    noria:resourceHostName "vm-app-prod.example.com" ;
    noria:resourceProductModel <productModel/VMwareESXi> ; # The VM runs on ESXi, not is ESXi. This is a simplification for the graph.
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:clusterController <resource/virtual-center-01> .

<resource/vm-db-staging> a noria:Resource ;
    rdfs:label "Virtual Machine for Staging Database"@en ;
    rdfs:comment "A virtual machine hosting a staging database instance."@en ;
    noria:resourceManagedBy <agent/DatabaseAdminTeam> ;
    noria:resourceHostName "vm-db-staging.example.com" ;
    noria:resourceProductModel <productModel/VMwareESXi> ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Staging> ;
    noria:clusterController <resource/virtual-center-01> .

# Example of virtual server status
<resource/vm-app-prod> noria:virtualServerStatus <kos/Resource/OperationalState/running> .
<resource/vm-db-staging> noria:virtualServerStatus <kos/Resource/OperationalState/running> .

# Example of network interface optical power metrics
<networkInterface/cr01-ge-0-0-1> noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Example of a ChangeRequest impacting a Service
<changeRequest/ServiceUpgrade> a noria:ChangeRequest ;
    rdfs:label "E-commerce Service Platform Upgrade"@en ;
    rdfs:comment "Major platform upgrade affecting the entire E-commerce Service."@en ;
    dcterms:created "2024-04-01T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-06-01T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-06-01T08:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact <service/ECommerceService> ;
    noria:changeRequestOutageDuration "PT8H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty <agent/BobJohnson> ;
    noria:changeRequestPilotParty <agent/AppSupportL2> ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef <http://itsm.example.com/change/CR-2024-004> .

# Example of AnomalyPattern
<anomalyPattern/HighCPULowThroughput> a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Throughput Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential performance bottleneck or resource contention where CPU usage is high but actual data throughput is low."@en ;
    skos:example "Observed on webserver01: CPU > 90%, Network I/O < 10Mbps."@en .

# Example of OperationPlan linked to AnomalyPattern (as a control method)
<operationPlan/PerformanceDiagnosis> a noria:OperationPlan ;
    rdfs:label "Application Performance Diagnosis Procedure"@en ;
    rdfs:comment "Procedure to diagnose and resolve application performance issues."@en ;
    folio:detects <anomalyPattern/HighCPULowThroughput> .

# Example of a CUid
<cuid/AliceSmithID> a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Unique corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount <agent/AliceSmith> .

<cuid/BobJohnsonID> a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Unique corporate user identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount <agent/BobJohnson> .

# Example of an EventRecord related to a CUid (e.g., an action performed by a user)
<eventRecord/UserActionLog> a noria:EventRecord ;
    rdfs:label "User Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change performed by a user."@en ;
    noria:loggingTime "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/edge-router01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "Configuration change applied by user 'asmith' on edge-router01."@en ;
    noria:logOriginatingAgent <agent/AliceSmith> .

# Example of a TroubleTicketNote with correlated execution (e.g., a command run)
<troubleTicketNote/CoreRouterNote2> a noria:TroubleTicketNote ;
    rdfs:label "Core Router Interface Reset Command"@en ;
    rdfs:comment "Command executed to reset the flapping interface."@en ;
    dcterms:created "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/System> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf <troubleTicket/CoreRouterInterfaceFlapTT> ;
    noria:troubleTicketNoteCorrelatedExecution <pep/InterfaceResetExecution> .

# Example of a DocumentAttachment
<documentAttachment/NetworkDiagram> a noria:DocumentAttachment ;
    rdfs:label "Corporate Network Diagram"@en ;
    rdfs:comment "PDF document showing the high-level corporate network topology."@en ;
    dcterms:created "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf" ;
    dcterms:title "Network_Topology_v2.3.pdf" ;
    dcterms:isPartOf <troubleTicket/CoreRouterInterfaceFlapTT> .

<documentAttachment/ServerLogExtract> a noria:DocumentAttachment ;
    rdfs:label "DNS Server Log Extract"@en ;
    rdfs:comment "Text file containing relevant log entries from dns01 during the outage."@en ;
    dcterms:created "2024-04-20T09:45:00Z"^^xsd:dateTime ;
    dcterms:format "text/plain" ;
    dcterms:title "dns01_outage_logs.txt" ;
    dcterms:isPartOf <troubleTicket/DNSOutageTT> .

# Example of a ChangeRequest with a specification
<changeRequest/FirewallRuleUpdate> noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardFirewallChange> .

<kos/ChangeRequest/specification/StandardFirewallChange> a skos:Concept ;
    rdfs:label "Standard Firewall Change Specification"@en ;
    rdfs:comment "Pre-approved specification for routine firewall rule modifications."@en .

# Example of a TroubleTicket with a problem responsibility
<troubleTicket/DNSOutageTT> noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> .
<troubleTicket/CustomerPortalSlowdownTT> noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> .

# Example of a TroubleTicket with a final problem category (after RCA)
<troubleTicket/DNSOutageTT> noria:problemCategory <kos/TroubleTicket/trouble-category/PowerFailure> .
<troubleTicket/CustomerPortalSlowdownTT> noria:problemCategory <kos/TroubleTicket/trouble-category/DatabaseContention> .

# Example of a ChangeRequest with actual start/end times (after execution)
<changeRequest/FirewallRuleUpdate>
    noria:changeRequestActualStartTime "2024-04-25T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-25T01:20:00Z"^^xsd:dateTime .

# Example of a TroubleTicket with notification enabled
<troubleTicket/DNSOutageTT> noria:troubleTicketIsNotificationEnable true .
<troubleTicket/CustomerPortalSlowdownTT> noria:troubleTicketIsNotificationEnable true .

# Example of a TroubleTicket with freeze item (e.g., during a planned maintenance window)
<troubleTicket/CoreRouterInterfaceFlapTT> noria:troubleTicketFreezeItem <eventRecord/CoreRouterFreezeStart>, <eventRecord/CoreRouterFreezeEnd> .

<eventRecord/CoreRouterFreezeStart> a noria:EventRecord ;
    rdfs:label "Core Router TT Freeze Start"@en ;
    rdfs:comment "Trouble Ticket TT-2024-003 entered freeze state for planned maintenance."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "TT-2024-003 status changed to Frozen due to planned maintenance on core-router01."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> .

<eventRecord/CoreRouterFreezeEnd> a noria:EventRecord ;
    rdfs:label "Core Router TT Freeze End"@en ;
    rdfs:comment "Trouble Ticket TT-2024-003 exited freeze state."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "TT-2024-003 status changed from Frozen to InProgress."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> .

# Example of a TroubleTicket with party intervention history
<troubleTicket/DNSOutageTT> noria:troubleTicketPartyIntervention <eventRecord/DNSAdminTeamIntervention>, <eventRecord/NOCIntervention> .

<eventRecord/DNSAdminTeamIntervention> a noria:EventRecord ;
    rdfs:label "DNS Admin Team Intervention Log"@en ;
    rdfs:comment "Log of DNS Admin Team taking ownership of DNS outage ticket."@en ;
    noria:loggingTime "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "Ownership of TT-2024-001 transferred to DNS Admin Team."@en ;
    noria:logOriginatingAgent <agent/DNSAdminTeam> ;
    dcterms:type <kos/Notification/EventType/ownershipChange> .

<eventRecord/NOCIntervention> a noria:EventRecord ;
    rdfs:label "NOC Escalation Log"@en ;
    rdfs:comment "Log of NOC escalating DNS outage to Incident Response Team."@en ;
    noria:loggingTime "2024-04-20T09:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "TT-2024-001 escalated to Incident Response Team by NOC."@en ;
    noria:logOriginatingAgent <agent/NetworkOpsCenter> ;
    dcterms:type <kos/Notification/EventType/escalation> .

# Example of a ChangeRequest with a related party (Change Management Team)
<changeRequest/WebserverOSUpgrade> noria:changeRequestRelatedParty <agent/ChangeManagementTeam> .
<changeRequest/FirewallRuleUpdate> noria:changeRequestRelatedParty <agent/ChangeManagementTeam> .
<changeRequest/CRMDBMigration> noria:changeRequestRelatedParty <agent/ChangeManagementTeam> .

# Example of a ChangeRequest being regulated
<changeRequest/CRMDBMigration> noria:changeRequestIsRegulated true .

# Example of a resource with multiple applications
<resource/shared-server-01> a noria:Resource ;
    rdfs:label "Shared Application Server 01"@en ;
    rdfs:comment "A server hosting multiple non-critical applications."@en ;
    noria:resourceManagedBy <agent/CloudInfraTeam> ;
    noria:resourceHostName "sharedapp01.example.com" ;
    noria:resourceProductModel <productModel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication <application/LogManagementSystem>, <application/MonitoringPlatform> .

# Example of an application module with support group and hotline group
<applicationModule/CustomerPortalProd>
    noria:applicationModuleSupportGroup <agent/AppSupportL2> ; # Can be the same as support team or a different L1 group
    noria:applicationModuleHotlineGroup <agent/IncidentResponseTeam> . # Hotline often goes to a dedicated incident team

# Example of a service composed of multiple application modules
<service/ECommerceService> seas:subSystemOf <applicationModule/CustomerPortalProd>, <applicationModule/CRMBackend> .

# Example of a resource being part of a site
<resource/dns01> bot:hasSpace <location/LocusA1> .
<resource/webserver01> bot:hasSpace <location/LocusB2> .

# Example of a site having a zero point (for geographical coordinates)
<location/DataCenterParis> bot:hasZeroPoint <wgs84_pos/ParisDCGeo> .
<wgs84_pos/ParisDCGeo> a wgs84_pos:Point ;
    wgs84_pos:lat "48.8566"^^xsd:float ;
    wgs84_pos:long "2.3522"^^xsd:float .

# Example of a resource with a specific characteristic (not directly in NORIA, but using dcterms:description for flexibility)
<resource/firewall01> dcterms:description "Firewall configured for high availability (active-passive)."@en .

# Example of an EventRecord with a probable cause (using dcterms:conformsTo)
<eventRecord/InterfaceDownAlarm> dcterms:conformsTo <kos/Notification/ProbableCause/HardwareFailure> .
<kos/Notification/ProbableCause/HardwareFailure> a skos:Concept ;
    rdfs:label "Hardware Failure"@en ;
    rdfs:comment "Probable cause: physical hardware component failure."@en .

# Example of an EventRecord with a security alarm cause
<eventRecord/LoginFailureLog> dcterms:conformsTo <kos/Notification/SecurityAlarmCause/AuthenticationFailure> .
<kos/Notification/SecurityAlarmCause/AuthenticationFailure> a skos:Concept ;
    rdfs:label "Authentication Failure"@en ;
    rdfs:comment "Security alarm cause: repeated failed authentication attempts."@en .

# Example of a TroubleTicket with a characteristic (using noria:troubleTicketCharacteristic)
<troubleTicket/DNSOutageTT> noria:troubleTicketCharacteristic <characteristic/DNSResolutionFailure> .

<characteristic/DNSResolutionFailure> a noria:Property ; # Using noria:Property as a generic characteristic class
    rdfs:label "DNS Resolution Failure"@en ;
    rdfs:comment "Characteristic indicating that DNS queries are failing or timing out."@en .

# Example of a ChangeRequest with a specific characteristic
<changeRequest/WebserverOSUpgrade> dcterms:description "Requires a full server reboot and application restart."@en .

# Example of a resource with a specific type of network interface (e.g., loopback)
<networkInterface/cr01-lo0> a noria:NetworkInterface ;
    rdfs:label "core-router01 lo0"@en ;
    rdfs:comment "Loopback interface on core-router01, used for management and routing protocols."@en ;
    noria:networkInterfaceOf <resource/core-router01> ;
    noria:networkInterfaceType "loopback"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# Example of a resource with a specific type of resource (e.g., load balancer)
<resource/loadbalancer01> a noria:Resource ;
    rdfs:label "Application Load Balancer 01"@en ;
    rdfs:comment "Distributes incoming application traffic across multiple web servers."@en ;
    noria:resourceManagedBy <agent/CloudInfraTeam> ;
    noria:resourceHostName "lb01.example.com" ;
    noria:resourceProductModel <productModel/DellPowerEdgeR740> ; # Placeholder, could be a specific LB appliance
    noria:resourceType <kos/Resource/type/load-balancer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication <application/CustomerPortal> .

# Example of a resource being managed by an individual agent
<resource/personal-dev-vm> a noria:Resource ;
    rdfs:label "Bob Johnson's Development VM"@en ;
    rdfs:comment "Virtual machine used by Bob Johnson for application development."@en ;
    noria:resourceManagedBy <agent/BobJohnson> ;
    noria:resourceHostName "bj-dev-vm.example.com" ;
    noria:resourceProductModel <productModel/VMwareESXi> ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Development> .

# Example of an agent having topic interest in a resource
<agent/BobJohnson> foaf:topic_interest <resource/personal-dev-vm>, <resource/webserver01> .
<agent/AliceSmith> foaf:topic_interest <resource/core-router01>, <resource/edge-router01> .

# Example of a TroubleTicketNote with a specific operation type (e.g., customer callback)
<troubleTicketNote/CustomerPortalNote2> a noria:TroubleTicketNote ;
    rdfs:label "Customer Callback for Portal Issue"@en ;
    rdfs:comment "Called customer to confirm portal slowness. Customer confirmed issue persists."@en ;
    dcterms:created "2024-04-20T12:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/LocalCustomerCallBack> ;
    dcterms:isPartOf <troubleTicket/CustomerPortalSlowdownTT> .

# Example of a ChangeRequest with a specific change cause (e.g., network extension)
<changeRequest/NetworkExpansion> a noria:ChangeRequest ;
    rdfs:label "Data Center Network Expansion"@en ;
    rdfs:comment "Expansion of network capacity within the Paris Data Center."@en ;
    dcterms:created "2024-03-10T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-15T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-15T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ;
    noria:changeRequestImpact <location/DataCenterParis>, <resource/core-router01> ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty <agent/AliceSmith> ;
    noria:changeRequestPilotParty <agent/NetworkOpsCenter> ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef <http://itsm.example.com/change/CR-2024-005> .

# Example of a resource with a specific operational state (e.g., maintenance)
<resource/edge-router01> noria:resourceUsageState <kos/Resource/LifecycleState/Maintenance> .

# Example of an application module with a specific status (e.g., decommissioned)
<applicationModule/CustomerPortalDev> noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Decommissioned> .

# Example of a TroubleTicket with a problem responsibility (e.g., customer)
<troubleTicket/CustomerConnectivityIssue> a noria:TroubleTicket ;
    rdfs:label "Customer Site Connectivity Issue"@en ;
    rdfs:comment "Customer reports loss of internet connectivity at their branch office."@en ;
    dcterms:created "2024-04-21T08:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketRelatedService <service/VPNService> ;
    noria:troubleTicketRelatedParty <agent/AliceSmith> ;
    noria:troubleTicketDescription "Customer site 'Branch-X' cannot reach corporate resources. Initial checks show no issue on our side."@en ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/IsolatedCustomerSite> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/NoIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/CustomerPremisesEquipment> ;
    noria:troubleTicketDetectionDateTime "2024-04-21T07:50:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/New> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/Customer> ;
    noria:documentHRef <http://itsm.example.com/ticket/TT-2024-005> .

# Example of a TroubleTicket with a problem category (e.g., customer premises equipment)
<troubleTicket/CustomerConnectivityIssue> noria:problemCategory <kos/TroubleTicket/trouble-category/CustomerPremisesEquipment> .

# Example of a ChangeRequest with a specific specification (e.g., standard configuration change)
<changeRequest/FirewallRuleUpdate> noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardFirewallChange> .

# Example of a resource with a specific management IP address (IPv6)
<resource/dns01> noria:resourceManagementIPAddress <http://example.com/ip/2001:0db8:0000:0000:0000:8a2e:0370:7334> .

# Example of a resource with a specific management IP address (IPv4)
<resource/webserver01> noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.101> .

