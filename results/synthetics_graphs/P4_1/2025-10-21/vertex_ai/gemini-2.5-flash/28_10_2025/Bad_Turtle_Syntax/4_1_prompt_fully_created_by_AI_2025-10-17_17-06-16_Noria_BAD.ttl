# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (Teams and Individuals) ---
<agent/DNSAdminTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'Administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution of related incidents."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

<agent/NetworkOpsCenter> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:label "Centre d'Opérations Réseau"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to alerts."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "All network-related incidents must be reported to NOC. Escalation matrix available on intranet."@en .

<agent/AppSupportL2> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:label "Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support for business applications, handling complex issues."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "Submit a ticket with full details. Only call for P1 incidents."@en .

<agent/SecurityOpsCenter> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:label "Centre d'Opérations de Sécurité"@fr ;
    rdfs:comment "Monitors and responds to security incidents and threats."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> ;
    noria:agentInstructions "Report all suspicious activities immediately via dedicated security channel."@en .

<agent/DatabaseAdminTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Admin Team"@en ;
    rdfs:label "Équipe d'Administration de Bases de Données"@fr ;
    rdfs:comment "Manages and maintains all corporate database systems."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "For database performance issues, provide query logs and relevant application context."@en .

<agent/CloudInfraTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cloud Infrastructure Team"@en ;
    rdfs:label "Équipe Infrastructure Cloud"@fr ;
    rdfs:comment "Manages and supports the company's cloud infrastructure and services."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "All cloud resource requests and issues must go through the cloud portal."@en .

<agent/IncidentResponseTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Incident Response Team"@en ;
    rdfs:label "Équipe de Réponse aux Incidents"@fr ;
    rdfs:comment "Specialized team for handling major incidents and coordinating resolution efforts."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Activated for P1/P2 incidents. Do not contact directly unless instructed by NOC/SOC."@en .

<agent/ChangeManagementTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Change Management Team"@en ;
    rdfs:label "Équipe de Gestion des Changements"@fr ;
    rdfs:comment "Responsible for reviewing, approving, and scheduling all IT changes."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit change requests via the change management portal at least 5 business days in advance."@en .

<agent/AliceSmith> a foaf:Agent, foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer, member of Network Operations Center."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

<agent/BobJohnson> a foaf:Agent, foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer, responsible for Customer Portal."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

<agent/CarolWhite> a foaf:Agent, foaf:Person ;
    rdfs:label "Carol White"@en ;
    rdfs:comment "Database Administrator, specializing in PostgreSQL."@en ;
    foaf:mbox <mailto:carol.white@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

<agent/DavidGreen> a foaf:Agent, foaf:Person ;
    rdfs:label "David Green"@en ;
    rdfs:comment "Security Analyst, part of the Security Operations Center."@en ;
    foaf:mbox <mailto:david.green@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> .

# --- Product Models ---
<productModel/DellPowerEdgeR740> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing and virtualization."@en ;
    noria:productManufacturedBy <org/DellTechnologies> .

<productModel/CiscoCatalyst9300> a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch for campus and branch deployments."@en ;
    noria:productManufacturedBy <org/CiscoSystems> .

<productModel/JuniperMX204> a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Compact, high-density universal routing platform for service providers and enterprises."@en ;
    noria:productManufacturedBy <org/JuniperNetworks> .

<productModel/VMwareESXi> a noria:ProductModel ;
    rdfs:label "VMware ESXi"@en ;
    rdfs:comment "Type-1 hypervisor for creating and running virtual machines."@en ;
    noria:productManufacturedBy <org/VMware> .

<productModel/PostgreSQL> a noria:ProductModel ;
    rdfs:label "PostgreSQL"@en ;
    rdfs:comment "Powerful, open source object-relational database system."@en ;
    noria:productManufacturedBy <org/PostgreSQLGlobalDevelopmentGroup> .

<productModel/ApacheKafka> a noria:ProductModel ;
    rdfs:label "Apache Kafka"@en ;
    rdfs:comment "Distributed streaming platform for building real-time data pipelines and streaming apps."@en ;
    noria:productManufacturedBy <org/ApacheSoftwareFoundation> .

<productModel/PaloAltoFirewall> a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220"@en ;
    rdfs:comment "Next-generation firewall for network security."@en ;
    noria:productManufacturedBy <org/PaloAltoNetworks> .

# --- Organizations (for productManufacturedBy) ---
<org/DellTechnologies> a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "American multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

<org/CiscoSystems> a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

<org/JuniperNetworks> a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en .

<org/VMware> a org:Organization ;
    rdfs:label "VMware"@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

<org/PostgreSQLGlobalDevelopmentGroup> a org:Organization ;
    rdfs:label "PostgreSQL Global Development Group"@en ;
    rdfs:comment "The global community of developers and users maintaining the PostgreSQL database."@en .

<org/ApacheSoftwareFoundation> a org:Organization ;
    rdfs:label "Apache Software Foundation"@en ;
    rdfs:comment "Non-profit corporation to support Apache software projects, including Apache Kafka."@en .

<org/PaloAltoNetworks> a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "American multinational cybersecurity company."@en .

# --- Locations ---
<location/DataCenterParis> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center facility located in Paris, France."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

<location/ServerRoomA> a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "A dedicated server room within the Paris Data Center."@en ;
    bot:hasSpace <location/DataCenterParis> .

<location/Rack1> a bot:Space ;
    rdfs:label "Rack 1"@en ;
    rdfs:comment "Physical rack unit within Server Room A."@en ;
    bot:hasSpace <location/ServerRoomA> .

<location/LocusA1> a noria:Locus ;
    rdfs:label "Locus A1 (Rack 1, Unit 1)"@en ;
    rdfs:comment "Specific location within Rack 1, Unit 1."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasSpace <location/Rack1> .

<location/LocusB2> a noria:Locus ;
    rdfs:label "Locus B2 (Rack 2, Unit 5)"@en ;
    rdfs:comment "Specific location within Rack 2, Unit 5."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "2"@en ;
    bot:hasSpace <location/Rack1> . # Assuming Rack1 is a generic rack, or create Rack2

# --- Resources ---
<resource/dns01> a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, critical infrastructure."@en ;
    noria:resourceManagedBy <agent/DNSAdminTeam> ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel <productModel/DellPowerEdgeR740> ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DELL-R740-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <application/CorporateInternetAccess> ;
    noria:locatedAtLocus <location/LocusA1> ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

