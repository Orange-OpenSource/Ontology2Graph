    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "Interface ge-0/0/1 on cr01.corp.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction <operationPlan/NetworkInterfaceTroubleshooting> .

<eventRecord/LoginFailureLog> a noria:EventRecord ;
