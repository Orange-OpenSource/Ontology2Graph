# --- Network Interfaces ---
<networkInterface/cr01-ge-0-0-1> a noria:NetworkInterface ;
    rdfs:label "core-router01 ge-0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/1 on core-router01, connected to edge-router01."@en ;
    noria:networkInterfaceOf <resource/core-router01> ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects <networkLink/cr01-er01-link> .

<networkInterface/er01-ge-0-0-1> a noria:NetworkInterface ;
    rdfs:label "edge-router01 ge-0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/1 on edge-router01, connected to core-router01."@en ;
    noria:networkInterfaceOf <resource/edge-router01> ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects <networkLink/cr01-er01-link> .

<networkInterface/web01-eth0> a noria:NetworkInterface ;
    rdfs:label "webserver01 eth0"@en ;
    rdfs:comment "Primary network interface for webserver01."@en ;
    noria:networkInterfaceOf <resource/webserver01> ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <networkLink/web01-fw01-link> .

<networkInterface/fw01-eth1> a noria:NetworkInterface ;
    rdfs:label "firewall01 eth1"@en ;
    rdfs:comment "Internal network interface for firewall01, connected to webserver01 segment."@en ;
    noria:networkInterfaceOf <resource/firewall01> ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <networkLink/web01-fw01-link> .

<networkInterface/db01-eth0> a noria:NetworkInterface ;
    rdfs:label "dbserver01 eth0"@en ;
    rdfs:comment "Primary network interface for dbserver01."@en ;
    noria:networkInterfaceOf <resource/dbserver01> ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links ---
<networkLink/cr01-er01-link> a noria:NetworkLink ;
    rdfs:label "Core-Edge Router Interconnect"@en ;
    rdfs:comment "High-speed link between core-router01 and edge-router01."@en ;
    noria:networkLinkId "NL-CR01-ER01-001" ;
    noria:networkLinkType "fiber-optic"@en ;
    noria:networkLinkInstallationDate "2021-11-01T12:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/core-router01> ;
    noria:networkLinkTerminationResourceDestination <resource/edge-router01> ;
    noria:resourceManagedBy <agent/NetworkOpsCenter> .

<networkLink/web01-fw01-link> a noria:NetworkLink ;
    rdfs:label "Webserver-Firewall Link"@en ;
    rdfs:comment "Internal network link connecting webserver01 to firewall01."@en ;
    noria:networkLinkId "NL-WEB01-FW01-001" ;
    noria:networkLinkType "ethernet"@en ;
    noria:networkLinkInstallationDate "2023-03-01T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/webserver01> ;
    noria:networkLinkTerminationResourceDestination <resource/firewall01> ;
    noria:resourceManagedBy <agent/SecurityOpsCenter> .

# --- Applications ---
<application/CorporateInternetAccess> a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet access for all corporate users and systems."@en ;
    noria:applicationModelIdentifier "CIA-001" ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
