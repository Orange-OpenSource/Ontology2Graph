<eventRecord/DBDiskFullAlert> a noria:EventRecord ;
    rdfs:label "Database Disk Full Alert"@en ;
    rdfs:comment "Alert indicating low disk space on dbserver01."@en ;
    noria:loggingTime "2024-04-20T13:45:00Z"^^xsd:dateTime ;
