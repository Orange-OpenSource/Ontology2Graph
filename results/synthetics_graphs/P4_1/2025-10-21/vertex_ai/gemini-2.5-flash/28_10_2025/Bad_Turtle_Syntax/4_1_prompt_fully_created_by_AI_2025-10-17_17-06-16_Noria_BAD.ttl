# --- Event Records ---
<eventRecord/DNSOutageLog> a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01 became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/dns01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<eventRecord/InterfaceDownAlarm> a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Alarm"@en ;
    rdfs:comment "Alarm triggered when core-router01's interface ge-0/0/1 went down."@en ;
