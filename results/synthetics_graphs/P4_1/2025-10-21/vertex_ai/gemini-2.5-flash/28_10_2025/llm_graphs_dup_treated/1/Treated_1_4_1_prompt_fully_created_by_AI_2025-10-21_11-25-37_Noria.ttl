# Agents (Teams)
foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server_extra_node_10 management."@en ;
    rdfs:label "Équipe Admin DNS"@fr ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_10> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical_extra_node_10 issues, use emergency hotline."@en ;
    org:memberOf org:NetworkServices .

foaf:Agent_NOC a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 team monitoring_extra_node_10 network infrastructure_extra_node_10 and responding to alerts."@en ;
