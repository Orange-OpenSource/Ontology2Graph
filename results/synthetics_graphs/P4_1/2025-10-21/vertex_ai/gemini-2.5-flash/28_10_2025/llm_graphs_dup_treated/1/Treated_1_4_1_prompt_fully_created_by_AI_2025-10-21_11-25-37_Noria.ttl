    rdfs:comment "Team providing support for business_extra_node_10 applications."@en ;
    rdfs:label "Équipe Support Applicatif"@fr ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_10> ;
    noria:agentInstructions "Use application-specific ticketing system. For critical_extra_node_10 issues, page on-call engineer."@en ;
