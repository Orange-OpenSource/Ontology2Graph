    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_10> ;
    noria:agentInstructions "All network alerts are routed here. Escalate to specific teams as per runbook."@en ;
    org:memberOf org:NetworkServices .

foaf:Agent_AppSupportTeam a foaf:Agent ;
