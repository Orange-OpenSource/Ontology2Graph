# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_DNSFailureLog a noria:EventRecord ;
    rdfs:label "DNS Resolution_extra_node_10 Failure_extra_node_10 Log"@en ;
    rdfs:comment "Log entry indicating a failure in DNS resolution on dns01."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01_extra_node_10 ;
    noria:logOriginatingManagementSystem noria:Application_LogManagementSystem ;
    noria:logText "DNS resolution failed for external domain example.com: Server_extra_node_10 Unreachable."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_10> .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router_extra_node_10 Interface Down Alarm"@en ;
    rdfs:comment "Alarm indicating that an interface on Core Router_extra_node_10 01 went down."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_LogManagementSystem ;
    noria:logText "Interface GigabitEthernet0/0/1 changed state to down."@en ;
    noria:loggingTime "2024-04-20T09:10:15Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_10> .

noria:EventRecord_ServerCPUAlert a noria:EventRecord ;
    rdfs:label "Web Server_extra_node_10 CPU Usage Alert"@en ;
    rdfs:comment "Alert for high_extra_node_10 CPU usage on E-commerce Web Server_extra_node_10 01."@en ;
