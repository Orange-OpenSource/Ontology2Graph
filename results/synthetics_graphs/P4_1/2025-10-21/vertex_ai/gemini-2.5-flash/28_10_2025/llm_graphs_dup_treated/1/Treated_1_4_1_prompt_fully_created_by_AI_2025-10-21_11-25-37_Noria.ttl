# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology_extra_node_10/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology_extra_node_10#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure_extra_node_10 Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology_extra_node_10
@prefix saref: <http://ontology_extra_node_10.tno.nl/saref#>.  #SAREF smart building appliances ontology_extra_node_10

@prefix observable: <https://unifiedcyberontology_extra_node_10.org/ontology_extra_node_10/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business_extra_node_10 offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology_extra_node_10/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# SKOS Concept Schemes and Concepts (Kos)
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/type/infrastructure_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure_extra_node_10 Application"@en ;
    rdfs:comment "Applications that provide core infrastructure_extra_node_10 services."@en .

<kos/application/type/business_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "Applications directly supporting business_extra_node_10 operations."@en .

<kos/application/type/monitoring_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "Applications used for monitoring_extra_node_10 IT systems."@en .

# Application Business Importance
<kos/application/business_extra_node_10-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business_extra_node_10 importance of applications."@en .

<kos/application/business_extra_node_10-importance/high_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/application/business_extra_node_10-importance> ;
    rdfs:label "High_extra_node_10 Business Importance"@en ;
    rdfs:comment "Application is critical_extra_node_10 for core business_extra_node_10 functions."@en .

<kos/application/business_extra_node_10-importance/medium_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/application/business_extra_node_10-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application supports important but not critical_extra_node_10 business_extra_node_10 functions."@en .

<kos/application/business_extra_node_10-importance/low> a skos:Concept ;
    skos:inScheme <kos/application/business_extra_node_10-importance> ;
    rdfs:label "Low Business Importance"@en ;
    rdfs:comment "Application supports non-critical_extra_node_10 business_extra_node_10 functions."@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction_extra_node_10> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Under Maintenance"@en ;
    rdfs:comment "The application module is temporarily offline for maintenance."@en .

<https://w3id.org/noria/kos/application/status/Development_extra_node_10> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Development_extra_node_10"@en ;
    rdfs:comment "The application module is currently under development."@en .

# Service Type
<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

<kos/service/type/CustomerFacingService_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer_extra_node_10 Facing Service"@en ;
    rdfs:comment "Service directly consumed by external customers."@en .

<kos/service/type/ResourceFacingService_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "Service supporting other services or internal operations."@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical_extra_node_10"@en ;
    rdfs:comment "Service completely down or major business_extra_node_10 impact."@en .

<kos/TroubleTicket/severity/Major_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major_extra_node_10"@en ;
    rdfs:comment "Service degraded or significant business_extra_node_10 impact."@en .

<kos/TroubleTicket/severity/Minor_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor_extra_node_10"@en ;
    rdfs:comment "Minor_extra_node_10 service impact or cosmetic issue."@en .

# Trouble Ticket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of trouble tickets."@en .

<kos/TroubleTicket/type/Failure_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure_extra_node_10"@en ;
    rdfs:comment "Indicates a system or service failure."@en .

<kos/TroubleTicket/type/Assistance_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance_extra_node_10"@en ;
    rdfs:comment "Request for user assistance or information."@en .

# Trouble Ticket Criticity
<kos/TroubleTicket/category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Criticity Scheme"@en ;
    rdfs:comment "A scheme for classifying the criticity of trouble tickets from a customer impact perspective."@en .

<kos/TroubleTicket/category/InterruptedService_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "Service is completely unavailable to the customer."@en .

<kos/TroubleTicket/category/DegradedService> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Degraded Service"@en ;
    rdfs:comment "Service is available but with reduced performance or functionality."@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A scheme for classifying the management priority of trouble tickets."@en .

<kos/TroubleTicket/priority/P1_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate action required."@en .

<kos/TroubleTicket/priority/P2_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High_extra_node_10 priority, urgent action required."@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Supervision_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision_extra_node_10 System"@en ;
    rdfs:comment "Ticket originated from an automated monitoring_extra_node_10 or supervision system."@en .

<kos/TroubleTicket/origin/Customer_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer_extra_node_10 Report"@en ;
    rdfs:comment "Ticket reported by a customer."@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A scheme for classifying the urgency level of trouble tickets."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention_extra_node_10"@en ;
    rdfs:comment "Requires immediate action to prevent further damage or restore service."@en .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying the final area of responsibility for a problem."@en .

<kos/TroubleTicket/problemResponsibility/NetworkOperations> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Network Operations"@en ;
    rdfs:comment "Responsibility lies with the network operations team."@en .

<kos/TroubleTicket/problemResponsibility/ApplicationSupport> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Application Support"@en ;
    rdfs:comment "Responsibility lies with the application support team."@en .

# Trouble Ticket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current activity status of trouble tickets."@en .

<kos/TroubleTicket/status/InProgress_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

<kos/TroubleTicket/status/Resolved_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved_extra_node_10"@en ;
    rdfs:comment "The issue described in the trouble ticket has been resolved."@en .

<kos/TroubleTicket/status/Closed> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Closed"@en ;
    rdfs:comment "The trouble ticket has been closed after resolution and verification."@en .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the provenance and disclosure rules for trouble ticket notes."@en .

<kos/TroubleTicket/commentType/Internal_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal_extra_node_10 Comment"@en ;
    rdfs:comment "Comment intended for internal team use only."@en .

<kos/TroubleTicket/commentType/Customer_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer_extra_node_10 Update"@en ;
    rdfs:comment "Comment intended for customer communication."@en .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the operation type of trouble ticket notes."@en .

<kos/TroubleTicket/operationType/Diagnosis_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis_extra_node_10"@en ;
    rdfs:comment "Note detailing diagnostic steps and findings."@en .

<kos/TroubleTicket/operationType/Resolution_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Resolution_extra_node_10 Step"@en ;
    rdfs:comment "Note detailing a step taken towards resolution."@en .

# Change Request Category
<kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the nature of change requests."@en .

<kos/ChangeRequest/category/InternalIntervention_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal_extra_node_10 Intervention_extra_node_10"@en ;
    rdfs:comment "Change initiated and executed by internal teams."@en .

# Change Request Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the impact and risk level of change requests."@en .

<kos/ChangeRequest/type/Standard_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard_extra_node_10 Change"@en ;
    rdfs:comment "Pre-approved change with low risk and impact."@en .

<kos/ChangeRequest/type/Major_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Major_extra_node_10 Change"@en ;
    rdfs:comment "High_extra_node_10 risk and impact change, requiring extensive approval."@en .

# Change Request Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying the cause or reason for change requests."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change due to software version upgrade."@en .

<kos/ChangeRequest/cause/Configuration_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration_extra_node_10 Change"@en ;
    rdfs:comment "Change due to modification of system configuration."@en .

# Change Request Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of change requests."@en .

<kos/ChangeRequest/status/Approved_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved_extra_node_10"@en ;
    rdfs:comment "Change request has been approved for execution."@en .

<kos/ChangeRequest/status/Implemented_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented_extra_node_10"@en ;
    rdfs:comment "Change has been successfully implemented."@en .

# Resource Type
<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of IT resources."@en .

<kos/Resource/type/Server_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server_extra_node_10"@en ;
    rdfs:comment "A computing server_extra_node_10 resource."@en .

<kos/Resource/type/Router_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router_extra_node_10"@en ;
    rdfs:comment "A network router_extra_node_10 resource."@en .

<kos/Resource/type/Database_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Database_extra_node_10 Server_extra_node_10"@en ;
    rdfs:comment "A server_extra_node_10 hosting a database."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying the lifecycle state of IT resources."@en .

<kos/Resource/LifecycleState/Production> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Production"@en ;
    rdfs:comment "Resource is in active production use."@en .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "Resource has been removed from service."@en .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of IT resources."@en .

<kos/Resource/OperationalState/Up_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up_extra_node_10"@en ;
    rdfs:comment "Resource is operational and running."@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of IT resources."@en .

<kos/Resource/AdministrativeState/Enabled_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Enabled_extra_node_10"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Disabled> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Disabled"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

# Notification Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the perceived severity of notifications/alarms."@en .

<Notification/Severity/PerceivedSeverity/Critical_extra_node_10> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical_extra_node_10"@en ;
    rdfs:comment "Highest severity, immediate attention required."@en .

<Notification/Severity/PerceivedSeverity/Major_extra_node_10> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Major_extra_node_10"@en ;
    rdfs:comment "High_extra_node_10 severity, urgent attention required."@en .

<Notification/Severity/PerceivedSeverity/Minor_extra_node_10> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Minor_extra_node_10"@en ;
    rdfs:comment "Low severity, non-urgent attention."@en .

<Notification/Severity/PerceivedSeverity/Warning_extra_node_10> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning_extra_node_10"@en ;
    rdfs:comment "Indicates a potential issue that may require attention."@en .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email_extra_node_10"@en ;
    rdfs:comment "Preferred contact method is email_extra_node_10."@en .

<kos/org/agent-contact-method/Phone_extra_node_10> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone_extra_node_10"@en ;
    rdfs:comment "Preferred contact method is phone_extra_node_10."@en .

# =============================================================================
# Organizations and Agents
# =============================================================================

# Organizations
org:ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department responsible for all IT services."@en ;
    rdfs:label "Département Informatique"@fr .

org:NetworkServices a org:OrganizationalUnit ;
    rdfs:label "Network Services"@en ;
    rdfs:comment "Organizational unit responsible for network infrastructure_extra_node_10."@en ;
    rdfs:label "Services Réseaux"@fr ;
    org:unitOf org:ITDepartment .

org:ApplicationDevelopment a org:OrganizationalUnit ;
    rdfs:label "Application Development_extra_node_10"@en ;
    rdfs:comment "Organizational unit responsible for developing and maintaining applications."@en ;
    rdfs:label "Développement Applicatif"@fr ;
    org:unitOf org:ITDepartment .

org:SecurityOperationsCenter a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
