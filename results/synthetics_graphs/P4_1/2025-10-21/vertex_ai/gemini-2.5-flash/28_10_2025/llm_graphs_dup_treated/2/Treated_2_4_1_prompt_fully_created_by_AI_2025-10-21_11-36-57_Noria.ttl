<https://w3id.org/noria/event/Log-WebServer01-CPUHigh> a noria:EventRecord ;
    rdfs:label "High_extra_node_7 CPU Usage on WebServer01 Log"@en ;
    rdfs:comment "Log entry indicating sustained high_extra_node_7 CPU usage on WebServer01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/WebServer01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringPlatform> ;
    dcterms:type <kos/Notification/EventType/PerformanceIssue> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_7> .

<https://w3id.org/noria/event/Alarm-DBServer01-DiskFull> a noria:EventRecord ;
    rdfs:label "Critical_extra_node_7 Alarm: DBServer01 Disk Full"@en ;
    rdfs:comment "Alarm triggered due to database server_extra_node_7 disk reaching critical_extra_node_7 capacity."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Disk /dev/sda1 on db01.corp.example.com is 98% full. Database_extra_node_7 operations may be impacted."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/DBServer01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringPlatform> ;
    dcterms:type <kos/Notification/EventType/StorageIssue> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_7> ;
    noria:alarmProposedRepairAction <https://w3id.org/noria/operationplan/DiskCleanupProcedure> .

<https://w3id.org/noria/event/Log-Router01-InterfaceDown> a noria:EventRecord ;
    rdfs:label "Router01 Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on Router01 went down."@en ;
    noria:loggingTime "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/2, changed state to down."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/Router01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringPlatform> ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_7> .

<https://w3id.org/noria/event/Log-Firewall01-BlockedTraffic> a noria:EventRecord ;
    rdfs:label "Firewall_extra_node_7 Blocked Traffic Alert"@en ;
    rdfs:comment "Log entry showing traffic blocked by Firewall01 due to security_extra_node_7 policy."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Blocked connection from 1.2.3.4 to 192.168.10.101 on port 80. Policy: Deny_Untrusted_Sources."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/Firewall01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringPlatform> ;
    dcterms:type <kos/Notification/EventType/SecurityAlert> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

<https://w3id.org/noria/event/Log-UserLoginFailure> a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on a critical_extra_node_7 system."@en ;
    noria:loggingTime "2024-04-20T10:40:00Z"^^xsd:dateTime ;
    noria:logText "User_extra_node_7 'baduser' failed to log in to db01.corp.example.com from 10.0.0.5_extra_node_7. Authentication failure."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/DBServer01> ;
    noria:logOriginatingAgent <https://w3id.org/noria/agent/ExternalAttacker> ; # Example of an external agent
