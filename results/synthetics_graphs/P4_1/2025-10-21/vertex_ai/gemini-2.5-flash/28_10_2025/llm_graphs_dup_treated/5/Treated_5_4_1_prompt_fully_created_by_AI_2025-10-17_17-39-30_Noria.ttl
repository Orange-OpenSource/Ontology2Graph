# --- Resources (noria:Resource) ---
noria:Resource_DNSServer01 a noria:Resource ;
    rdfs:label "Corporate DNS Server_extra_node_8 01"@en ;
    rdfs:comment "Primary DNS server_extra_node_8 for the corporate network, hosted in Main DC."@en ;
    noria:resourceLogisticId "RES-DNS-001" ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server_extra_node_8> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_8> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
