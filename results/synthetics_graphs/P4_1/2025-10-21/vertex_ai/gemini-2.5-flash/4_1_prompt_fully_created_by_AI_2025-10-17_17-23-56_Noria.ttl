# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
<agent/Team_NetworkOperations> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for the daily operation and maintenance of the network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "For critical issues, call the hotline first, then open a ticket."@en .

<agent/Team_ApplicationSupport> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing technical support for business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "All requests must be submitted via the ITSM portal."@en .

