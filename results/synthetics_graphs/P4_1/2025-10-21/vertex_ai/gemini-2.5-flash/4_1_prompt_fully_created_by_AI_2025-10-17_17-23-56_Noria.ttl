# --- Network Interfaces (noria:NetworkInterface) ---
<networkInterface/DB01_Eth0> a noria:NetworkInterface ;
    rdfs:label "db01-eth0"@en ;
    rdfs:comment "Ethernet interface for DB01 server, connected to internal network."@en ;
    noria:networkInterfaceOf <resource/Server_DB01> ;
    noria:networkInterfaceType <kos/network-interface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkInterface/WEB01_Eth0> a noria:NetworkInterface ;
    rdfs:label "web01-eth0"@en ;
    rdfs:comment "Ethernet interface for WEB01 server, connected to internal network."@en ;
    noria:networkInterfaceOf <resource/Server_WEB01> ;
    noria:networkInterfaceType <kos/network-interface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkInterface/Edge01_Gi0_0_0> a noria:NetworkInterface ;
    rdfs:label "edge01-Gi0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface on Edge Router 01, facing the internet."@en ;
    noria:networkInterfaceOf <resource/Router_Edge01> ;
    noria:networkInterfaceType <kos/network-interface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

<networkInterface/Edge01_Gi0_0_1> a noria:NetworkInterface ;
    rdfs:label "edge01-Gi0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface on Edge Router 01, facing the internal core switch."@en ;
    noria:networkInterfaceOf <resource/Router_Edge01> ;
    noria:networkInterfaceType <kos/network-interface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 ;
    noria:networkInterfaceLaserTxOpticalPower -1 ;
    noria:networkInterfaceLaserRxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -2 ;
    #noria:networkInterfaceLaserRxHighPowerWarningThreshold -0.5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -5 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -8 .

<networkInterface/Edge01_Gi0_0_2> a noria:NetworkInterface ;
