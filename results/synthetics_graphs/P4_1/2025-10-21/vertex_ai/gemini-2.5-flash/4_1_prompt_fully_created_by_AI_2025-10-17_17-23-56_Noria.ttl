# --- Operation Plans (noria:OperationPlan) ---
<operationPlan/DB_DiskExpansion_Procedure> a noria:OperationPlan ;
    rdfs:label "Database Disk Expansion Procedure"@en ;
    rdfs:comment "Standard operating procedure for expanding disk space on database servers."@en ;
    skos:example "Steps include: 1. Backup database. 2. Add new disk/expand LVM. 3. Extend filesystem. 4. Verify."@en .

<operationPlan/Router_OS_Upgrade_Procedure> a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems."@en ;
    skos:example "Steps include: 1. Backup configuration. 2. Upload new image. 3. Set boot variable. 4. Reload. 5. Verify."@en .

<operationPlan/Internet_Failover_Procedure> a noria:OperationPlan ;
    rdfs:label "Internet Link Failover Procedure"@en ;
    rdfs:comment "Procedure to activate backup internet link in case of primary link failure."@en ;
    skos:example "Steps include: 1. Verify primary link status. 2. Force routing to backup. 3. Verify internet access. 4. Notify stakeholders."@en .

<operationPlan/DDoS_Mitigation_Procedure> a noria:OperationPlan ;
    rdfs:label "DDoS Mitigation Procedure"@en ;
    rdfs:comment "Standard operating procedure for mitigating DDoS attacks."@en ;
    skos:example "Steps include: 1. Activate scrubbing center. 2. Block malicious IPs. 3. Monitor traffic patterns."@en .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
<actionPreCondition/DiskSpaceLow> a noria:ActionPreCondition ;
    rdfs:label "Disk Space Critically Low"@en ;
    rdfs:comment "Condition: Disk utilization on target server is above 90%."@en ;
    noria:operationPlanPreCondition <operationPlan/DB_DiskExpansion_Procedure> .

<actionPostCondition/DiskSpaceNormal> a noria:ActionPostCondition ;
    rdfs:label "Disk Space Normal"@en ;
    rdfs:comment "Expected outcome: Disk utilization on target server is below 70%."@en ;
    noria:operationPlanPostCondition <operationPlan/DB_DiskExpansion_Procedure> .

<actionPreCondition/PrimaryLinkDown> a noria:ActionPreCondition ;
    rdfs:label "Primary Internet Link Down"@en ;
    rdfs:comment "Condition: Primary internet link (Edge01 Gi0/0/0) is in operational 'down' state."@en ;
    noria:operationPlanPreCondition <operationPlan/Internet_Failover_Procedure> .

<actionPostCondition/InternetAccessRestored> a noria:ActionPostCondition ;
    rdfs:label "Internet Access Restored"@en ;
    rdfs:comment "Expected outcome: Internet connectivity is restored and verified from Paris DC."@en ;
    noria:operationPlanPostCondition <operationPlan/Internet_Failover_Procedure> .

<actionPreCondition/DDoSAttackDetected> a noria:ActionPreCondition ;
    rdfs:label "DDoS Attack Detected"@en ;
    rdfs:comment "Condition: High volume of suspicious traffic targeting public-facing services."@en ;
    noria:operationPlanPreCondition <operationPlan/DDoS_Mitigation_Procedure> .

<actionPostCondition/TrafficNormalised> a noria:ActionPostCondition ;
    rdfs:label "Traffic Normalized"@en ;
    rdfs:comment "Expected outcome: Inbound traffic volume returns to normal levels, and service is accessible."@en ;
    noria:operationPlanPostCondition <operationPlan/DDoS_Mitigation_Procedure> .

# --- Anomaly Patterns (noria:AnomalyPattern) ---
<anomalyPattern/HighCPULowDisk> a noria:AnomalyPattern ;
    rdfs:label "High CPU and Low Disk Space Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating a potential resource exhaustion issue where a server experiences both high CPU usage and critically low disk space, often preceding a crash or service degradation."@en ;
    skos:example "If (CPU > 90% for 5min) AND (Disk_Usage > 95%), then trigger this pattern."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
