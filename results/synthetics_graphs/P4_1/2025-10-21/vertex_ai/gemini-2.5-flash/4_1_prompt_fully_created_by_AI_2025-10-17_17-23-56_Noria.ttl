# --- Event Records (noria:EventRecord) ---
<eventRecord/Log_DB01_DiskFull> a noria:EventRecord ;
    rdfs:label "DB01 Disk Full Alert"@en ;
    rdfs:comment "Log entry indicating that the disk space on DB01 is critically low."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Disk usage on /dev/sda1 on db01.corp.example.com is 95%."@en ;
    noria:logOriginatingManagedObject <resource/Server_DB01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<eventRecord/Log_Edge01_InterfaceDown> a noria:EventRecord ;
    rdfs:label "Edge01 Interface Down Alert"@en ;
    rdfs:comment "Log entry indicating that the internet-facing interface on Edge Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:logOriginatingManagedObject <resource/Router_Edge01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<eventRecord/Log_WEB01_HighCPU> a noria:EventRecord ;
    rdfs:label "WEB01 High CPU Alert"@en ;
    rdfs:comment "Log entry indicating sustained high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject <resource/Server_WEB01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<eventRecord/Log_Firewall_BlockedAttempt> a noria:EventRecord ;
    rdfs:label "Firewall Blocked Attempt"@en ;
    rdfs:comment "Log entry showing a blocked connection attempt by the DMZ firewall."@en ;
    noria:loggingTime "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    noria:logText "FW-DMZ01: Blocked connection from 1.2.3.4 to 10.0.0.12 on port 80."@en ;
    noria:logOriginatingManagedObject <resource/Firewall_DMZ01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

<eventRecord/Log_Firewall_DDoSAttempt> a noria:EventRecord ;
    rdfs:label "DDoS Attack Attempt Detected"@en ;
    rdfs:comment "Log entry from firewall indicating a potential DDoS attack targeting the Customer Portal."@en ;
    noria:loggingTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:logText "High volume of SYN packets detected from multiple sources targeting 10.0.0.5 (Web Load Balancer)."@en ;
    noria:logOriginatingManagedObject <resource/Firewall_DMZ01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<eventRecord/Log_Edge01_FailoverExecuted> a noria:EventRecord ;
    rdfs:label "Edge01 Failover Executed"@en ;
    rdfs:comment "Log entry indicating the execution of the internet failover procedure."@en ;
    noria:loggingTime "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    noria:logText "Executed 'Internet Link Failover Procedure'. Primary link down, backup link activated."@en ;
    noria:logOriginatingManagedObject <resource/Router_Edge01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logOriginatingAgent <agent/Person_AliceSmith> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    pep:usedProcedure <operationPlan/Internet_Failover_Procedure> .

<eventRecord/Log_DDoS_MitigationAction> a noria:EventRecord ;
    rdfs:label "DDoS Mitigation Action"@en ;
    rdfs:comment "Log entry indicating actions taken to mitigate DDoS attack."@en ;
    noria:loggingTime "2024-04-20T12:15:00Z"^^xsd:dateTime ;
    noria:logText "Activated external DDoS scrubbing service. Blocked top 10 attacking IPs."@en ;
    noria:logOriginatingManagedObject <resource/Firewall_DMZ01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logOriginatingAgent <agent/Team_SecurityOperations> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    pep:usedProcedure <operationPlan/DDoS_Mitigation_Procedure> .

<eventRecord/Log_WANLink_Degradation> a noria:EventRecord ;
    rdfs:label "WAN Link Degradation Lyon-Paris"@en ;
