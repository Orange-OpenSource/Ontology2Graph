<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:prefLabel "Email"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:prefLabel "Phone"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

foaf:Agent1 noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .
foaf:Agent2 noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

# Example of noria:troubleTicketSupervisionTool
noria:TroubleTicket1 noria:troubleTicketSupervisionTool "Nagios" .
noria:TroubleTicket2 noria:troubleTicketSupervisionTool "Zabbix" .

# Example of noria:troubleTicketCause
noria:TroubleTicket1 noria:troubleTicketCause "DNS service process crashed due to memory leak."@en .
noria:TroubleTicket2 noria:troubleTicketCause "Fiber cut on WAN link between Paris and Lyon."@en .
noria:TroubleTicket5 noria:troubleTicketCause "Human error during firewall_extra_node_0 policy deployment."@en .

# Example of noria:troubleTicketTargetRestorationDateTime
noria:TroubleTicket1 noria:troubleTicketTargetRestorationDateTime "2024-04-10T10:30:00Z"^^xsd:dateTime .
noria:TroubleTicket2 noria:troubleTicketTargetRestorationDateTime "2024-04-11T15:00:00Z"^^xsd:dateTime .

# Example of noria:troubleTicketPlannedRestorationDateTime
noria:TroubleTicket1 noria:troubleTicketPlannedRestorationDateTime "2024-04-10T09:50:00Z"^^xsd:dateTime .

# Example of noria:troubleTicketCommittedRestorationDateTime
noria:TroubleTicket1 noria:troubleTicketCommittedRestorationDateTime "2024-04-10T11:00:00Z"^^xsd:dateTime .

# Example of noria:troubleTicketIsNotificationEnable
noria:TroubleTicket1 noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean .
noria:TroubleTicket3 noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean .

# Example of noria:documentExternalId
noria:TroubleTicket3 noria:documentExternalId "CUST-ACME-001" .
noria:ChangeRequest2 noria:documentExternalId "PROJ-CPORT-FEAT-005" .

# Example of noria:documentHRef
noria:TroubleTicket1 noria:documentHRef "https://itsm.example.com/ticket/TT12345"^^xsd:anyURI .
noria:ChangeRequest1 noria:documentHRef "https://itsm.example.com/change/CR67890"^^xsd:anyURI .

# Example of noria:changeRequestIsRegulated
noria:ChangeRequest3 noria:changeRequestIsRegulated "true"^^xsd:boolean . # Security changes often regulated

# Example of noria:alarmProposedRepairAction
noria:EventRecord2 noria:alarmProposedRepairAction noria:OperationPlan2 . # Link "Core Router_extra_node_0 Interface Down Alert" to "Core Router_extra_node_0 Interface Reset Procedure"
noria:EventRecord11 noria:alarmProposedRepairAction noria:OperationPlan4 . # Link "Web Server_extra_node_0 Disk Full Alert" to "Web Server_extra_node_0 Log Cleanup Procedure"

# Example of noria:alarmMonitoredAttribute (conceptual, as it's an abstract property)
# This would typically be a blank node or a specific instance of noria:StructuralObservable
# For example, if we had a class for "DiskUsageObservable"
# noria:EventRecord11 noria:alarmMonitoredAttribute [
#     a noria:StructuralObservable ;
#     rdfs:label "Disk Usage on /var/log"@en ;
#     noria:structuralElementObservableData "98%" ;
# ] .

# Example of noria:troubleTicketNoteCorrelatedExecution
# This would link to a pep:ProcedureExecutionContainer, which is a superclass of noria:TroubleTicket and noria:TroubleTicketNote.
# For simplicity, we can link it to an EventRecord that represents an action.
# Let's assume a specific event record represents the execution of a command.
<https://w3id.org/noria/event/restart_dns_command> a noria:EventRecord ;
    rdfs:label "DNS Service Restart Command"@en ;
    noria:loggingTime "2024-04-10T09:30:00Z"^^xsd:dateTime ;
    noria:logText "Command executed: systemctl restart named.service on dns01.corp.example.com"@en ;
    noria:logOriginatingAgent foaf:Agent1 ;
    noria:logOriginatingManagedObject noria:Resource1 .

noria:TroubleTicketNote1_TT1 noria:troubleTicketNoteCorrelatedExecution <https://w3id.org/noria/event/restart_dns_command> .

# Example of noria:troubleTicketFreezeItem
# This would be a list of EventRecords describing freeze periods.
<https://w3id.org/noria/event/tt1_freeze_start> a noria:EventRecord ;
    rdfs:label "Trouble Ticket 1 Freeze Start"@en ;
    noria:loggingTime "2024-04-10T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT12345 frozen due to external dependency."@en ;
    dcterms:references noria:TroubleTicket1 .

<https://w3id.org/noria/event/tt1_freeze_end> a noria:EventRecord ;
    rdfs:label "Trouble Ticket 1 Freeze End"@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT12345 unfrozen, external dependency resolved."@en ;
    dcterms:references noria:TroubleTicket1 .

noria:TroubleTicket1 noria:troubleTicketFreezeItem <https://w3id.org/noria/event/tt1_freeze_start> ;
    noria:troubleTicketFreezeItem <https://w3id.org/noria/event/tt1_freeze_end> .

# Example of noria:troubleTicketPartyIntervention
# This would be a list of events or specific objects describing interventions.
# For simplicity, we can link to EventRecords or TroubleTicketNotes.
noria:TroubleTicket1 noria:troubleTicketPartyIntervention noria:TroubleTicketNote1_TT1 ;
    noria:troubleTicketPartyIntervention noria:TroubleTicketNote2_TT1 .

# Example of noria:troubleTicketCharacteristic
# This would be a specific characteristic object.
# For simplicity, we can use a blank node or a specific class if defined.
noria:TroubleTicket3 noria:troubleTicketCharacteristic [
    a noria:Property ; # Using noria:Property as a generic characteristic
    rdfs:label "Impacted Customer_extra_node_0 Segment"@en ;
    rdfs:comment "The customer segment affected by the slow performance."@en ;
    rdf:value "Enterprise Customers"^^xsd:string
] .

