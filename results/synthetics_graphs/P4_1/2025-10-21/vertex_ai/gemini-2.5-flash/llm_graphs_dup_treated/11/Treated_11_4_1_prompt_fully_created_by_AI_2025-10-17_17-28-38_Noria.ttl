# --- Operation Plans, Pre/Post Conditions ---

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server_extra_node_0 Troubleshooting Guide"@en ;
    rdfs:comment "Standard_extra_node_0 operating procedure for diagnosing and resolving DNS server_extra_node_0 issues."@en ;
    rdfs:label "Guide de Dépannage Serveur DNS"@fr ;
    noria:operationPlanPreCondition noria:ActionPreCondition1_OP1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1_OP1 .

noria:ActionPreCondition1_OP1 a noria:ActionPreCondition ;
    rdfs:label "DNS Resolution Failure_extra_node_0 Observed"@en ;
    rdfs:comment "Condition: DNS queries to the corporate DNS server_extra_node_0 are failing or timing out."@en .

noria:ActionPostCondition1_OP1 a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored"@en ;
    rdfs:comment "Expected outcome: DNS queries to the corporate DNS server_extra_node_0 are successfully resolved."@en .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Core Router_extra_node_0 Interface Reset Procedure"@en ;
    rdfs:comment "Procedure for administratively bouncing a network interface on a core router_extra_node_0."@en ;
    rdfs:label "Procédure de Réinitialisation Interface Routeur Cœur"@fr ;
    noria:operationPlanPreCondition noria:ActionPreCondition1_OP2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1_OP2 .

noria:ActionPreCondition1_OP2 a noria:ActionPreCondition ;
    rdfs:label "Interface Status is 'Down'"@en ;
    rdfs:comment "Condition: A specific network interface on a core router_extra_node_0 is showing an operational status of 'down'."@en .

noria:ActionPostCondition1_OP2 a noria:ActionPostCondition ;
    rdfs:label "Interface Status is 'Up'"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is restored to 'up_extra_node_0'."@en .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Firewall_extra_node_0 Policy Review Process"@en ;
    rdfs:comment "Procedure for reviewing and validating firewall_extra_node_0 policy changes before deployment."@en ;
    rdfs:label "Process de Révision Politique Pare-feu"@fr ;
    noria:operationPlanPreCondition noria:ActionPreCondition1_OP3 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1_OP3 .

noria:ActionPreCondition1_OP3 a noria:ActionPreCondition ;
    rdfs:label "Security Incident Detected Post-Change"@en ;
    rdfs:comment "Condition: A security_extra_node_0 incident or unexpected traffic blockage is detected shortly after a firewall_extra_node_0 policy change."@en .

noria:ActionPostCondition1_OP3 a noria:ActionPostCondition ;
    rdfs:label "Policy Compliant, No Further Incidents"@en ;
    rdfs:comment "Expected outcome: Firewall_extra_node_0 policy is verified to be compliant and no further related security_extra_node_0 incidents occur."@en .

noria:OperationPlan4 a noria:OperationPlan ;
    rdfs:label "Web Server_extra_node_0 Log Cleanup Procedure"@en ;
    rdfs:comment "Routine procedure for clearing old log files on web servers to free up_extra_node_0 disk space."@en ;
    rdfs:label "Procédure de Nettoyage des Logs Serveur Web"@fr ;
    noria:operationPlanPreCondition noria:ActionPreCondition1_OP4 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1_OP4 .

noria:ActionPreCondition1_OP4 a noria:ActionPreCondition ;
    rdfs:label "Web Server_extra_node_0 Disk Usage High_extra_node_0"@en ;
    rdfs:comment "Condition: Disk usage on web server_extra_node_0 /var/log partition exceeds 90%."@en .

noria:ActionPostCondition1_OP4 a noria:ActionPostCondition ;
    rdfs:label "Web Server_extra_node_0 Disk Usage Below Threshold"@en ;
    rdfs:comment "Expected outcome: Disk usage on web server_extra_node_0 /var/log partition is reduced below 80%."@en .

