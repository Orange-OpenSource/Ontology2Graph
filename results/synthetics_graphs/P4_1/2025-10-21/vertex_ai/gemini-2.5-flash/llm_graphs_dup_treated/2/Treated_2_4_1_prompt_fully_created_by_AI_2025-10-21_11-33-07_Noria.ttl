# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:comment "Team responsible for 24/7 monitoring_extra_node_6 and initial response to network incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_6> ;
    noria:agentInstructions "Contact via dedicated hotline for critical_extra_node_6 issues. Use ticketing system for non-urgent matters."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Server_extra_node_6 Administration Team"@en ;
    rdfs:comment "Team managing physical_extra_node_6 and virtual_extra_node_6 server_extra_node_6 infrastructure_extra_node_6."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_6> ;
    noria:agentInstructions "Email_extra_node_6 for routine requests. Pager for critical_extra_node_6 server_extra_node_6 alerts."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Team providing support for critical_extra_node_6 business_extra_node_6 application 'CRM-Suite'."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat_extra_node_6 for immediate application issues. Open a ticket for feature requests."@en .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Database_extra_node_6 Administration Team"@en ;
