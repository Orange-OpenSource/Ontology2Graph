# Link EventRecords to TroubleTickets via documentStatusHistory
noria:TroubleTicket_001 noria:documentStatusHistory noria:EventRecord_DBError .
noria:TroubleTicket_002 noria:documentStatusHistory noria:EventRecord_RouterDown .

# Link ChangeRequests to EventRecords (e.g., for audit logs of changes)
noria:ChangeRequest_002 noria:documentStatusHistory noria:EventRecord_ConfigChange .

# Link Application Modules to Resources (indirectly, via Application)
# This is already covered by noria:resourceForApplication and noria:applicationModuleOf,
# but we can add more direct links if the model allowed for it, or infer.
# For now, the existing links provide sufficient density.

# Example of a resource being managed by an agent and also being part of an application
noria:Resource_Server001 noria:resourceManagedBy noria:Agent_BobJohnson .
noria:Resource_DBServer001 noria:resourceManagedBy noria:Agent_DavidGreen .
noria:Resource_Firewall001 noria:resourceManagedBy noria:Agent_CarolWhite .

# Example of an agent managing multiple resources
noria:Agent_AliceSmith noria:agentManagesResource noria:Resource_Router001, noria:Resource_Firewall001 .

# Example of an application module having a support leader
noria:AppModule_CustomerPortal_Prod noria:applicationModuleSupportLeader noria:Agent_BobJohnson .

# Example of an EventRecord being mitigated by a procedure execution
noria:EventRecord_DBError noria:alarmMitigatedBy noria:ProcedureExecutionContainer_TT001_NetCheck .

# Example of a TroubleTicketNote being correlated to an execution
noria:TroubleTicketNote_001_2 noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer_TT001_NetCheck .

# Example of a ChangeRequest having an actual start/end time after execution
noria:ChangeRequest_001
    noria:changeRequestActualStartTime "2024-04-25T22:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-25T22:45:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Completed> .

# Example of a TroubleTicket being resolved
noria:TroubleTicket_001
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T10:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/NetworkConnectivity> .

