# Adding an AnomalyPattern
noria:AnomalyPattern_HighCPUDatabase a noria:AnomalyPattern ;
    rdfs:label "High_extra_node_5 CPU on Database_extra_node_5 Server_extra_node_5 Pattern"@en ;
    rdfs:comment "Pattern indicating a potential database performance issue due to sustained high_extra_node_5 CPU usage."@en ;
    skos:example "Triggered when CPU usage on DB server_extra_node_5 exceeds 80% for more than 15 minutes, correlated with slow query logs."@en .

