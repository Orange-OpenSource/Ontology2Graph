# =============================================================================
# Operation Plans, Pre/Post Conditions (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:OperationPlan_TroubleshootNetwork a noria:OperationPlan ;
    rdfs:label "Network Troubleshooting Procedure"@en ;
    rdfs:comment "Standard_extra_node_5 operating procedure for diagnosing network connectivity issues."@en ;
    skos:example "Steps include ping, traceroute, interface status check, cable inspection."@en ;
    noria:operationPlanPreCondition noria:PreCond_NetworkIssueReported ;
    noria:operationPlanPostCondition noria:PostCond_NetworkIssueIdentified .

noria:OperationPlan_RestartDBService a noria:OperationPlan ;
    rdfs:label "Restart Database_extra_node_5 Service Procedure"@en ;
    rdfs:comment "Procedure to safely restart the database service on a server_extra_node_5."@en ;
    skos:example "Includes checking service status, stopping, starting, and verifying."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBServiceDown ;
    noria:operationPlanPostCondition noria:PostCond_DBServiceRunning .

noria:OperationPlan_ApplyFirewallRules a noria:OperationPlan ;
    rdfs:label "Apply Firewall Rules Procedure"@en ;
    rdfs:comment "Procedure for applying new firewall rules to a Palo Alto firewall."@en ;
    skos:example "Steps include rule creation, commit, and verification."@en ;
    noria:operationPlanPreCondition noria:PreCond_NewFirewallRulesReady ;
    noria:operationPlanPostCondition noria:PostCond_FirewallRulesApplied .

noria:PreCond_NetworkIssueReported a noria:ActionPreCondition ;
    rdfs:label "Network Issue Reported"@en ;
    rdfs:comment "A user or monitoring_extra_node_5 system has reported a network connectivity problem."@en .

noria:PreCond_DBServiceDown a noria:ActionPreCondition ;
    rdfs:label "Database_extra_node_5 Service Down"@en ;
    rdfs:comment "The database service is not running or is unresponsive."@en .

noria:PreCond_NewFirewallRulesReady a noria:ActionPreCondition ;
    rdfs:label "New Firewall Rules Ready"@en ;
    rdfs:comment "New firewall rules have been drafted and approved for implementation."@en .

noria:PostCond_NetworkIssueIdentified a noria:ActionPostCondition ;
    rdfs:label "Network Issue Identified"@en ;
    rdfs:comment "The root cause of the network problem has been determined."@en .

noria:PostCond_DBServiceRunning a noria:ActionPostCondition ;
    rdfs:label "Database_extra_node_5 Service Running"@en ;
    rdfs:comment "The database service has been successfully restarted and is operational."@en .

noria:PostCond_FirewallRulesApplied a noria:ActionPostCondition ;
    rdfs:label "Firewall Rules Applied"@en ;
    rdfs:comment "New firewall rules have been successfully applied and verified."@en .

# =============================================================================
# Procedure Execution Containers (pep:ProcedureExecutionContainer)
# =============================================================================

noria:ProcedureExecutionContainer_TT001_NetCheck a pep:ProcedureExecutionContainer ;
    rdfs:label "Network Check for TT-001"@en ;
    rdfs:comment "Container for actions taken during network troubleshooting for Trouble Ticket 001."@en ;
    pep:usedProcedure noria:OperationPlan_TroubleshootNetwork ;
    pep:hasInput noria:PreCond_NetworkIssueReported ;
    pep:hasOutput noria:PostCond_NetworkIssueIdentified .

noria:ProcedureExecutionContainer_CR001_FWUpdate a pep:ProcedureExecutionContainer ;
    rdfs:label "Firewall Update for CR-001"@en ;
    rdfs:comment "Container for actions taken to update firewall rules for Change Request 001."@en ;
    pep:usedProcedure noria:OperationPlan_ApplyFirewallRules ;
    pep:hasInput noria:PreCond_NewFirewallRulesReady ;
    pep:hasOutput noria:PostCond_FirewallRulesApplied .

