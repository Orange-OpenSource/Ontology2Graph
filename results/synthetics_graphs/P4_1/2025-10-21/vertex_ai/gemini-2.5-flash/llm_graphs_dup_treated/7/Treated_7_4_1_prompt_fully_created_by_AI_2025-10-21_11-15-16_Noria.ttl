# Adding a new OperationPlan for incident response
noria:OperationPlan_IncidentResponse_Malware a noria:OperationPlan ;
    rdfs:label "Malware Incident Response Procedure"@en ;
    rdfs:comment "Procedure for handling malware detection incidents, including isolation, analysis, and remediation."@en ;
    skos:example "Steps include network isolation, forensic image, malware removal, and vulnerability patching."@en ;
    noria:operationPlanPreCondition noria:PreCond_MalwareDetected ;
    noria:operationPlanPostCondition noria:PostCond_SystemCleanAndSecure .

noria:PreCond_MalwareDetected a noria:ActionPreCondition ;
    rdfs:label "Malware Detected"@en ;
    rdfs:comment "Antivirus or EDR system has reported malware presence on a system."@en .

noria:PostCond_SystemCleanAndSecure a noria:ActionPostCondition ;
    rdfs:label "System Clean and Secure"@en ;
    rdfs:comment "The infected system has been cleaned, vulnerabilities patched, and is deemed secure for re-integration."@en .

noria:ProcedureExecutionContainer_TT006_IR a pep:ProcedureExecutionContainer ;
    rdfs:label "Incident Response for TT-006"@en ;
    rdfs:comment "Container for incident response actions taken for Trouble Ticket 006."@en ;
    pep:usedProcedure noria:OperationPlan_IncidentResponse_Malware ;
    pep:hasInput noria:PreCond_MalwareDetected ;
    pep:hasOutput noria:PostCond_SystemCleanAndSecure .

noria:TroubleTicketNote_006_1 noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer_TT006_IR .

