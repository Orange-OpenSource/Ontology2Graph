    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_5> .

noria:EventRecord_DBError a noria:EventRecord ;
    rdfs:label "Database_extra_node_5 Connection Error Event"@en ;
    rdfs:comment "Log entry from Web Server_extra_node_5 001 reporting database connection issues."@en ;
