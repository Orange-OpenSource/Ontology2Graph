noria:EventRecord_RouterDown a noria:EventRecord ;
    rdfs:label "Router_extra_node_5 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router_extra_node_5 001 went down."@en ;
