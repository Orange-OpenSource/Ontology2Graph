# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, noria:CorporateUserIdentifier)
# =============================================================================

# Organizational Units (Teams)
noria:OrgUnit_NetOpsTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing and maintaining network infrastructure_extra_node_5."@en ;
    skos:example "Handles routing, switching, and firewall configurations."@en ;
    noria:agentWorkingHours "24/7 (on-call rotation)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "For critical_extra_node_5 issues, call the on-call number after sending an email."@en .

noria:OrgUnit_AppDevTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development_extra_node_5 Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business_extra_node_5 applications."@en ;
    skos:example "Develops and deploys microservices for customer-facing applications."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Open a ticket in Jira for any application-related issues."@en .

noria:OrgUnit_SecurityTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team dedicated to monitoring_extra_node_5, detecting, and responding to cybersecurity threats."@en ;
    skos:example "Monitors SIEM alerts and performs incident response."@en ;
    noria:agentWorkingHours "24/7 (shift-based)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_5> ;
    noria:agentInstructions "Immediate phone_extra_node_5 call for critical_extra_node_5 security_extra_node_5 incidents."@en .

noria:OrgUnit_DBATeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database_extra_node_5 Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticket> .

noria:OrgUnit_CloudOpsTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Manages cloud infrastructure_extra_node_5 and services."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

# Individual Agents (Employees)
noria:Agent_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer in the Network Operations Team."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone_extra_node_5 "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_5> ;
    noria:agentInstructions "Contact via corporate chat for non-urgent matters."@en ;
    noria:agentManagesResource noria:Resource_Router001, noria:Resource_Firewall001 .

noria:Agent_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Developer in the Application Development_extra_node_5 Team."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentManagesResource noria:Application_CustomerPortal .

noria:Agent_CarolWhite a foaf:Person, foaf:Agent ;
    rdfs:label "Carol White"@en ;
    rdfs:comment "Security Analyst in the Cybersecurity Operations Center."@en ;
    foaf:mbox <mailto:carol.white@example.com> ;
    noria:agentWorkingHours "24/7 (on-call)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_5> .

noria:Agent_DavidGreen a foaf:Person, foaf:Agent ;
    rdfs:label "David Green"@en ;
    rdfs:comment "Database_extra_node_5 Administrator."@en ;
    foaf:mbox <mailto:david.green@example.com> ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticket> .

# Corporate User Identifiers (CUid)
noria:CUid_AliceSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    foaf:accountServiceHomepage <https://intranet.example.com/profile/asmith> .

noria:CUid_BobJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string .

