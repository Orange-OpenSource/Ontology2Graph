# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_Cisco3850 a noria:ProductModel ;
    rdfs:label "Cisco_extra_node_5 Catalyst 3850 Series Switch"@en ;
    rdfs:comment "Enterprise-class stackable access layer switch_extra_node_5."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell_extra_node_5 PowerEdge R740 Server_extra_node_5"@en ;
    rdfs:comment "High_extra_node_5-performance rack server_extra_node_5 for data centers."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_PaloAlto500 a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-500 Firewall"@en ;
    rdfs:comment "Next-generation firewall for network security_extra_node_5."@en ;
    noria:productManufacturedBy noria:Org_PaloAlto .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware_extra_node_5 ESXi Hypervisor_extra_node_5"@en ;
    rdfs:comment "Type-1 hypervisor for virtualizing servers."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:ProductModel_NetAppFAS8040 a noria:ProductModel ;
    rdfs:label "NetApp FAS8040 Storage System"@en ;
    rdfs:comment "Unified storage system for enterprise data management."@en ;
    noria:productManufacturedBy noria:Org_NetApp .

# Manufacturers (org:Organization)
noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco_extra_node_5 Systems, Inc."@en ;
    rdfs:comment "Leading manufacturer of networking hardware."@en .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell_extra_node_5 Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:Org_PaloAlto a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "Global cybersecurity leader."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware_extra_node_5, Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

noria:Org_NetApp a org:Organization ;
    rdfs:label "NetApp, Inc."@en ;
    rdfs:comment "Hybrid cloud data services and data management company."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria:Site_DC_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    wgs84_pos:lat "48.867"^^xsd:float ;
    wgs84_pos:long "2.333"^^xsd:float .

noria:Site_Office_London a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:comment "Main office building in London."@en ;
    noria:siteId "OFF-LDN-01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Baker Street"@en ;
    noria:sitePrincipalAddressCityName "London"@en ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE"^^xsd:string ;
    noria:sitePrincipalAddressCountry "UK"^^xsd:string ;
    wgs84_pos:lat "51.523"^^xsd:float ;
    wgs84_pos:long "-0.158"^^xsd:float .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server_extra_node_5 Room A"@en ;
    rdfs:comment "Main server_extra_node_5 room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    seas:subSystemOf noria:Site_DC_Paris .

noria:Room_NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:comment "Network equipment closet in the London Office."@en ;
    bot:hasSpace noria:Locus_RackB1 ;
    seas:subSystemOf noria:Site_Office_London .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1 in Server_extra_node_5 Room A"@en ;
    rdfs:comment "Location for critical_extra_node_5 servers and network devices."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2 in Server_extra_node_5 Room A"@en ;
    rdfs:comment "Location for database servers."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_RackB1 a noria:Locus ;
    rdfs:label "Rack B1 in Network Closet B"@en ;
    rdfs:comment "Location for office network switches and routers."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    seas:subSystemOf noria:Room_NetworkClosetB .

