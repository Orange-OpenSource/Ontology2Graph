    noria:locusRow "01" ;
    bot:hasSpace <room/ServerRoom_A1> .

<locus/Rack_A1_R02> a noria:Locus ;
    rdfs:label "Rack A1-R02"@en ;
    rdfs:comment "Second rack in Server Room A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "02" ;
    bot:hasSpace <room/ServerRoom_A1> .

<site/Office_London> a bot:Site ;
