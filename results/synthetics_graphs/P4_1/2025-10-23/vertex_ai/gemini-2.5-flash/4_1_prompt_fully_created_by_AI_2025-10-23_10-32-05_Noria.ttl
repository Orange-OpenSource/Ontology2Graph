# --- Resources (noria:Resource) ---
# Physical and virtual IT assets.

<resource/Server_Web01> a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server hosting customer-facing applications."@en ;
    noria:resourceManagedBy <agent/Team_ApplicationSupport> ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel <productModel/Dell_PowerEdge_R750> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB01-2023" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/Rack_A1_R01> ;
    noria:resourceManagementIPAddress <observable/IPAddress_10.0.0.10> .

<resource/Server_DB01> a noria:Resource ;
