    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CP" ;
    noria:applicationType <kos/application/type/CustomerFacing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Customer Self-Service" ;
    noria:resourceForApplication <resource/Server_Web01> ;
    noria:resourceForApplication <resource/Server_DB01> ;
    noria:resourceForApplication <resource/VM_AppServer01> .

<application/InternalCRM> a noria:Application ;
