# --- Network Links (noria:NetworkLink) ---
# Connections between network interfaces or resources.

<networkLink/Core01_to_ISP> a noria:NetworkLink ;
    rdfs:label "Core01 to ISP Uplink"@en ;
    rdfs:comment "High-speed fiber link connecting Core Router 01 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-CORE01-ISP-01" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2022-05-20T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource <resource/Router_Core01> ;
    noria:networkLinkTerminationResource <resource/ISP_Router_External> . # Assuming an external ISP router resource

<networkLink/Core01_to_FW01> a noria:NetworkLink ;
    rdfs:label "Core01 to FW01 Link"@en ;
    rdfs:comment "Internal link between Core Router 01 and Edge Firewall 01."@en ;
    noria:networkLinkId "NL-CORE01-FW01-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-03-10T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/Router_Core01> ;
    noria:networkLinkTerminationResourceDestination <resource/Firewall_Edge01> .

<networkLink/FW01_to_Web01> a noria:NetworkLink ;
    rdfs:label "FW01 to Web01 Link"@en ;
    rdfs:comment "Link from Edge Firewall 01 to Web Server 01."@en ;
    noria:networkLinkId "NL-FW01-WEB01-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-03-10T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/Firewall_Edge01> ;
    noria:networkLinkTerminationResourceDestination <resource/Server_Web01> .

<networkLink/Web01_to_DB01> a noria:NetworkLink ;
    rdfs:label "Web01 to DB01 Link"@en ;
    rdfs:comment "Internal link between Web Server 01 and Database Server 01."@en ;
    noria:networkLinkId "NL-WEB01-DB01-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-15T12:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/Server_Web01> ;
    noria:networkLinkTerminationResourceDestination <resource/Server_DB01> .

<networkLink/Web01_to_VMApp01> a noria:NetworkLink ;
    rdfs:label "Web01 Host to VMApp01 Link"@en ;
    rdfs:comment "Virtual link between Web Server 01 (host) and Virtual Application Server 01 (guest)."@en ;
    noria:networkLinkId "NL-WEB01-VMAPP01-01" ;
    noria:networkLinkType "Virtual Network" ;
    noria:networkLinkInstallationDate "2023-06-01T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/Server_Web01> ;
    noria:networkLinkTerminationResourceDestination <resource/VM_AppServer01> .

<networkLink/London_to_Paris_WAN> a noria:NetworkLink ;
    rdfs:label "London-Paris WAN Link"@en ;
    rdfs:comment "Wide Area Network link connecting London Office to Paris Data Center."@en ;
    noria:networkLinkId "NL-LON-PAR-WAN-01" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2023-04-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/Router_London01> ;
    noria:networkLinkTerminationResourceDestination <resource/Router_Core01> ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> .

# --- Applications (noria:Application) ---
# Software systems providing business functions.

<application/CustomerPortal> a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:comment "Web application allowing customers to manage their accounts and services."@en ;
