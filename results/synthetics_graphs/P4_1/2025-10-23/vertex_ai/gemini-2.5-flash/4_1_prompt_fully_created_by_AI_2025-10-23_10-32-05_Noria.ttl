    noria:applicationModuleSupportTeam <agent/Team_ApplicationSupport> ;
    noria:applicationModuleSupportLeader <agent/Person_BobJohnson> ;
    noria:applicationModuleHotlineGroup <agent/Team_ApplicationSupport> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
