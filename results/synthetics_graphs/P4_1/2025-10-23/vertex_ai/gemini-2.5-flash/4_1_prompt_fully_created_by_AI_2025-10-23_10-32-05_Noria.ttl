    noria:resourceManagementIPAddress <observable/IPAddress_10.0.0.11> .

<resource/Router_Core01> a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> ;
    noria:resourceHostName "core01.corp.example.com" ;
    noria:resourceProductModel <productModel/Cisco_Catalyst_9300> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CORE01-2022" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/Rack_A1_R02> ;
    noria:resourceManagementIPAddress <observable/IPAddress_10.0.0.1> .

<resource/Firewall_Edge01> a noria:Resource ;
    rdfs:label "Edge Firewall 01"@en ;
    rdfs:comment "Perimeter firewall protecting the corporate network from external threats."@en ;
    noria:resourceManagedBy <agent/Team_SecurityOperations> ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel <productModel/PaloAlto_PA-5220> ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW01-2023" ;
