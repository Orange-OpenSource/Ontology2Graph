    noria:resourceInstallationDate "2023-03-10T14:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/Rack_A1_R02> ;
    noria:resourceManagementIPAddress <observable/IPAddress_10.0.0.2> .

<resource/VM_AppServer01> a noria:Resource ;
    rdfs:label "Virtual Application Server 01"@en ;
    rdfs:comment "Virtual machine hosting a component of the main business application."@en ;
    noria:resourceManagedBy <agent/Team_ApplicationSupport> ;
    noria:resourceHostName "vapp01.corp.example.com" ;
