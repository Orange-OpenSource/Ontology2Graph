# --- Operation Plans (noria:OperationPlan) ---
# Standardized procedures for IT operations.

<operationPlan/OP-NetworkOSUpgrade> a noria:OperationPlan ;
    rdfs:label "Standard Network OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading network device operating systems, including pre-checks, upgrade steps, and post-checks."@en ;
    skos:example "1. Verify device health. 2. Backup configuration. 3. Upload new OS image. 4. Reboot with new image. 5. Verify new OS and connectivity."@en ;
    noria:operationPlanPreCondition <actionPreCondition/NetworkDeviceHealthy> ;
    noria:operationPlanPostCondition <actionPostCondition/NetworkDeviceOperational> .

<operationPlan/OP-DBPatching> a noria:OperationPlan ;
    rdfs:label "Database Patching Procedure"@en ;
    rdfs:comment "Procedure for applying security patches and updates to database servers."@en ;
    skos:example "1. Backup database. 2. Stop database service. 3. Apply patch. 4. Start database service. 5. Verify database integrity."@en ;
    noria:operationPlanPreCondition <actionPreCondition/DatabaseBackupComplete> ;
    noria:operationPlanPostCondition <actionPostCondition/DatabaseOperational> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
# Conditions for executing and verifying operation plans.

<actionPreCondition/NetworkDeviceHealthy> a noria:ActionPreCondition ;
    rdfs:label "Network Device Healthy"@en ;
    rdfs:comment "All interfaces are up, CPU/memory utilization is normal, no critical alarms."@en ;
    skos:example "Check 'show interface status', 'show processes cpu', 'show logging' commands."@en .

<actionPostCondition/NetworkDeviceOperational> a noria:ActionPostCondition ;
    rdfs:label "Network Device Operational"@en ;
    rdfs:comment "Device is reachable, all expected interfaces are up, routing protocols converged, traffic flowing as expected."@en ;
    skos:example "Ping test to adjacent devices, verify routing table, check interface counters."@en .

<actionPreCondition/DatabaseBackupComplete> a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete"@en ;
    rdfs:comment "A full, verified backup of the database has been successfully completed."@en .

<actionPostCondition/DatabaseOperational> a noria:ActionPostCondition ;
    rdfs:label "Database Operational"@en ;
    rdfs:comment "Database service is running, connections are accepted, and data integrity checks pass."@en .

