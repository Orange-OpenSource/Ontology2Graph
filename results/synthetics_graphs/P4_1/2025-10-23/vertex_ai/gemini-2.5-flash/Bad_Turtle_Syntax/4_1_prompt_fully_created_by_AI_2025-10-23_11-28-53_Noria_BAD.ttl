# --- Operation Plans (noria:OperationPlan) ---
:OpPlan_RestartWebServer a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a web server instance."@en ;
    skos:example "Steps: 1. Check server status. 2. Attempt graceful restart. 3. Force restart if necessary. 4. Verify service availability."@en ;
    noria:operationPlanPreCondition :PreCond_WebServerHighCPU ;
    noria:operationPlanPostCondition :PostCond_WebServerRunningNormal .

:OpPlan_CheckFiberLink a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Procedure to diagnose and troubleshoot a downed fiber optic link."@en ;
    skos:example "Steps: 1. Verify physical connection. 2. Check optical power levels. 3. Contact ISP if external issue. 4. Replace SFP/cable if internal issue."@en ;
    noria:operationPlanPreCondition :PreCond_NetworkLinkDown ;
    noria:operationPlanPostCondition :PostCond_NetworkLinkUp .

:OpPlan_CleanDBLogs a noria:OperationPlan ;
    rdfs:label "Clean Database Logs Procedure"@en ;
    rdfs:comment "Procedure to free up disk space by cleaning old database logs."@en ;
    skos:example "Steps: 1. Identify large log files. 2. Backup logs. 3. Delete/archive old logs. 4. Verify disk space."@en ;
    noria:operationPlanPreCondition :PreCond_DBSrvDiskFull ;
    noria:operationPlanPostCondition :PostCond_DBSrvDiskSpaceOK .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
:PreCond_WebServerHighCPU a noria:ActionPreCondition ;
    rdfs:label "Web Server High CPU Condition"@en ;
    rdfs:comment "Condition where web server CPU utilization is consistently above a defined threshold."@en ;
    skos:example "CPU > 90% for 5 minutes."@en .

:PostCond_WebServerRunningNormal a noria:ActionPostCondition ;
    rdfs:label "Web Server Running Normally"@en ;
    rdfs:comment "Expected outcome: web server CPU utilization returns to normal levels and service is responsive."@en ;
    skos:example "CPU < 50% and HTTP 200 response time < 200ms."@en .

:PreCond_NetworkLinkDown a noria:ActionPreCondition ;
    rdfs:label "Network Link Down Condition"@en ;
    rdfs:comment "Condition where a critical network interface reports an operational 'down' status."@en ;
    skos:example "Interface Gi0/0/0 on CoreRouter01 is down."@en .

:PostCond_NetworkLinkUp a noria:ActionPostCondition ;
    rdfs:label "Network Link Up and Operational"@en ;
    rdfs:comment "Expected outcome: network interface operational status is 'up' and traffic flows normally."@en ;
    skos:example "Interface Gi0/0/0 on CoreRouter01 is up and ping to ISP gateway is successful."@en .

:PreCond_DBSrvDiskFull a noria:ActionPreCondition ;
    rdfs:label "Database Server Disk Full Condition"@en ;
    rdfs:comment "Condition where a database server's disk partition reaches critical capacity."@en ;
    skos:example "Disk usage on /var/lib/mysql > 95%."@en .

:PostCond_DBSrvDiskSpaceOK a noria:ActionPostCondition ;
    rdfs:label "Database Server Disk Space OK"@en ;
    rdfs:comment "Expected outcome: disk space on the database server is below warning thresholds."@en ;
    skos:example "Disk usage on /var/lib/mysql < 80%."@en .

