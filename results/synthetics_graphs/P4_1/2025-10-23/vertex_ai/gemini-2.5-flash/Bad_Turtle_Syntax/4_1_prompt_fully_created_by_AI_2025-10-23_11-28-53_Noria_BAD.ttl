# --- Applications (noria:Application) ---
:App_CorporateWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "Public-facing website for the company."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CW" ;
    noria:applicationType <kos/application/type/CustomerFacingService> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Marketing and Sales" ;
    noria:applicationFunctionalSubDomain "Online Presence Management" .

:App_CRMSystem a noria:Application ;
    rdfs:label "Customer Relationship Management (CRM) System"@en ;
    rdfs:comment "Internal system for managing customer interactions."@en ;
    noria:applicationModelIdentifier "CRM" ;
    noria:applicationNumericalIdentifier 1002 ;
