# --- Event Records (noria:EventRecord) ---
:Event_WebSrv01_CPU_High a noria:EventRecord ;
    rdfs:label "WebSrv01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on websrv01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject :Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmProposedRepairAction :OpPlan_RestartWebServer .

:Event_CoreRouter01_LinkDown a noria:EventRecord ;
    rdfs:label "CoreRouter01 Link Down Alert"@en ;
    rdfs:comment "Critical alert: GigabitEthernet0/0/0 on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down on corerouter01."@en ;
    noria:logOriginatingManagedObject :Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction :OpPlan_CheckFiberLink .

:Event_Firewall01_LoginFail a noria:EventRecord ;
    rdfs:label "Firewall01 Failed Login Attempts"@en ;
    rdfs:comment "Security event: multiple failed login attempts on Firewall 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Multiple failed login attempts detected from IP 1.2.3.4 on fw01.corp.example.com."@en ;
    noria:logOriginatingManagedObject :Resource_Firewall01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent :Agent_Security_Team . # SOC team is monitoring this

:Event_DBSrv01_DiskFull a noria:EventRecord ;
    rdfs:label "DBSrv01 Disk Full Alert"@en ;
    rdfs:comment "Alert indicating low disk space on Database Server 01."@en ;
    noria:loggingTime "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:logText "Disk usage on /var/lib/mysql on dbsrv01.corp.example.com is at 95%."@en ;
    noria:logOriginatingManagedObject :Resource_DBSrv01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction :OpPlan_CleanDBLogs .

:Event_VM_App01_Restart a noria:EventRecord ;
    rdfs:label "VM_App01 Restart Log"@en ;
    rdfs:comment "Log entry for a planned restart of VM_App01."@en ;
    noria:loggingTime "2024-04-19T23:00:00Z"^^xsd:dateTime ;
    noria:logText "Virtual machine vm-app01.corp.example.com restarted by John Doe as part of maintenance."@en ;
    noria:logOriginatingManagedObject :Resource_VM_App01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logOriginatingAgent :Agent_John_Doe .

