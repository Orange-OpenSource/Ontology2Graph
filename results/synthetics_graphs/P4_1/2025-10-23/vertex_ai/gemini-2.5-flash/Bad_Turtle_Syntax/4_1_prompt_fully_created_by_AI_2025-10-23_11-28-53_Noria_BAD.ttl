# --- Network Interfaces (noria:NetworkInterface) ---
:NI_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf :Resource_WebSrv01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Uplink to corporate LAN switch."@en ;
    noria:networkInterfaceConnects :NL_WebSrv01_Switch .

:NI_DBSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf :Resource_DBSrv01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Uplink to corporate SAN switch."@en ;
    noria:networkInterfaceConnects :NL_DBSrv01_Switch .

:NI_CoreRouter01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to ISP."@en ;
    noria:networkInterfaceOf :Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceConnects :NL_CoreRouter01_ISP .

:NI_CoreRouter01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface from Core Router 01 to internal LAN."@en ;
    noria:networkInterfaceOf :Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceConnects :NL_CoreRouter01_LAN .

:NI_Firewall01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet 0 (WAN)"@en ;
    rdfs:comment "External interface of Firewall 01."@en ;
    noria:networkInterfaceOf :Resource_Firewall01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NL_Firewall01_CoreRouter .

:NI_Firewall01_Eth1 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet 1 (LAN)"@en ;
    rdfs:comment "Internal interface of Firewall 01."@en ;
    noria:networkInterfaceOf :Resource_Firewall01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects :NL_Firewall01_CoreRouter .

# --- Network Links (noria:NetworkLink) ---
:NL_WebSrv01_Switch a noria:NetworkLink ;
    rdfs:label "WebSrv01 to LAN Switch Link"@en ;
    rdfs:comment "Ethernet link connecting Web Server 01 to the corporate LAN switch."@en ;
    noria:networkLinkId "NL-WS01-SW" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource :Resource_WebSrv01 ;
    noria:networkLinkTerminationResource :Resource_LANSwitch01 . # Assuming a LAN switch resource exists

:NL_DBSrv01_Switch a noria:NetworkLink ;
    rdfs:label "DBSrv01 to SAN Switch Link"@en ;
    rdfs:comment "Fiber Channel link connecting Database Server 01 to the SAN switch."@en ;
    noria:networkLinkId "NL-DB01-SAN" ;
    noria:networkLinkType "Fiber Channel" ;
    noria:networkLinkInstallationDate "2023-02-01T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource :Resource_DBSrv01 ;
    noria:networkLinkTerminationResource :Resource_SANSwitch01 . # Assuming a SAN switch resource exists

:NL_CoreRouter01_ISP a noria:NetworkLink ;
    rdfs:label "Core Router 01 to ISP Link"@en ;
    rdfs:comment "High-speed fiber link connecting Core Router 01 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-CR01-ISP" ;
    noria:networkLinkType "Optical Fiber" ;
    noria:networkLinkInstallationDate "2022-05-20T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination :Resource_ISP_Router01 ; # Assuming an ISP router resource exists
    noria:resourceManagedBy :Agent_Network_Team .

:NL_CoreRouter01_LAN a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Internal LAN Link"@en ;
    rdfs:comment "Internal link connecting Core Router 01 to the corporate LAN."@en ;
    noria:networkLinkId "NL-CR01-LAN" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-05-20T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource :Resource_CoreRouter01 ;
    noria:networkLinkTerminationResource :Resource_LANSwitch01 ;
    noria:resourceManagedBy :Agent_Network_Team .

:NL_Firewall01_CoreRouter a noria:NetworkLink ;
    rdfs:label "Firewall 01 to Core Router 01 Link"@en ;
    rdfs:comment "Link between the perimeter firewall and the core router."@en ;
    noria:networkLinkId "NL-FW01-CR01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-06-01T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_Firewall01 ;
    noria:networkLinkTerminationResourceDestination :Resource_CoreRouter01 ;
    noria:resourceManagedBy :Agent_Security_Team .

