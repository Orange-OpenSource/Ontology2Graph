    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressCountry "FR" .

:Site_Lyon_Office a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "LYN-OFF" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressCountry "FR" .

:Room_DC1_ServerRoom_A a noria:Room ;
    rdfs:label "DC1 Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center 1."@en ;
    bot:hasSpace :Locus_DC1_Rack_A1, :Locus_DC1_Rack_A2 .

:Room_DC1_NetworkRoom_B a noria:Room ;
    rdfs:label "DC1 Network Room B"@en ;
    rdfs:comment "Network equipment room in Paris Data Center 1."@en ;
    bot:hasSpace :Locus_DC1_Rack_B1 .

:Locus_DC1_Rack_A1 a noria:Locus ;
    rdfs:label "Rack A1 in DC1 Server Room A"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

:Locus_DC1_Rack_A2 a noria:Locus ;
    rdfs:label "Rack A2 in DC1 Server Room A"@en ;
    rdfs:comment "Specific rack location for database servers."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en .

:Locus_DC1_Rack_B1 a noria:Locus ;
    rdfs:label "Rack B1 in DC1 Network Room B"@en ;
    rdfs:comment "Specific rack location for network devices."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "1"@en .

