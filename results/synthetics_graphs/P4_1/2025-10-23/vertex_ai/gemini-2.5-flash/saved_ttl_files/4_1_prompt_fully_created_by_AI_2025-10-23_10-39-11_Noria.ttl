# --- Network Links (noria:NetworkLink) ---
<networkLink/CR01_FW01_Link> a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Firewall 01 Link"@en ;
    rdfs:comment "High-speed link between CR01 and FW01."@en ;
    noria:networkLinkTerminationResource <resource/CoreRouter01> ;
    noria:networkLinkTerminationResource <resource/Firewall01> ;
    noria:networkInterfaceConnects <networkInterface/CR01_GE0_0_0> ;
    noria:networkInterfaceConnects <networkInterface/FW01_ETH0_0> ;
    noria:networkLinkId "NL-CR01-FW01-001" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2020-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/TeamA> .

<networkLink/CR01_CR02_Link> a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Core Router 02 Interconnect"@en ;
    rdfs:comment "Redundant link between CR01 and CR02."@en ;
    noria:networkLinkTerminationResource <resource/CoreRouter01> ;
    noria:networkLinkTerminationResource <resource/CoreRouter02> ;
    noria:networkInterfaceConnects <networkInterface/CR01_GE0_0_1> ;
    noria:networkInterfaceConnects <networkInterface/CR02_GE0_0_0> ;
    noria:networkLinkId "NL-CR01-CR02-001" ;
    noria:networkLinkType "Fiber Optic 40Gbps" ;
    noria:networkLinkInstallationDate "2020-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/TeamA> .

<networkLink/WAN_Lyon_Paris> a noria:NetworkLink ;
    rdfs:label "WAN Link Lyon-Paris"@en ;
    rdfs:comment "Dedicated WAN link connecting Lyon office to Paris DC."@en ;
    noria:networkLinkTerminationResourceOrigin <resource/BranchRouter01> ;
    noria:networkLinkTerminationResourceDestination <resource/CoreRouter01> ;
    noria:networkInterfaceConnects <networkInterface/BR01_GE0_0_0> ;
    noria:networkLinkId "NL-WAN-LYN-PAR-001" ;
    noria:networkLinkType "MPLS VPN 1Gbps" ;
    noria:networkLinkInstallationDate "2021-08-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/TeamA> .

