# --- Event Records (noria:EventRecord) ---
<event/Log_CR01_InterfaceDown> a noria:EventRecord ;
    rdfs:label "Core Router 01 Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2023-10-26T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/CoreRouter01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/0, changed state to down"@en ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<event/Log_AppSrv01_HighCPU> a noria:EventRecord ;
    rdfs:label "Application Server 01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Application Server 01."@en ;
    noria:loggingTime "2023-10-26T10:15:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/AppServer01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "CPU utilization on app01.par.example.com exceeded 90% for 5 minutes."@en ;
    dcterms:type <kos/Notification/EventType/ThresholdExceeded> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<event/Log_FW01_BlockedTraffic> a noria:EventRecord ;
    rdfs:label "Firewall 01 Blocked Traffic Alert"@en ;
    rdfs:comment "Security alert from Firewall 01 about blocked suspicious traffic."@en ;
    noria:loggingTime "2023-10-26T10:20:15Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Firewall01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "Blocked connection attempt from 1.2.3.4 to 10.0.1.100 on port 8080."@en ;
    dcterms:type <kos/Notification/EventType/SecurityAlert> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent <agent/AliceJohnson> .

<event/Log_VM_Web_Prod_Restart> a noria:EventRecord ;
    rdfs:label "VM Web Prod Restart Log"@en ;
    rdfs:comment "Log entry indicating a restart of the Production Web Server VM."@en ;
    noria:loggingTime "2023-10-26T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/VM_Web_Prod> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "Virtual machine webprod.example.com restarted by system administrator."@en ;
    dcterms:type <kos/Notification/EventType/SystemRestart> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:logOriginatingAgent <agent/BobWilliams> .

<event/Log_BR01_WAN_Flap> a noria:EventRecord ;
    rdfs:label "Branch Router 01 WAN Interface Flap"@en ;
    rdfs:comment "Log entry indicating intermittent connectivity on Branch Router 01's WAN interface."@en ;
    noria:loggingTime "2023-10-26T10:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/BranchRouter01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "Interface ge-0/0/0 on br01.lyn.example.com flapping (up/down)."@en ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

