# --- Locations (bot:Site, noria:Room, noria:Locus) ---
<site/ParisDC> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressCountry "FR" .

<site/LyonOffice> a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressCountry "FR" .

<room/ServerRoomA> a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within Paris Data Center."@en ;
    bot:hasSpace <site/ParisDC> .

<room/NetworkCloset1> a noria:Room ;
    rdfs:label "Network Closet 1"@en ;
    rdfs:comment "Network equipment closet in Lyon Office, 3rd floor."@en ;
    bot:hasSpace <site/LyonOffice> .

<locus/RackA1> a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace <room/ServerRoomA> .

<locus/RackB5> a noria:Locus ;
    rdfs:label "Rack B5"@en ;
    rdfs:comment "Fifth rack in Server Room A."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:hasSpace <room/ServerRoomA> .

<locus/WallMount1> a noria:Locus ;
    rdfs:label "Wall Mount 1"@en ;
    rdfs:comment "Wall-mounted equipment location in Network Closet 1."@en ;
    noria:locusLine "WM" ;
    noria:locusRow "1" ;
    bot:hasSpace <room/NetworkCloset1> .

