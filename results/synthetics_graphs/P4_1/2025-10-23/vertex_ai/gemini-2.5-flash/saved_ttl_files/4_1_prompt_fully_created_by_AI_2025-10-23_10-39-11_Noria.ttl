# --- Operation Plans (noria:OperationPlan) ---
<operationPlan/RouterFirmwareUpgrade> a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware."@en ;
    skos:example "Steps include backup configuration, upload new image, verify checksum, reload, verify operation."@en ;
    noria:operationPlanPreCondition <actionPreCondition/RouterReadyForUpgrade> ;
    noria:operationPlanPostCondition <actionPostCondition/RouterUpgradeSuccessful> .

<operationPlan/AppServerRestart> a noria:OperationPlan ;
    rdfs:label "Application Server Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting an application server."@en ;
    skos:example "Steps include notifying users, gracefully shutting down services, restarting OS, verifying service availability."@en ;
    noria:operationPlanPreCondition <actionPreCondition/AppServerReadyForRestart> ;
    noria:operationPlanPostCondition <actionPostCondition/AppServerRestartSuccessful> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
<actionPreCondition/RouterReadyForUpgrade> a noria:ActionPreCondition ;
    rdfs:label "Router Ready for Upgrade"@en ;
    rdfs:comment "Condition: Router is in a stable state, configuration backed up, maintenance window approved."@en .

<actionPostCondition/RouterUpgradeSuccessful> a noria:ActionPostCondition ;
    rdfs:label "Router Upgrade Successful"@en ;
    rdfs:comment "Outcome: Router is operational on new firmware, all interfaces up, routing protocols converged."@en .

<actionPreCondition/AppServerReadyForRestart> a noria:ActionPreCondition ;
    rdfs:label "Application Server Ready for Restart"@en ;
    rdfs:comment "Condition: All critical processes stopped, database synchronized, users notified."@en .

<actionPostCondition/AppServerRestartSuccessful> a noria:ActionPostCondition ;
    rdfs:label "Application Server Restart Successful"@en ;
    rdfs:comment "Outcome: Application services are running, accessible, and responding normally."@en .

# --- Additional connections for density ---

# Link resources to applications they support
<resource/AppServer01> noria:resourceForApplication <application/InternalCRM> .
<resource/VM_Web_Prod> noria:resourceForApplication <application/CorporateWebsite> .
<resource/CoreRouter01> noria:resourceForApplication <application/MonitoringPlatform> .
<resource/Firewall01> noria:resourceForApplication <application/MonitoringPlatform> .

# Link application modules to resources
<applicationModule/CorporateWebsite_Prod> seas:subSystemOf <resource/VM_Web_Prod> .
<applicationModule/InternalCRM_Dev> seas:subSystemOf <resource/AppServer01> .
<applicationModule/MonitoringPlatform_Prod> seas:subSystemOf <resource/CoreRouter01> .
<applicationModule/MonitoringPlatform_Prod> seas:subSystemOf <resource/Firewall01> .

# Link agents to resources they manage (inverse of resourceManagedBy)
<agent/TeamA> noria:agentManagesResource <resource/CoreRouter01> .
<agent/TeamA> noria:agentManagesResource <resource/CoreRouter02> .
<agent/TeamA> noria:agentManagesResource <resource/BranchRouter01> .
<agent/TeamB> noria:agentManagesResource <resource/VM_Web_Prod> .
<agent/TeamC> noria:agentManagesResource <resource/AppServer01> .
<agent/TeamC> noria:agentManagesResource <resource/VirtualHost01> .
<agent/TeamD> noria:agentManagesResource <resource/Firewall01> .

# Link trouble tickets to event records for status history
<troubleTicket/TT20231026-001> noria:documentStatusHistory <event/Log_CR01_InterfaceDown> .
<troubleTicket/TT20231026-002> noria:documentStatusHistory <event/Log_AppSrv01_HighCPU> .
<troubleTicket/TT20231026-003> noria:documentStatusHistory <event/Log_BR01_WAN_Flap> .

# Link change requests to operation plans
<changeRequest/CR20231101-001> noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardSoftwareUpgrade> .
<changeRequest/CR20231101-001> noria:changeRequestImpact <networkInterface/CR01_GE0_0_0> .
<changeRequest/CR20231101-001> noria:changeRequestImpact <networkInterface/CR01_GE0_0_1> .

# Example of an EventRecord being mitigated by a ProcedureExecutionContainer (e.g., a ChangeRequest or TroubleTicket)
<event/Log_CR01_InterfaceDown> noria:alarmMitigatedBy <troubleTicket/TT20231026-001> .
<event/Log_AppSrv01_HighCPU> noria:alarmMitigatedBy <troubleTicket/TT20231026-002> .

# Example of a TroubleTicketNote correlated with a ProcedureExecutionContainer (e.g., a ChangeRequest or another TroubleTicket)
<troubleTicketNote/TT20231026-001-Note1> noria:troubleTicketNoteCorrelatedExecution <changeRequest/CR20231101-001> .

# Example of network interface observables
<networkInterface/CR01_GE0_0_0> noria:networkInterfaceRoutingPriorityMetric 100 .
<networkInterface/CR01_GE0_0_0> noria:networkInterfaceLaserTxOpticalPower -3 .
<networkInterface/CR01_GE0_0_0> noria:networkInterfaceLaserRxOpticalPower -5 .
<networkInterface/CR01_GE0_0_0> noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 .
<networkInterface/CR01_GE0_0_0> noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

<networkInterface/BR01_GE0_0_0> noria:networkInterfaceRoutingPriorityMetric 200 .
<networkInterface/BR01_GE0_0_0> noria:networkInterfaceLaserTxOpticalPower -2 .
<networkInterface/BR01_GE0_0_0> noria:networkInterfaceLaserRxOpticalPower -8 .
<networkInterface/BR01_GE0_0_0> noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 .
<networkInterface/BR01_GE0_0_0> noria:networkInterfaceLaserRxLowPowerWarningThreshold -12 .

# Example of virtual server status
<resource/VM_Web_Prod> noria:virtualServerStatus <kos/Resource/OperationalState/Running> .

# --- KOS Concepts (minimal examples for illustration, as they are usually external) ---
<kos/application/type/CustomerFacing> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/type> ; rdfs:label "Customer Facing"@en .
<kos/application/type/BusinessSupport> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/type> ; rdfs:label "Business Support"@en .
