<kos/application/business-importance/High> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ; rdfs:label "High"@en .
<kos/application/business-importance/Critical> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ; rdfs:label "Critical"@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; rdfs:label "Critical"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; rdfs:label "Major"@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; rdfs:label "Failure"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; rdfs:label "Assistance"@en .

<kos/TroubleTicket/category/InterruptedService> a skos:Concept ; skos:inScheme <kos/TroubleTicket/category> ; rdfs:label "Interrupted Service"@en .
<kos/TroubleTicket/category/DegradedService> a skos:Concept ; skos:inScheme <kos/TroubleTicket/category> ; rdfs:label "Degraded Service"@en .
<kos/TroubleTicket/category/IsolatedCustomerSite> a skos:Concept ; skos:inScheme <kos/TroubleTicket/category> ; rdfs:label "Isolated Customer Site"@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:inScheme <kos/TroubleTicket/priority> ; rdfs:label "P1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:inScheme <kos/TroubleTicket/priority> ; rdfs:label "P2"@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:inScheme <kos/TroubleTicket/origin> ; rdfs:label "Supervision"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:inScheme <kos/TroubleTicket/origin> ; rdfs:label "Customer"@en .
<kos/TroubleTicket/origin/User> a skos:Concept ; skos:inScheme <kos/TroubleTicket/origin> ; rdfs:label "User"@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; skos:inScheme <kos/TroubleTicket/urgency> ; rdfs:label "Immediate Intervention"@en .
