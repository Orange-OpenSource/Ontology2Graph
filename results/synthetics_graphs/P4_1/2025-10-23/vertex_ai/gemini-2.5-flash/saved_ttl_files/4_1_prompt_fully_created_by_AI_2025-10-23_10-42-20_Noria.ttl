    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FWDMZ-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/RackA1> ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.1> .

