# --- Operation Plans (noria:OperationPlan) ---
<operationplan/CheckFiberLink> a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and troubleshooting fiber optic link issues."@en ;
    skos:example "1. Verify physical connection. 2. Check optical power levels. 3. Contact ISP if issue persists."@en ;
    noria:operationPlanPreCondition <actionprecondition/FiberLinkDown> ;
    noria:operationPlanPostCondition <actionpostcondition/FiberLinkRestored> .

<operationplan/ExtendDiskPartition> a noria:OperationPlan ;
    rdfs:label "Extend Disk Partition Procedure"@en ;
    rdfs:comment "Procedure for safely extending a disk partition on a Linux VM."@en ;
    skos:example "1. Backup data. 2. Unmount partition. 3. Extend logical volume. 4. Resize filesystem. 5. Mount partition."@en ;
    noria:operationPlanPreCondition <actionprecondition/DiskSpaceLow> ;
    noria:operationPlanPostCondition <actionpostcondition/DiskSpaceIncreased> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
<actionprecondition/FiberLinkDown> a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Condition where a fiber optic network link is reported as down or experiencing severe errors."@en .

<actionpostcondition/FiberLinkRestored> a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored Post-Condition"@en ;
    rdfs:comment "Condition where a fiber optic network link is operational and stable, with acceptable optical power levels."@en .

<actionprecondition/DiskSpaceLow> a noria:ActionPreCondition ;
    rdfs:label "Disk Space Low Pre-Condition"@en ;
    rdfs:comment "Condition where a server's disk partition has less than 10% free space."@en .

<actionpostcondition/DiskSpaceIncreased> a noria:ActionPostCondition ;
    rdfs:label "Disk Space Increased Post-Condition"@en ;
    rdfs:comment "Condition where a server's disk partition has been successfully expanded, with more than 30% free space."@en .

# --- Additional Connections for Density ---
<agent/DNSAdminTeam> noria:agentManagesResource <resource/DNS01> .
<agent/NetworkOpsTeam> noria:agentManagesResource <resource/RouterCore01>, <resource/LoadBalancer01> .
<agent/SecurityTeam> noria:agentManagesResource <resource/FirewallDMZ> .
<agent/SystemAdmin> noria:agentManagesResource <resource/WebServerVM01> .
<agent/DatabaseAdmin> noria:agentManagesResource <resource/DBServerVM01> .

<resource/DNS01> noria:resourceForApplication <application/DNSInfrastructure> .
<resource/RouterCore01> noria:resourceForApplication <application/MonitoringPlatform> .
<resource/FirewallDMZ> noria:resourceForApplication <application/MonitoringPlatform> .
<resource/LoadBalancer01> noria:resourceForApplication <application/CorporateWebsite> .

<appmodule/CorporateWebsite-Prod> noria:applicationModuleAdministrationLeader <agent/SystemAdmin> .
<appmodule/CRMSystem-Prod> noria:applicationModuleAdministrationLeader <agent/DatabaseAdmin> .
<appmodule/MonitoringPlatform-Core> noria:applicationModuleAdministrationLeader <agent/NOCEngineer> .
<appmodule/DNSInfrastructure-Primary> noria:applicationModuleAdministrationLeader <agent/DNSAdminTeam> .

<troubleticket/TT20240423-001> noria:documentStatusHistory <event/RouterCore01-InterfaceDown> .
<troubleticket/TT20240423-002> noria:documentStatusHistory <event/DBServerVM01-DiskFull> .
<troubleticket/TT20240423-003> noria:documentStatusHistory <event/DNS01-CPUHigh> .

<changerequest/CR20240424-001> noria:documentStatusHistory <event/DBServerVM01-DiskFull> . # Link CR to the event that triggered it
<changerequest/CR20240424-002> noria:documentStatusHistory <event/WebServerVM01-LogonFailure> . # Example of a CR triggered by a security event (e.g., upgrade to patch vulnerability)

<event/RouterCore01-InterfaceDown> noria:alarmMitigatedBy <troubleticket/TT20240423-001> .
<event/DBServerVM01-DiskFull> noria:alarmMitigatedBy <troubleticket/TT20240423-002> .
<event/DNS01-CPUHigh> noria:alarmMitigatedBy <troubleticket/TT20240423-003> .

<troubleticketnote/TT20240423-002-Note1> noria:troubleTicketNoteCorrelatedExecution <changerequest/CR20240424-001> . # Note leads to a change request

# End of Graph
