    noria:serviceType <kos/service/type/BusinessService> ;
    seas:subSystemOf <appmodule/CRMSystem-Prod> ;
    seas:subSystemOf <resource/DBServerVM01> .

# --- Event Records (noria:EventRecord) ---
<event/DNS01-CPUHigh> a noria:EventRecord ;
    rdfs:label "DNS01 High CPU Alert"@en ;
    rdfs:comment "CPU utilization on DNS01 server exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/DNS01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "CPU usage on dns01.corp.example.com is 95%."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<event/RouterCore01-InterfaceDown> a noria:EventRecord ;
    rdfs:label "RouterCore01 Interface Down Alert"@en ;
    rdfs:comment "GigabitEthernet 0/0/1 on RouterCore01 went down."@en ;
    noria:loggingTime "2024-04-23T11:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/RouterCore01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <operationplan/CheckFiberLink> .

<event/WebServerVM01-LogonFailure> a noria:EventRecord ;
    rdfs:label "WebServerVM01 Repeated Logon Failures"@en ;
    rdfs:comment "Multiple failed login attempts detected on WebServerVM01."@en ;
    noria:loggingTime "2024-04-23T12:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/WebServerVM01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "Security audit failure: Logon Failure (0xC000006D) for user 'admin' from IP 1.2.3.4."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent <http://example.com/agent/ExternalAttacker> . # Example of external agent

<event/DBServerVM01-DiskFull> a noria:EventRecord ;
    rdfs:label "DBServerVM01 Disk Full Alert"@en ;
    rdfs:comment "Database server disk space critically low."@en ;
    noria:loggingTime "2024-04-23T13:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/DBServerVM01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "Disk usage on /var/lib/mysql is 98%."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<event/FirewallDMZ-ConfigChange> a noria:EventRecord ;
    rdfs:label "FirewallDMZ Configuration Change Log"@en ;
    rdfs:comment "Configuration change applied to DMZ Firewall by an administrator."@en ;
    noria:loggingTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/FirewallDMZ> ;
    noria:logOriginatingAgent <agent/SecurityTeam> ;
    noria:logText "Configuration committed by admin_user from 172.16.0.10."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

