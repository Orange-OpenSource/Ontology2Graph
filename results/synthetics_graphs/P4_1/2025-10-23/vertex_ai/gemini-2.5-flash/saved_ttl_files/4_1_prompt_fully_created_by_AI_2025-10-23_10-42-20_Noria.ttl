# --- Network Interfaces (noria:NetworkInterface) ---
<networkinterface/DNS01-Eth0> a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01."@en ;
    noria:networkInterfaceOf <resource/DNS01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

<networkinterface/RouterCore01-Gi0-0-1> a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Uplink interface for Core Router 01 to ISP."@en ;
    noria:networkInterfaceOf <resource/RouterCore01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

<networkinterface/RouterCore01-Gi0-0-2> a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface for Core Router 01 to internal network."@en ;
    noria:networkInterfaceOf <resource/RouterCore01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

<networkinterface/FirewallDMZ-Eth0> a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ Ethernet 0"@en ;
    rdfs:comment "External interface for DMZ Firewall."@en ;
    noria:networkInterfaceOf <resource/FirewallDMZ> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/FirewallDMZ-Eth1> a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ Ethernet 1"@en ;
    rdfs:comment "Internal interface for DMZ Firewall."@en ;
    noria:networkInterfaceOf <resource/FirewallDMZ> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/WebServerVM01-Eth0> a noria:NetworkInterface ;
    rdfs:label "WebServerVM01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for WebServerVM01."@en ;
    noria:networkInterfaceOf <resource/WebServerVM01> ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/DBServerVM01-Eth0> a noria:NetworkInterface ;
    rdfs:label "DBServerVM01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DBServerVM01."@en ;
    noria:networkInterfaceOf <resource/DBServerVM01> ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links (noria:NetworkLink) ---
<networklink/ISP-CoreRouter> a noria:NetworkLink ;
    rdfs:label "ISP Uplink to Core Router"@en ;
    rdfs:comment "High-speed fiber link connecting the corporate network to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-ISP-CR01" ;
    noria:networkLinkTerminationResourceOrigin <resource/RouterCore01> ;
    noria:networkLinkTerminationResourceDestination <http://example.com/resource/ISP-Router> ; # External resource
    noria:networkInterfaceConnects <networkinterface/RouterCore01-Gi0-0-1> ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" ;
    noria:resourceManagedBy <agent/NetworkOpsTeam> .

<networklink/CoreRouter-DMZFirewall> a noria:NetworkLink ;
    rdfs:label "Core Router to DMZ Firewall Link"@en ;
    rdfs:comment "Internal link between core router and DMZ firewall."@en ;
    noria:networkLinkId "NL-CR01-FWDMZ" ;
    noria:networkLinkTerminationResourceOrigin <resource/RouterCore01> ;
    noria:networkLinkTerminationResourceDestination <resource/FirewallDMZ> ;
    noria:networkInterfaceConnects <networkinterface/RouterCore01-Gi0-0-2> ;
    noria:networkInterfaceConnects <networkinterface/FirewallDMZ-Eth0> ;
    noria:networkLinkInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy <agent/NetworkOpsTeam> .

<networklink/DMZFirewall-WebServer> a noria:NetworkLink ;
    rdfs:label "DMZ Firewall to Web Server Link"@en ;
    rdfs:comment "Link from DMZ firewall to web server VM."@en ;
    noria:networkLinkId "NL-FWDMZ-WEB01" ;
    noria:networkLinkTerminationResourceOrigin <resource/FirewallDMZ> ;
    noria:networkLinkTerminationResourceDestination <resource/WebServerVM01> ;
    noria:networkInterfaceConnects <networkinterface/FirewallDMZ-Eth1> ;
    noria:networkInterfaceConnects <networkinterface/WebServerVM01-Eth0> ;
    noria:networkLinkInstallationDate "2023-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:resourceManagedBy <agent/SystemAdmin> .

<networklink/InternalNetwork-DNS01> a noria:NetworkLink ;
    rdfs:label "Internal Network to DNS01 Link"@en ;
    rdfs:comment "Link connecting DNS01 to the internal corporate network."@en ;
    noria:networkLinkId "NL-INT-DNS01" ;
    noria:networkLinkTerminationResource <resource/DNS01> ;
    noria:networkInterfaceConnects <networkinterface/DNS01-Eth0> ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy <agent/DNSAdminTeam> .

<networklink/WebServer-DBServer> a noria:NetworkLink ;
    rdfs:label "Web Server to DB Server Link"@en ;
    rdfs:comment "Internal link between web server and database server VMs."@en ;
    noria:networkLinkId "NL-WEB01-DB01" ;
    noria:networkLinkTerminationResourceOrigin <resource/WebServerVM01> ;
    noria:networkLinkTerminationResourceDestination <resource/DBServerVM01> ;
    noria:networkInterfaceConnects <networkinterface/WebServerVM01-Eth0> ; # Assuming a single interface for simplicity, in reality, often dedicated interfaces/VLANs
    noria:networkInterfaceConnects <networkinterface/DBServerVM01-Eth0> ;
    noria:networkLinkInstallationDate "2023-03-01T13:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:resourceManagedBy <agent/SystemAdmin> .

# --- Applications (noria:Application) ---
<application/CorporateWebsite> a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "The official public website of the corporation."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CW" ;
