    rdfs:comment "Core infrastructure service providing name resolution for internal systems."@en ;
    noria:applicationModelIdentifier "CORP-DNS-V1" ;
    noria:applicationNumericalIdentifier 3001 ;
    noria:applicationShortIdentifier "CorpDNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Name Resolution" ;
    noria:resourceForApplication noria:Resource_DNS01 .

noria:App_CustomerDB a noria:Application ;
    rdfs:label "Customer Database Service"@en ;
    rdfs:comment "Database service storing customer information for various business applications."@en ;
    noria:applicationModelIdentifier "CUSTDB-PROD" ;
    noria:applicationNumericalIdentifier 4001 ;
    noria:applicationShortIdentifier "CustDB" ;
    noria:applicationType <kos/application/type/database-service> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Data Management" ;
    noria:applicationFunctionalSubDomain "Customer Data Storage" ;
