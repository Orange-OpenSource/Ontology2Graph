# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OP_DNS_Troubleshooting a noria:OperationPlan ;
    rdfs:label "DNS Server Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving issues with corporate DNS servers."@en ;
    skos:example "Steps include checking network connectivity, DNS service status, log files, and configuration."@en ;
    noria:operationPlanPreCondition noria:APC_DNS_Unreachable ;
    noria:operationPlanPostCondition noria:APOC_DNS_Restored .

noria:OP_Firewall_RuleAdd a noria:OperationPlan ;
    rdfs:label "Firewall Rule Addition Procedure"@en ;
    rdfs:comment "Procedure for safely adding new rules to production firewalls."@en ;
    skos:example "Includes steps for rule definition, review, testing, and deployment."@en ;
    noria:operationPlanPreCondition noria:APC_Firewall_ChangeApproved ;
    noria:operationPlanPostCondition noria:APOC_Firewall_RuleActive .

noria:OP_Router_OSUpgrade a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the operating system of core network routers."@en ;
    skos:example "Includes pre-checks, backup, upgrade execution, and post-validation."@en ;
    noria:operationPlanPreCondition noria:APC_Router_UpgradeApproved ;
    noria:operationPlanPostCondition noria:APOC_Router_OSUpdated .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:APC_DNS_Unreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unreachable"@en ;
    rdfs:comment "Condition: DNS server is not responding to queries or ping."@en ;
    skos:example "Monitoring system reports DNS01 as down."@en .

noria:APOC_DNS_Restored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS server is responding to queries and services are functional."@en ;
    skos:example "Monitoring system reports DNS01 as up and healthy."@en .

noria:APC_Firewall_ChangeApproved a noria:ActionPreCondition ;
    rdfs:label "Firewall Change Approved"@en ;
    rdfs:comment "Condition: Change Request for firewall rule modification has been approved."@en ;
    skos:example "CR-20240419-001 status is 'Approved'."@en .

noria:APOC_Firewall_RuleActive a noria:ActionPostCondition ;
    rdfs:label "Firewall Rule Active and Verified"@en ;
    rdfs:comment "Outcome: New firewall rule is active and verified to be working as expected."@en ;
    skos:example "Connectivity tests through the new rule are successful."@en .

noria:APC_Router_UpgradeApproved a noria:ActionPreCondition ;
    rdfs:label "Router OS Upgrade Approved"@en ;
    rdfs:comment "Condition: Change Request for router OS upgrade has been approved."@en ;
    skos:example "CR-20240425-001 status is 'Approved'."@en .

noria:APOC_Router_OSUpdated a noria:ActionPostCondition ;
    rdfs:label "Router OS Updated and Functional"@en ;
    rdfs:comment "Outcome: Router OS is successfully updated, and all network services are functional."@en ;
    skos:example "Router uptime is normal, and network traffic flows without interruption."@en .

