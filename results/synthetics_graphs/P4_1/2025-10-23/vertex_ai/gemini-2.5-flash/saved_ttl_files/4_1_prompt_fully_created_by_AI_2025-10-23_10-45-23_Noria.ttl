    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam .

noria:NL_Core01_CoreSW01 a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to Core Switch 01"@en ;
    rdfs:comment "Internal link between Core Router 01 and the data center's core switch."@en ;
    noria:networkLinkId "LINK-RTRC01-CSW01" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ; # Core Switch is implicitly part of the network managed by RouterCore01
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam .

noria:NL_FirewallDMZ01_DMZSW a noria:NetworkLink ;
