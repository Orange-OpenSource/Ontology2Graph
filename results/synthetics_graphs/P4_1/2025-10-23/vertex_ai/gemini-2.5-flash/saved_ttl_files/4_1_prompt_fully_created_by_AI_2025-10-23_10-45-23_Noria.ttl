noria:CR_FirewallRuleUpdate_20240419 a noria:ChangeRequest ;
    rdfs:label "Firewall Rule Update for New Service"@en ;
    rdfs:comment "Planned change to add new firewall rules to DMZ Firewall 01 to allow traffic for a new customer service."@en ;
    dcterms:identifier "CR-20240419-001" ;
    dcterms:created "2024-04-15T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-19T18:30:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-19T17:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-19T19:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-19T17:55:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-19T18:15:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:Resource_FirewallDMZ01, noria:Service_CustomerFacingWeb ;
    noria:changeRequestOutageDuration "PT0H0M0S"^^xsd:duration ; # No expected outage
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Implemented> ;
    noria:changeRequestInitiatorParty noria:Person_CharlieBrown ;
    noria:changeRequestPilotParty noria:Person_CharlieBrown ;
    noria:changeRequestActorParty noria:Person_CharlieBrown ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef "https://changemanagement.example.com/CR-20240419-001" .

