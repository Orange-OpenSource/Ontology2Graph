<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor Severity"@en .
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:prefLabel "Failure Ticket"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:prefLabel "Assistance Ticket"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en .
<kos/TroubleTicket/priority/P3> a skos:Concept ; skos:prefLabel "Priority 3"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision Origin"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer Origin"@en .
