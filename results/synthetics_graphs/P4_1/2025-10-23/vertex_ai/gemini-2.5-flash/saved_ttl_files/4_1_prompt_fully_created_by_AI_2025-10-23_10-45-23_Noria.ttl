noria:Event_DNS01_Down a noria:EventRecord ;
    rdfs:label "DNS01 Server Down Alert"@en ;
    rdfs:comment "Alert indicating that Corporate DNS Server 01 is unreachable."@en ;
    dcterms:type <kos/Notification/EventType/alarm> ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "Host dns01.corp.example.com is DOWN. Ping failed."@en .

noria:Event_RouterCore01_InterfaceDown a noria:EventRecord ;
    rdfs:label "RouterCore01 Interface Down"@en ;
    rdfs:comment "Log entry indicating that GigabitEthernet0/0/0 on RouterCore01 changed state to down."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:loggingTime "2024-04-20T09:29:50Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en .

noria:Event_VMWeb01_HighCPU a noria:EventRecord ;
    rdfs:label "VMWeb01 High CPU Usage"@en ;
    rdfs:comment "Warning alert for high CPU utilization on Web Server VM 01."@en ;
    dcterms:type <kos/Notification/EventType/alarm> ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_VMWeb01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logText "CPU usage on web01.corp.example.com exceeded 90% for 5 minutes."@en .

noria:Event_FirewallDMZ01_ConfigChange a noria:EventRecord ;
    rdfs:label "FirewallDMZ01 Configuration Change"@en ;
    rdfs:comment "Log entry for a configuration change on Firewall DMZ 01."@en ;
    dcterms:type <kos/Notification/EventType/configurationChange> ;
    noria:loggingTime "2024-04-19T18:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logOriginatingAgent noria:Person_CharlieBrown ;
    noria:logText "Rule 'Allow_SSH_External' modified by Charlie Brown."@en .

noria:Event_DBServer01_DiskFull a noria:EventRecord ;
    rdfs:label "DBServer01 Disk Full Alert"@en ;
    rdfs:comment "Critical alert indicating that the disk space on Database Server 01 is nearly full."@en ;
    dcterms:type <kos/Notification/EventType/alarm> ;
    noria:loggingTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "Disk usage on /var/lib/mysql on db01.corp.example.com is at 98%."@en .

