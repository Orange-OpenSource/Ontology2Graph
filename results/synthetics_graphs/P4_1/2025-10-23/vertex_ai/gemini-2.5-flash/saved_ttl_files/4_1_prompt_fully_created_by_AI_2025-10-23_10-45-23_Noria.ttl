<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down Operational State"@en .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; skos:prefLabel "Up Administrative State"@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; skos:prefLabel "Down Administrative State"@en .

<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service Type"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service Type"@en .

<kos/Notification/EventType/stateChange> a skos:Concept ; skos:prefLabel "State Change Event Type"@en .
<kos/Notification/EventType/alarm> a skos:Concept ; skos:prefLabel "Alarm Event Type"@en .
<kos/Notification/EventType/configurationChange> a skos:Concept ; skos:prefLabel "Configuration Change Event Type"@en .
<kos/Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical Perceived Severity"@en .
<kos/Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major Perceived Severity"@en .
