noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "End-to-end service providing internet connectivity to all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CorpDNSProd, noria:Resource_RouterCore01, noria:Resource_FirewallDMZ01 .

noria:Service_CustomerFacingWeb a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "Service providing access to the public corporate website and customer portal."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_IntranetProd, noria:Resource_VMWeb01, noria:Resource_LoadBalancer01, noria:Resource_FirewallDMZ01 .

noria:Service_InternalDBAccess a noria:Service ;
    rdfs:label "Internal Database Access Service"@en ;
    rdfs:comment "Service providing secure access to internal databases for business applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:App_CustomerDB, noria:Resource_DBServer01 .

