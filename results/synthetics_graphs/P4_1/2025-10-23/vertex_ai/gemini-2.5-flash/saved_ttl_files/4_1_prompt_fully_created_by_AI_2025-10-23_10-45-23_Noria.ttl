    noria:applicationShortIdentifier "CorpIntranet" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Employee Services" ;
    noria:applicationFunctionalSubDomain "Internal Communication" ;
    noria:resourceForApplication noria:Resource_VMWeb01, noria:Resource_DBServer01 .

noria:App_MonitoringSystem a noria:Application ;
