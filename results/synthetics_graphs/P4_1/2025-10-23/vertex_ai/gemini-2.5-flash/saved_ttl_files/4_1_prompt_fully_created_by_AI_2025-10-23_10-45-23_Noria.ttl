noria:NL_DNS01_CoreSW01 a noria:NetworkLink ;
    rdfs:label "Link DNS01 to Core Switch 01"@en ;
    rdfs:comment "Ethernet link between DNS01 and Core Switch 01."@en ;
    noria:networkLinkId "LINK-DNS01-CSW01" ;
    noria:networkLinkTerminationResource noria:Resource_DNS01, noria:Resource_RouterCore01 ; # Assuming Core Switch is part of RouterCore01's domain
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam .

noria:NL_Core01_ISP a noria:NetworkLink ;
    rdfs:label "Uplink Core Router 01 to ISP"@en ;
