    noria:networkLinkInstallationDate "2023-02-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam .

noria:NL_DBServer01_AppSW a noria:NetworkLink ;
