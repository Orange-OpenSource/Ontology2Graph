<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; skos:prefLabel "Deferred Intervention Urgency"@en .
<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ; skos:prefLabel "Total Breakdown Category"@en .
<kos/TroubleTicket/trouble-category/IsolatedCustomerSite> a skos:Concept ; skos:prefLabel "Isolated Customer Site Category"@en .
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; skos:prefLabel "Managed Backbone Networks Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/Customer> a skos:Concept ; skos:prefLabel "Customer Responsibility"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment Type"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:prefLabel "Customer Comment Type"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis Operation Type"@en .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; skos:prefLabel "Tests and Measurements Operation Type"@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress Status"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved Status"@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; skos:prefLabel "Internal Intervention Category"@en .
<kos/ChangeRequest/category/ThirdPartyIntervention> a skos:Concept ; skos:prefLabel "Third Party Intervention Category"@en .
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change Type"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:prefLabel "Emergency Change Type"@en .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; skos:prefLabel "Software Upgrade Cause"@en .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; skos:prefLabel "Configuration Change Cause"@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:prefLabel "Approved Status"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; skos:prefLabel "Implemented Status"@en .

<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router Resource Type"@en .
<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server Resource Type"@en .
<kos/Resource/type/Firewall> a skos:Concept ; skos:prefLabel "Firewall Resource Type"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine Resource Type"@en .
<kos/Resource/type/LoadBalancer> a skos:Concept ; skos:prefLabel "Load Balancer Resource Type"@en .
