    noria:networkLinkInstallationDate "2022-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy noria:Agent_SecurityTeam .

noria:NL_VMWeb01_AppSW a noria:NetworkLink ;
    rdfs:label "Link VMWeb01 to Application Switch"@en ;
    rdfs:comment "Virtual link connecting Web Server VM 01 to the application network switch."@en ;
    noria:networkLinkId "LINK-VMWEB01-APPSW" ;
