# --- Network Interfaces (noria:NetworkInterface) ---
# Interfaces on network devices and servers.

<networkinterface/CorePAR01_Gi0_0_0> a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on Core Router PAR01"@en ;
    rdfs:comment "Uplink interface to ISP on Core Router PAR01."@en ;
    noria:networkInterfaceOf <resource/Router_Core_PAR01> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

<networkinterface/CorePAR01_Gi0_0_1> a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router PAR01"@en ;
    rdfs:comment "Internal link to Core Router PAR02."@en ;
    noria:networkInterfaceOf <resource/Router_Core_PAR01> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

<networkinterface/CorePAR02_Gi0_0_0> a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on Core Router PAR02"@en ;
    rdfs:comment "Internal link to Core Router PAR01."@en ;
    noria:networkInterfaceOf <resource/Router_Core_PAR02> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

<networkinterface/ServerWEB01_Eth0> a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Web App Server 01"@en ;
    rdfs:comment "Network interface for web application server."@en ;
    noria:networkInterfaceOf <resource/Server_App_WEB01> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkinterface/FirewallDMZ01_Eth1> a noria:NetworkInterface ;
    rdfs:label "Ethernet1 on DMZ Firewall 01"@en ;
    rdfs:comment "External interface of DMZ Firewall."@en ;
    noria:networkInterfaceOf <resource/Firewall_DMZ_FW01> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# --- Network Links (noria:NetworkLink) ---
# Connections between network interfaces or resources.

<networklink/Link_CorePAR01_ISP> a noria:NetworkLink ;
    rdfs:label "Uplink CorePAR01 to ISP"@en ;
    rdfs:comment "Primary internet uplink from Paris Data Center."@en ;
    noria:networkLinkTerminationResourceOrigin <resource/Router_Core_PAR01> ;
    noria:networkLinkTerminationResourceDestination <resource/ISP_Router_External> ; # Assuming an external ISP router resource
    noria:networkInterfaceConnects <networkinterface/CorePAR01_Gi0_0_0> ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> .

<resource/ISP_Router_External> a noria:Resource ;
    rdfs:label "ISP Edge Router"@en ;
    rdfs:comment "External router managed by the Internet Service Provider."@en ;
    noria:resourceType <kos/Resource/type/Router> .

<networklink/Link_CorePAR01_CorePAR02> a noria:NetworkLink ;
    rdfs:label "Inter-Core Router Link PAR01-PAR02"@en ;
    rdfs:comment "High-speed link between the two core routers in Paris DC."@en ;
    noria:networkLinkTerminationResourceOrigin <resource/Router_Core_PAR01> ;
    noria:networkLinkTerminationResourceDestination <resource/Router_Core_PAR02> ;
    noria:networkInterfaceConnects <networkinterface/CorePAR01_Gi0_0_1> ;
    noria:networkInterfaceConnects <networkinterface/CorePAR02_Gi0_0_0> ;
    noria:networkLinkType "Ethernet Cross-Connect" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> .

<networklink/Link_WEB01_Firewall> a noria:NetworkLink ;
    rdfs:label "Web Server to DMZ Firewall Link"@en ;
    rdfs:comment "Link connecting the web server to the DMZ firewall."@en ;
    noria:networkLinkTerminationResourceOrigin <resource/Server_App_WEB01> ;
    noria:networkLinkTerminationResourceDestination <resource/Firewall_DMZ_FW01> ;
    noria:networkInterfaceConnects <networkinterface/ServerWEB01_Eth0> ;
    noria:networkInterfaceConnects <networkinterface/FirewallDMZ01_Eth1> ;
    noria:networkLinkType "Internal Ethernet" ;
    noria:networkLinkInstallationDate "2023-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> .

# --- Applications (noria:Application) ---
