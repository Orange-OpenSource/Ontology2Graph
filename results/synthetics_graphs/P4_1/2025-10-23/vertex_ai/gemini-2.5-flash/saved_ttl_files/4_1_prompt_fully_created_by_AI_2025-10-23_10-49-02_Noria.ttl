# --- Services (noria:Service) ---
# End-to-end services provided to customers or internal users.

<service/InternetAccess> a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet access to all corporate users."@en ;
    noria:serviceType <kos/service/type/InfrastructureService> ;
    seas:subSystemOf <application/CorporateWebsite> ; # Example: Corporate Website relies on Internet Access
    seas:subSystemOf <application/CRMSystem> . # CRM System relies on Internet Access

<service/CustomerSupportPortal> a noria:Service ;
    rdfs:label "Customer Support Portal Service"@en ;
    rdfs:comment "External portal for customers to log support requests."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <applicationmodule/CorporateWebsite_Prod> ;
    seas:subSystemOf <applicationmodule/CRMSystem_Dev> . # Dev environment for testing portal features

# --- Event Records (noria:EventRecord) ---
# Logs, alarms, and notifications from various systems.

<eventrecord/Log_RouterCorePAR01_InterfaceDown> a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Core Router PAR01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Router_Core_PAR01> ;
    noria:logOriginatingManagementSystem <applicationmodule/MonitoringPlatform_Prod> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down." ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<eventrecord/Log_ServerWEB01_HighCPU> a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web App Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Server_App_WEB01> ;
    noria:logOriginatingManagementSystem <applicationmodule/MonitoringPlatform_Prod> ;
    noria:logText "CPU utilization on web-app01.example.com exceeded 90% for 5 minutes." ;
    dcterms:type <kos/Notification/EventType/ThresholdExceeded> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<eventrecord/Log_FirewallDMZ01_BlockedAttempt> a noria:EventRecord ;
    rdfs:label "Firewall Blocked Access Attempt"@en ;
    rdfs:comment "Log entry showing a blocked external access attempt on DMZ Firewall 01."@en ;
    noria:loggingTime "2024-04-20T10:20:10Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Firewall_DMZ_FW01> ;
    noria:logOriginatingManagementSystem <applicationmodule/MonitoringPlatform_Prod> ;
    noria:logText "Blocked connection attempt from 203.0.113.42 to 192.0.2.10 on port 80." ;
    dcterms:type <kos/Notification/EventType/SecurityAlert> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent <agent/Person_CharlieBrown> . # SOC analyst might be involved in reviewing this.

<eventrecord/Log_DB_SQL01_DiskFull> a noria:EventRecord ;
    rdfs:label "Database Server Disk Full Alert"@en ;
    rdfs:comment "Alert indicating low disk space on Database Server SQL 01."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Server_DB_SQL01> ;
    noria:logOriginatingManagementSystem <applicationmodule/MonitoringPlatform_Prod> ;
    noria:logText "Disk usage on /var/lib/mysql reached 95% on db-sql01.example.com." ;
    dcterms:type <kos/Notification/EventType/ThresholdExceeded> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

