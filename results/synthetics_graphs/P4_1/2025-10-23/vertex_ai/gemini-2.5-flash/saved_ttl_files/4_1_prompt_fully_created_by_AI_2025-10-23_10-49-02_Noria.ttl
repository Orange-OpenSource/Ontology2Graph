# --- Operation Plans (noria:OperationPlan) ---
# Standardized procedures for operations.

<operationplan/OP_DiskExpansion> a noria:OperationPlan ;
    rdfs:label "Database Disk Expansion Procedure"@en ;
    rdfs:comment "Step-by-step guide for expanding disk space on database servers."@en ;
    skos:example "1. Backup database. 2. Add new disk. 3. Extend logical volume. 4. Verify."@en ;
    noria:operationPlanPreCondition <actionprecondition/DiskSpaceLow> ;
    noria:operationPlanPostCondition <actionpostcondition/DiskSpaceIncreased> .

<operationplan/OP_RouterUpgrade> a noria:OperationPlan ;
    rdfs:label "Core Router Software Upgrade Procedure"@en ;
    rdfs:comment "Procedure for upgrading software on Cisco ASR 9000 series routers."@en ;
    skos:example "1. Download image. 2. Verify checksum. 3. Install image. 4. Reload router. 5. Verify connectivity."@en ;
    noria:operationPlanPreCondition <actionprecondition/RouterSoftwareOutdated> ;
    noria:operationPlanPostCondition <actionpostcondition/RouterSoftwareUpdated> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
# Conditions related to operation plans.

<actionprecondition/DiskSpaceLow> a noria:ActionPreCondition ;
    rdfs:label "Disk Space Low Condition"@en ;
    rdfs:comment "Condition where disk utilization exceeds 90%."@en ;
    skos:example "Disk usage > 90% on critical volume."@en .

<actionpostcondition/DiskSpaceIncreased> a noria:ActionPostCondition ;
    rdfs:label "Disk Space Increased Condition"@en ;
    rdfs:comment "Condition where disk utilization is below 70% after expansion."@en ;
    skos:example "Disk usage < 70% on critical volume."@en .

<actionprecondition/RouterSoftwareOutdated> a noria:ActionPreCondition ;
    rdfs:label "Router Software Outdated Condition"@en ;
    rdfs:comment "Condition where router software version is older than recommended."@en ;
    skos:example "Cisco IOS-XR version < 7.3.2."@en .

<actionpostcondition/RouterSoftwareUpdated> a noria:ActionPostCondition ;
    rdfs:label "Router Software Updated Condition"@en ;
    rdfs:comment "Condition where router software version is updated to the latest recommended."@en ;
    skos:example "Cisco IOS-XR version = 7.3.2."@en .

