# --- Anomaly Patterns ---
noria:AnomalyPattern_HighLatency a noria:AnomalyPattern ;
    rdfs:label "High Network Latency Pattern"@en ;
    rdfs:comment "Pattern indicating high network latency, potentially due to link congestion or device overload."@en ;
    skos:example "Repeated networkInterfaceOperationalStatus changes to Degraded, combined with high packet loss rates."@en .

noria:AnomalyPattern_DBDeadlock a noria:AnomalyPattern ;
    rdfs:label "Database Deadlock Pattern"@en ;
    rdfs:comment "Pattern indicating recurring database deadlocks, affecting application responsiveness."@en ;
    skos:example "Frequent 'deadlock detected' messages in database logs, leading to application timeouts."@en .

# --- Connecting Operation Plans to Anomaly Patterns ---
noria:OperationPlan_TroubleshootNetworkConnectivity seas:solves noria:AnomalyPattern_HighLatency .
noria:OperationPlan_DBOptimization seas:solves noria:AnomalyPattern_DBDeadlock .

noria:OperationPlan_DBOptimization a noria:OperationPlan ;
    rdfs:label "Database Optimization Procedure"@en ;
    rdfs:comment "Procedure for optimizing database performance and resolving deadlocks."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBPerfIssue ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBPerfRestored .

noria:ActionPreCondition_DBPerfIssue a noria:ActionPreCondition ;
    rdfs:label "Database Performance Issue Detected"@en ;
    rdfs:comment "Condition: Database performance metrics are below acceptable thresholds or deadlocks are reported."@en .

noria:ActionPostCondition_DBPerfRestored a noria:ActionPostCondition ;
    rdfs:label "Database Performance Restored"@en ;
    rdfs:comment "Outcome: Database performance metrics are within acceptable thresholds and no deadlocks are reported."@en .

