# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- SKOS Concepts for controlled vocabularies ---
# Application Types
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure Application"@en .
<kos/application/type/business-critical> a skos:Concept ; skos:prefLabel "Business Critical Application"@en .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring Application"@en .
<kos/application/type/database> a skos:Concept ; skos:prefLabel "Database Application"@en .
<kos/application/type/security> a skos:Concept ; skos:prefLabel "Security Application"@en .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; skos:prefLabel "Low Business Importance"@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:prefLabel "Maintenance"@en .

# Service Types
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en .
<kos/TroubleTicket/severity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en .

# Trouble Ticket Type
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:prefLabel "Failure"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:prefLabel "Assistance"@en .
<kos/TroubleTicket/type/Maintenance> a skos:Concept ; skos:prefLabel "Maintenance"@en .

# Trouble Ticket Criticity (Category)
<kos/TroubleTicket/category/TotalBreakdown> a skos:Concept ; skos:prefLabel "Total Breakdown"@en .
<kos/TroubleTicket/category/IsolatedCustomerSite> a skos:Concept ; skos:prefLabel "Isolated Customer Site"@en .
<kos/TroubleTicket/category/DegradedPerformance> a skos:Concept ; skos:prefLabel "Degraded Performance"@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en .
<kos/TroubleTicket/priority/P3> a skos:Concept ; skos:prefLabel "Priority 3"@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer Origin"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision System Origin"@en .
<kos/TroubleTicket/origin/Internal> a skos:Concept ; skos:prefLabel "Internal Origin"@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; skos:prefLabel "Immediate Intervention"@en .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; skos:prefLabel "Deferred Intervention"@en .

# Trouble Ticket Status
<kos/TroubleTicket/status/Initialised> a skos:Concept ; skos:prefLabel "Initialised"@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved"@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; skos:prefLabel "Closed"@en .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:prefLabel "Customer Comment"@en .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis Operation"@en .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; skos:prefLabel "Tests and Measurements Operation"@en .

# Change Request Category
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; skos:prefLabel "Internal Intervention"@en .
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; skos:prefLabel "Software Upgrade"@en .

# Change Request Type
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:prefLabel "Emergency Change"@en .

# Change Request Cause
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; skos:prefLabel "Configuration Change"@en .
<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ; skos:prefLabel "Preventative Maintenance"@en .

# Change Request Status
<kos/ChangeRequest/status/Planned> a skos:Concept ; skos:prefLabel "Planned"@en .
<kos/ChangeRequest/status/Executed> a skos:Concept ; skos:prefLabel "Executed"@en .
<kos/ChangeRequest/status/Closed> a skos:Concept ; skos:prefLabel "Closed"@en .

# Resource Type
<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server"@en .
<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router"@en .
<kos/Resource/type/Switch> a skos:Concept ; skos:prefLabel "Switch"@en .
<kos/Resource/type/Firewall> a skos:Concept ; skos:prefLabel "Firewall"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine"@en .
<kos/Resource/type/LoadBalancer> a skos:Concept ; skos:prefLabel "Load Balancer"@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:prefLabel "Decommissioned"@en .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; skos:prefLabel "Staging"@en .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Up"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down"@en .
<kos/Resource/OperationalState/Degraded> a skos:Concept ; skos:prefLabel "Degraded"@en .

# Resource Administrative State
<kos/Resource/AdministrativeState/Up> a skos:Concept ; skos:prefLabel "Up"@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; skos:prefLabel "Down"@en .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical Severity"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major Severity"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:prefLabel "Minor Severity"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning Severity"@en .
<Notification/Severity/PerceivedSeverity/Informational> a skos:Concept ; skos:prefLabel "Informational Severity"@en .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone"@en .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; skos:prefLabel "Ticketing System"@en .

# Problem Responsibility
<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ; skos:prefLabel "Network Team Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ; skos:prefLabel "Application Team Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/Vendor> a skos:Concept ; skos:prefLabel "Vendor Responsibility"@en .

# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
noria:Agent_NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Open a P1 ticket for critical network issues."@en .

noria:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email app-support@example.com for non-critical issues."@en .

noria:Agent_DBATeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all database systems."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox "john.doe@example.com" .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox "jane.smith@example.com" .

noria:Agent_AutomatedSystem a foaf:Agent ;
    rdfs:label "Automated Monitoring System"@en ;
    rdfs:comment "System responsible for generating automated alerts and events."@en .

# --- Organizations (org:Organization) ---
noria:Org_ManufacturerA a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Leading manufacturer of networking hardware."@en .

noria:Org_ManufacturerB a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:Org_ManufacturerC a org:Organization ;
    rdfs:label "Oracle Corporation"@en ;
    rdfs:comment "American multinational computer technology corporation."@en .

# --- Product Models (noria:ProductModel) ---
noria:ProductModel_Cisco_ASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "High-performance aggregation services router."@en ;
    noria:productManufacturedBy noria:Org_ManufacturerA .

noria:ProductModel_Dell_PowerEdge_R740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Versatile 2-socket, 2U rack server."@en ;
    noria:productManufacturedBy noria:Org_ManufacturerB .

noria:ProductModel_Juniper_SRX300 a noria:ProductModel ;
    rdfs:label "Juniper SRX300 Series Firewall"@en ;
    rdfs:comment "Secure router and firewall for small to medium-sized distributed enterprises."@en ;
    noria:productManufacturedBy noria:Org_ManufacturerA .

noria:ProductModel_VMware_ESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Type-1 hypervisor for creating and running virtual machines."@en ;
    noria:productManufacturedBy noria:Org_ManufacturerB . # Assuming VMware is part of Dell or closely related for this example

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
noria:Site_DataCenter_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center location in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_Office_Lyon a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoom_A1 a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack_A1_R1 .

noria:Room_NetworkCloset_B2 a noria:Room ;
    rdfs:label "Network Closet B2"@en ;
    rdfs:comment "Network equipment closet in Lyon Office."@en ;
    bot:hasSpace noria:Locus_Rack_B2_R1 .

noria:Locus_Rack_A1_R1 a noria:Locus ;
    rdfs:label "Rack A1-R1"@en ;
    rdfs:comment "First rack in Server Room A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "R1" .

noria:Locus_Rack_B2_R1 a noria:Locus ;
    rdfs:label "Rack B2-R1"@en ;
    rdfs:comment "First rack in Network Closet B2."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "R1" .

# --- Resources (noria:Resource) ---
noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server for customer-facing applications."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "websrv01.example.com" ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge_R740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
