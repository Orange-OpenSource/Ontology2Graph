# --- Network Interfaces (noria:NetworkInterface) ---
# Connection points on resources.

<networkinterface/cr01_ge-0-0-1> a noria:NetworkInterface ;
    rdfs:label "cr01 ge-0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/1 on Core Router 01, connected to internal network."@en ;
