    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

<networkinterface/cr01_ge-0-0-2> a noria:NetworkInterface ;
    rdfs:label "cr01 ge-0/0/2"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/2 on Core Router 01, connected to DMZ firewall."@en ;
    noria:networkInterfaceOf <resource/Router_Core_01> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

<networkinterface/fw01_ge-0-0-1> a noria:NetworkInterface ;
    rdfs:label "fw01 ge-0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/1 on DMZ Firewall 01, connected to core router."@en ;
