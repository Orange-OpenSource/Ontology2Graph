    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkinterface/fw01_ge-0-0-2> a noria:NetworkInterface ;
    rdfs:label "fw01 ge-0/0/2"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/2 on DMZ Firewall 01, connected to external network."@en ;
    noria:networkInterfaceOf <resource/Firewall_DMZ_01> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<networkinterface/web01_eth0> a noria:NetworkInterface ;
    rdfs:label "web01 eth0"@en ;
    rdfs:comment "Ethernet interface 0 on Web Server 01."@en ;
    noria:networkInterfaceOf <resource/Server_Web_01> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
