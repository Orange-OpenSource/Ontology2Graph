    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

# --- Services (noria:Service) ---
# End-to-end services composed of applications and resources.

<service/PublicWebAccess> a noria:Service ;
    rdfs:label "Public Web Access Service"@en ;
    rdfs:comment "Provides external users access to the corporate website and other public web resources."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <applicationmodule/CorporateWebsite_Prod> ;
    seas:subSystemOf <resource/Firewall_DMZ_01> .

<service/InternalDatabaseAccess> a noria:Service ;
    rdfs:label "Internal Database Access Service"@en ;
    rdfs:comment "Provides internal applications and users access to the corporate database."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf <applicationmodule/CorporateDatabase_Prod> ;
    seas:subSystemOf <resource/VirtualMachine_DB_01> .

# --- Event Records (noria:EventRecord) ---
# Logs and alarms generated by systems.

<eventrecord/Log_Router_InterfaceDown> a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Core Router 01."@en ;
    noria:loggingTime "2023-10-26T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Router_Core_01> ;
    noria:logOriginatingManagementSystem <applicationmodule/MonitoringSystem_Instance> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<eventrecord/Log_WebServer_HighCPU> a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2023-10-26T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Server_Web_01> ;
    noria:logOriginatingManagementSystem <applicationmodule/MonitoringSystem_Instance> ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<eventrecord/Log_Firewall_BlockedAttempt> a noria:EventRecord ;
    rdfs:label "Firewall Blocked Attempt Log"@en ;
    rdfs:comment "Log entry showing a blocked connection attempt by DMZ Firewall 01."@en ;
    noria:loggingTime "2023-10-26T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Firewall_DMZ_01> ;
    noria:logOriginatingManagementSystem <applicationmodule/MonitoringSystem_Instance> ;
    noria:logText "Blocked connection from 192.168.5.10 to 10.0.0.10 on port 80."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

<eventrecord/Log_DB_ConnectionError> a noria:EventRecord ;
    rdfs:label "Database Connection Error Log"@en ;
    rdfs:comment "Log entry indicating a connection error to the Corporate Database."@en ;
    noria:loggingTime "2023-10-26T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/VirtualMachine_DB_01> ;
    noria:logOriginatingManagementSystem <applicationmodule/MonitoringSystem_Instance> ;
    noria:logText "Failed to connect to database 'corp_db' from application 'app_frontend'."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

<eventrecord/Log_User_LoginFailure> a noria:EventRecord ;
