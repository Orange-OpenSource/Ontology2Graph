    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# --- Network Links (noria:NetworkLink) ---
# Connections between network interfaces/resources.

<networklink/cr01-fw01_link> a noria:NetworkLink ;
    rdfs:label "Core Router 01 to DMZ Firewall 01 Link"@en ;
    rdfs:comment "Direct link between cr01 ge-0/0/2 and fw01 ge-0/0/1."@en ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> ;
    noria:networkLinkId "NL-CR01-FW01-001" ;
    noria:networkLinkTerminationResource <resource/Router_Core_01>, <resource/Firewall_DMZ_01> ;
    noria:networkLinkInstallationDate "2022-02-20T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkInterfaceConnects <networkinterface/cr01_ge-0-0-2>, <networkinterface/fw01_ge-0-0-1> .

<networklink/fw01-internet_link> a noria:NetworkLink ;
    rdfs:label "DMZ Firewall 01 to Internet Link"@en ;
    rdfs:comment "Uplink from DMZ Firewall 01 to external internet provider."@en ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> ;
    noria:networkLinkId "NL-FW01-INET-001" ;
    noria:networkLinkTerminationResourceOrigin <resource/Firewall_DMZ_01> ;
    noria:networkLinkInstallationDate "2022-02-20T09:45:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 100Gbps" ;
    noria:networkInterfaceConnects <networkinterface/fw01_ge-0-0-2> .

<networklink/cr01-internal_link> a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Internal Network Link"@en ;
    rdfs:comment "Link from Core Router 01 to the internal corporate network segment."@en ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> ;
    noria:networkLinkId "NL-CR01-INT-001" ;
    noria:networkLinkTerminationResource <resource/Router_Core_01> ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 40Gbps" ;
    noria:networkInterfaceConnects <networkinterface/cr01_ge-0-0-1> .

# --- Applications (noria:Application) ---
# Software systems providing business functions.

<application/CorporateWebsite> a noria:Application ;
    rdfs:label "Corporate Website"@en ;
