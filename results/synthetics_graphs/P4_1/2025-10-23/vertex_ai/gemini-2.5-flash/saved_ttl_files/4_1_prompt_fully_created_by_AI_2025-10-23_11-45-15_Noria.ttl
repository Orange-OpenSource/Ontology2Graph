# --- Operation Plans (noria:OperationPlan) ---
# Standardized procedures for IT operations.

<operationplan/RouterOSUpgradeProcedure> a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading Cisco router operating systems."@en ;
    skos:example "Steps include backup configuration, download image, install image, reboot, verify."@en ;
    noria:operationPlanPreCondition <actionprecondition/RouterReadyForUpgrade> ;
    noria:operationPlanPostCondition <actionpostcondition/RouterOSUpgradeVerified> .

<operationplan/WebServerTroubleshootingGuide> a noria:OperationPlan ;
    rdfs:label "Web Server High CPU Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving high CPU issues on web servers."@en ;
    skos:example "Check running processes, analyze logs, restart services, scale resources."@en ;
    noria:operationPlanPreCondition <actionprecondition/HighCPUDetected> ;
    noria:operationPlanPostCondition <actionpostcondition/CPUUtilizationNormal> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
# Conditions for executing and verifying operation plans.

<actionprecondition/RouterReadyForUpgrade> a noria:ActionPreCondition ;
    rdfs:label "Router Ready for Upgrade"@en ;
    rdfs:comment "Condition: Router is in a stable state, configuration backed up, and maintenance window approved."@en .

<actionpostcondition/RouterOSUpgradeVerified> a noria:ActionPostCondition ;
    rdfs:label "Router OS Upgrade Verified"@en ;
    rdfs:comment "Outcome: New OS version confirmed, all interfaces up, routing protocols converged, and services restored."@en .

<actionprecondition/HighCPUDetected> a noria:ActionPreCondition ;
    rdfs:label "High CPU Detected"@en ;
    rdfs:comment "Condition: CPU utilization exceeds threshold for a sustained period."@en .

<actionpostcondition/CPUUtilizationNormal> a noria:ActionPostCondition ;
    rdfs:label "CPU Utilization Normal"@en ;
    rdfs:comment "Outcome: CPU utilization returned to normal levels, application performance restored."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
# Files attached to tickets or change requests.

<documentattachment/CR-20231101-001-Plan> a noria:DocumentAttachment ;
    rdfs:label "Router OS Upgrade Plan Document"@en ;
    rdfs:comment "Detailed plan for the Core Router OS upgrade, including rollback procedures."@en ;
    dcterms:isPartOf <changerequest/CR-20231101-001> ;
    dcterms:format "application/pdf" ;
    dcterms:title "CR-20231101-001_UpgradePlan.pdf" .

<documentattachment/TT-20231026-001-Screenshot> a noria:DocumentAttachment ;
    rdfs:label "Screenshot of Interface Status"@en ;
    rdfs:comment "Screenshot showing the 'down' status of ge-0/0/1 on Core Router 01."@en ;
    dcterms:isPartOf <troubleticket/TT-20231026-001> ;
    dcterms:format "image/png" ;
    dcterms:title "TT-20231026-001_InterfaceDown.png" .

# --- Additional connections for density ---

# Link applications to resources they use
<resource/Server_Web_01> noria:resourceForApplication <application/CorporateWebsite> .
<resource/VirtualMachine_DB_01> noria:resourceForApplication <application/CorporateDatabase> .
<resource/Router_Core_01> noria:resourceForApplication <application/MonitoringSystem> .
<resource/Firewall_DMZ_01> noria:resourceForApplication <application/MonitoringSystem> .

# Link agents to resources they manage (inverse of resourceManagedBy)
<agent/Team_NetworkOperations> noria:agentManagesResource <resource/Router_Core_01> .
<agent/Team_ApplicationSupport> noria:agentManagesResource <resource/Server_Web_01> .
<agent/Team_SecurityOperations> noria:agentManagesResource <resource/Firewall_DMZ_01> .
<agent/Team_DatabaseAdmin> noria:agentManagesResource <resource/VirtualMachine_DB_01> .

# Document status history for a trouble ticket
<troubleticket/TT-20231026-001> noria:documentStatusHistory <eventrecord/TT_Status_InProgress> .

<eventrecord/TT_Status_InProgress> a noria:EventRecord ;
    rdfs:label "TT-20231026-001 Status Change to InProgress"@en ;
    rdfs:comment "Status change event for Trouble Ticket TT-20231026-001."@en ;
    noria:loggingTime "2023-10-26T10:12:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <application/TicketingSystem> ;
    noria:logText "Trouble Ticket TT-20231026-001 status changed to InProgress."@en ;
    dcterms:references <troubleticket/TT-20231026-001> .

# Example of a trouble ticket impacting multiple resources/services
<troubleticket/TT-20231026-001> noria:troubleTicketImpacts <service/PublicWebAccess> ;
    noria:troubleTicketImpacts <resource/Router_Core_01> .

# Example of a change request impacting multiple resources/services
<changerequest/CR-20231101-001> noria:changeRequestImpact <service/PublicWebAccess> .

# Example of alarm proposed repair action
<eventrecord/Log_Router_InterfaceDown> noria:alarmProposedRepairAction <operationplan/TroubleshootNetworkInterface> .

<operationplan/TroubleshootNetworkInterface> a noria:OperationPlan ;
    rdfs:label "Troubleshoot Network Interface Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues with network interfaces."@en ;
    skos:example "Check cable, replace SFP, verify configuration, check peer status."@en .

# Example of alarm mitigated by a procedure execution
<eventrecord/Log_Router_InterfaceDown> noria:alarmMitigatedBy <pep/ProcedureExecutionContainer_TT-20231026-001_Resolution> .

<pep/ProcedureExecutionContainer_TT-20231026-001_Resolution> a pep:ProcedureExecutionContainer ;
    rdfs:label "Resolution Actions for TT-20231026-001"@en ;
    rdfs:comment "Container for all actions taken to resolve TT-20231026-001."@en ;
    dcterms:references <troubleticket/TT-20231026-001> ;
    # This container would typically have ldp:member relations to individual pep:ProcedureExecution instances
    # but since ldp is forbidden, we just link the container.
    .

# Example of a resource having a virtual server status
<resource/VirtualMachine_DB_01> noria:virtualServerStatus <kos/Resource/OperationalState/Running> .

# Example of network interface optical power metrics
<networkinterface/cr01_ge-0-0-1> noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Example of a trouble ticket freeze item
<troubleticket/TT-20231026-001> noria:troubleTicketFreezeItem <eventrecord/TT_Freeze_Start> .

<eventrecord/TT_Freeze_Start> a noria:EventRecord ;
    rdfs:label "TT-20231026-001 Freeze Start"@en ;
    rdfs:comment "Trouble Ticket TT-20231026-001 entered a frozen state due to external dependency."@en ;
    noria:loggingTime "2023-10-26T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <application/TicketingSystem> ;
    noria:logText "Ticket frozen awaiting vendor response."@en ;
    dcterms:references <troubleticket/TT-20231026-001> .

# Example of a change request specification
<changerequest/CR-20231101-001> noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardOSUpgrade> .

# Example of a change request actual start/end times
<changerequest/CR-20231101-001> noria:changeRequestActualStartTime "2023-11-01T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2023-11-01T03:55:00Z"^^xsd:dateTime .

# Example of a trouble ticket with problem responsibility
<troubleticket/TT-20231026-001> noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> .

# Example of a trouble ticket with criticity
<troubleticket/TT-20231026-001> noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> .

# Example of a trouble ticket with external ID
<troubleticket/TT-20231026-001> noria:documentExternalId "CUST-INC-98765" .

# Example of a trouble ticket with notification enabled
<troubleticket/TT-20231026-001> noria:troubleTicketIsNotificationEnable true .

# Example of a trouble ticket with target/planned/committed restoration dates
<troubleticket/TT-20231026-001> noria:troubleTicketTargetRestorationDateTime "2023-10-26T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2023-10-26T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2023-10-26T13:00:00Z"^^xsd:dateTime .

# Example of a network interface description
<networkinterface/cr01_ge-0-0-1> noria:networkInterfaceDescription "Uplink to internal distribution switch."@en .

# Example of a network link termination resource origin/destination for a unidirectional link
# (though the example link is bidirectional, demonstrating the properties)
<networklink/fw01-internet_link> noria:networkLinkTerminationResourceOrigin <resource/Firewall_DMZ_01> ;
    noria:networkLinkTerminationResourceDestination <resource/InternetProviderRouter> .

<resource/InternetProviderRouter> a noria:Resource ;
    rdfs:label "Internet Provider Router"@en ;
    rdfs:comment "Router managed by the internet service provider."@en ;
    noria:resourceType <kos/Resource/type/Router> .

# End of generated graph
