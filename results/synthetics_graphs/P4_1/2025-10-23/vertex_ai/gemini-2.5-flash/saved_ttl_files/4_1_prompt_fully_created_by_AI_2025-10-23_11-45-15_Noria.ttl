@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix devopsprod: <http://w3id.org/devops-infra/product#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent and org:OrganizationalUnit) ---
# Individuals and Teams responsible for managing resources, applications, and handling incidents.

<agent/Team_NetworkOperations> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for the day-to-day operation and maintenance of the network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. For non-critical, open a ticket."@en .

<agent/Team_ApplicationSupport> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All application-related issues must be reported via the ticketing system."@en .

<agent/Team_SecurityOperations> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate notification required for any suspected security breach."@en .

<agent/Team_DatabaseAdmin> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing and maintaining all corporate databases."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<agent/Person_AliceSmith> a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" .

<agent/Person_BobJohnson> a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> .

<agent/Person_CharlieBrown> a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> .

<agent/Person_DianaPrince> a foaf:Agent ;
    rdfs:label "Diana Prince"@en ;
    rdfs:comment "Database Administrator."@en ;
    foaf:mbox <mailto:diana.prince@example.com> .

<agent/CorporateUser_ASmith> a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount <agent/Person_AliceSmith> .

# --- Product Models (noria:ProductModel) ---
# Definitions of hardware/software product models.

<productmodel/Cisco_Catalyst_9300> a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300 Series Switch"@en ;
    rdfs:comment "High-performance enterprise access switch."@en ;
    noria:productManufacturedBy <org/CiscoSystems> .

<productmodel/Dell_PowerEdge_R750> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750 Server"@en ;
    rdfs:comment "General-purpose rack server for demanding workloads."@en ;
    noria:productManufacturedBy <org/DellTechnologies> .

<productmodel/Juniper_SRX3400> a noria:ProductModel ;
    rdfs:label "Juniper SRX3400 Services Gateway"@en ;
    rdfs:comment "Modular security services gateway for enterprise data centers."@en ;
    noria:productManufacturedBy <org/JuniperNetworks> .

<productmodel/VMware_ESXi> a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor for virtualized environments."@en ;
    noria:productManufacturedBy <org/VMware> .

<org/CiscoSystems> a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Multinational technology conglomerate that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

<org/DellTechnologies> a org:Organization ;
    rdfs:label "Dell Technologies Inc."@en ;
    rdfs:comment "American multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

<org/JuniperNetworks> a org:Organization ;
    rdfs:label "Juniper Networks Inc."@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en .

<org/VMware> a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
# Physical locations for resources.

<site/DataCenter_Paris> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

<room/ServerRoom_A1> a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace <site/DataCenter_Paris> .

<locus/Rack_A1_R01> a noria:Locus ;
    rdfs:label "Rack A1-R01"@en ;
    rdfs:comment "First rack in Server Room A1."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "01" ;
    bot:hasSpace <room/ServerRoom_A1> .

<site/Office_London> a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:comment "Main office building in London."@en ;
    noria:siteId "OFF-LDN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Baker Street" ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressCountry "UK" .

<room/CommsRoom_B2> a noria:Room ;
    rdfs:label "Communications Room B2"@en ;
    rdfs:comment "Network equipment room in London Office."@en ;
    bot:hasSpace <site/Office_London> .

<locus/Rack_B2_R05> a noria:Locus ;
    rdfs:label "Rack B2-R05"@en ;
    rdfs:comment "Fifth rack in Communications Room B2."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "05" ;
    bot:hasSpace <room/CommsRoom_B2> .

# --- Resources (noria:Resource) ---
# Physical and virtual IT assets.

<resource/Router_Core_01> a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router for the corporate network."@en ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceProductModel <productmodel/Cisco_Catalyst_9300> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "ABC12345DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/Rack_A1_R01> ;
    noria:resourceManagementIPAddress <observable/IPAddress_10.0.0.1> .

<resource/Server_Web_01> a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Server hosting the main corporate website."@en ;
    noria:resourceManagedBy <agent/Team_ApplicationSupport> ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel <productmodel/Dell_PowerEdge_R750> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "GHI67890JKL" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/Rack_A1_R01> ;
    noria:resourceManagementIPAddress <observable/IPAddress_10.0.0.10> .

<resource/Firewall_DMZ_01> a noria:Resource ;
    rdfs:label "DMZ Firewall 01"@en ;
    rdfs:comment "Firewall protecting the DMZ network segment."@en ;
    noria:resourceManagedBy <agent/Team_SecurityOperations> ;
    noria:resourceHostName "fw01.dmz.example.com" ;
    noria:resourceProductModel <productmodel/Juniper_SRX3400> ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "MNO12345PQR" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/Rack_A1_R01> ;
    noria:resourceManagementIPAddress <observable/IPAddress_10.0.0.20> .

<resource/VirtualMachine_DB_01> a noria:Resource ;
    rdfs:label "Database VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate database."@en ;
    noria:resourceManagedBy <agent/Team_DatabaseAdmin> ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel <productmodel/VMware_ESXi> ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-DB-01-UUID" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-04-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <application/CorporateDatabase> ;
    noria:clusterController <resource/Hypervisor_Host_01> ;
    noria:resourceManagementIPAddress <observable/IPAddress_10.0.0.30> .

<resource/Hypervisor_Host_01> a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines."@en ;
    noria:resourceManagedBy <agent/Team_ApplicationSupport> ;
    noria:resourceHostName "hv01.corp.example.com" ;
    noria:resourceProductModel <productmodel/Dell_PowerEdge_R750> ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
    noria:resourceSerialNumber "STU98765VWX" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/Rack_A1_R01> ;
    noria:resourceManagementIPAddress <observable/IPAddress_10.0.0.40> .

