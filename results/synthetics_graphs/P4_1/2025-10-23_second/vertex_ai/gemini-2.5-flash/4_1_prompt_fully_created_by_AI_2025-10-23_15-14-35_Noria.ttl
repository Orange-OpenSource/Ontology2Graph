    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.50> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface1 a noria:NetworkInterface ;
    rdfs:label "eth0 on DNS Server 01"@en ;
    rdfs:comment "Ethernet interface for DNS server connectivity."@en ;
    noria:networkInterfaceOf noria:Resource1 ;
    noria:networkInterfaceDescription "Primary network interface for DNS services."@en ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface2 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/0 on Core Router 01"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to the internal network."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceDescription "Internal LAN uplink."@en ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface3 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/1 on Core Router 01"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to the firewall."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceDescription "Uplink to perimeter firewall."@en ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

noria:NetworkInterface4 a noria:NetworkInterface ;
    rdfs:label "vnic0 on WebApp01 VM"@en ;
    rdfs:comment "Virtual network interface for WebApp01."@en ;
    noria:networkInterfaceOf noria:Resource3 ;
    noria:networkInterfaceDescription "VMware virtual NIC for web application."@en ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface5 a noria:NetworkInterface ;
    rdfs:label "eth1 on DB Server 01"@en ;
    rdfs:comment "Ethernet interface for database server connectivity."@en ;
    noria:networkInterfaceOf noria:Resource4 ;
    noria:networkInterfaceDescription "Dedicated network interface for database traffic."@en ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface6 a noria:NetworkInterface ;
    rdfs:label "intf0 on Firewall FW01"@en ;
    rdfs:comment "External interface of the perimeter firewall."@en ;
    noria:networkInterfaceOf noria:Resource5 ;
    noria:networkInterfaceDescription "WAN facing interface."@en ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -8 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -6 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -15 .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink1 a noria:NetworkLink ;
    rdfs:label "DNS-Router Link"@en ;
    rdfs:comment "Link between DNS Server 01 and Core Router 01."@en ;
    noria:networkLinkId "LINK-DNS-RTR-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource2 ;
    noria:networkInterfaceConnects noria:NetworkInterface1, noria:NetworkInterface2 ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:resourceManagedBy foaf:Agent2 .

noria:NetworkLink2 a noria:NetworkLink ;
    rdfs:label "Router-Firewall Link"@en ;
    rdfs:comment "Link between Core Router 01 and Firewall FW01."@en ;
    noria:networkLinkId "LINK-RTR-FW-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource2 ;
    noria:networkLinkTerminationResourceDestination noria:Resource5 ;
    noria:networkInterfaceConnects noria:NetworkInterface3, noria:NetworkInterface6 ;
    noria:networkLinkInstallationDate "2021-08-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 10Gbps" ;
    noria:resourceManagedBy foaf:Agent2 .

noria:NetworkLink3 a noria:NetworkLink ;
    rdfs:label "VM-DB Link"@en ;
    rdfs:comment "Logical link between WebApp01 VM and DB Server 01."@en ;
    noria:networkLinkId "LINK-VM-DB-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource3 ;
    noria:networkLinkTerminationResourceDestination noria:Resource4 ;
    noria:networkInterfaceConnects noria:NetworkInterface4, noria:NetworkInterface5 ;
    noria:networkLinkInstallationDate "2023-05-01T08:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:resourceManagedBy foaf:Agent3 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application1 a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet access for all corporate users."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Gateway Management" ;
    noria:elementManagedBy org:OrganizationalUnit1 .

noria:Application2 a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationModelIdentifier "CUST-PORTAL" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CPORTAL" ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Self-Service Portal" ;
    noria:elementManagedBy org:OrganizationalUnit2 .

noria:Application3 a noria:Application ;
    rdfs:label "Internal CRM"@en ;
    rdfs:comment "Customer Relationship Management system for internal sales and support teams."@en ;
    noria:applicationType <kos/application/type/internal-business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "INT-CRM" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "ICRM" ;
    noria:applicationFunctionalDomain "Sales and Marketing" ;
    noria:applicationFunctionalSubDomain "Customer Data Management" ;
    noria:elementManagedBy org:OrganizationalUnit2 .

noria:Application4 a noria:Application ;
    rdfs:label "Monitoring Platform"@en ;
    rdfs:comment "Centralized platform for collecting and analyzing metrics and logs."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "MON-PLAT" ;
    noria:applicationNumericalIdentifier 1004 ;
    noria:applicationShortIdentifier "MONITOR" ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance and Availability Monitoring" ;
    noria:elementManagedBy foaf:Agent2 .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

noria:ApplicationModule1 a noria:ApplicationModule ;
    rdfs:label "Corporate Internet Access Module 1"@en ;
    rdfs:comment "Production instance of the Corporate Internet Access application."@en ;
    noria:applicationModuleOf noria:Application1 ;
    noria:applicationModuleName "CIA-PROD-01" ;
    noria:applicationModuleIdentifier "PROD-01" ;
    noria:applicationModuleAdministrationTeam org:OrganizationalUnit1 ;
    noria:applicationModuleAdministrationLeader foaf:Person1 ;
    noria:applicationModuleSupportTeam foaf:Agent2 ;
