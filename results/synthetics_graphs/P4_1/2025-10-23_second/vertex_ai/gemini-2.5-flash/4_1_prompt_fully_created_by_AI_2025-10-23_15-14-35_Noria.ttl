    noria:resourceLogisticId "ASSET-FW-001" ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.30> .

noria:Resource6 a noria:Resource ;
    rdfs:label "Load Balancer LB01"@en ;
    rdfs:comment "Load balancer for distributing traffic to web application servers."@en ;
    noria:resourceManagedBy foaf:Agent3 ;
    noria:resourceHostName "lb01.customer.example.com" ;
    noria:resourceProductModel <https://example.com/product/F5BigIP> ;
    noria:resourceLogisticId "ASSET-LB-001" ;
