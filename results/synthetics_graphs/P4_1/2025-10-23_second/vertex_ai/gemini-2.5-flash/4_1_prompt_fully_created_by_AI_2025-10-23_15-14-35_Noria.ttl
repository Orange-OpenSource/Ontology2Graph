    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.40> .

noria:Resource8 a noria:Resource ;
    rdfs:label "Backup Storage Unit BSU01"@en ;
    rdfs:comment "Network Attached Storage (NAS) for backups."@en ;
    noria:resourceManagedBy foaf:Agent5 ;
    noria:resourceHostName "bsu01.corp.example.com" ;
    noria:resourceProductModel <https://example.com/product/NetAppFAS> ;
    noria:resourceLogisticId "ASSET-BSU-001" ;
    noria:resourceType <kos/Resource/type/Storage> ;
    noria:resourceSerialNumber "SN-BSU-001-MNO" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-10T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application3 ; # Backs up CRM data
