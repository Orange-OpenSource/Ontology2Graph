noria:Resource7 a noria:Resource ;
    rdfs:label "Monitoring Server MON01"@en ;
    rdfs:comment "Server hosting the central monitoring system."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "mon01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-MON-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-MON-001-JKL" ;
