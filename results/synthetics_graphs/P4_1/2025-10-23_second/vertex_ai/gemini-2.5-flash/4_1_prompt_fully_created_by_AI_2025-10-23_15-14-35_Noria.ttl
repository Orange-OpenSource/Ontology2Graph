    noria:changeRequestSpecification <kos/ChangeRequest/specification/FirewallPolicyUpdate> ;
    noria:changeRequestInitiatorParty foaf:Person3 ;
    noria:changeRequestPilotParty foaf:Person3 ;
    noria:changeRequestActorParty foaf:Person3 ;
