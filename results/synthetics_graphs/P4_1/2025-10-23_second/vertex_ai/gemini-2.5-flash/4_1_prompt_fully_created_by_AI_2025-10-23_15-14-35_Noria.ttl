@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix time: <http://www.w3.org/2006/time#> .

# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use hotline + ticketing system."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "All network-related alerts are routed here. Escalate to L2 Network Engineers if needed."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2/L3 support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Open a ticket via the internal portal for all application issues."@en .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SecureChat> ;
    noria:agentInstructions "Report all security incidents immediately via dedicated secure channel."@en .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "Database Admin Team"@en ;
    rdfs:comment "Team managing and maintaining all corporate databases."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For database performance issues, provide SQL query logs."@en .

foaf:Person1 a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior Network Engineer, member of NOC L2."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Person2 a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Lead for Customer Portal."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+33987654321" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Person3 a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Brown"@en ;
    rdfs:comment "Security Analyst in the SOC."@en ;
    foaf:mbox <mailto:alice.brown@example.com> ;
    foaf:phone "+33611223344" ;
    noria:agentWorkingHours "24/7 (on-call rotation)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SecureChat> .

org:OrganizationalUnit1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Infrastructure Department"@en ;
    rdfs:comment "Department overseeing all IT infrastructure, including network, servers, and storage."@en ;
    org:hasMember foaf:Person1 .

org:OrganizationalUnit2 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Software Development Department"@en ;
    rdfs:comment "Department responsible for developing and maintaining internal and external applications."@en ;
    org:hasMember foaf:Person2 .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel1 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for DNS and other critical services."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel2 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Cisco enterprise-grade network switch."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel3 a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for hosting virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com> .

noria:ProductModel4 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Juniper universal routing platform for edge and core networks."@en ;
    noria:productManufacturedBy <https://www.juniper.net> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site1 a bot:Site ;
    rdfs:label "Main Data Center Paris"@en ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room1 a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus1, noria:Locus3 ;
    seas:subSystemOf bot:Site1 .

noria:Room2 a noria:Room ;
    rdfs:label "Network Equipment Room B"@en ;
    rdfs:comment "Dedicated room for network devices in the Paris Data Center."@en ;
    bot:hasSpace noria:Locus2 ;
    seas:subSystemOf bot:Site1 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Location of critical servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    seas:subSystemOf noria:Room1 .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack B5 in Network Equipment Room B"@en ;
    rdfs:comment "Location of core network routers."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    seas:subSystemOf noria:Room2 .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack C2 in Server Room A"@en ;
    rdfs:comment "Location of database servers."@en ;
    noria:locusLine "C" ;
    noria:locusRow "2" ;
    seas:subSystemOf noria:Room1 .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource1 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted on Dell PowerEdge R740."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> .

noria:Resource2 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network, Juniper MX204."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "router01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel4 ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.20> .

noria:Resource3 a noria:Resource ;
    rdfs:label "Virtual Machine WebApp01"@en ;
    rdfs:comment "Virtual machine hosting the Customer Portal frontend."@en ;
    noria:resourceManagedBy foaf:Agent3 ;
    noria:resourceHostName "webapp01.customer.example.com" ;
    noria:resourceProductModel noria:ProductModel3 ; # Represents the underlying ESXi host
    noria:resourceLogisticId "ASSET-VM-001" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-UUID-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application2 ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.10> ;
    noria:clusterController noria:Resource7 . # Assuming MON01 is also a vCenter or similar

noria:Resource4 a noria:Resource ;
    rdfs:label "Database Server DB01"@en ;
    rdfs:comment "Physical server hosting the main customer database."@en ;
    noria:resourceManagedBy foaf:Agent5 ;
    noria:resourceHostName "db01.customer.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB-001-PQR" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application2 ;
    noria:locatedAtLocus noria:Locus3 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.20> .

noria:Resource5 a noria:Resource ;
    rdfs:label "Firewall FW01"@en ;
    rdfs:comment "Perimeter firewall protecting the corporate network."@en ;
    noria:resourceManagedBy foaf:Agent4 ;
    noria:resourceHostName "fw01.corp.example.com" ;
