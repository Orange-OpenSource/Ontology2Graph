noria:TroubleTicketNote2 a noria:TroubleTicketNote ;
    rdfs:label "Customer Portal DB Check"@en ;
    rdfs:comment "Checked database server DB01. Found high CPU usage and many blocked queries. Suspect inefficient queries from application backend. Notifying application team."@en ;
