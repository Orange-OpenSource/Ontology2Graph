noria:ChangeRequest2 a noria:ChangeRequest ;
    rdfs:label "DB Server OS Upgrade"@en ;
    rdfs:comment "Upgrade operating system on DB Server DB01 to enhance security and performance."@en ;
    dcterms:identifier "CR-20240423-002" ;
    dcterms:created "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T16:00:00Z"^^xsd:dateTime ;
