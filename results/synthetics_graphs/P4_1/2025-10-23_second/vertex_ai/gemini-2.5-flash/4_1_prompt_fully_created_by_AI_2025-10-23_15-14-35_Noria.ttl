    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:ApplicationModule3 a noria:ApplicationModule ;
    rdfs:label "Customer Portal Backend Prod"@en ;
    rdfs:comment "Production backend module for the Customer Portal."@en ;
    noria:applicationModuleOf noria:Application2 ;
    noria:applicationModuleName "CPORTAL-BE-PROD" ;
