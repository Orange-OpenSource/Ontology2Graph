# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Firewall Policy Deployment Guide"@en ;
    rdfs:comment "Guide for deploying new or updated firewall policies."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Status Check"@en ;
    rdfs:comment "Verify current status of 'named' service on DNS server. Ensure no critical dependencies are active."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Reachable"@en ;
    rdfs:comment "Confirm DNS service is running and resolving queries correctly from internal and external clients."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Firewall Config Backup"@en ;
    rdfs:comment "Ensure a recent backup of the firewall configuration is available before making changes."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Firewall Policy Active"@en ;
    rdfs:comment "Verify the new firewall policy is active and traffic flows as expected without unintended side effects."@en .

# =============================================================================
# Additional Connections for Density
# =============================================================================

# Connect Agents to Resources they manage (inverse of resourceManagedBy)
foaf:Agent1 noria:agentManagesResource noria:Resource1 .
foaf:Agent2 noria:agentManagesResource noria:Resource2, noria:Resource7 .
foaf:Agent3 noria:agentManagesResource noria:Resource3, noria:Resource6 .
foaf:Agent4 noria:agentManagesResource noria:Resource5 .
foaf:Agent5 noria:agentManagesResource noria:Resource4, noria:Resource8 .

# Connect Applications to Resources that support them
noria:Application1 seas:hasSubSystem noria:Resource1, noria:Resource2, noria:Resource5 .
noria:Application2 seas:hasSubSystem noria:Resource3, noria:Resource4, noria:Resource6 .
noria:Application3 seas:hasSubSystem noria:Resource4, noria:Resource8 .
noria:Application4 seas:hasSubSystem noria:Resource7 .

# Connect Application Modules to Resources
noria:ApplicationModule1 seas:hasSubSystem noria:Resource1 .
noria:ApplicationModule2 seas:hasSubSystem noria:Resource3, noria:Resource6 .
noria:ApplicationModule3 seas:hasSubSystem noria:Resource4 .
noria:ApplicationModule4 seas:hasSubSystem noria:Resource4, noria:Resource8 .
noria:ApplicationModule5 seas:hasSubSystem noria:Resource7 .

# Connect Services to Applications/ApplicationModules (inverse of seas:subSystemOf)
noria:Application1 seas:isSubSystemOf noria:Service1 .
noria:ApplicationModule1 seas:isSubSystemOf noria:Service1 .
noria:Application2 seas:isSubSystemOf noria:Service2 .
noria:ApplicationModule2 seas:isSubSystemOf noria:Service2 .
noria:ApplicationModule3 seas:isSubSystemOf noria:Service2 .
noria:Application3 seas:isSubSystemOf noria:Service3 .
noria:ApplicationModule4 seas:isSubSystemOf noria:Service3 .

# Connect TroubleTickets to impacted entities
noria:TroubleTicket1 noria:troubleTicketImpacts noria:Resource1, noria:Application1, noria:Service1 .
noria:TroubleTicket2 noria:troubleTicketImpacts noria:Resource3, noria:Resource4, noria:Application2, noria:Service2 .
noria:TroubleTicket3 noria:troubleTicketImpacts noria:Resource2, noria:NetworkInterface3, noria:NetworkLink2, noria:Service1 .

# Connect ChangeRequests to impacted entities
noria:ChangeRequest1 noria:changeRequestImpact noria:Resource5, noria:Application1 .
noria:ChangeRequest2 noria:changeRequestImpact noria:Resource4, noria:Application2, noria:ApplicationModule3 .

# Connect EventRecords to related parties (inverse of logOriginatingAgent)
foaf:Person3 prov:actedOnBehalfOf noria:EventRecord4 . # Example of using prov:actedOnBehalfOf for logOriginatingAgent

# Connect Operation Plans to Change Requests (as a procedure used)
noria:ChangeRequest1 pep:usedProcedure noria:OperationPlan2 .
noria:ChangeRequest2 pep:usedProcedure noria:OperationPlan1 . # Hypothetically, if OS upgrade involves a restart procedure.

# Connect Event Records to Trouble Tickets (as correlated notifications)
noria:TroubleTicket1 dcterms:relation noria:EventRecord1, noria:EventRecord2 .
noria:TroubleTicket2 dcterms:relation noria:EventRecord3 .

# Connect Trouble Ticket Notes to Event Records (as correlated notifications)
noria:TroubleTicketNote1 dcterms:relation noria:EventRecord1 .
noria:TroubleTicketNote2 dcterms:relation noria:EventRecord3 .

# Connect Agents to Organizational Units
org:OrganizationalUnit1 org:hasMember foaf:Person1 .
org:OrganizationalUnit2 org:hasMember foaf:Person2 .
foaf:Person1 org:memberOf org:OrganizationalUnit1 .
foaf:Person2 org:memberOf org:OrganizationalUnit2 .
foaf:Person3 org:memberOf foaf:Agent4 . # SOC is a team, so Person3 is a member of Agent4

# Connect CorporateUserIdentifier
<https://example.com/cuid/johndoe> a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    foaf:holdsAccount foaf:Person1 .

<https://example.com/cuid/janesmith> a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    observable:accountLogin "jsmith" ;
    foaf:holdsAccount foaf:Person2 .

