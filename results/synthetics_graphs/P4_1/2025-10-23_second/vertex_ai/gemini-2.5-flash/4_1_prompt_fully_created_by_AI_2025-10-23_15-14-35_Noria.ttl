# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Service Down Alert"@en ;
    rdfs:comment "Alert: DNS service 'named' on dns01.corp.example.com is down."@en ;
    dcterms:identifier "EVT-20240423-001" ;
    noria:loggingTime "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "Service 'named' on host 'dns01.corp.example.com' is in CRITICAL state."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan1 ;
    pep:hasExecutionResult "Service down" .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "Log entry: Interface ge-0/0/1 on router01.corp.example.com changed state to down."@en ;
    dcterms:identifier "EVT-20240423-002" ;
    noria:loggingTime "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    pep:hasExecutionResult "Interface down" .

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "DB High CPU Usage Alert"@en ;
    rdfs:comment "Alert: High CPU utilization (95%) on db01.customer.example.com."@en ;
    dcterms:identifier "EVT-20240423-003" ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource4 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "CPU usage on db01 exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    pep:hasExecutionResult "High CPU" .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Firewall Policy Change Log"@en ;
    rdfs:comment "Log entry: Firewall policy updated by Alice Brown."@en ;
    dcterms:identifier "EVT-20240423-004" ;
    noria:loggingTime "2024-04-23T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource5 ;
    noria:logOriginatingManagementSystem <https://example.com/management/firewall-manager> ;
    noria:logOriginatingAgent foaf:Person3 ;
    noria:logText "Policy 'WebAccess' updated to allow new IP range 192.168.1.0/24."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    pep:hasExecutionResult "Policy updated" .

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "Application Module Restart Log"@en ;
    rdfs:comment "Log entry: Customer Portal Frontend module restarted successfully."@en ;
    dcterms:identifier "EVT-20240423-005" ;
    noria:loggingTime "2024-04-23T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ApplicationModule2 ;
    noria:logOriginatingManagementSystem <https://example.com/management/app-orchestrator> ;
    noria:logText "Application module CPORTAL-FE-PROD restarted by automated system."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    pep:hasExecutionResult "Module restarted" .

