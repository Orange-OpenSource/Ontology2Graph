    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int .

noria:NetworkInterface_RouterCore01_Ge0_0_1
    noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-4"^^xsd:int .

noria:NetworkInterface_Firewall01_Ext
    noria:networkInterfaceLaserTxOpticalPower "-1"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "0"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

noria:Resource_DNS01
    noria:elementDistinguishedName "dns01.corp.example.com" .

noria:Application_CorpDNS
    noria:functionalElementDistinguishedName "CDNS" .

noria:ApplicationModule_CorpDNS_Prod
    noria:functionalElementDistinguishedName "CORP-DNS_PROD" .

