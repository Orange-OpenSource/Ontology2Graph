# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_DNS_Core
    a noria:NetworkLink ;
    rdfs:label "Link between DNS01 and RouterCore01"@en ;
    rdfs:comment "Internal network link connecting the DNS server to the core router."@en ;
    noria:networkLinkId "NL-DNS-CORE-001" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore01 .

noria:NetworkLink_Web_DB
    a noria:NetworkLink ;
    rdfs:label "Link between WebSrv01 and DBServer01"@en ;
    rdfs:comment "Internal network link for application-database communication."@en ;
    noria:networkLinkId "NL-WEB-DB-001" ;
    noria:networkLinkType "Virtual Ethernet 1Gbps" ;
    noria:networkLinkInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DBServer01 .

noria:NetworkLink_Firewall_Internet
