# Add a site for the rooms
<noria/Site_CorporateHQ>
    a bot:Site ;
    rdfs:label "Corporate Headquarters Site"@en ;
    rdfs:comment "Main corporate campus housing server rooms and offices."@en ;
    noria:siteId "HQ-SITE-001" ;
    noria:siteType "building" ;
    noria:sitePrincipalAddress "123 Main Street"@en ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCityName "New York" ;
    noria:sitePrincipalAddressCountry "US" ;
    bot:hasSpace noria:Room_ServerRoom314 .

<noria/Site_DataCenterA>
    a bot:Site ;
    rdfs:label "Primary Data Center Site A"@en ;
    rdfs:comment "Dedicated facility for core IT infrastructure."@en ;
    noria:siteId "DC-SITE-001" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Tech Avenue"@en ;
    noria:sitePrincipalAddressPostalCode "90210" ;
    noria:sitePrincipalAddressCityName "Los Angeles" ;
    noria:sitePrincipalAddressCountry "US" ;
    bot:hasSpace noria:Room_DataCenterA .

# Connect the sites to geographical coordinates (using wgs84_pos)
<noria/Site_CorporateHQ>
    wgs84_pos:lat "40.7128"^^xsd:float ;
    wgs84_pos:long "-74.0060"^^xsd:float .

<noria/Site_DataCenterA>
    wgs84_pos:lat "34.0522"^^xsd:float ;
    wgs84_pos:long "-118.2437"^^xsd:float .

# Add a DocumentAttachment example
<noria/DocumentAttachment_DNSDiagReport>
    a noria:DocumentAttachment ;
    rdfs:label "DNS Server Diagnostic Report"@en ;
    rdfs:comment "PDF report containing detailed diagnostics of the DNS server failure."@en ;
    dcterms:created "2024-04-20T09:35:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage ;
    dcterms:format "application/pdf" ;
    dcterms:source <http://itsm.example.com/attachments/TT-20240420-001/DNSDiagReport.pdf> .

<noria/DocumentAttachment_RouterUpgradePlan>
    a noria:DocumentAttachment ;
    rdfs:label "Router Firmware Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the core router firmware upgrade, including rollback procedures."@en ;
    dcterms:created "2024-04-17T16:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:source <http://itsm.example.com/attachments/CR-20240501-001/RouterUpgradePlan.docx> .
