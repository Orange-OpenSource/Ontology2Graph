    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for WebSrv01 virtual machine."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_Web_DB .

noria:NetworkInterface_DBServer01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DBServer01 physical server."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
