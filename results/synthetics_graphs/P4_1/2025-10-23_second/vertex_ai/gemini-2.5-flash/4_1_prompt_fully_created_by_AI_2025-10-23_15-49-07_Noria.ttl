# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_DNSFailover
    a noria:OperationPlan ;
    rdfs:label "DNS Server Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over to a secondary DNS server in case of primary server failure."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSServiceRestored .

noria:OperationPlan_RouterFirmwareUpdate
    a noria:OperationPlan ;
    rdfs:label "Core Router Firmware Update Procedure"@en ;
    rdfs:comment "Procedure for safely updating firmware on core network routers during a maintenance window."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterFirmwareUpdated .

