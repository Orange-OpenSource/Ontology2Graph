# =============================================================================
# Connections and Cross-references
# =============================================================================

# Link EventRecord_DNSFixApplied to the TroubleTicket it helped mitigate
noria:TroubleTicket_DNSOutage
    noria:alarmMitigatedBy noria:EventRecord_DNSFixApplied .

# Link ChangeRequest_RouterUpgrade to the OperationPlan that guides it
noria:ChangeRequest_RouterUpgrade
    noria:actionCorrelatedOperationPlan noria:OperationPlan_RouterFirmwareUpdate .

# Link ChangeRequest_DBMigration to the OperationPlan (assuming a generic migration plan)
noria:ChangeRequest_DBMigration
    noria:actionCorrelatedOperationPlan <noria/OperationPlan_DBMigration> .

<noria/OperationPlan_DBMigration>
    a noria:OperationPlan ;
    rdfs:label "Database Migration Procedure"@en ;
    rdfs:comment "Standard procedure for migrating database platforms."@en ;
    noria:operationPlanPreCondition <noria/ActionPreCondition_DBBackupComplete> ;
    noria:operationPlanPostCondition <noria/ActionPostCondition_DBMigratedAndVerified> .

<noria/ActionPreCondition_DBBackupComplete>
    a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete"@en ;
    rdfs:comment "Condition: Full backup of the database is successfully completed."@en .

<noria/ActionPostCondition_DBMigratedAndVerified>
    a noria:ActionPostCondition ;
    rdfs:label "Database Migrated and Verified"@en ;
    rdfs:comment "Outcome: Database successfully migrated to new platform and verified for integrity and performance."@en .

