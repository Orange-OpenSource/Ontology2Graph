    noria:documentExternalId "CUST-INC-98765" .

noria:ChangeRequest_RouterUpgrade
    noria:documentExternalId "EXT-CR-12345" .

# Add a CorporateUserIdentifier for John Doe
<noria/CUid_JohnDoe>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Unique corporate identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "jdoe@example.com" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

