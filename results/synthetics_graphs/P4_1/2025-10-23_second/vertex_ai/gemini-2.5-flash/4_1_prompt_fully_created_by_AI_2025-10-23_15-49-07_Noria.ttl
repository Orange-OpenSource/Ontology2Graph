noria:EventRecord_DNSDown
    a noria:EventRecord ;
    rdfs:label "DNS Server Down Alert"@en ;
    rdfs:comment "Automated alert indicating primary DNS server is unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN!"@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_DNSFailover .

noria:EventRecord_InterfaceDown
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical network interface on the core router went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "MAJOR: Interface GigabitEthernet0/0/1 on router-core01.dc.example.com is DOWN!"@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_DBHighLoad
    a noria:EventRecord ;
    rdfs:label "Database High Load Warning"@en ;
    rdfs:comment "Warning indicating high CPU utilization on the database server."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "WARNING: CPU utilization on db01.corp.example.com is 95%."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_DNSFixApplied
    a noria:EventRecord ;
    rdfs:label "DNS Failover Executed"@en ;
    rdfs:comment "Log entry confirming the execution of DNS failover procedure by an administrator."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logOriginatingManagementSystem noria:Application_TicketingSystem ;
    noria:logText "DNS failover to secondary server completed successfully. Service restored."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_RouterConfigChange
    a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router 01."@en ;
    noria:loggingTime "2024-04-21T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_NetworkOps ;
    noria:logText "Configuration changed by NetworkOps: added new VLAN interface."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

