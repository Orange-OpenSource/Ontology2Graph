    noria:networkLinkType "Fiber Optic 100Gbps" ;
    noria:networkLinkInstallationDate "2021-09-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Firewall01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore01 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application_CorpDNS
    a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:comment "Provides name resolution services for all internal corporate systems."@en ;
    noria:applicationModelIdentifier "CORP-DNS" ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CDNS" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
