# Add more connections for density
noria:Application_CorpDNS
    seas:subSystem noria:Resource_DNS01 .

noria:Application_WebApp
    seas:subSystem noria:Resource_WebSrv01, noria:Resource_DBServer01, noria:Resource_LoadBalancer01 .

