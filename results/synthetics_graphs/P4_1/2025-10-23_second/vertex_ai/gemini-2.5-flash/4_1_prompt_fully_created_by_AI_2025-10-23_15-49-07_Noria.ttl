noria:ActionPostCondition_DNSServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS queries are successfully resolved by a healthy DNS server."@en .

noria:ActionPreCondition_MaintenanceWindow
    a noria:ActionPreCondition ;
    rdfs:label "Scheduled Maintenance Window"@en ;
    rdfs:comment "Condition: A pre-approved maintenance window is active, minimizing service impact."@en .

noria:ActionPostCondition_RouterFirmwareUpdated
    a noria:ActionPostCondition ;
    rdfs:label "Router Firmware Updated and Stable"@en ;
    rdfs:comment "Outcome: Router firmware is successfully updated, and network services are stable."@en .

# =============================================================================
# Event Records (noria:EventRecord)
