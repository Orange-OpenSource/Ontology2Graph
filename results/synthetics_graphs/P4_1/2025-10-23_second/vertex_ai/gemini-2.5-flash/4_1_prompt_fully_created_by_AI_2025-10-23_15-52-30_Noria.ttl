# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:App_CorporateInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en, "Accès Internet Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Gateway Management" ;
    noria:elementManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceForApplication noria:Resource_CoreRouter01 .

noria:App_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal"@en, "Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CP-APP" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "CP" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Self-Service Management" ;
    noria:elementManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceForApplication noria:Resource_WebSrv01, noria:Resource_DB01, noria:Resource_VirtualMachine_AppDev .

noria:App_DNSResolution a noria:Application ;
    rdfs:label "DNS Resolution Service"@en, "Service de Résolution DNS"@fr ;
    rdfs:comment "Core service for resolving domain names to IP addresses."@en ;
    noria:applicationModelIdentifier "DNS-APP" ;
    noria:applicationNumericalIdentifier 3001 ;
    noria:applicationShortIdentifier "DNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Domain Name System" ;
    noria:elementManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceForApplication noria:Resource_DNS01, noria:Resource_DNS02 .

noria:App_SecurityMonitoring a noria:Application ;
