# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NL_DNS01_LAN a noria:NetworkLink ;
    rdfs:label "DNS01 to Corporate LAN Link"@en ;
    rdfs:comment "Link connecting DNS01 to the corporate LAN via CR01."@en ;
    noria:networkLinkId "NL-DNS01-LAN-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkInterfaceConnects noria:NI_DNS01_Eth1 .

noria:NL_CR01_ISP a noria:NetworkLink ;
    rdfs:label "CR01 to ISP Uplink"@en ;
    rdfs:comment "Uplink from Core Router 01 to Internet Service Provider."@en ;
    noria:networkLinkId "NL-CR01-ISP-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-05-20T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter01 ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkInterfaceConnects noria:NI_CR01_Ge0_0_0 .

noria:NL_WebDB_LAN a noria:NetworkLink ;
    rdfs:label "Web/DB to Corporate LAN Link"@en ;
    rdfs:comment "Link connecting WebSrv01 and DB01 to the corporate LAN."@en ;
    noria:networkLinkId "NL-WEBDB-LAN-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-03-10T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0 .

noria:NL_DB_Internal a noria:NetworkLink ;
    rdfs:label "DB Internal Link"@en ;
    rdfs:comment "Direct link between WebSrv01 and DB01 for application traffic."@en ;
    noria:networkLinkId "NL-DB-INT-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-03-10T09:45:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DB01 ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam .

noria:NL_VFW_External a noria:NetworkLink ;
    rdfs:label "Virtual Firewall External Link"@en ;
    rdfs:comment "Link from virtual firewall to external network/internet."@en ;
    noria:networkLinkId "NL-VFW-EXT-001" ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:networkLinkInstallationDate "2023-06-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_VirtualFirewall ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
