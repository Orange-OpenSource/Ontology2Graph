noria:NL_VFW_Internal a noria:NetworkLink ;
    rdfs:label "Virtual Firewall Internal Link"@en ;
    rdfs:comment "Link from virtual firewall to internal DMZ segment."@en ;
    noria:networkLinkId "NL-VFW-INT-001" ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:networkLinkInstallationDate "2023-06-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_VirtualFirewall ;
