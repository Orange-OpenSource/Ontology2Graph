@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (Teams and Individuals)
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use hotline. Otherwise, open a ticket."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call on-call engineer for P1/P2 incidents."@en .

foaf:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en, "Équipe Développement Applicatif"@fr ;
    rdfs:comment "Team developing and maintaining the Customer Portal application."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en, "Centre Opérations Sécurité"@fr ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for DNS infrastructure."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    org:memberOf foaf:Agent_DNSAdminTeam .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    org:memberOf foaf:Agent_NetworkOpsTeam .

foaf:Agent_AliceJohnson a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Customer Portal Application Owner."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    org:memberOf foaf:Agent_AppDevTeam .

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    foaf:accountName "jsmith" ;
    observable:accountLogin "jsmith" ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for critical infrastructure services."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com> .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480 Router"@en ;
    rdfs:comment "Edge router for large-scale network deployments."@en ;
    noria:productManufacturedBy <https://www.juniper.net> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server room within Main Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical servers in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of network equipment in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

bot:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en, "Site de Reprise après Sinistre"@fr ;
    noria:siteId "DR01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Boulevard"@en ;
    noria:sitePrincipalAddressCityName "Gotham City"@en ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomB a noria:Room ;
    rdfs:label "Server Room B"@en, "Salle Serveurs B"@fr ;
    rdfs:comment "Secondary server room within Disaster Recovery Site."@en ;
    bot:hasSpace noria:Locus_RackB1 .

noria:Locus_RackB1 a noria:Locus ;
    rdfs:label "Rack B1"@en ;
    rdfs:comment "Location of DR servers in Server Room B."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Main DC."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

