# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:Event_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_SecurityMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Event indicating a critical network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T07:58:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:App_SecurityMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckFiberLink .

noria:Event_WebSrvHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Customer Portal Web Server 01."@en ;
    noria:loggingTime "2024-04-21T14:15:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU utilization on web01.customerportal.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_SecurityMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_SecurityAlert_SQLI a noria:EventRecord ;
    rdfs:label "SQL Injection Attempt Alert"@en ;
    rdfs:comment "Security alert indicating a potential SQL injection attempt on Customer Portal."@en ;
    noria:loggingTime "2024-04-21T10:30:00Z"^^xsd:dateTime ;
    noria:logText "ALERT: SQL Injection attempt detected from IP 203.0.113.42 on Customer Portal."@en ;
    noria:logOriginatingManagedObject noria:App_CustomerPortal ;
    noria:logOriginatingManagementSystem noria:App_SecurityMonitoring ;
    noria:logOriginatingAgent <http://example.com/attacker/203.0.113.42> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_TT_DNSOutage_001_StatusChange_InProgress a noria:EventRecord ;
