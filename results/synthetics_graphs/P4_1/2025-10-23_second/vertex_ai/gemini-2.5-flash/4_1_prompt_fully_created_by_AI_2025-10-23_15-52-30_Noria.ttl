# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan_CheckFiberLink a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Procedure to diagnose and resolve fiber optic link issues."@en ;
    noria:operationPlanPreCondition noria:PreCond_FiberLinkDown ;
    noria:operationPlanPostCondition noria:PostCond_FiberLinkUp .

noria:PreCond_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Network interface operational status is 'down' and administrative status is 'up'."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Down> AND noria:networkInterfaceAdministrativeStatus = <kos/Resource/AdministrativeState/Up>" .

noria:PostCond_FiberLinkUp a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Up Post-Condition"@en ;
    rdfs:comment "Network interface operational status is 'up'."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Up>" .

noria:OperationPlan_RestartDNS a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en ;
    rdfs:comment "Procedure to restart the DNS service on a server."@en ;
    noria:operationPlanPreCondition noria:PreCond_DNSServiceDown ;
    noria:operationPlanPostCondition noria:PostCond_DNSServiceUp .

noria:PreCond_DNSServiceDown a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down Pre-Condition"@en ;
    rdfs:comment "DNS service is not responding on the server."@en ;
    skos:example "DNS query to server fails." .

noria:PostCond_DNSServiceUp a noria:ActionPostCondition ;
    rdfs:label "DNS Service Up Post-Condition"@en ;
    rdfs:comment "DNS service is responding on the server."@en ;
    skos:example "DNS query to server succeeds." .

# =============================================================================
# Additional Connectivity for Density
# =============================================================================

# Agent manages resources (inverse of noria:resourceManagedBy)
foaf:Agent_DNSAdminTeam noria:agentManagesResource noria:Resource_DNS01, noria:Resource_DNS02 .
foaf:Agent_NetworkOpsTeam noria:agentManagesResource noria:Resource_CoreRouter01, noria:Resource_VirtualFirewall, noria:NL_DNS01_LAN, noria:NL_CR01_ISP, noria:NL_WebDB_LAN, noria:NL_VFW_External, noria:NL_VFW_Internal, noria:Resource_Hypervisor01 .
foaf:Agent_AppDevTeam noria:agentManagesResource noria:Resource_WebSrv01, noria:Resource_DB01, noria:NL_DB_Internal, noria:Resource_VirtualMachine_AppDev .
foaf:Agent_SecurityTeam noria:agentManagesResource noria:Resource_LogServer .

# Resource for Application (explicitly linking resources to applications)
noria:Resource_DNS01 noria:resourceForApplication noria:App_DNSResolution .
noria:Resource_DNS02 noria:resourceForApplication noria:App_DNSResolution .
noria:Resource_CoreRouter01 noria:resourceForApplication noria:App_CorporateInternetAccess .
noria:Resource_WebSrv01 noria:resourceForApplication noria:App_CustomerPortal .
noria:Resource_DB01 noria:resourceForApplication noria:App_CustomerPortal .
noria:Resource_VirtualFirewall noria:resourceForApplication noria:App_CorporateInternetAccess, noria:App_CustomerPortal .
noria:Resource_LogServer noria:resourceForApplication noria:App_SecurityMonitoring .

# Application Modules related parties
noria:AppMod_CIA_Prod noria:applicationModuleSupportGroup foaf:Agent_NetworkOpsTeam ;
    noria:applicationModuleHotlineGroup foaf:Agent_NetworkOpsTeam .

noria:AppMod_CP_Prod noria:applicationModuleSupportGroup foaf:Agent_AppDevTeam ;
    noria:applicationModuleHotlineGroup foaf:Agent_AppDevTeam .

noria:AppMod_DNS_Prod noria:applicationModuleSupportGroup foaf:Agent_DNSAdminTeam ;
    noria:applicationModuleHotlineGroup foaf:Agent_DNSAdminTeam .

# Event records mitigated by (linking an event to a TT as a container for resolution actions)
noria:Event_DNSOutageLog noria:alarmMitigatedBy noria:TT_DNSOutage_001 .
noria:Event_WebSrvHighCPU noria:alarmMitigatedBy noria:TT_CustomerPortalPerf_002 .
