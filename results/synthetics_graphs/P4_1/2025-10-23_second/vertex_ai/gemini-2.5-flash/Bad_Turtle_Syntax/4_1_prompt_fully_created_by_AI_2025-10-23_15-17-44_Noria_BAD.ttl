observable:IPAddress_DNS01_MGMT a observable:IPAddress ;
    rdfs:label "DNS01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.10"^^xsd:string .

observable:IPAddress_WEB01_MGMT a observable:IPAddress ;
    rdfs:label "WEB01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.11"^^xsd:string .

observable:IPAddress_CR01_MGMT a observable:IPAddress ;
    rdfs:label "CR01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.1"^^xsd:string .

observable:IPAddress_ES01_MGMT a observable:IPAddress ;
    rdfs:label "ES01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.2"^^xsd:string .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface for DNS server."@en ;
    noria:networkInterfaceOf noria:Resource_DNSServer01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up .

noria:NetworkInterface_CR01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "cr01-Gi0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface on Core Router 01, facing internal network."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int .

noria:NetworkInterface_CR01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "cr01-Gi0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface on Core Router 01, facing external network."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up ;
    noria:networkInterfaceRoutingPriorityMetric "200"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

noria:NetworkInterface_CR01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "cr01-Gi0/0/2"@en ;
    rdfs:comment "GigabitEthernet interface on Core Router 01, for backup link."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up .

noria:NetworkInterface_ES01_Eth0_1 a noria:NetworkInterface ;
    rdfs:label "es01-eth0/1"@en ;
    rdfs:comment "Ethernet interface on Edge Switch 01, connected to DNS server."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeSwitch01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up .

noria:NetworkInterface_ES01_Eth0_2 a noria:NetworkInterface ;
    rdfs:label "es01-eth0/2"@en ;
    rdfs:comment "Ethernet interface on Edge Switch 01, connected to Web server."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeSwitch01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up .

noria:NetworkInterface_CRMDB_Eth0 a noria:NetworkInterface ;
    rdfs:label "crmdb01-eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for CRM Database VM."@en ;
    noria:networkInterfaceOf noria:Resource_VirtualMachine_CRM_DB ;
    noria:networkInterfaceType "virtual"@en ;
