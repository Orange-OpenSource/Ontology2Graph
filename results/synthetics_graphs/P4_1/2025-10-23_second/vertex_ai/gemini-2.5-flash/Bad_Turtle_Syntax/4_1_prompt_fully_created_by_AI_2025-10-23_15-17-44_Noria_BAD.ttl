# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_DNS_ES01 a noria:NetworkLink ;
    rdfs:label "Link DNS01-ES01"@en ;
    rdfs:comment "Physical link between DNS Server 01 and Edge Switch 01."@en ;
    noria:networkLinkId "NL-DNS-ES-001" ;
    noria:networkLinkType "Ethernet"@en ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_DNSServer01, noria:Resource_EdgeSwitch01 ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0, noria:NetworkInterface_ES01_Eth0_1 .

noria:NetworkLink_WEB_ES01 a noria:NetworkLink ;
    rdfs:label "Link WEB01-ES01"@en ;
    rdfs:comment "Physical link between Web Server 01 and Edge Switch 01."@en ;
    noria:networkLinkId "NL-WEB-ES-001" ;
    noria:networkLinkType "Ethernet"@en ;
    noria:networkLinkInstallationDate "2022-03-20T14:45:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv01, noria:Resource_EdgeSwitch01 ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_WebSrv01_Eth0, noria:NetworkInterface_ES01_Eth0_2 .

noria:NetworkLink_ES01_CR01 a noria:NetworkLink ;
    rdfs:label "Link ES01-CR01"@en ;
    rdfs:comment "Uplink from Edge Switch 01 to Core Router 01."@en ;
    noria:networkLinkId "NL-ES-CR-001" ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2022-02-10T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_EdgeSwitch01, noria:Resource_CoreRouter01 ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_ES01_Eth0_2, noria:NetworkInterface_CR01_Gi0_0_0 .

noria:NetworkLink_ES01_CR01_Backup a noria:NetworkLink ;
    rdfs:label "Link ES01-CR01 Backup"@en ;
    rdfs:comment "Backup uplink from Edge Switch 01 to Core Router 01."@en ;
    noria:networkLinkId "NL-ES-CR-002" ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2022-02-10T11:45:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_EdgeSwitch01, noria:Resource_CoreRouter01 ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_ES01_Eth0_1, noria:NetworkInterface_CR01_Gi0_0_2 .

noria:NetworkLink_CR01_LB01 a noria:NetworkLink ;
    rdfs:label "Link CR01-LB01"@en ;
    rdfs:comment "Link between Core Router 01 and Load Balancer 01."@en ;
    noria:networkLinkId "NL-CR-LB-001" ;
    noria:networkLinkType "Ethernet"@en ;
    noria:networkLinkInstallationDate "2023-06-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter01, noria:Resource_LoadBalancer01 ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_Gi0_0_1, noria:NetworkInterface_LB01_Eth0 .

noria:NetworkLink_LB01_WebSrv01 a noria:NetworkLink ;
    rdfs:label "Link LB01-WebSrv01"@en ;
    rdfs:comment "Link between Load Balancer 01 and Web Application Server 01."@en ;
