# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan_RouterInterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving router interface issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface reports an operational status of 'down'."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface reports an operational status of 'up' and traffic flows."@en .

noria:OperationPlan_CRMDBQueryOptimization a noria:OperationPlan ;
    rdfs:label "CRM DB Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries in CRM system."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_HighCPU ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LowCPU .

noria:ActionPreCondition_HighCPU a noria:ActionPreCondition ;
    rdfs:label "High CPU Usage on DB Server"@en ;
    rdfs:comment "Condition: Database server CPU utilization consistently above 80%."@en .

noria:ActionPostCondition_LowCPU a noria:ActionPostCondition ;
    rdfs:label "Normal CPU Usage on DB Server"@en ;
    rdfs:comment "Expected outcome: Database server CPU utilization returns to normal levels (below 50%)."@en .

noria:OperationPlan_WebSrvRestart a noria:OperationPlan ;
    rdfs:label "Web Server Restart Procedure"@en ;
    rdfs:comment "Standard procedure for restarting a web application server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebSrvUnresponsive ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebSrvResponsive .

noria:ActionPreCondition_WebSrvUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Web Server Unresponsive"@en ;
    rdfs:comment "Condition: Web server is not responding to HTTP requests or health checks."@en .

noria:ActionPostCondition_WebSrvResponsive a noria:ActionPostCondition ;
    rdfs:label "Web Server Responsive"@en ;
    rdfs:comment "Expected outcome: Web server is responding to HTTP requests and health checks."@en .

# =============================================================================
# Procedure Executions (related to TroubleTicketNotes)
# =============================================================================

noria:ProcedureExecutionContainer_CR01InterfaceFix a pep:ProcedureExecutionContainer ;
    rdfs:label "CR01 Interface Fix Execution"@en ;
    rdfs:comment "Container for actions taken to bring CR01 interface Gi0/0/1 back up."@en ;
    pep:usedProcedure noria:OperationPlan_RouterInterfaceTroubleshoot ;
    pep:hasInput noria:ActionPreCondition_InterfaceDown ;
    pep:hasOutput noria:ActionPostCondition_InterfaceUp ;
    pep:member noria:EventRecord_CR01InterfaceUpCommand, noria:EventRecord_CR01InterfaceUpConfirmation .

noria:ProcedureExecutionContainer_WebSrvRestart a pep:ProcedureExecutionContainer ;
    rdfs:label "Web Server Restart Execution"@en ;
    rdfs:comment "Container for actions taken to restart web01.corp.example.com."@en ;
    pep:usedProcedure noria:OperationPlan_WebSrvRestart ;
    pep:hasInput noria:ActionPreCondition_WebSrvUnresponsive ;
    pep:hasOutput noria:ActionPostCondition_WebSrvResponsive ;
    pep:member noria:EventRecord_WebSrvRestartCommand, noria:EventRecord_WebSrvHealthCheckOK .
