# Base URI for NORIA KOS concepts
@prefix kos: <https://w3id.org/noria/kos/> .

# =============================================================================
# Agents (Teams and Individuals)
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email ;
    noria:agentInstructions "For critical issues, use hotline number +1-800-DNS-HELP. Otherwise, open a ticket."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Phone ;
    noria:agentInstructions "Always call the NOC for network outages."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the CRM application."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 Operations"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Phone .

foaf:Agent_JohnDoe a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email .

foaf:Agent_JaneSmith a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email .

foaf:Agent_CustomerSupport a foaf:Agent ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "First line support for customer inquiries."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Phone .

foaf:Agent_DRTeam a foaf:Agent ;
    rdfs:label "Disaster Recovery Team"@en ;
    rdfs:comment "Team responsible for disaster recovery planning and execution."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri) + On-Call"@en ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Phone .

# =============================================================================
# Corporate User Identifiers
# =============================================================================

noria:CorporateUserIdentifier_JohnDoeCUid a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CorporateUserIdentifier_JaneSmithCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"@en ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various services."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> .

noria:ProductModel_CiscoASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "High-end router for enterprise network edge."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for hosting virtual machines."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> .

noria:ProductModel_JuniperEX4600 a noria:ProductModel ;
    rdfs:label "Juniper EX4600 Switch"@en ;
    rdfs:comment "High-performance switch for data center aggregation."@en ;
    noria:productManufacturedBy <http://www.juniper.net/organization> .

# =============================================================================
# Locations (Site, Room, Locus)
# =============================================================================

bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    noria:siteId "DC01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en ;
    wgs84_pos:lat "34.0522"^^xsd:float ;
    wgs84_pos:long "-118.2437"^^xsd:float .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room in Main Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    bot:hasElement noria:Resource_DNSServer01, noria:Resource_WebSrv01 .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room in Main Data Center."@en ;
    bot:hasSpace noria:Locus_RackB1 ;
    bot:hasElement noria:Resource_CoreRouter01, noria:Resource_EdgeSwitch01, noria:Resource_LoadBalancer01 .

noria:Locus_RackB1 a noria:Locus ;
    rdfs:label "Rack B1"@en ;
    rdfs:comment "First rack in Network Room B."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "1"@en .

bot:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    noria:siteId "DR01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "456 Backup Boulevard"@en ;
    noria:sitePrincipalAddressCityName "Safetown"@en ;
    noria:sitePrincipalAddressPostalCode "20002"@en ;
    noria:sitePrincipalAddressCountry "US"@en ;
    wgs84_pos:lat "38.9072"^^xsd:float ;
    wgs84_pos:long "-77.0369"^^xsd:float .

noria:Room_DRServerRoom a noria:Room ;
    rdfs:label "DR Server Room"@en ;
    rdfs:comment "Server room in Disaster Recovery Site."@en ;
    bot:hasSpace noria:Locus_DRRack1 ;
    bot:hasElement noria:Resource_DRWebSrv01 .

noria:Locus_DRRack1 a noria:Locus ;
    rdfs:label "DR Rack 1"@en ;
    rdfs:comment "First rack in DR Server Room."@en ;
    noria:locusLine "D"@en ;
    noria:locusRow "1"@en .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNSServer01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted on physical hardware."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType kos:Resource/type/Server ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress observable:IPAddress_DNS01_MGMT ;
    noria:virtualServerStatus kos:Resource/OperationalState/Up .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Application Server 01"@en ;
    rdfs:comment "Server hosting the main corporate web application."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceType kos:Resource/type/Server ;
    noria:resourceSerialNumber "SN-WEB-001-ABC" ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress observable:IPAddress_WEB01_MGMT ;
    noria:virtualServerStatus kos:Resource/OperationalState/Up .

noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for internal network routing."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceType kos:Resource/type/Router ;
    noria:resourceSerialNumber "SN-CR-001-DEF" ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2021-11-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB1 ;
    noria:resourceManagementIPAddress observable:IPAddress_CR01_MGMT .

noria:Resource_EdgeSwitch01 a noria:Resource ;
    rdfs:label "Edge Switch 01"@en ;
    rdfs:comment "Aggregation switch connecting servers to the core network."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "es01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperEX4600 ;
    noria:resourceLogisticId "ASSET-ES-001" ;
    noria:resourceType kos:Resource/type/Switch ;
    noria:resourceSerialNumber "SN-ES-001-GHI" ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB1 ;
    noria:resourceManagementIPAddress observable:IPAddress_ES01_MGMT .

noria:Resource_VirtualMachine_CRM_DB a noria:Resource ;
    rdfs:label "CRM Database VM"@en ;
    rdfs:comment "Virtual machine hosting the CRM application database."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "crmdb01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType kos:Resource/type/VirtualMachine ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CRMSystem ;
    noria:clusterController noria:Resource_HypervisorHost01 ;
    noria:virtualServerStatus kos:Resource/OperationalState/Up .

noria:Resource_HypervisorHost01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines, including CRM DB VM."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "hvhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType kos:Resource/type/Server ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceInstallationDate "2023-01-10T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 .

noria:Resource_BackupServer01 a noria:Resource ;
    rdfs:label "Backup Server 01"@en ;
    rdfs:comment "Server dedicated to data backup operations."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "backup01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType kos:Resource/type/Server ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceForApplication noria:Application_CRMSystem ;
    noria:locatedAtLocus noria:Locus_RackA1 .

noria:Resource_LoadBalancer01 a noria:Resource ;
    rdfs:label "Application Load Balancer 01"@en ;
    rdfs:comment "Distributes traffic to web application servers."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "lb01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceType kos:Resource/type/Router ;
    noria:resourceUsageState kos:Resource/LifecycleState/InProduction ;
    noria:resourceForApplication noria:Application_CRMSystem ;
    noria:locatedAtLocus noria:Locus_RackB1 .

noria:Resource_DRWebSrv01 a noria:Resource ;
    rdfs:label "DR Web Application Server 01"@en ;
    rdfs:comment "Disaster recovery server for the main corporate web application."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "drweb01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DRWEB-001" ;
    noria:resourceType kos:Resource/type/Server ;
    noria:resourceSerialNumber "SN-DRWEB-001-XYZ" ;
    noria:resourceUsageState kos:Resource/LifecycleState/Staging ;
    noria:resourceInstallationDate "2023-10-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_DRRack1 ;
    noria:resourceForApplication noria:Application_CRMSystem .

