@prefix gn: <https://www.geonames.org/ontology#> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .

# Base URI for NORIA instances
@base <https://w3id.org/noria/instances/> .

# =============================================================================
# SKOS Concepts (for properties with skos:inScheme restrictions)
# =============================================================================

# Application Types
<kos/application/type/infrastructure> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Represents an application that provides core infrastructure services."@en .

<kos/application/type/business> a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "Represents an application directly supporting business operations."@en .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for business operations."@en .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application is important but not critical for immediate business operations."@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently active and serving users."@en .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Development"@en ;
    rdfs:comment "The application module is under active development."@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Incident causing severe impact, requiring immediate attention."@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Incident causing significant impact, requiring urgent attention."@en .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor Severity"@en ;
    rdfs:comment "Incident causing low impact, can be addressed during normal operations."@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate resolution required."@en .

<kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, resolution within defined SLA."@en .

<kos/TroubleTicket/priority/P3> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 3"@en ;
    rdfs:comment "Medium priority, resolution within standard timeframe."@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Trouble ticket initiated by a customer."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision Origin"@en ;
    rdfs:comment "Trouble ticket initiated by an internal monitoring system."@en .

# Trouble Ticket Status
<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Trouble ticket is currently being worked on."@en .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "Trouble ticket issue has been resolved."@en .

<kos/TroubleTicket/status/Closed> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Closed"@en ;
    rdfs:comment "Trouble ticket has been closed after verification."@en .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Network Outage"@en ;
    rdfs:comment "Category for incidents related to network connectivity loss."@en .

<kos/TroubleTicket/trouble-category/ApplicationFailure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Application Failure"@en ;
    rdfs:comment "Category for incidents related to application malfunction."@en .

<kos/TroubleTicket/trouble-category/SecurityIncident> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Security Incident"@en ;
    rdfs:comment "Category for incidents related to security breaches or threats."@en .

<kos/TroubleTicket/trouble-category/InfrastructureIssue> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Infrastructure Issue"@en ;
    rdfs:comment "Category for incidents related to underlying infrastructure components."@en .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility lies with the team managing backbone network infrastructure."@en .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment visible only to internal teams."@en .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Note detailing diagnostic steps taken."@en .

# Change Request Category
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request for internal operational activities."@en .

# Change Request Type
<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Pre-approved change with low risk."@en .

# Change Request Cause
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change initiated due to a software upgrade."@en .

<http://www.example.com/kos/ChangeRequest/cause/NewFeature> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "New Feature Deployment"@en ;
    rdfs:comment "Change initiated for deploying a new feature."@en .

<http://www.example.com/kos/ChangeRequest/cause/NetworkOptimization> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Network Optimization"@en ;
    rdfs:comment "Change initiated for network performance optimization."@en .

<http://www.example.com/kos/ChangeRequest/cause/HardwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Hardware Upgrade"@en ;
    rdfs:comment "Change initiated for hardware component upgrade."@en .

# Change Request Status
<kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "Change request has been approved."@en .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "Change request has been successfully implemented."@en .

# Resource Type
<kos/Resource/type/Server> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A physical or virtual server resource."@en .

<kos/Resource/type/Router> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router resource."@en .

<kos/Resource/type/Switch> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network switch resource."@en .

<kos/Resource/type/VirtualMachine> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Virtual Machine"@en ;
    rdfs:comment "A virtual machine resource."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InProduction> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Resource is actively used in production environment."@en .

<kos/Resource/LifecycleState/Staging> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Staging"@en ;
    rdfs:comment "Resource is in a staging environment, awaiting production deployment."@en .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is operational."@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative Up"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative Down"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Perceived Severity"@en ;
    rdfs:comment "Alarm indicating a critical condition."@en .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Major Perceived Severity"@en ;
    rdfs:comment "Alarm indicating a major condition."@en .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning Perceived Severity"@en ;
    rdfs:comment "Alarm indicating a warning condition."@en .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Ticketing System"@en ;
    rdfs:comment "Preferred contact method is through the ticketing system."@en .

<kos/org/agent-contact-method/Pager> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Pager"@en ;
    rdfs:comment "Preferred contact method is pager for critical alerts."@en .

<kos/org/agent-contact-method/SIEMAlerts> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "SIEM Alerts"@en ;
    rdfs:comment "Preferred contact method is through SIEM alerts."@en .

# SLA Level
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement tier."@en .

# Service Type
<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "Service directly consumed or perceived by customers."@en .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "Service that supports other services or internal operations, not directly exposed to customers."@en .

# Network Interface Type (example concepts, not part of NORIA KOS)
<http://www.example.com/kos/network-interface-type/physical> a skos:Concept ;
    rdfs:label "Physical Network Interface"@en ;
    rdfs:comment "A hardware-based network interface."@en .

<http://www.example.com/kos/network-interface-type/virtual> a skos:Concept ;
    rdfs:label "Virtual Network Interface"@en ;
    rdfs:comment "A software-defined network interface."@en .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person)
# =============================================================================

Agent_ITOperationsTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Central team responsible for overall IT infrastructure operations."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use hotline and ticketing system. For non-critical, use ticketing system only."@en .

Agent_NetworkTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Team responsible for network design, implementation, and maintenance."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via phone for immediate network issues, otherwise use ticketing system."@en .

Agent_AppSupportTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support for business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All application issues must be logged in the ticketing system."@en .

Agent_DBAdminTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Pager> ;
    noria:agentInstructions "Critical database alerts trigger automated pager notifications. Follow up with ticket."@en .

Agent_SecurityTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "All security events are routed through SIEM. Do not contact directly unless instructed."@en .

Agent_CustomerSupportL1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Customer Support L1"@en ;
    rdfs:comment "First-level support for customer inquiries and basic troubleshooting."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate to L2 for technical issues beyond basic troubleshooting."@en .

Person_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentManagesResource Resource_CoreRouter1, Resource_EdgeRouter2 ;
    foaf:holdsAccount noria:CUid_ASmith .

Person_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    foaf:holdsAccount noria:CUid_BJohnson .

Person_CharlieDavis a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Davis"@en ;
    rdfs:comment "Customer Support Agent."@en ;
    foaf:mbox <mailto:charlie.davis@example.com> ;
    foaf:phone "+1-555-333-2222" ;
    noria:agentWorkingHours "8:00-17:00 (Mon-Fri)"@en ;
    foaf:holdsAccount noria:CUid_CDavis .

noria:CUid_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within the corporate IT system."@en ;
    foaf:accountName "asmith" .

noria:CUid_BJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Bob Johnson within the corporate IT system."@en ;
    foaf:accountName "bjohnson" .

noria:CUid_CDavis a noria:CorporateUserIdentifier ;
    rdfs:label "Charlie Davis's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Charlie Davis."@en ;
    foaf:accountName "cdavis" .

<http://www.example.com/external-attacker> a foaf:Agent ;
    rdfs:label "External Attacker"@en ;
    rdfs:comment "Represents an unknown external entity attempting unauthorized access."@en .

