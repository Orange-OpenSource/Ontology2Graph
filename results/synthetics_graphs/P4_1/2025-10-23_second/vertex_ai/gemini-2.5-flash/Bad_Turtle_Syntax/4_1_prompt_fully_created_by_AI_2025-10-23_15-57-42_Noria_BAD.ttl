# =============================================================================
# Location (bot:Site, noria:Room, noria:Locus)
# =============================================================================

Site_DataCenterParis a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en ;
    wgs84_pos:lat "48.8699"^^xsd:float ;
    wgs84_pos:long "2.3333"^^xsd:float .

Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace Site_DataCenterParis .

Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Specific rack location in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasSpace Room_ServerRoomA .

Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Specific rack location in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en ;
    bot:hasSpace Room_ServerRoomA .

# =============================================================================
# Resources (Servers, Routers, Switches, Virtual Machines, Hypervisors)
# =============================================================================

Resource_DBServer1 a noria:Resource ;
    rdfs:label "Database Server 1"@en ;
    rdfs:comment "Primary database server for critical business applications."@en ;
    noria:elementDistinguishedName "db01.corp.example.com" ;
    noria:resourceManagedBy Agent_DBAdminTeam ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel ProductModel_DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB01-XYZ789" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://www.example.com/ip/10.0.0.10> .

Resource_AppServer1 a noria:Resource ;
    rdfs:label "Application Server 1"@en ;
    rdfs:comment "Server hosting core application logic."@en ;
    noria:elementDistinguishedName "app01.corp.example.com" ;
    noria:resourceManagedBy Agent_ITOperationsTeam ;
    noria:resourceHostName "app01.corp.example.com" ;
    noria:resourceProductModel ProductModel_DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-APP01-ABC123" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-01T11:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://www.example.com/ip/10.0.0.11> .

Resource_CoreRouter1 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
