    dcterms:created "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketRelatedService Application_CustomerPortal ;
    noria:troubleTicketRelatedResource Resource_DBServer1 ;
    noria:troubleTicketRelatedParty Agent_DBAdminTeam ;
    noria:troubleTicketTrigger EventRecord_DB_HighCPU ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ApplicationFailure> ;
    noria:troubleTicketCause "High CPU load on DB server due to unoptimized query."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:documentStatusHistory EventRecord_TT_DB_StatusChange_InProgress, EventRecord_TT_DB_StatusChange_Resolved .

