# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

OperationPlan_DBQueryOptimization a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Standard operating procedure for identifying and optimizing slow database queries."@en ;
    noria:operationPlanPreCondition ActionPreCondition_HighCPUAlert ;
    noria:operationPlanPostCondition ActionPostCondition_LowCPUUsage .

ActionPreCondition_HighCPUAlert a noria:ActionPreCondition ;
    rdfs:label "High CPU Alert on DB Server"@en ;
    rdfs:comment "Condition: Database server CPU utilization consistently above 80%."@en .

ActionPostCondition_LowCPUUsage a noria:ActionPostCondition ;
    rdfs:label "Normalized CPU Usage on DB Server"@en ;
    rdfs:comment "Expected outcome: Database server CPU utilization below 50% after optimization."@en .

OperationPlan_RouterInterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Guide"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues with router interfaces."@en ;
    noria:operationPlanPreCondition ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition ActionPostCondition_InterfaceUp .

ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down"@en ;
    rdfs:comment "Condition: A critical network interface reports an operational status of 'down'."@en .

ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up"@en ;
    rdfs:comment "Expected outcome: The network interface operational status is 'up' and traffic is flowing."@en .

# =============================================================================
# Corrective Actions (pep:ProcedureExecution)
# =============================================================================

CorrectiveAction_RouterRestart a pep:ProcedureExecution ;
    rdfs:label "Router Interface Restart Action"@en ;
    rdfs:comment "Command executed to restart the problematic router interface."@en ;
    pep:hasCommand "interface GigabitEthernet0/0/1; shutdown; no shutdown"@en ;
    pep:hasSimpleResult "Interface status changed to up."@en ;
    pep:madeBy Person_AliceSmith ;
    pep:executedAt "2024-04-20T10:50:00Z"^^xsd:dateTime ;
    noria:actionCorrelatedOperationPlan OperationPlan_RouterInterfaceTroubleshoot ;
    dcterms:isPartOf TroubleTicket_NetworkOutage ; # This action is part of the TT's execution.
    dcterms:relation EventRecord_Router_InterfaceUp . # This action led to the interface coming up.
