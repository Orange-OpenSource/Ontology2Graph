# =============================================================================
# Services
# =============================================================================

Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ; # Assuming internal users are 'customers' of this service
    seas:subSystemOf Application_InternalMonitoring ; # The monitoring system helps manage this service
    seas:subSystemOf Application_CustomerPortal ; # Customer Portal relies on this service
    Resource_CoreRouter1 seas:subSystemOf Service_InternetAccess ;
    Resource_EdgeRouter2 seas:subSystemOf Service_InternetAccess ;
    NetworkLink_CR1_ER2_Link seas:subSystemOf Service_InternetAccess .

Service_BillingProcessing a noria:Service ;
    rdfs:label "Billing Processing Service"@en ;
    rdfs:comment "Service responsible for processing customer billing and generating invoices."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf Application_BillingSystem ;
    Resource_BillingDBServer seas:subSystemOf Service_BillingProcessing .

# =============================================================================
# Event Records
# =============================================================================

EventRecord_DB_HighCPU a noria:EventRecord ;
    rdfs:label "DB Server High CPU Alert"@en ;
    rdfs:comment "Automated alert indicating high CPU utilization on Database Server 1."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject Resource_DBServer1 ;
    noria:logOriginatingManagementSystem Application_InternalMonitoring ;
    noria:logText "CPU utilization on db01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

EventRecord_Router_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that an interface on Core Router 1 went down."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject Resource_CoreRouter1 ;
    noria:logOriginatingManagementSystem Application_InternalMonitoring ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface cr01-ge-0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

EventRecord_Security_LoginFailure a noria:EventRecord ;
    rdfs:label "Repeated Login Failures"@en ;
    rdfs:comment "Multiple failed login attempts detected on a web server VM."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject Resource_VirtualMachine_Web1 ;
    noria:logOriginatingManagementSystem Application_InternalMonitoring ; # Assuming IMS also handles security logs
    noria:logText "User 'admin' failed to log in 5 times from IP 192.168.1.100."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent <http://www.example.com/external-attacker> . # Example of external agent

EventRecord_Router_InterfaceUp a noria:EventRecord ;
    rdfs:label "Router Interface Up Confirmation"@en ;
    rdfs:comment "Confirmation that interface cr01-ge-0/0/1 on Core Router 1 is now up."@en ;
    noria:loggingTime "2024-04-20T10:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject Resource_CoreRouter1 ;
    noria:logOriginatingManagementSystem Application_InternalMonitoring ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface cr01-ge-0/0/1, changed state to up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

EventRecord_Billing_Error a noria:EventRecord ;
    rdfs:label "Billing System Processing Error"@en ;
