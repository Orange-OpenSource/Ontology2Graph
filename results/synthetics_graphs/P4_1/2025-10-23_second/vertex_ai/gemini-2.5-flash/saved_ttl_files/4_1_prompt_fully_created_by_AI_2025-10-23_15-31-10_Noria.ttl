# =============================================================================
# Operation Plans, Pre/Post Conditions (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down"@en ;
    rdfs:comment "Condition: DNS service is not responding on the server."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Up"@en ;
    rdfs:comment "Outcome: DNS service is responding and name resolution is functional."@en .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving issues with router interfaces, including SFP replacement."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Network Interface Status Down"@en ;
    rdfs:comment "Condition: A network interface is reporting an operational status of 'down'."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Network Interface Status Up"@en ;
    rdfs:comment "Outcome: The network interface is reporting an operational status of 'up' and traffic is flowing."@en .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Database Backup Procedure"@en ;
    rdfs:comment "Procedure for executing and verifying database backups."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition3 ;
    noria:operationPlanPostCondition noria:ActionPostCondition3 .

noria:ActionPreCondition3 a noria:ActionPreCondition ;
    rdfs:label "Backup Job Scheduled"@en ;
    rdfs:comment "Condition: A database backup job is scheduled to run."@en .

noria:ActionPostCondition3 a noria:ActionPostCondition ;
    rdfs:label "Backup Job Completed Successfully"@en ;
    rdfs:comment "Outcome: The database backup job completed without errors and data integrity is verified."@en .

