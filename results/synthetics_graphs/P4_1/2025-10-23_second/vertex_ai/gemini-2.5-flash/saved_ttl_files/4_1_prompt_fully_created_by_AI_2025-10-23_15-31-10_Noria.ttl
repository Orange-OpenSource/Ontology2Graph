# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Initial Diagnosis"@en ;
    rdfs:comment "Initial check shows DNS service is not responding on port 53. Investigating network connectivity to the server."@en ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person1 ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket1 .

noria:TroubleTicketNote2 a noria:TroubleTicketNote ;
    rdfs:label "Router Link Flapping Analysis"@en ;
    rdfs:comment "Observed CRC errors on Gi0/0/0. Suspect faulty SFP. Scheduling replacement."@en ;
    dcterms:created "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person1 ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket2 .

noria:TroubleTicketNote3 a noria:TroubleTicketNote ;
    rdfs:label "Customer Portal Performance Update"@en ;
    rdfs:comment "Identified several slow queries. Working with DB team to optimize. Increased database connection pool size as a temporary measure."@en ;
    dcterms:created "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person2 ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket3 .

