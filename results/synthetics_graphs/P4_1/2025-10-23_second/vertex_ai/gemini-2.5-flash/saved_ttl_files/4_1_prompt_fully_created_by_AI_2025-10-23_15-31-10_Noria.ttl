@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix devopsprod: <http://w3id.org/devops-infra/product#> .

# =============================================================================
# Agents (foaf:Agent) - Teams and Individuals
# =============================================================================

foaf:Agent1 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'Administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution of related incidents."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the emergency hotline after hours."@en ;
    noria:agentManagesResource noria:Resource1 .

foaf:Agent2 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en, "Centre d'Opérations Réseau (COR)"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to network-related incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "All network alerts are automatically routed to the NOC ticketing system."@en ;
    noria:agentManagesResource noria:Resource2, noria:Resource5, noria:Resource6, noria:NetworkLink1, noria:NetworkLink3, noria:NetworkLink5, noria:NetworkLink6 .

foaf:Agent3 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en, "Équipe de Support Applicatif"@fr ;
    rdfs:comment "Team providing support for business-critical applications, including the Customer Portal."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate performance issues to the Database Admin Team if database-related."@en ;
    noria:agentManagesResource noria:Resource3 .

foaf:Agent4 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (COS)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "Any detected intrusion or suspicious activity must be immediately reported."@en ;
    noria:agentManagesResource noria:Resource5 .

foaf:Agent5 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Admin Team"@en, "Équipe d'Administration de Bases de Données"@fr ;
    rdfs:comment "Specialized team managing and maintaining all corporate database systems."@en ;
    noria:agentWorkingHours "08:30-17:30 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For urgent database issues, contact the on-call DBA."@en ;
    noria:agentManagesResource noria:Resource4, noria:Resource7 .

foaf:Person1 a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Network Engineer, member of the NOC team."@en ;
    foaf:mbox "john.doe@example.com" ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentManagesResource noria:Resource2 ;
    org:memberOf foaf:Agent2 .

foaf:Person2 a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Application Lead for the Customer Portal, member of the Application Support Team."@en ;
    foaf:mbox "jane.smith@example.com" ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentManagesResource noria:Application3 ;
    org:memberOf foaf:Agent3 .

foaf:Person3 a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Brown"@en, "Alice Brun"@fr ;
    rdfs:comment "Security Analyst, member of the SOC team."@en ;
    foaf:mbox "alice.brown@example.com" ;
    foaf:phone "+1-555-111-2222" ;
    noria:agentManagesResource noria:Resource5 ;
    org:memberOf foaf:Agent4 .

foaf:OrgUnit1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Infrastructure Department"@en ;
    rdfs:comment "Parent department for DNS Admin Team, NOC, and Database Admin Team."@en ;
    org:hasMember foaf:Agent1, foaf:Agent2, foaf:Agent5 .

foaf:OrgUnit2 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Customer Service Department"@en ;
    rdfs:comment "Department responsible for direct customer interaction."@en ;
    org:hasMember foaf:Agent3 .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel1 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various IT services."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> .

noria:ProductModel2 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Cisco enterprise-class access layer switch."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> .

noria:ProductModel3 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Juniper universal routing platform for edge and core networks."@en ;
    noria:productManufacturedBy <http://www.juniper.net/organization> .

noria:ProductModel4 a noria:ProductModel ;
    rdfs:label "VMware ESXi Server"@en ;
    rdfs:comment "Virtualization platform for hosting virtual machines."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> .

noria:ProductModel5 a noria:ProductModel ;
    rdfs:label "Oracle Database Appliance X8-2M"@en ;
    rdfs:comment "Integrated system for running Oracle databases."@en ;
    noria:productManufacturedBy <http://www.oracle.com/organization> .

<http://www.dell.com/organization> a org:Organization ;
    rdfs:label "Dell Technologies"@en .

<http://www.cisco.com/organization> a org:Organization ;
    rdfs:label "Cisco Systems"@en .

<http://www.juniper.net/organization> a org:Organization ;
    rdfs:label "Juniper Networks"@en .

<http://www.vmware.com/organization> a org:Organization ;
    rdfs:label "VMware Inc."@en .

<http://www.oracle.com/organization> a org:Organization ;
    rdfs:label "Oracle Corporation"@en .

# =============================================================================
# Locations (noria:Room, noria:Locus)
# =============================================================================

noria:Room1 a noria:Room ;
    rdfs:label "Data Center Hall A"@en, "Salle de Données Hall A"@fr ;
    rdfs:comment "Main data center hall hosting critical infrastructure."@en ;
    bot:hasZone noria:Locus1, noria:Locus2, noria:Locus3, noria:Locus4 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack 15, Row C, Hall A"@en ;
    rdfs:comment "Specific location for DNS Server in Data Center Hall A."@en ;
    noria:locusLine "C"@en ;
    noria:locusRow "15"@en ;
    bot:hasElement noria:Resource1 .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack 16, Row C, Hall A"@en ;
    rdfs:comment "Specific location for Core Router 1 in Data Center Hall A."@en ;
    noria:locusLine "C"@en ;
    noria:locusRow "16"@en ;
    bot:hasElement noria:Resource2 .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack 20, Row D, Hall A (WebApp)"@en ;
    rdfs:comment "Specific location for Web Application Server in Data Center Hall A."@en ;
    noria:locusLine "D"@en ;
    noria:locusRow "20"@en ;
    bot:hasElement noria:Resource3 .

noria:Locus4 a noria:Locus ;
    rdfs:label "Rack 20, Row D, Hall A (DB)"@en ;
    rdfs:comment "Specific location for Database Server in Data Center Hall A."@en ;
    noria:locusLine "D"@en ;
    noria:locusRow "20"@en ;
    bot:hasElement noria:Resource4 .

noria:Locus5 a noria:Locus ;
    rdfs:label "Virtual Environment Cluster 1"@en ;
    rdfs:comment "Logical location for virtualized resources."@en ;
    bot:hasElement noria:Resource5 .

noria:Locus6 a noria:Locus ;
    rdfs:label "Rack 18, Row C, Hall A (Monitoring)"@en ;
    rdfs:comment "Specific location for Monitoring System Host in Data Center Hall A."@en ;
    noria:locusLine "C"@en ;
    noria:locusRow "18"@en ;
    bot:hasElement noria:Resource6 .

noria:Locus7 a noria:Locus ;
    rdfs:label "Rack 22, Row D, Hall A (Backup)"@en ;
    rdfs:comment "Specific location for Backup Storage Array in Data Center Hall A."@en ;
    noria:locusLine "D"@en ;
    noria:locusRow "22"@en ;
    bot:hasElement noria:Resource7 .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource1 a noria:Resource ;
    rdfs:label "Corporate DNS Server"@en, "Serveur DNS d'Entreprise"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical for internal and external name resolution."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress <observable:IPAddress_192.168.1.10> .

noria:Resource2 a noria:Resource ;
    rdfs:label "Core Router 1"@en, "Routeur Cœur 1"@fr ;
    rdfs:comment "Main router for the corporate network, handling internal and external traffic routing."@en ;
