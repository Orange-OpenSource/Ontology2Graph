    noria:logText "CRITICAL: Host dns01.corp.example.com is UNREACHABLE."@en ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logOriginatingAgent foaf:Agent2 ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan1 .

noria:EventRecord2 a noria:EventRecord ;
