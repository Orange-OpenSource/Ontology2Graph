# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface1 a noria:NetworkInterface ;
    rdfs:label "DNS Server Eth0"@en ;
    rdfs:comment "Ethernet interface for DNS server connectivity."@en ;
    noria:networkInterfaceOf noria:Resource1 ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink2 .

noria:NetworkInterface2 a noria:NetworkInterface ;
    rdfs:label "Router1 Gi0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 1, connecting to Core Router 2."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:NetworkLink1 .

noria:NetworkInterface3 a noria:NetworkInterface ;
    rdfs:label "Router1 Gi0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 1, connecting to Virtual Firewall."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 110 ;
    noria:networkInterfaceConnects noria:NetworkLink3 .

noria:NetworkInterface4 a noria:NetworkInterface ;
    rdfs:label "WebApp Server Eth0"@en ;
    rdfs:comment "Ethernet interface for Web Application Server."@en ;
    noria:networkInterfaceOf noria:Resource3 ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink4 .

noria:NetworkInterface5 a noria:NetworkInterface ;
    rdfs:label "DB Server Eth0"@en ;
    rdfs:comment "Ethernet interface for Database Server."@en ;
    noria:networkInterfaceOf noria:Resource4 ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink4 .

noria:NetworkInterface6 a noria:NetworkInterface ;
    rdfs:label "Virtual Firewall Eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Virtual Firewall, connecting to Core Router 1."@en ;
    noria:networkInterfaceOf noria:Resource5 ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink3 .

noria:NetworkInterface7 a noria:NetworkInterface ;
    rdfs:label "Monitoring Host Eth0"@en ;
    rdfs:comment "Ethernet interface for Monitoring System Host."@en ;
    noria:networkInterfaceOf noria:Resource6 ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink6 .

noria:NetworkInterface8 a noria:NetworkInterface ;
    rdfs:label "Backup Storage Eth0"@en ;
    rdfs:comment "Ethernet interface for Backup Storage Array."@en ;
    noria:networkInterfaceOf noria:Resource7 ;
