noria:Resource4 a noria:Resource ;
    rdfs:label "Database Server"@en, "Serveur de Base de Données"@fr ;
    rdfs:comment "Server hosting the primary database for the customer portal."@en ;
    noria:resourceManagedBy foaf:Agent5 ;
