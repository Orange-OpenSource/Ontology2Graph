    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logOriginatingAgent foaf:Agent_ExternalAttacker ; # Example of an external agent
    noria:logText "Failed login attempt for user 'admin' from IP 203.0.113.42."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

