# =============================================================================
# Operation Plans and Conditions (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:OperationPlan_RouterInterfaceBounce a noria:OperationPlan ;
    rdfs:label "Router Interface Bounce Procedure"@en ;
    rdfs:comment "Standard operating procedure to administratively shut down and then bring up a router interface."@en ;
    skos:example "Commands: 'shutdown', 'no shutdown'"@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Interface is Administratively Down"@en ;
    rdfs:comment "Condition: The target network interface must be in an administrative 'down' state."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Interface is Operational Up"@en ;
    rdfs:comment "Expected outcome: The target network interface should transition to an operational 'up' state."@en .

noria:OperationPlan_RouterInterfaceBounce noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown .
noria:OperationPlan_RouterInterfaceBounce noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:OperationPlan_WebSrvRestart a noria:OperationPlan ;
    rdfs:label "Web Server Restart Procedure"@en ;
    rdfs:comment "Procedure for gracefully restarting the web server service."@en .

noria:ActionPreCondition_LowTraffic a noria:ActionPreCondition ;
    rdfs:label "Low Traffic Period"@en ;
    rdfs:comment "Condition: Web server traffic must be below a defined threshold."@en .

noria:ActionPostCondition_ServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Web Service Restored"@en ;
    rdfs:comment "Expected outcome: Web service is accessible and responding to requests."@en .

noria:OperationPlan_WebSrvRestart noria:operationPlanPreCondition noria:ActionPreCondition_LowTraffic .
noria:OperationPlan_WebSrvRestart noria:operationPlanPostCondition noria:ActionPostCondition_ServiceRestored .

# =============================================================================
# Procedure Executions (pep:ProcedureExecutionContainer)
# =============================================================================

noria:ProcedureExecutionContainer_RouterFix a pep:ProcedureExecutionContainer ;
    rdfs:label "Router Interface Fix Execution"@en ;
    rdfs:comment "Container for the execution of actions to fix the router interface."@en ;
    pep:usedProcedure noria:OperationPlan_RouterInterfaceBounce ;
    pep:hasInput noria:ActionPreCondition_InterfaceDown ;
    pep:hasOutput noria:ActionPostCondition_InterfaceUp ;
    dcterms:created "2024-04-20T08:35:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_JohnDoe .

noria:EventRecord_RouterInterfaceUp a noria:EventRecord ;
    rdfs:label "Router Interface Up Event (Fix)"@en ;
    rdfs:comment "Event indicating a network interface on Core Router 01 came back up after manual intervention."@en ;
    noria:loggingTime "2024-04-20T08:38:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ;
    noria:logText "Interface GigabitEthernet0/0/1 on core-rtr01.dc01.example.com changed state to up by John Doe."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    noria:alarmMitigatedBy noria:ProcedureExecutionContainer_RouterFix .

noria:ProcedureExecutionContainer_RouterFix pep:member noria:EventRecord_RouterInterfaceUp .

noria:TroubleTicket_DNSOutage noria:documentStatusHistory noria:EventRecord_RouterInterfaceUp .
noria:TroubleTicket_DNSOutage noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> .

