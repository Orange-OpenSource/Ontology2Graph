# =============================================================================
# KOS Concepts (Knowledge Organization System)
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/business-critical> a skos:Concept ;
    skos:prefLabel "Business Critical Application"@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/monitoring> a skos:Concept ;
    skos:prefLabel "Monitoring Application"@en ;
    skos:inScheme <kos/application/type> .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

<kos/application/business-importance/high> a skos:Concept ;
    skos:prefLabel "High Business Importance"@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:prefLabel "Medium Business Importance"@en ;
    skos:inScheme <kos/application/business-importance> .

# Application Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:prefLabel "Development"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

# Trouble Ticket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:prefLabel "Major"@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

# Trouble Ticket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of trouble tickets."@en .

<kos/TroubleTicket/type/Incident> a skos:Concept ;
    skos:prefLabel "Incident"@en ;
    skos:inScheme <kos/TroubleTicket/type> .

<kos/TroubleTicket/type/Problem> a skos:Concept ;
    skos:prefLabel "Problem"@en ;
    skos:inScheme <kos/TroubleTicket/type> .

# Trouble Ticket Priority
<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A scheme for classifying the priority of trouble tickets."@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ;
    skos:prefLabel "Priority 1"@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/priority/P2> a skos:Concept ;
    skos:prefLabel "Priority 2"@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

# Trouble Ticket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:prefLabel "Customer"@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:prefLabel "Supervision System"@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A scheme for classifying the urgency of trouble tickets."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:prefLabel "Immediate Intervention"@en ;
    skos:inScheme <kos/TroubleTicket/urgency> .

<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ;
    skos:prefLabel "Deferred Intervention"@en ;
    skos:inScheme <kos/TroubleTicket/urgency> .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the technical impact or nature of trouble tickets."@en .

<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ;
    skos:prefLabel "Network Outage"@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/trouble-category/ServerFailure> a skos:Concept ;
    skos:prefLabel "Server Failure"@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying the responsibility for a problem."@en .

<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ;
    skos:prefLabel "Internal IT"@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

<kos/TroubleTicket/problemResponsibility/ExternalProvider> a skos:Concept ;
    skos:prefLabel "External Provider"@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

# Trouble Ticket Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of comments in trouble tickets."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:prefLabel "Internal Comment"@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

<kos/TroubleTicket/commentType/Customer> a skos:Concept ;
    skos:prefLabel "Customer Comment"@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

# Trouble Ticket Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of operation recorded in a trouble ticket note."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:prefLabel "Diagnosis"@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

<kos/TroubleTicket/operationType/Resolution> a skos:Concept ;
skos:prefLabel "Resolution"@en ;
skos:inScheme <kos/TroubleTicket/operationType> .

# Trouble Ticket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of trouble tickets."@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:prefLabel "In Progress"@en ;
    skos:inScheme <kos/TroubleTicket/status> .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:prefLabel "Resolved"@en ;
    skos:inScheme <kos/TroubleTicket/status> .

<kos/TroubleTicket/status/Closed> a skos:Concept ;
    skos:prefLabel "Closed"@en ;
    skos:inScheme <kos/TroubleTicket/status> .

# Change Request Category
<kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A scheme for classifying categories of change requests."@en .

<kos/ChangeRequest/category/Configuration> a skos:Concept ;
    skos:prefLabel "Configuration Change"@en ;
    skos:inScheme <kos/ChangeRequest/category> .

<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ;
    skos:prefLabel "Software Upgrade"@en ;
    skos:inScheme <kos/ChangeRequest/category> .

# Change Request Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of change requests."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:prefLabel "Standard Change"@en ;
    skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/type/Emergency> a skos:Concept ;
    skos:prefLabel "Emergency Change"@en ;
    skos:inScheme <kos/ChangeRequest/type> .

# Change Request Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying causes of change requests."@en .

<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ;
    skos:prefLabel "Preventative Maintenance"@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

<kos/ChangeRequest/cause/SecurityPatch> a skos:Concept ;
    skos:prefLabel "Security Patch"@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

# Change Request Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of change requests."@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:prefLabel "Approved"@en ;
    skos:inScheme <kos/ChangeRequest/status> .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:prefLabel "Implemented"@en ;
    skos:inScheme <kos/ChangeRequest/status> .

# Resource Type
<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of IT resources."@en .

<kos/Resource/type/Server> a skos:Concept ;
    skos:prefLabel "Server"@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Router> a skos:Concept ;
    skos:prefLabel "Router"@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/VirtualMachine> a skos:Concept ;
    skos:prefLabel "Virtual Machine"@en ;
    skos:inScheme <kos/Resource/type> .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying the lifecycle state of IT resources."@en .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

<kos/Resource/LifecycleState/Staging> a skos:Concept ;
    skos:prefLabel "Staging"@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

# Resource Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of IT resources."@en .

<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:prefLabel "Up"@en ;
    skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:prefLabel "Down"@en ;
    skos:inScheme <kos/Resource/OperationalState> .

# Resource Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of IT resources."@en .

<kos/Resource/AdministrativeState/Up> a skos:Concept ;
    skos:prefLabel "Up"@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

<kos/Resource/AdministrativeState/Down> a skos:Concept ;
    skos:prefLabel "Down"@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

# Service Type
<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:prefLabel "Customer Facing Service"@en ;
    skos:inScheme <kos/service/type> .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:prefLabel "Resource Facing Service"@en ;
    skos:inScheme <kos/service/type> .

# Notification Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the perceived severity of notifications/alarms."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:prefLabel "Major"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:prefLabel "Warning"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:prefLabel "Email"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:prefLabel "Phone"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent_ITOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Central team responsible for overall IT infrastructure operations and support."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use emergency hotline after hours."@en .

foaf:Agent_NetworkTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Open a ticket for all non-critical requests."@en .

foaf:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team dedicated to monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_CustomerA a foaf:Agent ;
    rdfs:label "Customer A"@en ;
    rdfs:comment "A key external customer."@en .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy org:Organization_Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series for high-density deployments."@en ;
    noria:productManufacturedBy org:Organization_Cisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy org:Organization_VMware .

org:Organization_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

org:Organization_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

org:Organization_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_DC01 a bot:Site ;
    rdfs:label "Main Data Center 01"@en ;
    rdfs:comment "Primary data center facility."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within DC01."@en ;
    bot:hasSpace bot:Site_DC01 .

noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "23"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackA2_U10 a noria:Locus ;
    rdfs:label "Rack A2, Unit 10"@en ;
    rdfs:comment "Specific location for a network device in Server Room A."@en ;
    noria:locusLine "A2"@en ;
    noria:locusRow "10"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

# =============================================================================
# Resources (noria:Resource, noria:NetworkInterface, noria:NetworkLink)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, running on Dell hardware."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress "10.0.0.10" .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Frontend web server hosting critical applications."@en ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress "10.0.0.20" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for data center network connectivity."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkTeam ;
    noria:resourceHostName "core-rtr01.dc01.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceLogisticId "ASSET-RTR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-11-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2_U10 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_VM_AppDB a noria:Resource ;
    rdfs:label "Virtual Machine for Application Database"@en ;
    rdfs:comment "Virtual machine hosting the database for the main business application."@en ;
    noria:resourceManagedBy foaf:Agent_ITOpsTeam ;
    noria:resourceHostName "appdb-vm01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
