    noria:troubleTicketDetectionDateTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T09:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_NetworkTeam ;
    noria:troubleTicketRelatedParty foaf:Agent_ITOpsTeam ;
    noria:troubleTicketRelatedService noria:Service_CustomerInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:Service_CustomerInternetAccess ;
