noria:TroubleTicketNote_DNSDiag1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Diagnosis Note 1"@en ;
    rdfs:comment "Initial diagnosis: confirmed DNS server is not responding to pings. Investigating network path."@en ;
