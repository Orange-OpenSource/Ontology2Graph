# =============================================================================
# Additional Interconnections for Density
# =============================================================================

# Link applications to resources
noria:Resource_DNS01 noria:resourceForApplication noria:Application_MonitoringPlatform . # DNS is critical for monitoring
noria:Resource_WebSrv01 noria:resourceForApplication noria:Application_CRMSystem .
noria:Resource_RouterCore01 noria:resourceForApplication noria:Application_MonitoringPlatform . # Router is monitored

# Link agents to resources they manage
foaf:Agent_JohnDoe noria:agentManagesResource noria:Resource_RouterCore01 .
foaf:Agent_JohnDoe noria:agentManagesResource noria:NetworkLink_ServerToRouter .
foaf:Agent_JaneSmith noria:agentManagesResource noria:Resource_WebSrv01 .
foaf:Agent_JaneSmith noria:agentManagesResource noria:Resource_VM_AppDB .

# Link applications to other applications (e.g., dependency)
noria:Application_CRMSystem seas:dependsOn noria:Application_DNS01 . # CRM depends on DNS for name resolution
noria:Application_MonitoringPlatform seas:monitors noria:Application_CRMSystem .
noria:Application_MonitoringPlatform seas:monitors noria:Service_CustomerInternetAccess .

# Link services to other services
noria:Service_CRM_Delivery seas:dependsOn noria:Service_CustomerInternetAccess .

# More event records
noria:EventRecord_CRMLogError a noria:EventRecord ;
    rdfs:label "CRM Application Log Error"@en ;
    rdfs:comment "Error message from CRM application logs indicating database connection failure."@en ;
    noria:loggingTime "2024-04-20T09:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ApplicationModule_CRM_Prod ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "Database connection failed for CRM_PROD_INSTANCE: Timeout."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:TroubleTicket_CRMFailure noria:troubleTicketTrigger noria:EventRecord_CRMLogError .

noria:EventRecord_CRMDbRestart a noria:EventRecord ;
    rdfs:label "CRM DB Restart Event"@en ;
