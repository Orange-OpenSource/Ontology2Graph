# =============================================================================
# Agents (foaf:Agent)
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use hotline + ticketing system."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center"@en, "Centre d'Opérations Réseau"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate to L2 support for complex network issues."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe de support applicatif"@fr ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Open a ticket for all application-related problems."@en .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Security Operations Center"@en, "Centre d'Opérations de Sécurité"@fr ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SecureChat> ;
    noria:agentInstructions "Report all suspicious activities immediately."@en .

foaf:Person1 a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, member of Network Operations Center."@en ;
    foaf:mbox "mailto:alice.smith@example.com" ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> .

foaf:Person2 a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead Developer for Customer Portal, member of Application Support Team."@en ;
    foaf:mbox "mailto:bob.johnson@example.com" ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

foaf:Person3 a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Security Analyst, member of Security Operations Center."@en ;
    foaf:mbox "mailto:charlie.brown@example.com" ;
    foaf:phone "+1-555-555-1122" ;
    noria:agentWorkingHours "24/7 (on-call)"@en .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "Database Admin Team"@en, "Équipe d'administration de bases de données"@fr ;
    rdfs:comment "Manages and maintains all corporate databases."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
