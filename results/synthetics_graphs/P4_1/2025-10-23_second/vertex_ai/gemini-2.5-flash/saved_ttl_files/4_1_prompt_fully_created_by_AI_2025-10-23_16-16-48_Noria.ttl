# Example of a more complex relationship: a TroubleTicketNote leading to a ChangeRequest
noria:TroubleTicketNote3 a noria:TroubleTicketNote ;
    rdfs:label "Root Cause Analysis for DB Performance"@en ;
    rdfs:comment "RCA concluded that the database performance issue is due to insufficient storage IOPS capacity. A change request for storage upgrade is recommended."@en ;
    dcterms:created "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent5 ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket3 .

noria:ChangeRequest4 a noria:ChangeRequest ;
    rdfs:label "Storage Array Upgrade for CRM DB"@en ;
    rdfs:comment "Upgrade the SAN-01 storage array to increase IOPS capacity for the CRM database."@en ;
    dcterms:identifier "CR-20240425-004" ;
    dcterms:created "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-10T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-10T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <https://w3id.org/noria/kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <https://w3id.org/noria/kos/ChangeRequest/cause/CapacityUpgrade> ;
    noria:changeRequestImpact noria:Resource8, noria:Resource4, noria:Application3 ;
    noria:changeRequestOutageDuration "PT4H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <https://w3id.org/noria/kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty foaf:Agent5 ;
    noria:changeRequestPilotParty foaf:Agent5 ;
    noria:changeRequestActorParty foaf:Agent5 ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef "http://changemgmt.example.com/CR-20240425-004" .

# Link the note to the change request (using dcterms:relation for general relation)
noria:TroubleTicketNote3 dcterms:relation noria:ChangeRequest4 .

