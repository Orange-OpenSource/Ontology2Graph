# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service1 a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing network connectivity and internet access to all employees."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:Application1, noria:ApplicationModule1 . # Service is composed of applications/modules

noria:Service2 a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "Aggregated service for all customer-facing web applications."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:Application2, noria:ApplicationModule2, noria:ApplicationModule3 .

noria:Service3 a noria:Service ;
    rdfs:label "Internal Business Process Service"@en ;
    rdfs:comment "Service supporting core internal business processes like CRM and Billing."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:Application3, noria:ApplicationModule4, noria:Application5, noria:ApplicationModule6 .

# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS server."@en ;
    noria:operationPlanPreCondition noria:PreCondition1 ;
    noria:operationPlanPostCondition noria:PostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving issues on router interfaces."@en ;
    noria:operationPlanPreCondition noria:PreCondition2 ;
    noria:operationPlanPostCondition noria:PostCondition2 .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Application Deployment Checklist"@en ;
    rdfs:comment "Checklist for deploying new application features to production."@en .

noria:PreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS queries are failing or timing out."@en .

noria:PostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Reachable"@en ;
    rdfs:comment "Expected outcome: DNS queries are resolving successfully."@en .

noria:PreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Router Interface Status Down"@en ;
    rdfs:comment "Condition: A critical router interface is reporting an 'administratively down' or 'down' operational status."@en .

noria:PostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Router Interface Status Up"@en ;
    rdfs:comment "Expected outcome: The router interface is reporting an 'up' operational status and passing traffic."@en .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Server Down Alert"@en ;
    rdfs:comment "Automated alert indicating that the Corporate DNS Server is unreachable."@en ;
    noria:loggingTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "Host dns01.corp.example.com is unreachable via ICMP."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan1 .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "Router Interface Down"@en ;
    rdfs:comment "Log entry from Core Router R1 indicating an interface went down."@en ;
    noria:loggingTime "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:OperationPlan2 .

noria:EventRecord3 a noria:EventRecord ;
