# =============================================================================
# Location (noria:Room, noria:Locus)
# =============================================================================

noria:Room1 a noria:Room ;
    rdfs:label "Data Center Hall A"@en, "Salle de Données Hall A"@fr ;
    rdfs:comment "Main data center hall housing critical infrastructure."@en ;
    bot:hasSubSpace noria:Locus1, noria:Locus2, noria:Locus3 ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room2 a noria:Room ;
    rdfs:label "Server Room 314"@en, "Salle Serveurs 314"@fr ;
    rdfs:comment "Smaller server room for development and testing environments."@en ;
    noria:sitePrincipalAddress "456 Innovation Drive"@en ;
    noria:sitePrincipalAddressCityName "Techville"@en ;
    noria:sitePrincipalAddressPostalCode "20002"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Location for DNS and core network equipment."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack B5, Unit 22"@en ;
    rdfs:comment "Location for web application servers."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "5"@en .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack C2, Unit 5"@en ;
    rdfs:comment "Location for database servers."@en ;
    noria:locusLine "C"@en ;
    noria:locusRow "2"@en .

noria:Locus4 a noria:Locus ;
    rdfs:label "Rack D1, Unit 1"@en ;
    rdfs:comment "Location for firewall and load balancer."@en ;
    noria:locusLine "D"@en ;
    noria:locusRow "1"@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource1 a noria:Resource ;
    rdfs:label "Corporate DNS Server"@en ;
    rdfs:comment "Primary DNS server for corporate network, critical for internet access."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource2 a noria:Resource ;
