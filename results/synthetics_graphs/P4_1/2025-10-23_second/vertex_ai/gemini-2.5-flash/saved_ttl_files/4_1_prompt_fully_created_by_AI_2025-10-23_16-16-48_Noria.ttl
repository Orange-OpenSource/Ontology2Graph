# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface1 a noria:NetworkInterface ;
    rdfs:label "Resource1_Eth0"@en ;
    rdfs:comment "Ethernet interface for Corporate DNS Server."@en ;
    noria:networkInterfaceOf noria:Resource1 ;
    noria:networkInterfaceType <http://example.com/kos/network/interface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> .

noria:NetworkInterface2 a noria:NetworkInterface ;
    rdfs:label "Resource2_Gi0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/1 on Core Router R1, connected to internal network."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceType <http://example.com/kos/network/interface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface3 a noria:NetworkInterface ;
    rdfs:label "Resource2_Gi0/0/2"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/2 on Core Router R1, connected to DMZ firewall."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceType <http://example.com/kos/network/interface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

noria:NetworkInterface4 a noria:NetworkInterface ;
    rdfs:label "Resource3_Eth0"@en ;
    rdfs:comment "Ethernet interface for Web Application Server A."@en ;
    noria:networkInterfaceOf noria:Resource3 ;
    noria:networkInterfaceType <http://example.com/kos/network/interface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> .

noria:NetworkInterface5 a noria:NetworkInterface ;
    rdfs:label "Resource6_Eth1_WAN"@en ;
    rdfs:comment "WAN-facing interface of Firewall FW-DMZ-01."@en ;
    noria:networkInterfaceOf noria:Resource6 ;
    noria:networkInterfaceType <http://example.com/kos/network/interface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -8 .

noria:NetworkInterface6 a noria:NetworkInterface ;
    rdfs:label "Resource6_Eth2_LAN"@en ;
    rdfs:comment "LAN-facing interface of Firewall FW-DMZ-01, connected to DMZ segment."@en ;
    noria:networkInterfaceOf noria:Resource6 ;
    noria:networkInterfaceType <http://example.com/kos/network/interface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink1 a noria:NetworkLink ;
    rdfs:label "Link_DNS_R1"@en ;
    rdfs:comment "Network link between Corporate DNS Server and Core Router R1."@en ;
    noria:networkLinkId "NL-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource2 ;
    noria:networkLinkInstallationDate "2020-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps"@en ;
    noria:resourceManagedBy foaf:Agent2 .

noria:NetworkLink2 a noria:NetworkLink ;
    rdfs:label "Link_R1_R2_Core"@en ;
    rdfs:comment "Core network link between Router R1 and another core router (not explicitly modeled here)."@en ;
    noria:networkLinkId "NL-002" ;
    noria:networkLinkTerminationResource noria:Resource2 ;
