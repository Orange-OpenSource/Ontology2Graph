    noria:loggingTime "2024-04-23T09:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "ERROR: Database connection failed for Customer Portal backend."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Database Connection Timeout"@en ;
    rdfs:comment "Log from Database Server DB1 showing repeated connection timeouts."@en ;
    noria:loggingTime "2024-04-23T09:12:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource4 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "ORA-03113: end-of-file on communication channel. Repeated connection timeouts."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "Firewall Block Alert"@en ;
    rdfs:comment "Alert from Firewall FW-DMZ-01 indicating a blocked connection attempt."@en ;
    noria:loggingTime "2024-04-23T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource6 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "Blocked connection from 1.2.3.4 to 172.16.0.10 on port 80."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent foaf:Person3 .

noria:EventRecord6 a noria:EventRecord ;
    rdfs:label "Load Balancer Health Check Failure"@en ;
    rdfs:comment "Alert from Load Balancer LB-Prod-01 indicating a backend server health check failure."@en ;
    noria:loggingTime "2024-04-23T09:18:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource7 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "Health check failed for backend server web-app-a.corp.example.com."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord7 a noria:EventRecord ;
    rdfs:label "Storage IOPS Threshold Exceeded"@en ;
    rdfs:comment "Alert from Storage Array SAN-01 indicating high IOPS usage."@en ;
    noria:loggingTime "2024-04-23T09:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource8 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "IOPS on volume 'CRM_DATA' exceeded critical threshold (15000 IOPS)."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord8 a noria:EventRecord ;
    rdfs:label "Backup Job Failed"@en ;
    rdfs:comment "Alert from Backup Server BKP-01 indicating a failed backup job for the Billing System."@en ;
    noria:loggingTime "2024-04-23T03:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource10 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logText "Backup job 'Billing_DB_Full' failed with error code 0x80070005."@en ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> .

