    noria:elementManagedBy foaf:Agent2 .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

noria:ApplicationModule1 a noria:ApplicationModule ;
    rdfs:label "Corporate Internet Access Module 1 - Production"@en ;
    rdfs:comment "Production instance of the Corporate Internet Access application."@en ;
