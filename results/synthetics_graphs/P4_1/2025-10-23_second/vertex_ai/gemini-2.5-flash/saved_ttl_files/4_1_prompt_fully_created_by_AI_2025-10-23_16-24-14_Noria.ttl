# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS server."@en ;
    skos:example "Steps include checking service status, attempting graceful restart, force restart if necessary, and verifying resolution."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Firewall Configuration Change Procedure"@en ;
    rdfs:comment "Procedure for safely applying configuration changes to the perimeter firewall."@en ;
    skos:example "Steps include backup config, apply changes, test connectivity, rollback if issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Database Backup Procedure"@en ;
    rdfs:comment "Routine procedure for performing full and incremental backups of critical databases."@en ;
    skos:example "Steps include initiating backup, monitoring progress, verifying integrity, and storing offsite."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition3 ;
    noria:operationPlanPostCondition noria:ActionPostCondition3 .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS queries to the corporate DNS server are failing or timing out."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Responding"@en ;
    rdfs:comment "Condition: DNS queries to the corporate DNS server are successfully resolved."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Firewall Access Blocked"@en ;
    rdfs:comment "Condition: Network traffic for a specific service or port is being blocked by the firewall."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Firewall Access Restored"@en ;
    rdfs:comment "Condition: Network traffic for the specified service or port is now flowing through the firewall as intended."@en .

noria:ActionPreCondition3 a noria:ActionPreCondition ;
    rdfs:label "Database Backup Required"@en ;
    rdfs:comment "Condition: Scheduled time for database backup has arrived or an urgent backup is needed."@en .

noria:ActionPostCondition3 a noria:ActionPostCondition ;
    rdfs:label "Database Backup Completed Successfully"@en ;
    rdfs:comment "Condition: Database backup process finished without errors and data integrity verified."@en .

# =============================================================================
# Additional connections for density
# =============================================================================

# Link agents to resources they manage
foaf:Agent1 noria:agentManagesResource noria:Resource1 .
foaf:Agent2 noria:agentManagesResource noria:Resource2, noria:Resource7 .
foaf:Agent3 noria:agentManagesResource noria:Resource3, noria:Resource6 .
foaf:Agent4 noria:agentManagesResource noria:Resource5 .
foaf:Agent5 noria:agentManagesResource noria:Resource4, noria:Resource8 .

# Link applications to resources they use (beyond resourceForApplication)
noria:Application2 seas:subSystem noria:Resource3, noria:Resource6 .
noria:Application3 seas:subSystem noria:Resource4, noria:Resource8 .
noria:Application4 seas:subSystem noria:Resource7 .

# Link application modules to resources they use
noria:ApplicationModule1 seas:subSystem noria:Resource1 .
noria:ApplicationModule2 seas:subSystem noria:Resource3, noria:Resource6 .
noria:ApplicationModule3 seas:subSystem noria:Resource4 .
noria:ApplicationModule4 seas:subSystem noria:Resource7 .

# Link services to application modules
noria:Service1 seas:subSystem noria:ApplicationModule1 .
noria:Service2 seas:subSystem noria:ApplicationModule2 .
noria:Service3 seas:subSystem noria:ApplicationModule3 .

# Link trouble tickets to notes
noria:TroubleTicket1 dcterms:hasPart noria:TroubleTicketNote1, noria:TroubleTicketNote2 .
noria:TroubleTicket2 dcterms:hasPart noria:TroubleTicketNote3 .

# Link change requests to operation plans
noria:ChangeRequest1 pep:usedProcedure noria:OperationPlan2 .
noria:ChangeRequest2 pep:usedProcedure noria:OperationPlan3 .

# Link event records to other event records (correlation)
noria:EventRecord6 dcterms:relation noria:EventRecord3 . # Load balancer health check failure correlated with high CPU on webapp.

# Link organizational units to agents
org:OrganizationalUnit1 org:hasMember foaf:Person1 .
org:OrganizationalUnit2 org:hasMember foaf:Person2 .
foaf:Agent4 org:hasMember foaf:Person3 .

# Example of a document attachment
noria:DocumentAttachment1 a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for Corporate LAN"@en ;
    rdfs:comment "Diagram showing the topology of the corporate local area network."@en ;
    dcterms:format "image/png" ;
    dcterms:isPartOf noria:TroubleTicket1 ;
    dcterms:source "https://docs.example.com/diagrams/corp_lan_v2.png"^^xsd:anyURI .

noria:TroubleTicket1 dcterms:hasPart noria:DocumentAttachment1 .
