# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use hotline + ticketing system."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to alerts."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "All network incidents must be reported via phone and ticket."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket for all application-related issues."@en .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SecureChat> ;
    noria:agentInstructions "Report all security incidents immediately through secure channels."@en .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "Database Admin Team"@en ;
    rdfs:comment "Team managing and maintaining database systems."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For database performance issues, provide detailed query logs."@en .

foaf:Person1 a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    foaf:name "John Doe" ;
    rdfs:comment "Senior Network Engineer, member of Network Operations Center."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    foaf:phone "+1-555-123-4567" ;
    org:memberOf foaf:Agent2 .

foaf:Person2 a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    foaf:name "Jane Smith" ;
    rdfs:comment "Application Lead for Customer Portal, member of Application Support Team."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    foaf:phone "+1-555-987-6543" ;
    org:memberOf foaf:Agent3 .

foaf:Person3 a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Brown"@en ;
    foaf:name "Alice Brown" ;
    rdfs:comment "Security Analyst, member of Security Operations Center."@en ;
    foaf:mbox "mailto:alice.brown@example.com" ;
    foaf:phone "+1-555-111-2222" ;
    org:memberOf foaf:Agent4 .

org:OrganizationalUnit1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Infrastructure Department"@en ;
    rdfs:comment "Department overseeing all IT infrastructure components."@en ;
    org:hasMember foaf:Agent1, foaf:Agent2, foaf:Agent5 .

org:OrganizationalUnit2 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Software Development Department"@en ;
    rdfs:comment "Department responsible for developing and maintaining software applications."@en ;
    org:hasMember foaf:Agent3 .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel1 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for DNS and web applications."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> .

noria:ProductModel2 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Cisco enterprise-class access layer switch."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> .

noria:ProductModel3 a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for hosting virtual machines."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> .

noria:ProductModel4 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Juniper universal routing platform for edge and core networks."@en ;
    noria:productManufacturedBy <http://www.juniper.net/organization> .

<http://www.dell.com/organization> a org:Organization ;
    rdfs:label "Dell Technologies"@en .

<http://www.cisco.com/organization> a org:Organization ;
    rdfs:label "Cisco Systems"@en .

<http://www.vmware.com/organization> a org:Organization ;
    rdfs:label "VMware Inc."@en .

<http://www.juniper.net/organization> a org:Organization ;
    rdfs:label "Juniper Networks"@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site1 a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC-MAIN-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en ;
    bot:hasSpace noria:Room1, noria:Room2 .

noria:Room1 a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Room dedicated to hosting physical servers."@en ;
    bot:hasZone noria:Locus1, noria:Locus3 ;
    bot:hasElement noria:Resource1, noria:Resource3, noria:Resource4, noria:Resource7, noria:Resource8 .

noria:Room2 a noria:Room ;
    rdfs:label "Network Equipment Room B"@en ;
    rdfs:comment "Room dedicated to hosting network devices like routers and firewalls."@en ;
    bot:hasZone noria:Locus2 ;
    bot:hasElement noria:Resource2, noria:Resource5, noria:Resource6 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasElement noria:Resource1, noria:Resource4 .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack B5 in Network Equipment Room B"@en ;
    rdfs:comment "Specific rack location for network devices."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "5"@en ;
    bot:hasElement noria:Resource2, noria:Resource5, noria:Resource6 .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack C2 in Server Room A"@en ;
    rdfs:comment "Specific rack location for virtualized infrastructure."@en ;
    noria:locusLine "C"@en ;
    noria:locusRow "2"@en ;
    bot:hasElement noria:Resource3, noria:Resource7, noria:Resource8 .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource1 a noria:Resource ;
    rdfs:label "Corporate DNS Server"@en ;
    rdfs:comment "Primary DNS server for corporate network, running on a physical machine."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-R740-001" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress observable:IPAddress1 .

noria:Resource2 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Main router for internal network traffic and internet egress."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel4 ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-MX204-001" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus2 ;
    noria:resourceManagementIPAddress observable:IPAddress2 .

noria:Resource3 a noria:Resource ;
    rdfs:label "Virtual Machine WebApp01"@en ;
    rdfs:comment "Virtual machine hosting the frontend of the Customer Portal application."@en ;
    noria:resourceManagedBy foaf:Agent3 ;
    noria:resourceHostName "webapp01.portal.example.com" ;
    noria:resourceProductModel noria:ProductModel3 ;
    noria:resourceLogisticId "ASSET-VM-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-ID-001" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application2 ;
    noria:locatedAtLocus noria:Locus3 ;
    noria:resourceManagementIPAddress observable:IPAddress3 ;
    noria:virtualServerStatus <https://w3id.org/noria/kos/Resource/OperationalState/Running> .

noria:Resource4 a noria:Resource ;
    rdfs:label "Database Server DB01"@en ;
    rdfs:comment "Physical server hosting the main database for internal applications."@en ;
    noria:resourceManagedBy foaf:Agent5 ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-R740-002" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application3 ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress observable:IPAddress4 .

noria:Resource5 a noria:Resource ;
    rdfs:label "Firewall FW01"@en ;
    rdfs:comment "Perimeter firewall protecting the corporate network."@en ;
    noria:resourceManagedBy foaf:Agent4 ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel2 ; # Using a switch model for example, could be a dedicated firewall model
    noria:resourceLogisticId "ASSET-FW-001" ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-CAT9300-001" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus2 ;
    noria:resourceManagementIPAddress observable:IPAddress5 .

noria:Resource6 a noria:Resource ;
    rdfs:label "Load Balancer LB01"@en ;
    rdfs:comment "Load balancer distributing traffic to web application servers."@en ;
