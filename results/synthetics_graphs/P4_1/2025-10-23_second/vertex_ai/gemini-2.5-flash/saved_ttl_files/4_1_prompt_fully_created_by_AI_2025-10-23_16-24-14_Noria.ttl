# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface1 a noria:NetworkInterface ;
    rdfs:label "eth0 on Corporate DNS Server"@en ;
    rdfs:comment "Primary network interface for DNS server."@en ;
    noria:networkInterfaceOf noria:Resource1 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink1 .

noria:NetworkInterface2 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/0 on Core Router 1"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to internal network segment."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceDescription "Internal LAN uplink."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:NetworkLink1 .

noria:NetworkInterface3 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/1 on Core Router 1"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to firewall."@en ;
    noria:networkInterfaceOf noria:Resource2 ;
    noria:networkInterfaceDescription "External WAN uplink to Firewall."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceConnects noria:NetworkLink2 .

noria:NetworkInterface4 a noria:NetworkInterface ;
    rdfs:label "vnic0 on Virtual Machine WebApp01"@en ;
    rdfs:comment "Virtual network interface for the web application VM."@en ;
    noria:networkInterfaceOf noria:Resource3 ;
    noria:networkInterfaceDescription "Virtual NIC for web traffic."@en ;
    noria:networkInterfaceType "virtual"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink3 .

noria:NetworkInterface5 a noria:NetworkInterface ;
    rdfs:label "eth1 on Database Server DB01"@en ;
    rdfs:comment "Dedicated network interface for database replication."@en ;
    noria:networkInterfaceOf noria:Resource4 ;
    noria:networkInterfaceDescription "Replication link to secondary DB server."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NetworkInterface6 a noria:NetworkInterface ;
    rdfs:label "port1 on Firewall FW01"@en ;
    rdfs:comment "Interface connecting firewall to core router."@en ;
    noria:networkInterfaceOf noria:Resource5 ;
    noria:networkInterfaceDescription "Uplink from Core Router."@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink2 .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink1 a noria:NetworkLink ;
    rdfs:label "Internal LAN Segment A"@en ;
    rdfs:comment "Local Area Network segment connecting DNS server and Core Router."@en ;
    noria:networkLinkId "LAN-SEG-A-001" ;
    noria:networkLinkType "Ethernet"@en ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource2 ;
    noria:resourceManagedBy foaf:Agent2 .

noria:NetworkLink2 a noria:NetworkLink ;
    rdfs:label "WAN Link to Firewall"@en ;
    rdfs:comment "Wide Area Network link between Core Router and Firewall."@en ;
    noria:networkLinkId "WAN-FW-001" ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2021-06-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource2 ;
    noria:networkLinkTerminationResourceDestination noria:Resource5 ;
    noria:resourceManagedBy foaf:Agent2 .

noria:NetworkLink3 a noria:NetworkLink ;
    rdfs:label "Load Balancer to WebApp VM Link"@en ;
    rdfs:comment "Internal link from Load Balancer to WebApp Virtual Machine."@en ;
    noria:networkLinkId "LB-VM-001" ;
    noria:networkLinkType "Virtual Ethernet"@en ;
    noria:networkLinkInstallationDate "2023-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource6 ;
    noria:networkLinkTerminationResourceDestination noria:Resource3 ;
    noria:resourceManagedBy foaf:Agent3 .

