    rdfs:comment "Provides internet connectivity for all corporate users and services."@en ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "Internet Gateway Management"@en ;
    noria:elementManagedBy foaf:Agent2 .

noria:Application2 a noria:Application ;
