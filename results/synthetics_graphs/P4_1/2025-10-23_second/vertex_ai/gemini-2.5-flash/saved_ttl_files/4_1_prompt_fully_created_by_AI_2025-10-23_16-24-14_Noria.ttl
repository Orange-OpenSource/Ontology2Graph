noria:Application4 a noria:Application ;
    rdfs:label "Monitoring Platform"@en ;
    rdfs:comment "Centralized platform for monitoring IT infrastructure and applications."@en ;
    noria:applicationModelIdentifier "MON-PLAT" ;
    noria:applicationNumericalIdentifier 1004 ;
    noria:applicationShortIdentifier "MONITOR" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/management-tool> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
