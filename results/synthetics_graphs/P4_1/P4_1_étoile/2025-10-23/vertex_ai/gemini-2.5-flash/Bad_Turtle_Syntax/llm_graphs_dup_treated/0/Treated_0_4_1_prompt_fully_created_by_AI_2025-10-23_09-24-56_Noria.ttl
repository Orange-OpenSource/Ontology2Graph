# =============================================================================
# Agents (foaf:Agent & org:OrganizationalUnit)
# =============================================================================

noria:Agent_DNSAdminTeam_extra_node_0 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server_extra_node_0 management and configuration."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_0> ;
    noria:agentInstructions "Contact via ticketing system for non-urgent issues, direct call for critical_extra_node_0 outages."@en .

noria:Agent_NOC_extra_node_0 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "24/7 team monitoring_extra_node_0 network infrastructure_extra_node_0 and handling incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_0> ;
    noria:agentInstructions "Always call the hotline for critical_extra_node_0 network issues."@en .

noria:Agent_SecurityTeam_extra_node_0 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring_extra_node_0 and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SecureChat_extra_node_0> ;
    noria:agentInstructions "Follow established security incident response procedures."@en .

noria:Agent_JohnDoe_extra_node_0 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the DNS Admin Team."@en ;
    foaf:mbox <mailto:john.doe@example.com_extra_node_0> ;
    foaf:holdsAccount noria:CUid_JohnDoe_extra_node_0 .

noria:CUid_JohnDoe_extra_node_0 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User_extra_node_0 ID"@en ;
    rdfs:comment "Corporate login for John Doe."@en ;
    foaf:accountName "jdoe" .

