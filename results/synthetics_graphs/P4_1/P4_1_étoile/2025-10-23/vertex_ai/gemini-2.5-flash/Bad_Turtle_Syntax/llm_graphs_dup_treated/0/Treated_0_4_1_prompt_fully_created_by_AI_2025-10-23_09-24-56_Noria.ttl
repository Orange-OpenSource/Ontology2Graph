noria:TroubleTicket_DNSOutage001_extra_node_0 a noria:TroubleTicket ;
    rdfs:label "DNS Server_extra_node_0 Outage Incident - TT001"@en ;
    rdfs:comment "Critical_extra_node_0 incident: Corporate DNS server_extra_node_0 unreachable, impacting internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical_extra_node_0> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress_extra_node_0> ;
    noria:troubleTicketRelatedService noria:Application_CorpInternetAccess_extra_node_0 ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01_extra_node_0 ;
    noria:troubleTicketRelatedParty noria:Agent_NOC_extra_node_0 ;
    noria:troubleTicketRelatedParty noria:Agent_DNSAdminTeam_extra_node_0 ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog_extra_node_0 ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision_extra_node_0> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure_extra_node_0> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention_extra_node_0> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown_extra_node_0> ;
    noria:troubleTicketCause "Misconfigured firewall rule blocking DNS traffic."@en ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring" ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:documentStatusHistory noria:EventRecord_DNSOutageLog_extra_node_0 . # Initial status change

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote_DNSOutage001_Note1_extra_node_0 a noria:TroubleTicketNote ;
    rdfs:label "TT001 - Initial Diagnosis_extra_node_0 Note"@en ;
    rdfs:comment "Initial checks confirm DNS service is not responding on port 53. No local issues found on the server_extra_node_0 itself. Suspecting network or firewall."@en ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage001_extra_node_0 ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_NOC_extra_node_0 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_0> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis_extra_node_0> .

noria:TroubleTicketNote_DNSOutage001_Note2_extra_node_0 a noria:TroubleTicketNote ;
    rdfs:label "TT001 - Firewall_extra_node_0 Rule Update Note"@en ;
    rdfs:comment "Identified a recently deployed firewall rule on fw01 blocking outbound DNS traffic. Rule has been temporarily disabled. Monitoring for service restoration."@en ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage001_extra_node_0 ;
    dcterms:created "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JohnDoe_extra_node_0 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_0> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements_extra_node_0> ;
    noria:troubleTicketNoteCorrelatedExecution noria:ChangeRequest_FirewallRuleUpdate_extra_node_0 . # Link to the change that fixed it

