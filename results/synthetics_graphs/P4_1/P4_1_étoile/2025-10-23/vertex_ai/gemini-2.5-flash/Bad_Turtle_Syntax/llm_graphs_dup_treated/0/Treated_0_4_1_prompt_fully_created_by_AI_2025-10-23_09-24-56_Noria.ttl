noria:EventRecord_DNSOutageLog_extra_node_0 a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_0 Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server_extra_node_0 dns01.corp.example.com became unreachable."@en ;
