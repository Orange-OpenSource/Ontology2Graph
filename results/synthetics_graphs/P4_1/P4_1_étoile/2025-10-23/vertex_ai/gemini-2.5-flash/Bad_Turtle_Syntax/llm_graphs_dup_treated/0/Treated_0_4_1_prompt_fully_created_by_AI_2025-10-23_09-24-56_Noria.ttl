# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_FirewallRuleDisable_extra_node_0 a noria:OperationPlan ;
    rdfs:label "Firewall_extra_node_0 Rule Disable Procedure"@en ;
    rdfs:comment "Standard_extra_node_0 operating procedure for temporarily disabling a firewall rule."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_VerifyImpact_extra_node_0 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ServiceRestored_extra_node_0 .

noria:ActionPreCondition_VerifyImpact_extra_node_0 a noria:ActionPreCondition ;
    rdfs:label "Verify Impact Before Disabling Rule"@en ;
    rdfs:comment "Ensure that disabling the rule will mitigate the current issue without causing new critical_extra_node_0 problems."@en .

noria:ActionPostCondition_ServiceRestored_extra_node_0 a noria:ActionPostCondition ;
    rdfs:label "Service Restored Confirmation"@en ;
    rdfs:comment "Confirm that the affected service (e.g., DNS resolution) is fully restored and operational."@en .

noria:ChangeRequest_FirewallRuleUpdate_extra_node_0 noria:actionCorrelatedOperationPlan noria:OperationPlan_FirewallRuleDisable_extra_node_0 .

