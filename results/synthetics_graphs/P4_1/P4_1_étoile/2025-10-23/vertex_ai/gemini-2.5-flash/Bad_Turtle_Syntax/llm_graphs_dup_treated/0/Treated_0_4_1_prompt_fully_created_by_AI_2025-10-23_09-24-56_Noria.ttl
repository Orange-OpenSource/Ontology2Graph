    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_0 ;
    noria:logOriginatingAgent noria:Agent_JohnDoe_extra_node_0 .

noria:EventRecord_DNSUpLog_extra_node_0 a noria:EventRecord ;
