    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01_extra_node_0 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_0 ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Critical_extra_node_0> .

noria:EventRecord_FirewallChangeLog_extra_node_0 a noria:EventRecord ;
