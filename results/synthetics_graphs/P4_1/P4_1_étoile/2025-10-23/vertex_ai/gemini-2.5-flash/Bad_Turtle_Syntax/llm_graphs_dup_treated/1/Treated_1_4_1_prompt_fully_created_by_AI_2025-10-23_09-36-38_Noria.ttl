# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetIF_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Primary network interface for DNS services."@en ;
    noria:networkInterfaceType "physical" ;
