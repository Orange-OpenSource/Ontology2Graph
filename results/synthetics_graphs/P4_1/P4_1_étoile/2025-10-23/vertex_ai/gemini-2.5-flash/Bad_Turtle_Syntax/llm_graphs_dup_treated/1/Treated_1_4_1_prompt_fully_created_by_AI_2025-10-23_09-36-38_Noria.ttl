# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OpPlan_DNS_Failover a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over DNS services to a secondary server."@en ;
    skos:example "Steps include verifying secondary server health, updating load balancer, and monitoring resolution."@en ;
    noria:operationPlanPreCondition noria:PreCond_DNS_Unreachable ;
    noria:operationPlanPostCondition noria:PostCond_DNS_Resolving .

noria:OpPlan_Router_Rollback a noria:OperationPlan ;
    rdfs:label "Router Configuration Rollback Procedure"@en ;
    rdfs:comment "Procedure to revert router configuration to a previous stable state."@en ;
    skos:example "Steps include loading previous configuration, verifying connectivity, and notifying stakeholders."@en ;
    noria:operationPlanPreCondition noria:PreCond_Router_ConfigError ;
    noria:operationPlanPostCondition noria:PostCond_Router_ConfigRestored .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:PreCond_DNS_Unreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Unreachable Pre-condition"@en ;
    rdfs:comment "Condition: Primary DNS server is not responding to queries."@en ;
    skos:example "Ping to DNS server fails, dig/nslookup queries fail."@en .

noria:PostCond_DNS_Resolving a noria:ActionPostCondition ;
    rdfs:label "DNS Resolving Post-condition"@en ;
    rdfs:comment "Condition: DNS queries are successfully resolved by the secondary server."@en ;
    skos:example "Dig/nslookup queries return correct IP addresses, client machines can access internet."@en .

noria:PreCond_Router_ConfigError a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Error Pre-condition"@en ;
    rdfs:comment "Condition: Routing table shows incorrect entries or routes are missing."@en ;
    skos:example "Show ip route command output indicates issues, traceroute fails."@en .

noria:PostCond_Router_ConfigRestored a noria:ActionPostCondition ;
    rdfs:label "Router Configuration Restored Post-condition"@en ;
    rdfs:comment "Condition: Router configuration is reverted, and network connectivity is restored."@en ;
    skos:example "Show ip route command output is correct, network services are reachable."@en .

# =============================================================================
# Additional connections for density
# =============================================================================

# Link Trouble Tickets to Operation Plans (conceptual, via related actions)
noria:TT_DNSOutage noria:troubleTicketCharacteristic noria:OpPlan_DNS_Failover .
noria:TT_RouterConfigIssue noria:troubleTicketCharacteristic noria:OpPlan_Router_Rollback .

# Link Event Records to Trouble Ticket Notes (as correlated executions)
noria:TTNote_DNSOutage_1 noria:troubleTicketNoteCorrelatedExecution noria:Event_DNS_Down .
noria:TTNote_CustomerPortalSlow_1 noria:troubleTicketNoteCorrelatedExecution noria:Event_WebSrv_HighCPU .

# Link Agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_AdminTeam noria:agentManagesResource noria:Resource_DNS01 .
foaf:Agent_NetworkOps noria:agentManagesResource noria:Resource_RouterCore01, noria:Resource_Firewall01 .
foaf:Agent_AppDev noria:agentManagesResource noria:Resource_WebSrv01, noria:Resource_DB01 .

# Link Applications to resources they use (inverse of resourceForApplication)
noria:App_CustomerPortal seas:subSystem noria:Resource_WebSrv01, noria:Resource_DB01 .
noria:App_CorpInternetAccess seas:subSystem noria:Resource_Firewall01 .

# Link Application Modules to Services (inverse of seas:subSystemOf)
noria:Service_ExternalConnectivity seas:subSystem noria:AppMod_CorpInternetAccess_Prod .
noria:Service_CustomerFacing seas:subSystem noria:AppMod_CustomerPortal_Prod .

# Link resources to their network interfaces (inverse of networkInterfaceOf)
noria:Resource_DNS01 seas:hasConnectionPoint noria:NetIF_DNS01_Eth0 .
noria:Resource_RouterCore01 seas:hasConnectionPoint noria:NetIF_RouterCore01_Gi0_0_1 .
noria:Resource_WebSrv01 seas:hasConnectionPoint noria:NetIF_WebSrv01_Eth0 .
noria:Resource_Firewall01 seas:hasConnectionPoint noria:NetIF_Firewall01_Ext .

# Link network interfaces to network links (inverse of networkInterfaceConnects)
noria:NetLink_DC_Core seas:connectsSystemAt noria:NetIF_RouterCore01_Gi0_0_1, noria:NetIF_Firewall01_Ext .
noria:NetLink_DNS_Web seas:connectsSystemAt noria:NetIF_DNS01_Eth0, noria:NetIF_WebSrv01_Eth0 .

# Example of a virtual server status
