    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2020-07-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_PatchPanel_P1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

<http://example.com/ip/10.0.0.1> a observable:IPAddress ;
    rdfs:label "10.0.0.1"@en ;
    observable:ipAddressValue "10.0.0.1" .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
