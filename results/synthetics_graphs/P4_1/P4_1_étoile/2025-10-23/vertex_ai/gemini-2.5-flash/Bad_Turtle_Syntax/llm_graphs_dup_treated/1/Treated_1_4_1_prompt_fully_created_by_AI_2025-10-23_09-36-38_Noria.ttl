noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various applications."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization_extra_node_2> . # Assuming a URI for Dell organization_extra_node_2

<http://www.dell.com/organization_extra_node_2> a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of Dell PowerEdge servers."@en .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch/router series."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization_extra_node_2> . # Assuming a URI for Cisco organization_extra_node_2

<http://www.cisco.com/organization_extra_node_2> a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of Cisco networking equipment."@en .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for hosting virtual machines."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization_extra_node_2> . # Assuming a URI for VMware organization_extra_node_2

<http://www.vmware.com/organization_extra_node_2> a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Developer of virtualization software."@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

<http://example.com/ip/192.168.1.10> a observable:IPAddress ;
    rdfs:label "192.168.1.10"@en ;
    observable:ipAddressValue "192.168.1.10" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the data center, located in London Office."@en ;
