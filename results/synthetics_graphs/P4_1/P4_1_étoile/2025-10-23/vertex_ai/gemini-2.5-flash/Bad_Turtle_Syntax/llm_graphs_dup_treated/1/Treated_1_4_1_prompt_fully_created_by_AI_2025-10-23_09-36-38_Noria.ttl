noria:Event_DNS_Down a noria:EventRecord ;
    rdfs:label "DNS Server Down Alert"@en ;
    rdfs:comment "Automated alert: DNS service on dns01.corp.example.com is down."@en ;
    noria:loggingTime "2024-04-20T07:59:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "Service 'named' on host 'dns01.corp.example.com' is CRITICAL."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_2> .

noria:Event_Router_LinkDown a noria:EventRecord ;
    rdfs:label "Router Link Down Notification"@en ;
    rdfs:comment "Automated notification: GigabitEthernet0/0/1 on router-core-ldn01 changed state to down."@en ;
    noria:loggingTime "2024-04-20T13:58:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_2> .

noria:Event_WebSrv_HighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Warning"@en ;
    rdfs:comment "Automated warning: CPU utilization on web01.corp.example.com is above 80%."@en ;
    noria:loggingTime "2024-04-20T09:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "CPU utilization on web01.corp.example.com: 85% (threshold 80%)."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_TT_DNSOutage_StatusChange a noria:EventRecord ;
    rdfs:label "Trouble Ticket DNS Outage Status Change"@en ;
    rdfs:comment "Status of TT_DNSOutage changed to InProgress."@en ;
    noria:loggingTime "2024-04-20T08:06:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://example.com/ticketing-system> ; # Assuming a URI for a ticketing system
    noria:logOriginatingAgent foaf:Agent_AdminTeam ;
    noria:logText "Trouble Ticket TT_DNSOutage status updated to InProgress by Admin Team."@en ;
    dcterms:references noria:TT_DNSOutage .

<http://example.com/ticketing-system> a noria:Application ;
    rdfs:label "ITSM Ticketing System"@en ;
    rdfs:comment "Application used for managing incidents and changes."@en ;
    noria:applicationType <kos/application/type/infrastructure> .

noria:Event_CR_RouterConfig_Start a noria:EventRecord ;
    rdfs:label "Change Request Router Config Start"@en ;
    rdfs:comment "Implementation of CR_RouterConfig started."@en ;
    noria:loggingTime "2024-04-21T02:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://example.com/change-management-system> ; # Assuming a URI for a change management system
    noria:logOriginatingAgent foaf:Agent_NetworkOps ;
    noria:logText "Change Request CR_RouterConfig implementation started by Network Operations Team."@en ;
    dcterms:references noria:CR_RouterConfig .

<http://example.com/change-management-system> a noria:Application ;
    rdfs:label "ITSM Change Management System"@en ;
    rdfs:comment "Application used for managing IT changes."@en ;
    noria:applicationType <kos/application/type/infrastructure> .

