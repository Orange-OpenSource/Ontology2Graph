    noria:applicationModuleSlaLevelDate "2023-03-15T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:Org_NetworkAdmin a org:OrganizationalUnit ;
    rdfs:label "Network Administration Unit"@en ;
    rdfs:comment "Organizational unit for network administration."@en .

noria:Org_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Organizational unit for network operations."@en .

noria:Org_AppDevOps a org:OrganizationalUnit ;
    rdfs:label "Application DevOps Unit"@en ;
    rdfs:comment "Organizational unit for application development and operations."@en .

noria:Org_CustomerSupport a org:OrganizationalUnit ;
    rdfs:label "Customer Support Unit"@en ;
    rdfs:comment "Organizational unit for customer support."@en .

# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service_EnterpriseConnectivity a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing network connectivity to all enterprise locations and users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> .

noria:Service_CustomerFacingWeb a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "Service encompassing all web applications directly accessible by customers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> .

# Linking Application Modules to Services (using seas:subSystemOf as suggested)
noria:ApplicationModule_InternetAccess_Prod seas:subSystemOf noria:Service_EnterpriseConnectivity .
noria:ApplicationModule_CustomerPortal_Prod seas:subSystemOf noria:Service_CustomerFacingWeb .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN. Ping failed."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating GigabitEthernet0/0/0 on Core Router 1 went down."@en ;
    noria:loggingTime "2024-04-20T08:55:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1 ;
    noria:logOriginatingManagementSystem noria:Application_NMS .

noria:EventRecord_LoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on the Customer Portal VM."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:logText "Authentication failed for user 'baduser' from IP 203.0.113.42 on vm-portal-01."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingManagedObject noria:Resource_VM_CustomerPortal ;
    noria:logOriginatingManagementSystem noria:Application_SIEM ;
    noria:logOriginatingAgent noria:Agent_ExternalAttacker .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Infrastructure Monitoring System"@en ;
    rdfs:comment "Application responsible for monitoring IT infrastructure health."@en ;
    noria:applicationType <kos/application/type/monitoring-tool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

noria:Application_NMS a noria:Application ;
    rdfs:label "Network Management System"@en ;
    rdfs:comment "Application for managing and monitoring network devices."@en ;
    noria:applicationType <kos/application/type/network-management> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

noria:Agent_ExternalAttacker a foaf:Agent ;
    rdfs:label "External Attacker"@en ;
    rdfs:comment "Hypothetical external entity attempting unauthorized access."@en .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket_DNSOutage a noria:TroubleTicket ;
    rdfs:label "Critical DNS Server Outage"@en ;
    rdfs:comment "Incident reported due to primary DNS server being unreachable, impacting internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketCause "Network connectivity loss to DNS server."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedService noria:Application_CorporateInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty noria:Agent_DNSAdminTeam ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:documentExternalId "TT-20240420-001" ;
    noria:documentHRef "http://ticketing.example.com/TT-20240420-001" .

noria:TroubleTicket_CustomerPortalSlowness a noria:TroubleTicket ;
    rdfs:label "Customer Portal Performance Degradation"@en ;
    rdfs:comment "Customers reporting slow response times on the portal."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketCause "Unidentified application bottleneck."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedService noria:Application_CustomerPortal ;
    noria:troubleTicketRelatedResource noria:Resource_VM_CustomerPortal ;
    noria:troubleTicketRelatedParty noria:Agent_JaneSmith ;
    noria:documentExternalId "TT-20240420-002" ;
    noria:documentHRef "http://ticketing.example.com/TT-20240420-002" .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote_DNSDiag1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage - Initial Diagnosis"@en ;
    rdfs:comment "Initial checks show no power loss on DNS01. Network team investigating link status."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JohnDoe ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage .

noria:TroubleTicketNote_PortalRestart a noria:TroubleTicketNote ;
    rdfs:label "Customer Portal - VM Restart Attempt"@en ;
    rdfs:comment "Attempted restarting the Customer Portal VM. No immediate improvement observed."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:created "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JaneSmith ;
    dcterms:isPartOf noria:TroubleTicket_CustomerPortalSlowness .

# =============================================================================
# Change Requests (noria:ChangeRequest)
# =============================================================================

noria:ChangeRequest_RouterUpgrade a noria:ChangeRequest ;
    rdfs:label "Core Router Software Upgrade"@en ;
    rdfs:comment "Planned software upgrade for Core Router 1 to enhance security and performance."@en ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ;
    noria:changeRequestPlannedStartTime "2024-05-10T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-10T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestImpact noria:Resource_RouterCore1 ;
    noria:changeRequestImpact noria:ApplicationModule_InternetAccess_Prod ;
    noria:changeRequestInitiatorParty noria:Agent_NetworkOpsTeam ;
    noria:changeRequestPilotParty noria:Agent_JohnDoe ;
    noria:changeRequestActorParty noria:Agent_NetworkOpsTeam ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestIsRegulated true ;
    noria:documentExternalId "CR-20240510-001" ;
    noria:documentHRef "http://changemgmt.example.com/CR-20240510-001" .

noria:ChangeRequest_FirewallRuleAdd a noria:ChangeRequest ;
    rdfs:label "Add Firewall Rule for New Service"@en ;
    rdfs:comment "Request to add a new firewall rule to allow traffic for a new internal service."@en ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestCategory <kos/ChangeRequest/category/Configuration> ;
    noria:changeRequestPlannedStartTime "2024-04-25T18:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-25T18:30:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestImpact noria:Resource_RouterCore1 ; # Assuming firewall is integrated or managed by router
    noria:changeRequestInitiatorParty noria:Agent_AppDevTeam ;
    noria:changeRequestActorParty noria:Agent_NetworkOpsTeam ;
    noria:changeRequestOutageDuration "PT0S"^^xsd:duration ;
    noria:documentExternalId "CR-20240425-002" ;
    noria:documentHRef "http://changemgmt.example.com/CR-20240425-002" .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_RouterFirmwareUpdate a noria:OperationPlan ;
    rdfs:label "Router Firmware Update Procedure"@en ;
    rdfs:comment "Standard operating procedure for updating router firmware, including pre-checks and rollback plan."@en .

noria:OperationPlan_VMRestart a noria:OperationPlan ;
    rdfs:label "Virtual Machine Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting a virtual machine, including application health checks."@en .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:PreCondition_NetworkConnectivityOK a noria:ActionPreCondition ;
    rdfs:label "Network Connectivity OK"@en ;
    rdfs:comment "Verify network connectivity to the device before starting the operation."@en .

noria:PostCondition_ServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Service Restored"@en ;
    rdfs:comment "Confirm that the affected service is fully operational after the intervention."@en .

noria:OperationPlan_RouterFirmwareUpdate noria:operationPlanPreCondition noria:PreCondition_NetworkConnectivityOK ;
    noria:operationPlanPostCondition noria:PostCondition_ServiceRestored .

noria:OperationPlan_VMRestart noria:operationPlanPostCondition noria:PostCondition_ServiceRestored .

# =============================================================================
# Connecting more entities for density
# =============================================================================

# Link SIEM to DNS01 for log collection
noria:Resource_DNS01 noria:resourceForApplication noria:Application_SIEM .
noria:Resource_RouterCore1 noria:resourceForApplication noria:Application_SIEM .
noria:Resource_VM_CustomerPortal noria:resourceForApplication noria:Application_SIEM .

# Link DNS Admin Team to Core DNS Application
noria:Agent_DNSAdminTeam noria:agentManagesResource noria:Application_CoreDNS .

# Link Network Ops Team to Corporate Internet Access Application
noria:Agent_NetworkOpsTeam noria:agentManagesResource noria:Application_CorporateInternetAccess .

# Link App Dev Team to Customer Portal Application
noria:Agent_AppDevTeam noria:agentManagesResource noria:Application_CustomerPortal .

# Link John Doe to DNS Admin Team (as an organizational unit member, though foaf:Agent is used for both)
# For simplicity, I'll link John Doe directly to a resource he manages.
noria:Agent_JohnDoe noria:agentManagesResource noria:Resource_DNS01 .

# Link Jane Smith to Customer Portal VM
noria:Agent_JaneSmith noria:agentManagesResource noria:Resource_VM_CustomerPortal .

# Add a virtual server status for the VM
noria:Resource_VM_CustomerPortal noria:virtualServerStatus <kos/Resource/OperationalState/up> .

# Add more optical power details for network interfaces
noria:NetworkInterface_RouterCore1_Gi0_0_0 noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Document status history for TroubleTicket
noria:TroubleTicket_DNSOutage noria:documentStatusHistory noria:EventRecord_DNSOutageStatusChange .

noria:EventRecord_DNSOutageStatusChange a noria:EventRecord ;
    rdfs:label "DNS Outage Status Change to InProgress"@en ;
    noria:loggingTime "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240420-001 status changed from Initialised to InProgress."@en ;
    noria:logOriginatingManagementSystem noria:Application_TicketingSystem .

noria:Application_TicketingSystem a noria:Application ;
    rdfs:label "ITSM Ticketing System"@en ;
    rdfs:comment "Application for managing IT service incidents and requests."@en ;
    noria:applicationType <kos/application/type/itsm> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

# Document status history for ChangeRequest
noria:ChangeRequest_RouterUpgrade noria:documentStatusHistory noria:EventRecord_CRStatusChange .

noria:EventRecord_CRStatusChange a noria:EventRecord ;
    rdfs:label "CR Router Upgrade Status Change to Scheduled"@en ;
    noria:loggingTime "2024-04-22T15:00:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-20240510-001 status changed from Approved to Scheduled."@en ;
    noria:logOriginatingManagementSystem noria:Application_ChangeManagementSystem .

noria:Application_ChangeManagementSystem a noria:Application ;
    rdfs:label "Change Management System"@en ;
    rdfs:comment "Application for managing IT changes."@en ;
    noria:applicationType <kos/application/type/itsm> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

# Add a related party to a Change Request
noria:ChangeRequest_RouterUpgrade noria:changeRequestRelatedParty noria:Agent_NetworkOpsTeam .
noria:ChangeRequest_FirewallRuleAdd noria:changeRequestRelatedParty noria:Agent_SecurityTeam .

# Add problem responsibility to a Trouble Ticket
noria:TroubleTicket_DNSOutage noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> .
noria:TroubleTicket_CustomerPortalSlowness noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> .

# Add trouble ticket impacts
noria:TroubleTicket_DNSOutage noria:troubleTicketImpacts noria:Application_CorporateInternetAccess ;
    noria:troubleTicketImpacts noria:Resource_DNS01 .

noria:TroubleTicket_CustomerPortalSlowness noria:troubleTicketImpacts noria:Application_CustomerPortal ;
    noria:troubleTicketImpacts noria:Resource_VM_CustomerPortal .

# Add a correlated execution to a TroubleTicketNote
noria:TroubleTicketNote_PortalRestart noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer_VM_Restart_Attempt .

noria:ProcedureExecutionContainer_VM_Restart_Attempt a pep:ProcedureExecutionContainer ;
    rdfs:label "VM Restart Execution Container"@en ;
    rdfs:comment "Container for the execution records related to the VM restart attempt."@en .

# Add an EventRecord as a member of the ProcedureExecutionContainer
noria:EventRecord_VM_Restart_Command a noria:EventRecord ;
    rdfs:label "VM Restart Command Log"@en ;
    noria:loggingTime "2024-04-20T10:40:00Z"^^xsd:dateTime ;
    noria:logText "Command 'systemctl restart customer-portal-app' executed on vm-portal-01 by Jane Smith."@en ;
    noria:logOriginatingManagedObject noria:Resource_VM_CustomerPortal ;
    noria:logOriginatingAgent noria:Agent_JaneSmith ;
    # pep:member is not in NORIA, but pep:ProcedureExecutionContainer is a subclass of pep:ProcedureExecution, which has pep:hasCommand and pep:hasSimpleResult.
    # The instruction says "track the corresponding EventRecord through the ldp:member property" but ldp is forbidden.
    # I will use dcterms:hasPart as a generic relation for containment within the container.
    dcterms:hasPart noria:ProcedureExecutionContainer_VM_Restart_Attempt .

# Add a corporate user identifier
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount noria:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount noria:Agent_JaneSmith .
