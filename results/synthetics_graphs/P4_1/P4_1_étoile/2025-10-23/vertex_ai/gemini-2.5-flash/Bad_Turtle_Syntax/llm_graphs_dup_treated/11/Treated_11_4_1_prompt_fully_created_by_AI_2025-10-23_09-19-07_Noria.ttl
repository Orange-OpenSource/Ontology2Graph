@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent)
# =============================================================================

noria:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and operations."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

noria:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure, including routers and links."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Immediate escalation for network outages. Use dedicated incident management platform."@en .

noria:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the Customer Portal application."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "For bugs, create a JIRA ticket. For urgent issues, ping on Slack."@en .

noria:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/soc-platform> ;
    noria:agentInstructions "All security alerts are routed through the SIEM. Do not contact directly unless instructed."@en .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual IT administrator, member of the DNS Admin Team."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Email for non-urgent requests."@en .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead developer for the Customer Portal application."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Contact for critical application issues."@en .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various enterprise applications."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "High-performance router series for enterprise and service provider networks."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor for virtualized environments."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

# =============================================================================
# Locations (noria:Room, noria:Locus)
# =============================================================================

noria:Room_DataCenterA a noria:Room ;
    rdfs:label "Primary Data Center A"@en ;
    rdfs:comment "Main data center facility for corporate IT infrastructure."@en .

noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location within Data Center A for server deployment."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "23"@en .

noria:Locus_RackA1_U24 a noria:Locus ;
    rdfs:label "Rack A1, Unit 24"@en ;
    rdfs:comment "Specific location within Data Center A for server deployment."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "24"@en .

noria:Locus_RackB2_U10 a noria:Locus ;
    rdfs:label "Rack B2, Unit 10"@en ;
    rdfs:comment "Specific location within Data Center A for network equipment."@en ;
    noria:locusLine "B2"@en ;
    noria:locusRow "10"@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, physical host."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CoreDNS ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_RouterCore1 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Main router for the corporate backbone network."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CorporateInternetAccess ;
    noria:locatedAtLocus noria:Locus_RackB2_U10 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_VM_CustomerPortal a noria:Resource ;
    rdfs:label "Customer Portal VM"@en ;
    rdfs:comment "Virtual machine hosting the Customer Portal application."@en ;
    noria:resourceManagedBy noria:Agent_AppDevTeam ;
    noria:resourceHostName "vm-portal-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceSerialNumber "VM-CP-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:locatedAtLocus noria:Locus_RackA1_U24 ; # Assuming the VM runs on a host in this locus
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.50> .

noria:Resource_SIEMServer a noria:Resource ;
    rdfs:label "SIEM Log Server"@en ;
    rdfs:comment "Server dedicated to collecting and analyzing security logs."@en ;
    noria:resourceManagedBy noria:Agent_SecurityTeam ;
    noria:resourceHostName "siem-log-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-SIEM-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_SIEM ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on DNS01"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Management and DNS traffic interface."@en ;
    noria:networkInterfaceType "physical"@en .

noria:NetworkInterface_RouterCore1_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on RouterCore1"@en ;
    rdfs:comment "Uplink interface from Core Router 1 to ISP."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceDescription "ISP Uplink 1"@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 .

noria:NetworkInterface_RouterCore1_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on RouterCore1"@en ;
    rdfs:comment "Internal network interface from Core Router 1 to corporate LAN."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 60 ;
    noria:networkInterfaceDescription "Corporate LAN connection"@en ;
    noria:networkInterfaceType "physical"@en .

noria:NetworkInterface_VM_Portal_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Customer Portal VM"@en ;
    rdfs:comment "Virtual network interface for the Customer Portal VM."@en ;
    noria:networkInterfaceOf noria:Resource_VM_CustomerPortal ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Application traffic interface."@en ;
    noria:networkInterfaceType "virtual"@en .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_ISP_Uplink1 a noria:NetworkLink ;
    rdfs:label "ISP Uplink 1 Link"@en ;
    rdfs:comment "Physical link connecting Core Router 1 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-ISP-UPLINK1" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore1 ; # One end of the link
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam .

noria:NetworkLink_LAN_Core1_DNS01 a noria:NetworkLink ;
    rdfs:label "LAN Link Core1 to DNS01"@en ;
    rdfs:comment "Internal LAN link connecting Core Router 1 to DNS01 server."@en ;
    noria:networkLinkId "NL-LAN-CORE1-DNS01" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore1 ;
    noria:networkLinkTerminationResource noria:Resource_DNS01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam .

noria:NetworkInterface_RouterCore1_Gi0_0_1 noria:networkInterfaceConnects noria:NetworkLink_LAN_Core1_DNS01 .
noria:NetworkInterface_DNS01_Eth0 noria:networkInterfaceConnects noria:NetworkLink_LAN_Core1_DNS01 .
noria:NetworkInterface_RouterCore1_Gi0_0_0 noria:networkInterfaceConnects noria:NetworkLink_ISP_Uplink1 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application_CorporateInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "Internet Gateway Management"@en .

noria:Application_CoreDNS a noria:Application ;
    rdfs:label "Core DNS Service"@en ;
    rdfs:comment "Centralized DNS resolution service for internal and external queries."@en ;
    noria:applicationType <kos/application/type/service-platform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Infrastructure Services"@en ;
    noria:applicationFunctionalSubDomain "Name Resolution"@en .

noria:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Self-Service Portal"@en .

noria:Application_SIEM a noria:Application ;
    rdfs:label "Security Information and Event Management"@en ;
    rdfs:comment "System for real-time analysis of security alerts generated by network hardware and applications."@en ;
    noria:applicationType <kos/application/type/security-platform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Security Operations"@en ;
    noria:applicationFunctionalSubDomain "Threat Detection and Response"@en .

