@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix time: <http://www.w3.org/2006/time#> .

# =============================================================================
# KOS Concept Schemes and Concepts
# =============================================================================

# KOS Schemes
<kos/application/type> a skos:ConceptScheme ; rdfs:label "Application Type Scheme"@en .
<kos/application/business-importance> a skos:ConceptScheme ; rdfs:label "Application Business Importance Scheme"@en .
<kos/application/status> a skos:ConceptScheme ; rdfs:label "Application Status Scheme"@en .
<kos/TroubleTicket/severity> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Severity Scheme"@en .
<kos/TroubleTicket/type> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Type Scheme"@en .
<kos/TroubleTicket/origin> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Origin Scheme"@en .
<kos/TroubleTicket/status> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Status Scheme"@en .
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Trouble Category Scheme"@en .
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en .
<kos/TroubleTicket/commentType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Comment Type Scheme"@en .
<kos/TroubleTicket/operationType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Operation Type Scheme"@en .
<kos/ChangeRequest/type> a skos:ConceptScheme ; rdfs:label "Change Request Type Scheme"@en .
<kos/ChangeRequest/cause> a skos:ConceptScheme ; rdfs:label "Change Request Cause Scheme"@en .
<kos/ChangeRequest/status> a skos:ConceptScheme ; rdfs:label "Change Request Status Scheme"@en .
<kos/Resource/type> a skos:ConceptScheme ; rdfs:label "Resource Type Scheme"@en .
<kos/Resource/LifecycleState> a skos:ConceptScheme ; rdfs:label "Resource Lifecycle State Scheme"@en .
<kos/Resource/OperationalState> a skos:ConceptScheme ; rdfs:label "Resource Operational State Scheme"@en .
<kos/Resource/AdministrativeState> a skos:ConceptScheme ; rdfs:label "Resource Administrative State Scheme"@en .
<kos/Notification/EventType> a skos:ConceptScheme ; rdfs:label "Notification Event Type Scheme"@en .
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ; rdfs:label "Perceived Severity Scheme"@en .
<kos/application/sla-level> a skos:ConceptScheme ; rdfs:label "Application SLA Level Scheme"@en .
<kos/ChangeRequest/category> a skos:ConceptScheme ; rdfs:label "Change Request Category Scheme"@en .
<kos/ChangeRequest/specification> a skos:ConceptScheme ; rdfs:label "Change Request Specification Scheme"@en .
<kos/org/agent-contact-method> a skos:ConceptScheme ; rdfs:label "Agent Contact Method Scheme"@en .
<kos/TroubleTicket/priority> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Priority Scheme"@en .
<kos/TroubleTicket/urgency> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Urgency Scheme"@en .
<kos/TroubleTicket/category> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Criticity Scheme"@en .
<kos/service/type> a skos:ConceptScheme ; rdfs:label "Service Type Scheme"@en .

# KOS Concepts
<kos/application/type/infrastructure> a skos:Concept ; skos:inScheme <kos/application/type> ; rdfs:label "Infrastructure"@en .
<kos/application/type/service-platform> a skos:Concept ; skos:inScheme <kos/application/type> ; rdfs:label "Service Platform"@en .
<kos/application/business-importance/high> a skos:Concept ; skos:inScheme <kos/application/business-importance> ; rdfs:label "High"@en .
<kos/application/business-importance/medium> a skos:Concept ; skos:inScheme <kos/application/business-importance> ; rdfs:label "Medium"@en .
<kos/application/status/InProduction> a skos:Concept ; skos:inScheme <kos/application/status> ; rdfs:label "In Production"@en .
<kos/application/status/Development> a skos:Concept ; skos:inScheme <kos/application/status> ; rdfs:label "Development"@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; rdfs:label "Critical"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; rdfs:label "Major"@en .
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; rdfs:label "Failure"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:inScheme <kos/TroubleTicket/origin> ; rdfs:label "Supervision"@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:inScheme <kos/TroubleTicket/status> ; rdfs:label "In Progress"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:inScheme <kos/TroubleTicket/status> ; rdfs:label "Resolved"@en .
<kos/TroubleTicket/trouble-category/PerformanceDegradation> a skos:Concept ; skos:inScheme <kos/TroubleTicket/trouble-category> ; rdfs:label "Performance Degradation"@en .
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; skos:inScheme <kos/TroubleTicket/problemResponsibility> ; rdfs:label "Managed Backbone Networks"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:inScheme <kos/TroubleTicket/commentType> ; rdfs:label "Internal Comment"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:inScheme <kos/TroubleTicket/operationType> ; rdfs:label "Diagnosis"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:inScheme <kos/TroubleTicket/priority> ; rdfs:label "Priority 1"@en .
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; skos:inScheme <kos/TroubleTicket/urgency> ; rdfs:label "Immediate Intervention"@en .
<kos/TroubleTicket/category/InterruptedService> a skos:Concept ; skos:inScheme <kos/TroubleTicket/category> ; rdfs:label "Interrupted Service"@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:inScheme <kos/ChangeRequest/type> ; rdfs:label "Standard Change"@en .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; skos:inScheme <kos/ChangeRequest/cause> ; rdfs:label "Software Upgrade"@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:inScheme <kos/ChangeRequest/status> ; rdfs:label "Approved"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; skos:inScheme <kos/ChangeRequest/status> ; rdfs:label "Implemented"@en .
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; skos:inScheme <kos/ChangeRequest/category> ; rdfs:label "Internal Intervention"@en .
<kos/ChangeRequest/specification/DNS_Software_Upgrade_v2> a skos:Concept ; skos:inScheme <kos/ChangeRequest/specification> ; rdfs:label "DNS Software Upgrade v2 Plan"@en .

<kos/Resource/type/Server> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Server"@en .
<kos/Resource/type/Router> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Router"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Virtual Machine"@en .
<kos/Resource/LifecycleState/InUse> a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; rdfs:label "In Use"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; rdfs:label "Up"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; rdfs:label "Down"@en .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; skos:inScheme <kos/Resource/AdministrativeState> ; rdfs:label "Up"@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; skos:inScheme <kos/Resource/AdministrativeState> ; rdfs:label "Down"@en .

<kos/Notification/EventType/stateChange> a skos:Concept ; skos:inScheme <kos/Notification/EventType> ; rdfs:label "State Change Event"@en .
<kos/Notification/EventType/performanceAlert> a skos:Concept ; skos:inScheme <kos/Notification/EventType> ; rdfs:label "Performance Alert Event"@en .
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Critical"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Warning"@en .

<kos/application/sla-level/Gold> a skos:Concept ; skos:inScheme <kos/application/sla-level> ; rdfs:label "Gold SLA Level"@en .

<kos/org/agent-contact-method/Email> a skos:Concept ; skos:inScheme <kos/org/agent-contact-method> ; rdfs:label "Email"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:inScheme <kos/org/agent-contact-method> ; rdfs:label "Phone"@en .

<kos/service/type/CustomerFacingService> a skos:Concept ; skos:inScheme <kos/service/type> ; rdfs:label "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:inScheme <kos/service/type> ; rdfs:label "Resource Facing Service"@en .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

noria:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and configuration."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for non-urgent issues, direct email for critical alerts."@en .

noria:Agent_NOC a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline for all critical incidents."@en .

noria:Agent_SoftwareDeploymentTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Software Deployment Team"@en ;
    rdfs:comment "Team responsible for deploying and upgrading software on IT resources."@en ;
    noria:agentWorkingHours "08:30-17:30 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead engineer for Core Infrastructure Services."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network Operations Specialist."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria:Site_DataCenterA a bot:Site ;
    rdfs:label "Main Data Center A"@en ;
    noria:siteId "DC-A-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoom101 a noria:Room ;
    rdfs:label "Server Room 101"@en ;
    rdfs:comment "Primary server room in Data Center A."@en ;
    bot:hasSpace noria:Locus_Rack5 ;
    bot:hasSpace noria:Locus_Rack6 ;
    seas:subSystemOf noria:Site_DataCenterA .

noria:Locus_Rack5 a noria:Locus ;
    rdfs:label "Rack 5"@en ;
    rdfs:comment "Fifth rack in Server Room 101."@en ;
    noria:locusLine "A" ;
    noria:locusRow "5" ;
    seas:subSystemOf noria:Room_ServerRoom101 .

noria:Locus_Rack6 a noria:Locus ;
    rdfs:label "Rack 6"@en ;
    rdfs:comment "Sixth rack in Server Room 101."@en ;
    noria:locusLine "A" ;
    noria:locusRow "6" ;
    seas:subSystemOf noria:Room_ServerRoom101 .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <https://www.dell.com/organization> . # Assuming Dell is an org:Organization

noria:ProductModel_CiscoASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Edge router for enterprise networks."@en ;
    noria:productManufacturedBy <https://www.cisco.com/organization> . # Assuming Cisco is an org:Organization

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com/organization> . # Assuming VMware is an org:Organization

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for internal and external resolution."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack5 ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
    noria:resourceForApplication noria:Application_CoreInfraServices .

noria:Resource_RouterEdge01 a noria:Resource ;
    rdfs:label "Edge Router 01"@en ;
    rdfs:comment "Main router connecting the corporate network to the internet."@en ;
    noria:resourceManagedBy noria:Agent_NOC ;
    noria:resourceHostName "router-edge01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack6 ;
    noria:resourceManagementIPAddress "192.168.1.1" ;
    noria:resourceForApplication noria:Application_CorporateInternetAccess .

noria:Resource_VMWeb01 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy noria:Agent_SoftwareDeploymentTeam ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself, but it's a valid link.
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-WEB-01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack5 ; # Assuming the VM runs on a host in Rack 5
    noria:resourceManagementIPAddress "10.0.0.50" ;
    noria:resourceForApplication noria:Application_CorporateWebsite .

noria:Resource_ClusterController01 a noria:Resource ;
    rdfs:label "Virtualization Cluster Controller 01"@en ;
    rdfs:comment "Controller for the VMware ESXi cluster."@en ;
    noria:resourceManagedBy noria:Agent_SoftwareDeploymentTeam ;
    noria:resourceHostName "vcenter01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:locatedAtLocus noria:Locus_Rack5 .

noria:Resource_VMWeb02 a noria:Resource ;
    rdfs:label "Web Server VM 02"@en ;
    rdfs:comment "Second virtual machine hosting the corporate website, part of a cluster."@en ;
    noria:resourceManagedBy noria:Agent_SoftwareDeploymentTeam ;
    noria:resourceHostName "web02.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:locatedAtLocus noria:Locus_Rack5 ;
    noria:resourceManagementIPAddress "10.0.0.51" ;
    noria:clusterController noria:Resource_ClusterController01 ;
    noria:resourceForApplication noria:Application_CorporateWebsite .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface 0 on Corporate DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceType "physical" .

noria:NetworkInterface_RouterEdge01_Gig0_0_1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1"@en ;
    rdfs:comment "WAN uplink interface on Edge Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterEdge01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -8 ;
    noria:networkInterfaceType "physical" .

noria:NetworkInterface_RouterEdge01_Gig0_0_2 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/2"@en ;
    rdfs:comment "LAN interface on Edge Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterEdge01 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical" .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_WAN_BranchOffice a noria:NetworkLink ;
    rdfs:label "WAN Link to Branch Office X"@en ;
    rdfs:comment "Dedicated fiber link connecting Data Center A to Branch Office X."@en ;
    noria:resourceManagedBy noria:Agent_NOC ;
    noria:networkLinkId "WAN-DC-BO-001" ;
    noria:networkLinkTerminationResource noria:Resource_RouterEdge01 ;
    noria:networkLinkInstallationDate "2021-08-01T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" .

noria:NetworkInterface_RouterEdge01_Gig0_0_1 noria:networkInterfaceConnects noria:NetworkLink_WAN_BranchOffice .

noria:NetworkLink_InternalLAN_DC a noria:NetworkLink ;
    rdfs:label "Internal LAN Data Center A"@en ;
    rdfs:comment "High-speed internal network within Data Center A."@en ;
    noria:resourceManagedBy noria:Agent_NOC ;
    noria:networkLinkId "LAN-DC-001" ;
    noria:networkLinkTerminationResource noria:Resource_DNS01, noria:Resource_RouterEdge01 ;
    noria:networkLinkInstallationDate "2022-01-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" .

noria:NetworkInterface_DNS01_Eth0 noria:networkInterfaceConnects noria:NetworkLink_InternalLAN_DC .
noria:NetworkInterface_RouterEdge01_Gig0_0_2 noria:networkInterfaceConnects noria:NetworkLink_InternalLAN_DC .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application_CoreInfraServices a noria:Application ;
    rdfs:label "Core Infrastructure Services"@en ;
    rdfs:comment "Critical services like DNS, DHCP, NTP for the entire corporate network."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services Management"@en ;
    noria:applicationFunctionalSubDomain "DNS Resolution"@en .

noria:Application_CorporateInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and systems."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Connectivity Management"@en .

noria:Application_CorporateWebsite a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "Public-facing website for company information and services."@en ;
    noria:applicationType <kos/application/type/service-platform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Marketing and Communications"@en .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

noria:ApplicationModule_DNSProd a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en ;
    rdfs:comment "Production instance of the Corporate DNS Service."@en ;
    noria:applicationModuleOf noria:Application_CoreInfraServices ;
    noria:applicationModuleName "DNS_PROD_MODULE" ;
    noria:applicationModuleIdentifier "DNS-PROD-01" ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam noria:Agent_DNSAdminTeam ;
    noria:applicationModuleSupportTeam noria:Agent_NOC ;
    noria:applicationModuleSlaLevel <kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

noria:ApplicationModule_WebProd a noria:ApplicationModule ;
    rdfs:label "Corporate Website Production Module"@en ;
    rdfs:comment "Production instance of the Corporate Website."@en ;
    noria:applicationModuleOf noria:Application_CorporateWebsite ;
    noria:applicationModuleName "WEB_PROD_MODULE" ;
    noria:applicationModuleIdentifier "WEB-PROD-01" ;
    noria:applicationModuleStatus <kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam noria:Agent_SoftwareDeploymentTeam ;
    noria:applicationModuleSupportTeam noria:Agent_NOC ;
    noria:applicationModuleSlaLevel <kos/application/sla-level/Gold> ;
    noria:applicationModuleHotlineEnabled false .

# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service_EnterpriseConnectivity a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing network connectivity across the enterprise."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_CorporateInternetAccess ; # A service can be a subsystem of an application
    seas:subSystemOf noria:Application_CoreInfraServices .

noria:ApplicationModule_DNSProd seas:subSystemOf noria:Service_EnterpriseConnectivity .
noria:ApplicationModule_WebProd seas:subSystemOf noria:Service_EnterpriseConnectivity .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNS_CPU_High a noria:EventRecord ;
    rdfs:label "DNS Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating sustained high CPU usage on the primary DNS server."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on dns01.corp.example.com exceeded 90% for 15 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ; # Assuming a monitoring system application
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:type <kos/Notification/EventType/performanceAlert> .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Application responsible for collecting and analyzing system metrics and logs."@en ;
    noria:applicationType <kos/application/type/service-platform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

noria:EventRecord_Router_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that GigabitEthernet0/0/1 on router-edge01 went down."@en ;
    noria:loggingTime "2024-04-23T11:15:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterEdge01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/stateChange> .

noria:EventRecord_DNS_SoftwareUpgrade_Log a noria:EventRecord ;
    rdfs:label "DNS Software Upgrade Log"@en ;
    rdfs:comment "Log entry for successful DNS software upgrade on dns01."@en ;
    noria:loggingTime "2024-04-22T03:00:00Z"^^xsd:dateTime ;
    noria:logText "DNS server software upgraded to version 2.0.1."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingAgent noria:Agent_JohnDoe ;
    noria:logOriginatingManagementSystem noria:Application_DeploymentTool ; # Assuming a deployment tool application
    dcterms:type <kos/Notification/EventType/stateChange> .

noria:Application_DeploymentTool a noria:Application ;
    rdfs:label "Automated Deployment Tool"@en ;
    rdfs:comment "Application used for automated software deployments and configuration management."@en ;
    noria:applicationType <kos/application/type/service-platform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket_DNS_Performance a noria:TroubleTicket ;
    rdfs:label "DNS Server Performance Degradation"@en ;
    rdfs:comment "Users report slow DNS resolution, impacting various applications."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketRelatedService noria:ApplicationModule_DNSProd ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty noria:Agent_NOC ;
    noria:troubleTicketTrigger noria:EventRecord_DNS_CPU_High ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketCause "High CPU usage on DNS server due to unexpected query load."@en ;
    noria:troubleTicketImpacts noria:Application_CorporateInternetAccess, noria:Application_CorporateWebsite ;
    noria:documentHRef "https://ticketing.example.com/TT-2024-04-23-001"^^xsd:anyURI .

noria:TroubleTicket_WAN_Outage a noria:TroubleTicket ;
    rdfs:label "WAN Link Outage to Branch Office X"@en ;
    rdfs:comment "Branch Office X reports complete loss of connectivity due to WAN link failure."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketRelatedService noria:Service_EnterpriseConnectivity ;
    noria:troubleTicketRelatedResource noria:Resource_RouterEdge01, noria:NetworkLink_WAN_BranchOffice ;
    noria:troubleTicketRelatedParty noria:Agent_NOC ;
    noria:troubleTicketTrigger noria:EventRecord_Router_InterfaceDown ;
    noria:troubleTicketDetectionDateTime "2024-04-23T11:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketCause "Physical fiber cut on WAN link."@en ;
    noria:troubleTicketImpacts noria:Application_CorporateInternetAccess ;
    noria:documentHRef "https://ticketing.example.com/TT-2024-04-23-002"^^xsd:anyURI .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote_DNS_Diag1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Performance Diagnosis Note 1"@en ;
    rdfs:comment "Initial diagnosis: observed high CPU, checked logs, no obvious errors. Escalating to L2."@en ;
    dcterms:created "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_JaneSmith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_DNS_Performance .

noria:TroubleTicketNote_WAN_Restore1 a noria:TroubleTicketNote ;
    rdfs:label "WAN Outage Restoration Update"@en ;
    rdfs:comment "Field technician dispatched to investigate fiber cut. Estimated repair time 4 hours."@en ;
    dcterms:created "2024-04-23T11:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_NOC ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_WAN_Outage .

