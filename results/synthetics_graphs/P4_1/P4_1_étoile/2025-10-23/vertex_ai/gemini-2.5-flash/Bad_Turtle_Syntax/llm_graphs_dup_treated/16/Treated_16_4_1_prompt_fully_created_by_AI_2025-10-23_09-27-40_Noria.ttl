    noria:documentHRef "https://changemanagement.example.com/CR-2024-04-21-001"^^xsd:anyURI ;
    noria:documentStatusHistory noria:EventRecord_DNS_SoftwareUpgrade_Log .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_DNS_Troubleshooting a noria:OperationPlan ;
    rdfs:label "DNS Troubleshooting Guide"@en ;
    rdfs:comment "Standard operating procedure for diagnosing DNS resolution issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNS_HighCPU ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_Resolved .

noria:OperationPlan_WAN_Failover a noria:OperationPlan ;
    rdfs:label "WAN Link Failover Procedure"@en ;
    rdfs:comment "Procedure to activate backup WAN link in case of primary link failure."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WAN_LinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WAN_Restored .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition_DNS_HighCPU a noria:ActionPreCondition ;
    rdfs:label "High DNS Server CPU Usage"@en ;
    rdfs:comment "Condition: DNS server CPU usage consistently above 80%."@en .

noria:ActionPostCondition_DNS_Resolved a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored"@en ;
    rdfs:comment "Outcome: DNS queries are resolved successfully and CPU usage is normal."@en .

noria:ActionPreCondition_WAN_LinkDown a noria:ActionPreCondition ;
    rdfs:label "WAN Link Operational Status Down"@en ;
    rdfs:comment "Condition: Primary WAN link interface reports operational status 'down'."@en .

noria:ActionPostCondition_WAN_Restored a noria:ActionPostCondition ;
    rdfs:label "WAN Connectivity Restored"@en ;
    rdfs:comment "Outcome: Branch office connectivity is restored via primary or backup link."@en .

