    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_DNS01, noria:ApplicationModule_DNSProd ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ; # 1 hour planned outage
    noria:changeRequestInitiatorParty noria:Agent_JohnDoe ;
    noria:changeRequestPilotParty noria:Agent_SoftwareDeploymentTeam ;
    noria:changeRequestActorParty noria:Agent_SoftwareDeploymentTeam ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
