noria:ChangeRequest_DNS_Upgrade a noria:ChangeRequest ;
    rdfs:label "DNS Software Upgrade to v2.0.1"@en ;
    rdfs:comment "Upgrade DNS server software to address known vulnerabilities and improve performance."@en ;
    noria:changeRequestPlannedStartTime "2024-04-22T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-22T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-22T02:05:00Z"^^xsd:dateTime ;
