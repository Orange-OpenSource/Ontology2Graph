# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

<agent/WebOpsTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "WebOps Team"@en ;
    rdfs:comment "Team responsible for the operation and maintenance of web-facing applications and infrastructure."@en ;
    skos:example "This team handles deployment, monitoring, and incident response for critical web services."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "For critical issues, use the dedicated incident management channel and follow up with a phone call."@en ;
    noria:agentManagesResource <resource/WebServer01>, <resource/LoadBalancer01> ;
    .

<agent/NetworkTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing the corporate network infrastructure, including routers and switches."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Open a trouble ticket for all network-related issues. For emergencies, call the hotline."@en ;
    noria:agentManagesResource <resource/CoreRouter01>, <resource/EdgeRouter01> ;
    .

<agent/DBA_Team> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database management and performance."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentManagesResource <resource/DBServer01> ;
    .

<agent/JohnDoe> a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for the WebOps Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    .

<agent/JaneSmith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network Engineer on the Network Operations Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+33987654321" ;
    .

<agent/CustomerSupport> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Support Tier 1"@en ;
    rdfs:comment "First line of support for customer inquiries and issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

<location/DataCenterParis> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris, France."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "48.8699"^^xsd:float ;
    wgs84_pos:long "2.3329"^^xsd:float ;
    .

<location/RoomA1> a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace <location/DataCenterParis> ; # Assuming bot:hasSpace can link a Room to a Site
    .

<location/LocusR1C5> a noria:Locus ;
    rdfs:label "Rack 1, Column 5"@en ;
    rdfs:comment "Specific location for equipment in Server Room A1."@en ;
    noria:locusLine "R1" ;
    noria:locusRow "C5" ;
    bot:hasSpace <location/RoomA1> ; # Assuming bot:hasSpace can link a Locus to a Room
    .

<location/DataCenterLyon> a bot:Site ;
    rdfs:label "Lyon Data Center"@en ;
    rdfs:comment "Secondary data center located in Lyon, France."@en ;
    noria:siteId "DC-LYN-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "45.7494"^^xsd:float ;
    wgs84_pos:long "4.8432"^^xsd:float ;
    .

<location/RoomB2> a noria:Room ;
    rdfs:label "Network Room B2"@en ;
    rdfs:comment "Network equipment room within the Lyon Data Center."@en ;
    bot:hasSpace <location/DataCenterLyon> ;
    .

<location/LocusR3C10> a noria:Locus ;
    rdfs:label "Rack 3, Column 10"@en ;
    rdfs:comment "Specific location for network equipment in Network Room B2."@en ;
    noria:locusLine "R3" ;
    noria:locusRow "C10" ;
    bot:hasSpace <location/RoomB2> ;
    .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

<productmodel/DellPowerEdgeR740> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy <org/Dell> ;
    .

<productmodel/CiscoCatalyst9300> a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch from Cisco."@en ;
    noria:productManufacturedBy <org/Cisco> ;
    .

<productmodel/JuniperMX204> a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Compact, high-density universal routing platform from Juniper Networks."@en ;
    noria:productManufacturedBy <org/JuniperNetworks> ;
    .

<org/Dell> a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en ;
    .

<org/Cisco> a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en ;
    .

<org/JuniperNetworks> a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products, including routers, switches, network management software, network security products, and software-defined networking technology."@en ;
    .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

<resource/WebServer01> a noria:Resource ;
    rdfs:label "E-commerce Web Server 01"@en ;
    rdfs:comment "Primary web server hosting the E-commerce platform frontend."@en ;
    noria:resourceManagedBy <agent/WebOpsTeam> ;
    noria:resourceHostName "web01.ecommerce.example.com" ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceProductModel <productmodel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <application/EcommercePlatform> ;
    noria:locatedAtLocus <location/LocusR1C5> ;
    noria:resourceManagementIPAddress <ip/192.168.1.10> ;
    .

<resource/DBServer01> a noria:Resource ;
    rdfs:label "E-commerce Database Server 01"@en ;
    rdfs:comment "Primary database server for the E-commerce platform."@en ;
    noria:resourceManagedBy <agent/DBA_Team> ;
    noria:resourceHostName "db01.ecommerce.example.com" ;
    noria:resourceLogisticId "ASSET-DB-001" ;
    noria:resourceProductModel <productmodel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DB-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <application/EcommercePlatform> ;
    noria:locatedAtLocus <location/LocusR1C5> ;
    noria:resourceManagementIPAddress <ip/192.168.1.11> ;
    .

<resource/CoreRouter01> a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network in Paris DC."@en ;
    noria:resourceManagedBy <agent/NetworkTeam> ;
    noria:resourceHostName "cr01.paris.example.com" ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceProductModel <productmodel/JuniperMX204> ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-CR-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <location/LocusR3C10> ;
    noria:resourceManagementIPAddress <ip/10.0.0.1> ;
    .

<resource/EdgeRouter01> a noria:Resource ;
    rdfs:label "Edge Router 01"@en ;
    rdfs:comment "Edge router connecting the Paris DC to the internet."@en ;
    noria:resourceManagedBy <agent/NetworkTeam> ;
    noria:resourceHostName "er01.paris.example.com" ;
    noria:resourceLogisticId "ASSET-ER-001" ;
    noria:resourceProductModel <productmodel/CiscoCatalyst9300> ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-ER-001-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <location/LocusR3C10> ;
    noria:resourceManagementIPAddress <ip/10.0.0.2> ;
    .

<resource/LoadBalancer01> a noria:Resource ;
    rdfs:label "E-commerce Load Balancer 01"@en ;
    rdfs:comment "Load balancer distributing traffic to E-commerce web servers."@en ;
    noria:resourceManagedBy <agent/WebOpsTeam> ;
    noria:resourceHostName "lb01.ecommerce.example.com" ;
    noria:resourceLogisticId "ASSET-LB-001" ;
    noria:resourceType <kos/Resource/type/load-balancer> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T09:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <application/EcommercePlatform> ;
    noria:locatedAtLocus <location/LocusR1C5> ;
    noria:resourceManagementIPAddress <ip/192.168.1.5> ;
    .

<ip/192.168.1.10> a observable:IPAddress ;
    rdfs:label "192.168.1.10"@en ;
    rdfs:comment "Management IP address for Web Server 01."@en ;
    observable:ipAddressValue "192.168.1.10"^^xsd:string ;
    .

<ip/192.168.1.11> a observable:IPAddress ;
    rdfs:label "192.168.1.11"@en ;
    rdfs:comment "Management IP address for DB Server 01."@en ;
    observable:ipAddressValue "192.168.1.11"^^xsd:string ;
    .

<ip/10.0.0.1> a observable:IPAddress ;
    rdfs:label "10.0.0.1"@en ;
    rdfs:comment "Management IP address for Core Router 01."@en ;
    observable:ipAddressValue "10.0.0.1"^^xsd:string ;
    .

<ip/10.0.0.2> a observable:IPAddress ;
    rdfs:label "10.0.0.2"@en ;
    rdfs:comment "Management IP address for Edge Router 01."@en ;
    observable:ipAddressValue "10.0.0.2"^^xsd:string ;
    .

<ip/192.168.1.5> a observable:IPAddress ;
    rdfs:label "192.168.1.5"@en ;
    rdfs:comment "Management IP address for Load Balancer 01."@en ;
    observable:ipAddressValue "192.168.1.5"^^xsd:string ;
    .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

<networkinterface/WebServer01-eth0> a noria:NetworkInterface ;
    rdfs:label "WebServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf <resource/WebServer01> ;
    noria:networkInterfaceDescription "Ethernet interface connected to internal network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <networklink/InternalLAN> ;
    .

<networkinterface/CoreRouter01-ge-0-0-0> a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal LAN."@en ;
    noria:networkInterfaceOf <resource/CoreRouter01> ;
    noria:networkInterfaceDescription "Uplink to internal network segment."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <networklink/InternalLAN> ;
    .

<networkinterface/EdgeRouter01-ge-0-0-1> a noria:NetworkInterface ;
    rdfs:label "EdgeRouter01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Edge Router 01 to the internet."@en ;
    noria:networkInterfaceOf <resource/EdgeRouter01> ;
    noria:networkInterfaceDescription "Internet uplink interface."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <networklink/InternetUplink> ;
    .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

<networklink/InternalLAN> a noria:NetworkLink ;
    rdfs:label "Internal LAN - Paris DC"@en ;
    rdfs:comment "Local Area Network segment connecting servers and core router in Paris DC."@en ;
    noria:networkLinkId "LAN-PARIS-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/NetworkTeam> ;
    noria:networkLinkTerminationResourceOrigin <resource/WebServer01> ;
    noria:networkLinkTerminationResourceDestination <resource/CoreRouter01> ;
    .

<networklink/InternetUplink> a noria:NetworkLink ;
    rdfs:label "Internet Uplink - Paris DC"@en ;
    rdfs:comment "External link connecting Paris DC to the internet."@en ;
    noria:networkLinkId "UPLINK-PARIS-01" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2022-05-01T08:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/NetworkTeam> ;
    noria:networkLinkTerminationResourceOrigin <resource/EdgeRouter01> ;
    # Assuming the other end is an external ISP router, not modeled here as a noria:Resource
    .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

<application/EcommercePlatform> a noria:Application ;
    rdfs:label "E-commerce Platform"@en ;
    rdfs:comment "Main application for online sales and customer interactions."@en ;
    noria:applicationModelIdentifier "ECOMM-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "ECOMM" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Sales and Customer Management"@en ;
    noria:applicationFunctionalSubDomain "Online Order Processing"@en ;
    noria:elementManagedBy <agent/WebOpsTeam> ;
    .

<application/MonitoringSystem> a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Application responsible for collecting and analyzing logs and metrics from IT infrastructure."@en ;
    noria:applicationModelIdentifier "MONITOR-V3" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "MONITOR" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Event and Log Management"@en ;
    noria:elementManagedBy <agent/NetworkTeam> ;
    .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

<applicationmodule/EcommerceFrontend> a noria:ApplicationModule ;
    rdfs:label "E-commerce Frontend Module"@en ;
    rdfs:comment "Module handling the user-facing web interface of the E-commerce platform."@en ;
    noria:applicationModuleOf <application/EcommercePlatform> ;
    noria:applicationModuleName "ECOMM_FRONTEND_PROD" ;
    noria:applicationModuleIdentifier "FRONTEND-01" ;
    noria:applicationModuleAdministrationTeam <agent/WebOpsTeam> ;
    noria:applicationModuleAdministrationLeader <agent/JohnDoe> ;
    noria:applicationModuleSupportTeam <agent/WebOpsTeam> ;
    noria:applicationModuleSupportLeader <agent/JohnDoe> ;
    noria:applicationModuleHotlineGroup <agent/WebOpsTeam> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    .

<applicationmodule/EcommerceBackend> a noria:ApplicationModule ;
    rdfs:label "E-commerce Backend Module"@en ;
    rdfs:comment "Module handling business logic and database interactions for the E-commerce platform."@en ;
    noria:applicationModuleOf <application/EcommercePlatform> ;
    noria:applicationModuleName "ECOMM_BACKEND_PROD" ;
    noria:applicationModuleIdentifier "BACKEND-01" ;
    noria:applicationModuleAdministrationTeam <agent/DBA_Team> ;
    noria:applicationModuleSupportTeam <agent/DBA_Team> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    .

<applicationmodule/MonitoringAgent> a noria:ApplicationModule ;
    rdfs:label "Monitoring Agent Module"@en ;
    rdfs:comment "Agents deployed on resources to collect data for the Central Monitoring System."@en ;
    noria:applicationModuleOf <application/MonitoringSystem> ;
    noria:applicationModuleName "MONITOR_AGENT_V1" ;
    noria:applicationModuleIdentifier "AGENT-01" ;
    noria:applicationModuleSupportTeam <agent/NetworkTeam> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    .

# =============================================================================
# Services (noria:Service)
# =============================================================================

<service/CustomerFacingEcommerce> a noria:Service ;
    rdfs:label "Customer-Facing E-commerce Service"@en ;
    rdfs:comment "End-to-end service providing online shopping capabilities to customers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <applicationmodule/EcommerceFrontend> ; # A service can be composed of application modules
    seas:subSystemOf <applicationmodule/EcommerceBackend> ;
    .

<service/InternalNetworkConnectivity> a noria:Service ;
    rdfs:label "Internal Network Connectivity Service"@en ;
    rdfs:comment "Service ensuring network connectivity within the corporate data centers."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf <networklink/InternalLAN> ;
    seas:subSystemOf <resource/CoreRouter01> ;
    .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

<event/HTTP503ErrorLog> a noria:EventRecord ;
    rdfs:label "HTTP 503 Error Log"@en ;
    rdfs:comment "Log entry indicating an HTTP 503 Service Unavailable error from the web server."@en ;
    noria:loggingTime "2024-04-23T14:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/WebServer01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "HTTP 503 Service Unavailable: Backend server not responding."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    .

<event/NetworkInterfaceDown> a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-23T14:28:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/CoreRouter01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "Interface ge-0/0/0 on cr01.paris.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <operationplan/CheckFiberConnection> ;
    .

<event/DBConnectionError> a noria:EventRecord ;
    rdfs:label "Database Connection Error"@en ;
    rdfs:comment "Log entry from application indicating issues connecting to the database."@en ;
    noria:loggingTime "2024-04-23T14:31:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <applicationmodule/EcommerceBackend> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "Failed to connect to database 'ecommerce_prod' on db01.ecommerce.example.com."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    .

<event/ServerRestartLog> a noria:EventRecord ;
    rdfs:label "Web Server Restart Log"@en ;
    rdfs:comment "System log entry confirming the restart of Web Server 01."@en ;
    noria:loggingTime "2024-04-23T15:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/WebServer01> ;
    noria:logOriginatingAgent <agent/JohnDoe> ;
    noria:logText "System reboot initiated by user 'jdoe' via SSH."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

<troubleticket/TT-20240423-001> a noria:TroubleTicket ;
    rdfs:label "High Latency on E-commerce Frontend"@en ;
    rdfs:comment "Customers are reporting slow loading times and occasional 503 errors on the E-commerce platform."@en ;
    noria:documentExternalId "INC-2024-04-23-001" ;
    noria:documentHRef <https://ticketing.example.com/TT-20240423-001> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger <event/HTTP503ErrorLog> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Prometheus/Grafana"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ApplicationPerformance> ;
    noria:troubleTicketCause "Unresponsive backend service due to resource exhaustion on web server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T14:35:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T15:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <agent/WebOpsTeam>, <agent/CustomerSupport> ;
    noria:troubleTicketRelatedService <application/EcommercePlatform> ;
    noria:troubleTicketRelatedResource <resource/WebServer01>, <resource/LoadBalancer01> ;
    noria:troubleTicketImpacts <applicationmodule/EcommerceFrontend>, <resource/WebServer01> ;
    .

<troubleticket/TT-20240423-002> a noria:TroubleTicket ;
    rdfs:label "Core Router Interface Flapping"@en ;
    rdfs:comment "Alerts received about intermittent connectivity on Core Router 01's internal interface."@en ;
    noria:documentExternalId "NET-INC-2024-04-23-002" ;
    noria:documentHRef <https://ticketing.example.com/TT-20240423-002> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/DowngradingEquipment> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <event/NetworkInterfaceDown> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkConnectivity> ;
    noria:troubleTicketCause "Suspected faulty SFP module on ge-0/0/0."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T14:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T17:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <agent/NetworkTeam> ;
    noria:troubleTicketRelatedService <service/InternalNetworkConnectivity> ;
    noria:troubleTicketRelatedResource <resource/CoreRouter01> ;
    noria:troubleTicketImpacts <networkinterface/CoreRouter01-ge-0-0-0> ;
    .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

<troubleticketnote/TTN-20240423-001-01> a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis and Web Server Restart"@en ;
    rdfs:comment "Initial investigation showed high CPU usage on Web Server 01. Performed a graceful restart of the server. Monitoring for recovery."@en ;
    dcterms:created "2024-04-23T14:50:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/JohnDoe> ;
    dcterms:isPartOf <troubleticket/TT-20240423-001> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution <event/ServerRestartLog> ;
    .

<troubleticketnote/TTN-20240423-001-02> a noria:TroubleTicketNote ;
    rdfs:label "Service Restored Confirmation"@en ;
    rdfs:comment "After restart, HTTP 503 errors ceased, and latency returned to normal. Customer confirmed service restoration."@en ;
    dcterms:created "2024-04-23T15:30:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/JohnDoe> ;
    dcterms:isPartOf <troubleticket/TT-20240423-001> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    .

# =============================================================================
# Change Requests (noria:ChangeRequest)
# =============================================================================

<changerequest/CR-20240501-001> a noria:ChangeRequest ;
    rdfs:label "E-commerce Platform Software Upgrade"@en ;
    rdfs:comment "Planned upgrade of the E-commerce platform software to version 3.0 for new features and security patches."@en ;
    noria:documentExternalId "CR-ECOMM-2024-05-01" ;
    noria:documentHRef <https://changemanagement.example.com/CR-20240501-001> ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact <application/EcommercePlatform>, <resource/WebServer01>, <resource/DBServer01> ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/ApplicationUpgradeProcedure> ;
    noria:changeRequestInitiatorParty <agent/JohnDoe> ;
    noria:changeRequestPilotParty <agent/JohnDoe> ;
    noria:changeRequestActorParty <agent/WebOpsTeam> ;
    noria:changeRequestIsRegulated false ;
    .

<changerequest/CR-20240510-002> a noria:ChangeRequest ;
    rdfs:label "Core Router Firmware Update"@en ;
    rdfs:comment "Mandatory firmware update for Core Router 01 to address critical security vulnerabilities."@en ;
    noria:documentExternalId "CR-NET-2024-05-10" ;
    noria:documentHRef <https://changemanagement.example.com/CR-20240510-002> ;
    noria:changeRequestPlannedStartTime "2024-05-10T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-10T02:30:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact <resource/CoreRouter01> ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ; # 1 hour 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkDeviceFirmwareUpdate> ;
    noria:changeRequestInitiatorParty <agent/JaneSmith> ;
    noria:changeRequestPilotParty <agent/JaneSmith> ;
    noria:changeRequestActorParty <agent/NetworkTeam> ;
    noria:changeRequestIsRegulated true ;
    .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

<operationplan/ApplicationUpgradeProcedure> a noria:OperationPlan ;
    rdfs:label "E-commerce Application Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading the E-commerce platform software."@en ;
    skos:example "Steps include database backup, code deployment, configuration update, and smoke testing."@en ;
    noria:operationPlanPreCondition <actionprecondition/SystemHealthCheck> ;
    noria:operationPlanPostCondition <actionpostcondition/ServiceFunctionalityVerified> ;
    .

<operationplan/CheckFiberConnection> a noria:OperationPlan ;
    rdfs:label "Check Fiber Connection Procedure"@en ;
    rdfs:comment "Procedure to diagnose and resolve fiber optic link issues."@en ;
    skos:example "Steps include visual inspection, optical power measurement, and SFP module replacement."@en ;
    noria:operationPlanPreCondition <actionprecondition/OpticalPowerLow> ;
    noria:operationPlanPostCondition <actionpostcondition/OpticalPowerNormal> ;
    .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

<actionprecondition/SystemHealthCheck> a noria:ActionPreCondition ;
    rdfs:label "System Health Check Passed"@en ;
    rdfs:comment "All critical system metrics (CPU, Memory, Disk, Network) are within normal operating thresholds before starting the upgrade."@en ;
    skos:example "CPU < 70%, Memory < 80%, Disk usage < 90%, Network latency < 5ms."@en ;
    .

<actionpostcondition/ServiceFunctionalityVerified> a noria:ActionPostCondition ;
    rdfs:label "Service Functionality Verified"@en ;
    rdfs:comment "All core functionalities of the E-commerce platform (browsing, adding to cart, checkout) are verified to be working correctly after the upgrade."@en ;
    skos:example "Automated end-to-end tests passed, manual smoke tests successful."@en ;
    .

<actionprecondition/OpticalPowerLow> a noria:ActionPreCondition ;
    rdfs:label "Optical Power Low"@en ;
    rdfs:comment "Received optical power on the network interface is below the warning threshold."@en ;
    skos:example "noria:networkInterfaceLaserRxOpticalPower < noria:networkInterfaceLaserRxLowPowerWarningThreshold."@en ;
    .

<actionpostcondition/OpticalPowerNormal> a noria:ActionPostCondition ;
    rdfs:label "Optical Power Normal"@en ;
    rdfs:comment "Received optical power on the network interface is within normal operating range after intervention."@en ;
    skos:example "noria:networkInterfaceLaserRxOpticalPower > noria:networkInterfaceLaserRxLowPowerWarningThreshold."@en ;
    .

