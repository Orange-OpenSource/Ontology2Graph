# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

<operationplan/RestartWebServerService> a noria:OperationPlan ;
    rdfs:label "Restart Web Server Service"@en ;
    rdfs:comment "Standard operating procedure to restart the web server application service."@en ;
    skos:example "Steps include checking logs, gracefully stopping service, verifying process termination, starting service, and verifying accessibility."@en ;
    noria:operationPlanPreCondition <actionprecondition/HighCPULoad> ;
    noria:operationPlanPostCondition <actionpostcondition/ServiceRestored> .

<operationplan/DBQueryOptimizationProcedure> a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries."@en ;
    noria:operationPlanPreCondition <actionprecondition/SlowDBPerformance> ;
    noria:operationPlanPostCondition <actionpostcondition/DBPerformanceRestored> .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

<actionprecondition/HighCPULoad> a noria:ActionPreCondition ;
    rdfs:label "High CPU Load Detected"@en ;
    rdfs:comment "Condition where a server's CPU utilization exceeds a predefined threshold for a sustained period."@en ;
    skos:example "CPU > 90% for 5 minutes on a production server."@en .

<actionpostcondition/ServiceRestored> a noria:ActionPostCondition ;
    rdfs:label "Service Restored"@en ;
    rdfs:comment "Condition where the affected service is fully operational and accessible to users."@en ;
    skos:example "Web application responds to requests, no error messages, customer confirms access."@en .

<actionprecondition/SlowDBPerformance> a noria:ActionPreCondition ;
    rdfs:label "Slow Database Performance"@en ;
    rdfs:comment "Condition where database queries are executing slowly, impacting application responsiveness."@en ;
    skos:example "Average query response time > 500ms for critical transactions."@en .

<actionpostcondition/DBPerformanceRestored> a noria:ActionPostCondition ;
    rdfs:label "Database Performance Restored"@en ;
    rdfs:comment "Condition where database query execution times return to acceptable levels."@en ;
    skos:example "Average query response time < 100ms for critical transactions."@en .

