# --- Operation Plans (noria:OperationPlan) ---
:OperationPlan_Router_Failover a noria:OperationPlan ;
    rdfs:label "Router Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for initiating a router failover in case of primary link failure."@en ;
    skos:example "Steps include verifying link status, initiating BGP graceful shutdown, and monitoring traffic shift."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Primary_Link_Down ;
    noria:operationPlanPostCondition :ActionPostCondition_Traffic_Shifted .

:OperationPlan_Web_Server_Restart a noria:OperationPlan ;
    rdfs:label "Web Server Graceful Restart"@en ;
    rdfs:comment "Procedure for gracefully restarting a web server to apply updates or resolve minor issues."@en ;
    skos:example "Steps include draining connections, stopping services, restarting OS, and verifying service availability."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_High_CPU_Load ;
    noria:operationPlanPostCondition :ActionPostCondition_CPU_Normalized .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
:ActionPreCondition_Primary_Link_Down a noria:ActionPreCondition ;
    rdfs:label "Primary WAN Link Down"@en ;
    rdfs:comment "Condition: The primary WAN link is detected as being down or in a degraded state."@en ;
    skos:example "EventRecord_CR01_Interface_Down indicates this condition."@en .

:ActionPostCondition_Traffic_Shifted a noria:ActionPostCondition ;
    rdfs:label "Traffic Shifted to Secondary Link"@en ;
    rdfs:comment "Expected outcome: All traffic has successfully shifted to the secondary WAN link."@en ;
    skos:example "Monitoring tools show traffic flowing through the backup link and service is restored."@en .

:ActionPreCondition_High_CPU_Load a noria:ActionPreCondition ;
    rdfs:label "High CPU Load on Web Server"@en ;
    rdfs:comment "Condition: Web server CPU utilization consistently above threshold."@en ;
    skos:example "EventRecord_Web01_CPU_High indicates this condition."@en .

:ActionPostCondition_CPU_Normalized a noria:ActionPostCondition ;
    rdfs:label "CPU Load Normalized"@en ;
    rdfs:comment "Expected outcome: Web server CPU utilization has returned to normal levels."@en ;
    skos:example "Monitoring shows CPU usage below 50% after restart."@en .

# --- Connecting Events to Procedures ---
:EventRecord_CR01_Interface_Down noria:alarmProposedRepairAction :OperationPlan_Router_Failover .
:EventRecord_Web01_CPU_High noria:alarmProposedRepairAction :OperationPlan_Web_Server_Restart .

# --- Example of a Corporate User Identifier ---
:CUid_John_Doe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe, an IT Operations Engineer."@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "jdoe@example.com" .

:Agent_John_Doe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "IT Operations Engineer."@en ;
    foaf:holdsAccount :CUid_John_Doe ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

:Agent_IT_Ops_Team noria:agentManagesResource :Resource_Web_Server_01, :Resource_DB_Server_01 .
:Agent_Network_Admin noria:agentManagesResource :Resource_Core_Router_01, :NetworkLink_CR01_ISP_A .
