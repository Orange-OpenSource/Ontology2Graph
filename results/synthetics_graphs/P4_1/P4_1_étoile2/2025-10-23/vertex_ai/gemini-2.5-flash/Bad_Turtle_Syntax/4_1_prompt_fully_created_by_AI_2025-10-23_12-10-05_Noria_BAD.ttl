    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-15T10:10:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_Web_Server_01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Core_Router_01 ; # Simplified, assuming CR01 is the LAN gateway
    noria:resourceManagedBy :Agent_Network_Admin .

:NetworkLink_CR01_ISP_A a noria:NetworkLink ;
    rdfs:label "CR01 to ISP A WAN Link"@en ;
