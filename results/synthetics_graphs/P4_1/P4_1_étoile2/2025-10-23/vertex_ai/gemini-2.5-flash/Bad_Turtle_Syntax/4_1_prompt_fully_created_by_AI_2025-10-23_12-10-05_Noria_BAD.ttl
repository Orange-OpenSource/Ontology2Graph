    noria:applicationModuleOf :Application_Internet_Gateway ;
    noria:applicationModuleName "INETGW_PROD" ;
    noria:applicationModuleIdentifier "PROD-IGW-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
