    noria:networkLinkType "Fiber Optic WAN" ;
    noria:networkLinkInstallationDate "2022-05-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource :Resource_Core_Router_01 ;
    noria:resourceManagedBy :Agent_Network_Admin .

:NetworkLink_CR01_LAN a noria:NetworkLink ;
    rdfs:label "CR01 to DC LAN Link"@en ;
    rdfs:comment "High-speed link connecting Core Router 01 to the Data Center internal network."@en ;
    noria:networkLinkId "NL-CR01-DC-LAN" ;
    noria:networkLinkType "10GbE" ;
    noria:networkLinkInstallationDate "2022-05-20T15:15:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource :Resource_Core_Router_01 ;
    noria:resourceManagedBy :Agent_Network_Admin .

