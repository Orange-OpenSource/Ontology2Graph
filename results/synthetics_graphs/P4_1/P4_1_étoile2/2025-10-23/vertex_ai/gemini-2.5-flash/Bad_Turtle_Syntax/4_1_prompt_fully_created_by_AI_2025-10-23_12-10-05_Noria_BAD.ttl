# --- Services (noria:Service) ---
:Service_Public_Connectivity a noria:Service ;
    rdfs:label "Public Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing public internet access and hosting for external applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :ApplicationModule_CorpWeb_Prod, :ApplicationModule_InetGW_Prod . # Linking application modules to a service

# --- Event Records (noria:EventRecord) ---
:EventRecord_Web01_CPU_High a noria:EventRecord ;
    rdfs:label "Web01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "CPU usage on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:EventRecord_CR01_Interface_Down a noria:EventRecord ;
    rdfs:label "CR01 Interface Down Alert"@en ;
    rdfs:comment "Critical alert: Core Router 01 external interface went down."@en ;
    noria:loggingTime "2024-04-23T10:10:15Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Core_Router_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "Interface GigabitEthernet0/0/0 on cr01.dc.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_DB01_Disk_Full a noria:EventRecord ;
    rdfs:label "DB01 Disk Full Alert"@en ;
    rdfs:comment "Alert: Database Server 01 disk space is critically low."@en ;
    noria:loggingTime "2024-04-23T09:50:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "Disk /data on db01.corp.example.com is 98% full."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:EventRecord_User_Login_Failed a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on a system."@en ;
    noria:loggingTime "2024-04-23T10:12:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logOriginatingAgent :Agent_External_Attacker ; # Example of an external agent
    noria:logText "Failed login for user 'admin' from IP 192.168.1.100."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

:Agent_External_Attacker a foaf:Agent ;
    rdfs:label "Unknown External User"@en ;
    rdfs:comment "Represents an unknown external entity attempting unauthorized access."@en .

# --- Trouble Tickets (noria:TroubleTicket) ---
:TroubleTicket_CRITICAL_Internet_Outage a noria:TroubleTicket ;
    rdfs:label "CRITICAL: Internet Gateway Outage"@en ;
    rdfs:comment "Major incident affecting public internet connectivity due to Core Router 01 interface down."@en ;
    dcterms:identifier "TT-20240423-001" ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :EventRecord_CR01_Interface_Down ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
