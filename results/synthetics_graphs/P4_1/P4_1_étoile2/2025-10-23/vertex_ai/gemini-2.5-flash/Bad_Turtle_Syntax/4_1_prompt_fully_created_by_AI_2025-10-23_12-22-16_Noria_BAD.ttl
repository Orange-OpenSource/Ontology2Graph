    noria:applicationModuleHotlineEnabled false .

# --- Services ---
:Service_Web_Access a noria:Service ;
    rdfs:label "Customer Web Access Service"@en ;
    rdfs:comment "End-to-end service for customer access to the portal."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :ApplicationModule_CP_Prod .

:Service_Database_Backend a noria:Service ;
    rdfs:label "Database Backend Service"@en ;
    rdfs:comment "Backend database service supporting multiple applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf :ApplicationModule_CP_Prod .

# --- Event Records ---
:EventRecord_Web_Server_CPU_High a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:EventRecord_DB_Connection_Error a noria:EventRecord ;
    rdfs:label "Database Connection Error Log"@en ;
    rdfs:comment "Log entry indicating a connection error to Database Server 01."@en ;
    noria:loggingTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Customer_Portal ;
    noria:logText "Failed to connect to database 'customer_db' on db01.corp.example.com."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

:EventRecord_Network_Interface_Down a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Critical alert: Network interface on Core Switch 01 went down."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Core_Switch_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logText "Interface GigabitEthernet0/0/1 on coresw01.corp.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction :OperationPlan_Restart_Interface .

:EventRecord_User_Login_Failure a noria:EventRecord ;
    rdfs:label "User Login Failure"@en ;
    rdfs:comment "Log of a failed login attempt by a user."@en ;
    noria:loggingTime "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Application_Customer_Portal ;
    noria:logOriginatingAgent :Agent_Customer_User_1 ;
    noria:logText "User 'jdoe' failed to log in to Customer Portal."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

:Agent_Customer_User_1 a foaf:Agent ;
    rdfs:label "John Doe (Customer)"@en ;
    rdfs:comment "A customer attempting to access the portal."@en .

# --- Trouble Tickets ---
:TroubleTicket_CP_Outage a noria:TroubleTicket ;
    rdfs:label "Customer Portal Outage"@en ;
    rdfs:comment "Critical incident: Customer Portal is completely inaccessible."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
