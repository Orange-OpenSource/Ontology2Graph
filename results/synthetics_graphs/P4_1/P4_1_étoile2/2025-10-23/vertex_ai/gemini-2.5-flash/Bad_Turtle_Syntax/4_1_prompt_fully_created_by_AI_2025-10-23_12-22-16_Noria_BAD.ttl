# --- Operation Plans, Pre/Post Conditions ---
:OperationPlan_Restart_Interface a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a network interface on a Cisco device."@en ;
    skos:example "Commands: 'interface GigabitEthernet0/0/1', 'shutdown', 'no shutdown'"@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Interface_Down ;
    noria:operationPlanPostCondition :ActionPostCondition_Interface_Up .

:ActionPreCondition_Interface_Down a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: The network interface's operational status is 'down'."@en .

:ActionPostCondition_Interface_Up a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up'."@en .

:OperationPlan_DB_Patch_Apply a noria:OperationPlan ;
    rdfs:label "Database Patch Application Procedure"@en ;
    rdfs:comment "Procedure for applying security patches to the database software."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_DB_Maintenance_Window ;
    noria:operationPlanPostCondition :ActionPostCondition_DB_Service_Restored .

:ActionPreCondition_DB_Maintenance_Window a noria:ActionPreCondition ;
    rdfs:label "Database Maintenance Window"@en ;
    rdfs:comment "Condition: Scheduled maintenance window for database operations."@en .

:ActionPostCondition_DB_Service_Restored a noria:ActionPostCondition ;
    rdfs:label "Database Service Restored"@en ;
    rdfs:comment "Expected outcome: Database service is fully operational and accessible."@en .

