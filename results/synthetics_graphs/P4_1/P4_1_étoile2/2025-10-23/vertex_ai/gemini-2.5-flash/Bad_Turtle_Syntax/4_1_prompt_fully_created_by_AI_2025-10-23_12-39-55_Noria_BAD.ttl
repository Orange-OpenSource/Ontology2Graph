    noria:networkLinkId "DC-LAN-001" ;
    noria:networkLinkType "Ethernet"@en ;
    noria:networkLinkInstallationDate "2022-01-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_Network_Admin ;
    noria:networkLinkTerminationResourceOrigin :Resource_Router_Edge_01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Web_Server_01 . # Simplified for example, typically connects to a switch

:NetworkLink_Internet_Uplink a noria:NetworkLink ;
    rdfs:label "Internet Uplink"@en ;
    rdfs:comment "External link providing internet connectivity to the data center."@en ;
    noria:networkLinkId "ISP-UPLINK-001" ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:networkLinkInstallationDate "2022-01-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy :Agent_Network_Admin ;
    noria:networkLinkTerminationResource :Resource_Router_Edge_01 .

# --- Applications (noria:Application) ---
:Application_Customer_Portal a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:label "Application Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CUST-PORTAL-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CPORTAL" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Customer Self-Service"@en ;
    noria:elementManagedBy :Agent_App_Support_L2 .

:Application_Monitoring_System a noria:Application ;
    rdfs:label "Infrastructure Monitoring System"@en ;
    rdfs:label "Système de Supervision d'Infrastructure"@fr ;
    rdfs:comment "System for monitoring the health and performance of IT infrastructure."@en ;
    noria:applicationModelIdentifier "MON-SYS-V3" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "MONSYS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:elementManagedBy :Agent_IT_Ops_Team .

# --- Application Modules (noria:ApplicationModule) ---
:ApplicationModule_Customer_Portal_Prod a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:label "Module de Production Portail Client"@fr ;
    rdfs:comment "Production instance of the Customer Portal Application."@en ;
    noria:applicationModuleOf :Application_Customer_Portal ;
    noria:applicationModuleName "CPORTAL_PROD" ;
    noria:applicationModuleIdentifier "PROD-001" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam :Agent_IT_Ops_Team ;
    noria:applicationModuleSupportTeam :Agent_App_Support_L2 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

:ApplicationModule_Customer_Portal_Dev a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en ;
    rdfs:label "Module de Développement Portail Client"@fr ;
    rdfs:comment "Development instance of the Customer Portal Application."@en ;
    noria:applicationModuleOf :Application_Customer_Portal ;
    noria:applicationModuleName "CPORTAL_DEV" ;
    noria:applicationModuleIdentifier "DEV-001" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InDevelopment> ;
    noria:applicationModuleAdministrationTeam :Agent_IT_Ops_Team ;
    noria:applicationModuleSupportTeam :Agent_App_Support_L2 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleHotlineEnabled false .

# --- Services (noria:Service) ---
:Service_Customer_Facing_Web a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:label "Service Web Client"@fr ;
    rdfs:comment "End-to-end service providing web access to customers, composed of the Customer Portal Application."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :ApplicationModule_Customer_Portal_Prod . # Simplified, typically a service would compose multiple modules/applications.

:Service_Internal_Monitoring a noria:Service ;
    rdfs:label "Internal Monitoring Service"@en ;
    rdfs:comment "Service providing monitoring capabilities for internal infrastructure."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf :Application_Monitoring_System .

# --- Event Records (noria:EventRecord) ---
:EventRecord_Web_Server_CPU_High a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-03-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:EventRecord_Router_Interface_Down a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating that an interface on Edge Router 01 went down."@en ;
    noria:loggingTime "2024-03-20T10:10:15Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on edge01.dc.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject :Resource_Router_Edge_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_DB_Login_Failure a noria:EventRecord ;
    rdfs:label "Database Login Failure Alert"@en ;
    rdfs:comment "Security alert for multiple failed login attempts on DB Server 01."@en ;
    noria:loggingTime "2024-03-20T10:12:30Z"^^xsd:dateTime ;
    noria:logText "Multiple failed login attempts detected for user 'admin' on db01.corp.example.com from IP 192.168.1.5."@en ;
    noria:logOriginatingManagedObject :Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:logOriginatingAgent :Agent_Security_Team ; # The system detected it, but the security team is involved.
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:EventRecord_Config_Change_Router a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change applied to Edge Router 01."@en ;
    noria:loggingTime "2024-03-19T15:00:00Z"^^xsd:dateTime ;
    noria:logText "Configuration applied by Network Administrator John Doe on edge01.dc.example.com."@en ;
    noria:logOriginatingManagedObject :Resource_Router_Edge_01 ;
    noria:logOriginatingAgent :Agent_Network_Admin ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System .

# --- Trouble Tickets (noria:TroubleTicket) ---
:TroubleTicket_Internet_Outage a noria:TroubleTicket ;
    rdfs:label "Internet Uplink Outage"@en ;
    rdfs:label "Panne Liaison Internet"@fr ;
    rdfs:comment "Critical incident: Internet uplink to data center is down, impacting all services."@en ;
