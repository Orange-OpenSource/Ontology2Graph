# --- Operation Plans (noria:OperationPlan) ---
:OperationPlan_OS_Upgrade_Procedure a noria:OperationPlan ;
    rdfs:label "Standard OS Upgrade Procedure"@en ;
    rdfs:comment "Documented procedure for performing operating system upgrades on production servers."@en ;
    skos:example "Steps include backup, pre-checks, upgrade execution, post-checks, and rollback plan."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Server_Ready_For_Upgrade ;
    noria:operationPlanPostCondition :ActionPostCondition_OS_Upgrade_Successful .

:OperationPlan_Network_Firewall_Update a noria:OperationPlan ;
    rdfs:label "Network Firewall Rule Update Procedure"@en ;
    rdfs:comment "Procedure for safely adding or modifying firewall rules on network devices."@en ;
    skos:example "Steps include rule validation, staging, deployment, and traffic verification."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Firewall_Change_Approved ;
    noria:operationPlanPostCondition :ActionPostCondition_Firewall_Rule_Active .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
:ActionPreCondition_Server_Ready_For_Upgrade a noria:ActionPreCondition ;
    rdfs:label "Server Ready for Upgrade"@en ;
    rdfs:comment "All data backed up, maintenance window approved, and monitoring alerts suppressed."@en .

:ActionPostCondition_OS_Upgrade_Successful a noria:ActionPostCondition ;
    rdfs:label "OS Upgrade Successful"@en ;
    rdfs:comment "Server rebooted, all services started, and application functionality verified."@en .

:ActionPreCondition_Firewall_Change_Approved a noria:ActionPreCondition ;
    rdfs:label "Firewall Change Approved"@en ;
    rdfs:comment "Change Request for firewall rule update has been approved by change advisory board."@en .

:ActionPostCondition_Firewall_Rule_Active a noria:ActionPostCondition ;
    rdfs:label "Firewall Rule Active and Verified"@en ;
    rdfs:comment "New firewall rule is active, and traffic flow for the new service has been successfully tested."@en .

# --- Additional Connections for Density ---
:Agent_IT_Ops_Team noria:agentManagesResource :Resource_Web_Server_01, :Resource_DB_Server_01, :Resource_Virtual_Machine_App_01, :Resource_Hypervisor_01 .
:Agent_Network_Admin noria:agentManagesResource :Resource_Router_Edge_01, :NetworkLink_DC_Internal_LAN, :NetworkLink_Internet_Uplink .
:Agent_App_Support_L2 noria:agentManagesResource :Application_Customer_Portal, :ApplicationModule_Customer_Portal_Prod, :ApplicationModule_Customer_Portal_Dev .

:TroubleTicket_Internet_Outage noria:documentStatusHistory :EventRecord_Router_Interface_Down .
:TroubleTicket_Customer_Portal_Slow noria:documentStatusHistory :EventRecord_Web_Server_CPU_High .

:ChangeRequest_Web_Server_Upgrade dcterms:hasPart :OperationPlan_OS_Upgrade_Procedure .
:ChangeRequest_Network_Firewall_Rule dcterms:hasPart :OperationPlan_Network_Firewall_Update .

:EventRecord_Router_Interface_Down noria:alarmProposedRepairAction :OperationPlan_Network_Firewall_Update . # Example of linking an alarm to a potential repair action.
:EventRecord_Web_Server_CPU_High noria:alarmMitigatedBy :TroubleTicketNote_Customer_Portal_Update_1 . # The note describes the action that mitigated the alarm.

:Application_Customer_Portal noria:resourceForApplication :Resource_Web_Server_01, :Resource_DB_Server_01, :Resource_Virtual_Machine_App_01 .
:Application_Monitoring_System noria:resourceForApplication :Resource_Hypervisor_01 . # Monitoring system itself runs on a hypervisor.

