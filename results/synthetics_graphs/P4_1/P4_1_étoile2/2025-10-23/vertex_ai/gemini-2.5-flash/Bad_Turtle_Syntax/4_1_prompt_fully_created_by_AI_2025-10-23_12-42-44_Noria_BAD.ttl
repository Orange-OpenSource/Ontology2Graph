    noria:changeRequestActorParty foaf:Agent_Network_Admin ;
    noria:changeRequestIsRegulated true .

# --- Operation Plans (noria:OperationPlan) ---
# Standardized procedures for IT operations.
<operationplan/op-web-patching> a noria:OperationPlan ;
    rdfs:label "Web Server Patching Procedure"@en ;
    rdfs:comment "Standard operating procedure for applying OS patches to web servers."@en ;
    skos:example "Steps include: backup, apply patches, reboot, verify service."@en ;
    noria:operationPlanPreCondition <actionprecondition/web-server-reachable> ;
    noria:operationPlanPostCondition <actionpostcondition/web-service-verified> .

<operationplan/op-router-firmware-upgrade> a noria:OperationPlan ;
    rdfs:label "Core Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed procedure for upgrading firmware on core network routers."@en ;
    skos:example "Steps include: pre-checks, backup config, upload image, reload, post-checks."@en ;
    noria:operationPlanPreCondition <actionprecondition/router-reachable-and-stable> ;
    noria:operationPlanPostCondition <actionpostcondition/router-operational-and-stable> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
# Conditions that must be met before/after an operation.
<actionprecondition/web-server-reachable> a noria:ActionPreCondition ;
    rdfs:label "Web Server Reachable"@en ;
    rdfs:comment "Ensure the web server is reachable via ping and SSH before starting patching."@en .

<actionpostcondition/web-service-verified> a noria:ActionPostCondition ;
    rdfs:label "Web Service Verified"@en ;
    rdfs:comment "Verify that the corporate website is accessible and functional after patching."@en .

<actionprecondition/router-reachable-and-stable> a noria:ActionPreCondition ;
    rdfs:label "Router Reachable and Stable"@en ;
    rdfs:comment "Confirm router is reachable, CPU/memory usage is normal, and no critical alarms are active."@en .

<actionpostcondition/router-operational-and-stable> a noria:ActionPostCondition ;
    rdfs:label "Router Operational and Stable"@en ;
    rdfs:comment "Verify router uptime, routing table, interface status, and absence of critical alarms after upgrade."@en .

# Linking Change Requests to Operation Plans
<changerequest/cr-20240425-001> noria:changeRequestSpecification <operationplan/op-web-patching> .
<changerequest/cr-20240426-001> noria:changeRequestSpecification <operationplan/op-router-firmware-upgrade> .

# Example of an EventRecord being mitigated by a ProcedureExecutionContainer (e.g., a TroubleTicket)
<eventrecord/cr01-link-down-20240423-01> noria:alarmMitigatedBy <troubleticket/tt-20240423-001> .

# Example of document status history for a TroubleTicket
<troubleticket/tt-20240423-001> noria:documentStatusHistory <eventrecord/tt-status-change-inprogress> .

<eventrecord/tt-status-change-inprogress> a noria:EventRecord ;
    rdfs:label "TT-20240423-001 Status Change to InProgress"@en ;
    noria:loggingTime "2024-04-23T10:12:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240423-001 status changed from New to InProgress." ;
    noria:logOriginatingManagementSystem <application/ticketing-system> ;
    noria:logOriginatingAgent foaf:Agent_IT_Ops_Team ;
    dcterms:references <troubleticket/tt-20240423-001> .

<application/ticketing-system> a noria:Application ;
    rdfs:label "ITSM Ticketing System"@en ;
    noria:applicationShortIdentifier "ITSM" ;
    noria:applicationType <kos/application/type/internal-business> ;
    noria:elementManagedBy foaf:Agent_IT_Ops_Team .
