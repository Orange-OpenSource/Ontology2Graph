# =============================================================================
# Procedural Elements (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

<operationplan/RestartServer> a noria:OperationPlan ;
    rdfs:label "Standard Server Restart Procedure"@en ;
    rdfs:comment "A documented procedure for safely restarting a server, including pre-checks and post-checks."@en ;
    skos:example "Steps include: 1. Check logs for root cause. 2. Attempt graceful shutdown. 3. Force power cycle if necessary. 4. Verify service restoration."@en ;
    noria:operationPlanPreCondition <actionprecondition/ServerUnresponsive> ;
    noria:operationPlanPostCondition <actionpostcondition/ServiceRestored> .

<actionprecondition/ServerUnresponsive> a noria:ActionPreCondition ;
    rdfs:label "Server Unresponsive Pre-Condition"@en ;
    rdfs:comment "Condition: Server is not responding to network pings or management interface access."@en .

<actionpostcondition/ServiceRestored> a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Condition: All critical services on the server are running and accessible, and monitoring alerts are cleared."@en .

<operationplan/OSPatchingProcedure> a noria:OperationPlan ;
    rdfs:label "Operating System Patching Procedure"@en ;
    rdfs:comment "Detailed steps for applying OS patches and updates to production servers."@en ;
    noria:operationPlanPreCondition <actionprecondition/BackupCompleted> ;
    noria:operationPlanPostCondition <actionpostcondition/SystemStabilityVerified> .

<actionprecondition/BackupCompleted> a noria:ActionPreCondition ;
    rdfs:label "Backup Completed Pre-Condition"@en ;
    rdfs:comment "Condition: A full backup of the system has been successfully completed and verified."@en .

<actionpostcondition/SystemStabilityVerified> a noria:ActionPostCondition ;
    rdfs:label "System Stability Verified Post-Condition"@en ;
    rdfs:comment "Condition: System uptime, resource utilization, and application functionality are stable after patching."@en .

