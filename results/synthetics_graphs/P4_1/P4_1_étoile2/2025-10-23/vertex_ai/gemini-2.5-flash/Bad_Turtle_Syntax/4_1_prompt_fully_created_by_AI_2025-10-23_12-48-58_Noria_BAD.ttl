<location/DataCenter_NYC01> a bot:Site ;
    rdfs:label "NYC01 Data Center"@en ;
    rdfs:comment "Primary data center located in New York City."@en ;
    noria:siteId "NYC01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Main Street"@en ;
    noria:sitePrincipalAddressCityName "New York"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

<location/ServerRoom_NYC01_A> a noria:Room ;
    rdfs:label "Server Room A - NYC01"@en ;
    rdfs:comment "Main server room within the NYC01 Data Center."@en ;
    bot:hasSpace <location/DataCenter_NYC01> .

<location/Locus_NYC01_A_R12_U23> a noria:Locus ;
    rdfs:label "Rack 12, Unit 23 in Server Room A"@en ;
    rdfs:comment "Specific location for a server within Rack 12, Unit 23."@en ;
    noria:locusLine "Rack 12"@en ;
    noria:locusRow "Unit 23"@en ;
    bot:hasSpace <location/ServerRoom_NYC01_A> .

<location/Locus_NYC01_A_R12_U24> a noria:Locus ;
    rdfs:label "Rack 12, Unit 24 in Server Room A"@en ;
    rdfs:comment "Specific location for a server within Rack 12, Unit 24."@en ;
    noria:locusLine "Rack 12"@en ;
    noria:locusRow "Unit 24"@en ;
    bot:hasSpace <location/ServerRoom_NYC01_A> .

<location/Locus_NYC01_A_R05_U10> a noria:Locus ;
    rdfs:label "Rack 05, Unit 10 in Server Room A"@en ;
    rdfs:comment "Specific location for a network device within Rack 05, Unit 10."@en ;
    noria:locusLine "Rack 05"@en ;
    noria:locusRow "Unit 10"@en ;
    bot:hasSpace <location/ServerRoom_NYC01_A> .

