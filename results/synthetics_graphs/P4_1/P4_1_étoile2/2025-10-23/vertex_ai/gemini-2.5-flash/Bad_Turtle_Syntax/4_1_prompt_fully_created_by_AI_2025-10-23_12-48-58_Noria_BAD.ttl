# =============================================================================
# Resources (noria:Resource)
# =============================================================================

<resource/DNS01> a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for the corporate network, critical for internet access."@en ;
    noria:resourceManagedBy <agent/DNSAdminTeam> ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel <productmodel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <location/Locus_NYC01_A_R12_U23> ;
    noria:resourceManagementIPAddress "192.168.10.10" .

<resource/DNS02> a noria:Resource ;
    rdfs:label "Corporate DNS Server 02"@en ;
    rdfs:comment "Secondary DNS server for the corporate network, providing redundancy."@en ;
    noria:resourceManagedBy <agent/DNSAdminTeam> ;
    noria:resourceHostName "dns02.corp.example.com" ;
    noria:resourceProductModel <productmodel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceLogisticId "LOG-DNS-002" ;
    noria:resourceSerialNumber "SN-DNS02-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <location/Locus_NYC01_A_R12_U24> ;
    noria:resourceManagementIPAddress "192.168.10.11" .

<resource/CoreSwitch01> a noria:Resource ;
    rdfs:label "Core Network Switch 01"@en ;
    rdfs:comment "Main network switch in the NYC01 data center."@en ;
    noria:resourceManagedBy <agent/NetworkOperationsCenter> ;
    noria:resourceHostName "coresw01.nyc01.example.com" ;
    noria:resourceProductModel <productmodel/CiscoCatalyst9300> ;
    noria:resourceType <kos/Resource/type/NetworkDevice> ;
    noria:resourceLogisticId "LOG-CSW-001" ;
    noria:resourceSerialNumber "SN-CSW01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-05-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <location/Locus_NYC01_A_R05_U10> ;
    noria:resourceManagementIPAddress "10.0.0.1" .

<resource/VirtualMachine_Web01> a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceManagedBy <agent/ApplicationSupportTeam> ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T14:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "172.16.1.10" .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

<networkinterface/DNS01_Eth0> a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf <resource/DNS01> ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/DNS02_Eth0> a noria:NetworkInterface ;
    rdfs:label "DNS02 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS02 server."@en ;
    noria:networkInterfaceOf <resource/DNS02> ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/CoreSwitch01_Gi0_1> a noria:NetworkInterface ;
    rdfs:label "CoreSwitch01 GigabitEthernet0/1"@en ;
    rdfs:comment "Uplink interface from CoreSwitch01 to external network."@en ;
    noria:networkInterfaceOf <resource/CoreSwitch01> ;
    noria:networkInterfaceDescription "Uplink to ISP router."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/CoreSwitch01_Gi0_2> a noria:NetworkInterface ;
    rdfs:label "CoreSwitch01 GigabitEthernet0/2"@en ;
    rdfs:comment "Interface connecting CoreSwitch01 to DNS servers VLAN."@en ;
    noria:networkInterfaceOf <resource/CoreSwitch01> ;
    noria:networkInterfaceDescription "Connection to DNS server segment."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

<networklink/DNS01_CoreSwitch_Link> a noria:NetworkLink ;
    rdfs:label "Link DNS01 to CoreSwitch01"@en ;
    rdfs:comment "Physical link between DNS01 and CoreSwitch01."@en ;
    noria:networkLinkId "NL-DNS01-CSW01" ;
    noria:networkLinkTerminationResourceOrigin <resource/DNS01> ;
    noria:networkLinkTerminationResourceDestination <resource/CoreSwitch01> ;
    noria:networkLinkInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy <agent/NetworkOperationsCenter> ;
    noria:networkInterfaceConnects <networkinterface/DNS01_Eth0> ;
    noria:networkInterfaceConnects <networkinterface/CoreSwitch01_Gi0_2> .

<networklink/DNS02_CoreSwitch_Link> a noria:NetworkLink ;
    rdfs:label "Link DNS02 to CoreSwitch01"@en ;
    rdfs:comment "Physical link between DNS02 and CoreSwitch01."@en ;
    noria:networkLinkId "NL-DNS02-CSW01" ;
    noria:networkLinkTerminationResourceOrigin <resource/DNS02> ;
    noria:networkLinkTerminationResourceDestination <resource/CoreSwitch01> ;
    noria:networkLinkInstallationDate "2022-01-15T11:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy <agent/NetworkOperationsCenter> ;
    noria:networkInterfaceConnects <networkinterface/DNS02_Eth0> ;
    noria:networkInterfaceConnects <networkinterface/CoreSwitch01_Gi0_2> .

<networklink/CoreSwitch_ISP_Uplink> a noria:NetworkLink ;
    rdfs:label "CoreSwitch01 to ISP Uplink"@en ;
    rdfs:comment "Uplink connection from CoreSwitch01 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-CSW01-ISP" ;
    noria:networkLinkTerminationResourceOrigin <resource/CoreSwitch01> ;
    noria:networkLinkInstallationDate "2021-05-20T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" ;
    noria:resourceManagedBy <agent/NetworkOperationsCenter> ;
    noria:networkInterfaceConnects <networkinterface/CoreSwitch01_Gi0_1> .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

<application/CorporateInternetAccess> a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and services."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "Internet Connectivity"@en ;
    noria:resourceManagedBy <agent/NetworkOperationsCenter> .

<application/CorporateWebsite> a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "Public-facing website for the company."@en ;
    noria:applicationType <kos/application/type/business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationModelIdentifier "CWEB-APP" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CWEB" ;
    noria:applicationFunctionalDomain "Marketing & Sales"@en ;
    noria:applicationFunctionalSubDomain "Online Presence"@en ;
    noria:resourceManagedBy <agent/ApplicationSupportTeam> ;
    noria:resourceForApplication <resource/VirtualMachine_Web01> .

<application/MonitoringSystem> a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "System responsible for monitoring the health and performance of IT infrastructure."@en ;
    noria:applicationType <kos/application/type/management> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "NMS-APP" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationFunctionalDomain "IT Operations"@en ;
    noria:applicationFunctionalSubDomain "Monitoring & Alerting"@en ;
    noria:resourceManagedBy <agent/NetworkOperationsCenter> .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

<applicationmodule/CIA_Prod> a noria:ApplicationModule ;
    rdfs:label "Corporate Internet Access Production Module"@en ;
    rdfs:comment "Production instance of the Corporate Internet Access application."@en ;
    noria:applicationModuleOf <application/CorporateInternetAccess> ;
    noria:applicationModuleName "CIA_Prod" ;
    noria:applicationModuleIdentifier "CIA-PROD-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Critical> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam <agent/NetworkOperationsCenter> ;
    noria:applicationModuleSupportTeam <agent/NetworkOperationsCenter> ;
    noria:applicationModuleHotlineGroup <agent/NetworkOperationsCenter> .

<applicationmodule/CWEB_Prod> a noria:ApplicationModule ;
    rdfs:label "Corporate Website Production Module"@en ;
    rdfs:comment "Production instance of the Corporate Website application."@en ;
    noria:applicationModuleOf <application/CorporateWebsite> ;
    noria:applicationModuleName "CWEB_Prod" ;
    noria:applicationModuleIdentifier "CWEB-PROD-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w33id.org/noria/kos/application/sla-level/High> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleAdministrationTeam <agent/ApplicationSupportTeam> ;
    noria:applicationModuleSupportTeam <agent/ApplicationSupportTeam> .

# =============================================================================
# Services (noria:Service)
# =============================================================================

<service/EnterpriseConnectivity> a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing network connectivity and internet access to the enterprise."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <applicationmodule/CIA_Prod> ; # Linking service to application module
    seas:subSystemOf <resource/DNS01> ; # Service relies on DNS01
    seas:subSystemOf <resource/CoreSwitch01> . # Service relies on CoreSwitch01

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

<eventrecord/DNS01_Down_Alert> a noria:EventRecord ;
    rdfs:label "DNS01 Server Down Alert"@en ;
    rdfs:comment "Alert generated by monitoring system indicating DNS01 is unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logText "Host dns01.corp.example.com is DOWN. Ping failed."@en ;
    noria:logOriginatingManagedObject <resource/DNS01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <operationplan/RestartServer> .

<eventrecord/DNS01_Interface_Down> a noria:EventRecord ;
    rdfs:label "DNS01 Interface Down Log"@en ;
    rdfs:comment "Log entry from CoreSwitch01 indicating DNS01's interface went down."@en ;
    noria:loggingTime "2024-04-10T08:59:50Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/2 on coresw01 changed state to down."@en ;
    noria:logOriginatingManagedObject <resource/CoreSwitch01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<eventrecord/DNS01_Restart_Success> a noria:EventRecord ;
    rdfs:label "DNS01 Server Restart Success"@en ;
    rdfs:comment "Log entry confirming successful restart of DNS01."@en ;
    noria:loggingTime "2024-04-10T09:30:00Z"^^xsd:dateTime ;
    noria:logText "System reboot initiated by John Doe. Services restored."@en ;
    noria:logOriginatingManagedObject <resource/DNS01> ;
    noria:logOriginatingAgent <agent/JohnDoe> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

<eventrecord/DNS01_CPU_Spike> a noria:EventRecord ;
    rdfs:label "DNS01 CPU Spike Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on DNS01 prior to outage."@en ;
    noria:loggingTime "2024-04-10T08:45:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on dns01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject <resource/DNS01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

<troubleticket/TT-20240410-001> a noria:TroubleTicket ;
    rdfs:label "Critical DNS01 Server Outage"@en ;
    rdfs:comment "Primary DNS server dns01.corp.example.com is down, impacting corporate internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
