# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizational Units (Teams)
<org/team/NetworkOperations> a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for the overall network infrastructure operations and maintenance."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical issues, call the hotline immediately. For non-critical, use the ticketing system."@en .

<org/team/ApplicationSupport> a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the portal for all application-related issues."@en .

<org/team/SecurityOperations> a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate all security alerts to the SOC hotline."@en .

# Individual Agents
<foaf/agent/AliceSmith> a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    org:memberOf <org/team/NetworkOperations> .

<foaf/agent/BobJohnson> a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    org:memberOf <org/team/ApplicationSupport> .

<foaf/agent/CharlieBrown> a foaf:Person ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    foaf:phone "+1-555-111-2222" ;
    org:memberOf <org/team/SecurityOperations> .

# Corporate User Identifiers
<noria/cuid/ASmith> a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount <foaf/agent/AliceSmith> .

# =============================================================================
# Locations
# =============================================================================

<bot/site/DataCenter_Paris> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

<noria/room/ServerRoom_A> a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room within the Paris Data Center."@en ;
    bot:hasSpace <bot/site/DataCenter_Paris> .

<noria/locus/Rack_A1_U10> a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Specific location within Server Room A for server rack A1, unit 10."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "10" ;
    bot:hasSpace <noria/room/ServerRoom_A> .

<noria/locus/Rack_B2_U5> a noria:Locus ;
    rdfs:label "Rack B2, Unit 5"@en ;
    rdfs:comment "Specific location within Server Room A for server rack B2, unit 5."@en ;
    noria:locusLine "B2" ;
    noria:locusRow "5" ;
    bot:hasSpace <noria/room/ServerRoom_A> .

# =============================================================================
# Product Models
# =============================================================================

<noria/productmodel/DellPowerEdgeR740> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <org/company/Dell> .

<noria/productmodel/CiscoCatalyst9300> a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch."@en ;
    noria:productManufacturedBy <org/company/Cisco> .

<noria/productmodel/VMwareESXi> a noria:ProductModel ;
    rdfs:label "VMware ESXi"@en ;
    rdfs:comment "Hypervisor for virtual machines."@en ;
    noria:productManufacturedBy <org/company/VMware> .

<org/company/Dell> a org:Organization ;
    rdfs:label "Dell Inc."@en ;
    rdfs:comment "Technology company that develops, sells, repairs, and supports computers and related products and services."@en .

<org/company/Cisco> a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

<org/company/VMware> a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

# =============================================================================
# Resources
# =============================================================================

<noria/resource/Server_Web01> a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Primary web server hosting the corporate website."@en ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceLogisticId "LOG-WEB-001" ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ" ;
    noria:resourceProductModel <noria/productmodel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/team/ApplicationSupport> ;
    noria:locatedAtLocus <noria/locus/Rack_A1_U10> ;
    noria:resourceManagementIPAddress <observable/ipaddress/192.168.1.10> .

<noria/resource/Router_Core01> a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network, handling internal and external traffic."@en ;
    noria:resourceHostName "router01.corp.example.com" ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceProductModel <noria/productmodel/CiscoCatalyst9300> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/team/NetworkOperations> ;
    noria:locatedAtLocus <noria/locus/Rack_B2_U5> ;
    noria:resourceManagementIPAddress <observable/ipaddress/10.0.0.1> .

<noria/resource/VM_DB01> a noria:Resource ;
    rdfs:label "Database VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate database."@en ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceLogisticId "LOG-VM-DB-001" ;
    noria:resourceSerialNumber "SN-VM-DB-001-DEF" ;
    noria:resourceProductModel <noria/productmodel/VMwareESXi> ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/team/ApplicationSupport> ;
    noria:resourceForApplication <noria/application/CorporateWebsite> ;
    noria:clusterController <noria/resource/Hypervisor_Host01> ;
    noria:resourceManagementIPAddress <observable/ipaddress/192.168.1.20> .

<noria/resource/Hypervisor_Host01> a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical host running virtual machines."@en ;
    noria:resourceHostName "hypervisor01.corp.example.com" ;
    noria:resourceLogisticId "LOG-HV-001" ;
    noria:resourceSerialNumber "SN-HV-001-GHI" ;
    noria:resourceProductModel <noria/productmodel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/team/NetworkOperations> ;
    noria:locatedAtLocus <noria/locus/Rack_A1_U10> ;
    noria:resourceManagementIPAddress <observable/ipaddress/192.168.1.5> .

# =============================================================================
# Network Interfaces
# =============================================================================

<noria/networkinterface/Web01_Eth0> a noria:NetworkInterface ;
    rdfs:label "Web01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf <noria/resource/Server_Web01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connected to internal LAN segment 192.168.1.0/24" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<noria/networkinterface/Router01_Gig0_0_0> a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface for Core Router 01 to the internet."@en ;
    noria:networkInterfaceOf <noria/resource/Router_Core01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Internet Uplink" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int .

<noria/networkinterface/Router01_Gig0_0_1> a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Internal LAN interface for Core Router 01."@en ;
    noria:networkInterfaceOf <noria/resource/Router_Core01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Internal LAN" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<noria/networkinterface/VMDB01_Eth0> a noria:NetworkInterface ;
    rdfs:label "DB01 Virtual Ethernet 0"@en ;
    rdfs:comment "Virtual network interface for Database VM 01."@en ;
    noria:networkInterfaceOf <noria/resource/VM_DB01> ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "Connected to internal DB segment 192.168.1.0/24" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links
# =============================================================================

<noria/networklink/InternetUplink_Link> a noria:NetworkLink ;
    rdfs:label "Internet Uplink Link"@en ;
    rdfs:comment "Physical fiber link connecting Core Router 01 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-ISP-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2022-03-20T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <noria/resource/Router_Core01> ;
    noria:networkLinkTerminationResourceDestination <noria/resource/ISP_Router> ;
    noria:resourceManagedBy <org/team/NetworkOperations> .

<noria/networklink/InternalLAN_Link> a noria:NetworkLink ;
    rdfs:label "Internal LAN Link"@en ;
    rdfs:comment "Logical link representing the internal corporate LAN segment."@en ;
    noria:networkLinkId "NL-LAN-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-03-20T14:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource <noria/resource/Router_Core01> ;
    noria:networkLinkTerminationResource <noria/resource/Server_Web01> ;
    noria:networkLinkTerminationResource <noria/resource/VM_DB01> ;
    noria:resourceManagedBy <org/team/NetworkOperations> .

<noria/resource/ISP_Router> a noria:Resource ;
    rdfs:label "ISP Router"@en ;
    rdfs:comment "Router managed by the Internet Service Provider."@en ;
    noria:resourceHostName "isp-router.example.com" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> .

<noria/networkinterface/Router01_Gig0_0_0> noria:networkInterfaceConnects <noria/networklink/InternetUplink_Link> .
<noria/networkinterface/Web01_Eth0> noria:networkInterfaceConnects <noria/networklink/InternalLAN_Link> .
<noria/networkinterface/Router01_Gig0_0_1> noria:networkInterfaceConnects <noria/networklink/InternalLAN_Link> .
<noria/networkinterface/VMDB01_Eth0> noria:networkInterfaceConnects <noria/networklink/InternalLAN_Link> .

# =============================================================================
# Applications
# =============================================================================

<noria/application/CorporateWebsite> a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "The official corporate website, accessible to the public."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CW" ;
    noria:applicationType <kos/application/type/CustomerFacing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Marketing and Sales" ;
    noria:applicationFunctionalSubDomain "Online Presence" .

<noria/application/InternalCRM> a noria:Application ;
    rdfs:label "Internal CRM System"@en ;
    rdfs:comment "Customer Relationship Management system used internally by sales and support teams."@en ;
    noria:applicationModelIdentifier "CRM" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/InternalBusiness> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales and Support Operations" .

<noria/application/MonitoringSystem> a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "System for monitoring network devices and services."@en ;
    noria:applicationModelIdentifier "NMS" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Network Monitoring" .

# =============================================================================
# Application Modules
# =============================================================================

<noria/applicationmodule/CorporateWebsite_Prod> a noria:ApplicationModule ;
    rdfs:label "Corporate Website Production Module"@en ;
    rdfs:comment "Production instance of the Corporate Website application."@en ;
    noria:applicationModuleOf <noria/application/CorporateWebsite> ;
    noria:applicationModuleName "CORPWEB_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleAdministrationTeam <org/team/ApplicationSupport> ;
    noria:applicationModuleAdministrationLeader <foaf/agent/BobJohnson> ;
    noria:applicationModuleSupportTeam <org/team/ApplicationSupport> ;
    noria:applicationModuleSupportLeader <foaf/agent/BobJohnson> ;
    noria:applicationModuleHotlineGroup <org/team/ApplicationSupport> .

<noria/applicationmodule/InternalCRM_Dev> a noria:ApplicationModule ;
    rdfs:label "Internal CRM System Development Module"@en ;
    rdfs:comment "Development instance of the Internal CRM System."@en ;
    noria:applicationModuleOf <noria/application/InternalCRM> ;
    noria:applicationModuleName "CRM_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InDevelopment> ;
    noria:applicationModuleAdministrationTeam <org/team/ApplicationSupport> .

# =============================================================================
# Services
# =============================================================================

<noria/service/PublicWebAccess> a noria:Service ;
    rdfs:label "Public Web Access Service"@en ;
    rdfs:comment "End-to-end service providing public access to corporate web resources."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <noria/applicationmodule/CorporateWebsite_Prod> .

<noria/service/InternalNetworkConnectivity> a noria:Service ;
    rdfs:label "Internal Network Connectivity Service"@en ;
    rdfs:comment "Core service ensuring network connectivity for all internal systems."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf <noria/resource/Router_Core01> .

# =============================================================================
# Event Records
# =============================================================================

<noria/eventrecord/Log_Web01_CPU_High> a noria:EventRecord ;
    rdfs:label "Web01 High CPU Alert"@en ;
    rdfs:comment "Log entry indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject <noria/resource/Server_Web01> ;
    noria:logOriginatingManagementSystem <noria/application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<noria/eventrecord/Log_Router01_InterfaceDown> a noria:EventRecord ;
    rdfs:label "Router01 Interface Down Alert"@en ;
    rdfs:comment "Log entry indicating that an interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/0 on router01.corp.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject <noria/resource/Router_Core01> ;
    noria:logOriginatingManagementSystem <noria/application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<noria/eventrecord/Log_UserLoginFailure> a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security log entry for a failed login attempt."@en ;
    noria:loggingTime "2024-04-20T10:20:10Z"^^xsd:dateTime ;
    noria:logText "Failed login for user 'unknown' from IP 203.0.113.42 on Web01."@en ;
    noria:logOriginatingManagedObject <noria/resource/Server_Web01> ;
    noria:logOriginatingManagementSystem <noria/application/MonitoringSystem> ;
    noria:logOriginatingAgent <foaf/agent/CharlieBrown> ; # Assuming Charlie Brown is monitoring this
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

<noria/eventrecord/Log_ConfigChange_Router01> a noria:EventRecord ;
    rdfs:label "Router01 Configuration Change"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router 01."@en ;
    noria:loggingTime "2024-04-19T15:00:00Z"^^xsd:dateTime ;
    noria:logText "Configuration changed by asmith from console."@en ;
    noria:logOriginatingManagedObject <noria/resource/Router_Core01> ;
    noria:logOriginatingAgent <foaf/agent/AliceSmith> .

# =============================================================================
# Trouble Tickets
# =============================================================================

<noria/troubleticket/TT_20240420_001> a noria:TroubleTicket ;
    rdfs:label "Internet Uplink Down Incident"@en ;
    rdfs:comment "Critical incident: Internet uplink for corporate network is down, impacting all external services."@en ;
    dcterms:created "2024-04-20T10:16:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <noria/eventrecord/Log_Router01_InterfaceDown> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Fiber cut on ISP side."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <org/team/NetworkOperations> ;
    noria:troubleTicketRelatedParty <foaf/agent/AliceSmith> ;
    noria:troubleTicketRelatedService <noria/service/PublicWebAccess> ;
    noria:troubleTicketRelatedResource <noria/resource/Router_Core01> ;
    noria:troubleTicketImpacts <noria/application/CorporateWebsite> ;
    noria:troubleTicketImpacts <noria/service/PublicWebAccess> ;
    noria:troubleTicketImpacts <noria/networklink/InternetUplink_Link> ;
    noria:documentStatusHistory <noria/eventrecord/TT_20240420_001_StatusChange_Initialised> ;
    noria:documentStatusHistory <noria/eventrecord/TT_20240420_001_StatusChange_InProgress> .

<noria/eventrecord/TT_20240420_001_StatusChange_Initialised> a noria:EventRecord ;
    rdfs:label "TT_20240420_001 Status Initialised"@en ;
    noria:loggingTime "2024-04-20T10:16:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT_20240420_001 status changed to Initialised."@en ;
    noria:logOriginatingManagementSystem <noria/application/MonitoringSystem> ;
    dcterms:references <noria/troubleticket/TT_20240420_001> .

<noria/eventrecord/TT_20240420_001_StatusChange_InProgress> a noria:EventRecord ;
    rdfs:label "TT_20240420_001 Status InProgress"@en ;
