# =============================================================================
# Operation Plans and Conditions
# =============================================================================

<noria/operationplan/RouterOSUpgradeProcedure> a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems."@en ;
    skos:example "Steps include backup configuration, download new image, install, reboot, verify."@en ;
    noria:operationPlanPreCondition <noria/actionprecondition/RouterBackupComplete> ;
    noria:operationPlanPostCondition <noria/actionpostcondition/RouterOSVerified> .

<noria/actionprecondition/RouterBackupComplete> a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Complete"@en ;
    rdfs:comment "Ensures that a full backup of the router configuration has been successfully performed before proceeding with the OS upgrade."@en .

<noria/actionpostcondition/RouterOSVerified> a noria:ActionPostCondition ;
    rdfs:label "Router OS Version Verified"@en ;
    rdfs:comment "Verifies that the router is running the new OS version and all critical services are operational after the upgrade."@en .

<noria/eventrecord/Log_Router01_InterfaceDown> noria:alarmProposedRepairAction <noria/operationplan/TroubleshootInterfaceDown> .

<noria/operationplan/TroubleshootInterfaceDown> a noria:OperationPlan ;
    rdfs:label "Troubleshoot Interface Down Procedure"@en ;
    rdfs:comment "Procedure to diagnose and resolve network interface down issues."@en ;
    noria:operationPlanPreCondition <noria/actionprecondition/InterfaceStatusDown> ;
    noria:operationPlanPostCondition <noria/actionpostcondition/InterfaceStatusUp> .

<noria/actionprecondition/InterfaceStatusDown> a noria:ActionPreCondition ;
    rdfs:label "Network Interface Operational Status Down"@en ;
    rdfs:comment "Condition where a network interface's operational status is reported as 'down'."@en .

<noria/actionpostcondition/InterfaceStatusUp> a noria:ActionPostCondition ;
    rdfs:label "Network Interface Operational Status Up"@en ;
    rdfs:comment "Condition where a network interface's operational status is restored to 'up'."@en .

