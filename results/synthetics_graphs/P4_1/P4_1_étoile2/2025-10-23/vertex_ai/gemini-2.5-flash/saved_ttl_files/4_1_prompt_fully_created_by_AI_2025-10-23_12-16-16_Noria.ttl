# --- Trouble Tickets (noria:TroubleTicket) ---
noria:TroubleTicket_DNSOutage
    a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident de panne du serveur DNS"@fr ;
    rdfs:comment "Critical incident regarding the corporate DNS server being unreachable."@en ;
    dcterms:identifier "TT-DNS-20240420-001" ;
    dcterms:created "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/NetworkConnectivity> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketCause "Network connectivity issue to DNS server."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:ApplicationModule_CorpDNS_Prod ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty noria:Agent_AdminTeam, noria:Agent_NetworkOps ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageLog ;
    noria:documentStatusHistory noria:EventRecord_DNSStatusChangeToInProgress, noria:EventRecord_DNSStatusChangeToResolved .

noria:TroubleTicket_WebAppPerf
    a noria:TroubleTicket ;
    rdfs:label "Web App Performance Degradation"@en ;
    rdfs:label "Dégradation des performances de l'application Web"@fr ;
    rdfs:comment "Customer reported slow response times for the web application."@en ;
