noria:ProductModel_CiscoNexus9K
    a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series for high-density deployments."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> . # Assuming a URI for Cisco organization

noria:ProductModel_VMwareESXi
    a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> . # Assuming a URI for VMware organization

# --- Resources (noria:Resource) ---
noria:Resource_DNS01
    a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_RouterCore01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for internal network traffic in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTR-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.254> .

noria:Resource_WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:label "Serveur Web 01"@fr ;
    rdfs:comment "Server hosting the customer-facing web application."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-WEB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceForApplication noria:Application_WebApp ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> .

noria:Resource_Firewall01
    a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:label "Pare-feu Périphérique 01"@fr ;
    rdfs:comment "Firewall protecting the corporate network from external threats."@en ;
    noria:resourceManagedBy noria:Agent_SecurityAnalyst ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceSerialNumber "SN-FW-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_DB01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:label "Serveur de Base de Données 01"@fr ;
    rdfs:comment "Database server for the customer-facing web application."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/database-server> ;
    noria:resourceSerialNumber "SN-DB-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceForApplication noria:Application_WebApp ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.30> .

# --- Network Interfaces (noria:NetworkInterface) ---
noria:NetworkInterface_DNS01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DNS01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to internal network."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_RouterCore01_Ge0_0_1
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting core router to internal server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to server rack A1."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_RouterCore01_Ge0_0_2
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting core router to internal server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to server rack A2."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_WebSrv01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for WebSrv01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Ethernet interface for web application traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_Firewall01_Ext
    a noria:NetworkInterface ;
    rdfs:label "Firewall01 External Interface"@en ;
    rdfs:comment "External facing interface of Firewall01, connected to ISP."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceDescription "WAN interface to external network."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -8 .

noria:NetworkInterface_Firewall01_Int
    a noria:NetworkInterface ;
    rdfs:label "Firewall01 Internal Interface"@en ;
    rdfs:comment "Internal facing interface of Firewall01, connected to core router."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceDescription "LAN interface to internal network."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links (noria:NetworkLink) ---
noria:NetworkLink_DNS01_Core01
    a noria:NetworkLink ;
    rdfs:label "Link DNS01 to Core01"@en ;
    rdfs:comment "Physical link between DNS01 and RouterCore01."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkId "NL-DNS-RTR-001" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Ge0_0_1 .

noria:NetworkLink_WebSrv01_Core01
    a noria:NetworkLink ;
    rdfs:label "Link WebSrv01 to Core01"@en ;
    rdfs:comment "Physical link between WebSrv01 and RouterCore01."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkId "NL-WEB-RTR-001" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2023-05-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_WebSrv01_Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Ge0_0_1 .

noria:NetworkLink_Firewall_Internet
    a noria:NetworkLink ;
    rdfs:label "Link Firewall to Internet"@en ;
    rdfs:comment "External link from Firewall01 to the Internet via ISP."@en ;
    noria:resourceManagedBy noria:Agent_ExternalVendor ;
    noria:networkLinkId "NL-FW-ISP-001" ;
    noria:networkLinkType "Fiber Optic 1Gbps" ;
    noria:networkLinkInstallationDate "2021-08-10T12:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_Firewall01_Ext .

noria:NetworkLink_Firewall_Internal
    a noria:NetworkLink ;
    rdfs:label "Link Firewall to Internal Network"@en ;
    rdfs:comment "Internal link from Firewall01 to RouterCore01."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkId "NL-FW-INT-001" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2021-08-10T12:30:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_Firewall01_Int ;
    noria:networkInterfaceConnects noria:NetworkInterface_RouterCore01_Ge0_0_2 .

# --- Applications (noria:Application) ---
noria:Application_CorpDNS
    a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:label "Service DNS d'entreprise"@fr ;
    rdfs:comment "Critical infrastructure application providing name resolution."@en ;
    noria:applicationModelIdentifier "CORP-DNS-V2" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "CorpDNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Name Resolution" .

noria:Application_WebApp
    a noria:Application ;
    rdfs:label "Customer Web Application"@en ;
    rdfs:label "Application Web Client"@fr ;
