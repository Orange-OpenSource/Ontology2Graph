# --- Operation Plans (noria:OperationPlan) ---
noria:OperationPlan_DNSFailover
    a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:label "Procédure de basculement DNS"@fr ;
    rdfs:comment "Standard operating procedure for failing over DNS service in case of primary server outage."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ServiceRestored .

noria:OperationPlan_FirewallUpdate
    a noria:OperationPlan ;
    rdfs:label "Firewall Update Procedure"@en ;
    rdfs:label "Procédure de mise à jour du pare-feu"@fr ;
    rdfs:comment "Procedure for safely updating firewall firmware during a maintenance window."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FirmwareUpdated .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:ActionPreCondition_DNSUnreachable
    a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unreachable"@en ;
    rdfs:comment "Condition: Primary DNS server is not responding to network requests."@en ;
    skos:example "Ping to dns01.corp.example.com fails."@en .

noria:ActionPostCondition_ServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored"@en ;
    rdfs:comment "Outcome: The affected service (e.g., DNS resolution) is fully functional again."@en ;
    skos:example "DNS queries are successfully resolved by corporate clients."@en .

noria:ActionPreCondition_MaintenanceWindow
    a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Active"@en ;
    rdfs:comment "Condition: The scheduled maintenance window is currently active, allowing for planned service interruptions."@en ;
    skos:example "Current time is between CR-FW-20240501-001 planned start and end times."@en .

noria:ActionPostCondition_FirmwareUpdated
    a noria:ActionPostCondition ;
    rdfs:label "Firmware Updated Successfully"@en ;
    rdfs:comment "Outcome: The device firmware has been updated to the target version without errors."@en ;
    skos:example "Firewall version command shows new firmware version."@en .

