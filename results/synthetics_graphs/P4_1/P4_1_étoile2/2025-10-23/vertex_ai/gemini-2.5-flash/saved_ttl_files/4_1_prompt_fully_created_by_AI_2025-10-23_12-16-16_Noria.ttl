# --- Trouble Ticket Notes (noria:TroubleTicketNote) ---
noria:TroubleTicketNote_DNSFixAttempt
    a noria:TroubleTicketNote ;
    rdfs:label "DNS Fix Attempt Note"@en ;
    rdfs:comment "Note detailing actions taken to restore DNS service."@en ;
    dcterms:created "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_AdminTeam ;
    dcterms:description "Attempted to restart DNS service on dns01.corp.example.com. Service still unreachable. Investigating network path."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage .

noria:TroubleTicketNote_WebAppDiag
    a noria:TroubleTicketNote ;
    rdfs:label "Web App Diagnosis Note"@en ;
    rdfs:comment "Initial diagnosis for web application performance issue."@en ;
    dcterms:created "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    dcterms:creator noria:OrgUnit_L2Support ;
    dcterms:description "Confirmed high CPU on websrv01.corp.example.com. No recent code deployments. Checking database performance."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_WebAppPerf .

