    seas:subSystemOf noria:Application_CorpDNS ; # Conceptual link, a service can group applications
    seas:subSystemOf noria:Application_WebApp . # Conceptual link

noria:Service_CustomerFacing
    a noria:Service ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:label "Service Client"@fr ;
