# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

<operationplan/DBUpgradeProcedure> a noria:OperationPlan ;
    rdfs:label "Database Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading application databases."@en ;
    skos:example "Steps include backup, stop application, run upgrade script, verify, start application."@en ;
    noria:operationPlanPreCondition <actionprecondition/DBBackupComplete> ;
    noria:operationPlanPostCondition <actionpostcondition/DBVersionVerified> .

<actionprecondition/DBBackupComplete> a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completed"@en ;
    rdfs:comment "Ensures a full backup of the database is completed before starting the upgrade."@en ;
    skos:example "Verify backup logs and integrity checks."@en .

<actionpostcondition/DBVersionVerified> a noria:ActionPostCondition ;
    rdfs:label "Database Version Verified"@en ;
    rdfs:comment "Confirms the database has been successfully upgraded to the target version."@en ;
    skos:example "Check database version number and application functionality."@en .

<operationplan/RouterFirmwareUpdate> a noria:OperationPlan ;
    rdfs:label "Router Firmware Update Procedure"@en ;
    rdfs:comment "Procedure for updating firmware on network routers."@en ;
    skos:example "Steps include downloading firmware, uploading to device, reboot, verify."@en ;
    noria:operationPlanPreCondition <actionprecondition/NetworkRedundancyCheck> ;
    noria:operationPlanPostCondition <actionpostcondition/RouterOperational> .

<actionprecondition/NetworkRedundancyCheck> a noria:ActionPreCondition ;
    rdfs:label "Network Redundancy Verified"@en ;
    rdfs:comment "Ensures redundant paths are active before performing maintenance on a core router."@en .

<actionpostcondition/RouterOperational> a noria:ActionPostCondition ;
    rdfs:label "Router Operational and Stable"@en ;
    rdfs:comment "Confirms the router is fully operational and stable after firmware update."@en ;
    skos:example "Verify routing protocols, interface status, and traffic flow."@en .

# =============================================================================
# Connections and cross-references
# =============================================================================

# Link a TroubleTicket to a ChangeRequest (e.g., a CR was created to fix the root cause of a TT)
<troubleticket/TT-20240423-002> dcterms:relation <changerequest/CR-20240425-001> .

# Link an EventRecord to a TroubleTicket (as a status history entry)
<troubleticket/TT-20240423-001> noria:documentStatusHistory <event/TTStatusChangeInProgress> .

<event/TTStatusChangeInProgress> a noria:EventRecord ;
    rdfs:label "Trouble Ticket Status Change to InProgress"@en ;
    noria:loggingTime "2024-04-23T10:07:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "Trouble Ticket TT-20240423-001 status changed to InProgress."@en ;
    dcterms:references <troubleticket/TT-20240423-001> .

# Link a ChangeRequest to an OperationPlan
<changerequest/CR-20240425-001> noria:changeRequestSpecification <operationplan/DBUpgradeProcedure> .
<changerequest/CR-20240426-002> noria:changeRequestSpecification <operationplan/RouterFirmwareUpdate> .

# Link an Application to a Resource it uses
<application/CorporateWebsite> noria:resourceForApplication <resource/VMWeb01> .
<application/InternalCRM> noria:resourceForApplication <resource/ServerApp01> .

# Link an Agent to resources they manage
<agent/JohnDoe> noria:agentManagesResource <resource/RouterCore01> .
<agent/JaneSmith> noria:agentManagesResource <resource/ServerApp01> .

# Example of a DocumentAttachment
<documentattachment/NetworkDiagram> a noria:DocumentAttachment ;
    rdfs:label "Paris DC Network Diagram v2.1"@en ;
    rdfs:comment "Diagram showing the network topology of the Paris Data Center."@en ;
    dcterms:created "2024-03-01T09:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf" ;
    dcterms:isPartOf <troubleticket/TT-20240423-001> ;
    dcterms:isPartOf <changerequest/CR-20240426-002> .

