# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix time: <http://www.w3.org/2006/time#> .

# --- Domain specific ---
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

<agent/TeamA> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:label "Équipe du Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "Team responsible for 24/7 monitoring and initial response to network incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Contact via dedicated incident management system or emergency hotline."@en .

<agent/TeamB> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe de Support Applicatif"@fr ;
    rdfs:comment "Team responsible for maintaining and supporting critical business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit a ticket via the IT Service Portal for non-critical issues."@en .

<agent/JohnDoe> a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, part of the NOC Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

<agent/JaneSmith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer, part of the Application Support Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

<agent/CustomerService> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Service Department"@en ;
    rdfs:comment "First point of contact for customer inquiries and issues."@en ;
    noria:agentWorkingHours "7:00 am - 10:00 pm (Mon-Sun)"@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

<location/SiteParis> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris, France."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

<location/RoomServerA> a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace <location/SiteParis> .

<location/LocusRack12> a noria:Locus ;
    rdfs:label "Rack 12, Server Room A"@en ;
    rdfs:comment "Specific location of Rack 12 within Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "12" ;
    bot:hasSpace <location/RoomServerA> .

<location/SiteLondon> a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:comment "Main office building in London, UK."@en ;
    noria:siteId "OFF-LDN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Baker Street" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE" ;
    noria:sitePrincipalAddressCountry "GB" .

<location/RoomNetworkCloset> a noria:Room ;
    rdfs:label "Network Closet, 3rd Floor"@en ;
    rdfs:comment "Contains network equipment for the 3rd floor of the London Office."@en ;
    bot:hasSpace <location/SiteLondon> .

<location/LocusPatchPanel> a noria:Locus ;
    rdfs:label "Patch Panel 01, Network Closet"@en ;
    rdfs:comment "Location of the main patch panel."@en ;
    noria:locusLine "PP" ;
    noria:locusRow "01" ;
    bot:hasSpace <location/RoomNetworkCloset> .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

<productmodel/CiscoASR9K> a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "High-end router series for carrier-grade networks."@en ;
    noria:productManufacturedBy <org/CiscoSystems> .

<productmodel/DellPowerEdgeR750> a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "Rack server for demanding workloads."@en ;
    noria:productManufacturedBy <org/DellTechnologies> .

<productmodel/VMwareESXi> a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <org/VMware> .

<org/CiscoSystems> a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en .

<org/DellTechnologies> a org:Organization ;
    rdfs:label "Dell Technologies Inc."@en .

<org/VMware> a org:Organization ;
    rdfs:label "VMware Inc."@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

<resource/RouterCore01> a noria:Resource ;
    rdfs:label "Core Router 01 - Paris DC"@en ;
    rdfs:comment "Primary core router in Paris Data Center."@en ;
    noria:resourceHostName "core-rtr-01.par.example.com" ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceProductModel <productmodel/CiscoASR9K> ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "ABC12345DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/TeamA> ;
    noria:locatedAtLocus <location/LocusRack12> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

<resource/ServerApp01> a noria:Resource ;
    rdfs:label "Application Server 01 - Paris DC"@en ;
    rdfs:comment "Server hosting critical business applications."@en ;
    noria:resourceHostName "app-srv-01.par.example.com" ;
    noria:resourceLogisticId "LOG-SRV-001" ;
    noria:resourceProductModel <productmodel/DellPowerEdgeR750> ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "GHI67890JKL" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/TeamB> ;
    noria:locatedAtLocus <location/LocusRack12> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.2> .

<resource/VMWeb01> a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the main corporate website."@en ;
    noria:resourceHostName "web-vm-01.example.com" ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy <agent/TeamB> ;
    noria:resourceForApplication <application/CorporateWebsite> ;
    noria:clusterController <resource/HypervisorHost01> .

<resource/HypervisorHost01> a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical host running virtual machines."@en ;
    noria:resourceHostName "hv-host-01.par.example.com" ;
    noria:resourceProductModel <productmodel/DellPowerEdgeR750> ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy <agent/TeamB> ;
    noria:locatedAtLocus <location/LocusRack12> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

<networkinterface/RouterCore01-GE0-0-0> a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on Core Router 01"@en ;
    rdfs:comment "Uplink interface for Core Router 01."@en ;
    noria:networkInterfaceOf <resource/RouterCore01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <networklink/CoreLinkParisLondon> .

<networkinterface/RouterCore01-GE0-0-1> a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"@en ;
    rdfs:comment "Internal network interface for Core Router 01."@en ;
    noria:networkInterfaceOf <resource/RouterCore01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

<networkinterface/ServerApp01-Eth0> a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Application Server 01"@en ;
    rdfs:comment "Main network interface for Application Server 01."@en ;
    noria:networkInterfaceOf <resource/ServerApp01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/VMWeb01-Eth0> a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Web Server VM 01"@en ;
    rdfs:comment "Virtual network interface for Web Server VM 01."@en ;
    noria:networkInterfaceOf <resource/VMWeb01> ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

<networklink/CoreLinkParisLondon> a noria:NetworkLink ;
    rdfs:label "Core Link Paris-London"@en ;
    rdfs:comment "High-capacity fiber link connecting Paris and London data centers."@en ;
    noria:networkLinkId "NL-PAR-LDN-001" ;
    noria:networkLinkType "fiber optic" ;
    noria:networkLinkInstallationDate "2020-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/RouterCore01> ;
    noria:networkLinkTerminationResourceDestination <resource/RouterCore02> ; # Assuming another router in London
    noria:resourceManagedBy <agent/TeamA> .

<resource/RouterCore02> a noria:Resource ;
    rdfs:label "Core Router 02 - London Office"@en ;
    rdfs:comment "Core router in London Office, connected to Paris DC."@en ;
    noria:resourceHostName "core-rtr-02.ldn.example.com" ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceManagedBy <agent/TeamA> ;
    noria:locatedAtLocus <location/LocusPatchPanel> .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

<application/CorporateWebsite> a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:label "Site Web d'Entreprise"@fr ;
    rdfs:comment "The official corporate website, accessible to the public."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CW" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Marketing and Sales" ;
    noria:applicationFunctionalSubDomain "Online Presence Management" .

<application/InternalCRM> a noria:Application ;
    rdfs:label "Internal CRM System"@en ;
    rdfs:label "Système CRM Interne"@fr ;
    rdfs:comment "Customer Relationship Management system used by sales and support teams."@en ;
    noria:applicationModelIdentifier "CRM" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales and Support Operations" .

<application/MonitoringSystem> a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:label "Système de Supervision Réseau"@fr ;
    rdfs:comment "System for monitoring network devices and services."@en ;
    noria:applicationModelIdentifier "NMS" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Network Monitoring" .

# =============================================================================
# Application Modules (noria:ApplicationModule)
# =============================================================================

<applicationmodule/CorporateWebsiteProd> a noria:ApplicationModule ;
    rdfs:label "Corporate Website Production Module"@en ;
    rdfs:comment "Production instance of the Corporate Website application."@en ;
    noria:applicationModuleOf <application/CorporateWebsite> ;
    noria:applicationModuleName "CORPWEB_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleAdministrationTeam <agent/TeamB> ;
    noria:applicationModuleAdministrationLeader <agent/JaneSmith> ;
    noria:applicationModuleSupportTeam <agent/TeamB> ;
    noria:applicationModuleHotlineEnabled true .

<applicationmodule/InternalCRMDev> a noria:ApplicationModule ;
    rdfs:label "Internal CRM Development Module"@en ;
    rdfs:comment "Development instance of the Internal CRM System."@en ;
    noria:applicationModuleOf <application/InternalCRM> ;
    noria:applicationModuleName "CRM_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
    noria:applicationModuleAdministrationTeam <agent/TeamB> ;
    noria:applicationModuleSupportTeam <agent/TeamB> ;
    noria:applicationModuleHotlineEnabled false .

# =============================================================================
# Services (noria:Service)
# =============================================================================

<service/InternetAccess> a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <applicationmodule/CorporateWebsiteProd> . # Example of linking a service to an app module

<service/VPNService> a noria:Service ;
    rdfs:label "Remote VPN Access Service"@en ;
    rdfs:comment "Enables secure remote access to the corporate network."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf <application/MonitoringSystem> . # Example of linking a service to an application

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

<event/NetworkInterfaceDown> a noria:EventRecord ;
    rdfs:label "Network Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/RouterCore01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<event/ApplicationError> a noria:EventRecord ;
    rdfs:label "Application Error Log"@en ;
    rdfs:comment "Log entry indicating an error in the Corporate Website application."@en ;
    noria:loggingTime "2024-04-23T10:10:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <application/CorporateWebsite> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "ERROR: Database connection failed for Corporate Website."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<event/UserLoginFailure> a noria:EventRecord ;
    rdfs:label "User Login Failure Event"@en ;
    rdfs:comment "Security event: multiple failed login attempts for a user."@en ;
    noria:loggingTime "2024-04-23T10:15:45Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <application/InternalCRM> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logOriginatingAgent <agent/JohnDoe> ; # John Doe's account might be targeted
    noria:logText "Failed login attempt for user 'johndoe' from IP 192.168.1.100 (5 times)."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

<troubleticket/TT-20240423-001> a noria:TroubleTicket ;
    rdfs:label "Core Router 01 Interface Down Incident"@en ;
    rdfs:comment "Critical incident: Core Router 01's uplink interface went down, impacting internet access."@en ;
    dcterms:created "2024-04-23T10:06:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <event/NetworkInterfaceDown> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Physical fiber cut suspected."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <agent/TeamA> ;
    noria:troubleTicketRelatedResource <resource/RouterCore01> ;
    noria:troubleTicketRelatedService <service/InternetAccess> ;
    noria:troubleTicketImpacts <application/CorporateWebsite>, <application/InternalCRM> ;
    noria:documentHRef <http://itsm.example.com/ticket/TT-20240423-001> .

<troubleticket/TT-20240423-002> a noria:TroubleTicket ;
    rdfs:label "Corporate Website Database Connection Issue"@en ;
    rdfs:comment "Issue with the corporate website failing to connect to its database."@en ;
    dcterms:created "2024-04-23T10:11:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger <event/ApplicationError> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Prometheus" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/CorruptedService> ;
    noria:troubleTicketCause "Database server overload."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:10:30Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty <agent/TeamB> ;
    noria:troubleTicketRelatedService <application/CorporateWebsite> ;
    noria:documentHRef <http://itsm.example.com/ticket/TT-20240423-002> .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

<troubleticketnote/TTN-20240423-001-01> a noria:TroubleTicketNote ;
    rdfs:label "Initial diagnosis for TT-20240423-001"@en ;
    rdfs:comment "First note on the Core Router incident."@en ;
    dcterms:created "2024-04-23T10:08:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/JohnDoe> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:description "Confirmed interface GE0/0/0 is physically down. Initiating fiber link check with provider."@en ;
    dcterms:isPartOf <troubleticket/TT-20240423-001> .

<troubleticketnote/TTN-20240423-001-02> a noria:TroubleTicketNote ;
    rdfs:label "Customer update for TT-20240423-001"@en ;
    rdfs:comment "Update provided to customer regarding the internet access outage."@en ;
    dcterms:created "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/CustomerService> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/InwardCustomerComments> ;
    dcterms:description "Customer notified of ongoing issue and estimated resolution time of 12:00 PM UTC."@en ;
    dcterms:isPartOf <troubleticket/TT-20240423-001> .

# =============================================================================
# Change Requests (noria:ChangeRequest)
# =============================================================================

<changerequest/CR-20240425-001> a noria:ChangeRequest ;
    rdfs:label "Corporate Website Database Upgrade"@en ;
    rdfs:comment "Planned upgrade of the database server for the Corporate Website to improve performance."@en ;
    dcterms:created "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-25T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact <application/CorporateWebsite> ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty <agent/JaneSmith> ;
    noria:changeRequestPilotParty <agent/JaneSmith> ;
    noria:changeRequestActorParty <agent/TeamB> ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef <http://itsm.example.com/change/CR-20240425-001> .

<changerequest/CR-20240426-002> a noria:ChangeRequest ;
    rdfs:label "Core Router Firmware Update"@en ;
    rdfs:comment "Mandatory firmware update for Core Router 01 to address security vulnerabilities."@en ;
    dcterms:created "2024-04-22T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-26T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-26T03:30:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact <resource/RouterCore01> ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
