    dcterms:modified "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T06:00:00Z"^^xsd:dateTime ;
