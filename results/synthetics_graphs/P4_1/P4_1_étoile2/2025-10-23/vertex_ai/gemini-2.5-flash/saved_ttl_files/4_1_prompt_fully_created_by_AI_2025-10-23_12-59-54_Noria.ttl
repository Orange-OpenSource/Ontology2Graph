    noria:changeRequestSpecification <kos/ChangeRequest/specification/DatabaseMigration> ;
    noria:changeRequestInitiatorParty foaf:Agent_AppDev ;
    noria:changeRequestPilotParty foaf:Agent_ChangeManager ;
    noria:changeRequestActorParty foaf:Agent_AppDev ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef <http://changemgmt.example.com/CR-20240501-002> .

# =============================================================================
# Operation Plans
# =============================================================================

noria:OpPlan_RouterOSUpdate
    a noria:OperationPlan ;
    rdfs:label "Router OS Update Procedure"@en ;
    rdfs:label "Procédure de mise à jour de l'OS du routeur"@fr ;
    rdfs:comment "Standard operating procedure for updating network device operating systems."@en ;
    skos:example "Steps include pre-checks, image upload, reload, and post-checks."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterReach ;
    noria:operationPlanPostCondition noria:PostCond_RouterUp .

noria:OpPlan_DBFailover
    a noria:OperationPlan ;
    rdfs:label "Database Failover Procedure"@en ;
    rdfs:label "Procédure de basculement de base de données"@fr ;
    rdfs:comment "Procedure for gracefully failing over a database to a standby instance."@en ;
    skos:example "Steps include verifying replication, initiating failover, and updating application configurations."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBBackup ;
    noria:operationPlanPostCondition noria:PostCond_DBServiceOnline .

# =============================================================================
# Action Pre/Post Conditions
# =============================================================================

noria:PreCond_RouterReach
    a noria:ActionPreCondition ;
    rdfs:label "Router Reachability Check"@en ;
    rdfs:comment "Verify that the router is reachable and has management access before starting the update."@en ;
    skos:example "Ping test to management IP, SSH access verification."@en .

noria:PostCond_RouterUp
    a noria:ActionPostCondition ;
    rdfs:label "Router Up and Running"@en ;
    rdfs:comment "Confirm that the router has successfully rebooted, all interfaces are up, and routing protocols are converged."@en ;
    skos:example "Verify interface status, routing table, and network connectivity."@en .

noria:PreCond_DBBackup
    a noria:ActionPreCondition ;
    rdfs:label "Database Backup Verified"@en ;
    rdfs:comment "Ensure a recent and valid backup of the database exists before starting migration."@en ;
    skos:example "Check backup logs and perform a test restore if necessary."@en .

noria:PostCond_DBServiceOnline
    a noria:ActionPostCondition ;
    rdfs:label "Database Service Online"@en ;
    rdfs:comment "Confirm that the database service is running on the new server and applications can connect successfully."@en ;
    skos:example "Check database process status, application connectivity tests, and data integrity checks."@en .

# =============================================================================
# Additional Connections for Density
# =============================================================================

# Link an EventRecord to a ChangeRequest for status history
noria:CR_RouterUpgrade noria:documentStatusHistory noria:Event_ConfigChange .

# Link an OperationPlan to a ChangeRequest
noria:CR_RouterUpgrade pep:usedProcedure noria:OpPlan_RouterOSUpdate .
noria:CR_DBMigration pep:usedProcedure noria:OpPlan_DBFailover .

# Link an Application to a Service
noria:App_CorpDNS seas:subSystemOf noria:Service_InternetAccess .
noria:App_WebPortal seas:subSystemOf noria:Service_CustomerFacing .

# Link a Resource to an Application
noria:Resource_DNS01 noria:resourceForApplication noria:App_CorpDNS .
noria:Resource_WebSrv01 noria:resourceForApplication noria:App_WebPortal .
noria:Resource_DB01 noria:resourceForApplication noria:App_WebPortal .

# Link a Network Interface to a Network Link
noria:NetInt_DNS01_Eth0 noria:networkInterfaceConnects noria:NetLink_DNS_Core .
noria:NetInt_RouterCore01_Gi0_0_1 noria:networkInterfaceConnects noria:NetLink_DNS_Core .
noria:NetInt_WebSrv01_Eth0 noria:networkInterfaceConnects noria:NetLink_Web_Core .
noria:NetInt_RouterCore01_Gi0_0_2 noria:networkInterfaceConnects noria:NetLink_Web_Core .
noria:NetInt_RouterCore01_Gi0_0_2 noria:networkInterfaceConnects noria:NetLink_Core_Internet .
noria:NetInt_Firewall01_Ext noria:networkInterfaceConnects noria:NetLink_Core_Internet .

# Link Agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_AdminTeam noria:agentManagesResource noria:Resource_DNS01 .
foaf:Agent_NetworkOps noria:agentManagesResource noria:Resource_RouterCore01 .
foaf:Agent_NetworkOps noria:agentManagesResource noria:Resource_Firewall01 .
foaf:Agent_AppDev noria:agentManagesResource noria:Resource_WebSrv01 .
foaf:Agent_AppDev noria:agentManagesResource noria:Resource_DB01 .

# Link Agents to applications they manage (via applicationModuleAdministrationLeader)
foaf:Agent_AdminTeam noria:agentManagesResource noria:AppMod_CorpDNS_Prod .
foaf:Agent_AppDev noria:agentManagesResource noria:AppMod_WebPortal_Prod .
foaf:Agent_AppDev noria:agentManagesResource noria:AppMod_WebPortal_Dev .

# Example of a virtual server status
noria:Resource_WebSrv01 noria:virtualServerStatus <kos/Resource/OperationalState/up> .

# Example of alarm mitigation
noria:Event_DNSDown noria:alarmMitigatedBy noria:TT_DNSOutage . # The TT itself acts as a container for mitigation actions.
