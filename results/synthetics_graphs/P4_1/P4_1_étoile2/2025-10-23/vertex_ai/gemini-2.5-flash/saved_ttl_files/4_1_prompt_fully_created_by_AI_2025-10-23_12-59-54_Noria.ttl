# Change Requests
# =============================================================================

noria:CR_RouterUpgrade
    a noria:ChangeRequest ;
    rdfs:label "Core Router OS Upgrade"@en ;
    rdfs:label "Mise à niveau de l'OS du routeur cœur"@fr ;
    rdfs:comment "Planned upgrade of the operating system on Core Router 01 to enhance security and features."@en ;
    dcterms:identifier "CR-20240425-001" ;
    dcterms:created "2024-04-15T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-22T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-25T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_RouterCore01 ;
    noria:changeRequestImpact noria:Service_InternetAccess ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkOSUpdate> ;
    noria:changeRequestInitiatorParty foaf:Agent_NetworkOps ;
    noria:changeRequestPilotParty foaf:Agent_ChangeManager ;
    noria:changeRequestActorParty foaf:Agent_NetworkOps ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef <http://changemgmt.example.com/CR-20240425-001> .

noria:CR_DBMigration
    a noria:ChangeRequest ;
    rdfs:label "Database Migration"@en ;
    rdfs:label "Migration de base de données"@fr ;
    rdfs:comment "Migration of the customer web portal database to a new, more performant server."@en ;
    dcterms:identifier "CR-20240501-002" ;
