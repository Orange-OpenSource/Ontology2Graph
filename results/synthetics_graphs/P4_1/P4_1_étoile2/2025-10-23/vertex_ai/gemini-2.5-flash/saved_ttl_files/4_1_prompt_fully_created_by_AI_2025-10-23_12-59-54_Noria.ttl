    noria:documentHRef <http://ticketing.example.com/TT-20240420-002> .

# =============================================================================
# Trouble Ticket Notes
# =============================================================================

noria:TTNote_DNSFix
    a noria:TroubleTicketNote ;
    rdfs:label "DNS Fix Note"@en ;
    rdfs:comment "Note detailing the steps taken to restore DNS service."@en ;
    dcterms:created "2024-04-20T10:00:00Z"^^xsd:dateTime ;
