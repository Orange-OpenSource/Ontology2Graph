# =============================================================================
# Services
# =============================================================================

noria:Service_InternetAccess
    a noria:Service ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:label "Accès Internet d'entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet connectivity to all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:AppMod_CorpDNS_Prod ;
    seas:subSystem noria:AppMod_WebPortal_Prod ;
    seas:subSystem noria:Resource_RouterCore01 ;
    seas:subSystem noria:Resource_Firewall01 .

noria:Service_CustomerFacing
    a noria:Service ;
    rdfs:label "Customer Facing Services"@en ;
    rdfs:label "Services orientés client"@fr ;
    rdfs:comment "Collection of services directly consumed by external customers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:AppMod_WebPortal_Prod .

# =============================================================================
# Event Records
# =============================================================================

noria:Event_DNSDown
    a noria:EventRecord ;
    rdfs:label "DNS Service Down Alert"@en ;
    rdfs:comment "Alert indicating that the Corporate DNS service is unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "DNS service on dns01.corp.example.com is not responding to queries."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_InterfaceFlap
    a noria:EventRecord ;
    rdfs:label "Router Interface Flap"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down and then up repeatedly."@en ;
    noria:loggingTime "2024-04-20T09:05:30Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1 on router-core01.corp.example.com flapped multiple times."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_HighCPU
    a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating sustained high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.app.example.com exceeded 90% for 15 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_ConfigChange
    a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Log entry detailing a configuration change applied to Core Router 01."@en ;
    noria:loggingTime "2024-04-19T23:00:00Z"^^xsd:dateTime ;
    noria:logText "Configuration changed by Network Operations Team: 'interface Gi0/0/1 shutdown'."@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_NetworkOps ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

