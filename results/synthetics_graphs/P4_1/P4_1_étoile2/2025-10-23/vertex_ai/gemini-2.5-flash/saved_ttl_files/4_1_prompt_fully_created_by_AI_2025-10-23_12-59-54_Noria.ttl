noria:TT_DNSOutage
    a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident de panne du serveur DNS"@fr ;
    rdfs:comment "Critical incident reported due to corporate DNS server being unreachable, impacting all internal services."@en ;
