# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix time: <http://www.w3.org/2006/time#> .

# --- Domain specific ---
@prefix bot: <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# NORIA Ontology Metadata (as provided in the schema)
# =============================================================================

<https://w3id.org/noria/ontology/>
	a owl:Ontology ;
	dcterms:title "The NORIA Ontology"@en ;
    dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.
"""@en ;
    dcterms:issued "2022-05-10"^^xsd:date ;
	dcterms:modified "2024-03-15"^^xsd:date ;
	owl:versionInfo "v0.3" ;
.

# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizational Units (Teams)
<org/team/NetworkOperations> a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for 24/7 network infrastructure monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Contact via dedicated incident hotline for critical issues."@en .

<org/team/ApplicationSupport> a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing L2/L3 support for business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all requests."@en .

<org/team/SecurityOperations> a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:label "Centre des Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Escalate critical security alerts immediately."@en .

# Individual Agents (Employees)
<foaf/agent/AliceSmith> a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentManagesResource <resource/Router01> ;
    noria:agentManagesResource <resource/Firewall01> .

<foaf/agent/BobJohnson> a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

<foaf/agent/CustomerX> a foaf:Agent ;
    rdfs:label "Customer X Representative"@en ;
    rdfs:comment "External customer reporting an issue."@en .

