    noria:applicationModuleHotlineEnabled false .

# =============================================================================
# Services
# =============================================================================

<service/EnterpriseConnectivity> a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing network connectivity to all enterprise locations."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <applicationmodule/InternetAccess-Prod> .

<service/CustomerDataManagement> a noria:Service ;
    rdfs:label "Customer Data Management Service"@en ;
    rdfs:comment "Service for managing all customer-related data and interactions."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <applicationmodule/CRMSystem-Prod> .

# =============================================================================
# Event Records
# =============================================================================

<eventrecord/Router01-InterfaceDown> a noria:EventRecord ;
    rdfs:label "Router01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Router01 went down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:logOriginatingManagedObject <resource/Router01> ;
    noria:logOriginatingManagementSystem <application/NetworkMonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<eventrecord/ServerApp01-HighCPU> a noria:EventRecord ;
    rdfs:label "ServerApp01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Application Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on appserver01 exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject <resource/ServerApp01> ;
    noria:logOriginatingManagementSystem <application/ApplicationMonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<eventrecord/Firewall01-BlockedAttack> a noria:EventRecord ;
    rdfs:label "Firewall01 Blocked Attack Log"@en ;
    rdfs:comment "Log entry showing a blocked cyber attack attempt by Firewall01."@en ;
    noria:loggingTime "2024-04-20T09:50:10Z"^^xsd:dateTime ;
    noria:logText "Blocked SQL Injection attempt from 192.0.2.10 on port 80."@en ;
    noria:logOriginatingManagedObject <resource/Firewall01> ;
    noria:logOriginatingManagementSystem <application/SecurityInformationEventManagement> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<application/NetworkMonitoringSystem> a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

<application/ApplicationMonitoringSystem> a noria:Application ;
    rdfs:label "Application Monitoring System"@en ;
    noria:applicationShortIdentifier "AMS" ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

<application/SecurityInformationEventManagement> a noria:Application ;
    rdfs:label "Security Information and Event Management (SIEM)"@en ;
    noria:applicationShortIdentifier "SIEM" ;
    noria:applicationType <kos/application/type/security> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> .

# =============================================================================
# Trouble Tickets
# =============================================================================

<troubleticket/TT-20240420-001> a noria:TroubleTicket ;
    rdfs:label "Internet Access Outage"@en ;
    rdfs:label "Panne d'Accès Internet"@fr ;
    rdfs:comment "Critical incident: Corporate internet access is completely down due to a router interface failure."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:06:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService <applicationmodule/InternetAccess-Prod> ;
    noria:troubleTicketRelatedResource <resource/Router01> ;
    noria:troubleTicketRelatedParty <org/team/NetworkOperations> ;
    noria:troubleTicketTrigger <eventrecord/Router01-InterfaceDown> ;
    noria:troubleTicketCause "Physical interface failure on core router."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketImpacts <application/InternetAccess>, <service/EnterpriseConnectivity> .

<troubleticket/TT-20240420-002> a noria:TroubleTicket ;
    rdfs:label "CRM Performance Degradation"@en ;
    rdfs:label "Dégradation Performance CRM"@fr ;
    rdfs:comment "Users report slow response times on the CRM system, likely due to high server load."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/User> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedService <applicationmodule/CRMSystem-Prod> ;
    noria:troubleTicketRelatedResource <resource/ServerApp01> ;
    noria:troubleTicketRelatedParty <org/team/ApplicationSupport> ;
    noria:troubleTicketTrigger <eventrecord/ServerApp01-HighCPU> ;
    noria:troubleTicketCause "Unexpected high CPU usage on application server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketImpacts <application/CRMSystem>, <service/CustomerDataManagement> .

# =============================================================================
# Trouble Ticket Notes
# =============================================================================

<troubleticketnote/TT-20240420-001-Note1> a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for TT-20240420-001"@en ;
    rdfs:comment "Engineer Alice Smith confirmed interface GE0/0/0 on Router01 is physically down. Initiating troubleshooting steps."@en ;
    dcterms:created "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator <foaf/agent/AliceSmith> ;
    dcterms:isPartOf <troubleticket/TT-20240420-001> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

<troubleticketnote/TT-20240420-001-Note2> a noria:TroubleTicketNote ;
    rdfs:label "Customer Update Note for TT-20240420-001"@en ;
    rdfs:comment "Customer X informed about the ongoing outage and estimated restoration time."@en ;
    dcterms:created "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator <org/team/NetworkOperations> ;
    dcterms:isPartOf <troubleticket/TT-20240420-001> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/InwardCustomerComments> .

# =============================================================================
# Change Requests
# =============================================================================

<changerequest/CR-20240425-001> a noria:ChangeRequest ;
    rdfs:label "Router01 Software Upgrade"@en ;
    rdfs:label "Mise à Jour Logicielle Routeur01"@fr ;
    rdfs:comment "Planned software upgrade for Router01 to address known vulnerabilities and improve performance."@en ;
    dcterms:created "2024-04-15T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-25T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact <resource/Router01> ;
    noria:changeRequestImpact <applicationmodule/InternetAccess-Prod> ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty <foaf/agent/AliceSmith> ;
    noria:changeRequestPilotParty <org/team/NetworkOperations> ;
    noria:changeRequestActorParty <org/team/NetworkOperations> ;
    noria:changeRequestIsRegulated true .

<changerequest/CR-20240426-002> a noria:ChangeRequest ;
    rdfs:label "CRM Database Migration"@en ;
    rdfs:comment "Migration of CRM database to a new, more powerful server instance."@en ;
    dcterms:created "2024-04-18T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-26T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-26T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ; # Using NetworkExtension as a placeholder for infrastructure change
    noria:changeRequestImpact <resource/ServerApp01> ;
    noria:changeRequestImpact <applicationmodule/CRMSystem-Prod> ;
    noria:changeRequestOutageDuration "PT6H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty <foaf/agent/BobJohnson> ;
    noria:changeRequestPilotParty <org/team/ApplicationSupport> ;
    noria:changeRequestActorParty <org/team/ApplicationSupport> ;
    noria:changeRequestIsRegulated false .

# =============================================================================
# Operation Plans and Conditions
# =============================================================================

<operationplan/RouterInterfaceTroubleshooting> a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving router interface issues."@en ;
    skos:example "Check cable, verify configuration, reseat module, replace module."@en ;
    noria:operationPlanPreCondition <actionprecondition/InterfaceDownConfirmed> ;
    noria:operationPlanPostCondition <actionpostcondition/InterfaceUpConfirmed> .

<actionprecondition/InterfaceDownConfirmed> a noria:ActionPreCondition ;
    rdfs:label "Interface Down Confirmed"@en ;
    rdfs:comment "Pre-condition: Network interface status is confirmed to be 'down' via monitoring and direct verification."@en .

<actionpostcondition/InterfaceUpConfirmed> a noria:ActionPostCondition ;
    rdfs:label "Interface Up Confirmed"@en ;
    rdfs:comment "Post-condition: Network interface status is 'up' and traffic is flowing normally."@en .

<operationplan/ApplicationServerCPUOptimization> a noria:OperationPlan ;
    rdfs:label "Application Server CPU Optimization Procedure"@en ;
    rdfs:comment "Procedure to identify and mitigate high CPU usage on application servers."@en ;
    skos:example "Analyze process list, check logs for errors, optimize database queries, scale out application instances."@en ;
    noria:operationPlanPreCondition <actionprecondition/HighCPUAlertActive> ;
    noria:operationPlanPostCondition <actionpostcondition/CPUUsageNormal> .

<actionprecondition/HighCPUAlertActive> a noria:ActionPreCondition ;
    rdfs:label "High CPU Alert Active"@en ;
    rdfs:comment "Pre-condition: An alert for high CPU usage on an application server is active."@en .

<actionpostcondition/CPUUsageNormal> a noria:ActionPostCondition ;
    rdfs:label "CPU Usage Normal"@en ;
    rdfs:comment "Post-condition: CPU utilization on the application server is within normal operating parameters."@en .

# =============================================================================
# Additional connections for density
# =============================================================================

# Link a TroubleTicket to an OperationPlan via a correlated action (conceptual, as noria:CorrectiveMaintenanceAction is not explicitly defined here, but implied by pep:ProcedureExecutionContainer)
# For simplicity, we can link the TroubleTicket directly to the OperationPlan as a related procedure.
<troubleticket/TT-20240420-001> pep:usedProcedure <operationplan/RouterInterfaceTroubleshooting> .
<troubleticket/TT-20240420-002> pep:usedProcedure <operationplan/ApplicationServerCPUOptimization> .

# Link ChangeRequest to OperationPlan
<changerequest/CR-20240425-001> noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardSoftwareUpgrade> .
<changerequest/CR-20240425-001> pep:usedProcedure <operationplan/RouterInterfaceTroubleshooting> . # Assuming the upgrade involves some troubleshooting steps

