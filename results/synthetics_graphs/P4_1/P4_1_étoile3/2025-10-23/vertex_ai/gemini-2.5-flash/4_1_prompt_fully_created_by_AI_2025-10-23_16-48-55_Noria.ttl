<application/InternetAccess> a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:label "Accès Internet Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users."@en ;
    noria:applicationShortIdentifier "CORP-INT" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Connectivity" .

<application/CRMSystem> a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:label "Système de Gestion de la Relation Client"@fr ;
    rdfs:comment "Core business application for managing customer interactions."@en ;
    noria:applicationShortIdentifier "CRM-PROD" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales and Support" .

<application/SecurityService> a noria:Application ;
    rdfs:label "Perimeter Security Service"@en ;
    rdfs:comment "Provides firewall and intrusion prevention for the corporate network."@en ;
    noria:applicationShortIdentifier "PERIM-SEC" ;
    noria:applicationType <kos/application/type/security> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Security Management" ;
    noria:applicationFunctionalSubDomain "Network Security" .

