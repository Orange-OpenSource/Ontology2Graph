    noria:applicationModuleAdministrationTeam <org/team/NetworkOperations> ;
    noria:applicationModuleSupportTeam <org/team/NetworkOperations> ;
    noria:applicationModuleHotlineEnabled true .

<applicationmodule/CRMSystem-Prod> a noria:ApplicationModule ;
    rdfs:label "CRM System - Production"@en ;
    rdfs:comment "Production instance of the CRM System application."@en ;
    noria:applicationModuleOf <application/CRMSystem> ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleName "CRM-PROD_PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-02-01T00:00:00Z"^^xsd:dateTime ;
