# =============================================================================
# Network Interfaces
# =============================================================================

<networkinterface/Router01-GE0-0-0> a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface for Router01."@en ;
    noria:networkInterfaceOf <resource/Router01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to ISP A" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <networklink/UplinkISP-A> .

<networkinterface/Router01-GE0-0-1> a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Internal network interface for Router01."@en ;
    noria:networkInterfaceOf <resource/Router01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to internal LAN" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <networklink/InternalLAN-Router01-ServerApp01> .

<networkinterface/ServerApp01-Eth0> a noria:NetworkInterface ;
    rdfs:label "ServerApp01 Ethernet0"@en ;
    rdfs:comment "Main network interface for ServerApp01."@en ;
    noria:networkInterfaceOf <resource/ServerApp01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connection to application network" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <networklink/InternalLAN-Router01-ServerApp01> .

<networkinterface/Firewall01-Eth1> a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet1"@en ;
    rdfs:comment "External interface for Firewall01."@en ;
    noria:networkInterfaceOf <resource/Firewall01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "External WAN interface" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <networklink/UplinkISP-A> .

# =============================================================================
# Network Links
# =============================================================================

<networklink/UplinkISP-A> a noria:NetworkLink ;
    rdfs:label "Uplink to ISP A"@en ;
    rdfs:comment "Primary internet uplink from Data Center Paris to ISP A."@en ;
    noria:networkLinkId "NL-ISP-A-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2022-12-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/Router01> ;
    noria:networkLinkTerminationResourceDestination <resource/Firewall01> ;
    noria:resourceManagedBy <org/team/NetworkOperations> .

<networklink/InternalLAN-Router01-ServerApp01> a noria:NetworkLink ;
    rdfs:label "Internal LAN Link Router01-ServerApp01"@en ;
    rdfs:comment "Internal network link connecting Router01 to ServerApp01."@en ;
    noria:networkLinkId "NL-INT-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-20T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/Router01> ;
    noria:networkLinkTerminationResourceDestination <resource/ServerApp01> ;
    noria:resourceManagedBy <org/team/NetworkOperations> .

