    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

<noria/room/ServerRoomA> a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace <bot/site/DataCenterParis> .

<noria/locus/RackA12> a noria:Locus ;
    rdfs:label "Rack A12"@en ;
    rdfs:comment "Location of servers in Rack A12."@en ;
    noria:locusLine "A" ;
    noria:locusRow "12" ;
    bot:hasSpace <noria/room/ServerRoomA> .

<noria/locus/RackB05> a noria:Locus ;
    rdfs:label "Rack B05"@en ;
    rdfs:comment "Location of network equipment in Rack B05."@en ;
    noria:locusLine "B" ;
    noria:locusRow "05" ;
    bot:hasSpace <noria/room/ServerRoomA> .

