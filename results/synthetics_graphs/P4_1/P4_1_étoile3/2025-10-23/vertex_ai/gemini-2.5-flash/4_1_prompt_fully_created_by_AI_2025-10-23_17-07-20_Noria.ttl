# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents and Organizational Units
# =============================================================================

noria:Agent_AdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and configuration."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, direct call for critical outages."@en .

noria:Agent_NetworkOps a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Use emergency hotline for network-wide incidents."@en .

noria:Agent_AppDev a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Submit feature requests via project management tool."@en .

noria:Agent_SecurityAnalyst a foaf:Agent ;
    rdfs:label "Security Analyst John Doe"@en ;
    rdfs:comment "Individual responsible for security monitoring and incident response."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

noria:Agent_CustomerA a foaf:Agent ;
    rdfs:label "Customer A Representative"@en ;
    rdfs:comment "Representative for a key customer reporting service issues."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

noria:Agent_ChangeManager a foaf:Agent ;
    rdfs:label "Change Manager Jane Smith"@en ;
    rdfs:comment "Manager overseeing the change management process."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

noria:OrgUnit_L1Support a org:OrganizationalUnit ;
    rdfs:label "Level 1 Support"@en, "Support N1"@fr ;
    rdfs:comment "First line of support for user and application issues."@en ;
    noria:agentWorkingHours "24/7"@en .

noria:OrgUnit_L2Support a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support"@en, "Support N2"@fr ;
    rdfs:comment "Second line of support, handling more complex application and infrastructure problems."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"@en .

noria:OrgUnit_Hotline a org:OrganizationalUnit ;
    rdfs:label "Hotline Team"@en, "Equipe d'astreinte"@fr ;
    rdfs:comment "On-call team for critical incidents outside business hours."@en ;
    noria:agentWorkingHours "After-hours and weekends"@en .

# =============================================================================
# Locations
# =============================================================================

noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données Paris"@fr ;
    rdfs:comment "Primary data center location for corporate services."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack12_U23 .

noria:Locus_Rack12_U23 a noria:Locus ;
    rdfs:label "Rack 12, Unit 23"@en ;
    rdfs:comment "Specific location within Server Room A for server equipment."@en ;
    noria:locusLine "Rack 12" ;
    noria:locusRow "U23" .

noria:Site_LondonOffice a bot:Site ;
    rdfs:label "London Office"@en, "Bureau de Londres"@fr ;
    rdfs:comment "Secondary office location with local network infrastructure."@en ;
    noria:siteId "OFF-LDN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Baker Street" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE" ;
    noria:sitePrincipalAddressCountry "UK" .

noria:Room_NetworkCloset a noria:Room ;
    rdfs:label "Network Closet"@en, "Local Réseau"@fr ;
    rdfs:comment "Network equipment closet in the London Office."@en ;
    bot:hasSpace noria:Locus_PatchPanel_A1 .

noria:Locus_PatchPanel_A1 a noria:Locus ;
    rdfs:label "Patch Panel A1"@en ;
    rdfs:comment "Location of a patch panel for network connections."@en ;
    noria:locusLine "Panel A" ;
    noria:locusRow "1" .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model commonly used for enterprise applications."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> . # Assuming a URI for Dell

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch series from Cisco."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> . # Assuming a URI for Cisco

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> . # Assuming a URI for VMware

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network, located in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-05-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Virtual machine hosting the customer web portal."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "web01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The host is ESXi, the VM is on it.
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceLogisticId "LOG-WEB-001" ;
    noria:resourceSerialNumber "SN-WEB-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.10> .

noria:Resource_DB01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Dedicated database server for critical applications."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "db01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceLogisticId "LOG-DB-001" ;
    noria:resourceSerialNumber "SN-DB-001-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-06-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.20> .

noria:Resource_Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Firewall protecting the corporate network perimeter."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Using a switch model as a placeholder for a firewall appliance
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceLogisticId "LOG-FW-001" ;
    noria:resourceSerialNumber "SN-FW-001-JKL" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-01T16:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_PatchPanel_A1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.254> .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetInt_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to internal network."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetInt_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to DNS server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to DNS segment."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetInt_RouterCore01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 01 to Web server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to Web segment."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetInt_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Virtual Ethernet interface for web traffic."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links
# =============================================================================

noria:NetLink_DNS_Core a noria:NetworkLink ;
    rdfs:label "DNS to Core Link"@en ;
    rdfs:comment "Physical link between DNS01 and Core Router 01."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkId "LINK-DNS-CORE-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore01 ;
    noria:networkInterfaceConnects noria:NetInt_DNS01_Eth0 ;
    noria:networkInterfaceConnects noria:NetInt_RouterCore01_Gi0_0_1 ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps" .

noria:NetLink_Core_Web a noria:NetworkLink ;
    rdfs:label "Core to Web Link"@en ;
    rdfs:comment "Logical link between Core Router 01 and Web Server 01."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkId "LINK-CORE-WEB-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_WebSrv01 ;
    noria:networkInterfaceConnects noria:NetInt_RouterCore01_Gi0_0_2 ;
    noria:networkInterfaceConnects noria:NetInt_WebSrv01_Eth0 ;
    noria:networkLinkInstallationDate "2023-03-10T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "VLAN Trunk" .

# =============================================================================
# Applications
# =============================================================================

noria:App_CorpDNS a noria:Application ;
    rdfs:label "Corporate DNS Service"@en, "Service DNS d'Entreprise"@fr ;
    rdfs:comment "Critical application providing name resolution for all corporate services."@en ;
    noria:elementManagedBy noria:Agent_AdminTeam ;
    noria:applicationModelIdentifier "CORP-DNS" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "DNS-SVC" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Name Resolution" .

noria:App_WebPortal a noria:Application ;
    rdfs:label "Customer Web Portal"@en, "Portail Web Client"@fr ;
    rdfs:comment "Public-facing web application for customer interactions."@en ;
    noria:elementManagedBy noria:Agent_AppDev ;
    noria:applicationModelIdentifier "CUST-WEB" ;
    noria:applicationNumericalIdentifier 201 ;
    noria:applicationShortIdentifier "WEB-PORTAL" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Online Self-Service" .

noria:App_Monitoring a noria:Application ;
    rdfs:label "Network Monitoring System"@en, "Système de Supervision Réseau"@fr ;
    rdfs:comment "Internal application for monitoring network devices and services."@en ;
    noria:elementManagedBy noria:Agent_NetworkOps ;
    noria:applicationModelIdentifier "NET-MON" ;
    noria:applicationNumericalIdentifier 301 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/management-tool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance Monitoring" .

# =============================================================================
# Application Modules
# =============================================================================

noria:AppMod_CorpDNS_Prod a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en ;
    rdfs:comment "Production instance of the Corporate DNS Service."@en ;
    noria:applicationModuleOf noria:App_CorpDNS ;
    noria:applicationModuleName "CORP-DNS_PROD" ;
    noria:applicationModuleIdentifier "PROD-001" ;
    noria:applicationModuleAdministrationTeam noria:OrgUnit_L2Support ;
    noria:applicationModuleAdministrationLeader noria:Agent_AdminTeam ;
    noria:applicationModuleSupportTeam noria:OrgUnit_L1Support ;
    noria:applicationModuleHotlineGroup noria:OrgUnit_Hotline ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:AppMod_WebPortal_Prod a noria:ApplicationModule ;
    rdfs:label "Customer Web Portal Production Module"@en ;
    rdfs:comment "Production instance of the Customer Web Portal."@en ;
    noria:applicationModuleOf noria:App_WebPortal ;
    noria:applicationModuleName "CUST-WEB_PROD" ;
    noria:applicationModuleIdentifier "PROD-002" ;
    noria:applicationModuleAdministrationTeam noria:OrgUnit_L2Support ;
    noria:applicationModuleAdministrationLeader noria:Agent_AppDev ;
    noria:applicationModuleSupportTeam noria:OrgUnit_L1Support ;
    noria:applicationModuleHotlineGroup noria:OrgUnit_Hotline ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:AppMod_WebPortal_Dev a noria:ApplicationModule ;
    rdfs:label "Customer Web Portal Development Module"@en ;
    rdfs:comment "Development instance of the Customer Web Portal."@en ;
    noria:applicationModuleOf noria:App_WebPortal ;
    noria:applicationModuleName "CUST-WEB_DEV" ;
    noria:applicationModuleIdentifier "DEV-001" ;
    noria:applicationModuleAdministrationTeam noria:OrgUnit_L1Support ;
    noria:applicationModuleAdministrationLeader noria:Agent_AppDev ;
    noria:applicationModuleSupportTeam noria:OrgUnit_L1Support ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> .

# =============================================================================
# Services
# =============================================================================

noria:Service_InternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access"@en, "Accès Internet Entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet connectivity to corporate users."@en ;
    noria:elementManagedBy noria:Agent_NetworkOps ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:AppMod_CorpDNS_Prod ;
    seas:subSystem noria:AppMod_WebPortal_Prod ;
    seas:subSystem noria:Resource_Firewall01 ;
    seas:subSystem noria:Resource_RouterCore01 .

noria:Service_InternalDB a noria:Service ;
    rdfs:label "Internal Database Service"@en, "Service Base de Données Interne"@fr ;
    rdfs:comment "Service providing database access for internal applications."@en ;
    noria:elementManagedBy noria:Agent_AppDev ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:Resource_DB01 .

# =============================================================================
# Event Records
# =============================================================================

noria:Event_DNS_Down a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating that the corporate DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "CRITICAL: DNS server dns01.corp.example.com is unreachable on port 53."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_Interface_Flap a noria:EventRecord ;
    rdfs:label "Router Interface Flap"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 flapped (went down and up)."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "Interface GigabitEthernet0/0/1 on router-core01 changed state to down, then to up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_Web_Error a noria:EventRecord ;
    rdfs:label "Web Server Error Log"@en ;
    rdfs:comment "Application log entry showing a critical error on the web server."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "ERROR: Database connection failed for web application. Service degraded."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_Config_Change a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Log entry detailing a configuration change applied to Core Router 01."@en ;
    noria:loggingTime "2024-04-19T18:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent noria:Agent_NetworkOps ;
    noria:logText "Configuration updated by Network Operations Team: added new VLAN interface."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TT_DNS_Outage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Critical incident reported due to corporate DNS server being unreachable."@en ;
    dcterms:created "2024-04-20T09:01:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:Event_DNS_Down ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
