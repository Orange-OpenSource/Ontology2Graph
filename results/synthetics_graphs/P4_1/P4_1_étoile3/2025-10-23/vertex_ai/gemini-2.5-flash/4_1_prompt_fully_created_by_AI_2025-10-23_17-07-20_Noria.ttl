# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OpPlan_DNS_Restart a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS service."@en ;
    skos:example "Steps include checking process status, attempting graceful restart, and forced restart if necessary."@en ;
    noria:operationPlanPreCondition noria:PreCond_DNS_Unreachable ;
    noria:operationPlanPostCondition noria:PostCond_DNS_Resolves .

noria:PreCond_DNS_Unreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Unreachable Pre-condition"@en ;
    rdfs:comment "Condition: DNS server is not responding to queries or pings."@en ;
    skos:example "Monitoring system reports DNS service down."@en .

noria:PostCond_DNS_Resolves a noria:ActionPostCondition ;
    rdfs:label "DNS Resolves Post-condition"@en ;
    rdfs:comment "Condition: DNS server is responding to queries successfully."@en ;
    skos:example "Monitoring system reports DNS service up and functional."@en .

noria:OpPlan_Router_Firmware a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Procedure for upgrading firmware on core network routers."@en ;
    skos:example "Includes backup, upgrade, and verification steps."@en ;
    noria:operationPlanPreCondition noria:PreCond_Router_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:PostCond_Router_Online .

noria:PreCond_Router_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Router Maintenance Window Pre-condition"@en ;
    rdfs:comment "Condition: Approved maintenance window is active for the router."@en ;
    skos:example "Change Request CR-NET-001 is in 'In Progress' status."@en .

noria:PostCond_Router_Online a noria:ActionPostCondition ;
    rdfs:label "Router Online Post-condition"@en ;
    rdfs:comment "Condition: Router is online, forwarding traffic, and all interfaces are up."@en ;
    skos:example "Network monitoring confirms router reachability and interface status."@en .

# =============================================================================
# Additional Connections for Density
# =============================================================================

# Connect resources to applications they serve
noria:Resource_DNS01 noria:resourceForApplication noria:App_CorpDNS .
noria:Resource_WebSrv01 noria:resourceForApplication noria:App_WebPortal .
noria:Resource_DB01 noria:resourceForApplication noria:App_WebPortal .
noria:Resource_RouterCore01 noria:resourceForApplication noria:App_Monitoring .
noria:Resource_Firewall01 noria:resourceForApplication noria:App_Monitoring .

# Connect agents to resources they manage (inverse of resourceManagedBy)
noria:Agent_AdminTeam noria:agentManagesResource noria:Resource_DNS01 .
noria:Agent_NetworkOps noria:agentManagesResource noria:Resource_RouterCore01 .
noria:Agent_NetworkOps noria:agentManagesResource noria:Resource_Firewall01 .
noria:Agent_AppDev noria:agentManagesResource noria:Resource_WebSrv01 .
noria:Agent_AppDev noria:agentManagesResource noria:Resource_DB01 .

# Connect application modules to resources they utilize (using seas:subSystemOf)
noria:AppMod_CorpDNS_Prod seas:subSystem noria:Resource_DNS01 .
noria:AppMod_WebPortal_Prod seas:subSystem noria:Resource_WebSrv01 .
noria:AppMod_WebPortal_Prod seas:subSystem noria:Resource_DB01 .

# Connect Event Records to potential repair actions
noria:Event_DNS_Down noria:alarmProposedRepairAction noria:OpPlan_DNS_Restart .
noria:Event_Interface_Flap noria:alarmProposedRepairAction noria:OpPlan_Router_Firmware .

# Connect Trouble Tickets to their notes
noria:TT_DNS_Outage dcterms:hasPart noria:TTNote_DNS_Investigation .
noria:TT_Web_Performance dcterms:hasPart noria:TTNote_Web_Diagnosis .

# Connect Change Requests to their impacted services/resources
noria:CR_RouterUpgrade noria:changeRequestImpact noria:Resource_RouterCore01 .
noria:CR_DBMigration noria:changeRequestImpact noria:Resource_DB01 .
noria:CR_DBMigration noria:changeRequestImpact noria:App_WebPortal .

# Example of a correlated execution for a trouble ticket note (using pep:ProcedureExecutionContainer)
# Assuming a hypothetical procedure execution container for the DNS investigation
noria:ProcExecCont_DNS_Check a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS Investigation Execution Container"@en ;
    dcterms:description "Container for actions taken during DNS outage investigation."@en ;
    pep:member noria:Event_Interface_Flap . # Example: interface flap was part of the investigation

noria:TTNote_DNS_Investigation noria:troubleTicketNoteCorrelatedExecution noria:ProcExecCont_DNS_Check .

# Example of a document attachment
noria:DocAttach_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for Paris DC"@en ;
    rdfs:comment "Diagram showing the network topology of the Paris Data Center."@en ;
    dcterms:isPartOf noria:TT_DNS_Outage ;
    dcterms:isPartOf noria:CR_RouterUpgrade ;
    dcterms:format "image/png" ;
    dcterms:source <http://docs.example.com/network_diagram_paris_dc.png> .

