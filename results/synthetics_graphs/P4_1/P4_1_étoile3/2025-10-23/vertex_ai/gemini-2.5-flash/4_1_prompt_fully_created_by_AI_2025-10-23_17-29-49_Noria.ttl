    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Virtual NIC for database traffic."@en .

# -----------------------------------------------------------------------------
# Network Links (noria:NetworkLink)
# -----------------------------------------------------------------------------

noria:NetLink_DC_Uplink
    a noria:NetworkLink ;
    rdfs:label "Data Center Uplink"@en ;
    rdfs:comment "High-speed fiber link connecting the data center to the internet."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkId "NL-DC-UPLINK-01" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination <http://example.com/external/ISP_Router> ; # External resource
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic WAN" ;
    noria:networkInterfaceConnects noria:NetIF_RouterCore01_Gi0_0_1 .

noria:NetLink_Internal_A
    a noria:NetworkLink ;
    rdfs:label "Internal Link A (Router-DNS)"@en ;
    rdfs:comment "Internal network link between core router and DNS server."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkId "NL-INT-RTR-DNS-01" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01, noria:Resource_DNS01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkInterfaceConnects noria:NetIF_RouterCore01_Gi0_0_2, noria:NetIF_DNS01_Eth0 .

noria:NetLink_Internal_B
    a noria:NetworkLink ;
    rdfs:label "Internal Link B (Router-VMHost)"@en ;
    rdfs:comment "Internal network link between core router and virtualization host."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkId "NL-INT-RTR-VMH-01" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01, noria:Resource_VMHost01 ;
    noria:networkLinkInstallationDate "2022-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkInterfaceConnects noria:NetIF_RouterCore01_Gi0_0_2, noria:NetIF_VMHost01_vmnic0 .

