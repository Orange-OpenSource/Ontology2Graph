noria:Event_InterfaceDown
    a noria:EventRecord ;
    rdfs:label "Router Interface Down"@en ;
    rdfs:comment "Alert: GigabitEthernet 0/0/1 on router-core01 is down."@en ;
    noria:loggingTime "2024-04-10T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "LINKPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/InterfaceStateChange> .

noria:Event_DBError
    a noria:EventRecord ;
    rdfs:label "Database Connection Error"@en ;
    rdfs:comment "Error: Failed to connect to database db01.corp.example.com."@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DB01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "ERROR: Database connection pool exhausted for db01." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    dcterms:type <kos/Notification/EventType/ApplicationError> .

noria:Event_ConfigChange
    a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Informational: Configuration change applied to router-core01."@en ;
    noria:loggingTime "2024-04-09T23:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
