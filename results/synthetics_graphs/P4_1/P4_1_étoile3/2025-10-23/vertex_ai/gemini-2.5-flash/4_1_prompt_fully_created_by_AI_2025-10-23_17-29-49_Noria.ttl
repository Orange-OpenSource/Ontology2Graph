# -----------------------------------------------------------------------------
# Operation Plans (noria:OperationPlan)
# -----------------------------------------------------------------------------

noria:OpPlan_RouterRestart
    a noria:OperationPlan ;
    rdfs:label "Router Restart Procedure"@en ;
    rdfs:label "Procédure de Redémarrage Routeur"@fr ;
    rdfs:comment "Standard operating procedure for restarting a core network router."@en ;
    skos:example "Steps include: notify stakeholders, save configuration, execute restart command, verify connectivity."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterUnresponsive ;
    noria:operationPlanPostCondition noria:PostCond_RouterOnline .

noria:OpPlan_DBBackup
    a noria:OperationPlan ;
    rdfs:label "Database Backup Procedure"@en ;
    rdfs:label "Procédure de Sauvegarde Base de Données"@fr ;
    rdfs:comment "Routine procedure for backing up critical databases."@en ;
    skos:example "Steps include: verify disk space, initiate backup, verify backup integrity, log completion."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBConsistent ;
    noria:operationPlanPostCondition noria:PostCond_BackupComplete .

# -----------------------------------------------------------------------------
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# -----------------------------------------------------------------------------

noria:PreCond_RouterUnresponsive
    a noria:ActionPreCondition ;
    rdfs:label "Router Unresponsive"@en ;
    rdfs:comment "Condition: Router is not responding to ping or management access."@en ;
    skos:example "Ping to management IP fails, SSH/Telnet connection refused."@en .

noria:PostCond_RouterOnline
    a noria:ActionPostCondition ;
    rdfs:label "Router Online and Stable"@en ;
    rdfs:comment "Expected outcome: Router is fully operational, all interfaces up, and routing protocols converged."@en ;
    skos:example "Ping to management IP succeeds, all critical interfaces are up, BGP/OSPF neighbors established."@en .

noria:PreCond_DBConsistent
    a noria:ActionPreCondition ;
    rdfs:label "Database Consistent State"@en ;
    rdfs:comment "Condition: Database is in a consistent state, no active transactions that would be corrupted by backup."@en ;
    skos:example "Check database logs for errors, ensure no critical writes are in progress."@en .

noria:PostCond_BackupComplete
    a noria:ActionPostCondition ;
    rdfs:label "Backup Operation Completed"@en ;
    rdfs:comment "Expected outcome: Database backup completed successfully and verified."@en ;
    skos:example "Backup file exists, checksum matches, restore test successful."@en .

# -----------------------------------------------------------------------------
# Additional Connections for Density
# -----------------------------------------------------------------------------

# Link Event Records to Trouble Tickets (documentStatusHistory)
noria:TT_DNSOutage noria:documentStatusHistory noria:Event_DNSDown .
noria:TT_WebSlow noria:documentStatusHistory noria:Event_DBError .

# Link Change Request to related events (e.g., configuration changes)
noria:CR_RouterUpgrade noria:documentStatusHistory noria:Event_ConfigChange .

# Link Application Modules to their support leaders
noria:AppMod_CorpDNS_Prod noria:applicationModuleAdministrationLeader noria:Agent_AdminTeam ;
                          noria:applicationModuleSupportLeader noria:Agent_NetworkOps . # Example: NetworkOps leader for L2 support

noria:AppMod_WebPortal_Prod noria:applicationModuleAdministrationLeader noria:Agent_AppDev ;
                           noria:applicationModuleSupportLeader noria:Agent_AppDev . # AppDev leader for L2 support

# Link Agents to resources they manage (inverse of resourceManagedBy)
noria:Agent_AdminTeam noria:agentManagesResource noria:Resource_DNS01 .
noria:Agent_NetworkOps noria:agentManagesResource noria:Resource_RouterCore01, noria:Resource_VMHost01 .
noria:Agent_AppDev noria:agentManagesResource noria:Resource_WebSrv01, noria:Resource_DB01 .

# Link Operation Plans to Change Requests (actionCorrelatedOperationPlan)
# This property is for CorrectiveMaintenanceAction or ChangeAction, not directly for CR.
# However, a CR can be seen as a container for actions, and an OpPlan guides actions.
# For density, we can imply a relationship or create an intermediate action if needed.
# Let's assume a ChangeAction for the CR_RouterUpgrade.
# Since noria:actionCorrelatedOperationPlan is for noria:CorrectiveMaintenanceAction or noria:ChangeAction,
# and these are subclasses of pep:ProcedureExecution, we can create a dummy one.
# For simplicity and to avoid creating too many intermediate classes not explicitly asked for,
# I'll skip direct linking of CR to OpPlan with this specific property,
# but rather show how an OpPlan could be used in the context of a CR.
# The schema states: "a ChangeRequest is a context for (potentially) many *ChangeAction* to occur".
# So, a ChangeAction would use the OperationPlan.

# Example of a ChangeAction (not explicitly a NORIA class, but implied by PEP alignment)
# For now, I'll stick to the provided classes.
# The prompt asks for "relations with d’autres entités via les propriétés du vocabulaire".
# noria:changeRequestSpecification is the closest for linking a CR to a predefined plan/specification.
# However, noria:OperationPlan is a class, not a skos:Concept.
# So, I'll add a comment here to indicate this potential connection.
# noria:CR_RouterUpgrade noria:changeRequestSpecification noria:OpPlan_RouterRestart . # This would be incorrect as range is skos:Concept.

# Let's add more observable properties to Network Interfaces
noria:NetIF_RouterCore01_Gi0_0_1 noria:networkInterfaceLaserTxOpticalPower -3 ;
                                  noria:networkInterfaceLaserRxOpticalPower -5 ;
                                  noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
                                  noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetIF_RouterCore01_Gi0_0_2 noria:networkInterfaceLaserTxOpticalPower -2 ;
                                  noria:networkInterfaceLaserRxOpticalPower -4 .

