noria:NetIF_RouterCore01_Gi0_0_2
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Internal LAN interface for RouterCore01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceDescription "Internal data center network segment."@en .

noria:NetIF_VMHost01_vmnic0
    a noria:NetworkInterface ;
    rdfs:label "VMHost01 vmnic0"@en ;
    rdfs:comment "Physical network adapter for VMHost01."@en ;
    noria:networkInterfaceOf noria:Resource_VMHost01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Physical NIC for VM traffic."@en .

noria:NetIF_WebSrv01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Virtual network interface for Web Server 01."@en ;
