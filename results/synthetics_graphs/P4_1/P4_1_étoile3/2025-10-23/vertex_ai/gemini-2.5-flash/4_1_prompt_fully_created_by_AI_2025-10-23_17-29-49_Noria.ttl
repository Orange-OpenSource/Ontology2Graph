    noria:productManufacturedBy <http://www.vmware.com/organization> . # Assuming a URI for VMware

# -----------------------------------------------------------------------------
# Resources (noria:Resource)
# -----------------------------------------------------------------------------

noria:Resource_DNS01
    a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical infrastructure."@en ;
    noria:resourceManagedBy noria:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_CorpDNS ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_RouterCore01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for data center network connectivity."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "router-core01.dc.example.com" ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_Monitoring ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_VMHost01
    a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:label "Hôte de Virtualisation 01"@fr ;
    rdfs:comment "Physical server hosting multiple virtual machines."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "vmhost01.dc.example.com" ;
    noria:resourceLogisticId "LOG-VMH-001" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceSerialNumber "SN-VMH-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_WebPortal ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> .

noria:Resource_WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:label "Serveur Web 01"@fr ;
    rdfs:comment "Virtual machine hosting the corporate web portal."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/virtual-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_WebPortal ;
    noria:clusterController noria:Resource_VMHost01 ;
    noria:virtualServerStatus <kos/Resource/OperationalState/running> .

noria:Resource_DB01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:label "Serveur de Base de Données 01"@fr ;
    rdfs:comment "Virtual machine hosting the corporate database."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/virtual-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T11:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_WebPortal ;
    noria:clusterController noria:Resource_VMHost01 ;
    noria:virtualServerStatus <kos/Resource/OperationalState/running> .

