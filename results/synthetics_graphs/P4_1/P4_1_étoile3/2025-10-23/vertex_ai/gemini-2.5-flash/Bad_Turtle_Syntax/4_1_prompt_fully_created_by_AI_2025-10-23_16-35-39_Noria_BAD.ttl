    noria:troubleTicketDetectionDateTime "2024-04-23T09:55:00Z"^^xsd:dateTime ;
    noria:troubleTicketCause "Faulty transceiver on router interface."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketImpacts noria:NetworkLink/internet-uplink-01 ;
    noria:troubleTicketTrigger noria:EventRecord/log-interface-down-01 .

