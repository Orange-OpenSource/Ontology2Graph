# -----------------------------------------------------------------------------
# Operation Plans (noria:OperationPlan)
# -----------------------------------------------------------------------------
noria:OperationPlan/db-restart-procedure a noria:OperationPlan ;
    rdfs:label "Database Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for safely restarting the production database to resolve connectivity issues."@en ;
    skos:example "Steps include: 1. Notify stakeholders. 2. Stop application services. 3. Stop database service. 4. Start database service. 5. Start application services. 6. Verify connectivity and application functionality."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition/db-unreachable-precond ;
    noria:operationPlanPostCondition noria:ActionPostCondition/db-reachable-postcond .

noria:OperationPlan/interface-troubleshoot-procedure a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving network interface issues, including physical checks and configuration verification."@en ;
    skos:example "Steps include: 1. Check physical cabling. 2. Verify interface status via CLI. 3. Check transceiver diagnostics. 4. Clear interface counters. 5. Reconfigure interface if necessary."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition/interface-down-precond ;
    noria:operationPlanPostCondition noria:ActionPostCondition/interface-up-postcond .

# -----------------------------------------------------------------------------
# Action Pre-Conditions (noria:ActionPreCondition)
# -----------------------------------------------------------------------------
noria:ActionPreCondition/db-unreachable-precond a noria:ActionPreCondition ;
    rdfs:label "Database Unreachable Pre-condition"@en ;
    rdfs:comment "Condition that triggers the database restart procedure: Database server is not reachable from application server."@en ;
    skos:example "Ping to DB IP fails, application logs show connection errors, monitoring alerts for database connectivity."@en .

noria:ActionPreCondition/interface-down-precond a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-condition"@en ;
    rdfs:comment "Condition that triggers network interface troubleshooting: Network interface reports operational status 'down'."@en ;
    skos:example "Monitoring system alerts 'interface down', router CLI shows interface status 'down', no traffic flow."@en .

# -----------------------------------------------------------------------------
# Action Post-Conditions (noria:ActionPostCondition)
# -----------------------------------------------------------------------------
noria:ActionPostCondition/db-reachable-postcond a noria:ActionPostCondition ;
    rdfs:label "Database Reachable Post-condition"@en ;
    rdfs:comment "Expected outcome after database restart: Database server is reachable and application can connect successfully."@en ;
    skos:example "Ping to DB IP succeeds, application logs show successful connection, CRM system is functional and accessible to users."@en .

noria:ActionPostCondition/interface-up-postcond a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-condition"@en ;
    rdfs:comment "Expected outcome after troubleshooting: Network interface reports operational status 'up' and traffic flows normally."@en ;
    skos:example "Monitoring system clears 'interface down' alert, router CLI shows interface status 'up', traffic statistics normalize."@en .

# -----------------------------------------------------------------------------
# Procedure Execution Containers (pep:ProcedureExecutionContainer)
# -----------------------------------------------------------------------------
noria:ProcedureExecutionContainer/db-fix-exec a pep:ProcedureExecutionContainer ;
    rdfs:label "Database Fix Execution"@en ;
    rdfs:comment "Container for actions taken to fix the database connectivity issue for TT-2024-001."@en ;
    pep:hasProcedure noria:OperationPlan/db-restart-procedure ;
    pep:hasAgent noria:Agent/jane-smith ;
    pep:hasInput noria:TroubleTicket/tt-2024-001 ;
    pep:hasOutput noria:EventRecord/db-restart-success-log .

# Linking EventRecord to its mitigation
noria:EventRecord/log-db-unreachable-01 noria:alarmMitigatedBy noria:ProcedureExecutionContainer/db-fix-exec .
