    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network misconfiguration on database VM."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedSpecificNetworks> ;
    noria:troubleTicketImpacts noria:Application/crm-system ;
    noria:troubleTicketImpacts noria:Service/customer-facing-crm ;
