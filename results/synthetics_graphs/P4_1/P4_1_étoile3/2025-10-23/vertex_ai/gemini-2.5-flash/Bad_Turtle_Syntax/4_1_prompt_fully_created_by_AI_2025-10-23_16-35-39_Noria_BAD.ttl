# -----------------------------------------------------------------------------
# Product Models (noria:ProductModel)
# -----------------------------------------------------------------------------
noria:ProductModel/dell-r740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy noria:Org/dell .

noria:ProductModel/cisco-asr1k a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Enterprise-grade aggregation services router from Cisco."@en ;
    noria:productManufacturedBy noria:Org/cisco .

noria:ProductModel/vmware-esxi a noria:ProductModel ;
    rdfs:label "VMware ESXi Virtualization Platform"@en ;
    rdfs:comment "Hypervisor software for virtual machines from VMware."@en ;
    noria:productManufacturedBy noria:Org/vmware .

# -----------------------------------------------------------------------------
# Resources (noria:Resource)
# -----------------------------------------------------------------------------
noria:Resource/server-app-01 a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Physical server hosting critical applications, part of the CRM system infrastructure."@en ;
    noria:resourceHostName "app-srv-01.corp.example.com" ;
    noria:resourceLogisticId "LOG-APP-01-XYZ" ;
    noria:resourceSerialNumber "SN-APP-01-12345" ;
    noria:resourceProductModel noria:ProductModel/dell-r740 ;
    noria:resourceManagedBy noria:Agent/team-ops ;
    noria:resourceType <kos/Resource/type/physical-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus/rack-a1 ;
    noria:resourceManagementIPAddress "192.168.10.10" ;
    noria:resourceForApplication noria:Application/crm-system .

noria:Resource/router-core-01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for datacenter network connectivity, handling internet uplink and internal routing."@en ;
    noria:resourceHostName "core-rtr-01.corp.example.com" ;
    noria:resourceLogisticId "LOG-RTR-01-ABC" ;
    noria:resourceSerialNumber "SN-RTR-01-67890" ;
    noria:resourceProductModel noria:ProductModel/cisco-asr1k ;
    noria:resourceManagedBy noria:Agent/team-network ;
    noria:resourceType <kos/Resource/type/network-router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus/rack-b1 ;
    noria:resourceManagementIPAddress "10.0.0.1" ;
    noria:resourceForApplication noria:Application/monitoring-platform . # Monitoring platform relies on network infrastructure

noria:Resource/vm-db-prod a noria:Resource ;
    rdfs:label "Production Database VM"@en ;
    rdfs:comment "Virtual machine hosting the production database for the CRM system."@en ;
    noria:resourceHostName "db-prod-vm.corp.example.com" ;
    noria:resourceManagedBy noria:Agent/team-ops ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication noria:Application/crm-system ;
    noria:clusterController noria:Resource/hypervisor-01 .

noria:Resource/hypervisor-01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server running VMware ESXi, hosting multiple VMs including the production database VM."@en ;
    noria:resourceHostName "hv-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel/dell-r740 ;
    noria:resourceManagedBy noria:Agent/team-ops ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus noria:Locus/rack-a2 ;
    noria:resourceManagementIPAddress "192.168.10.11" ;
    noria:resourceForApplication noria:Application/crm-system . # Hypervisor supports CRM VMs

noria:Resource/isp-router-01 a noria:Resource ;
    rdfs:label "ISP Router 01"@en ;
    rdfs:comment "External router managed by the Internet Service Provider, providing internet access."@en ;
    noria:resourceType <kos/Resource/type/network-router> ;
    noria:resourceHostName "isp-rtr-01.isp.example.com" .

# -----------------------------------------------------------------------------
# Network Interfaces (noria:NetworkInterface)
# -----------------------------------------------------------------------------
noria:NetworkInterface/app-srv-01-eth0 a noria:NetworkInterface ;
    rdfs:label "app-srv-01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Application Server 01, connecting to the internal datacenter network."@en ;
    noria:networkInterfaceOf noria:Resource/server-app-01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to core switch" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface/core-rtr-01-ge0-0-0 a noria:NetworkInterface ;
    rdfs:label "core-rtr-01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internet uplink."@en ;
    noria:networkInterfaceOf noria:Resource/router-core-01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Internet Uplink" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 .

noria:NetworkInterface/core-rtr-01-ge0-0-1 a noria:NetworkInterface ;
    rdfs:label "core-rtr-01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to internal datacenter network segment."@en ;
    noria:networkInterfaceOf noria:Resource/router-core-01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Datacenter Internal Link" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

noria:NetworkInterface/vm-db-prod-eth0 a noria:NetworkInterface ;
