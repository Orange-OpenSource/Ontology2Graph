# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix org: <http://www.w3.org/ns/org#> .

# --- Domain specific ---
@prefix bot:  <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix time: <http://www.w3.org/2006/time#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# -----------------------------------------------------------------------------
# Agents (foaf:Agent, org:OrganizationalUnit)
# -----------------------------------------------------------------------------
noria:Agent/team-ops a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Operations Team"@en ;
    rdfs:label "Équipe Opérations"@fr ;
    rdfs:comment "Team responsible for day-to-day IT operations and incident response."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all non-critical issues. For critical issues, use emergency hotline."@en .

noria:Agent/team-network a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:label "Équipe Ingénierie Réseau"@fr ;
    rdfs:comment "Specialized team managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call rotation" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For network outages, call the on-call engineer directly."@en .

noria:Agent/john-doe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:label "Jean Dupont"@fr ;
    rdfs:comment "Lead Network Engineer, responsible for core network infrastructure."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentManagesResource noria:Resource/router-core-01 .

noria:Agent/jane-smith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:label "Jeanne Martin"@fr ;
    rdfs:comment "Application Support Specialist for CRM and related systems."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentManagesResource noria:Resource/server-app-01 .

noria:Agent/customer-a a foaf:Agent ;
    rdfs:label "Customer A"@en ;
    rdfs:comment "External customer reporting an issue with CRM service."@en .

# -----------------------------------------------------------------------------
# Organizations (org:Organization)
# -----------------------------------------------------------------------------
noria:Org/dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of IT hardware, including servers."@en .

noria:Org/cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:Org/vmware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

# -----------------------------------------------------------------------------
# Locations (bot:Site, noria:Room, noria:Locus)
# -----------------------------------------------------------------------------
noria:Site/datacenter-paris a bot:Site ;
    rdfs:label "Paris Datacenter"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    rdfs:comment "Main datacenter facility located in Paris, France."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room/server-room-a a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Primary server room within the Paris Datacenter, housing critical infrastructure."@en ;
    bot:hasSubSpace noria:Site/datacenter-paris ;
    bot:hasSpace noria:Locus/rack-a1, noria:Locus/rack-a2, noria:Locus/rack-b1, noria:Locus/rack-b2,
                 noria:Locus/rack-c1, noria:Locus/rack-c2, noria:Locus/rack-d1, noria:Locus/rack-d2,
                 noria:Locus/rack-e1, noria:Locus/rack-e2, noria:Locus/rack-f1, noria:Locus/rack-f2,
                 noria:Locus/rack-g1, noria:Locus/rack-g2, noria:Locus/rack-h1, noria:Locus/rack-h2,
                 noria:Locus/rack-i1, noria:Locus/rack-i2, noria:Locus/rack-j1, noria:Locus/rack-j2,
                 noria:Locus/rack-k1, noria:Locus/rack-k2, noria:Locus/rack-l1, noria:Locus/rack-l2,
                 noria:Locus/rack-m1, noria:Locus/rack-m2, noria:Locus/rack-n1, noria:Locus/rack-n2,
                 noria:Locus/rack-o1, noria:Locus/rack-o2, noria:Locus/rack-p1, noria:Locus/rack-p2,
                 noria:Locus/rack-q1, noria:Locus/rack-q2, noria:Locus/rack-r1, noria:Locus/rack-r2,
                 noria:Locus/rack-s1, noria:Locus/rack-s2, noria:Locus/rack-t1, noria:Locus/rack-t2,
                 noria:Locus/rack-u1, noria:Locus/rack-u2, noria:Locus/rack-v1, noria:Locus/rack-v2,
                 noria:Locus/rack-w1, noria:Locus/rack-w2, noria:Locus/rack-x1, noria:Locus/rack-x2,
                 noria:Locus/rack-y1, noria:Locus/rack-y2, noria:Locus/rack-z1, noria:Locus/rack-z2 .

