    noria:locusRow "U2" .

:Locus_Rack_A2_U1 a noria:Locus ;
    rdfs:label "Rack A2, Unit 1"@en ;
    rdfs:comment "Location for router 'RTR-CORE-01' in Server Hall A."@en ;
    noria:locusLine "A2" ;
    noria:locusRow "U1" .

