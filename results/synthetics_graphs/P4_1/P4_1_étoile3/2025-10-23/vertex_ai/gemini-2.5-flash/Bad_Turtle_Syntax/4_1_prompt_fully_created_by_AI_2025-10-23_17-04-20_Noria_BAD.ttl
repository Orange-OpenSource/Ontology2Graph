    noria:sitePrincipalAddressCityName "Paris"@fr ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

:Room_Server_Hall_A a noria:Room ;
    rdfs:label "Server Hall A"@en ;
    rdfs:comment "Main server hall within the Paris Data Center."@en ;
    bot:hasSpace :Locus_Rack_A1_U1, :Locus_Rack_A1_U2, :Locus_Rack_A2_U1 .

:Locus_Rack_A1_U1 a noria:Locus ;
