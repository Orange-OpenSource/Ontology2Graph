# --- Network Interfaces (noria:NetworkInterface) ---
:NetworkInterface_Web_Server_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0 on Web Server 01"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
