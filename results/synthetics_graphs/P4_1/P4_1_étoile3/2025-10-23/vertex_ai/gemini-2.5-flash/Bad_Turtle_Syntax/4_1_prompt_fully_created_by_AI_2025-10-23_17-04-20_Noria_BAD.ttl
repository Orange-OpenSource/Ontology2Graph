    noria:applicationModuleHotlineEnabled true .

# --- Services (noria:Service) ---
:Service_Customer_Facing_Web_Service a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "End-to-end service providing public web access, including corporate website and customer portal."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :ApplicationModule_Corporate_Website_Prod . # Example of how a service might group modules

:Service_Internal_Data_Access a noria:Service ;
    rdfs:label "Internal Data Access Service"@en ;
    rdfs:comment "Service enabling internal applications to access shared database resources."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf :ApplicationModule_CRM_Backend_API .

# --- Event Records (noria:EventRecord) ---
:EventRecord_Web_Server_CPU_High a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on the primary web server."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on srv-web-01.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject :Resource_Web_Server_01 ;
    noria:logOriginatingManagementSystem :Application_Monitoring_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

:EventRecord_Network_Interface_Down a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Critical alert: GigabitEthernet0/0/1 on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down on rtr-core-01.example.com."@en ;
    noria:logOriginatingManagedObject :Resource_Core_Router_01 ;
    noria:logOriginatingManagementSystem :Application_NMS_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction :OperationPlan_Restart_Interface .

:EventRecord_DB_Login_Failure a noria:EventRecord ;
    rdfs:label "Database Login Failure"@en ;
    rdfs:comment "Multiple failed login attempts on the database server."@en ;
    noria:loggingTime "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:logText "Failed login for user 'baduser' from IP 192.168.1.100 on srv-db-01.example.com."@en ;
    noria:logOriginatingManagedObject :Resource_DB_Server_01 ;
    noria:logOriginatingManagementSystem :Application_SIEM_System ;
    noria:logOriginatingAgent :Agent_Security_Team ; # The SIEM system is managed by the security team
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:Application_Monitoring_System a noria:Application ;
    rdfs:label "Infrastructure Monitoring System"@en ;
