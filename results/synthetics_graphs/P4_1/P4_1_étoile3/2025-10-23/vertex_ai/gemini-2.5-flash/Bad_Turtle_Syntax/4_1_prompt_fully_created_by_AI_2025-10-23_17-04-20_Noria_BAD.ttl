# --- Operation Plans (noria:OperationPlan) ---
:OperationPlan_Restart_Interface a noria:OperationPlan ;
    rdfs:label "Network Interface Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network interface on a router."@en ;
    skos:example "CLI commands: 'shutdown interface Gi0/0/1', 'no shutdown interface Gi0/0/1'"@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Interface_Down ;
    noria:operationPlanPostCondition :ActionPostCondition_Interface_Up .

:OperationPlan_Web_Server_Troubleshoot a noria:OperationPlan ;
    rdfs:label "Web Server Performance Troubleshooting"@en ;
    rdfs:comment "Procedure to diagnose and resolve performance issues on web servers."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_High_CPU_Load ;
    noria:operationPlanPostCondition :ActionPostCondition_Normal_CPU_Load .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
:ActionPreCondition_Interface_Down a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: The network interface's operational status is 'down'."@en .

:ActionPostCondition_Interface_Up a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up' and traffic is flowing."@en .

:ActionPreCondition_High_CPU_Load a noria:ActionPreCondition ;
    rdfs:label "High CPU Load on Server"@en ;
    rdfs:comment "Condition: Server CPU utilization consistently above 80%."@en .

:ActionPostCondition_Normal_CPU_Load a noria:ActionPostCondition ;
    rdfs:label "Normal CPU Load on Server"@en ;
    rdfs:comment "Expected outcome: Server CPU utilization returns to normal levels (below 50%)."@en .

# --- Connecting Event Records to Trouble Tickets and Change Requests ---
:TroubleTicket_Network_Outage_01
    noria:documentStatusHistory :EventRecord_TT01_Status_InProgress .

:EventRecord_TT01_Status_InProgress a noria:EventRecord ;
    rdfs:label "Trouble Ticket 01 Status Change to InProgress"@en ;
    rdfs:comment "System event recording the status change of Trouble Ticket Network_Outage_01 to InProgress."@en ;
    noria:loggingTime "2024-04-23T10:17:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-01 status changed from 'Initialised' to 'InProgress'."@en ;
    noria:logOriginatingManagementSystem :Application_Ticketing_System ;
    noria:logOriginatingManagedObject :TroubleTicket_Network_Outage_01 .

:Application_Ticketing_System a noria:Application ;
    rdfs:label "ITSM Ticketing System"@en ;
    rdfs:comment "Application used for managing incidents, problems, and changes."@en ;
    noria:applicationType <kos/application/type/it-service-management> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

:ChangeRequest_Router_Firmware_Upgrade
    noria:documentStatusHistory :EventRecord_CR01_Status_Scheduled .

:EventRecord_CR01_Status_Scheduled a noria:EventRecord ;
    rdfs:label "Change Request 01 Status Change to Scheduled"@en ;
    rdfs:comment "System event recording the status change of Change Request Router_Firmware_Upgrade to Scheduled."@en ;
    noria:loggingTime "2024-04-10T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-01 status changed from 'Approved' to 'Scheduled'."@en ;
    noria:logOriginatingManagementSystem :Application_Ticketing_System ;
    noria:logOriginatingManagedObject :ChangeRequest_Router_Firmware_Upgrade .

