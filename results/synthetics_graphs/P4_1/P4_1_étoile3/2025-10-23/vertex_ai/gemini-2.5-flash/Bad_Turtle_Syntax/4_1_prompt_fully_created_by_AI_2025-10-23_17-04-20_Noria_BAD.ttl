    noria:resourceManagedBy :Agent_Network_Admin .

:NetworkLink_DB_Core_01 a noria:NetworkLink ;
    rdfs:label "Link DB Server 01 to Core Router 01"@en ;
    rdfs:comment "Internal network link between DB Server 01 and Core Router 01."@en ;
    noria:networkLinkId "NL-DB-CORE-01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2023-01-15T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_DB_Server_01 ;
    noria:networkLinkTerminationResourceDestination :Resource_Core_Router_01 ;
    noria:resourceManagedBy :Agent_Network_Admin .

:NetworkLink_Core_External a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to External Gateway"@en ;
    rdfs:comment "External network link from Core Router 01 to the internet gateway."@en ;
    noria:networkLinkId "NL-CORE-EXT-01" ;
    noria:networkLinkType "Fiber Optic 100Gbps" ;
    noria:networkLinkInstallationDate "2022-05-20T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin :Resource_Core_Router_01 ;
    noria:resourceManagedBy :Agent_Network_Admin .

# --- Applications (noria:Application) ---
:Application_Corporate_Website a noria:Application ;
