    rdfs:label "Customer Relationship Management (CRM) System"@en ;
    rdfs:comment "Internal system for managing customer interactions and data."@en ;
    noria:applicationModelIdentifier "CRM-PROD" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Operations" ;
    noria:applicationFunctionalSubDomain "Customer Data Management" .

:Application_Corporate_Internet_Access a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and systems."@en ;
