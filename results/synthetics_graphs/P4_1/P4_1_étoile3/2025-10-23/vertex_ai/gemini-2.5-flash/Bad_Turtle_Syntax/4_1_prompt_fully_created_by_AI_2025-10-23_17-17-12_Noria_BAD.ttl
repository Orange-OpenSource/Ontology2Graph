### Services (noria:Service) ###
noria:instance/Service/InternetAccessService a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:label "Service d'Accès Internet d'Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:instance/ApplicationModule/CorpDNS-Prod ;
    seas:subSystemOf noria:instance/ApplicationModule/WebAppPortal-Prod .

noria:instance/Service/InternalDataService a noria:Service ;
    rdfs:label "Internal Data Exchange Service"@en ;
    rdfs:label "Service d'Échange de Données Interne"@fr ;
    rdfs:comment "Facilitates data exchange between internal applications and databases."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:instance/Resource/DBServerProd .

### Trouble Tickets (noria:TroubleTicket) ###
noria:instance/TroubleTicket/TT20240315-001 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident de Panne Serveur DNS"@fr ;
    rdfs:comment "Primary DNS server (dns01.corp.example.com) is unreachable, causing widespread internal network issues."@en ;
    dcterms:identifier "TT20240315-001" ;
    dcterms:created "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-03-15T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/NetworkOutage> ;
    noria:troubleTicketCause "Hardware failure on DNS01 server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
