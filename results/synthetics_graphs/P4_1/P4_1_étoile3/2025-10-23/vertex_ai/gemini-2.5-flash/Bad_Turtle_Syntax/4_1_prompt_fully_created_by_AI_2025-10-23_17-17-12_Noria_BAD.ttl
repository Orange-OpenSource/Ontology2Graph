### Resources (noria:Resource) ###
noria:instance/Resource/DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for internal network resolution."@en ;
    noria:resourceManagedBy noria:instance/Agent/AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:instance/ProductModel/DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:instance/Location/RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:instance/Resource/WebSrv01 a noria:Resource ;
    rdfs:label "Web Application Server 01"@en ;
    rdfs:label "Serveur d'Application Web 01"@fr ;
    rdfs:comment "Virtual server hosting the main corporate web application."@en ;
    noria:resourceManagedBy noria:instance/Agent/SupportTeamL2 ;
    noria:resourceHostName "webapp01.corp.example.com" ;
    noria:resourceProductModel noria:instance/ProductModel/VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/virtual-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:instance/Location/RackA2 ;
    noria:resourceForApplication noria:instance/Application/WebAppPortal ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.50> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/running> .

noria:instance/Resource/RouterCore1 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for internal network routing and external connectivity."@en ;
    noria:resourceManagedBy noria:instance/Agent/NOC ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel noria:instance/ProductModel/CiscoCatalyst9300 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:instance/Location/RackB1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.1> .

noria:instance/Resource/FirewallDMZ a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:label "Pare-feu DMZ"@fr ;
    rdfs:comment "Firewall protecting the Demilitarized Zone."@en ;
    noria:resourceManagedBy noria:instance/Agent/AdminTeam ;
    noria:resourceHostName "fw-dmz01.corp.example.com" ;
    noria:resourceProductModel noria:instance/ProductModel/CiscoCatalyst9300 ; # Example, could be a dedicated firewall product model
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-09-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:instance/Location/RackB2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.1> .

noria:instance/Resource/DBServerProd a noria:Resource ;
    rdfs:label "Production Database Server"@en ;
    rdfs:label "Serveur de Base de Données de Production"@fr ;
    rdfs:comment "Physical server hosting critical production databases."@en ;
    noria:resourceManagedBy noria:instance/Agent/AdminTeam ;
    noria:resourceHostName "dbprod01.corp.example.com" ;
    noria:resourceProductModel noria:instance/ProductModel/DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DB01-PQR" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-02-20T16:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:instance/Location/RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> .

### Network Interfaces (noria:NetworkInterface) ###
noria:instance/NetworkInterface/DNS01-Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:instance/Resource/DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Connected to internal LAN segment 192.168.1.0/24."@en ;
    noria:networkInterfaceConnects noria:instance/NetworkLink/Link-DNS01-RouterCore1 .

noria:instance/NetworkInterface/RouterCore1-Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore1 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting RouterCore1 to internal LAN."@en ;
    noria:networkInterfaceOf noria:instance/Resource/RouterCore1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Internal LAN uplink."@en ;
    noria:networkInterfaceConnects noria:instance/NetworkLink/Link-DNS01-RouterCore1 .

noria:instance/NetworkInterface/RouterCore1-Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "RouterCore1 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting RouterCore1 to DMZ Firewall."@en ;
    noria:networkInterfaceOf noria:instance/Resource/RouterCore1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceDescription "DMZ uplink."@en ;
    noria:networkInterfaceConnects noria:instance/NetworkLink/Link-RouterCore1-FirewallDMZ .

noria:instance/NetworkInterface/FirewallDMZ-Ext a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ External Interface"@en ;
    rdfs:comment "External interface of the DMZ Firewall, facing the internet."@en ;
    noria:networkInterfaceOf noria:instance/Resource/FirewallDMZ ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Internet facing interface."@en ;
    noria:networkInterfaceLaserTxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPower -7 .

noria:instance/NetworkInterface/FirewallDMZ-Int a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ Internal Interface"@en ;
    rdfs:comment "Internal interface of the DMZ Firewall, facing RouterCore1."@en ;
    noria:networkInterfaceOf noria:instance/Resource/FirewallDMZ ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Internal DMZ interface."@en ;
    noria:networkInterfaceConnects noria:instance/NetworkLink/Link-RouterCore1-FirewallDMZ .

### Network Links (noria:NetworkLink) ###
noria:instance/NetworkLink/Link-DNS01-RouterCore1 a noria:NetworkLink ;
    rdfs:label "Link DNS01 to RouterCore1"@en ;
    rdfs:comment "Physical Ethernet link between DNS01 and RouterCore1."@en ;
    noria:networkLinkId "NL-001" ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:instance/Resource/DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:instance/Resource/RouterCore1 ;
    noria:resourceManagedBy noria:instance/Agent/NOC .

noria:instance/NetworkLink/Link-RouterCore1-FirewallDMZ a noria:NetworkLink ;
    rdfs:label "Link RouterCore1 to FirewallDMZ"@en ;
    rdfs:comment "Physical fiber link between RouterCore1 and FirewallDMZ."@en ;
    noria:networkLinkId "NL-002" ;
    noria:networkLinkType "Fiber Optic 10Gbps" ;
    noria:networkLinkInstallationDate "2021-06-20T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:instance/Resource/RouterCore1 ;
    noria:networkLinkTerminationResourceDestination noria:instance/Resource/FirewallDMZ ;
    noria:resourceManagedBy noria:instance/Agent/NOC .

