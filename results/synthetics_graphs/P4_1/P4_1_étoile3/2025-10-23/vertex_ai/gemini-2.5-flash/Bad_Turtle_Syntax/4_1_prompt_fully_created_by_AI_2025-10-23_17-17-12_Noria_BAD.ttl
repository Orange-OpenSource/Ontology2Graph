# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix org: <http://www.w3.org/ns/org#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

### Agents (foaf:Agent, org:OrganizationalUnit) ###
noria:instance/Agent/AdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Infrastructure Admin Team"@en ;
    rdfs:label "Équipe d'Administration Infrastructure"@fr ;
    rdfs:comment "Team responsible for core IT infrastructure management, including servers and network devices."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, direct phone for critical incidents."@en .

noria:instance/Agent/SupportTeamL2 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Level 2 Support Team"@en ;
    rdfs:label "Équipe Support Niveau 2"@fr ;
    rdfs:comment "Second-line support for application and service issues."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentInstructions "Escalate from L1 or via automated alerts. Use dedicated chat for urgent matters."@en .

noria:instance/Agent/NOC a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:label "Centre d'Opérations Réseau"@fr ;
    rdfs:comment "Monitors network health and responds to network-related incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentInstructions "Follow standard operating procedures for network alerts. Open trouble tickets for all incidents."@en .

noria:instance/Agent/JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:label "Jean Dupont"@fr ;
    rdfs:comment "Individual IT engineer, member of the Admin Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentInstructions "Available for direct contact during working hours for urgent matters."@en .

noria:instance/Agent/JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:label "Jeanne Martin"@fr ;
    rdfs:comment "Application support specialist, member of the Support Team L2."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+33198765432" .

noria:instance/Agent/CustomerService a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Service Department"@en ;
    rdfs:label "Service Client"@fr ;
    rdfs:comment "First point of contact for customer inquiries and incident reporting."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sat)"@en .

### Locations ###
noria:instance/Location/DataCenterParis a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center location for production systems."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR" .

noria:instance/Location/ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:instance/Location/RackA1 ;
    bot:hasSpace noria:instance/Location/RackA2 ;
    bot:hasSpace noria:instance/Location/RackB1 ;
    bot:hasSpace noria:instance/Location/RackB2 .

noria:instance/Location/RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:label "Baie A1"@fr ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

noria:instance/Location/RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:label "Baie A2"@fr ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en .

noria:instance/Location/RackB1 a noria:Locus ;
    rdfs:label "Rack B1"@en ;
    rdfs:label "Baie B1"@fr ;
    rdfs:comment "First rack in Server Room B."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "1"@en .

noria:instance/Location/RackB2 a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:label "Baie B2"@fr ;
    rdfs:comment "Second rack in Server Room B."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "2"@en .

