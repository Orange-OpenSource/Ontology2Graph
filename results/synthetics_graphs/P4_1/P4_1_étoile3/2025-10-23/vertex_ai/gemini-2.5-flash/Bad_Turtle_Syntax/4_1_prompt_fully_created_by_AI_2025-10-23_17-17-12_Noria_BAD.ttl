### Operation Plans (noria:OperationPlan) ###
noria:instance/OperationPlan/DNSFailoverProcedure a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:label "Procédure de Basculement DNS"@fr ;
    rdfs:comment "Standard operating procedure for failing over to a secondary DNS server in case of primary outage."@en ;
    skos:example "Steps include verifying primary server status, activating secondary, and updating network configurations."@en ;
    noria:operationPlanPreCondition noria:instance/ActionPreCondition/DNSPrimaryDown ;
    noria:operationPlanPostCondition noria:instance/ActionPostCondition/DNSSecondaryActive .

noria:instance/OperationPlan/RouterConfigUpdateProcedure a noria:OperationPlan ;
    rdfs:label "Router Configuration Update Procedure"@en ;
    rdfs:label "Procédure de Mise à Jour Configuration Routeur"@fr ;
    rdfs:comment "Procedure for safely updating configuration on core network routers."@en ;
    skos:example "Includes backup, pre-checks, configuration application, and post-checks."@en ;
    noria:operationPlanPreCondition noria:instance/ActionPreCondition/RouterConfigBackupExists ;
    noria:operationPlanPostCondition noria:instance/ActionPostCondition/RouterConfigApplied .

### Action Pre/Post Conditions ###
noria:instance/ActionPreCondition/DNSPrimaryDown a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Down"@en ;
    rdfs:comment "Condition: The primary DNS server is unresponsive or inaccessible."@en .

noria:instance/ActionPostCondition/DNSSecondaryActive a noria:ActionPostCondition ;
    rdfs:label "Secondary DNS Server Active"@en ;
    rdfs:comment "Outcome: The secondary DNS server is actively serving DNS requests."@en .

noria:instance/ActionPreCondition/RouterConfigBackupExists a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Exists"@en ;
    rdfs:comment "Condition: A recent backup of the router's configuration is available."@en .

noria:instance/ActionPostCondition/RouterConfigApplied a noria:ActionPostCondition ;
    rdfs:label "Router Configuration Successfully Applied"@en ;
    rdfs:comment "Outcome: The new configuration has been applied to the router and verified."@en .

