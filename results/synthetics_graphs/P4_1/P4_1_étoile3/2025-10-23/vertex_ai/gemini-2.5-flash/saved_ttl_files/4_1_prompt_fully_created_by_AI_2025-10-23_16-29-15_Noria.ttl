# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents and Organizational Units
# =============================================================================

foaf:Agent_AdminTeam
    a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and operations."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, phone for critical outages."@en .

foaf:Agent_NetworkOps
    a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always use the dedicated hotline for network incidents."@en .

foaf:Agent_AppDev
    a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:label "Équipe de Développement Applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

foaf:Agent_SecurityAnalyst
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Security Analyst responsible for incident response."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_CustomerA
    a foaf:Agent ;
    rdfs:label "Customer A Representative"@en ;
    rdfs:comment "Key contact for Customer A's services."@en .

foaf:Agent_ExternalVendor
    a foaf:Agent ;
    rdfs:label "External Hardware Vendor Support"@en ;
    rdfs:comment "Third-party support for hardware maintenance."@en .

org:OrgUnit_L1Support
    a org:OrganizationalUnit ;
    rdfs:label "Level 1 Support"@en ;
    rdfs:label "Support Niveau 1"@fr ;
    rdfs:comment "First line of support for user issues."@en .

org:OrgUnit_L2Support
    a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support"@en ;
    rdfs:label "Support Niveau 2"@fr ;
    rdfs:comment "Second line of support for technical issues, escalating from L1."@en .

org:OrgUnit_Hotline
    a org:OrganizationalUnit ;
    rdfs:label "Hotline Team"@en ;
    rdfs:label "Équipe d'Astreinte"@fr ;
    rdfs:comment "On-call team for critical incidents outside business hours."@en .

# =============================================================================
# Locations
# =============================================================================

bot:Site_ParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center for corporate services."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

noria:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC .

noria:Locus_RackA1
    a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of critical infrastructure servers."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackA2
    a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of network equipment."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <https://www.dell.com/> . # Assuming Dell is an org:Organization

noria:ProductModel_CiscoNexus9K
    a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series for high-density deployments."@en ;
    noria:productManufacturedBy <https://www.cisco.com/> . # Assuming Cisco is an org:Organization

noria:ProductModel_VMwareESXi
    a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com/> . # Assuming VMware is an org:Organization

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01
    a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical for internal and external resolution."@en ;
    noria:resourceManagedBy foaf:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_CorpInternetAccess ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

noria:Resource_RouterCore01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for data center network connectivity and external routing."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:resourceHostName "router-core-01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-07-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_CorpInternetAccess ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_VMHost01
    a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:label "Hôte de Virtualisation 01"@fr ;
    rdfs:comment "ESXi host running multiple virtual machines for various applications."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:resourceHostName "vmhost01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceLogisticId "LOG-VMH-001" ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
    noria:resourceSerialNumber "SN-VMH-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "192.168.1.20" .

noria:Resource_WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:label "Serveur Web 01"@fr ;
    rdfs:comment "Virtual machine hosting the corporate customer portal."@en ;
    noria:resourceManagedBy foaf:Agent_AppDev ;
    noria:resourceHostName "web01.portal.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_CustomerPortal ;
    noria:clusterController noria:Resource_VMHost01 .

noria:Resource_DB01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:label "Serveur de Base de Données 01"@fr ;
    rdfs:comment "Virtual machine hosting the database for the customer portal."@en ;
    noria:resourceManagedBy foaf:Agent_AppDev ;
    noria:resourceHostName "db01.portal.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T11:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_CustomerPortal ;
    noria:clusterController noria:Resource_VMHost01 .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetIF_DNS01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetLink_DC_Core .

noria:NetIF_RouterCore01_Ge0_0_1
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigE 0/0/1"@en ;
    rdfs:comment "Internal uplink from Core Router to data center network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Gigabit Ethernet interface to internal DC network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:NetLink_DC_Core .

noria:NetIF_RouterCore01_Ge0_0_2
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigE 0/0/2"@en ;
    rdfs:comment "External uplink from Core Router to internet."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Gigabit Ethernet interface to external internet provider."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceConnects noria:NetLink_External .

noria:NetIF_VMHost01_Mgmt
    a noria:NetworkInterface ;
    rdfs:label "VMHost01 Management Interface"@en ;
    rdfs:comment "Management interface for the virtualization host."@en ;
    noria:networkInterfaceOf noria:Resource_VMHost01 ;
    noria:networkInterfaceDescription "Dedicated interface for ESXi management."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetLink_DC_Core .

# =============================================================================
# Network Links
# =============================================================================

noria:NetLink_DC_Core
    a noria:NetworkLink ;
    rdfs:label "Data Center Core Link"@en ;
    rdfs:comment "High-speed internal link connecting servers and core network equipment within the data center."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:networkLinkId "NL-DC-CORE-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2020-06-20T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore01 .

noria:NetLink_External
    a noria:NetworkLink ;
    rdfs:label "External Internet Link"@en ;
    rdfs:comment "Link providing internet access to the data center."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:networkLinkId "NL-EXT-001" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2019-11-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 .

# =============================================================================
# Applications
# =============================================================================

noria:App_CorpInternetAccess
    a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:label "Accès Internet d'Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity for all corporate users and services."@en ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "Internet Gateway Management"@en .

noria:App_CustomerPortal
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:label "Application Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CP-APP" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "CUSTPORTAL" ;
    noria:applicationType <kos/application/type/BusinessApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Self-Service Portal"@en .

noria:App_MonitoringSystem
    a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:label "Système de Supervision Centralisé"@fr ;
    rdfs:comment "Application for collecting, analyzing, and alerting on IT infrastructure metrics and logs."@en ;
    noria:applicationModelIdentifier "CMS-APP" ;
    noria:applicationNumericalIdentifier 3001 ;
    noria:applicationShortIdentifier "CMS" ;
    noria:applicationType <kos/application/type/ITSMTool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Monitoring and Alerting"@en .

# =============================================================================
# Application Modules
# =============================================================================

noria:AppMod_CorpInternetAccess_Prod
    a noria:ApplicationModule ;
    rdfs:label "Corporate Internet Access Production Module"@en ;
    rdfs:label "Module de Production Accès Internet d'Entreprise"@fr ;
    rdfs:comment "Production instance of the Corporate Internet Access application."@en ;
    noria:applicationModuleOf noria:App_CorpInternetAccess ;
    noria:applicationModuleName "CIA_PROD" ;
    noria:applicationModuleIdentifier "CIA-PROD-01" ;
    noria:applicationModuleAdministrationTeam org:OrgUnit_L2Support ;
    noria:applicationModuleSupportTeam org:OrgUnit_L1Support ;
    noria:applicationModuleHotlineGroup org:OrgUnit_Hotline ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:AppMod_CustomerPortal_Prod
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:label "Module de Production Portail Client"@fr ;
    rdfs:comment "Production instance of the Customer Portal application, directly serving end-users."@en ;
    noria:applicationModuleOf noria:App_CustomerPortal ;
    noria:applicationModuleName "CP_PROD" ;
    noria:applicationModuleIdentifier "CP-PROD-01" ;
    noria:applicationModuleAdministrationTeam org:OrgUnit_L2Support ;
    noria:applicationModuleAdministrationLeader foaf:Agent_AppDev ; # Assuming AppDev team leader
    noria:applicationModuleSupportTeam org:OrgUnit_L1Support ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:AppMod_CustomerPortal_Dev
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en ;
    rdfs:label "Module de Développement Portail Client"@fr ;
    rdfs:comment "Development instance of the Customer Portal application, used for testing and new feature implementation."@en ;
    noria:applicationModuleOf noria:App_CustomerPortal ;
    noria:applicationModuleName "CP_DEV" ;
    noria:applicationModuleIdentifier "CP-DEV-01" ;
    noria:applicationModuleAdministrationTeam foaf:Agent_AppDev ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> .

# =============================================================================
# Services
# =============================================================================

noria:Service_InternetConnectivity
    a noria:Service ;
    rdfs:label "Internet Connectivity Service"@en ;
    rdfs:label "Service de Connectivité Internet"@fr ;
    rdfs:comment "End-to-end service providing internet access to internal and external entities."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CorpInternetAccess_Prod .

noria:Service_CustomerFacing
    a noria:Service ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:label "Service Client"@fr ;
    rdfs:comment "Service directly consumed by external customers via the customer portal."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CustomerPortal_Prod .

# =============================================================================
# Event Records
# =============================================================================

noria:Event_DNSFailure
    a noria:EventRecord ;
    rdfs:label "DNS Service Failure Log"@en ;
    rdfs:comment "Log entry indicating a failure in the DNS service on DNS01."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "DNS service 'named' on dns01.corp.example.com is not responding."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_HighLoad
    a noria:EventRecord ;
    rdfs:label "Web Server High Load Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "CPU utilization on web01.portal.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_PortDown
    a noria:EventRecord ;
    rdfs:label "Router Port Down Log"@en ;
    rdfs:comment "Log entry indicating that a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T11:00:10Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "Interface GigE 0/0/1 on router-core-01 changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_ConfigChange
    a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Log entry detailing a configuration change applied to Core Router 01."@en ;
    noria:loggingTime "2024-04-19T15:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logOriginatingAgent foaf:Agent_NetworkOps ;
    noria:logText "Configuration changed by Network Operations Team: 'no shutdown interface GigE 0/0/1'."@en .

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TT_DNSOutage
    a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "Critical incident: Corporate DNS server is unreachable, causing widespread service disruption."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:Event_DNSFailure ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Unidentified software crash on DNS service."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_AdminTeam ;
    noria:troubleTicketRelatedService noria:App_CorpInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:App_CorpInternetAccess, noria:Service_InternetConnectivity .

noria:TT_PortalSlow
    a noria:TroubleTicket ;
    rdfs:label "Customer Portal Slow Performance"@en ;
    rdfs:label "Performances Lentes Portail Client"@fr ;
    rdfs:comment "Customers are reporting slow response times on the portal, impacting user experience."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
