# =============================================================================
# Change Requests
# =============================================================================

noria:CR_RouterUpgrade
    a noria:ChangeRequest ;
    rdfs:label "Core Router Software Upgrade"@en ;
    rdfs:label "Mise à Jour Logicielle Routeur Cœur"@fr ;
    rdfs:comment "Planned software upgrade for Core Router 01 to enhance security and performance."@en ;
    dcterms:created "2024-04-15T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-18T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_RouterCore01, noria:Service_InternetConnectivity ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkDeviceSoftwareUpgrade> ;
    noria:changeRequestInitiatorParty foaf:Agent_NetworkOps ;
    noria:changeRequestPilotParty foaf:Agent_NetworkOps ;
    noria:changeRequestActorParty foaf:Agent_ExternalVendor ;
    noria:changeRequestIsRegulated true .

noria:CR_PortalFeature
    a noria:ChangeRequest ;
    rdfs:label "Customer Portal New Feature Deployment"@en ;
    rdfs:label "Déploiement Nouvelle Fonctionnalité Portail Client"@fr ;
    rdfs:comment "Deployment of a new feature for the customer portal, requiring application and database updates."@en ;
    dcterms:created "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-16T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-26T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/Configuration> ;
    noria:changeRequestImpact noria:AppMod_CustomerPortal_Prod, noria:Resource_WebSrv01, noria:Resource_DB01 ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ; # 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty foaf:Agent_AppDev ;
    noria:changeRequestPilotParty foaf:Agent_AppDev ;
    noria:changeRequestActorParty foaf:Agent_AppDev ;
    noria:changeRequestIsRegulated false .

# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OpPlan_RouterRestart
    a noria:OperationPlan ;
    rdfs:label "Router Restart Procedure"@en ;
    rdfs:label "Procédure de Redémarrage du Routeur"@fr ;
    rdfs:comment "Standard operating procedure for restarting a network router in case of unresponsiveness."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterReachable ;
    noria:operationPlanPostCondition noria:PostCond_RouterUp .

noria:OpPlan_DBPatch
    a noria:OperationPlan ;
    rdfs:label "Database Patching Procedure"@en ;
    rdfs:label "Procédure de Patching Base de Données"@fr ;
    rdfs:comment "Procedure for applying security patches to database servers."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBBackupComplete ;
    noria:operationPlanPostCondition noria:PostCond_DBPerformanceOK .

noria:PreCond_RouterReachable
    a noria:ActionPreCondition ;
    rdfs:label "Router Reachable via Management Interface"@en ;
    rdfs:comment "Condition: The router must be reachable via its management IP address before attempting a restart."@en ;
    skos:example "Ping to 10.0.0.1 is successful."@en .

noria:PostCond_RouterUp
    a noria:ActionPostCondition ;
    rdfs:label "Router Operational and Interfaces Up"@en ;
    rdfs:comment "Expected outcome: Router is fully operational, and all critical interfaces are in 'up' state."@en ;
    skos:example "All network interfaces on router-core-01 show 'up' status."@en .

noria:PreCond_DBBackupComplete
    a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completed"@en ;
    rdfs:comment "Condition: A full backup of the database must be completed before applying patches."@en ;
    skos:example "Last successful backup timestamp is recent."@en .

noria:PostCond_DBPerformanceOK
    a noria:ActionPostCondition ;
    rdfs:label "Database Performance Normal"@en ;
    rdfs:comment "Expected outcome: Database performance metrics (CPU, I/O, query times) are within normal thresholds after patching."@en ;
    skos:example "Average query response time below 50ms."@en .

# =============================================================================
# Additional Connections for Density
# =============================================================================

# Link Event Records to Trouble Tickets via documentStatusHistory (as EventRecord is a DynamicElement)
noria:TT_DNSOutage noria:documentStatusHistory noria:Event_DNSFailure .
noria:TT_PortalSlow noria:documentStatusHistory noria:Event_HighLoad .
noria:TT_RouterPortDown noria:documentStatusHistory noria:Event_PortDown .

# Link Change Requests to Event Records (e.g., for audit logs of changes)
noria:CR_RouterUpgrade noria:documentStatusHistory noria:Event_ConfigChange .

# Link Application Modules to Resources they run on
noria:AppMod_CustomerPortal_Prod seas:subSystemOf noria:Resource_WebSrv01, noria:Resource_DB01 .
noria:AppMod_CustomerPortal_Dev seas:subSystemOf noria:Resource_WebSrv01 . # Assuming dev also runs on web01 for simplicity

# Link Agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_AdminTeam noria:agentManagesResource noria:Resource_DNS01 .
foaf:Agent_NetworkOps noria:agentManagesResource noria:Resource_RouterCore01, noria:Resource_VMHost01 .
foaf:Agent_AppDev noria:agentManagesResource noria:Resource_WebSrv01, noria:Resource_DB01 .

# Link Services to Application Modules (inverse of seas:subSystemOf)
noria:AppMod_CorpInternetAccess_Prod seas:subSystemOf noria:Service_InternetConnectivity .
noria:AppMod_CustomerPortal_Prod seas:subSystemOf noria:Service_CustomerFacing .

# Link Trouble Tickets to Operation Plans (as potential proposed repair actions)
noria:TT_RouterPortDown noria:troubleTicketCharacteristic noria:OpPlan_RouterRestart . # Using characteristic as a placeholder for "potential action"

# Link Event Records to proposed repair actions
noria:Event_PortDown noria:alarmProposedRepairAction noria:OpPlan_RouterRestart .

# Link Event Records to ProcedureExecutionContainer (TroubleTicket or TroubleTicketNote)
noria:Event_DNSFailure pep:member noria:TT_DNSOutage .
noria:Event_HighLoad pep:member noria:TT_PortalSlow .
noria:Event_PortDown pep:member noria:TT_RouterPortDown .
noria:Event_ConfigChange pep:member noria:CR_RouterUpgrade .

# Example of a TroubleTicketNote correlated execution (if a specific action was logged)
# For instance, if a restart command was logged as an EventRecord and linked to a TTNote
# noria:TTNote_DNSOutage_Diag noria:troubleTicketNoteCorrelatedExecution noria:Event_DNS_RestartAttempt .
# (This would require creating another EventRecord for the restart attempt)

# Adding more details to existing entities for density
noria:Resource_DNS01
    noria:elementDistinguishedName "dns01.corp.example.com" .

noria:App_CustomerPortal
    noria:functionalElementDistinguishedName "CUSTPORTAL" .

noria:TT_DNSOutage
    dcterms:identifier "TT-20240420-001" ;
    dcterms:title "DNS Server Outage Incident"@en ;
    dcterms:description "The primary corporate DNS server is completely down, affecting all internal services and internet access."@en ;
    dcterms:created "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CUST-REF-DNS-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-20240420-001" .

noria:CR_RouterUpgrade
    dcterms:identifier "CR-20240415-001" ;
    dcterms:title "Core Router Software Upgrade"@en ;
    dcterms:description "Upgrade of Cisco IOS-XE on router-core-01 to version 17.6.3 for security patches."@en ;
    dcterms:created "2024-04-15T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-18T14:00:00Z"^^xsd:dateTime ;
    noria:documentHRef "https://itsm.example.com/change/CR-20240415-001" .

# Example of a more complex relationship for a NetworkLink
noria:NetLink_DC_Core
    noria:networkLinkTerminationResource noria:Resource_DNS01, noria:Resource_RouterCore01, noria:Resource_VMHost01 .

# Example of a resource being part of multiple applications
noria:Resource_VMHost01
    noria:resourceForApplication noria:App_CustomerPortal, noria:App_MonitoringSystem . # Assuming monitoring system also runs on VMs

# Example of an application module having a support leader
noria:AppMod_CorpInternetAccess_Prod
    noria:applicationModuleSupportLeader foaf:Agent_NetworkOps . # Assuming a specific person from NetworkOps leads support

# Example of a CUid for an agent
<https://w3id.org/noria/cuid/jdoe>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_SecurityAnalyst .

foaf:Agent_SecurityAnalyst
    foaf:account <https://w3id.org/noria/cuid/jdoe> .

