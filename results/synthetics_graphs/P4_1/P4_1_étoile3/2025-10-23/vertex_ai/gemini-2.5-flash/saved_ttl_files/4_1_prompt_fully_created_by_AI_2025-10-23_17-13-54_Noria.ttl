# --- Operation Plans and Conditions ---
<https://w3id.org/noria/operationplan/RouterFailoverProcedure>
    a noria:OperationPlan ;
    rdfs:label "Router Failover Procedure"@en ;
    rdfs:label "Procédure de Basculement Routeur"@fr ;
    rdfs:comment "Standard operating procedure for initiating a router failover in case of primary link failure."@en ;
    skos:example "This procedure involves verifying link status, initiating a route change, and confirming traffic flow on the backup link."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/PrimaryLinkDown> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/TrafficRestored> .

<https://w3id.org/noria/actionprecondition/PrimaryLinkDown>
    a noria:ActionPreCondition ;
    rdfs:label "Primary Link Down"@en ;
    rdfs:comment "Condition: The primary network link is detected as down or unreachable."@en ;
    skos:example "Ping to primary gateway fails, BGP session down, interface operational status is 'down'."@en .

<https://w3id.org/noria/actionpostcondition/TrafficRestored>
    a noria:ActionPostCondition ;
    rdfs:label "Traffic Restored on Backup Link"@en ;
    rdfs:comment "Expected outcome: Network traffic is successfully routed through the backup link."@en ;
    skos:example "Ping to external services succeeds, traffic graphs show activity on backup interface, customer reports service restoration."@en .

<https://w3id.org/noria/operationplan/WebServerScalingProcedure>
    a noria:OperationPlan ;
    rdfs:label "Web Server Scaling Procedure"@en ;
    rdfs:label "Procédure de Mise à l'Échelle Serveur Web"@fr ;
    rdfs:comment "Procedure to dynamically scale up or down web server resources based on load."@en ;
    skos:example "This procedure details steps for adding CPU/memory or deploying new instances in a cloud environment."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/HighCPULoad> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/CPULoadNormalized> .

<https://w3id.org/noria/actionprecondition/HighCPULoad>
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Load Detected"@en ;
    rdfs:comment "Condition: CPU utilization on web servers consistently exceeds a predefined threshold."@en ;
    skos:example "Average CPU > 80% for 15 minutes."@en .

<https://w3id.org/noria/actionpostcondition/CPULoadNormalized>
    a noria:ActionPostCondition ;
    rdfs:label "CPU Load Normalized"@en ;
    rdfs:comment "Expected outcome: CPU utilization on web servers returns to normal operating levels."@en ;
    skos:example "Average CPU < 50% for 30 minutes after scaling action."@en .

