# --- Agents and Organizations ---
<https://w3id.org/noria/agent/ITOperationsTeam>
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:label "Équipe Opérations IT"@fr ;
    rdfs:comment "Team responsible for the overall IT infrastructure operations and incident response."@en ;
    skos:example "This team handles first-level support and monitoring for critical systems."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Contact via internal ticketing system for non-critical issues, direct phone for critical alerts."@en .

