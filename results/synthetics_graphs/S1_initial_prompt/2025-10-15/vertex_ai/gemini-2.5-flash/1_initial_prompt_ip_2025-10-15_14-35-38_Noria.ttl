# =============================================================================
# Location Information
# =============================================================================

ex:DataCenter_East a bot:Site ;
    rdfs:label "East Coast Data Center"@en ;
    rdfs:comment "Primary data center facility located on the East Coast, hosting critical production services."@en ;
    noria:siteId "DC-EAST-01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Way"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "USA"@en ;
    bot:containsZone ex:ServerRoom_A_East, ex:NetworkRoom_B_East .

ex:DataCenter_West a bot:Site ;
    rdfs:label "West Coast Data Center"@en ;
    rdfs:comment "Secondary data center facility located on the West Coast, used for disaster recovery and development environments."@en ;
    noria:siteId "DC-WEST-01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "456 Innovation Drive"@en ;
    noria:sitePrincipalAddressCityName "Siliconville"@en ;
    noria:sitePrincipalAddressPostalCode "90210"@en ;
    noria:sitePrincipalAddressCountry "USA"@en ;
    bot:containsZone ex:ServerRoom_C_West .

ex:ServerRoom_A_East a noria:Room ;
    rdfs:label "Server Room A (East DC)"@en ;
    rdfs:comment "A dedicated room within the East Coast Data Center for housing critical production servers."@en ;
    bot:containsZone ex:Rack_A1_U10_East, ex:Rack_A2_U15_East .

ex:NetworkRoom_B_East a noria:Room ;
    rdfs:label "Network Room B (East DC)"@en ;
    rdfs:comment "Room dedicated to core networking equipment in the East Coast Data Center."@en ;
    bot:containsZone ex:Rack_B1_U1_East .

ex:ServerRoom_C_West a noria:Room ;
    rdfs:label "Server Room C (West DC)"@en ;
    rdfs:comment "Room for development and staging servers in the West Coast Data Center."@en ;
    bot:containsZone ex:Rack_C1_U5_West .

ex:Rack_A1_U10_East a noria:Locus ;
    rdfs:label "Rack A1, Unit 10 (East DC)"@en ;
    rdfs:comment "Specific location within Server Room A, Rack A1, Unit 10, housing Webserver01."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "10"@en .

ex:Rack_A2_U15_East a noria:Locus ;
    rdfs:label "Rack A2, Unit 15 (East DC)"@en ;
    rdfs:comment "Specific location within Server Room A, Rack A2, Unit 15, housing DatabaseServer01."@en ;
    noria:locusLine "A2"@en ;
    noria:locusRow "15"@en .

ex:Rack_B1_U1_East a noria:Locus ;
    rdfs:label "Rack B1, Unit 1 (East DC)"@en ;
    rdfs:comment "Specific location within Network Room B, Rack B1, Unit 1, housing RouterCore01 and Firewall01."@en ;
    noria:locusLine "B1"@en ;
    noria:locusRow "1"@en .

ex:Rack_C1_U5_West a noria:Locus ;
    rdfs:label "Rack C1, Unit 5 (West DC)"@en ;
    rdfs:comment "Specific location within Server Room C, Rack C1, Unit 5, housing Dev Webserver."@en ;
    noria:locusLine "C1"@en ;
    noria:locusRow "5"@en .

