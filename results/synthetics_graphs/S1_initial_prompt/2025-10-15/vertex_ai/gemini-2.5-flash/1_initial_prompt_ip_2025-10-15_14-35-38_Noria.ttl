<https://w3id.org/noria/kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category KOS"@en ;
    rdfs:comment "Controlled vocabulary for categories of change requests."@en .

<https://w3id.org/noria/kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type KOS"@en ;
