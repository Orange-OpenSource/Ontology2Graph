    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/in-production> .

ex:E-commerceService a noria:Service ;
    rdfs:label "E-commerce Service"@en ;
    rdfs:comment "An end-to-end service providing online shopping capabilities, underpinned by the Customer Portal and related backend systems."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystem ex:CustomerPortalApp_Prod .

ex:InternalReportingService a noria:Service ;
