ex:TTN_CustomerPortalDown_Diagnosis a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket Note: Initial Diagnosis (Customer Portal)"@en ;
    rdfs:comment "Initial investigation revealed high CPU usage on webserver01 and webserver02. Suspected resource exhaustion or application bug. Initiated webserver restart procedure."@en ;
    dcterms:created "2024-04-23T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator ex:BobJohnson ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/internal> ;
