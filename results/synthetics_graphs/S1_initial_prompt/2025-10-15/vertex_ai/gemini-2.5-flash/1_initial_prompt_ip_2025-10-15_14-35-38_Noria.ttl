# =============================================================================
# Organizational Structure
# =============================================================================

ex:TechCorp a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "A leading technology company providing various digital services globally."@en ;
    org:hasUnit ex:NetOpsTeam, ex:AppSupportTeam, ex:SecurityTeam, ex:DevOpsTeam .

ex:NetOpsTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Responsible for managing and maintaining the company's global network infrastructure."@en ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri), on-call 24/7"@en ;
    noria:agentInstructions "Contact via ticketing system for critical issues, direct call for emergencies. Escalation matrix available on internal wiki."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/phone> .

ex:AppSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Provides Level 2 and Level 3 support for all business-critical applications."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentInstructions "Escalate via PagerDuty for P1/P2 incidents. Use Slack for general inquiries."@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/chat> .

ex:SecurityTeam a org:OrganizationalUnit ;
