<https://w3id.org/noria/kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency KOS"@en ;
    rdfs:comment "Controlled vocabulary for urgency levels of trouble tickets."@en .

<https://w3id.org/noria/kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category KOS"@en ;
