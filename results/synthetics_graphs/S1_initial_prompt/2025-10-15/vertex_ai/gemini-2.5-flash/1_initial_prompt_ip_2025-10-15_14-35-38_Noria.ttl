# =============================================================================
# SKOS Concept Schemes and Concepts for Controlled Vocabularies
# =============================================================================

<https://w3id.org/noria/kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type KOS"@en ;
    rdfs:comment "Controlled vocabulary for types of applications."@en .

