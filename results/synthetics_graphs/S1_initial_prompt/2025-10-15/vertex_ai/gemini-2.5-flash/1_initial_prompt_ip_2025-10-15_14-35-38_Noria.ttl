# =============================================================================
# Procedural Elements
# =============================================================================

ex:WebserverRestartProcedure a noria:OperationPlan ;
    rdfs:label "Webserver Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for safely restarting webserver instances in the production environment."@en ;
    noria:operationPlanPreCondition ex:PreCond_WebserverRestart_NoTraffic ;
    noria:operationPlanPostCondition ex:PostCond_WebserverRestart_ServiceUp .

ex:RouterFirmwareUpgradeProcedure a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed procedure for upgrading router firmware, including configuration backup, pre-checks, upgrade steps, and post-verification."@en ;
    noria:operationPlanPreCondition ex:PreCond_RouterUpgrade_Backup ;
    noria:operationPlanPostCondition ex:PostCond_RouterUpgrade_ConnectivityOK .

ex:IDSInvestigationProcedure a noria:OperationPlan ;
    rdfs:label "IDS Alert Investigation Procedure"@en ;
    rdfs:comment "Procedure for investigating and responding to alerts generated by the Intrusion Detection System."@en ;
    noria:operationPlanPreCondition ex:PreCond_IDSAlert_Context ;
    noria:operationPlanPostCondition ex:PostCond_IDSAlert_Resolution .

ex:PreCond_WebserverRestart_NoTraffic a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: No Active Traffic"@en ;
    rdfs:comment "Ensure no active user sessions or critical traffic is routed to the webserver before initiating a restart. This may involve draining connections from the load balancer."@en .

ex:PostCond_WebserverRestart_ServiceUp a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Web Service Up"@en ;
    rdfs:comment "Verify that the web service is accessible, responding correctly, and integrated with the load balancer after the restart."@en .

ex:PreCond_RouterUpgrade_Backup a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Configuration Backup"@en ;
    rdfs:comment "Ensure a full configuration backup of the router is performed and stored securely before starting the firmware upgrade."@en .

ex:PostCond_RouterUpgrade_ConnectivityOK a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Network Connectivity Verified"@en ;
    rdfs:comment "Verify end-to-end network connectivity through the router, including all critical services, after the firmware upgrade."@en .

ex:PreCond_IDSAlert_Context a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Gather Alert Context"@en ;
    rdfs:comment "Collect all available context for the IDS alert, including source/destination IPs, timestamps, and affected assets."@en .

ex:PostCond_IDSAlert_Resolution a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Alert Resolution"@en ;
    rdfs:comment "Ensure the IDS alert is either confirmed as a true positive and mitigated, or identified as a false positive and tuned."@en .

ex:HighCPULowThroughputPattern a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Throughput Anomaly Pattern"@en ;
    rdfs:comment "Describes a failure mode where a resource experiences persistently high CPU utilization but delivers disproportionately low network throughput, indicating a potential bottleneck, software bug, or misconfiguration."@en ;
    folio:hasCause "Software bug or misconfiguration leading to CPU spin-lock, inefficient code, or resource contention."@en .

ex:IDSFalsePositivePattern a noria:AnomalyPattern ;
    rdfs:label "IDS False Positive Pattern"@en ;
    rdfs:comment "Describes a pattern where the IDS generates alerts for legitimate traffic or expected behavior, leading to unnecessary investigations."@en ;
    folio:hasCause "Misconfigured IDS rules, outdated threat intelligence, or changes in application behavior not reflected in security policies."@en .
