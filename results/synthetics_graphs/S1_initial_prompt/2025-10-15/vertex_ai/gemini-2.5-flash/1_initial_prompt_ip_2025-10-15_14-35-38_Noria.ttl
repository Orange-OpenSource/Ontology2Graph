    dcterms:isPartOf ex:TT_CustomerPortalDown ;
    noria:troubleTicketNoteCorrelatedExecution ex:ER_Webserver_Restarted .

ex:TTN_IDSAlert_Investigation a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket Note: IDS Alert Investigation"@en ;
    rdfs:comment "Investigated IDS alert. Identified source IP as external. Blocked IP at firewall. No evidence of successful breach found. Monitoring logs for further activity."@en ;
    dcterms:created "2024-04-24T12:30:00Z"^^xsd:dateTime ;
    dcterms:creator ex:CarolWhite ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/diagnosis> ;
    dcterms:isPartOf ex:TT_IDSAlert .

