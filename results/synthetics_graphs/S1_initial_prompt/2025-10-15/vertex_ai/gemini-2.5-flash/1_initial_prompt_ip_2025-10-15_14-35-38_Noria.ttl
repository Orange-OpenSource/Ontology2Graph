    dcterms:isPartOf ex:TT_CustomerPortalDown .

ex:TTN_CustomerPortalDown_Resolution a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket Note: Resolution (Customer Portal)"@en ;
    rdfs:comment "Webserver01 and Webserver02 restarted. CPU usage normalized. Customer Portal service restored and verified. Monitoring for recurrence."@en ;
    dcterms:created "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    dcterms:creator ex:BobJohnson ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/internal> ;
