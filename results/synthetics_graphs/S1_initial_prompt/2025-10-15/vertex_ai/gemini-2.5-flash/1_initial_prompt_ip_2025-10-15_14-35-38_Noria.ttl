ex:ER_Webserver_CPU_High a noria:EventRecord ;
    rdfs:label "Event: Webserver CPU High Alert"@en ;
    rdfs:comment "Automated alert indicating high CPU utilization on webserver01, exceeding threshold."@en ;
    dcterms:identifier "ER-WS-CPU-20240423-001"@en ;
    noria:loggingTime "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on webserver01 exceeded 90% for 5 minutes. Current: 95%."@en ;
    noria:logOriginatingManagedObject ex:Webserver01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/Notification/Severity/PerceivedSeverity/critical> ;
    noria:alarmProposedRepairAction ex:WebserverRestartProcedure .

ex:ER_Router_Interface_Down a noria:EventRecord ;
