ex:CustomerPortalApp a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "The main web application for customer interaction, account management, and service requests."@en ;
    noria:applicationModelIdentifier "CPA-V2.0"@en ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CPA"@en ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Online Self-Service"@en .

ex:InventoryManagementApp a noria:Application ;
    rdfs:label "Inventory Management Application"@en ;
    rdfs:comment "Internal application for tracking and managing IT asset inventory."@en ;
    noria:applicationModelIdentifier "IMA-V1.5"@en ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "IMA"@en ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/internal-tool> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Resource Management"@en ;
    noria:applicationFunctionalSubDomain "Asset Tracking"@en .

ex:CustomerPortalApp_Prod a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "The production instance of the Customer Portal Application, serving live customer traffic."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CPA_PROD"@en ;
    noria:applicationModuleIdentifier "PROD-001"@en ;
    noria:applicationModuleAdministrationTeam ex:AppSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:BobJohnson ;
    noria:applicationModuleSupportTeam ex:AppSupportTeam ;
    noria:applicationModuleSupportLeader ex:BobJohnson ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/in-production> .

ex:CustomerPortalApp_Dev a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en ;
    rdfs:comment "The development instance of the Customer Portal Application, used for new feature development and testing."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CPA_DEV"@en ;
    noria:applicationModuleIdentifier "DEV-001"@en ;
    noria:applicationModuleAdministrationTeam ex:DevOpsTeam ;
    noria:applicationModuleAdministrationLeader ex:DavidGreen ;
    noria:applicationModuleSupportTeam ex:DevOpsTeam ;
    noria:applicationModuleSupportLeader ex:DavidGreen ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/gold> ;
    noria:applicationModuleSlaLevelDate "2023-03-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/development> .

ex:InventoryManagementApp_Prod a noria:ApplicationModule ;
    rdfs:label "Inventory Management Production Module"@en ;
    rdfs:comment "The production instance of the Inventory Management Application."@en ;
    noria:applicationModuleOf ex:InventoryManagementApp ;
    noria:applicationModuleName "IMA_PROD"@en ;
    noria:applicationModuleIdentifier "PROD-002"@en ;
    noria:applicationModuleAdministrationTeam ex:AppSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:BobJohnson ;
    noria:applicationModuleSupportTeam ex:AppSupportTeam ;
    noria:applicationModuleSupportLeader ex:BobJohnson ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/gold> ;
