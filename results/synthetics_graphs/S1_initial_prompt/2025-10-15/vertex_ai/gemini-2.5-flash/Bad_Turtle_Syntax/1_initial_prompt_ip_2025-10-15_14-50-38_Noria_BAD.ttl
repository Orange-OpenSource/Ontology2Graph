ex:CustomerDataService
    a noria:Service ;
    rdfs:label "Customer Data Access Service"@en ;
    rdfs:comment "An end-to-end service providing access to customer data, underpinned by the CRM system."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf ex:CRM_Prod_Module . # Service is composed of the CRM Production Module

# --- Dynamic Elements: Event Records ---

ex:Event_Server01_CPU_High
    a noria:EventRecord ;
    rdfs:label "Server01 CPU High Alert"@en ;
    rdfs:comment "An event record indicating high CPU utilization on Server01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on crmdb01.example.com exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject ex:Server01 ;
    noria:logOriginatingManagementSystem ex:Monitoring_Dashboard ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Warning> .

ex:Event_RouterA_LinkDown
    a noria:EventRecord ;
    rdfs:label "RouterA Link Down Alert"@en ;
    rdfs:comment "An event record indicating that a network link on RouterA went down."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1 on router-a.example.com changed state to down."^^xsd:string ;
    noria:logOriginatingManagedObject ex:RouterA ;
    noria:logOriginatingManagementSystem ex:Monitoring_Dashboard ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction ex:RouterA_Troubleshooting_Plan .

ex:Event_RouterA_LinkUp
    a noria:EventRecord ;
    rdfs:label "RouterA Link Up Notification"@en ;
    rdfs:comment "An event record indicating that a network link on RouterA came back up."@en ;
    noria:loggingTime "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1 on router-a.example.com changed state to up."^^xsd:string ;
    noria:logOriginatingManagedObject ex:RouterA ;
    noria:logOriginatingManagementSystem ex:Monitoring_Dashboard ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Warning> .

ex:Event_Alice_ConfigChange
    a noria:EventRecord ;
    rdfs:label "Alice's Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change performed by Alice Smith on RouterA."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Configuration changed on router-a.example.com by asmith: interface GigabitEthernet0/0/1 no shutdown."^^xsd:string ;
    noria:logOriginatingManagedObject ex:RouterA ;
    noria:logOriginatingAgent ex:AliceSmith ;
    noria:logOriginatingManagementSystem ex:NetworkOperationsTeam .

