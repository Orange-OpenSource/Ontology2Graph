# --- Procedural Elements ---

ex:RouterA_Troubleshooting_Plan
    a noria:OperationPlan ;
    rdfs:label "RouterA Link Troubleshooting Plan"@en ;
    rdfs:comment "A standard operating procedure for troubleshooting a down link on RouterA."@en ;
    noria:operationPlanPreCondition ex:RouterA_LinkDown_PreCond ;
    noria:operationPlanPostCondition ex:RouterA_LinkUp_PostCond .

ex:CRM_Database_Backup_Plan
    a noria:OperationPlan ;
    rdfs:label "CRM Database Daily Backup Plan"@en ;
    rdfs:comment "A scheduled operation plan for daily backup of the CRM database."@en ;
    noria:operationPlanPreCondition ex:CRM_DB_Healthy_PreCond ;
    noria:operationPlanPostCondition ex:CRM_DB_Backup_Complete_PostCond .

ex:RouterA_LinkDown_PreCond
    a noria:ActionPreCondition ;
    rdfs:label "RouterA Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: RouterA GigabitEthernet 0/0/1 is in operational 'down' state."@en .

ex:RouterA_LinkUp_PostCond
    a noria:ActionPostCondition ;
    rdfs:label "RouterA Link Up Post-Condition"@en ;
    rdfs:comment "Outcome: RouterA GigabitEthernet 0/0/1 is in operational 'up' state and traffic is flowing."@en .

ex:CRM_DB_Healthy_PreCond
    a noria:ActionPreCondition ;
    rdfs:label "CRM Database Healthy Pre-Condition"@en ;
    rdfs:comment "Condition: CRM database server is operational and database integrity checks pass."@en .

ex:CRM_DB_Backup_Complete_PostCond
    a noria:ActionPostCondition ;
    rdfs:label "CRM Database Backup Complete Post-Condition"@en ;
    rdfs:comment "Outcome: CRM database backup successfully completed and verified."@en .

# --- Anomaly Pattern ---

ex:LinkFlapAnomaly
    a noria:AnomalyPattern ;
    rdfs:label "Network Link Flap Anomaly Pattern"@en ;
    rdfs:comment "Describes a pattern of frequent up/down transitions on a network link, indicating instability."@en ;
    folio:hasCause "Faulty transceiver or cable"^^xsd:string ;
    folio:hasEffect "Intermittent service disruption"^^xsd:string .

