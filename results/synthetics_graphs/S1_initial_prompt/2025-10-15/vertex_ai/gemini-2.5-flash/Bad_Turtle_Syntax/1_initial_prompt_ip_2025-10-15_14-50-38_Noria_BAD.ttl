# =============================================================================
# Knowledge Graph Instances based on NORIA Schema
# =============================================================================

# --- SKOS Concepts for Controlled Vocabularies ---
# These concepts are used as ranges for various noria properties.
# They are defined here to ensure they exist for the graph.

<kos/application/type/CRM>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "CRM Application Type"@en ;
    rdfs:comment "Represents a Customer Relationship Management application type."@en .

<kos/application/type/Monitoring>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring Application Type"@en ;
    rdfs:comment "Represents a system monitoring application type."@en .

<kos/application/business-importance/High>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Indicates an application with high business importance."@en .

<kos/application/business-importance/Medium>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Indicates an application with medium business importance."@en .

<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly exposed to and consumed by customers."@en .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that manages resources and is not directly exposed to customers."@en .

<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Indicates a critical incident severity, requiring immediate attention."@en .

<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Indicates a major incident severity, impacting significant services."@en .

<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure Ticket Type"@en ;
    rdfs:comment "A trouble ticket type indicating a system or service failure."@en .

<kos/TroubleTicket/status/InProgress>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress Status"@en ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

<kos/TroubleTicket/status/Resolved>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved Status"@en ;
    rdfs:comment "The issue described in the trouble ticket has been resolved."@en .

<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "The trouble ticket was initiated by a customer."@en .

<kos/TroubleTicket/origin/Supervision>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision Origin"@en ;
    rdfs:comment "The trouble ticket was initiated by a monitoring or supervision system."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention Urgency"@en ;
    rdfs:comment "Indicates that immediate intervention is required for the trouble ticket."@en .

<kos/TroubleTicket/trouble-category/TotalBreakdown>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Total Breakdown Category"@en ;
    rdfs:comment "Category for incidents involving a complete system or service breakdown."@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks Responsibility"@en ;
    rdfs:comment "Responsibility for the problem lies with the team managing backbone networks."@en .

<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment Type"@en ;
    rdfs:comment "A comment intended for internal team use."@en .

<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation Type"@en ;
    rdfs:comment "Operation type related to diagnosing an issue."@en .

<kos/ChangeRequest/type/Standard>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change Type"@en ;
    rdfs:comment "A pre-approved change with low risk and impact."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade Cause"@en ;
    rdfs:comment "The change is caused by a planned software upgrade."@en .

<kos/ChangeRequest/status/Approved>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved Status"@en ;
    rdfs:comment "The change request has been approved and is ready for scheduling."@en .

<kos/Resource/OperationalState/Up>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Operational State Up"@en ;
    rdfs:comment "Indicates a resource is fully operational."@en .

<kos/Resource/OperationalState/Down>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Operational State Down"@en ;
    rdfs:comment "Indicates a resource is not operational."@en .

<kos/Resource/AdministrativeState/Up>
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative State Up"@en ;
    rdfs:comment "Indicates a resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Down>
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative State Down"@en ;
    rdfs:comment "Indicates a resource is administratively disabled."@en .

<kos/Resource/type/Server>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server Resource Type"@en ;
    rdfs:comment "A resource classified as a server."@en .

<kos/Resource/type/Router>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router Resource Type"@en ;
    rdfs:comment "A resource classified as a network router."@en .

<kos/Resource/type/Switch>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Switch Resource Type"@en ;
    rdfs:comment "A resource classified as a network switch."@en .

<kos/Resource/LifecycleState/InProduction>
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Production Lifecycle State"@en ;
    rdfs:comment "The resource is currently in active production use."@en .

<kos/Notification/Severity/PerceivedSeverity/Critical>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Perceived Severity"@en ;
    rdfs:comment "A perceived severity level indicating a critical condition."@en .

<kos/Notification/Severity/PerceivedSeverity/Warning>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning Perceived Severity"@en ;
    rdfs:comment "A perceived severity level indicating a warning condition."@en .

<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email Contact Method"@en ;
    rdfs:comment "Preferred contact method via email."@en .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone Contact Method"@en ;
    rdfs:comment "Preferred contact method via phone."@en .

# --- Organizational Structure ---

ex:OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company."@en ;
    org:hasUnit ex:NetworkOperationsTeam, ex:ApplicationSupportTeam .

ex:NetworkOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the network infrastructure."@en ;
    org:unitOf ex:OrangeTelecom ;
    org:hasMember ex:AliceSmith ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical network issues, call the hotline. For non-critical, use ticketing system."^^xsd:string .

ex:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    org:unitOf ex:OrangeTelecom ;
    org:hasMember ex:BobJohnson ;
    noria:agentWorkingHours "8:30 AM - 4:30 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit all application issues via the CRM ticketing system."^^xsd:string .

ex:AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer in the Network Operations Team."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+33123456789" ;
    foaf:holdsAccount ex:AliceCUid .

ex:BobJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Specialist in the Application Support Team."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+33987654321" ;
    foaf:holdsAccount ex:BobCUid .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "asmith-corp-id-12345"^^xsd:string .

ex:BobCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "bjohnson-corp-id-67890"^^xsd:string .

# --- Locations ---

ex:DataCenterParis
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    bot:containsZone ex:ServerRoomA .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSubSpace ex:Rack1_Locus .

ex:Rack1_Locus
    a noria:Locus ;
    rdfs:label "Rack 1 Locus"@en ;
    rdfs:comment "Specific location for Rack 1 within Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

# --- Resources ---

ex:HP_ProLiant_DL380
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380"@en ;
    rdfs:comment "Product model for a common server."@en ;
    noria:productManufacturedBy ex:HPE_Organization .

ex:Cisco_Catalyst_9300
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Product model for a network switch."@en ;
    noria:productManufacturedBy ex:Cisco_Organization .

ex:Cisco_ASR_1000
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000"@en ;
    rdfs:comment "Product model for a network router."@en ;
    noria:productManufacturedBy ex:Cisco_Organization .

ex:HPE_Organization
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

ex:Cisco_Organization
    a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

ex:Server01
    a noria:Resource ;
    rdfs:label "CRM Database Server 01"@en ;
    rdfs:comment "A server hosting the CRM database."@en ;
    noria:resourceHostName "crmdb01.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-SRV-001"^^xsd:string ;
    noria:resourceProductModel ex:HP_ProLiant_DL380 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-SRV-001-XYZ"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:ApplicationSupportTeam ;
    noria:locatedAtLocus ex:Rack1_Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> ;
    noria:resourceForApplication ex:CRM_System .

ex:RouterA
    a noria:Resource ;
    rdfs:label "Core Router A"@en ;
    rdfs:comment "A core network router in the data center."@en ;
    noria:resourceHostName "router-a.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceProductModel ex:Cisco_ASR_1000 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:locatedAtLocus ex:Rack1_Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> ;
    noria:clusterController ex:RouterB . # Example of cluster controller

ex:RouterB
    a noria:Resource ;
    rdfs:label "Core Router B"@en ;
    rdfs:comment "A core network router in the data center, acting as a cluster controller for Router A."@en ;
    noria:resourceHostName "router-b.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-RTR-002"^^xsd:string ;
    noria:resourceProductModel ex:Cisco_ASR_1000 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-002-DEF"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-20T14:35:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:locatedAtLocus ex:Rack1_Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.2> .

ex:SwitchC
    a noria:Resource ;
    rdfs:label "Access Switch C"@en ;
    rdfs:comment "An access layer network switch."@en ;
    noria:resourceHostName "switch-c.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-SWT-001"^^xsd:string ;
    noria:resourceProductModel ex:Cisco_Catalyst_9300 ;
    noria:resourceType <kos/Resource/type/Switch> ;
    noria:resourceSerialNumber "SN-SWT-001-GHI"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:locatedAtLocus ex:Rack1_Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.100> .

# --- Network Interfaces and Links ---

ex:Server01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "Server01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface for Server01."@en ;
    noria:networkInterfaceOf ex:Server01 ;
    noria:networkInterfaceDescription "Main network interface for CRM database access."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

ex:RouterA_GE0_0_1
    a noria:NetworkInterface ;
    rdfs:label "RouterA GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface on RouterA, connecting to SwitchC."@en ;
    noria:networkInterfaceOf ex:RouterA ;
    noria:networkInterfaceDescription "Uplink to access switch C."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower -3^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower -5^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -4^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10^^xsd:int .

ex:SwitchC_GE1_0_1
    a noria:NetworkInterface ;
    rdfs:label "SwitchC GigabitEthernet 1/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface on SwitchC, connecting to RouterA."@en ;
    noria:networkInterfaceOf ex:SwitchC ;
    noria:networkInterfaceDescription "Downlink from core router A."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

ex:Link_RouterA_SwitchC
    a noria:NetworkLink ;
    rdfs:label "Link between RouterA and SwitchC"@en ;
    rdfs:comment "A physical network link connecting RouterA's GE0/0/1 to SwitchC's GE1/0/1."@en ;
    noria:networkLinkId "NL-RTR-SWT-001"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin ex:RouterA ;
    noria:networkLinkTerminationResourceDestination ex:SwitchC ;
    noria:networkLinkInstallationDate "2023-05-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:networkInterfaceConnects ex:RouterA_GE0_0_1, ex:SwitchC_GE1_0_1 .

# --- Applications and Services ---

ex:CRM_System
    a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:comment "The primary application for managing customer interactions."@en ;
    noria:applicationModelIdentifier "CRM-APP-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001^^xsd:int ;
    noria:applicationShortIdentifier "CRM"^^xsd:string ;
    noria:applicationType <kos/application/type/CRM> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Sales and Marketing"^^xsd:string ;
    noria:elementManagedBy ex:ApplicationSupportTeam .

ex:Monitoring_Dashboard
    a noria:Application ;
    rdfs:label "Network Monitoring Dashboard"@en ;
    rdfs:comment "Application for visualizing network health and performance."@en ;
    noria:applicationModelIdentifier "NMD-APP-V1"^^xsd:string ;
