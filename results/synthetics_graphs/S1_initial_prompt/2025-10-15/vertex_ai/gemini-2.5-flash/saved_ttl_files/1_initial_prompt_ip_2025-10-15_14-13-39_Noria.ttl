ex:MajorChange
    a skos:Concept ;
    skos:inScheme ex:ChangeRequestTypeScheme ;
    rdfs:label "Major"@en ;
    rdfs:comment "High-risk, complex change requiring extensive approval."@en .

ex:ChangeRequestSpecificationScheme
    a skos:ConceptScheme ;
    dcterms:title "Change Request Specification Scheme"@en ;
