ex:InternalComment
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketCommentTypeScheme ;
    rdfs:label "Internal"@en ;
    rdfs:comment "Comment intended for internal team members."@en .

ex:CustomerFacingComment
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketCommentTypeScheme ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Comment visible to the customer."@en .

ex:TroubleTicketOperationTypeScheme
    a skos:ConceptScheme ;
