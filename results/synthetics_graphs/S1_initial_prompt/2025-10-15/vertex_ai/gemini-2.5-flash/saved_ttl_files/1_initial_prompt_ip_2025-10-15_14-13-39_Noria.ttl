# =============================================================================
# SKOS Concept Schemes and Concepts (for controlled vocabularies)
# =============================================================================

ex:ApplicationTypeScheme
    a skos:ConceptScheme ;
    dcterms:title "Application Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for types of applications."@en .

ex:WebApplication
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Web Application"@en ;
    rdfs:comment "An application accessible via a web browser."@en .

ex:DatabaseApplication
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Database Application"@en ;
    rdfs:comment "An application primarily managing data storage and retrieval."@en .

ex:MonitoringApplication
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "An application used for system and network monitoring."@en .

ex:ApplicationBusinessImportanceScheme
    a skos:ConceptScheme ;
    dcterms:title "Application Business Importance Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the business importance of applications."@en .

ex:CriticalImportance
    a skos:Concept ;
    skos:inScheme ex:ApplicationBusinessImportanceScheme ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for core business operations."@en .

ex:HighImportance
    a skos:Concept ;
    skos:inScheme ex:ApplicationBusinessImportanceScheme ;
    rdfs:label "High"@en ;
    rdfs:comment "Application is important but not immediately critical."@en .

ex:MediumImportance
    a skos:Concept ;
    skos:inScheme ex:ApplicationBusinessImportanceScheme ;
    rdfs:label "Medium"@en ;
    rdfs:comment "Application has moderate business impact."@en .

ex:TroubleTicketSeverityScheme
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket severity levels."@en .

ex:SeverityCritical
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketSeverityScheme ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Service completely down or major business impact."@en .

ex:SeverityMajor
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketSeverityScheme ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant service degradation or partial outage."@en .

ex:TroubleTicketTypeScheme
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for types of trouble tickets."@en .

ex:FailureType
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketTypeScheme ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Indicates a system or service failure."@en .

ex:PerformanceIssueType
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketTypeScheme ;
    rdfs:label "Performance Issue"@en ;
    rdfs:comment "Indicates a performance degradation."@en .

ex:TroubleTicketStatusScheme
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for trouble ticket statuses."@en .

ex:StatusInProgress
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketStatusScheme ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Ticket is currently being worked on."@en .

ex:StatusResolved
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketStatusScheme ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "Issue has been resolved."@en .

ex:ChangeRequestStatusScheme
    a skos:ConceptScheme ;
    dcterms:title "Change Request Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for change request statuses."@en .

ex:CRStatusApproved
    a skos:Concept ;
    skos:inScheme ex:ChangeRequestStatusScheme ;
    rdfs:label "Approved"@en ;
    rdfs:comment "Change request has been approved for implementation."@en .

ex:CRStatusImplemented
    a skos:Concept ;
    skos:inScheme ex:ChangeRequestStatusScheme ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "Change request has been successfully implemented."@en .

ex:ResourceTypeScheme
    a skos:ConceptScheme ;
    dcterms:title "Resource Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for types of IT resources."@en .

ex:RouterType
    a skos:Concept ;
    skos:inScheme ex:ResourceTypeScheme ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network device that forwards data packets between computer networks."@en .

ex:ServerType
    a skos:Concept ;
    skos:inScheme ex:ResourceTypeScheme ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computer program or a device that provides functionality for other programs or devices."@en .

ex:SwitchType
    a skos:Concept ;
    skos:inScheme ex:ResourceTypeScheme ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network device that connects devices in a computer network."@en .

ex:OperationalStateScheme
    a skos:ConceptScheme ;
    dcterms:title "Operational State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for operational states of resources/interfaces."@en .

ex:OperationalStateUp
    a skos:Concept ;
    skos:inScheme ex:OperationalStateScheme ;
    rdfs:label "Up"@en ;
    rdfs:comment "The entity is operational and functioning."@en .

ex:OperationalStateDown
    a skos:Concept ;
    skos:inScheme ex:OperationalStateScheme ;
    rdfs:label "Down"@en ;
    rdfs:comment "The entity is not operational or functioning."@en .

ex:AdministrativeStateScheme
    a skos:ConceptScheme ;
    dcterms:title "Administrative State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for administrative states of resources/interfaces."@en .

ex:AdministrativeStateUp
    a skos:Concept ;
    skos:inScheme ex:AdministrativeStateScheme ;
    rdfs:label "Up"@en ;
    rdfs:comment "The entity is administratively enabled."@en .

ex:AdministrativeStateDown
    a skos:Concept ;
    skos:inScheme ex:AdministrativeStateScheme ;
    rdfs:label "Down"@en ;
    rdfs:comment "The entity is administratively disabled."@en .

ex:ServiceTypeScheme
    a skos:ConceptScheme ;
    dcterms:title "Service Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for types of services."@en .

ex:CustomerFacingService
    a skos:Concept ;
    skos:inScheme ex:ServiceTypeScheme ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by customers."@en .

ex:ResourceFacingService
    a skos:Concept ;
    skos:inScheme ex:ServiceTypeScheme ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations."@en .

ex:AgentContactMethodScheme
    a skos:ConceptScheme ;
    dcterms:title "Agent Contact Method Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

ex:EmailContact
    a skos:Concept ;
    skos:inScheme ex:AgentContactMethodScheme ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

ex:PhoneContact
    a skos:Concept ;
    skos:inScheme ex:AgentContactMethodScheme ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

ex:TroubleTicketOriginScheme
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the origin of trouble tickets."@en .

ex:CustomerOrigin
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketOriginScheme ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Ticket originated from a customer report."@en .

ex:MonitoringSystemOrigin
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketOriginScheme ;
    rdfs:label "Monitoring System"@en ;
    rdfs:comment "Ticket originated from an automated monitoring system alert."@en .

ex:ChangeRequestCauseScheme
    a skos:ConceptScheme ;
    dcterms:title "Change Request Cause Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the cause of change requests."@en .

ex:SoftwareUpgradeCause
    a skos:Concept ;
    skos:inScheme ex:ChangeRequestCauseScheme ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change requested due to a software upgrade."@en .

ex:ConfigurationChangeCause
    a skos:Concept ;
    skos:inScheme ex:ChangeRequestCauseScheme ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change requested for configuration modification."@en .

ex:TroubleTicketCategoryScheme
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Category Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the category of trouble tickets."@en .

ex:NetworkOutage
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketCategoryScheme ;
    rdfs:label "Network Outage"@en ;
    rdfs:comment "Category for incidents involving network connectivity loss."@en .

ex:ApplicationCrash
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketCategoryScheme ;
    rdfs:label "Application Crash"@en ;
    rdfs:comment "Category for incidents involving application failures."@en .

ex:TroubleTicketPriorityScheme
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the priority of trouble tickets."@en .

ex:P1Priority
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketPriorityScheme ;
    rdfs:label "P1 - Critical"@en ;
    rdfs:comment "Highest priority, immediate attention required."@en .

ex:P2Priority
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketPriorityScheme ;
    rdfs:label "P2 - High"@en ;
    rdfs:comment "High priority, significant impact, requires prompt attention."@en .

ex:TroubleTicketUrgencyScheme
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the urgency of trouble tickets."@en .

ex:ImmediateIntervention
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketUrgencyScheme ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Urgency requiring immediate action."@en .

ex:DeferredIntervention
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketUrgencyScheme ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Urgency allowing for delayed action."@en .

ex:TroubleTicketProblemResponsibilityScheme
    a skos:ConceptScheme ;
