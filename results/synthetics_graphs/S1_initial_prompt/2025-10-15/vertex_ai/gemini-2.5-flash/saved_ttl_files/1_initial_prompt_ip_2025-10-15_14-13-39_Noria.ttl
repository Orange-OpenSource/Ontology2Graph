# =============================================================================
# Organization and Agents
# =============================================================================

ex:OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company."@en ;
    org:hasUnit ex:NetworkOperationsTeam, ex:ApplicationSupportTeam .

ex:NetworkOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf ex:OrangeTelecom ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod ex:PhoneContact ;
    noria:agentInstructions "For critical issues, call the hotline. For non-critical, use ticketing system."@en .

ex:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    org:unitOf ex:OrangeTelecom ;
    noria:agentWorkingHours "8:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod ex:EmailContact ;
    noria:agentInstructions "Submit a ticket via the internal portal for all requests."@en .

ex:AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer in the Network Operations Team."@en ;
    org:memberOf ex:NetworkOperationsTeam ;
    foaf:holdsAccount ex:AliceCUid ;
    noria:agentManagesResource ex:CoreRouter01, ex:AccessSwitch01 .

ex:BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead Developer for the CRM System."@en ;
    org:memberOf ex:ApplicationSupportTeam ;
    foaf:holdsAccount ex:BobCUid ;
    noria:agentManagesResource ex:AppServer01 .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within the organization's IT systems."@en ;
    foaf:accountName "asmith" ;
    observable:accountLogin "asmith" ;
    observable:accountIdentifier "asmith-corp-id-12345" .

ex:BobCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Bob Johnson within the organization's IT systems."@en ;
    foaf:accountName "bjohnson" ;
    observable:accountLogin "bjohnson" ;
    observable:accountIdentifier "bjohnson-corp-id-67890" .

# =============================================================================
# Locations
# =============================================================================

ex:DataCenterA
    a bot:Site ;
    rdfs:label "Main Data Center A"@en ;
    rdfs:comment "Primary data center facility for Orange Telecom."@en ;
    noria:siteId "DCA-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" ;
    noria:sitePrincipalAddressStreet "Tech Avenue" ;
    bot:containsZone ex:ServerRoom1 .

ex:ServerRoom1
    a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "A dedicated room within Data Center A for housing servers and network equipment."@en ;
    bot:hasSpace ex:Rack1Locus .

ex:Rack1Locus
    a noria:Locus ;
    rdfs:label "Rack 1 in Server Room 1"@en ;
    rdfs:comment "Specific location of Rack 1 within Server Room 1."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

# =============================================================================
# Resources and Product Models
# =============================================================================

ex:CiscoNexus9K_Model
    a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Product model for Cisco Nexus 9000 series switches."@en ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:DellPowerEdgeR740_Model
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Product model for Dell PowerEdge R740 servers."@en ;
    noria:productManufacturedBy ex:DellTechnologies .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

ex:DellTechnologies
    a org:Organization ;
    rdfs:label "Dell Technologies Inc."@en ;
    rdfs:comment "Manufacturer of computer hardware and software."@en .

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router in Data Center A."@en ;
    noria:resourceLogisticId "CR01-DCA-01" ;
    noria:resourceHostName "core-router-01.dca.example.com" ;
    noria:resourceProductModel ex:CiscoNexus9K_Model ;
    noria:resourceType ex:RouterType ;
    noria:resourceSerialNumber "ABC123XYZ" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState#InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack1Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:clusterController ex:NetworkController01 .

ex:AppServer01
    a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting the CRM application module."@en ;
    noria:resourceLogisticId "AS01-DCA-01" ;
    noria:resourceHostName "app-server-01.dca.example.com" ;
    noria:resourceProductModel ex:DellPowerEdgeR740_Model ;
    noria:resourceType ex:ServerType ;
    noria:resourceSerialNumber "DEF456UVW" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState#InProduction> ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack1Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> ;
    noria:resourceManagedBy ex:ApplicationSupportTeam ;
    noria:resourceForApplication ex:CRMSystem_Prod ;
    noria:virtualServerStatus ex:OperationalStateUp .

ex:NetworkController01
    a noria:Resource ;
    rdfs:label "Network Controller 01"@en ;
    rdfs:comment "Centralized controller for network devices."@en ;
    noria:resourceHostName "net-controller-01.dca.example.com" ;
    noria:resourceType ex:ServerType ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:resourceForApplication ex:MonitoringPlatform .

# =============================================================================
# Network Interfaces and Links
# =============================================================================

ex:CoreRouter01_Eth0_1
    a noria:NetworkInterface ;
    rdfs:label "Core Router 01 Ethernet 0/1"@en ;
    rdfs:comment "Ethernet interface 0/1 on Core Router 01."@en ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
