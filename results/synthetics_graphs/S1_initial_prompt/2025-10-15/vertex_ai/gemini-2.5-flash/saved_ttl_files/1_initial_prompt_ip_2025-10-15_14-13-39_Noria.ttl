    noria:troubleTicketNoteOperationType ex:ResolutionOperation ;
    dcterms:isPartOf ex:TT_20240315_001 ;
    noria:troubleTicketNoteCorrelatedExecution ex:CorrectiveAction_InterfaceBounce .

