ex:ChangeRequestTypeScheme
    a skos:ConceptScheme ;
    dcterms:title "Change Request Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for types of change requests."@en .

ex:StandardChange
    a skos:Concept ;
    skos:inScheme ex:ChangeRequestTypeScheme ;
