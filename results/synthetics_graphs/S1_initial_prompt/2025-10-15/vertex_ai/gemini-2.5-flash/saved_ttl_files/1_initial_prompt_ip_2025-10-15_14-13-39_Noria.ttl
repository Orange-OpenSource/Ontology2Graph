    rdfs:comment "Responsibility lies with the team managing backbone network infrastructure."@en .

ex:CustomerResponsibility
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketProblemResponsibilityScheme ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Responsibility lies with the customer."@en .

ex:TroubleTicketCommentTypeScheme
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Comment Type Scheme"@en ;
