ex:ChangeRequestCategoryScheme
    a skos:ConceptScheme ;
    dcterms:title "Change Request Category Scheme"@en ;
    rdfs:comment "A controlled vocabulary for categories of change requests."@en .

ex:InternalIntervention
    a skos:Concept ;
