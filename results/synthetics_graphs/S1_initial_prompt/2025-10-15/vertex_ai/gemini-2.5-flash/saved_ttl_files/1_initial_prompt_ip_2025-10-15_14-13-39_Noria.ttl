# Corrective Maintenance Action (as an EventRecord which is a pep:ProcedureExecution)
ex:CorrectiveAction_InterfaceBounce
    a noria:EventRecord, pep:ProcedureExecution ;
    rdfs:label "Corrective Action: Interface Bounce on Core Router 01"@en ;
    rdfs:comment "An event recording the execution of a corrective action (interface bounce) on Core Router 01, related to TT-20240315-001."@en ;
    noria:loggingTime "2024-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Executed 'shutdown' then 'no shutdown' on GigabitEthernet0/0/1 of core-router-01." ;
    noria:logOriginatingManagedObject ex:CoreRouter01_Eth0_1 ;
    noria:logOriginatingAgent ex:AliceSmith ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    dcterms:type ex:CorrectiveAction ;
    pep:usedProcedure ex:RouterRestartProcedure ; # Links the execution to the plan
    dcterms:isPartOf ex:TT_20240315_001 . # This event is part of the TT's execution context

ex:TT_20240315_001_Note2
    a noria:TroubleTicketNote ;
    rdfs:label "Resolution Note for TT-20240315-001"@en ;
    rdfs:comment "Note detailing the resolution for the CRM outage, including the corrective action taken."@en ;
