# --- Operation Plans and Conditions ---

ex:RestartWebServerProcedure
    a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "A standard operating procedure for restarting the web server in case of unresponsiveness."@en ;
    noria:operationPlanPreCondition ex:WebServerUnresponsiveCondition ;
    noria:operationPlanPostCondition ex:WebServerResponsiveCondition .

ex:WebServerUnresponsiveCondition
    a noria:ActionPreCondition ;
    rdfs:label "Web Server Unresponsive"@en ;
    rdfs:comment "Condition indicating that the web server is not responding to requests."@en .

ex:WebServerResponsiveCondition
    a noria:ActionPostCondition ;
    rdfs:label "Web Server Responsive"@en ;
    rdfs:comment "Condition indicating that the web server is responding to requests after an action."@en .

ex:CustomerPortalUpgradePlan
    a noria:OperationPlan ;
    rdfs:label "Customer Portal Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for upgrading the Customer Portal application to a new version."@en ;
    noria:operationPlanPreCondition ex:BackupCompleteCondition ;
    noria:operationPlanPostCondition ex:NewVersionActiveCondition .

ex:BackupCompleteCondition
    a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete"@en ;
    rdfs:comment "Ensures a full backup of the database is completed before proceeding with the upgrade."@en .

ex:NewVersionActiveCondition
    a noria:ActionPostCondition ;
    rdfs:label "New Version Active and Functional"@en ;
    rdfs:comment "Confirms that the new version of the Customer Portal is deployed, active, and all functionalities are verified."@en .

