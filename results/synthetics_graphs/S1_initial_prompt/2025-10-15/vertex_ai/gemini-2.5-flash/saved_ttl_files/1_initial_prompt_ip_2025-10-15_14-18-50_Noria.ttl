    dcterms:created "2024-04-23T14:35:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CUST-INC-9876" ;
    noria:documentHRef <http://itsm.techcorp.com/tickets/TT-20240423-001> ;
    noria:troubleTicketSeverity ex:MajorSeverity ; # Example SKOS Concept
    noria:troubleTicketType ex:FailureTicketType ; # Example SKOS Concept
    noria:troubleTicketCriticity ex:InterruptedServiceCriticity ; # Example SKOS Concept
    noria:troubleTicketPriority ex:P1Priority ; # Example SKOS Concept
    noria:troubleTicketOrigin ex:SupervisionOrigin ; # Example SKOS Concept
    noria:troubleTicketTrigger ex:WebServerDownEvent ;
    noria:troubleTicketUrgency ex:ImmediateInterventionUrgency ; # Example SKOS Concept
    noria:troubleTicketSupervisionTool "Zabbix" ;
    noria:troubleTicketCategory ex:TotalBreakdownCategory ; # Example SKOS Concept
    noria:troubleTicketCause "High CPU load leading to service crash." ;
    noria:troubleTicketDetectionDateTime "2024-04-23T14:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T16:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent ex:InProgressStatus ; # Example SKOS Concept
    noria:troubleTicketRelatedParty ex:ITOperationsTeam ;
    noria:troubleTicketRelatedResource ex:WebServer01 ;
    noria:troubleTicketRelatedService ex:WebAccessService ;
    noria:troubleTicketImpacts ex:CustomerPortalProdModule .

