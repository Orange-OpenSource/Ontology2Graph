# --- Organizational Structure ---

ex:TechCorpSolutions
    a org:Organization ;
    rdfs:label "TechCorp Solutions Inc."@en ;
    rdfs:comment "The main organization, a leading provider of IT services and solutions."@en ;
    org:hasUnit ex:ITOperationsTeam, ex:WebDevTeam .

ex:ITOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Responsible for the day-to-day operations and maintenance of the IT infrastructure."@en ;
    org:unitOf ex:TechCorpSolutions ;
    noria:agentWorkingHours "Mon-Fri, 9:00-17:00 UTC"@en ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. For routine requests, submit a ticket via the internal portal."@en ;
    foaf:member ex:JohnDoe .

ex:WebDevTeam
    a org:OrganizationalUnit ;
    rdfs:label "Web Development Team"@en ;
    rdfs:comment "Responsible for the development, deployment, and support of web-based applications."@en ;
    org:unitOf ex:TechCorpSolutions ;
    noria:agentWorkingHours "Mon-Fri, 9:30-18:00 UTC"@en ;
    noria:agentInstructions "Contact via internal chat for urgent matters, otherwise use project management tools."@en ;
    foaf:member ex:JaneSmith .

ex:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A senior system administrator in the IT Operations Team."@en ;
    foaf:mbox <mailto:john.doe@techcorp.com> ;
    foaf:phone "+1-555-123-4567" ;
    foaf:holdsAccount ex:JohnDoeCUid ;
    noria:agentManagesResource ex:WebServer01, ex:DBServer01, ex:RouterCore01 .

ex:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A lead developer in the Web Development Team."@en ;
    foaf:mbox <mailto:jane.smith@techcorp.com> ;
    foaf:phone "+1-555-987-6543" ;
    foaf:holdsAccount ex:JaneSmithCUid ;
    noria:agentManagesResource ex:CustomerPortalApp, ex:CustomerPortalProdModule .

ex:JohnDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "John Doe's unique identifier for accessing TechCorp's IT resources."@en ;
    foaf:accountName "jdoe" ;
    observable:accountIdentifier "jdoe_techcorp_id_12345" .

ex:JaneSmithCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Jane Smith's unique identifier for accessing TechCorp's IT resources."@en ;
    foaf:accountName "jsmith" ;
    observable:accountIdentifier "jsmith_techcorp_id_67890" .

