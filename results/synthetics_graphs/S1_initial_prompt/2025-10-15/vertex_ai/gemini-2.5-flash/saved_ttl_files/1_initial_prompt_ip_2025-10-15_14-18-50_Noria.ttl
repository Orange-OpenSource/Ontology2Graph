# --- Trouble Tickets ---

ex:TT_WebServerOutage_001
    a noria:TroubleTicket ;
    rdfs:label "TT-20240423-001: Web Server 01 Outage"@en ;
    rdfs:comment "Trouble ticket opened due to Web Server 01 becoming unresponsive, impacting the Customer Portal."@en ;
