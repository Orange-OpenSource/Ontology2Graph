ex:TT_WebServerOutage_001_Note1
    a noria:TroubleTicketNote ;
    rdfs:label "TT-20240423-001 Note 1"@en ;
    rdfs:comment "Initial diagnostic note for Web Server 01 outage: High CPU usage observed before crash."@en ;
