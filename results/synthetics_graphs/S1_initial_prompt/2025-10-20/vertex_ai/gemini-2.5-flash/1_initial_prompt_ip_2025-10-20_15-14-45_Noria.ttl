# Prefixes
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix saref: <http://ontology.tno.nl/saref#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix devopsprod: <http://w3id.org/devops-infra/product#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix ex: <http://example.com/noria-kg/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Example Knowledge Graph based on NORIA Ontology
# This section describes a fictional IT infrastructure and its management,
# demonstrating the use of classes and properties from the NORIA schema.
# =============================================================================

# --- SKOS Concepts for Controlled Vocabularies ---
# These concepts represent controlled vocabulary values used throughout the knowledge graph.
# They are defined here for completeness, as they are referenced by various entities.

ex:ApplicationType_CRM
    a skos:Concept ;
    rdfs:label "CRM Application Type"@en ;
    rdfs:comment "Represents a Customer Relationship Management application type, central for managing customer interactions and data."@en ;
    skos:inScheme <kos/application/type> .

ex:ApplicationType_Monitoring
    a skos:Concept ;
    rdfs:label "Monitoring Application Type"@en ;
    rdfs:comment "Represents an IT infrastructure monitoring application type, crucial for detecting and alerting on system health and performance issues."@en ;
    skos:inScheme <kos/application/type> .

ex:BusinessImportance_High
    a skos:Concept ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Indicates a critical application with high business impact, meaning its unavailability would severely affect business operations."@en ;
    skos:inScheme <kos/application/business-importance> .

ex:BusinessImportance_Medium
    a skos:Concept ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Indicates an application with moderate business impact, where temporary unavailability might cause inconvenience but not critical business disruption."@en ;
    skos:inScheme <kos/application/business-importance> .

ex:SLA_Level_Gold
    a skos:Concept ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Service Level Agreement indicating highest priority and availability targets, typically for mission-critical systems."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

ex:SLA_Level_Silver
    a skos:Concept ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Service Level Agreement indicating standard priority and availability targets, for important but not immediately critical systems."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

ex:ApplicationStatus_InProduction
    a skos:Concept ;
    rdfs:label "In Production Status"@en ;
    rdfs:comment "The application module is currently active and serving live users in a production environment."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

ex:ApplicationStatus_Development
    a skos:Concept ;
    rdfs:label "Development Status"@en ;
    rdfs:comment "The application module is currently in a development environment, used for coding, testing, and feature implementation."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

ex:ServiceType_CustomerFacing
    a skos:Concept ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly exposed to and consumed by external customers, impacting their experience and business directly."@en ;
    skos:inScheme <kos/service/type> .

ex:ServiceType_Internal
    a skos:Concept ;
    rdfs:label "Internal Service"@en ;
    rdfs:comment "A service used internally by the organization, not directly by customers, supporting internal operations or other services."@en ;
    skos:inScheme <kos/service/type> .

ex:TroubleTicketSeverity_Major
    a skos:Concept ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Indicates a significant incident impacting service availability or performance, often leading to widespread disruption."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

ex:TroubleTicketSeverity_Minor
    a skos:Concept ;
    rdfs:label "Minor Severity"@en ;
    rdfs:comment "Indicates a minor incident with limited impact, affecting a small number of users or a non-critical function."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

ex:TroubleTicketType_Failure
    a skos:Concept ;
    rdfs:label "Failure Ticket Type"@en ;
    rdfs:comment "A trouble ticket type specifically for reporting system failures, crashes, or unexpected shutdowns."@en ;
    skos:inScheme <kos/TroubleTicket/type> .

ex:TroubleTicketPriority_P1
    a skos:Concept ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, requiring immediate attention and resolution due to severe business impact."@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

ex:TroubleTicketPriority_P3
    a skos:Concept ;
    rdfs:label "Priority 3"@en ;
    rdfs:comment "Medium priority, requiring attention within a defined timeframe, typically for issues with moderate impact."@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

ex:TroubleTicketOrigin_Supervision
    a skos:Concept ;
    rdfs:label "Supervision Origin"@en ;
    rdfs:comment "Trouble ticket originated from an automated monitoring system, indicating proactive detection of an issue."@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

ex:TroubleTicketOrigin_Customer
    a skos:Concept ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Trouble ticket originated from a customer report, indicating a direct impact on end-users."@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

ex:TroubleTicketStatus_InProgress
    a skos:Concept ;
    rdfs:label "In Progress Status"@en ;
    rdfs:comment "The trouble ticket is currently being actively worked on by assigned personnel."@en ;
    skos:inScheme <kos/TroubleTicket/status> .

ex:TroubleTicketStatus_Resolved
    a skos:Concept ;
    rdfs:label "Resolved Status"@en ;
    rdfs:comment "The issue described in the trouble ticket has been resolved, and the service is restored."@en ;
    skos:inScheme <kos/TroubleTicket/status> .

ex:TroubleTicketCommentType_Internal
    a skos:Concept ;
    rdfs:label "Internal Comment Type"@en ;
    rdfs:comment "A comment intended for internal team communication, not visible to external parties like customers."@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

ex:TroubleTicketOperationType_Diagnosis
    a skos:Concept ;
    rdfs:label "Diagnosis Operation Type"@en ;
    rdfs:comment "An operation type related to diagnosing the root cause of an issue, involving investigation and analysis."@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

ex:ChangeRequestCategory_InternalIntervention
    a skos:Concept ;
    rdfs:label "Internal Intervention Category"@en ;
    rdfs:comment "A change request category for internal maintenance, upgrades, or configuration changes that do not involve external vendors or customers."@en ;
    skos:inScheme <kos/ChangeRequest/category> .

ex:ChangeRequestType_Standard
    a skos:Concept ;
    rdfs:label "Standard Change Type"@en ;
    rdfs:comment "A routine, pre-approved change with low risk, often automated or following a well-defined procedure."@en ;
    skos:inScheme <kos/ChangeRequest/type> .

ex:ChangeRequestCause_SoftwareUpgrade
    a skos:Concept ;
    rdfs:label "Software Upgrade Cause"@en ;
    rdfs:comment "The reason for the change request is a software upgrade, aiming to improve functionality, security, or performance."@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

ex:ChangeRequestStatus_Approved
    a skos:Concept ;
    rdfs:label "Approved Status"@en ;
    rdfs:comment "The change request has been formally approved and is awaiting execution during its scheduled window."@en ;
    skos:inScheme <kos/ChangeRequest/status> .

ex:ChangeRequestStatus_Implemented
    a skos:Concept ;
    rdfs:label "Implemented Status"@en ;
    rdfs:comment "The change request has been successfully implemented and verified."@en ;
    skos:inScheme <kos/ChangeRequest/status> .

ex:ResourceLifecycleState_InProduction
    a skos:Concept ;
    rdfs:label "In Production Lifecycle State"@en ;
    rdfs:comment "The resource is currently active in a production environment, supporting live services."@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

ex:ResourceLifecycleState_Staging
    a skos:Concept ;
    rdfs:label "Staging Lifecycle State"@en ;
    rdfs:comment "The resource is in a staging environment, used for final testing before production deployment."@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

ex:ResourceOperationalState_Up
    a skos:Concept ;
    rdfs:label "Operational State Up"@en ;
    rdfs:comment "The resource or interface is currently operational and functioning as expected."@en ;
    skos:inScheme <kos/Resource/OperationalState> .

ex:ResourceOperationalState_Down
    a skos:Concept ;
    rdfs:label "Operational State Down"@en ;
    rdfs:comment "The resource or interface is currently not operational, indicating a fault or planned outage."@en ;
    skos:inScheme <kos/Resource/OperationalState> .

ex:ResourceAdministrativeState_Up
    a skos:Concept ;
    rdfs:label "Administrative State Up"@en ;
    rdfs:comment "The resource or interface is administratively enabled, meaning it is configured to be active."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

ex:ResourceAdministrativeState_Down
    a skos:Concept ;
    rdfs:label "Administrative State Down"@en ;
    rdfs:comment "The resource or interface is administratively disabled, meaning it has been intentionally shut down."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

ex:ResourceType_Router
    a skos:Concept ;
    rdfs:label "Router Resource Type"@en ;
    rdfs:comment "A network device that forwards data packets between different computer networks, acting as a traffic director."@en ;
    skos:inScheme <kos/Resource/type> .

ex:ResourceType_Server
    a skos:Concept ;
    rdfs:label "Server Resource Type"@en ;
    rdfs:comment "A computer program or a device that provides functionality for other programs or devices, typically hosting applications or data."@en ;
    skos:inScheme <kos/Resource/type> .

ex:ResourceType_Switch
    a skos:Concept ;
    rdfs:label "Switch Resource Type"@en ;
    rdfs:comment "A network device that connects devices in a computer network by using packet switching to receive, process, and forward data to the destination device within the same network segment."@en ;
    skos:inScheme <kos/Resource/type> .

ex:AlarmSeverity_Critical
    a skos:Concept ;
    rdfs:label "Critical Alarm Severity"@en ;
    rdfs:comment "Indicates a critical alarm requiring immediate action, often associated with service outages or severe performance degradation."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

ex:AlarmSeverity_Warning
    a skos:Concept ;
    rdfs:label "Warning Alarm Severity"@en ;
    rdfs:comment "Indicates a warning, a potential issue that needs attention but is not yet critical, such as high resource utilization."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

ex:EventType_StateChange
    a skos:Concept ;
    rdfs:label "State Change Event Type"@en ;
    rdfs:comment "An event indicating a change in the operational state of a component, e.g., from 'up' to 'down' or vice versa."@en ;
    skos:inScheme <kos/Notification/EventType> .

ex:EventType_ConfigurationChange
    a skos:Concept ;
    rdfs:label "Configuration Change Event Type"@en ;
    rdfs:comment "An event indicating a change in the configuration of a component, which might impact its behavior or connectivity."@en ;
    skos:inScheme <kos/Notification/EventType> .

ex:AgentContactMethod_Email
    a skos:Concept ;
    rdfs:label "Email Contact Method"@en ;
    rdfs:comment "Preferred contact method is email, suitable for non-urgent communications or detailed information exchange."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

ex:AgentContactMethod_Phone
    a skos:Concept ;
    rdfs:label "Phone Contact Method"@en ;
    rdfs:comment "Preferred contact method is phone, suitable for urgent communications or real-time discussions."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

# --- Organizations and Agents ---
# These entities represent the organizational structure and personnel involved in managing the IT infrastructure.

ex:OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "A leading telecommunications company, serving millions of customers globally with various communication services."@en ;
    org:hasUnit ex:NetworkOperationsTeam, ex:ApplicationSupportTeam .

ex:NetworkOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing and maintaining the core network infrastructure, ensuring connectivity and performance."@en ;
    org:unitOf ex:OrangeTelecom ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod ex:AgentContactMethod_Phone ;
    noria:agentInstructions "For critical network issues, call the on-call engineer directly. For non-critical requests, use the network ticketing system."@en ;
    foaf:member ex:AliceSmith .

ex:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications, including troubleshooting, maintenance, and user assistance."@en ;
    org:unitOf ex:OrangeTelecom ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod ex:AgentContactMethod_Email ;
    noria:agentInstructions "Submit all application-related requests via the dedicated application support portal for efficient tracking."@en ;
    foaf:member ex:BobJohnson .

ex:AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, a key member of the Network Operations Team, specializing in router and switch management."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+33 1 23 45 67 89" ;
    foaf:holdsAccount ex:AliceCUid .

ex:BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Specialist, a dedicated member of the Application Support Team, focusing on CRM system issues."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+33 1 98 76 54 32" ;
    foaf:holdsAccount ex:BobCUid .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate login identifier for Alice Smith, used for accessing internal IT resources and systems."@en ;
    foaf:accountName "asmith" ;
    observable:accountLogin "asmith" ;
    observable:accountIdentifier "asmith-corp-id-123" .

ex:BobCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Corporate login identifier for Bob Johnson, used for accessing internal IT resources and systems."@en ;
    foaf:accountName "bjohnson" ;
    observable:accountLogin "bjohnson" ;
    observable:accountIdentifier "bjohnson-corp-id-456" .

# --- Locations ---
# These entities describe the physical locations where IT resources are housed.

ex:ParisDataCenter
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "The primary data center located in Paris, France, hosting critical IT infrastructure for Orange Telecom."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" ;
    bot:containsZone ex:ServerRoomA1 .

ex:ServerRoomA1
    a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "A dedicated server room within the Paris Data Center, designed for optimal server operation and cooling."@en ;
    bot:hasSubSpace ex:RackR1Locus, ex:RackR2Locus .

ex:RackR1Locus
    a noria:Locus ;
    rdfs:label "Rack R1 Locus"@en ;
    rdfs:comment "Specific location for Rack R1 in Server Room A1, identified by its row and column within the room layout."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

ex:RackR2Locus
    a noria:Locus ;
    rdfs:label "Rack R2 Locus"@en ;
    rdfs:comment "Specific location for Rack R2 in Server Room A1, housing critical application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

# --- Product Models ---
# These entities represent the specific models of hardware products used in the infrastructure.

ex:CiscoISR4451
    a noria:ProductModel ;
    rdfs:label "Cisco ISR 4451-X"@en ;
    rdfs:comment "Product model for a Cisco Integrated Services Router, known for its high performance and modularity."@en ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:DellPowerEdgeR740
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Product model for a Dell PowerEdge R740 server, a versatile rack server for demanding workloads."@en ;
    noria:productManufacturedBy ex:DellTechnologies .

ex:HPAruba2930F
    a noria:ProductModel ;
    rdfs:label "HP Aruba 2930F"@en ;
    rdfs:comment "Product model for an HP Aruba 2930F switch, providing reliable and secure access layer connectivity."@en ;
    noria:productManufacturedBy ex:HPE .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "A multinational technology conglomerate that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products globally."@en .

ex:DellTechnologies
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "An American multinational technology company that develops, sells, repairs, and supports computers and related products and services, including servers and storage solutions."@en .

ex:HPE
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "An American multinational enterprise information technology company, focusing on servers, storage, networking, consulting and support."@en .

# --- Resources ---
# These entities represent the actual physical or virtual IT assets in the infrastructure.

ex:Router01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "A critical core network router in the Paris Data Center, responsible for routing traffic between major network segments."@en ;
    noria:resourceHostName "router-par-01" ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceProductModel ex:CiscoISR4451 ;
    noria:resourceSerialNumber "FOC12345678" ;
    noria:resourceType ex:ResourceType_Router ;
    noria:resourceUsageState ex:ResourceLifecycleState_InProduction ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://10.0.0.1> ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:locatedAtLocus ex:RackR1Locus ;
    noria:resourceForApplication ex:MonitoringPlatform ;
    noria:clusterController ex:MonitoringPlatform .

ex:Server01
    a noria:Resource ;
    rdfs:label "CRM Database Server 01"@en ;
    rdfs:comment "The primary database server for the CRM system, hosting critical customer data."@en ;
    noria:resourceHostName "db-crm-01" ;
    noria:resourceLogisticId "LOG-SRV-001" ;
    noria:resourceProductModel ex:DellPowerEdgeR740 ;
    noria:resourceSerialNumber "ABC98765432" ;
    noria:resourceType ex:ResourceType_Server ;
    noria:resourceUsageState ex:ResourceLifecycleState_InProduction ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://10.0.0.10> ;
    noria:resourceManagedBy ex:ApplicationSupportTeam ;
    noria:locatedAtLocus ex:RackR2Locus ;
    noria:resourceForApplication ex:CRMSystem_Prod ;
    noria:clusterController ex:MonitoringPlatform .

ex:Switch01
    a noria:Resource ;
    rdfs:label "Access Switch 01"@en ;
    rdfs:comment "An access layer switch connecting servers in Rack R2 to the wider network."@en ;
    noria:resourceHostName "sw-par-01" ;
    noria:resourceLogisticId "LOG-SWT-001" ;
    noria:resourceProductModel ex:HPAruba2930F ;
    noria:resourceSerialNumber "XYZ11223344" ;
    noria:resourceType ex:ResourceType_Switch ;
    noria:resourceUsageState ex:ResourceLifecycleState_InProduction ;
    noria:resourceInstallationDate "2022-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://10.0.0.20> ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:locatedAtLocus ex:RackR2Locus ;
    noria:resourceForApplication ex:MonitoringPlatform ;
    noria:clusterController ex:MonitoringPlatform .

# --- Network Interfaces ---
# These entities represent the network connectivity points of resources.

ex:Router01_GE0_0_1
    a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Network interface on Router01 connecting to the CRM DB Server segment, crucial for application traffic."@en ;
    noria:networkInterfaceOf ex:Router01 ;
    noria:networkInterfaceDescription "Uplink to CRM DB Server segment" ;
    noria:networkInterfaceAdministrativeStatus ex:ResourceAdministrativeState_Up ;
    noria:networkInterfaceOperationalStatus ex:ResourceOperationalState_Up ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

ex:Server01_ETH0
    a noria:NetworkInterface ;
    rdfs:label "Server01 Ethernet0"@en ;
    rdfs:comment "Primary network interface on Server01, providing network access for the CRM database."@en ;
    noria:networkInterfaceOf ex:Server01 ;
    noria:networkInterfaceDescription "Primary interface for CRM DB" ;
    noria:networkInterfaceAdministrativeStatus ex:ResourceAdministrativeState_Up ;
    noria:networkInterfaceOperationalStatus ex:ResourceOperationalState_Up ;
    noria:networkInterfaceType "physical" .

ex:Switch01_Port1
    a noria:NetworkInterface ;
    rdfs:label "Switch01 Port 1"@en ;
    rdfs:comment "Network interface on Switch01 connecting to Router01, forming the uplink to the core network."@en ;
    noria:networkInterfaceOf ex:Switch01 ;
    noria:networkInterfaceDescription "Uplink to Core Router" ;
    noria:networkInterfaceAdministrativeStatus ex:ResourceAdministrativeState_Up ;
    noria:networkInterfaceOperationalStatus ex:ResourceOperationalState_Up ;
    noria:networkInterfaceType "physical" .

ex:Switch01_Port2
    a noria:NetworkInterface ;
    rdfs:label "Switch01 Port 2"@en ;
    rdfs:comment "Network interface on Switch01 connecting to Server01, providing local network access for the server."@en ;
    noria:networkInterfaceOf ex:Switch01 ;
    noria:networkInterfaceDescription "Connection to CRM DB Server" ;
    noria:networkInterfaceAdministrativeStatus ex:ResourceAdministrativeState_Up ;
    noria:networkInterfaceOperationalStatus ex:ResourceOperationalState_Up ;
    noria:networkInterfaceType "physical" .

# --- Network Links ---
# These entities represent the connections between network interfaces and resources.

ex:Link_Router01_Switch01
    a noria:NetworkLink ;
    rdfs:label "Link between Router01 and Switch01"@en ;
    rdfs:comment "Physical network link connecting Router01's GE0/0/1 to Switch01's Port 1, forming a critical path for data."@en ;
    noria:networkLinkId "NL-RTR01-SW01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2022-05-10T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin ex:Router01 ;
    noria:networkLinkTerminationResourceDestination ex:Switch01 ;
    noria:resourceManagedBy ex:NetworkOperationsTeam .

ex:Link_Switch01_Server01
    a noria:NetworkLink ;
    rdfs:label "Link between Switch01 and Server01"@en ;
    rdfs:comment "Physical network link connecting Switch01's Port 2 to Server01's ETH0, enabling communication for the CRM database."@en ;
    noria:networkLinkId "NL-SW01-SRV01" ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:networkLinkInstallationDate "2021-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin ex:Switch01 ;
    noria:networkLinkTerminationResourceDestination ex:Server01 ;
    noria:resourceManagedBy ex:NetworkOperationsTeam .

# Linking interfaces to links
ex:Router01_GE0_0_1 noria:networkInterfaceConnects ex:Link_Router01_Switch01 .
ex:Switch01_Port1 noria:networkInterfaceConnects ex:Link_Router01_Switch01 .
ex:Switch01_Port2 noria:networkInterfaceConnects ex:Link_Switch01_Server01 .
ex:Server01_ETH0 noria:networkInterfaceConnects ex:Link_Switch01_Server01 .

# --- Applications and Modules ---
# These entities represent the software applications and their specific deployments.

ex:CRMSystem
    a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:comment "Core application for managing customer interactions, sales, and support, vital for business operations."@en ;
    noria:applicationModelIdentifier "CRM-APP-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType ex:ApplicationType_CRM ;
    noria:applicationBusinessImportance ex:BusinessImportance_High ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Sales & Marketing" .

ex:MonitoringPlatform
    a noria:Application ;
    rdfs:label "IT Monitoring Platform"@en ;
    rdfs:comment "Platform for monitoring IT infrastructure and applications, collecting metrics and logs for operational awareness."@en ;
    noria:applicationModelIdentifier "MON-PLAT-V3" ;
    noria:applicationNumericalIdentifier 2002 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType ex:ApplicationType_Monitoring ;
    noria:applicationBusinessImportance ex:BusinessImportance_Medium ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance & Availability Monitoring" ;
    seas:subSystemOf ex:OrangeTelecom .

ex:CRMSystem_Prod
    a noria:ApplicationModule ;
    rdfs:label "CRM System Production Module"@en ;
    rdfs:comment "Production instance of the CRM System, serving live customer data and interactions."@en ;
    noria:applicationModuleOf ex:CRMSystem ;
    noria:applicationModuleName "CRM_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:BobJohnson ;
    noria:applicationModuleSupportTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleSupportLeader ex:BobJohnson ;
    noria:applicationModuleSlaLevel ex:SLA_Level_Gold ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus ex:ApplicationStatus_InProduction ;
    seas:subSystemOf ex:CustomerDataService .

ex:CRMSystem_Dev
    a noria:ApplicationModule ;
    rdfs:label "CRM System Development Module"@en ;
    rdfs:comment "Development instance of the CRM System, used by developers for building and testing new features."@en ;
    noria:applicationModuleOf ex:CRMSystem ;
    noria:applicationModuleName "CRM_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleAdministrationTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:BobJohnson ;
    noria:applicationModuleSlaLevel ex:SLA_Level_Silver ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleStatus ex:ApplicationStatus_Development .

# --- Services ---
# These entities represent end-to-end services provided to customers or internal users.

ex:CustomerDataService
    a noria:Service ;
    rdfs:label "Customer Data Access Service"@en ;
    rdfs:comment "An end-to-end service providing secure and reliable access to customer data, underpinned by the CRM system and its infrastructure."@en ;
    noria:serviceType ex:ServiceType_CustomerFacing .

# --- Event Records ---
# These entities capture significant occurrences or observations within the IT environment.

ex:Event_Server01_Down
    a noria:EventRecord ;
    rdfs:label "Server01 Down Event"@en ;
    rdfs:comment "An event indicating that Server01 went down unexpectedly, triggering an immediate alert."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Server db-crm-01 is unreachable via ICMP. All services hosted on it are affected." ;
    noria:logOriginatingManagedObject ex:Server01 ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    noria:alarmSeverity ex:AlarmSeverity_Critical ;
    dcterms:type ex:EventType_StateChange .

ex:Event_Router01_InterfaceUp
    a noria:EventRecord ;
    rdfs:label "Router01 Interface Up Event"@en ;
    rdfs:comment "An event indicating that Router01's interface GE0/0/1 came up, potentially after a previous outage or maintenance."@en ;
    noria:loggingTime "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    noria:logText "INFO: Interface GigabitEthernet0/0/1 on router-par-01 changed state to up. Connectivity restored." ;
    noria:logOriginatingManagedObject ex:Router01 ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    noria:alarmSeverity ex:AlarmSeverity_Warning ; # Could be warning if it was flapping, indicating potential instability
    dcterms:type ex:EventType_StateChange .

ex:Event_Router01_ConfigChange
    a noria:EventRecord ;
    rdfs:label "Router01 Configuration Change Event"@en ;
    rdfs:comment "An event recording a configuration change on Router01, performed by Alice Smith, indicating an administrative action."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by asmith (192.168.1.100). Applied new routing policy." ;
    noria:logOriginatingManagedObject ex:Router01 ;
    noria:logOriginatingAgent ex:AliceSmith ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    dcterms:type ex:EventType_ConfigurationChange .

# --- Trouble Tickets ---
# These entities represent incidents or problems requiring resolution.

ex:TT_2024_001_ServerDown
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket for CRM DB Server Down"@en ;
    rdfs:comment "Incident ticket created due to Server01 (CRM DB Server) being down, impacting the Customer Data Access Service."@en ;
    noria:documentExternalId "INC-2024-001" ;
    noria:documentHRef <http://ticketing.example.com/INC-2024-001> ;
    noria:troubleTicketTrigger ex:Event_Server01_Down ;
    noria:troubleTicketRelatedResource ex:Server01 ;
    noria:troubleTicketRelatedService ex:CustomerDataService ;
    noria:troubleTicketSeverity ex:TroubleTicketSeverity_Major ;
    noria:troubleTicketType ex:TroubleTicketType_Failure ;
    noria:troubleTicketPriority ex:TroubleTicketPriority_P1 ;
    noria:troubleTicketOrigin ex:TroubleTicketOrigin_Supervision ;
    noria:troubleTicketStatusCurrent ex:TroubleTicketStatus_InProgress ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedParty ex:NetworkOperationsTeam, ex:ApplicationSupportTeam ;
    noria:troubleTicketCause "Unidentified OS crash on Server01, possibly due to memory exhaustion."@en ;
    noria:troubleTicketImpacts ex:Server01, ex:CustomerDataService ;
    noria:documentStatusHistory ex:Event_Server01_Down .

ex:TT_2024_002_CustomerReport
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket for CRM Login Issue"@en ;
    rdfs:comment "Incident ticket created due to a customer reporting intermittent login issues with the CRM system."@en ;
    noria:documentExternalId "CUST-INC-2024-002" ;
    noria:documentHRef <http://ticketing.example.com/CUST-INC-2024-002> ;
    noria:troubleTicketRelatedService ex:CustomerDataService ;
    noria:troubleTicketSeverity ex:TroubleTicketSeverity_Minor ;
    noria:troubleTicketType ex:TroubleTicketType_Failure ;
    noria:troubleTicketPriority ex:TroubleTicketPriority_P3 ;
    noria:troubleTicketOrigin ex:TroubleTicketOrigin_Customer ;
    noria:troubleTicketStatusCurrent ex:TroubleTicketStatus_InProgress ;
    noria:troubleTicketDetectionDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedParty ex:ApplicationSupportTeam ;
    noria:troubleTicketCause "Customer reported intermittent login failures, possibly related to authentication service."@en .

# --- Trouble Ticket Notes ---
# These entities provide detailed updates and comments related to trouble tickets.

ex:TT_2024_001_Note01
    a noria:TroubleTicketNote ;
    rdfs:label "TT-2024-001 Initial Diagnosis Note"@en ;
    rdfs:comment "Initial diagnosis note for TT-2024-001. Confirmed server unreachability and initiated escalation."@en ;
    dcterms:isPartOf ex:TT_2024_001_ServerDown ;
    dcterms:creator ex:AliceSmith ;
    dcterms:created "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    dcterms:description "Confirmed server db-crm-01 is not responding to pings from multiple network points. Escalating to server team for further investigation and action."@en ;
    noria:troubleTicketNoteCommentType ex:TroubleTicketCommentType_Internal ;
    noria:troubleTicketNoteOperationType ex:TroubleTicketOperationType_Diagnosis .

ex:TT_2024_001_Note02
    a noria:TroubleTicketNote ;
    rdfs:label "TT-2024-001 Resolution Note"@en ;
    rdfs:comment "Resolution note for TT-2024-001. Server rebooted, and CRM service restored after successful restart procedure."@en ;
    dcterms:isPartOf ex:TT_2024_001_ServerDown ;
    dcterms:creator ex:BobJohnson ;
    dcterms:created "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    dcterms:description "Server db-crm-01 rebooted successfully after a hard reset. CRM application is now accessible and responding. Monitoring for stability over the next 24 hours."@en ;
    noria:troubleTicketNoteCommentType ex:TroubleTicketCommentType_Internal ;
    noria:troubleTicketNoteOperationType ex:TroubleTicketOperationType_Diagnosis ;
    noria:troubleTicketNoteCorrelatedExecution ex:ServerRestartProcedureExecution .

# --- Change Requests ---
# These entities represent planned changes to the IT infrastructure or applications.

ex:CR_2024_005_RouterUpgrade
    a noria:ChangeRequest ;
    rdfs:label "Change Request for Router Firmware Upgrade"@en ;
    rdfs:comment "Planned firmware upgrade for Router01 to enhance security, fix known bugs, and improve overall network performance."@en ;
    noria:documentExternalId "CR-NET-2024-005" ;
    noria:documentHRef <http://changemgmt.example.com/CR-NET-2024-005> ;
    noria:changeRequestImpact ex:Router01, ex:Link_Router01_Switch01 ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent ex:ChangeRequestStatus_Approved ;
    noria:changeRequestCategory ex:ChangeRequestCategory_InternalIntervention ;
    noria:changeRequestType ex:ChangeRequestType_Standard ;
    noria:changeRequestChangeCause ex:ChangeRequestCause_SoftwareUpgrade ;
    noria:changeRequestInitiatorParty ex:AliceSmith ;
    noria:changeRequestPilotParty ex:AliceSmith ;
    noria:changeRequestActorParty ex:NetworkOperationsTeam ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # Expected 2 hours outage for the upgrade process
    noria:changeRequestIsRegulated false ;
    noria:documentStatusHistory ex:Event_Router01_ConfigChange .

# --- Operation Plans and Conditions ---
# These entities define standardized procedures and their associated pre/post conditions.

ex:RouterFirmwareUpgradePlan
    a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for safely upgrading router firmware, including steps for backup, upgrade, and verification."@en ;
    noria:operationPlanPreCondition ex:RouterUpgradePreCheck ;
    noria:operationPlanPostCondition ex:RouterUpgradePostCheck .

ex:RouterUpgradePreCheck
    a noria:ActionPreCondition ;
    rdfs:label "Router Upgrade Pre-Condition Check"@en ;
    rdfs:comment "Checks to perform before initiating a router firmware upgrade, such as verifying current configuration backup, checking device health, and confirming maintenance window."@en .

ex:RouterUpgradePostCheck
    a noria:ActionPostCondition ;
    rdfs:label "Router Upgrade Post-Condition Check"@en ;
    rdfs:comment "Checks to perform after a router firmware upgrade, including verifying the new firmware version, checking interface status, validating routing tables, and testing connectivity."@en .

ex:ServerRestartProcedure
    a noria:OperationPlan ;
    rdfs:label "Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for safely restarting a server, ensuring minimal disruption to services."@en ;
    noria:operationPlanPreCondition ex:ServerRestartPreCheck ;
    noria:operationPlanPostCondition ex:ServerRestartPostCheck .

ex:ServerRestartPreCheck
    a noria:ActionPreCondition ;
    rdfs:label "Server Restart Pre-Condition Check"@en ;
    rdfs:comment "Checks to perform before restarting a server, such as notifying affected users, verifying application status, and ensuring data integrity."@en .

ex:ServerRestartPostCheck
    a noria:ActionPostCondition ;
    rdfs:label "Server Restart Post-Condition Check"@en ;
    rdfs:comment "Checks to perform after a server restart, including verifying OS boot, ensuring all critical application services are running, and testing connectivity."@en .

# --- Procedure Executions (linking actions to plans) ---
# These entities record the actual execution of operation plans.

ex:RouterFirmwareUpgradeExecution
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Router Firmware Upgrade Execution for CR-2024-005"@en ;
    rdfs:comment "Record of the execution of the router firmware upgrade procedure for Change Request CR-2024-005, detailing the actual start and end times."@en ;
    noria:actionCorrelatedOperationPlan ex:RouterFirmwareUpgradePlan ;
    dcterms:isPartOf ex:CR_2024_005_RouterUpgrade ;
    prov:startedAtTime "2024-05-01T02:05:00Z"^^xsd:dateTime ;
    prov:endedAtTime "2024-05-01T03:45:00Z"^^xsd:dateTime ;
    pep:hasPerformer ex:AliceSmith .

ex:ServerRestartProcedureExecution
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Server Restart Procedure Execution for TT-2024-001"@en ;
    rdfs:comment "Record of the execution of the server restart procedure for Trouble Ticket TT-2024-001, performed to restore service."@en ;
    noria:actionCorrelatedOperationPlan ex:ServerRestartProcedure ;
    dcterms:isPartOf ex:TT_2024_001_ServerDown ;
    prov:startedAtTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    prov:endedAtTime "2024-04-20T10:40:00Z"^^xsd:dateTime ;
    pep:hasPerformer ex:BobJohnson .

# --- Observable Properties ---
# These entities represent dynamic, measurable qualities of structural elements.

ex:Router01_GE0_0_1_TxPower
    a noria:StructuralObservable ;
    rdfs:label "Router01 GE0/0/1 Transmit Optical Power"@en ;
    rdfs:comment "Observable property for the transmit optical power of Router01's GE0/0/1 interface, measured in dBm."@en ;
    noria:structuralObservableOf ex:Router01_GE0_0_1 ;
    noria:networkInterfaceLaserTxOpticalPower -2 .

ex:Router01_GE0_0_1_RxPower
    a noria:StructuralObservable ;
    rdfs:label "Router01 GE0/0/1 Receive Optical Power"@en ;
    rdfs:comment "Observable property for the receive optical power of Router01's GE0/0/1 interface, measured in dBm."@en ;
    noria:structuralObservableOf ex:Router01_GE0_0_1 ;
    noria:networkInterfaceLaserRxOpticalPower -3 .

ex:Server01_VirtualServerStatus
    a noria:StructuralObservable ;
    rdfs:label "Server01 Virtual Server Status"@en ;
    rdfs:comment "Observable property for the virtual server status of Server01, indicating its current operational state."@en ;
    noria:structuralObservableOf ex:Server01 ;
    noria:virtualServerStatus ex:ResourceOperationalState_Up .

# --- Document Attachments ---
# These entities represent files or documents associated with other entities.

ex:RouterConfigBackupFile
    a noria:DocumentAttachment ;
    rdfs:label "Router01 Configuration Backup"@en ;
    rdfs:comment "Backup configuration file for Router01, created before the firmware upgrade and attached to the change request for reference."@en ;
    dcterms:isPartOf ex:CR_2024_005_RouterUpgrade ;
    dcterms:format "application/octet-stream" ;
    dcterms:identifier "router-par-01-config-20240430.cfg" .

ex:ServerLogFile
    a noria:DocumentAttachment ;
    rdfs:label "Server01 Crash Log"@en ;
    rdfs:comment "Log file collected from Server01 after the crash, attached to the trouble ticket to aid in root cause analysis."@en ;
    dcterms:isPartOf ex:TT_2024_001_ServerDown ;
    dcterms:format "text/plain" ;
    dcterms:identifier "db-crm-01-crash-20240420.log" .

# --- Anomaly Patterns ---
# These entities describe recurring patterns of anomalies or failures.

ex:HighCPUAnomaly
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Usage Anomaly Pattern"@en ;
    rdfs:comment "Describes a pattern of abnormally high CPU usage on a server, potentially indicating a performance issue, a runaway process, or a denial-of-service attack."@en ;
    folio:hasConsequence "Service Degradation" ;
    folio:hasCause "Software Bug", "DoS Attack" .

ex:InterfaceFlapAnomaly
    a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Anomaly Pattern"@en ;
    rdfs:comment "Describes a pattern where a network interface repeatedly goes up and down, indicating instability due to physical layer issues, hardware faults, or configuration errors."@en ;
    folio:hasConsequence "Network Instability", "Packet Loss" ;
    folio:hasCause "Faulty Cable", "Hardware Issue", "Configuration Error" .
