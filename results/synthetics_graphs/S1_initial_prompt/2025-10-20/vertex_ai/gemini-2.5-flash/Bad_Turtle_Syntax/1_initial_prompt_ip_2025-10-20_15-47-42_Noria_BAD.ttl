    dcterms:references ex:CR_WebServer01OSUpgrade ;
    noria:logOriginatingManagementSystem ex:TicketingSystem .

ex:CR_StatusChange_Executed a noria:EventRecord ;
    rdfs:label "CR Status Change to Executed" ;
    rdfs:comment "Event record for the status change of Change Request CR-20240425-001 to Executed." ;
