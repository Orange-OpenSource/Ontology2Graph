# =============================================================================
# 6. Trouble Tickets
# =============================================================================

ex:TT_CustomerPortalOutage a noria:TroubleTicket ;
    rdfs:label "Customer Portal Outage" ;
    rdfs:comment "Trouble ticket opened due to a complete outage of the customer portal, impacting critical business operations and requiring immediate attention." ;
    dcterms:identifier "TT-20240423-001"^^xsd:string ;
    noria:documentExternalId "CUST-P-OUTAGE-001"^^xsd:string ;
    noria:documentHRef <http://ticketing.example.com/TT-20240423-001>^^xsd:anyURI ;
    noria:troubleTicketSeverity ex:BlockingSeverity ;
    noria:troubleTicketType ex:FailureTicketType ;
    noria:troubleTicketCriticity ex:InterruptedServiceCriticity ;
    noria:troubleTicketPriority ex:P1Priority ;
    noria:troubleTicketOrigin ex:CustomerOrigin ;
    noria:troubleTicketTrigger ex:HighLatencyAlertEvent ;
    noria:troubleTicketUrgency ex:ImmediateInterventionUrgency ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory ex:TotalBreakdownCategory ;
    noria:troubleTicketCause "Suspected network congestion or web server overload, confirmed by high CPU usage on WebServer01."^^xsd:string ;
    noria:problemResponsibility ex:InternalITResponsibility ;
    noria:troubleTicketDetectionDateTime "2024-04-23T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T16:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T15:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T17:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true^^xsd:boolean ;
    noria:troubleTicketStatusCurrent ex:InProgressStatus ;
    noria:documentStatusHistory ex:TT_StatusChange_InProgress, ex:TT_StatusChange_Resolved ;
    noria:troubleTicketRelatedParty ex:OperationsTeam, ex:JohnDoe ;
    noria:troubleTicketPartyIntervention ex:TT_PartyIntervention_OpsTeam ;
    noria:troubleTicketRelatedService ex:WebAccessService ;
    noria:troubleTicketRelatedResource ex:WebServer01, ex:LoadBalancer01 ;
    noria:troubleTicketImpacts ex:CustomerPortalProdModule, ex:WebAccessService, ex:WebServer01 ;
    noria:troubleTicketCharacteristic ex:HighVisibilityCharacteristic ;
    noria:troubleTicketFreezeItem ex:TT_Freeze_InitialDiagnosis .

ex:BlockingSeverity a skos:Concept ;
    rdfs:label "Blocking Severity" ;
    rdfs:comment "Trouble ticket severity: Blocking, indicating complete service unavailability." ;
    skos:inScheme <kos/TroubleTicket/severity> .

ex:FailureTicketType a skos:Concept ;
    rdfs:label "Failure Ticket Type" ;
    rdfs:comment "Trouble ticket type: Failure, indicating a system or service malfunction." ;
    skos:inScheme <kos/TroubleTicket/type> .

ex:InterruptedServiceCriticity a skos:Concept ;
    rdfs:label "Interrupted Service Criticity" ;
    rdfs:comment "Trouble ticket criticity: Interrupted Service, meaning the service is completely down." ;
    skos:inScheme <kos/TroubleTicket/category> .

ex:P1Priority a skos:Concept ;
    rdfs:label "P1 Priority" ;
    rdfs:comment "Trouble ticket priority: P1 (Highest), requiring immediate and continuous attention." ;
    skos:inScheme <kos/TroubleTicket/priority> .

ex:CustomerOrigin a skos:Concept ;
    rdfs:label "Customer Origin" ;
    rdfs:comment "Trouble ticket origin: Reported by an external customer." ;
    skos:inScheme <kos/TroubleTicket/origin> .

ex:ImmediateInterventionUrgency a skos:Concept ;
    rdfs:label "Immediate Intervention Urgency" ;
    rdfs:comment "Trouble ticket urgency: Immediate Intervention, indicating a need for urgent action." ;
    skos:inScheme <kos/TroubleTicket/urgency> .

ex:TotalBreakdownCategory a skos:Concept ;
    rdfs:label "Total Breakdown Category" ;
    rdfs:comment "Trouble ticket category: Total Breakdown, implying a complete system failure." ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

ex:InternalITResponsibility a skos:Concept ;
    rdfs:label "Internal IT Responsibility" ;
    rdfs:comment "Problem responsibility: Identified as an issue within the internal IT infrastructure." ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

ex:InProgressStatus a skos:Concept ;
    rdfs:label "In Progress Status" ;
    rdfs:comment "Trouble ticket status: Currently being actively worked on." ;
    skos:inScheme <kos/TroubleTicket/status> .

ex:TT_PartyIntervention_OpsTeam a noria:TroubleTicketPartyIntervention ;
    rdfs:label "Operations Team Intervention on TT-20240423-001" ;
    rdfs:comment "Record of Operations Team's intervention on the trouble ticket, including ownership transfer and initial actions." ;
    dcterms:created "2024-04-23T14:05:00Z"^^xsd:dateTime ;
    dcterms:creator ex:JohnDoe ;
    dcterms:description "Operations Team took ownership of the ticket and started diagnosis, assigning John Doe as the lead."^^xsd:string ;
    dcterms:subject ex:OperationsTeam .

ex:HighVisibilityCharacteristic a noria:Property ;
    rdfs:label "High Visibility Characteristic" ;
    rdfs:comment "Characteristic indicating the trouble ticket has high visibility due to significant business impact or public exposure." .

ex:TT_Freeze_InitialDiagnosis a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze during Initial Diagnosis" ;
    rdfs:comment "A period where the trouble ticket was temporarily frozen to allow for initial diagnosis and data collection without triggering SLA breaches." ;
    dcterms:identifier "TT-FREEZE-20240423-001"^^xsd:string ;
    noria:loggingTime "2024-04-23T14:10:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240423-001 frozen for 15 minutes for initial diagnosis."^^xsd:string ;
    dcterms:type <kos/Notification/EventType/freezePeriod> ;
    dcterms:references ex:TT_CustomerPortalOutage .

ex:TT_Note_Diagnosis a noria:TroubleTicketNote ;
    rdfs:label "Diagnosis Note for Customer Portal Outage" ;
    rdfs:comment "Initial diagnosis steps taken for the Customer Portal outage, including web server log analysis and service restart." ;
    dcterms:identifier "TTN-20240423-001"^^xsd:string ;
    dcterms:created "2024-04-23T14:15:00Z"^^xsd:dateTime ;
    dcterms:creator ex:JohnDoe ;
    dcterms:description "Checked web server logs, found high CPU usage on WebServer01. Restarted Apache service. Latency improved after restart."^^xsd:string ;
    noria:troubleTicketNoteCommentType ex:InternalCommentType ;
    noria:troubleTicketNoteOperationType ex:DiagnosisOperationType ;
    noria:troubleTicketNoteCorrelatedExecution ex:WebServerRestartExecution ;
    dcterms:isPartOf ex:TT_CustomerPortalOutage .

ex:InternalCommentType a skos:Concept ;
    rdfs:label "Internal Comment Type" ;
    rdfs:comment "Comment type: Internal, visible only to internal teams." ;
    skos:inScheme <kos/TroubleTicket/commentType> .

ex:DiagnosisOperationType a skos:Concept ;
    rdfs:label "Diagnosis Operation Type" ;
    rdfs:comment "Operation type: Diagnosis, involving investigation and identification of the problem." ;
    skos:inScheme <kos/TroubleTicket/operationType> .

ex:WebServerRestartExecution a pep:ProcedureExecutionContainer ;
    rdfs:label "Web Server Restart Execution" ;
    rdfs:comment "Container for events related to the execution of the web server restart procedure, including the command issued and its outcome." ;
    dcterms:identifier "PROCEXEC-WSRESTART-20240423-001"^^xsd:string ;
    pep:hasProcedure ex:WebServerRestartProcedure ;
    pep:member ex:WebServer01RestartLog ;
    pep:hasInput "Restart command issued"^^xsd:string ;
    pep:hasOutput "Apache service restarted successfully"^^xsd:string .

ex:TT_Note_Resolution a noria:TroubleTicketNote ;
    rdfs:label "Resolution Note for Customer Portal Outage" ;
    rdfs:comment "Final resolution steps for the Customer Portal outage, confirming service restoration and customer satisfaction." ;
    dcterms:identifier "TTN-20240423-002"^^xsd:string ;
    dcterms:created "2024-04-23T15:30:00Z"^^xsd:dateTime ;
    dcterms:creator ex:JohnDoe ;
    dcterms:description "After restart, CPU usage normalized and latency returned to normal. Customer confirmed service restoration. Monitoring shows stable performance."^^xsd:string ;
    noria:troubleTicketNoteCommentType ex:InternalCommentType ;
    noria:troubleTicketNoteOperationType ex:ResolutionOperationType ;
    dcterms:isPartOf ex:TT_CustomerPortalOutage .

ex:ResolutionOperationType a skos:Concept ;
    rdfs:label "Resolution Operation Type" ;
    rdfs:comment "Operation type: Resolution, indicating the problem has been fixed." ;
    skos:inScheme <kos/TroubleTicket/operationType> .

# =============================================================================
# 7. Change Requests and Procedures
# =============================================================================

ex:CR_WebServer01OSUpgrade a noria:ChangeRequest ;
    rdfs:label "Change Request: Web Server 01 OS Upgrade" ;
    rdfs:comment "Change request to upgrade the operating system of Web Server 01 to a newer, more secure version during a scheduled maintenance window." ;
    dcterms:identifier "CR-20240425-001"^^xsd:string ;
    noria:documentExternalId "OS-UPGRADE-WS01"^^xsd:string ;
    noria:documentHRef <http://changemanagement.example.com/CR-20240425-001>^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-05-01T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-05-01T03:45:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory ex:InternalInterventionCategory ;
    noria:changeRequestType ex:StandardChangeType ;
    noria:changeRequestChangeCause ex:SoftwareUpgradeCause ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestStatusCurrent ex:ImplementedStatus ;
    noria:documentStatusHistory ex:CR_StatusChange_Approved, ex:CR_StatusChange_Executed ;
    noria:changeRequestInitiatorParty ex:JaneSmith ;
    noria:changeRequestPilotParty ex:JohnDoe ;
    noria:changeRequestActorParty ex:OperationsTeam ;
    noria:changeRequestImpact ex:WebServer01 ;
    noria:changeRequestSpecification ex:StandardOSUpgradeProcedure ;
    noria:changeRequestIsRegulated true^^xsd:boolean .

ex:InternalInterventionCategory a skos:Concept ;
    rdfs:label "Internal Intervention Category" ;
    rdfs:comment "Change request category: Internal Intervention, performed by internal IT staff." ;
    skos:inScheme <kos/ChangeRequest/category> .

ex:StandardChangeType a skos:Concept ;
    rdfs:label "Standard Change Type" ;
    rdfs:comment "Change request type: Standard Change, a pre-approved change with low risk." ;
    skos:inScheme <kos/ChangeRequest/type> .

ex:SoftwareUpgradeCause a skos:Concept ;
    rdfs:label "Software Upgrade Cause" ;
    rdfs:comment "Change cause: Software Upgrade, driven by security or feature requirements." ;
    skos:inScheme <kos/ChangeRequest/cause> .

ex:ImplementedStatus a skos:Concept ;
    rdfs:label "Implemented Status" ;
    rdfs:comment "Change request status: The change has been successfully executed." ;
    skos:inScheme <kos/ChangeRequest/status> .

ex:ApprovedStatus a skos:Concept ;
    rdfs:label "Approved Status" ;
    rdfs:comment "Change request status: The change has been formally approved for execution." ;
    skos:inScheme <kos/ChangeRequest/status> .

ex:StandardOSUpgradeProcedure a noria:OperationPlan ;
    rdfs:label "Standard OS Upgrade Procedure" ;
    rdfs:comment "A predefined, documented procedure for upgrading operating systems on web servers, minimizing downtime and ensuring service continuity." ;
    noria:operationPlanPreCondition ex:OSUpgradePreCondition ;
    noria:operationPlanPostCondition ex:OSUpgradePostCondition .

ex:OSUpgradePreCondition a noria:ActionPreCondition ;
    rdfs:label "OS Upgrade Pre-Condition" ;
    rdfs:comment "Pre-conditions for OS upgrade: Full system backup completed, current OS version recorded, application dependencies checked, maintenance window confirmed, and rollback plan in place." .

ex:OSUpgradePostCondition a noria:ActionPostCondition ;
    rdfs:label "OS Upgrade Post-Condition" ;
    rdfs:comment "Post-conditions for OS upgrade: New OS version verified, all critical application services started and functional, system health checks passed, network connectivity confirmed, and performance metrics stable." .

ex:WebServerRestartProcedure a pep:Procedure, noria:OperationPlan ;
    rdfs:label "Web Server Restart Procedure" ;
    rdfs:comment "A standard operating procedure for restarting a web server to resolve performance issues or apply minor configuration changes." ;
    noria:operationPlanPreCondition ex:VerifyImpactPreCondition ;
    noria:operationPlanPostCondition ex:VerifyServiceRestoredPostCondition .

ex:VerifyImpactPreCondition a noria:ActionPreCondition ;
    rdfs:label "Verify Impact Pre-Condition" ;
    rdfs:comment "Pre-condition: Confirm service impact and identify affected users before proceeding with restart, ensuring minimal disruption." .

ex:VerifyServiceRestoredPostCondition a noria:ActionPostCondition ;
    rdfs:label "Verify Service Restored Post-Condition" ;
    rdfs:comment "Post-condition: Verify web service is accessible and latency is within normal limits after restart, and monitor for any regressions." .

ex:NetworkTroubleshootingProcedure a noria:OperationPlan ;
    rdfs:label "Network Troubleshooting Procedure" ;
    rdfs:comment "A systematic procedure for diagnosing and resolving network connectivity issues, from physical layer to application layer." ;
    noria:operationPlanPreCondition ex:NetworkTroubleshootingPreCondition ;
    noria:operationPlanPostCondition ex:NetworkTroubleshootingPostCondition .

ex:NetworkTroubleshootingPreCondition a noria:ActionPreCondition ;
    rdfs:label "Network Troubleshooting Pre-Condition" ;
    rdfs:comment "Pre-condition: Verify scope of impact, gather initial symptoms, check recent changes, and collect relevant network device logs." .

ex:NetworkTroubleshootingPostCondition a noria:ActionPostCondition ;
    rdfs:label "Network Troubleshooting Post-Condition" ;
    rdfs:comment "Post-condition: Network connectivity restored, affected services operational, root cause identified, and preventative measures documented." .

# =============================================================================
# 8. Document Attachment
# =============================================================================

ex:OSUpgradePlanDoc a noria:DocumentAttachment ;
    rdfs:label "OS Upgrade Plan Document" ;
    rdfs:comment "Attachment containing the detailed plan and checklist for the OS upgrade on WebServer01, including steps, timelines, and rollback procedures." ;
    dcterms:identifier "DOC-OSUPGRADE-PLAN-001"^^xsd:string ;
    dcterms:title "OS Upgrade Plan for WebServer01"^^xsd:string ;
    dcterms:format "application/pdf"^^xsd:string ;
    dcterms:isPartOf ex:CR_WebServer01OSUpgrade .

ex:NetworkDiagramDoc a noria:DocumentAttachment ;
    rdfs:label "Network Diagram Document" ;
    rdfs:comment "Attachment containing the network topology diagram for Data Center A, illustrating connections between all network devices and servers." ;
    dcterms:identifier "DOC-NETWORK-DCA-001"^^xsd:string ;
    dcterms:title "Data Center A Network Diagram"^^xsd:string ;
    dcterms:format "image/png"^^xsd:string ;
    dcterms:isPartOf ex:TT_CustomerPortalOutage .

# =============================================================================
# 9. Anomaly Patterns
# =============================================================================

ex:HighCPULatencyAnomaly a noria:AnomalyPattern ;
    rdfs:label "High CPU and Latency Anomaly Pattern" ;
    rdfs:comment "Pattern indicating a potential issue when both CPU usage is consistently high (e.g., >90% for 5 minutes) and network latency is observed (e.g., >200ms), often leading to service degradation." ;
    folio:hasCause "Resource Exhaustion"^^xsd:string ;
    folio:hasEffect "Service Degradation"^^xsd:string ;
    dcterms:description "This pattern is often indicative of an application bottleneck, a denial-of-service attack, or inefficient resource allocation. Mitigation typically involves scaling resources or optimizing application code."^^xsd:string ;
    folio:hasMitigation ex:WebServerRestartProcedure .

ex:LinkFlapAnomaly a noria:AnomalyPattern ;
    rdfs:label "Network Link Flap Anomaly Pattern" ;
    rdfs:comment "Pattern indicating a network link repeatedly changing state between up and down within a short period (e.g., 3 times in 1 minute), suggesting instability." ;
    folio:hasCause "Faulty Hardware or Cabling"^^xsd:string ;
    folio:hasEffect "Intermittent Connectivity Loss"^^xsd:string ;
    dcterms:description "Frequent link flaps can lead to routing instability, packet loss, and intermittent service interruptions. Investigation usually involves checking physical connections and device logs."^^xsd:string ;
    folio:hasMitigation ex:NetworkTroubleshootingProcedure .
