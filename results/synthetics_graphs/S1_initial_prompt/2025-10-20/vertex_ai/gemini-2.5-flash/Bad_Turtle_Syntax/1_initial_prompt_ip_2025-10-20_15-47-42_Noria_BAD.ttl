    noria:logOriginatingManagementSystem ex:TicketingSystem .

ex:TT_StatusChange_Resolved a noria:EventRecord ;
    rdfs:label "TT Status Change to Resolved" ;
    rdfs:comment "Event record for the status change of Trouble Ticket TT-20240423-001 to Resolved." ;
    dcterms:identifier "TT-STATUS-20240423-001-RESOLVED"^^xsd:string ;
    noria:loggingTime "2024-04-23T15:45:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240423-001 status changed to Resolved."^^xsd:string ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    dcterms:references ex:TT_CustomerPortalOutage ;
    noria:logOriginatingManagementSystem ex:TicketingSystem .

ex:CR_StatusChange_Approved a noria:EventRecord ;
    rdfs:label "CR Status Change to Approved" ;
