# =============================================================================
# 5. Event Records
# =============================================================================

ex:HighLatencyAlertEvent a noria:EventRecord ;
    rdfs:label "High Latency Alert on Web Server 01" ;
    rdfs:comment "An event record indicating high network latency detected on Web Server 01, potentially due to resource contention or network issues." ;
    dcterms:identifier "ALERT-WS01-LATENCY-20240423-001"^^xsd:string ;
    noria:loggingTime "2024-04-23T14:00:00Z"^^xsd:dateTime ;
    noria:logText "High latency detected on webserver01.example.com, average response time 500ms. CPU usage 95%."^^xsd:string ;
    noria:logOriginatingManagedObject ex:WebServer01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystem ;
    noria:alarmSeverity ex:CriticalSeverity ;
    noria:alarmProposedRepairAction ex:WebServerRestartProcedure .

ex:CriticalSeverity a skos:Concept ;
    rdfs:label "Critical Severity" ;
    rdfs:comment "Alarm severity: Critical, indicating immediate attention is required to prevent service outage." ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

ex:ConfigChangeEvent a noria:EventRecord ;
    rdfs:label "Configuration Change on Web Server 01" ;
    rdfs:comment "An event record detailing a configuration change applied to Web Server 01, specifically an Apache tuning parameter update." ;
    dcterms:identifier "CONFIG-WS01-20240422-001"^^xsd:string ;
    noria:loggingTime "2024-04-22T10:30:00Z"^^xsd:dateTime ;
    noria:logText "Apache configuration updated by jsmith: MaxClients increased to 256."^^xsd:string ;
    noria:logOriginatingManagedObject ex:WebServer01 ;
    noria:logOriginatingAgent ex:JaneSmith ;
    noria:logOriginatingManagementSystem ex:ConfigurationManagementSystem .

ex:LinkDownEvent a noria:EventRecord ;
    rdfs:label "Network Link Down Alert on Core Router 01" ;
    rdfs:comment "An event indicating that a critical network link on Core Router 01 has gone down, potentially impacting external connectivity." ;
    dcterms:identifier "ALERT-CR01-LINKDOWN-20240423-002"^^xsd:string ;
    noria:loggingTime "2024-04-23T14:05:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1 on CoreRouter01 changed state to down."^^xsd:string ;
    noria:logOriginatingManagedObject ex:CoreRouter01Eth0 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystem ;
    noria:alarmSeverity ex:CriticalSeverity ;
    noria:alarmProposedRepairAction ex:NetworkTroubleshootingProcedure .

ex:OSPatchAppliedEvent a noria:EventRecord ;
    rdfs:label "OS Patch Applied on Web Server 02" ;
    rdfs:comment "An event confirming the successful application of an OS security patch on Web Server 02 by an automated bot." ;
    dcterms:identifier "PATCH-WS02-20240424-001"^^xsd:string ;
    noria:loggingTime "2024-04-24T03:15:00Z"^^xsd:dateTime ;
    noria:logText "Security patch KB123456 applied successfully to webserver02.example.com."^^xsd:string ;
    noria:logOriginatingManagedObject ex:WebServer02 ;
    noria:logOriginatingManagementSystem ex:PatchManagementSystem ;
    noria:logOriginatingAgent ex:OperationsTeamBot .

ex:WebServer01RestartLog a noria:EventRecord ;
    rdfs:label "WebServer01 Restart Log" ;
    rdfs:comment "Log entry for the restart command executed on WebServer01 as part of incident resolution." ;
    dcterms:identifier "LOG-WS01-RESTART-20240423-001"^^xsd:string ;
    noria:loggingTime "2024-04-23T14:20:00Z"^^xsd:dateTime ;
    noria:logText "Command 'systemctl restart apache2' executed on webserver01.example.com by jdoe."^^xsd:string ;
    noria:logOriginatingManagedObject ex:WebServer01 ;
    noria:logOriginatingAgent ex:JohnDoe ;
    dcterms:type <kos/Notification/EventType/commandExecution> .

ex:TT_StatusChange_InProgress a noria:EventRecord ;
    rdfs:label "TT Status Change to In Progress" ;
    rdfs:comment "Event record for the status change of Trouble Ticket TT-20240423-001 to In Progress." ;
    dcterms:identifier "TT-STATUS-20240423-001-INPROG"^^xsd:string ;
    noria:loggingTime "2024-04-23T14:05:00Z"^^xsd:dateTime ;
