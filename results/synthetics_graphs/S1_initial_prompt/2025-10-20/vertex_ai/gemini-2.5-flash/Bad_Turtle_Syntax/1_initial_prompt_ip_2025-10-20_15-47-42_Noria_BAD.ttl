@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix org: <http://www.w3.org/ns/org#> .
@prefix pep: <https://w3id.org/pep/>.
@prefix bot:  <https://w3id.org/bot#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix ex: <http://example.com/noria-kg/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

# =============================================================================
# 1. Organizational Units and Agents
# =============================================================================

ex:OrangeCorp a org:Organization ;
    rdfs:label "Orange Corporation" ;
    rdfs:comment "The main organization managing all IT infrastructure and services for example.com." .

ex:OperationsTeam a org:OrganizationalUnit ;
    rdfs:label "Operations Team" ;
    rdfs:comment "Team responsible for the day-to-day operation and maintenance of IT services, ensuring high availability and performance." ;
    org:unitOf ex:OrangeCorp ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:HotlineContactMethod ;
    noria:agentInstructions "For critical issues, use the dedicated hotline (ext. 1234). For non-critical, open a ticket in the Ticketing System."^^xsd:string .

ex:DevelopmentTeam a org:OrganizationalUnit ;
    rdfs:label "Development Team" ;
    rdfs:comment "Team responsible for developing and deploying new features and applications, and maintaining existing codebases." ;
    org:unitOf ex:OrangeCorp ;
    noria:agentWorkingHours "9:00 AM - 5:30 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:EmailContactMethod ;
    noria:agentInstructions "Prefer email for non-urgent requests. For code reviews, use the internal Git platform."^^xsd:string .

ex:NetworkTeam a org:OrganizationalUnit ;
    rdfs:label "Network Team" ;
    rdfs:comment "Team responsible for managing the core network infrastructure, including routers, switches, and firewalls." ;
    org:unitOf ex:OrangeCorp ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:HotlineContactMethod ;
    noria:agentInstructions "For network emergencies, call directly (ext. 5678). Otherwise, open a ticket in the Ticketing System."^^xsd:string .

ex:JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe" ;
    rdfs:comment "Lead Engineer in the Operations Team, responsible for critical application support." ;
    org:memberOf ex:OperationsTeam ;
    foaf:holdsAccount ex:JohnDoeCUid ;
    noria:agentWorkingHours "8:30 AM - 6:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent matters, otherwise email."^^xsd:string .

ex:JohnDoeCUid a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID" ;
    rdfs:comment "Unique identifier for John Doe within the corporate IT system, used for authentication and access control." ;
    foaf:accountName "jdoe"@en ;
    observable:accountLogin "jdoe"@en ;
    observable:accountIdentifier "JD001"^^xsd:string .

ex:JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Senior Developer in the Development Team, specializing in front-end applications." ;
    org:memberOf ex:DevelopmentTeam ;
    foaf:holdsAccount ex:JaneSmithCUid ;
    noria:agentWorkingHours "9:00 AM - 5:30 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Prefer email for non-urgent requests. For code reviews, use Git platform."^^xsd:string .

ex:JaneSmithCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID" ;
    rdfs:comment "Unique identifier for Jane Smith within the corporate IT system." ;
    foaf:accountName "jsmith"@en ;
    observable:accountLogin "jsmith"@en ;
    observable:accountIdentifier "JS002"^^xsd:string .

ex:PeterJones a foaf:Person, foaf:Agent ;
    rdfs:label "Peter Jones" ;
    rdfs:comment "Network Engineer in the Network Team, responsible for router and switch configurations." ;
    org:memberOf ex:NetworkTeam ;
    foaf:holdsAccount ex:PeterJonesCUid ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "For network emergencies, call directly. Otherwise, open a ticket."^^xsd:string .

ex:PeterJonesCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Peter Jones's Corporate User ID" ;
    rdfs:comment "Unique identifier for Peter Jones within the corporate IT system." ;
    foaf:accountName "pjones"@en ;
    observable:accountLogin "pjones"@en ;
    observable:accountIdentifier "PJ003"^^xsd:string .

ex:OperationsTeamBot a foaf:Agent ;
    rdfs:label "Operations Team Bot" ;
    rdfs:comment "Automated agent performing routine operational tasks such as patch deployments and system restarts." .

ex:EmailContactMethod a skos:Concept ;
    rdfs:label "Email Contact Method" ;
    rdfs:comment "Preferred contact method via email." ;
    skos:inScheme <kos/org/agent-contact-method> .

ex:HotlineContactMethod a skos:Concept ;
    rdfs:label "Hotline Contact Method" ;
    rdfs:comment "Preferred contact method via dedicated hotline for urgent issues." ;
    skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# 2. Location
# =============================================================================

ex:DataCenterA a bot:Site ;
    rdfs:label "Data Center A" ;
    rdfs:comment "Primary data center for hosting critical applications and infrastructure." ;
    noria:siteId "DCA01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    bot:containsZone ex:ServerRoom1 .

ex:ServerRoom1 a noria:Room ;
    rdfs:label "Server Room 1" ;
    rdfs:comment "A dedicated server room within Data Center A, housing racks of servers and network equipment." ;
    bot:containsZone ex:Rack1A, ex:Rack1B .

ex:Rack1A a noria:Locus ;
    rdfs:label "Rack 1A" ;
    rdfs:comment "Specific rack location within Server Room 1, used for web and database servers." ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

ex:Rack1B a noria:Locus ;
    rdfs:label "Rack 1B" ;
    rdfs:comment "Specific rack location within Server Room 1, used for core network equipment." ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

# =============================================================================
# 3. Applications and Services
# =============================================================================

ex:CustomerPortalApp a noria:Application ;
    rdfs:label "Customer Portal Application" ;
    rdfs:comment "The main web application for customer interaction, providing account management and service access." ;
    noria:applicationModelIdentifier "CP-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CPORTAL"^^xsd:string ;
    noria:applicationType ex:WebAppType ;
    noria:applicationBusinessImportance ex:HighImportance ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Online Customer Services"^^xsd:string .

ex:WebAppType a skos:Concept ;
    rdfs:label "Web Application Type" ;
    rdfs:comment "Type of application: Web Application." ;
    skos:inScheme <kos/application/type> .

ex:HighImportance a skos:Concept ;
    rdfs:label "High Business Importance" ;
    rdfs:comment "Business importance level: High, indicating critical impact on business operations if unavailable." ;
    skos:inScheme <kos/application/business-importance> .

ex:CustomerPortalProdModule a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module" ;
    rdfs:comment "The live production instance of the Customer Portal application, serving real customer traffic." ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CP-V2_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:OperationsTeam ;
    noria:applicationModuleAdministrationLeader ex:JohnDoe ;
    noria:applicationModuleSupportTeam ex:OperationsTeam ;
    noria:applicationModuleSupportLeader ex:JohnDoe ;
    noria:applicationModuleHotlineEnabled true^^xsd:boolean ;
    noria:applicationModuleSlaLevel ex:SLA_Gold ;
    noria:applicationModuleSlaLevelDate "2023-01-15T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleStatus ex:StatusInProduction ;
    noria:applicationModuleRelatedParty ex:OperationsTeam ;
    noria:applicationModuleSupportGroup ex:OperationsTeam ;
    noria:applicationModuleHotlineGroup ex:OperationsTeam .

ex:CustomerPortalStagingModule a noria:ApplicationModule ;
    rdfs:label "Customer Portal Staging Module" ;
    rdfs:comment "The staging instance of the Customer Portal application, used for pre-production testing and validation." ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CP-V2_STAGING"^^xsd:string ;
    noria:applicationModuleIdentifier "STAGING"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:DevelopmentTeam ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith ;
    noria:applicationModuleHotlineEnabled false^^xsd:boolean ;
    noria:applicationModuleStatus ex:StatusInDevelopment ;
    noria:applicationModuleRelatedParty ex:DevelopmentTeam ;
    noria:applicationModuleSupportGroup ex:DevelopmentTeam .

ex:CustomerPortalDevModule a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module" ;
    rdfs:comment "The development instance of the Customer Portal application, used by developers for feature implementation." ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CP-V2_DEV"^^xsd:string ;
    noria:applicationModuleIdentifier "DEV"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:DevelopmentTeam ;
    noria:applicationModuleAdministrationLeader ex:JaneSmith ;
    noria:applicationModuleHotlineEnabled false^^xsd:boolean ;
    noria:applicationModuleStatus ex:StatusInDevelopment ;
    noria:applicationModuleRelatedParty ex:DevelopmentTeam ;
    noria:applicationModuleSupportGroup ex:DevelopmentTeam .

ex:SLA_Gold a skos:Concept ;
    rdfs:label "SLA Gold Level" ;
    rdfs:comment "Service Level Agreement: Gold, indicating highest priority and availability requirements." ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

ex:StatusInProduction a skos:Concept ;
    rdfs:label "In Production Status" ;
    rdfs:comment "Application module status: Currently running in a production environment." ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

ex:StatusInDevelopment a skos:Concept ;
    rdfs:label "In Development Status" ;
    rdfs:comment "Application module status: Currently under active development or testing." ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

ex:WebAccessService a noria:Service ;
    rdfs:label "Web Access Service" ;
    rdfs:comment "Provides external web access to the Customer Portal, handling HTTP/HTTPS traffic." ;
    noria:serviceType ex:CustomerFacingServiceType ;
    seas:subSystemOf ex:CustomerPortalProdModule, ex:LoadBalancer01 .

ex:CustomerFacingServiceType a skos:Concept ;
    rdfs:label "Customer Facing Service Type" ;
    rdfs:comment "Type of service: Directly consumed by end-customers." ;
    skos:inScheme <kos/service/type> .

ex:DatabaseService a noria:Service ;
    rdfs:label "Database Service" ;
    rdfs:comment "Provides database access for the Customer Portal Production Module, ensuring data persistence and retrieval." ;
    noria:serviceType ex:ResourceFacingServiceType ;
    seas:subSystemOf ex:CustomerPortalProdModule, ex:DBServer01 .

ex:ResourceFacingServiceType a skos:Concept ;
    rdfs:label "Resource Facing Service Type" ;
    rdfs:comment "Type of service: Internal service, not directly exposed to end-customers." ;
    skos:inScheme <kos/service/type> .

ex:MonitoringSystem a noria:Application ;
    rdfs:label "Monitoring System" ;
    rdfs:comment "Application responsible for collecting metrics, logs, and generating alerts from IT infrastructure." ;
    noria:applicationShortIdentifier "MONSYS"^^xsd:string .

ex:ConfigurationManagementSystem a noria:Application ;
    rdfs:label "Configuration Management System" ;
    rdfs:comment "Application used for managing and deploying configurations across servers and network devices." ;
    noria:applicationShortIdentifier "CMS"^^xsd:string .

ex:PatchManagementSystem a noria:Application ;
    rdfs:label "Patch Management System" ;
    rdfs:comment "Application for managing and deploying software patches and updates to servers." ;
    noria:applicationShortIdentifier "PMS"^^xsd:string .

ex:TicketingSystem a noria:Application ;
    rdfs:label "Ticketing System" ;
    rdfs:comment "Application used for managing trouble tickets and change requests, centralizing incident and change workflows." ;
    noria:applicationShortIdentifier "TKSYS"^^xsd:string .

# =============================================================================
# 4. Resources and Network Components
# =============================================================================

ex:WebServer01 a noria:Resource ;
    rdfs:label "Web Server 01" ;
    rdfs:comment "A physical server hosting the Customer Portal production module, responsible for serving web content." ;
    noria:resourceLogisticId "WS01-LOG-ID"^^xsd:string ;
    noria:resourceHostName "webserver01.example.com"^^xsd:string ;
    noria:resourceProductModel ex:HPProLiantDL380 ;
    noria:resourceType ex:ServerResourceType ;
    noria:resourceSerialNumber "SN-WS01-XYZ"^^xsd:string ;
    noria:resourceUsageState ex:InUseLifecycleState ;
    noria:resourceInstallationDate "2022-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalProdModule ;
    noria:locatedAtLocus ex:Rack1A ;
    noria:resourceManagementIPAddress ex:WebServer01MgmtIP ;
    noria:resourceManagedBy ex:OperationsTeam ;
    noria:clusterController ex:WebServerCluster ;
    seas:subSystemOf ex:CustomerPortalProdModule .

ex:WebServer02 a noria:Resource ;
    rdfs:label "Web Server 02" ;
    rdfs:comment "Another physical server hosting the Customer Portal production module, providing redundancy and load distribution." ;
    noria:resourceLogisticId "WS02-LOG-ID"^^xsd:string ;
    noria:resourceHostName "webserver02.example.com"^^xsd:string ;
    noria:resourceProductModel ex:HPProLiantDL380 ;
    noria:resourceType ex:ServerResourceType ;
    noria:resourceSerialNumber "SN-WS02-ABC"^^xsd:string ;
    noria:resourceUsageState ex:InUseLifecycleState ;
    noria:resourceInstallationDate "2022-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalProdModule ;
    noria:locatedAtLocus ex:Rack1A ;
    noria:resourceManagementIPAddress ex:WebServer02MgmtIP ;
    noria:resourceManagedBy ex:OperationsTeam ;
    noria:clusterController ex:WebServerCluster ;
    seas:subSystemOf ex:CustomerPortalProdModule .

ex:DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01" ;
    rdfs:comment "Database server for the Customer Portal production module, storing all application data." ;
    noria:resourceLogisticId "DB01-LOG-ID"^^xsd:string ;
    noria:resourceHostName "dbserver01.example.com"^^xsd:string ;
    noria:resourceProductModel ex:DellPowerEdgeR740 ;
    noria:resourceType ex:DatabaseResourceType ;
    noria:resourceSerialNumber "SN-DB01-DEF"^^xsd:string ;
    noria:resourceUsageState ex:InUseLifecycleState ;
    noria:resourceInstallationDate "2022-04-15T11:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalProdModule ;
    noria:locatedAtLocus ex:Rack1A ;
    noria:resourceManagementIPAddress ex:DBServer01MgmtIP ;
    noria:resourceManagedBy ex:OperationsTeam ;
    seas:subSystemOf ex:CustomerPortalProdModule .

ex:LoadBalancer01 a noria:Resource ;
    rdfs:label "Load Balancer 01" ;
    rdfs:comment "Load balancer distributing incoming traffic to web servers for the Web Access Service, ensuring high availability and performance." ;
    noria:resourceLogisticId "LB01-LOG-ID"^^xsd:string ;
    noria:resourceHostName "loadbalancer01.example.com"^^xsd:string ;
    noria:resourceProductModel ex:F5BigIP ;
    noria:resourceType ex:LoadBalancerResourceType ;
    noria:resourceSerialNumber "SN-LB01-GHI"^^xsd:string ;
    noria:resourceUsageState ex:InUseLifecycleState ;
    noria:resourceInstallationDate "2022-02-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:WebAccessService ;
    noria:locatedAtLocus ex:Rack1A ;
    noria:resourceManagementIPAddress ex:LoadBalancer01MgmtIP ;
    noria:resourceManagedBy ex:OperationsTeam ;
    seas:subSystemOf ex:WebAccessService .

ex:CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01" ;
    rdfs:comment "Main router for Data Center A, handling internal and external network traffic, acting as a gateway." ;
    noria:resourceLogisticId "CR01-LOG-ID"^^xsd:string ;
    noria:resourceHostName "corerouter01.example.com"^^xsd:string ;
    noria:resourceProductModel ex:CiscoASR9K ;
    noria:resourceType ex:RouterResourceType ;
    noria:resourceSerialNumber "SN-CR01-JKL"^^xsd:string ;
    noria:resourceUsageState ex:InUseLifecycleState ;
    noria:resourceInstallationDate "2021-01-10T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack1B ;
    noria:resourceManagementIPAddress ex:CoreRouter01MgmtIP ;
    noria:resourceManagedBy ex:NetworkTeam .

ex:VirtualMachine01 a noria:Resource ;
    rdfs:label "Virtual Machine 01" ;
    rdfs:comment "A virtual machine running on Web Server 01, hosting a microservice for the Customer Portal." ;
    noria:resourceHostName "vm01.example.com"^^xsd:string ;
    noria:resourceProductModel ex:VMwareESXi ;
    noria:resourceType ex:VirtualMachineResourceType ;
    noria:resourceSerialNumber "VM-WS01-001"^^xsd:string ;
    noria:resourceUsageState ex:InUseLifecycleState ;
    noria:resourceInstallationDate "2023-06-01T14:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalProdModule ;
    seas:subSystemOf ex:WebServer01 ;
    noria:resourceManagedBy ex:OperationsTeam ;
    noria:virtualServerStatus ex:RunningOperationalState .

ex:WebServerCluster a noria:Resource ;
    rdfs:label "Web Server Cluster" ;
    rdfs:comment "A logical cluster of web servers (WebServer01, WebServer02) configured for high availability and load balancing." ;
    noria:resourceType ex:ServerClusterResourceType ;
    noria:resourceManagedBy ex:OperationsTeam .

ex:HPProLiantDL380 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380" ;
    rdfs:comment "Product model for HP ProLiant DL380 servers, a common enterprise-grade server." ;
    noria:productManufacturedBy ex:HPE .

ex:DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740" ;
    rdfs:comment "Product model for Dell PowerEdge R740 servers, known for performance and scalability." ;
    noria:productManufacturedBy ex:Dell .

ex:F5BigIP a noria:ProductModel ;
    rdfs:label "F5 BIG-IP" ;
    rdfs:comment "Product model for F5 BIG-IP load balancers, providing advanced traffic management." ;
    noria:productManufacturedBy ex:F5Networks .

ex:CiscoASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series" ;
    rdfs:comment "Product model for Cisco ASR 9000 series routers, high-performance edge routers." ;
    noria:productManufacturedBy ex:Cisco .

ex:VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi" ;
    rdfs:comment "Virtualization platform product model, enabling multiple virtual machines on a single physical server." ;
    noria:productManufacturedBy ex:VMware .

ex:HPE a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise" ;
    rdfs:comment "Manufacturer of HP ProLiant servers and other enterprise IT solutions." .

ex:Dell a org:Organization ;
    rdfs:label "Dell Technologies" ;
    rdfs:comment "Manufacturer of Dell PowerEdge servers and a wide range of IT products." .

ex:F5Networks a org:Organization ;
    rdfs:label "F5 Networks" ;
    rdfs:comment "Manufacturer of application delivery networking and security products." .

ex:Cisco a org:Organization ;
    rdfs:label "Cisco Systems" ;
    rdfs:comment "Leading manufacturer of networking hardware and software." .

ex:VMware a org:Organization ;
    rdfs:label "VMware Inc." ;
    rdfs:comment "Pioneer and leader in virtualization software and cloud infrastructure." .

ex:ServerResourceType a skos:Concept ;
    rdfs:label "Server Resource Type" ;
    rdfs:comment "Type of resource: Physical Server." ;
    skos:inScheme <kos/Resource/type> .

ex:DatabaseResourceType a skos:Concept ;
    rdfs:label "Database Server Resource Type" ;
    rdfs:comment "Type of resource: Dedicated Database Server." ;
    skos:inScheme <kos/Resource/type> .

ex:LoadBalancerResourceType a skos:Concept ;
    rdfs:label "Load Balancer Resource Type" ;
    rdfs:comment "Type of resource: Network Load Balancer." ;
    skos:inScheme <kos/Resource/type> .

ex:RouterResourceType a skos:Concept ;
    rdfs:label "Router Resource Type" ;
    rdfs:comment "Type of resource: Network Router." ;
    skos:inScheme <kos/Resource/type> .

ex:VirtualMachineResourceType a skos:Concept ;
    rdfs:label "Virtual Machine Resource Type" ;
    rdfs:comment "Type of resource: Virtual Machine." ;
    skos:inScheme <kos/Resource/type> .

ex:ServerClusterResourceType a skos:Concept ;
    rdfs:label "Server Cluster Resource Type" ;
    rdfs:comment "Type of resource: Logical Server Cluster." ;
    skos:inScheme <kos/Resource/type> .

ex:InUseLifecycleState a skos:Concept ;
    rdfs:label "In Use Lifecycle State" ;
    rdfs:comment "Resource lifecycle state: Currently active and in production use." ;
    skos:inScheme <kos/Resource/LifecycleState> .

ex:WebServer01MgmtIP a observable:IPAddress ;
    rdfs:label "Web Server 01 Management IP" ;
    rdfs:comment "Management IP address for remote administration of Web Server 01." ;
    observable:ipAddressValue "192.168.1.10"^^xsd:string .

ex:WebServer02MgmtIP a observable:IPAddress ;
    rdfs:label "Web Server 02 Management IP" ;
    rdfs:comment "Management IP address for remote administration of Web Server 02." ;
    observable:ipAddressValue "192.168.1.11"^^xsd:string .

ex:DBServer01MgmtIP a observable:IPAddress ;
    rdfs:label "Database Server 01 Management IP" ;
    rdfs:comment "Management IP address for remote administration of Database Server 01." ;
    observable:ipAddressValue "192.168.1.20"^^xsd:string .

ex:LoadBalancer01MgmtIP a observable:IPAddress ;
    rdfs:label "Load Balancer 01 Management IP" ;
    rdfs:comment "Management IP address for remote administration of Load Balancer 01." ;
    observable:ipAddressValue "192.168.1.5"^^xsd:string .

ex:CoreRouter01MgmtIP a observable:IPAddress ;
    rdfs:label "Core Router 01 Management IP" ;
    rdfs:comment "Management IP address for remote administration of Core Router 01." ;
    observable:ipAddressValue "10.0.0.1"^^xsd:string .

ex:RunningOperationalState a skos:Concept ;
    rdfs:label "Running Operational State" ;
    rdfs:comment "Operational state: The virtual machine is currently running and active." ;
    skos:inScheme <kos/Resource/OperationalState> .

# Network Interfaces
ex:WebServer01Eth0 a noria:NetworkInterface ;
    rdfs:label "Web Server 01 Ethernet 0" ;
    rdfs:comment "Primary network interface for Web Server 01, connected to the internal network segment." ;
    noria:networkInterfaceOf ex:WebServer01 ;
    noria:networkInterfaceDescription "Main production interface"^^xsd:string ;
    noria:networkInterfaceType ex:PhysicalInterfaceType ;
    noria:networkInterfaceAdministrativeStatus ex:UpAdministrativeState ;
    noria:networkInterfaceOperationalStatus ex:UpOperationalState ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -6 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

ex:WebServer02Eth0 a noria:NetworkInterface ;
    rdfs:label "Web Server 02 Ethernet 0" ;
    rdfs:comment "Primary network interface for Web Server 02, connected to the internal network segment." ;
    noria:networkInterfaceOf ex:WebServer02 ;
    noria:networkInterfaceDescription "Main production interface"^^xsd:string ;
    noria:networkInterfaceType ex:PhysicalInterfaceType ;
    noria:networkInterfaceAdministrativeStatus ex:UpAdministrativeState ;
    noria:networkInterfaceOperationalStatus ex:UpOperationalState ;
    noria:networkInterfaceLaserTxOpticalPower -4 ;
    noria:networkInterfaceLaserRxOpticalPower -7 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -6 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

ex:DBServer01Eth0 a noria:NetworkInterface ;
    rdfs:label "Database Server 01 Ethernet 0" ;
    rdfs:comment "Primary network interface for DB Server 01, connected to the database network segment." ;
    noria:networkInterfaceOf ex:DBServer01 ;
    noria:networkInterfaceDescription "Main production interface"^^xsd:string ;
    noria:networkInterfaceType ex:PhysicalInterfaceType ;
    noria:networkInterfaceAdministrativeStatus ex:UpAdministrativeState ;
    noria:networkInterfaceOperationalStatus ex:UpOperationalState ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -4 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -8 .

