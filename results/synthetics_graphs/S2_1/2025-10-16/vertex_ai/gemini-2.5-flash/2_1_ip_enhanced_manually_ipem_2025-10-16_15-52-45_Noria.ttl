# Synthetic Knowledge Graph based on NORIA Ontology

# --- Organizational Entities ---

<https://w3id.org/noria/data/org/GlobalTelcoCorp>
    a org:Organization ;
    rdfs:label "Global Telco Corp"@en ;
    rdfs:comment "A multinational telecommunications and IT services provider."@en ;
    noria:agentWorkingHours "24/7 Global Operations"^^xsd:string ;
    noria:agentInstructions "Refer to regional contact matrix for specific inquiries."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/InternalPortal> ;
    .

<https://w3id.org/noria/data/org/NetworkOperationsCenter>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "Centralized unit responsible for monitoring and managing network infrastructure."@en ;
    org:unitOf <https://w3id.org/noria/data/org/GlobalTelcoCorp> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "Escalate critical network alarms immediately via phone. Use ticketing system for routine maintenance."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    .

<https://w3id.org/noria/data/org/ApplicationSupportL2>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support team for critical business applications."@en ;
    org:unitOf <https://w3id.org/noria/data/org/GlobalTelcoCorp> ;
    noria:agentWorkingHours "08:00-20:00 Mon-Sun"^^xsd:string ;
    noria:agentInstructions "All application-related incidents must be logged in the ITSM system. On-call rotation for off-hours."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    .

<https://w3id.org/noria/data/org/SecurityOperationsCenter>
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team dedicated to monitoring, detecting, analyzing, and responding to cybersecurity incidents."@en ;
    org:unitOf <https://w3id.org/noria/data/org/GlobalTelcoCorp> ;
    noria:agentWorkingHours "24/7 Threat Monitoring"^^xsd:string ;
    noria:agentInstructions "Report all suspected security incidents to the SOC hotline. Do not attempt to remediate without guidance."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Hotline> ;
    .

