# --- Organizational Entities ---
:Org_GlobalTechSolutions
    a org:Organization ;
    rdfs:label "Global Tech Solutions Inc."@en ;
    rdfs:comment "A leading global technology company."@en ;
.

:Org_CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en ;
.

:Org_ISP_A
    a org:Organization ;
    rdfs:label "Internet Service Provider A"@en ;
    rdfs:comment "External ISP providing internet connectivity."@en ;
.

:Org_ISP_B
    a org:Organization ;
    rdfs:label "Internet Service Provider B"@en ;
    rdfs:comment "External ISP providing backup internet connectivity."@en ;
.

:OrgUnit_ITOperations
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The central department responsible for IT infrastructure and services."@en ;
    org:unitOf :Org_GlobalTechSolutions ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

:OrgUnit_NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team managing network infrastructure."@en ;
    org:unitOf :OrgUnit_ITOperations ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentInstructions "For critical network issues, use emergency hotline."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

:Person_AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer, responsible for core network operations."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    org:memberOf :OrgUnit_NetworkTeam ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Email for non-urgent matters, phone for urgent."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

:Person_BobJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "IT Operations Manager, overseeing all IT services."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf :OrgUnit_ITOperations ;
    noria:agentWorkingHours "08:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "All requests must go through Alice Smith first."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

:CUid_AliceSmith_NetOps
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith Network Operations Account"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith in Network Operations, used for system access."@en ;
    foaf:accountName "asmith_netops"^^xsd:string ;
    foaf:holdsAccount :Person_AliceSmith ;
.

# --- Location Entities ---
:Site_DataCenter_Paris
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris, France."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string ;
.

:Room_ServerRoom_A1
    a noria:Room ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "Main server room within the Paris Data Center, housing critical infrastructure."@en ;
    bot:hasSpace :Site_DataCenter_Paris ;
.

:Locus_Rack_R12
    a noria:Locus ;
    rdfs:label "Rack R12, Server Room A1"@en ;
    rdfs:comment "Specific location for rack R12 within Server Room A1, containing network and server equipment."@en ;
    bot:containsZone :Room_ServerRoom_A1 ;
    noria:locusLine "L"^^xsd:string ;
    noria:locusRow "12"^^xsd:string ;
.

# --- Structural Elements ---
:ProductModel_Cisco_ASR9K
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series"@en ;
    rdfs:comment "Product model for Cisco ASR 9000 series routers, known for high performance."@en ;
    noria:productManufacturedBy :Org_CiscoSystems ;
.

:Resource_Router_Core1
    a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Primary core router in Paris Data Center, handling critical network traffic."@en ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceHostName "core-rtr-01.paris.gts.com"^^xsd:string ;
    noria:resourceSerialNumber "SN-RTR-001-XYZ"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://192.168.10.1> ;
    noria:resourceProductModel :ProductModel_Cisco_ASR9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy :OrgUnit_NetworkTeam ;
    noria:locatedAtLocus :Locus_Rack_R12 ;
    noria:resourceForApplication :App_GlobalWAN ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> ;
.

:Resource_Server_AppDB
    a noria:Resource ;
