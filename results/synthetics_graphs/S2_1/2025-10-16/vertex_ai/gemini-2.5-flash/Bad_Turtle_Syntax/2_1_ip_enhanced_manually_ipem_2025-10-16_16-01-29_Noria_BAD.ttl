:NetworkInterface_Core1_Eth0
    a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0"@en ;
    rdfs:comment "Primary Ethernet interface on Core Router 1, connected to ISP A."@en ;
    noria:networkInterfaceDescription "Uplink to ISP A"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceOf :Resource_Router_Core1 ;
    noria:networkInterfaceConnects :NetworkLink_Core1_ISP_A ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
