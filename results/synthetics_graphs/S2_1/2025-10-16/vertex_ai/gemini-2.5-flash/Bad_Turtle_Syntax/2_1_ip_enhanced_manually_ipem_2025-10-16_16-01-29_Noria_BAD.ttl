    rdfs:comment "Manages the server cluster, ensuring high availability and load balancing."@en ;
    noria:resourceHostName "cluster-mgr-01"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy :OrgUnit_ITOperations ;
.

