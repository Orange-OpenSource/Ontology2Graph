    rdfs:label "High Latency Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating unusually high network latency, potentially signaling a problem like congestion or link degradation."@en ;
    folio:hasCause "Network Congestion"^^xsd:string ;
.

:OperationPlan_TroubleshootLink
    a noria:OperationPlan ;
    rdfs:label "Troubleshoot Network Link Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network link issues, including physical layer checks."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_LinkDownDetected ;
    noria:operationPlanPostCondition :ActionPostCondition_LinkRestored ;
.

:OperationPlan_DBRestart
    a noria:OperationPlan ;
    rdfs:label "Database Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the application database in case of critical errors."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_DBErrorDetected ;
    noria:operationPlanPostCondition :ActionPostCondition_DBOperational ;
.

:OperationPlan_RouterUpgrade
    a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Procedure for upgrading router operating system software, including pre-checks and post-checks."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition :ActionPostCondition_SoftwareUpdated ;
.

:ActionPreCondition_LinkDownDetected
    a noria:ActionPreCondition ;
    rdfs:label "Link Down Detected"@en ;
    rdfs:comment "Pre-condition: a network link is reported as down by monitoring systems."@en ;
.

:ActionPostCondition_LinkRestored
    a noria:ActionPostCondition ;
    rdfs:label "Link Restored"@en ;
    rdfs:comment "Post-condition: the network link is operational again and traffic is flowing normally."@en ;
.

:ActionPreCondition_DBErrorDetected
    a noria:ActionPreCondition ;
    rdfs:label "Database Error Detected"@en ;
    rdfs:comment "Pre-condition: a critical database error is reported, indicating service degradation."@en ;
.

:ActionPostCondition_DBOperational
    a noria:ActionPostCondition ;
    rdfs:label "Database Operational"@en ;
    rdfs:comment "Post-condition: the database is fully operational and accessible, with no reported errors."@en ;
.

:ActionPreCondition_MaintenanceWindow
    a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Available"@en ;
    rdfs:comment "Pre-condition: a scheduled maintenance window is active, allowing for disruptive changes."@en ;
.

:ActionPostCondition_SoftwareUpdated
    a noria:ActionPostCondition ;
    rdfs:label "Software Updated and Verified"@en ;
    rdfs:comment "Post-condition: router software is updated and verified operational, with all services restored."@en ;
.

