    rdfs:comment "Database server for critical applications, hosting customer data."@en ;
    noria:resourceLogisticId "LOG-SRV-005"^^xsd:string ;
    noria:resourceHostName "app-db-01.paris.gts.com"^^xsd:string ;
    noria:resourceSerialNumber "SN-SRV-005-ABC"^^xsd:string ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://10.0.0.5> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy :OrgUnit_ITOperations ;
    noria:locatedAtLocus :Locus_Rack_R12 ;
    noria:resourceForApplication :App_CustomerPortal ;
    noria:clusterController :Resource_ClusterMgr_01 ;
.

:Resource_ClusterMgr_01
    a noria:Resource ;
