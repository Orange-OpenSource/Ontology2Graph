# --- Procedural Elements ---

<anomalypattern/high_cpu_low_traffic>
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "High CPU, Low Traffic Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating potential resource exhaustion or misconfiguration: high CPU usage with unexpectedly low network traffic."@en ;
    folio:hasCause "Misconfigured routing policy"^^xsd:string ;
.

<operationplan/interface_troubleshooting_guide>
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Network Interface Troubleshooting Guide"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    noria:operationPlanPreCondition <actionprecondition/interface_down_alert> ;
    noria:operationPlanPostCondition <actionpostcondition/interface_restored_traffic_flow> ;
.

<actionprecondition/interface_down_alert>
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Alert Received"@en ;
    rdfs:comment "Pre-condition: An alert indicating a network interface is down has been received."@en ;
.

<actionpostcondition/interface_restored_traffic_flow>
    a noria:ActionPostCondition ;
    rdfs:label "Interface Restored and Traffic Flowing"@en ;
    rdfs:comment "Post-condition: The network interface is up, and traffic is flowing as expected."@en ;
.

<action/corrective_action_router_restart>
    a pep:CorrectiveMaintenanceAction ;
    rdfs:label "Corrective Action: Router Interface Restart"@en ;
    rdfs:comment "An action taken to restart a network interface."@en ;
    noria:actionCorrelatedOperationPlan <operationplan/interface_troubleshooting_guide> ;
    pep:hasCommand "interface GigabitEthernet0/0/0; shutdown; no shutdown"^^xsd:string ;
    pep:hasResult "Interface status changed to up."^^xsd:string ;
    pep:madeBy <agent/john_doe> ;
.

<action/change_action_software_upgrade>
    a pep:ChangeAction ;
    rdfs:label "Change Action: Software Upgrade Execution"@en ;
    rdfs:comment "Execution of the software upgrade procedure on Core Router 01."@en ;
    noria:actionCorrelatedOperationPlan <operationplan/router_software_upgrade_procedure> ;
    pep:hasCommand "install activate file bootflash:asr9k-os-px-7.3.2.tar"^^xsd:string ;
    pep:hasResult "Software upgrade completed successfully."^^xsd:string ;
    pep:madeBy <org/network_ops_team> ;
.

<operationplan/router_software_upgrade_procedure>
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading router operating system software."@en ;
    noria:operationPlanPreCondition <actionprecondition/maintenance_window_approved> ;
    noria:operationPlanPostCondition <actionpostcondition/router_operational_new_version> ;
.

<actionprecondition/maintenance_window_approved>
    a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Approved"@en ;
    rdfs:comment "Pre-condition: A maintenance window for the change has been approved."@en ;
.

<actionpostcondition/router_operational_new_version>
    a noria:ActionPostCondition ;
    rdfs:label "Router Operational with New Version"@en ;
    rdfs:comment "Post-condition: Router is fully operational and running the new software version."@en ;
.

<pepcontainer/interface_restart_execution>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Interface Restart Execution Container"@en ;
    rdfs:comment "Container for the execution of the interface restart procedure."@en ;
.
