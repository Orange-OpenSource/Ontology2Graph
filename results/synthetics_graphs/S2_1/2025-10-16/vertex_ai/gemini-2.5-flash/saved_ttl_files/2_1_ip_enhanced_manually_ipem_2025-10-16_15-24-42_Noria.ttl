# Synthetic Knowledge Graph based on Noria.ttl schema

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix saref: <http://ontology.tno.nl/saref#>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix devopsprod: <http://w3id.org/devopsprod/> . # Corrected prefix for devopsprod
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# SKOS Concepts for controlled vocabularies
# =============================================================================

# Application Types
<kos/application/type/WebPlatform>
    a skos:Concept ;
    skos:prefLabel "Web Platform"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<kos/application/type/DatabaseService>
    a skos:Concept ;
    skos:prefLabel "Database Service"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

# Application Business Importance
<kos/application/business-importance/High>
    a skos:Concept ;
    skos:prefLabel "High"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

<kos/application/business-importance/Medium>
    a skos:Concept ;
    skos:prefLabel "Medium"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

# Application Module SLA Level
<https://w3id.org/noria/kos/application/sla-level/Gold>
    a skos:Concept ;
    skos:prefLabel "Gold SLA"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# Application Module Status
<https://w3id.org/noria/kos/application/status/Production>
    a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

# Service Types
<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:prefLabel "Customer Facing Service"@en ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    skos:prefLabel "Resource Facing Service"@en ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> .

# TroubleTicket Severity
<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    skos:prefLabel "Major"@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Minor>
    a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

# TroubleTicket Type
<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    skos:prefLabel "Failure"@en ;
    skos:inScheme <kos/TroubleTicket/type> .

# TroubleTicket Criticity
<kos/TroubleTicket/category/InterruptedService>
    a skos:Concept ;
    skos:prefLabel "Interrupted Service"@en ;
    skos:inScheme <kos/TroubleTicket/category> .

# TroubleTicket Priority
<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    skos:prefLabel "Priority 1"@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

# TroubleTicket Origin
<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    skos:prefLabel "Customer"@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

# TroubleTicket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    skos:prefLabel "Immediate Intervention"@en ;
    skos:inScheme <kos/TroubleTicket/urgency> .

# TroubleTicket Trouble Category
<kos/TroubleTicket/trouble-category/TotalBreakdown>
    a skos:Concept ;
    skos:prefLabel "Total Breakdown"@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

# TroubleTicket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks>
    a skos:Concept ;
    skos:prefLabel "Managed Backbone Networks"@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

# TroubleTicket Status
<kos/TroubleTicket/status/InProgress>
    a skos:Concept ;
    skos:prefLabel "In Progress"@en ;
    skos:inScheme <kos/TroubleTicket/status> .

# TroubleTicketNote Comment Type
<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    skos:prefLabel "Internal Comment"@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

# TroubleTicketNote Operation Type
<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    skos:prefLabel "Diagnosis"@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

# ChangeRequest Category
<kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    skos:prefLabel "Internal Intervention"@en ;
    skos:inScheme <kos/ChangeRequest/category> .

# ChangeRequest Type
<kos/ChangeRequest/type/StandardChange>
    a skos:Concept ;
    skos:prefLabel "Standard Change"@en ;
    skos:inScheme <kos/ChangeRequest/type> .

# ChangeRequest Cause
<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    skos:prefLabel "Software Upgrade"@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

# ChangeRequest Status
<kos/ChangeRequest/status/Scheduled>
    a skos:Concept ;
    skos:prefLabel "Scheduled"@en ;
    skos:inScheme <kos/ChangeRequest/status> .

# ChangeRequest Specification
<kos/ChangeRequest/specification/RoutineMaintenance>
    a skos:Concept ;
    skos:prefLabel "Routine Maintenance"@en ;
    skos:inScheme <kos/ChangeRequest/specification> .

# Resource Operational State
<kos/Resource/OperationalState/Up>
    a skos:Concept ;
    skos:prefLabel "Up"@en ;
    skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/OperationalState/Down>
    a skos:Concept ;
    skos:prefLabel "Down"@en ;
    skos:inScheme <kos/Resource/OperationalState> .

# Resource Administrative State
<kos/Resource/AdministrativeState/Enabled>
    a skos:Concept ;
    skos:prefLabel "Enabled"@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

<kos/Resource/AdministrativeState/Disabled>
    a skos:Concept ;
    skos:prefLabel "Disabled"@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

# Resource Type
<kos/Resource/type/Router>
    a skos:Concept ;
    skos:prefLabel "Network Router"@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Server>
    a skos:Concept ;
    skos:prefLabel "Application Server"@en ;
    skos:inScheme <kos/Resource/type> .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InProduction>
    a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical>
    a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Warning>
    a skos:Concept ;
    skos:prefLabel "Warning"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Agent Contact Method
<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:prefLabel "Email"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:prefLabel "Phone"@en ;
    skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Abstract Classes (defined for consistency, not instantiated directly)
# =============================================================================

noria:ProceduralObject
    a owl:Class ;
    rdfs:label "Procedural Object"@en ;
    rdfs:comment "An abstract class for objects related to procedures, plans, and patterns."@en ;
    rdfs:isDefinedBy noria: ;
.

noria:StructuralProperty
    a owl:Class ;
    rdfs:label "Structural Property"@en ;
    rdfs:comment "An abstract class for properties of structural elements."@en ;
    rdfs:subClassOf noria:Property ;
    rdfs:isDefinedBy noria: ;
.

# =============================================================================
# Synthetic Knowledge Graph Instances
# =============================================================================

# --- Organizational Entities ---

<agent/john_doe>
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee responsible for network operations."@en ;
    foaf:name "John Doe"^^xsd:string ;
    foaf:mbox "mailto:john.doe@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

<agent/jane_smith>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A team leader for application support."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    foaf:mbox "mailto:jane.smith@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

<org/network_ops_team>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing core network infrastructure."@en ;
    org:unitOf <org/it_department> ;
    org:hasMember <agent/john_doe> ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentInstructions "Escalate critical network issues to this team."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentManagesResource <resource/router_core_01> ;
    noria:agentManagesResource <networklink/isp_uplink_a> ;
.

<org/app_support_team>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing level 2 support for critical applications."@en ;
    org:unitOf <org/it_department> ;
    org:hasMember <agent/jane_smith> ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit tickets via the internal portal."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource <resource/app_server_01> ;
    noria:agentManagesResource <applicationmodule/web_portal_prod> ;
.

<org/it_department>
    a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department of the company."@en ;
    org:hasUnit <org/network_ops_team>, <org/app_support_team> ;
.

<cuid/john_doe_cuid>
    a noria:CorporateUserIdentifier, observable:UserAccount ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for John Doe within the corporate IT system."@en ;
    foaf:accountName "jdoe01"^^xsd:string ;
    foaf:accountServiceHomepage <https://intranet.example.com/profile/jdoe01> ;
    foaf:holdsAccount <agent/john_doe> ;
.

# --- Location Entities ---

<room/server_room_314>
    a noria:Room, bot:Space ;
    rdfs:label "Server Room 314"@en ;
    rdfs:comment "Main data center server room, located in Building A."@en ;
    bot:hasSpace <locus/rack_a05_u12> ;
.

<locus/rack_a05_u12>
    a noria:Locus, bot:Space ;
    rdfs:label "Rack A05, Unit 12"@en ;
    rdfs:comment "Specific location within Server Room 314 for network equipment."@en ;
    noria:locusLine "A05"^^xsd:string ;
    noria:locusRow "12"^^xsd:string ;
    bot:hasElement <resource/router_core_01> ;
.

<site/main_datacenter>
    a bot:Site, org:Site ;
    rdfs:label "Main Data Center Site"@en ;
    rdfs:comment "Primary data center facility for all IT operations."@en ;
    noria:siteId "DC-MAIN-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "USA"^^xsd:string ;
    bot:hasSpace <room/server_room_314> ;
.

# --- Structural Elements ---

<resource/router_core_01>
    a noria:Resource, seas:System, seas:CommunicationDevice, bot:Element, observable:Device, log:Host ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router for the corporate network."@en ;
    noria:resourceHostName "router-core-01.example.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-RTR-001"^^xsd:string ;
    noria:resourceSerialNumber "SN123456789"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/network_ops_team> ;
    noria:resourceProductModel <productmodel/cisco_asr9k> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus <locus/rack_a05_u12> ;
    noria:resourceManagementIPAddress <https://192.168.1.1/management> ;
    noria:resourceForApplication <application/corporate_network_infra> ;
    noria:clusterController <resource/cluster_manager_01> ;
.

<resource/app_server_01>
    a noria:Resource, seas:System, observable:Device, log:Host ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting the main web application."@en ;
    noria:resourceHostName "app-server-01.example.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-SRV-001"^^xsd:string ;
    noria:resourceSerialNumber "SN987654321"^^xsd:string ;
    noria:resourceInstallationDate "2023-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/app_support_team> ;
    noria:resourceProductModel <productmodel/hp_proliant_dl380> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus <locus/rack_a05_u12> ; # Assuming it's in the same rack for simplicity
    noria:resourceManagementIPAddress <https://10.0.0.10/management> ;
    noria:resourceForApplication <application/web_portal> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> ;
.

<resource/cluster_manager_01>
    a noria:Resource, seas:System, observable:Device, log:Host ;
    rdfs:label "Cluster Manager 01"@en ;
    rdfs:comment "Dedicated server managing the router cluster."@en ;
    noria:resourceHostName "cluster-mgr-01.example.com"^^xsd:string ;
    noria:resourceLogisticId "ASSET-CLM-001"^^xsd:string ;
    noria:resourceSerialNumber "SN555555555"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/network_ops_team> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
.

<productmodel/cisco_asr9k>
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series"@en ;
    rdfs:comment "Product model for Cisco Aggregation Services Routers."@en ;
    noria:productManufacturedBy <org/cisco_systems> ;
.

<productmodel/hp_proliant_dl380>
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380"@en ;
    rdfs:comment "Product model for HP ProLiant DL380 servers."@en ;
    noria:productManufacturedBy <org/hewlett_packard> ;
.

<org/cisco_systems>
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of networking hardware."@en ;
.

<org/hewlett_packard>
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of enterprise IT infrastructure."@en ;
.

<networkinterface/router_core_01_ge0_0_0>
    a noria:NetworkInterface, seas:CommunicationConnectionPoint, observable:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on Core Router 01"@en ;
    rdfs:comment "Uplink interface for Core Router 01."@en ;
    noria:networkInterfaceOf <resource/router_core_01> ;
    noria:networkInterfaceDescription "Uplink to ISP A"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int ;
    noria:networkInterfaceConnects <networklink/isp_uplink_a> ;
.

<networkinterface/app_server_01_eth0>
    a noria:NetworkInterface, seas:CommunicationConnectionPoint, observable:NetworkInterface ;
    rdfs:label "eth0 on Application Server 01"@en ;
    rdfs:comment "Primary network interface for Application Server 01."@en ;
    noria:networkInterfaceOf <resource/app_server_01> ;
    noria:networkInterfaceDescription "Main application traffic interface"^^xsd:string ;
    noria:networkInterfaceType "virtual"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects <networklink/server_to_switch_a> ;
.

<networklink/isp_uplink_a>
    a noria:NetworkLink, seas:CommunicationConnection ;
    rdfs:label "ISP Uplink A"@en ;
    rdfs:comment "Fiber optic link connecting Core Router 01 to ISP A."@en ;
    noria:networkLinkId "NL-ISP-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-01-10T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin <resource/router_core_01> ;
    noria:networkLinkTerminationResourceDestination <resource/isp_router_a> ;
    noria:networkLinkTerminationResource <resource/router_core_01>, <resource/isp_router_a> ;
.

<networklink/server_to_switch_a>
    a noria:NetworkLink, seas:CommunicationConnection ;
    rdfs:label "Server to Switch Link A"@en ;
    rdfs:comment "Ethernet link connecting Application Server 01 to the data center switch."@en ;
    noria:networkLinkId "NL-SRV-SW-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-02-28T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin <resource/app_server_01> ;
    noria:networkLinkTerminationResourceDestination <resource/datacenter_switch_01> ;
    noria:networkLinkTerminationResource <resource/app_server_01>, <resource/datacenter_switch_01> ;
.

<resource/isp_router_a>
    a noria:Resource, seas:System, seas:CommunicationDevice ;
    rdfs:label "ISP Router A"@en ;
    rdfs:comment "External router managed by ISP A."@en ;
    noria:resourceHostName "isp-router-a.isp.com"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Router> ;
.

<resource/datacenter_switch_01>
    a noria:Resource, seas:System, seas:CommunicationDevice ;
    rdfs:label "Data Center Switch 01"@en ;
    rdfs:comment "Core switch in the data center."@en ;
    noria:resourceHostName "dc-switch-01.example.com"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Router> ;
.

<structuralobservable/router_interface_status>
    a noria:StructuralObservable ;
    rdfs:label "Router Interface Status Observable"@en ;
    rdfs:comment "An observable property for a router interface's status."@en ;
    noria:structuralObservableOf <networkinterface/router_core_01_ge0_0_0> ;
.

# --- Functional Elements ---

<application/web_portal>
    a noria:Application, seas:System, observable:Application ;
    rdfs:label "Corporate Web Portal"@en ;
    rdfs:comment "The main web application for internal and external users."@en ;
    noria:applicationModelIdentifier "WEBPORTAL-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "WEBPORTAL"^^xsd:string ;
    noria:applicationType <kos/application/type/WebPlatform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Online Services"^^xsd:string ;
    noria:elementManagedBy <org/app_support_team> ;
.

<application/corporate_network_infra>
    a noria:Application, seas:System, observable:Application ;
    rdfs:label "Corporate Network Infrastructure"@en ;
    rdfs:comment "Represents the overall corporate network as an application."@en ;
    noria:applicationModelIdentifier "CORP-NET-V1"^^xsd:string ;
    noria:applicationNumericalIdentifier "2001"^^xsd:int ;
    noria:applicationShortIdentifier "CORPNET"^^xsd:string ;
    noria:applicationType <kos/application/type/DatabaseService> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "IT Infrastructure Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Network Operations"^^xsd:string ;
    noria:elementManagedBy <org/network_ops_team> ;
.

<applicationmodule/web_portal_prod>
    a noria:ApplicationModule, seas:System ;
    rdfs:label "Web Portal Production Module"@en ;
    rdfs:comment "The production instance of the Corporate Web Portal application."@en ;
    noria:applicationModuleOf <application/web_portal> ;
    noria:applicationModuleName "WEBPORTAL_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-01"^^xsd:string ;
    noria:applicationModuleAdministrationTeam <org/app_support_team> ;
