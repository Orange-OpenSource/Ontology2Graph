# --- Anomaly Patterns ---

<anomalypattern/high_cpu_low_traffic>
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "High CPU, Low Traffic Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating a potential resource exhaustion or stuck process: high CPU usage with unexpectedly low network traffic."@en .

# --- Operation Plans ---

<operationplan/interface_troubleshooting>
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing network interface issues."@en ;
    noria:operationPlanPreCondition <actionprecondition/interface_down_alert> ;
    noria:operationPlanPostCondition <actionpostcondition/interface_restored> .

<operationplan/server_restart>
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Application Server Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting an application server."@en ;
    noria:operationPlanPreCondition <actionprecondition/high_cpu_alert> ;
    noria:operationPlanPostCondition <actionpostcondition/cpu_normal> .

# --- Action Pre-conditions ---

<actionprecondition/interface_down_alert>
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Alert Received"@en ;
    rdfs:comment "Pre-condition: An alert indicating a network interface is down has been received."@en .

<actionprecondition/high_cpu_alert>
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Alert Received"@en ;
    rdfs:comment "Pre-condition: An alert indicating high CPU usage on a server has been received."@en .

# --- Action Post-conditions ---

<actionpostcondition/interface_restored>
    a noria:ActionPostCondition ;
    rdfs:label "Interface Operational"@en ;
    rdfs:comment "Post-condition: The network interface is confirmed to be operational."@en .

<actionpostcondition/cpu_normal>
    a noria:ActionPostCondition ;
    rdfs:label "CPU Usage Normal"@en ;
    rdfs:comment "Post-condition: CPU utilization has returned to normal levels."@en .

# --- Actions (Corrective Maintenance / Change Action) ---
# These are not explicitly defined as classes in Noria.ttl, but pep:ProcedureExecution is used.
# I'll create instances of pep:ProcedureExecution and link them.

<action/corrective_rtr_interface_reset>
    a pep:ProcedureExecution ;
    rdfs:label "Corrective Action: Router Interface Reset"@en ;
    rdfs:comment "Action taken to reset a router interface."@en ;
    noria:actionCorrelatedOperationPlan <operationplan/interface_troubleshooting> ;
    pep:madeBy <agent/john_doe> ;
    pep:hasCommand "interface GigabitEthernet0/0/1; shutdown; no shutdown"^^xsd:string ;
    pep:hasSimpleResult "Interface reset successfully."^^xsd:string .

<action/change_srv_software_update>
    a pep:ProcedureExecution ;
    rdfs:label "Change Action: Server Software Update"@en ;
    rdfs:comment "Action taken to update software on Application Server 01."@en ;
    noria:actionCorrelatedOperationPlan <operationplan/server_restart> ;
    pep:madeBy <agent/jane_smith> ;
    pep:hasCommand "sudo apt update && sudo apt upgrade -y"^^xsd:string ;
    pep:hasSimpleResult "Software updated and server restarted."^^xsd:string .

# Link actions to relevant dynamic elements
<troubleticket/tt_20240320_001>
    noria:troubleTicketPartyIntervention <action/corrective_rtr_interface_reset> .

<changerequest/cr_20240325_001>
    dcterms:relation <action/change_srv_software_update> . # Using dcterms:relation as a generic link for actions related to CR.

<eventrecord/log_rtr01_interface_down>
    noria:alarmMitigatedBy <action/corrective_rtr_interface_reset> .

# Example of noria:alarmMonitoredAttribute
<eventrecord/log_srv01_cpu_spike>
    noria:alarmMonitoredAttribute [
        a noria:StructuralObservable ;
        rdfs:label "CPU Usage Metric"@en ;
        rdfs:comment "Monitored attribute for CPU usage."@en ;
        noria:structuralElementObservableData "95"^^xsd:int ;
        noria:structuralObservableOf <resource/server_app_01>
    ] .

