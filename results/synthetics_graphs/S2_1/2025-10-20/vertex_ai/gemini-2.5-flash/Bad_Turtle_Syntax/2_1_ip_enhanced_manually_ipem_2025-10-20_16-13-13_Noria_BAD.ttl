# --- Event Records ---

<eventrecord/log_rtr01_interface_down>
    a noria:EventRecord, BBO:DocumentResource, pep:ProcedureExecution, observable:EventRecord, log:Event ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down."@en ;
    noria:loggingTime "2024-03-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject <resource/router_core_01> ;
    noria:logOriginatingManagementSystem <application/monitoring_platform> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <operationplan/interface_troubleshooting> .

<eventrecord/log_srv01_cpu_spike>
    a noria:EventRecord, BBO:DocumentResource, pep:ProcedureExecution, observable:EventRecord, log:Event ;
    rdfs:label "Server CPU Spike Event"@en ;
    rdfs:comment "Log entry indicating high CPU utilization on a server."@en ;
    noria:loggingTime "2024-03-20T11:15:30Z"^^xsd:dateTime ;
    noria:logText "CPU utilization exceeded 90% for 5 minutes on app-srv-01"^^xsd:string ;
    noria:logOriginatingManagedObject <resource/server_app_01> ;
    noria:logOriginatingManagementSystem <application/monitoring_platform> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent <agent/john_doe> . # Example of an agent causing an event (e.g., running a heavy script)
    # noria:alarmMonitoredAttribute could point to a blank node describing the attribute and its value.
    # [ a noria:StructuralObservable ; rdfs:label "CPU Usage" ; rdf:value "95%"^^xsd:string ] .

# --- Trouble Tickets ---

<troubleticket/tt_20240320_001>
    a noria:TroubleTicket, pep:ProcedureExecutionContainer, BBO:DocumentResource ;
    rdfs:label "Network Outage in DC-PAR-01"@en ;
