# --- Organizational Entities ---

noria:instance/Org_ITOperations
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The central department responsible for IT infrastructure and services."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for all issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

noria:instance/Org_NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentInstructions "For critical network issues, use direct hotline."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    org:unitOf noria:instance/Org_ITOperations ;
.

noria:instance/Person_AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer and Team Lead."@en ;
    foaf:mbox "mailto:alice.smith@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    org:memberOf noria:instance/Org_NetworkTeam ;
.

noria:instance/Person_BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    foaf:mbox "mailto:bob.johnson@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use internal chat for quick questions."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    org:memberOf noria:instance/Org_ITOperations ;
.

noria:instance/CorporateUserIdentifier_ASmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within the organization."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    foaf:holdsAccount noria:instance/Person_AliceSmith ;
.

noria:instance/Org_CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "A multinational technology conglomerate that develops, manufactures, and sells networking hardware."@en ;
.

