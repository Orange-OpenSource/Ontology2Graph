# --- External Entities (foaf:Agent, org:Organization, org:OrganizationalUnit, bot:Site) ---

# foaf:Agent (for persons)
<https://w3id.org/noria/agent/JohnDoe>
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A synthetic agent representing an employee."@en ;
    foaf:name "John Doe"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
.
<https://w3id.org/noria/agent/JaneSmith>
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A synthetic agent representing a team leader."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    noria:agentWorkingHours "08:30-17:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call directly for urgent issues."^^xsd:string ;
.
<https://w3id.org/noria/agent/AliceJohnson>
    a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "A synthetic agent representing a system administrator."@en ;
    foaf:name "Alice Johnson"^^xsd:string ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use chat for quick queries."^^xsd:string ;
.

