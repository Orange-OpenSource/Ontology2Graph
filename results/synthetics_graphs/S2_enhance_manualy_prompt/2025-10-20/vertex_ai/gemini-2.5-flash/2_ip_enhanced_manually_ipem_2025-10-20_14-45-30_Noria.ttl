# noria:EventRecord
<https://w3id.org/noria/event/Log_DB_Error_001>
    a noria:EventRecord ;
    rdfs:label "Database Error Log Entry"@en ;
    rdfs:comment "Log entry indicating a database connection error."@en ;
    noria:loggingTime "2024-04-01T09:58:00Z"^^xsd:dateTime ;
    noria:logText "ERROR: Database connection failed for user 'crm_app'."^^xsd:string ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/app/CRM_System> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/app/Monitoring_Platform> ;
    noria:logOriginatingAgent <https://w3id.org/noria/agent/JaneSmith> ; # Example of an agent being the 'creator' of the log entry (e.g., via manual action or script)
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <https://w3id.org/noria/opplan/Restart_App_Servers> ;
.
<https://w3id.org/noria/event/Log_CPU_Warning_002>
    a noria:EventRecord ;
    rdfs:label "High CPU Warning Log"@en ;
    rdfs:comment "Log entry indicating high CPU usage on a server."@en ;
    noria:loggingTime "2024-04-02T07:55:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU usage on server 'app-server-01' exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/App_Server_01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/app/Monitoring_Platform> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmProposedRepairAction <https://w3id.org/noria/opplan/Check_DB_Metrics> ;
.
<https://w3id.org/noria/event/Log_Router_Config_003>
    a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on a core router."@en ;
    noria:loggingTime "2024-04-05T23:50:00Z"^^xsd:dateTime ;
    noria:logText "INFO: Configuration changed by 'alicej' from '10.0.0.10'."^^xsd:string ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/Router_Core_01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/app/Monitoring_Platform> ;
    noria:logOriginatingAgent <https://w3id.org/noria/agent/AliceJohnson> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
.

# Linking TroubleTicket to EventRecord
<https://w3id.org/noria/tt/TT-2024-001>
    noria:troubleTicketTrigger <https://w3id.org/noria/event/Log_DB_Error_001> ;
    noria:documentStatusHistory <https://w3id.org/noria/event/Log_DB_Error_001> ;
.
<https://w3id.org/noria/tt/TT-2024-002>
    noria:troubleTicketTrigger <https://w3id.org/noria/event/Log_CPU_Warning_002> ;
.

# Linking ChangeRequest to EventRecord
<https://w3id.org/noria/cr/CR-2024-002>
    noria:documentStatusHistory <https://w3id.org/noria/event/Log_Router_Config_003> ;
.

