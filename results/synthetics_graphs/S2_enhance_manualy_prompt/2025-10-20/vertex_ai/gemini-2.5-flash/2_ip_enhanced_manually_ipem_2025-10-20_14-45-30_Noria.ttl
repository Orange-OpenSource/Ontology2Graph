# --- Additional links to ensure all ObjectProperties are used and nodes are connected ---

# noria:elementManagedBy (already used extensively)
# noria:structuralElementObservable (used by noria:virtualServerStatus, noria:networkInterfaceAdministrativeStatus, noria:networkInterfaceOperationalStatus)
# noria:structuralObservableOf (inverse of structuralElementObservable, implicitly covered by direct property usage)
# noria:structuralElementObservableData (used by noria:networkInterfaceRoutingPriorityMetric, noria:networkInterfaceLaserTxOpticalPower, etc.)
# noria:eventRelatedElement (used by noria:troubleTicketRelatedService, noria:troubleTicketRelatedResource, noria:logOriginatingManagedObject, noria:logOriginatingManagementSystem, noria:changeRequestImpact)
# noria:eventRelatedParty (used by noria:troubleTicketRelatedParty, noria:logOriginatingAgent)
# noria:applicationModuleOf (used)
# noria:applicationModuleRelatedParty (used by noria:applicationModuleAdministrationTeam, etc.)
# noria:applicationModuleAdministrationTeam (used)
# noria:applicationModuleAdministrationLeader (used)
# noria:applicationModuleSupportTeam (used)
# noria:applicationModuleSupportLeader (used)
# noria:applicationModuleSupportGroup (used)
# noria:applicationModuleHotlineGroup (used)
# noria:applicationModuleSlaLevel (used)
# noria:serviceType (used)
# noria:documentStatusHistory (used)
