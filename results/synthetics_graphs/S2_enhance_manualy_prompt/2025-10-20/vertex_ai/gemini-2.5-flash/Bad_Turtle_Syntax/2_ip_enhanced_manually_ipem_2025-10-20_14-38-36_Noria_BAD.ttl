noria:ttnote/2024_04_20_002_01
    a noria:TroubleTicketNote ;
    rdfs:label "CPU spike investigation for TT-002"@en ;
    rdfs:comment "Identified a long-running database query causing CPU spikes. Working on optimization."@en ;
