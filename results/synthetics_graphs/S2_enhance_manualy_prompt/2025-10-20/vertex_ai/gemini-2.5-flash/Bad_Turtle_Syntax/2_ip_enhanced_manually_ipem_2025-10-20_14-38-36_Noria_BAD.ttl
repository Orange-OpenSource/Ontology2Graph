# --- org:OrganizationalUnit ---
noria:orgunit/network_ops
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure operations."@en ;
    org:identifier "OU-NETOPS"^^xsd:string ;
    org:unitOf noria:org/orange_telecom ;
    org:member noria:agent/john_doe ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "Follow incident management procedures."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

noria:orgunit/app_support
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for application support."@en ;
    org:identifier "OU-APPSUP"^^xsd:string ;
    org:unitOf noria:org/orange_telecom ;
    org:member noria:agent/jane_smith ;
    noria:agentWorkingHours "08:00-20:00 (Mon-Sun)"^^xsd:string ;
    noria:agentInstructions "Escalate to L3 if necessary."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

noria:orgunit/service_management
