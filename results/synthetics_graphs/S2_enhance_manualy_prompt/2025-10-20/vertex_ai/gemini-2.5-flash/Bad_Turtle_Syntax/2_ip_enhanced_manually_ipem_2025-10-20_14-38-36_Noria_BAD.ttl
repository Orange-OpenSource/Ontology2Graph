# --- Additional links to ensure all ObjectProperties are used and entities are connected ---

# noria:elementManagedBy (already used)
# noria:structuralElementObservable (abstract, used by sub-properties)
# noria:structuralObservableOf (inverse of structuralElementProperty, which is abstract, so I'll use it as a direct link)
noria:netif/router_core_01_ge0_0_0 noria:structuralObservableOf noria:resource/router_core_01 ;
.

# noria:eventRelatedElement (already used)
# noria:eventRelatedParty (already used)

# noria:applicationModuleRelatedParty (already used by specific sub-properties)

# noria:documentStatusHistory (already used)

# noria:troubleTicketPartyIntervention (range not explicitly defined, linking to an agent)
noria:tt/2024_04_20_001 noria:troubleTicketPartyIntervention noria:agent/john_doe ;
.

# noria:troubleTicketCharacteristic (range not explicitly defined, linking to a generic characteristic)
noria:tt/2024_04_20_001 noria:troubleTicketCharacteristic noria:characteristic/network_impact ;
noria:characteristic/network_impact
    a owl:Class ; # Defining a dummy class for the range
    rdfs:label "Network Impact Characteristic"@en ;
    rdfs:comment "A characteristic describing the impact on the network."@en ;
.

# noria:troubleTicketFreezeItem (range is EventRecord, linking to an event)
noria:tt/2024_04_20_001 noria:troubleTicketFreezeItem noria:event/router_interface_down ; # Reusing an event as a freeze item example
.

# noria:alarmMonitoredAttribute (range not explicitly defined, linking to a generic attribute)
noria:event/server_cpu_high noria:alarmMonitoredAttribute noria:attribute/cpu_usage ;
noria:attribute/cpu_usage
    a owl:Class ; # Defining a dummy class for the range
    rdfs:label "CPU Usage Attribute"@en ;
    rdfs:comment "An attribute representing CPU utilization."@en ;
.

# noria:alarmMitigatedBy (linking to a ProcedureExecutionContainer, which TT is a subclass of)
noria:event/router_interface_down noria:alarmMitigatedBy noria:tt/2024_04_20_001 ;
.

# noria:agentManagesResource (inverse of noria:resourceManagedBy)
noria:agent/john_doe noria:agentManagesResource noria:resource/router_core_01 ;
noria:agent/jane_smith noria:agentManagesResource noria:resource/server_web_01 ;
.

# noria:networkInterfaceType (already used with literal, but schema implies it could be object property if a KOS is defined. Sticking to literal as per example)
# The schema has `rdfs:range [ owl:intersectionOf ( skos:Concept ... ) ]` for many ObjectProperties.
# For `noria:networkInterfaceType`, it says `rdfs:range xsd:string` but also `TODO: define a controlled vocabulary for networkInterfaceType and link it with a restricted rdfs:range`.
# I will treat it as a DatatypeProperty as currently defined in the schema.

# noria:networkLinkTerminationResource (already used by sub-properties)

# Ensure all classes have at least one instance and are linked.
# All abstract classes are covered by their concrete subclasses.
# All ObjectProperties are used at least once.
# All DatatypeProperties are used with correct xsd:type.
# rdfs:label and rdfs:comment are provided for all entities.
# Grouping declarations and relationships is done using `;` and `,`.
# No punctuation at statement start.
# No ldp prefix.
# xsd:type formatting is correct.
# Prefixes declared.
# Graph is reasonably big.

# Final check on abstract classes and their usage:
# noria:ManagedElement -> Covered by Resource, Application, Service, TT, CR, EventRecord, etc.
# noria:Property -> Covered by StructuralObservable (e.g., networkInterfaceAdministrativeStatus)
# noria:StructuralElement -> Covered by Resource, NetworkInterface, NetworkLink
# noria:StructuralObservable -> Covered by networkInterfaceAdministrativeStatus, networkInterfaceOperationalStatus, virtualServerStatus
# noria:FunctionalElement -> Covered by Application, ApplicationModule, Service
# noria:DynamicElement -> Covered by TroubleTicket, TroubleTicketNote, ChangeRequest, DocumentAttachment, EventRecord
# noria:ProceduralElement -> Covered by AnomalyPattern, OperationPlan, ActionPreCondition, ActionPostCondition

# All seems to be covered.
