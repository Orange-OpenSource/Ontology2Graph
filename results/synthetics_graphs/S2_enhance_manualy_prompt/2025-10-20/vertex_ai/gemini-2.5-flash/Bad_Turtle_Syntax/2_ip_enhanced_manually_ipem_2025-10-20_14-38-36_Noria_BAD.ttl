    rdfs:label "Service Management Team"@en ;
    rdfs:comment "Team responsible for overall service management."@en ;
    org:identifier "OU-SRVMGMT"^^xsd:string ;
    org:unitOf noria:org/orange_telecom ;
    org:member noria:agent/alice_williams ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Review SLA reports."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

