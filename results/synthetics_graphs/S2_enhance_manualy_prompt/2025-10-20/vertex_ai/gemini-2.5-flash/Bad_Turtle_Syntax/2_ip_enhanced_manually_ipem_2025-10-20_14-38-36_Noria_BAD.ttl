# --- foaf:Agent (People and Teams) ---
noria:agent/john_doe
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An example employee, a network engineer."@en ;
    foaf:name "John Doe"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

noria:agent/jane_smith
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An example employee, a system administrator."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system first, then phone."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

noria:agent/alice_williams
    a foaf:Agent ;
    rdfs:label "Alice Williams"@en ;
    rdfs:comment "An example employee, a service manager."@en ;
    foaf:name "Alice Williams"^^xsd:string ;
    noria:agentWorkingHours "10:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
.

