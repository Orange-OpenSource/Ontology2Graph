# --- noria:EventRecord ---
noria:event/router_interface_down
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject noria:resource/router_core_01 ;
    noria:logOriginatingManagementSystem noria:app/monitoring_system ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:op_plan/check_interface ;
.

noria:event/server_cpu_high
    a noria:EventRecord ;
    rdfs:label "Server CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on a web server."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on server-web-01 exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject noria:resource/server_web_01 ;
    noria:logOriginatingManagementSystem noria:app/monitoring_system ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent noria:agent/jane_smith ; # Example of an agent generating an event (e.g., manual check)
.

noria:event/config_change_router
    a noria:EventRecord ;
    rdfs:label "Router Configuration Change Event"@en ;
    rdfs:comment "Log entry for a configuration change on a router."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by vty0 (192.168.1.5)"^^xsd:string ;
    noria:logOriginatingManagedObject noria:resource/router_core_01 ;
    noria:logOriginatingAgent noria:agent/john_doe ;
.

