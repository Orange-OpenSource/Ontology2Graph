# --- Custom class for IP Address reification (to handle schema inconsistency) ---
noria:IPAddress
    a owl:Class ;
    rdfs:label "IP Address" ;
    rdfs:comment "Represents an IP address, used as a reification target for object properties that link to IP address literals, resolving a schema inconsistency where noria:resourceManagementIPAddress is an ObjectProperty but its sub-property observable:ipAddress is a DatatypeProperty." ;
    rdfs:isDefinedBy noria: ;
.

noria:hasIPAddressValue
    a owl:DatatypeProperty ;
    rdfs:label "has IP Address Value" ;
    rdfs:comment "The actual string value of an IP address." ;
    rdfs:domain noria:IPAddress ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy noria: ;
.

