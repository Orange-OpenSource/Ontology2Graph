# --- Core Organizational Entities ---

noria:OrgOrange
    a org:Organization ;
    rdfs:label "Orange S.A."@en ;
    rdfs:comment "The main organization, Orange S.A."@en ;
.

noria:TeamNetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network operations."@en ;
    org:unitOf noria:OrgOrange ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for L2 issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethodEmail ;
.

noria:TeamAppDev
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for application development and maintenance."@en ;
    org:unitOf noria:OrgOrange ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Use internal chat for urgent requests."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethodChat ;
.

noria:TeamSecurity
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    org:unitOf noria:OrgOrange ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Call emergency hotline for critical security incidents."^^xsd:string ;
