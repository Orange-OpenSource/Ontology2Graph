# =============================================================================
# Core Entities
# =============================================================================

# foaf:Agent, org:Organization, org:OrganizationalUnit, bot:Site
noria:instance/Agent/JohnDoe
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An individual agent, a key employee in the IT department."@en ;
    foaf:name "John Doe" ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email .

noria:instance/Agent/JaneSmith
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An individual agent, a senior network engineer."@en ;
    foaf:name "Jane Smith" ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone .

noria:instance/Agent/AutomationBot
    a foaf:Agent ;
    rdfs:label "Automation Bot"@en ;
    rdfs:comment "An automated agent responsible for routine maintenance tasks."@en ;
    foaf:name "Automation Bot" ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Do not contact directly; monitor logs for activity."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email .

noria:instance/Agent/AliceWonder
    a foaf:Agent ;
    rdfs:label "Alice Wonder"@en ;
    rdfs:comment "A database administrator."@en ;
    foaf:name "Alice Wonder" ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Email for non-urgent database queries."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email .

noria:instance/Agent/BobBuilder
    a foaf:Agent ;
    rdfs:label "Bob Builder"@en ;
    rdfs:comment "A facilities manager."@en ;
    foaf:name "Bob Builder" ;
    noria:agentWorkingHours "8:00-16:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Call for physical site issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone .

noria:instance/Organization/ITDepartment
    a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology Department of the company."@en ;
    org:hasMember noria:instance/Agent/JohnDoe ;
    org:hasMember noria:instance/Agent/JaneSmith .

noria:instance/Organization/CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "A multinational technology conglomerate that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

noria:instance/Organization/DellTechnologies
    a org:Organization ;
    rdfs:label "Dell Technologies Inc."@en ;
    rdfs:comment "An American multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:instance/OrganizationalUnit/NetworkOperations
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "A team within the IT Department responsible for network infrastructure."@en ;
    org:unitOf noria:instance/Organization/ITDepartment ;
    org:hasMember noria:instance/Agent/JaneSmith ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentInstructions "For critical network issues, escalate to this team immediately."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone .

noria:instance/OrganizationalUnit/ApplicationSupport
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "A team responsible for supporting various business applications."@en ;
    org:unitOf noria:instance/Organization/ITDepartment ;
    org:hasMember noria:instance/Agent/JohnDoe ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Submit tickets via the internal portal."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email .

noria:instance/OrganizationalUnit/DatabaseTeam
    a org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database management."@en ;
    org:unitOf noria:instance/Organization/ITDepartment ;
    org:hasMember noria:instance/Agent/AliceWonder ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Submit database change requests via portal."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email .

noria:instance/OrganizationalUnit/FacilitiesManagement
    a org:OrganizationalUnit ;
    rdfs:label "Facilities Management Team"@en ;
    rdfs:comment "Team responsible for physical infrastructure."@en ;
    org:unitOf noria:instance/Organization/ITDepartment ;
    org:hasMember noria:instance/Agent/BobBuilder ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Emergency calls only."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone .

noria:instance/Site/MainDataCenter
    a bot:Site ;
