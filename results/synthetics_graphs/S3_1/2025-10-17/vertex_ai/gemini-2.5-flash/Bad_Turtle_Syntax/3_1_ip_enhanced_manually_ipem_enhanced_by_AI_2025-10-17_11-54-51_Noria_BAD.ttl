# KOS for noria:applicationType
noria:kos/application/type/CustomerFacingService
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "An application type directly visible and usable by a customer."@en .

noria:kos/application/type/ResourceFacingService
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "An application type that supports customer-facing services but is not directly exposed to customers."@en .

noria:kos/application/type/Infrastructure
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Infrastructure"@en ;
    rdfs:comment "An application type representing core infrastructure components."@en .

