    a noria:OperationPlan ;
    rdfs:label "Security Incident Response Procedure"@en ;
    rdfs:comment "Procedure for responding to detected security incidents."@en ;
    noria:operationPlanPreCondition noria:actionprecondition/SecurityAlertConfirmed ;
    noria:operationPlanPostCondition noria:actionpostcondition/ThreatMitigated ;
    pep:hasInput noria:eventrecord/LogEntry006 ;
    pep:hasOutput noria:changerequest/CR-2024-005 .

# noria:ActionPreCondition instances
noria:actionprecondition/InterfaceDownDetected
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Detected"@en ;
    rdfs:comment "Pre-condition: a network interface is reported as down."@en .

noria:actionprecondition/BackupCompleted
    a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completed"@en ;
    rdfs:comment "Pre-condition: a full backup of the database has been successfully completed."@en .

noria:actionprecondition/ServerProvisioned
    a noria:ActionPreCondition ;
    rdfs:label "New Server Provisioned"@en ;
    rdfs:comment "Pre-condition: a new web server VM has been provisioned and configured."@en .

noria:actionprecondition/MaliciousIPIdentified
    a noria:ActionPreCondition ;
    rdfs:label "Malicious IP Identified"@en ;
    rdfs:comment "Pre-condition: a malicious IP address has been identified and confirmed."@en .

noria:actionprecondition/SecurityAlertConfirmed
    a noria:ActionPreCondition ;
    rdfs:label "Security Alert Confirmed"@en ;
    rdfs:comment "Pre-condition: a security alert has been investigated and confirmed as a legitimate threat."@en .

# noria:ActionPostCondition instances
noria:actionpostcondition/InterfaceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Interface Operational"@en ;
    rdfs:comment "Post-condition: the network interface is restored to an operational state."@en .

noria:actionpostcondition/DBServiceOperational
    a noria:ActionPostCondition ;
    rdfs:label "Database Service Operational"@en ;
    rdfs:comment "Post-condition: the database service is fully operational after upgrade."@en .

noria:actionpostcondition/ServerOperationalInPool
    a noria:ActionPostCondition ;
    rdfs:label "Server Operational in Load Balancer Pool"@en ;
    rdfs:comment "Post-condition: the new web server is operational and serving traffic via the load balancer."@en .

noria:actionpostcondition/TrafficBlocked
    a noria:ActionPostCondition ;
    rdfs:label "Malicious Traffic Blocked"@en ;
    rdfs:comment "Post-condition: traffic from the malicious IP address is successfully blocked by the firewall."@en .

noria:actionpostcondition/ThreatMitigated
    a noria:ActionPostCondition ;
    rdfs:label "Threat Mitigated"@en ;
    rdfs:comment "Post-condition: the security threat has been successfully mitigated."@en .

