# noria:AnomalyPattern instances
noria:anomalypattern/HighCPULowTraffic
    a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Traffic Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating high CPU usage with unexpectedly low network traffic, potentially a denial-of-service attack or misconfiguration."@en ;
    folio:hasConsequence noria:troubleticket/TT-2024-002 .

noria:anomalypattern/InterfaceFlap
    a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Anomaly"@en ;
    rdfs:comment "Anomaly pattern for a network interface repeatedly going up and down, indicating instability."@en ;
    folio:hasConsequence noria:troubleticket/TT-2024-001 .

