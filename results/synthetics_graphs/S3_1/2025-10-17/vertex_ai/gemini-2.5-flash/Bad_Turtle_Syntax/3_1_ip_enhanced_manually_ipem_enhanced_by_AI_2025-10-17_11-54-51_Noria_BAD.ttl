    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    noria:operationPlanPreCondition noria:actionprecondition/InterfaceDownDetected ;
    noria:operationPlanPostCondition noria:actionpostcondition/InterfaceRestored ;
    pep:hasInput noria:resource/Router01 ;
    pep:hasInput noria:eventrecord/LogEntry001 ;
    pep:hasOutput noria:eventrecord/LogEntry001 .

