# foaf:Agent instances
noria:agent/JohnDoe
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An IT administrator responsible for network operations."@en ;
    foaf:name "John Doe" ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent issues, phone for critical alerts."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email .

noria:agent/JaneSmith
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A senior network engineer and team lead."@en ;
    foaf:name "Jane Smith" ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "8:30-17:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Always call for P1 incidents."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone .

noria:agent/AliceJohnson
    a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "A software developer in the application team."@en ;
    foaf:name "Alice Johnson" ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    noria:agentWorkingHours "10:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email .

noria:agent/BobWhite
    a foaf:Agent ;
    rdfs:label "Bob White"@en ;
    rdfs:comment "A junior network engineer."@en ;
    foaf:name "Bob White" ;
    foaf:mbox <mailto:bob.white@example.com> ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Shadow senior engineers for first 3 months."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email .

noria:agent/CharlieGreen
    a foaf:Agent ;
    rdfs:label "Charlie Green"@en ;
    rdfs:comment "A security analyst in the SOC team."@en ;
    foaf:name "Charlie Green" ;
    foaf:mbox <mailto:charlie.green@example.com> ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Analyze security alerts and escalate as needed."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email .

# org:Organization instances
noria:org/ITSolutionsInc
    a org:Organization ;
    rdfs:label "IT Solutions Inc."@en ;
    rdfs:comment "A leading IT services provider."@en ;
    org:hasUnit noria:orgunit/NetworkOperations ;
    org:hasUnit noria:orgunit/ApplicationDevelopment ;
    org:hasUnit noria:orgunit/SecurityOperations .

noria:org/CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "A global technology conglomerate."@en .

noria:org/HPE
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "An American multinational enterprise information technology company."@en .

noria:org/JuniperNetworks
    a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "A multinational corporation that develops and markets networking products."@en .

# org:OrganizationalUnit instances
noria:orgunit/NetworkOperations
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf noria:org/ITSolutionsInc ;
    org:member noria:agent/JohnDoe ;
    org:member noria:agent/JaneSmith ;
    org:member noria:agent/BobWhite ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "Follow incident response procedures."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone .

noria:orgunit/ApplicationDevelopment
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining applications."@en ;
    org:unitOf noria:org/ITSolutionsInc ;
    org:member noria:agent/AliceJohnson ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit bug reports via Jira."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Email .

noria:orgunit/CustomerSupport
    a org:OrganizationalUnit ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "First-line support for customer inquiries and issues."@en ;
    org:unitOf noria:org/ITSolutionsInc ;
    noria:agentWorkingHours "8:00-20:00 (Mon-Sun)"^^xsd:string ;
    noria:agentInstructions "Escalate to L2 teams as per SLA."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone .

noria:orgunit/SecurityOperations
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC) Team"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:unitOf noria:org/ITSolutionsInc ;
    org:member noria:agent/CharlieGreen ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "Prioritize critical security events."^^xsd:string ;
    noria:agentPreferredContactMethod noria:kos/org/agent-contact-method/Phone .

