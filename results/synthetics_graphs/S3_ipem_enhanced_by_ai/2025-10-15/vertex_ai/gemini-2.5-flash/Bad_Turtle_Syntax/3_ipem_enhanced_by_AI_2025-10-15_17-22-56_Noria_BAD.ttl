# --- Network Links (noria:NetworkLink) ---
noria-inst:Link_WebServer_CoreRouter
    a noria:NetworkLink ;
    rdfs:label "Link WebServer 01 to Core Router DC1"@en ;
    rdfs:comment "High-speed Ethernet link connecting WebServer_01 to the data center core router for internal traffic."@en ;
    noria:networkLinkId "LINK-WS01-CRDC1"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-01-15T12:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria-inst:WebServer_01 ;
    noria:networkLinkTerminationResourceDestination noria-inst:CoreRouter_DC1 ;
    noria:networkLinkTerminationResource noria-inst:WebServer_01, noria-inst:CoreRouter_DC1 ;
    noria:resourceManagedBy noria-inst:Network_Engineering_Team ;
.

noria-inst:Link_CoreRouter_External
    a noria:NetworkLink ;
    rdfs:label "Link Core Router DC1 to External Network"@en ;
    rdfs:comment "WAN link from data center to internet service provider, carrying all external traffic."@en ;
    noria:networkLinkId "LINK-CRDC1-ISP"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-05-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria-inst:CoreRouter_DC1 ;
    noria:networkLinkTerminationResourceDestination noria-inst:External_ISP_Router ;
    noria:networkLinkTerminationResource noria-inst:CoreRouter_DC1, noria-inst:External_ISP_Router ;
    noria:resourceManagedBy noria-inst:Network_Engineering_Team ;
.

noria-inst:Link_AccessSwitch_CoreNetwork
    a noria:NetworkLink ;
    rdfs:label "Link Access Switch BO1 to Core Network"@en ;
    rdfs:comment "Uplink from branch office access switch to the corporate core network, providing connectivity for the London office."@en ;
    noria:networkLinkId "LINK-ASBO1-CORE"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-03-10T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria-inst:AccessSwitch_BO1 ;
    noria:networkLinkTerminationResourceDestination noria-inst:CoreRouter_DC1 ;
    noria:networkLinkTerminationResource noria-inst:AccessSwitch_BO1, noria-inst:CoreRouter_DC1 ;
    noria:resourceManagedBy noria-inst:Network_Engineering_Team ;
.

noria-inst:NI_WebServer_01_Eth0 noria:networkInterfaceConnects noria-inst:Link_WebServer_CoreRouter .
