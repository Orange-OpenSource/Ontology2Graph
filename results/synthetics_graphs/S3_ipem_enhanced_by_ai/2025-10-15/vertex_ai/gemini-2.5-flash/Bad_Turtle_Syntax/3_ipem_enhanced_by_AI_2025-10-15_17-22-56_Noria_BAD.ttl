# --- Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person) ---
noria-inst:IT_Operations_Team
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "The primary team responsible for day-to-day IT infrastructure operations, including server and application management."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for all non-critical issues. For critical issues, use emergency hotline."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method#TicketingSystem ;
.

noria-inst:Network_Engineering_Team
    a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team for network design, implementation, and advanced troubleshooting of network devices and links."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Escalate network-related incidents from IT Operations. Direct contact for project work."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method#Email ;
.

noria-inst:Security_Team
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC) Team"@en ;
    rdfs:comment "Team responsible for monitoring, detecting, analyzing, and responding to cybersecurity incidents across all systems."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Immediate notification for all security alerts. Follow established incident response protocols."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method#SecurityAlertSystem ;
.

noria-inst:Alice_Smith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer, specializing in WAN technologies and routing protocols."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Available for network architecture consultations and high-level network troubleshooting."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method#Phone ;
.

noria-inst:Bob_Johnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "IT Operations Manager, overseeing incident management and change requests for applications and servers."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+1-555-987-6543"^^xsd:string ;
    noria:agentWorkingHours "08:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Oversees incident management and change requests for critical business applications."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method#Email ;
.

noria-inst:Charlie_Brown
    a foaf:Person ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Security Analyst, responsible for analyzing security events and coordinating responses."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    foaf:phone "+1-555-111-2222"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Handles security incident analysis and reporting, working closely with the SOC team."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method#InternalChat ;
.

noria-inst:System_Agent_Monitoring
    a foaf:Agent ;
    rdfs:label "Automated Monitoring Agent"@en ;
    rdfs:comment "An automated system agent responsible for generating monitoring alerts and events."@en ;
.

noria-inst:External_Attacker_Agent
    a foaf:Agent ;
    rdfs:label "External Attacker"@en ;
    rdfs:comment "Represents an unknown external entity attempting unauthorized access or malicious activities."@en ;
.

# --- Corporate User Identifier ---
noria-inst:CUid_ASmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within the corporate IT system, used for login and access."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "AS-001"^^xsd:string ;
.

noria-inst:CUid_BJohnson
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Bob Johnson within the corporate IT system, used for login and access."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "BJ-002"^^xsd:string ;
.

noria-inst:Alice_Smith foaf:holdsAccount noria-inst:CUid_ASmith ;
    noria:agentManagesResource noria-inst:CoreRouter_DC1, noria-inst:Link_CoreRouter_External ;
.

noria-inst:Bob_Johnson foaf:holdsAccount noria-inst:CUid_BJohnson ;
    noria:agentManagesResource noria-inst:WebServer_01, noria-inst:DatabaseServer_01, noria-inst:App_CustomerPortal ;
.

