@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix org: <http://www.w3.org/ns/org#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix inst: <https://w3id.org/noria/instance/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# SKOS Concept Schemes and Concepts
# These concepts are used as ranges for various ObjectProperties in the NORIA schema.
# =============================================================================

<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme" ;
    rdfs:comment "Defines various methods for contacting an agent." .

inst:ContactMethod_Email a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email" ;
    rdfs:comment "Preferred contact method: Email." .

inst:ContactMethod_Phone a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone" ;
    rdfs:comment "Preferred contact method: Phone." .

<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme" ;
    rdfs:comment "Categorizes applications by their primary function or role." .

inst:AppType_ServicePlatform a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Service Platform" ;
    rdfs:comment "Application type: Service Platform, providing core services." .

inst:AppType_Infrastructure a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure" ;
    rdfs:comment "Application type: Infrastructure, supporting underlying systems." .

<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme" ;
    rdfs:comment "Classifies applications based on their business impact." .

inst:BizImp_High a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High" ;
    rdfs:comment "Business importance: High, critical for core business operations." .

inst:BizImp_Medium a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium" ;
    rdfs:comment "Business importance: Medium, important but not immediately critical." .

<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
    rdfs:label "Application Module SLA Level Scheme" ;
    rdfs:comment "Defines service level agreement tiers for application modules." .

inst:SLA_Gold a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold" ;
    rdfs:comment "SLA Level: Gold, highest priority and availability." .

inst:SLA_Silver a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Silver" ;
    rdfs:comment "SLA Level: Silver, standard priority and availability." .

<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme" ;
    rdfs:comment "Describes the operational status of an application module." .

inst:AppModStatus_Production a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production" ;
    rdfs:comment "Application module status: In Production, actively serving users." .

inst:AppModStatus_Development a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Development" ;
    rdfs:comment "Application module status: In Development, under active construction or testing." .

<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme" ;
    rdfs:comment "Categorizes services based on their interaction with customers or resources." .

inst:ServiceType_CustomerFacing a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service" ;
    rdfs:comment "Service type: Customer Facing, directly consumed by end-users." .

inst:ServiceType_ResourceFacing a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service" ;
    rdfs:comment "Service type: Resource Facing, supporting other services or internal operations." .

<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme" ;
    rdfs:comment "Defines the impact level of a trouble ticket." .

inst:TTSeverity_Critical a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical" ;
    rdfs:comment "Trouble Ticket Severity: Critical, major service disruption." .

inst:TTSeverity_Major a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major" ;
    rdfs:comment "Trouble Ticket Severity: Major, significant service degradation." .

<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme" ;
    rdfs:comment "Classifies trouble tickets by their nature." .

inst:TTType_Failure a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure" ;
    rdfs:comment "Trouble Ticket Type: Failure, indicating a system or component malfunction." .

inst:TTType_Assistance a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance" ;
    rdfs:comment "Trouble Ticket Type: Assistance, for user support or queries." .

<kos/TroubleTicket/category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Criticity Scheme" ;
    rdfs:comment "Describes the criticality of a trouble ticket from a customer impact perspective." .

inst:TTCriticity_InterruptedService a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Interrupted Service" ;
    rdfs:comment "Trouble Ticket Criticity: Interrupted Service, service is completely unavailable." .

inst:TTCriticity_CorruptedService a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Corrupted Service" ;
    rdfs:comment "Trouble Ticket Criticity: Corrupted Service, service is available but with data integrity issues." .

<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme" ;
    rdfs:comment "Defines the urgency for resolving a trouble ticket." .

inst:TTPriority_P1 a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "P1" ;
    rdfs:comment "Trouble Ticket Priority: P1, highest priority, immediate action required." .

inst:TTPriority_P2 a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "P2" ;
    rdfs:comment "Trouble Ticket Priority: P2, high priority, prompt action required." .

<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme" ;
    rdfs:comment "Indicates the source from which a trouble ticket was created." .

inst:TTOrigin_Customer a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer" ;
    rdfs:comment "Trouble Ticket Origin: Customer, reported by an external customer." .

inst:TTOrigin_Supervision a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision" ;
    rdfs:comment "Trouble Ticket Origin: Supervision, detected by monitoring systems." .

<kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme" ;
    rdfs:comment "Describes the required response time for a trouble ticket." .

inst:TTUrgency_Immediate a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention" ;
    rdfs:comment "Trouble Ticket Urgency: Immediate Intervention, requires immediate attention." .

inst:TTUrgency_Deferred a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Deferred Intervention" ;
    rdfs:comment "Trouble Ticket Urgency: Deferred Intervention, can be scheduled for later." .

<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category Scheme" ;
    rdfs:comment "Categorizes the nature or technical impact of the incident." .

inst:TTTCategory_TotalBreakdown a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Total Breakdown" ;
    rdfs:comment "Trouble Ticket Trouble Category: Total Breakdown, complete system failure." .

inst:TTTCategory_IsolatedSite a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Isolated Customer Site" ;
    rdfs:comment "Trouble Ticket Trouble Category: Isolated Customer Site, specific customer location is affected." .

<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme" ;
    rdfs:comment "Identifies the party responsible for resolving the problem." .

inst:TTProblemResp_Customer a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Customer" ;
    rdfs:comment "Problem Responsibility: Customer, issue lies with the customer's equipment or configuration." .

inst:TTProblemResp_ManagedNetwork a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks" ;
    rdfs:comment "Problem Responsibility: Managed Backbone Networks, issue lies within the managed network infrastructure." .

<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme" ;
    rdfs:comment "Describes the current lifecycle status of a trouble ticket." .

inst:TTStatus_InProgress a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress" ;
    rdfs:comment "Trouble Ticket Status: In Progress, actively being worked on." .

inst:TTStatus_Resolved a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved" ;
    rdfs:comment "Trouble Ticket Status: Resolved, issue has been fixed." .

<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme" ;
    rdfs:comment "Categorizes the type of comment in a trouble ticket note." .

inst:TTNoteCommentType_Internal a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal" ;
    rdfs:comment "Trouble Ticket Note Comment Type: Internal, for internal team communication." .

inst:TTNoteCommentType_Customer a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer" ;
    rdfs:comment "Trouble Ticket Note Comment Type: Customer, visible to the customer." .

<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme" ;
    rdfs:comment "Describes the type of operation or action recorded in a trouble ticket note." .

inst:TTNoteOpType_Diagnosis a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis" ;
    rdfs:comment "Trouble Ticket Note Operation Type: Diagnosis, related to problem investigation." .

inst:TTNoteOpType_Tests a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Tests and Measurements" ;
    rdfs:comment "Trouble Ticket Note Operation Type: Tests and Measurements, related to verification steps." .

<kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme" ;
    rdfs:comment "Classifies change requests by the nature of the intervention." .

inst:CRCategory_Internal a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention" ;
    rdfs:comment "Change Request Category: Internal Intervention, performed by internal teams." .

inst:CRCategory_ThirdParty a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Third Party Intervention" ;
    rdfs:comment "Change Request Category: Third Party Intervention, involving external vendors." .

<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme" ;
    rdfs:comment "Describes the a priori impact and risk level of a change request." .

inst:CRType_Standard a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change" ;
    rdfs:comment "Change Request Type: Standard Change, pre-approved, low-risk changes." .

inst:CRType_Emergency a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Emergency Change" ;
    rdfs:comment "Change Request Type: Emergency Change, for urgent, unplanned changes." .

<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme" ;
    rdfs:comment "Indicates the reason or trigger for a change request." .

inst:CRCause_SoftwareUpgrade a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade" ;
    rdfs:comment "Change Request Cause: Software Upgrade, to update software versions." .

inst:CRCause_Configuration a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change" ;
    rdfs:comment "Change Request Cause: Configuration Change, to modify system settings." .

<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme" ;
    rdfs:comment "Describes the current lifecycle status of a change request." .

inst:CRStatus_Approved a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved" ;
    rdfs:comment "Change Request Status: Approved, ready for implementation." .

inst:CRStatus_Implemented a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented" ;
    rdfs:comment "Change Request Status: Implemented, change has been successfully applied." .

<kos/ChangeRequest/specification> a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme" ;
    rdfs:comment "Refers to a standard operation plan or catalog item for recurring activities." .

inst:CRSpec_RoutineMaintenance a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Routine Maintenance" ;
    rdfs:comment "Change Request Specification: Routine Maintenance, scheduled upkeep." .

inst:CRSpec_SecurityPatch a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Security Patch Deployment" ;
    rdfs:comment "Change Request Specification: Security Patch Deployment, for security updates." .

<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme" ;
    rdfs:comment "Describes the current operational state of a resource." .

inst:OpState_Up a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up" ;
    rdfs:comment "Operational State: Up, resource is functioning normally." .

inst:OpState_Down a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down" ;
    rdfs:comment "Operational State: Down, resource is not functioning." .

<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme" ;
    rdfs:comment "Describes the desired administrative state of a resource." .

inst:AdminState_Enabled a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Enabled" ;
    rdfs:comment "Administrative State: Enabled, resource is administratively active." .

inst:AdminState_Disabled a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Disabled" ;
    rdfs:comment "Administrative State: Disabled, resource is administratively inactive." .

<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Perceived Severity Scheme" ;
    rdfs:comment "Indicates the perceived severity of an alarm or notification." .

inst:PerceivedSeverity_Critical a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical" ;
    rdfs:comment "Perceived Severity: Critical, immediate and severe impact." .

inst:PerceivedSeverity_Warning a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning" ;
    rdfs:comment "Perceived Severity: Warning, potential issue, requires attention." .

<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme" ;
    rdfs:comment "Categorizes resources by their functional type." .

inst:ResourceType_Router a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router" ;
    rdfs:comment "Resource Type: Router, network routing device." .

inst:ResourceType_Server a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server" ;
    rdfs:comment "Resource Type: Server, computing host." .

<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme" ;
    rdfs:comment "Describes the lifecycle stage of a resource." .

inst:LifecycleState_Production a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Production" ;
    rdfs:comment "Resource Lifecycle State: In Production, actively used in live environment." .

inst:LifecycleState_Decommissioned a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Decommissioned" ;
    rdfs:comment "Resource Lifecycle State: Decommissioned, removed from service." .

# =============================================================================
# Core Entities: Agents, Organizations, Locations
# =============================================================================

inst:Org_ITDept a org:Organization ;
    rdfs:label "IT Department Inc." ;
    rdfs:comment "The main IT organization responsible for infrastructure and applications." ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod inst:ContactMethod_Email .

inst:OrgUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Team responsible for network infrastructure management and monitoring." ;
    org:unitOf inst:Org_ITDept ;
    noria:agentWorkingHours "24/7 On-call"^^xsd:string ;
    noria:agentInstructions "For critical issues, use hotline. For routine, use email."^^xsd:string ;
    noria:agentPreferredContactMethod inst:ContactMethod_Phone .

inst:OrgUnit_AppDev a org:OrganizationalUnit ;
    rdfs:label "Application Development Team" ;
    rdfs:comment "Team responsible for application development, deployment, and maintenance." ;
    org:unitOf inst:Org_ITDept ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit requests via internal portal."^^xsd:string ;
    noria:agentPreferredContactMethod inst:ContactMethod_Email .

inst:Person_AliceSmith a foaf:Person ;
    rdfs:label "Alice Smith" ;
    rdfs:comment "Network Engineer, Team Lead for Network Operations. Manages core network resources." ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    org:memberOf inst:OrgUnit_NetworkOps ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Escalate to Alice for P1 network incidents."^^xsd:string ;
    noria:agentPreferredContactMethod inst:ContactMethod_Phone .

inst:Person_BobJohnson a foaf:Person ;
    rdfs:label "Bob Johnson" ;
    rdfs:comment "Senior Software Developer, Team Lead for Application Development. Oversees critical applications." ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    org:memberOf inst:OrgUnit_AppDev ;
    noria:agentWorkingHours "10:00 am - 7:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact Bob for critical application bugs."^^xsd:string ;
    noria:agentPreferredContactMethod inst:ContactMethod_Email .

inst:CorporateUserIdentifier_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID" ;
    rdfs:comment "Unique corporate user identifier for Alice Smith, used for system access." ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "U12345"^^xsd:string .

inst:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center" ;
    rdfs:comment "Primary data center facility, housing critical IT infrastructure." ;
    noria:siteId "DC-MAIN-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Techville"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

inst:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A" ;
    rdfs:comment "Main server room within the data center, containing racks of servers and network equipment." ;
    bot:hasSpace inst:Site_MainDC .

inst:Locus_Rack12A a noria:Locus ;
    rdfs:label "Rack 12A" ;
    rdfs:comment "Specific rack location 'A12' in Server Room A, hosting network devices." ;
    bot:hasSpace inst:Room_ServerRoomA ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "12"^^xsd:string .

inst:Locus_Rack12B a noria:Locus ;
    rdfs:label "Rack 12B" ;
    rdfs:comment "Specific rack location 'B12' in Server Room A, hosting application servers." ;
    bot:hasSpace inst:Room_ServerRoomA ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "12"^^xsd:string .

# =============================================================================
# Product Models
# =============================================================================

inst:ProductModel_Cisco3850 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 3850" ;
    rdfs:comment "Product model for Cisco Catalyst 3850 series switches, known for enterprise-level networking." ;
    noria:productManufacturedBy inst:Org_ITDept . # Using ITDept as a placeholder for a manufacturer org.

inst:ProductModel_DellPowerEdge a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740" ;
    rdfs:comment "Product model for Dell PowerEdge R740 servers, commonly used for virtualization and databases." ;
    noria:productManufacturedBy inst:Org_ITDept . # Placeholder

# =============================================================================
# Structural Elements: Resources, Network Interfaces, Network Links
# =============================================================================

inst:Resource_Router01 a noria:Resource ;
    rdfs:label "Core Router 01" ;
    rdfs:comment "Primary core router in the data center, handling high-volume network traffic." ;
    noria:elementDistinguishedName "router-core-01.dc-main"^^xsd:string ;
    noria:structuralElementDistinguishedName "router-core-01.dc-main"^^xsd:string ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceHostName "router01.example.com"^^xsd:string ;
    noria:resourceSerialNumber "SN-RTR-001-XYZ"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.1"^^xsd:string ;
    noria:elementManagedBy inst:OrgUnit_NetworkOps ;
    noria:resourceProductModel inst:ProductModel_Cisco3850 ;
    noria:resourceType inst:ResourceType_Router ;
    noria:resourceUsageState inst:LifecycleState_Production ;
    noria:locatedAtLocus inst:Locus_Rack12A ;
    noria:virtualServerStatus inst:OpState_Up ;
    noria:agentManagesResource inst:Person_AliceSmith ;
    noria:resourceForApplication inst:Application_WebPortal .

inst:Resource_Server01 a noria:Resource ;
    rdfs:label "Application Server 01" ;
    rdfs:comment "Server hosting critical applications, part of the web portal infrastructure." ;
    noria:elementDistinguishedName "app-server-01.dc-main"^^xsd:string ;
    noria:structuralElementDistinguishedName "app-server-01.dc-main"^^xsd:string ;
    noria:resourceLogisticId "LOG-SRV-001"^^xsd:string ;
    noria:resourceHostName "server01.example.com"^^xsd:string ;
    noria:resourceSerialNumber "SN-SRV-001-ABC"^^xsd:string ;
    noria:resourceInstallationDate "2022-02-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.10"^^xsd:string ;
    noria:elementManagedBy inst:OrgUnit_AppDev ;
    noria:resourceProductModel inst:ProductModel_DellPowerEdge ;
    noria:resourceType inst:ResourceType_Server ;
    noria:resourceUsageState inst:LifecycleState_Production ;
    noria:locatedAtLocus inst:Locus_Rack12B ;
    noria:virtualServerStatus inst:OpState_Up ;
    noria:agentManagesResource inst:Person_BobJohnson ;
    noria:resourceForApplication inst:Application_WebPortal .

inst:Resource_Server02 a noria:Resource ;
    rdfs:label "Database Server 02" ;
    rdfs:comment "Server hosting the main database for applications, configured in a cluster." ;
    noria:elementDistinguishedName "db-server-02.dc-main"^^xsd:string ;
