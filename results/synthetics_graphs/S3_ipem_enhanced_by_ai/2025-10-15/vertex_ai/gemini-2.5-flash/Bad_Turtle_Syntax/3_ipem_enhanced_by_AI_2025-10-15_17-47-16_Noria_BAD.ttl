    noria:logOriginatingManagementSystem inst:Application_MonitoringSystem ;
    noria:logOriginatingAgent inst:Person_BobJohnson ;
    noria:alarmSeverity inst:PerceivedSeverity_Major ;
    noria:eventRelatedElement inst:Application_WebPortal ;
    noria:eventRelatedParty inst:Person_BobJohnson .

