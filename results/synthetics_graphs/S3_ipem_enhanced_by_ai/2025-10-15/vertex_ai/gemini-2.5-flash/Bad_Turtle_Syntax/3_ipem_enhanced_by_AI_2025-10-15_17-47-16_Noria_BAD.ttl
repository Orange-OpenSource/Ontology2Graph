inst:EventRecord_RouterDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event" ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down, triggering an alert." ;
    noria:elementDistinguishedName "event-router-down-20240401"^^xsd:string ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:loggingTime "2024-04-01T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject inst:Resource_Router01 ;
    noria:logOriginatingManagementSystem inst:Application_MonitoringSystem ;
    noria:logOriginatingAgent inst:Person_AliceSmith ; # Could be a system agent too
    noria:alarmSeverity inst:PerceivedSeverity_Critical ;
    noria:alarmProposedRepairAction inst:OperationPlan_RestartInterface ;
    noria:alarmMonitoredAttribute inst:StructuralObservable_TrafficVolume ; # Linking to a structural observable
    noria:alarmMitigatedBy inst:TT_NetworkOutage ;
    noria:eventRelatedElement inst:Resource_Router01 ;
    noria:eventRelatedParty inst:Person_AliceSmith .

inst:EventRecord_AppError a noria:EventRecord ;
