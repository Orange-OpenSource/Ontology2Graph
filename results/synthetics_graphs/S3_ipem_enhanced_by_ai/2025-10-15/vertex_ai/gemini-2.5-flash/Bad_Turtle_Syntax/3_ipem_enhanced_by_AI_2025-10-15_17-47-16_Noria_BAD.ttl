# =============================================================================
# Procedural Elements: Operation Plans, Anomaly Patterns, Pre/Post Conditions
# =============================================================================

inst:OperationPlan_RestartInterface a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Procedure" ;
    rdfs:comment "Standard operating procedure for restarting a faulty network interface to restore connectivity." ;
    noria:elementDistinguishedName "op-restart-interface"^^xsd:string ;
    noria:operationPlanPreCondition inst:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition inst:ActionPostCondition_InterfaceUp .

inst:OperationPlan_DBRestart a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure" ;
    rdfs:comment "Procedure to restart the database service on a server, used to resolve connectivity issues." ;
    noria:elementDistinguishedName "op-db-restart"^^xsd:string ;
    noria:operationPlanPreCondition inst:ActionPreCondition_DBError ;
    noria:operationPlanPostCondition inst:ActionPostCondition_DBServiceRunning .

inst:AnomalyPattern_HighTrafficSpike a noria:AnomalyPattern ;
    rdfs:label "High Traffic Spike Anomaly Pattern" ;
    rdfs:comment "Pattern indicating an unusual surge in network traffic, potentially a DDoS attack or misconfiguration." ;
    noria:elementDistinguishedName "ap-high-traffic-spike"^^xsd:string ;
    folio:hasCause "Potential DDoS attack"^^xsd:string .

inst:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down" ;
    rdfs:comment "Condition: A network interface is in a 'down' operational state, indicating a loss of link." ;
    noria:elementDistinguishedName "precond-if-down"^^xsd:string .

inst:ActionPreCondition_DBError a noria:ActionPreCondition ;
    rdfs:label "Database Connection Error" ;
    rdfs:comment "Condition: Application logs show database connection errors, preventing data access." ;
    noria:elementDistinguishedName "precond-db-error"^^xsd:string .

inst:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up" ;
    rdfs:comment "Expected outcome: The network interface is in an 'up' operational state, confirming restored connectivity." ;
    noria:elementDistinguishedName "postcond-if-up"^^xsd:string .

inst:ActionPostCondition_DBServiceRunning a noria:ActionPostCondition ;
    rdfs:label "Database Service Running" ;
    rdfs:comment "Expected outcome: Database service is running and accessible, resolving application issues." ;
    noria:elementDistinguishedName "postcond-db-running"^^xsd:string .

# =============================================================================
# Structural Observables
# =============================================================================

inst:StructuralObservable_TrafficVolume a noria:StructuralObservable ;
    rdfs:label "Network Traffic Volume" ;
    rdfs:comment "Observable property representing the volume of network traffic on a specific interface or device." ;
    noria:elementDistinguishedName "obs-traffic-volume"^^xsd:string ;
    noria:structuralElementObservableData "1.5 Gbps"^^xsd:string ;
    noria:elementProperty inst:Resource_Router01 ;
    noria:structuralObservableOf inst:Resource_Router01 .

inst:StructuralObservable_CPUUsage a noria:StructuralObservable ;
    rdfs:label "Server CPU Usage" ;
    rdfs:comment "Observable property representing the CPU utilization of a server, indicating workload." ;
    noria:elementDistinguishedName "obs-cpu-usage"^^xsd:string ;
    noria:structuralElementObservableData "75%"^^xsd:string ;
    noria:elementProperty inst:Resource_Server01 ;
    noria:structuralObservableOf inst:Resource_Server01 .

# Additional links to ensure all ObjectProperties are used and graph is richly interconnected.
inst:Resource_Router01 noria:structuralElementObservable inst:StructuralObservable_TrafficVolume .
inst:Resource_Server01 noria:structuralElementObservable inst:StructuralObservable_CPUUsage .

inst:EventRecord_RouterDown noria:actionCorrelatedOperationPlan inst:OperationPlan_RestartInterface .
inst:EventRecord_AppError noria:actionCorrelatedOperationPlan inst:OperationPlan_DBRestart .
