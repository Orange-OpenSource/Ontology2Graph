# =============================================================================
# Agent and Organization Instances
# =============================================================================

noria-data:Org_GlobalIT
    a org:Organization ;
    rdfs:label "Global IT Department"@en ;
    rdfs:comment "The main IT organization responsible for all IT services."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via internal ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:Contact_Email ;
    .

noria-data:OU_WebOps
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Web Operations Team"@en ;
    rdfs:comment "Team responsible for web application deployment and maintenance."@en ;
    org:unitOf noria-data:Org_GlobalIT ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "For critical issues, use emergency hotline."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:Contact_Phone ;
    .

noria-data:OU_NetOps
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    org:unitOf noria-data:Org_GlobalIT ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentInstructions "All network incidents must be reported via the NMS."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:Contact_Phone ;
    .

noria-data:Person_Alice
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Engineer in Web Operations."@en ;
    org:memberOf noria-data:OU_WebOps ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:Contact_Email ;
    .

noria-data:Person_Bob
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Network Administrator."@en ;
    org:memberOf noria-data:OU_NetOps ;
    noria:agentWorkingHours "8:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Call directly for network emergencies."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:Contact_Phone ;
    .

noria-data:Person_Charlie
    a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Junior Developer in Web Operations."@en ;
    org:memberOf noria-data:OU_WebOps ;
    noria:agentWorkingHours "9:30-18:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact Alice for approvals."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:Contact_Email ;
    .

