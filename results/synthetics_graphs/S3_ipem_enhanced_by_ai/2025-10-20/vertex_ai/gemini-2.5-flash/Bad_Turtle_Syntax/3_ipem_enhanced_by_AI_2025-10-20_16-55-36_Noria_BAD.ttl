    rdfs:comment "An instance of the abstract class FunctionalElement, representing a high-level service component."^^xsd:string ;
    noria:functionalElementDistinguishedName "GEN-FE-001"^^xsd:string ;
    noria:elementManagedBy inst:AppDev_Team .

inst:GenericDynamicElement_01 a noria:DynamicElement ;
    rdfs:label "Generic Dynamic Element 01"^^xsd:string ;
    rdfs:comment "An instance of the abstract class DynamicElement, representing a time-sensitive event or activity."^^xsd:string ;
    noria:elementManagedBy inst:AliceBrown ;
    noria:eventRelatedElement inst:Switch_NYC_Floor5 ;
    noria:eventRelatedParty inst:AliceBrown .

inst:GenericProceduralElement_01 a noria:ProceduralElement ;
    rdfs:label "Generic Procedural Element 01"^^xsd:string ;
    rdfs:comment "An instance of the abstract class ProceduralElement, representing a documented operational process."^^xsd:string ;
    noria:elementManagedBy inst:NetworkOps_EU .

inst:CorrectiveAction_DBFix a pep:ProcedureExecution ;
    rdfs:label "Corrective Action for DB Performance"^^xsd:string ;
    rdfs:comment "An execution record of a procedure aimed at resolving database performance issues."^^xsd:string ;
    noria:actionCorrelatedOperationPlan inst:TroubleshootDBPerformancePlan .

inst:GenericTroubleTicketCharacteristic a skos:Concept ;
    rdfs:label "Generic Trouble Ticket Characteristic"^^xsd:string ;
    rdfs:comment "A general characteristic that can be associated with any trouble ticket."^^xsd:string .

inst:TT_DB_Performance_002 noria:troubleTicketCharacteristic inst:GenericTroubleTicketCharacteristic .

inst:GenericAlarmMonitoredAttribute a skos:Concept ;
    rdfs:label "Generic Alarm Monitored Attribute"^^xsd:string ;
    rdfs:comment "A general attribute that is monitored for alarm conditions, such as disk I/O."^^xsd:string .

inst:Event_DB_HighCPU noria:alarmMonitoredAttribute inst:GenericAlarmMonitoredAttribute .

inst:TT_DB_Performance_002 noria:alarmMitigatedBy inst:CorrectiveAction_DBFix .

