# =============================================================================
# Organization related instances
# =============================================================================

inst:GlobalCorp a org:Organization ;
    rdfs:label "Global Technologies Inc."^^xsd:string ;
    rdfs:comment "A multinational technology corporation providing IT services."^^xsd:string ;
    noria:agentInstructions "Refer to corporate policy for engagement and communication protocols."^^xsd:string ;
    noria:agentPreferredContactMethod inst:ContactMethod_Email .

inst:NetworkOps_EU a org:OrganizationalUnit ;
    rdfs:label "Network Operations Europe"^^xsd:string ;
    rdfs:comment "Manages network infrastructure and services across all European regions."^^xsd:string ;
    org:unitOf inst:GlobalCorp ;
    noria:agentWorkingHours "Mon-Fri 8:00-18:00 CET"^^xsd:string ;
    noria:agentInstructions "For all network-related requests, use the dedicated ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod inst:ContactMethod_Phone .

inst:AppDev_Team a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"^^xsd:string ;
    rdfs:comment "Responsible for the development, deployment, and maintenance of core business applications."^^xsd:string ;
    org:unitOf inst:GlobalCorp ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00 EST"^^xsd:string ;
    noria:agentInstructions "For new feature requests, submit a detailed proposal. For bug reports, open a ticket with full reproduction steps."^^xsd:string ;
    noria:agentPreferredContactMethod inst:ContactMethod_Chat .

inst:AliceBrown a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Brown"^^xsd:string ;
    rdfs:comment "Senior Network Architect, specializing in data center networking and security."^^xsd:string ;
    org:memberOf inst:NetworkOps_EU ;
    noria:agentWorkingHours "Mon-Fri 8:30-17:30 CET"^^xsd:string ;
    noria:agentPreferredContactMethod inst:ContactMethod_Phone .

inst:BobWhite a foaf:Person, foaf:Agent ;
    rdfs:label "Bob White"^^xsd:string ;
    rdfs:comment "Lead Software Engineer, focusing on backend systems and database optimization."^^xsd:string ;
    org:memberOf inst:AppDev_Team ;
    noria:agentWorkingHours "Mon-Fri 9:00-18:00 EST"^^xsd:string ;
    noria:agentPreferredContactMethod inst:ContactMethod_Email .

inst:CorporateUser_AliceBrown a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Brown's Corporate ID"^^xsd:string ;
    rdfs:comment "Unique identifier for Alice Brown within the corporate IT system, used for login and access."^^xsd:string ;
    foaf:accountName "abrown"^^xsd:string ;
    observable:accountIdentifier "abrown_id_789"^^xsd:string ;
    observable:accountLogin "abrown_login"^^xsd:string .

inst:CorporateUser_BobWhite a noria:CorporateUserIdentifier ;
    rdfs:label "Bob White's Corporate ID"^^xsd:string ;
    rdfs:comment "Unique identifier for Bob White, granting access to development and production environments."^^xsd:string ;
    foaf:accountName "bwhite"^^xsd:string ;
    observable:accountIdentifier "bwhite_id_456"^^xsd:string ;
    observable:accountLogin "bwhite_login"^^xsd:string .

