# Location related instances
# =============================================================================

inst:DataCenter_London a bot:Site ;
    rdfs:label "London Data Center"^^xsd:string ;
    rdfs:comment "Primary data center for European operations, hosting critical infrastructure."^^xsd:string ;
    noria:siteId "DC-LDN-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "45 Shard Street, London"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "E1 8XX"^^xsd:string ;
    noria:sitePrincipalAddressCityName "London"^^xsd:string ;
    noria:sitePrincipalAddressCountry "UK"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Shard Street"^^xsd:string .

inst:Office_NewYork a bot:Site ;
    rdfs:label "New York Office"^^xsd:string ;
