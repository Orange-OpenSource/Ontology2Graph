# =============================================================================
# Procedural elements
# =============================================================================

inst:TroubleshootDBPerformancePlan a noria:OperationPlan ;
    rdfs:label "Troubleshoot DB Performance Plan"^^xsd:string ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving database performance issues, including query optimization and resource scaling."^^xsd:string .

inst:SecurityIncidentResponsePlan a noria:OperationPlan ;
    rdfs:label "Security Incident Response Plan"^^xsd:string ;
    rdfs:comment "Detailed protocol for responding to detected security incidents, from containment to recovery and post-incident analysis."^^xsd:string .

inst:PreCondition_HighCPU a noria:ActionPreCondition ;
    rdfs:label "High CPU Pre-Condition"^^xsd:string ;
    rdfs:comment "Pre-condition for triggering performance troubleshooting: server CPU utilization is consistently above a defined threshold."^^xsd:string .

inst:PostCondition_PerformanceNormal a noria:ActionPostCondition ;
    rdfs:label "Performance Normal Post-Condition"^^xsd:string ;
    rdfs:comment "Post-condition for successful resolution: system performance metrics return to normal and stable levels."^^xsd:string .

inst:AnomalyPattern_SQLInjection a noria:AnomalyPattern ;
    rdfs:label "SQL Injection Anomaly Pattern"^^xsd:string ;
    rdfs:comment "A recognized pattern of database queries and access attempts indicative of a potential SQL injection attack."^^xsd:string .

inst:TroubleshootDBPerformancePlan
    noria:operationPlanPreCondition inst:PreCondition_HighCPU ;
    noria:operationPlanPostCondition inst:PostCondition_PerformanceNormal .

inst:SecurityIncidentResponsePlan
    noria:operationPlanPreCondition inst:AnomalyPattern_SQLInjection ;
    noria:operationPlanPostCondition inst:PostCondition_PerformanceNormal .

# =============================================================================
# Dynamic elements (Events, Tickets, Changes)
# =============================================================================

inst:Event_DB_HighCPU a noria:EventRecord ;
    rdfs:label "Database High CPU Event"^^xsd:string ;
    rdfs:comment "Log entry indicating sustained high CPU usage on the primary database server, potentially impacting application performance."^^xsd:string ;
    noria:loggingTime "2024-05-01T08:30:00Z"^^xsd:dateTime ;
    noria:logText "CPU_ALERT: db-srv-01.dc-ldn.global CPU usage exceeded 90% for 15 minutes. Investigate immediately."^^xsd:string ;
    noria:logOriginatingManagedObject inst:Server_DB_01 ;
    noria:logOriginatingManagementSystem inst:Security_Monitoring_App ;
    noria:logOriginatingAgent inst:BobWhite ;
    noria:alarmSeverity inst:AlarmSeverity_Warning ;
    noria:alarmProposedRepairAction inst:TroubleshootDBPerformancePlan .

inst:Event_Security_Alert a noria:EventRecord ;
    rdfs:label "Security Alert Event"^^xsd:string ;
    rdfs:comment "Log entry for a detected security threat, specifically a potential SQL injection attempt against the ERP application."^^xsd:string ;
    noria:loggingTime "2024-05-02T11:00:00Z"^^xsd:dateTime ;
    noria:logText "SECURITY_ALERT: Potential SQL Injection detected on ERP application. Source IP: 203.0.113.42."^^xsd:string ;
    noria:logOriginatingManagedObject inst:ERP_Application ;
    noria:logOriginatingManagementSystem inst:Security_Monitoring_App ;
    noria:logOriginatingAgent inst:AliceBrown ;
    noria:alarmSeverity inst:AlarmSeverity_Critical ;
    noria:alarmProposedRepairAction inst:SecurityIncidentResponsePlan ;
    noria:alarmMonitoredAttribute inst:Server_DB_01 .

inst:TT_DB_Performance_002 a noria:TroubleTicket ;
    rdfs:label "Database Performance Degradation"^^xsd:string ;
    rdfs:comment "Trouble ticket opened due to slow database performance affecting the ERP application, reported by multiple users."^^xsd:string ;
    noria:documentExternalId "EXT-TT-DB-002"^^xsd:string ;
    noria:documentHRef "https://itsm.global.com/ticket/TT-2024-05-01-002"^^xsd:anyURI ;
    noria:troubleTicketSeverity inst:TTSeverity_Major ;
    noria:troubleTicketType inst:TTType_Failure ;
    noria:troubleTicketCriticity inst:TTCriticity_CorruptedService ;
    noria:troubleTicketPriority inst:TTPriority_P2 ;
    noria:troubleTicketOrigin inst:TTOrigin_Supervision ;
    noria:troubleTicketTrigger inst:Event_DB_HighCPU ;
    noria:troubleTicketUrgency inst:TTUrgency_Deferred ;
    noria:troubleTicketSupervisionTool "Prometheus"^^xsd:string ;
    noria:troubleTicketCategory inst:TTTroubleCategory_DowngradingEquipment ;
    noria:problemCategory inst:TTTroubleCategory_DowngradingEquipment ;
    noria:troubleTicketCause "Inefficient database queries leading to high CPU utilization and slow response times."^^xsd:string ;
    noria:problemResponsibility inst:TTProblemResponsibility_ApplicationHosting ;
    noria:troubleTicketDetectionDateTime "2024-05-01T08:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-05-01T18:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-05-01T17:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-05-02T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true^^xsd:boolean ;
    noria:troubleTicketStatusCurrent inst:TTStatus_InProgress ;
    noria:troubleTicketRelatedParty inst:BobWhite ;
    noria:troubleTicketPartyIntervention inst:AppDev_Team ;
    noria:troubleTicketRelatedService inst:FinancialReportingService ;
    noria:troubleTicketRelatedResource inst:Server_DB_01 ;
    noria:troubleTicketImpacts inst:ERP_Application ;
    noria:troubleTicketImpacts inst:FinancialReportingService ;
    noria:troubleTicketCharacteristic inst:AnomalyPattern_SQLInjection ;
    noria:troubleTicketFreezeItem inst:Event_DB_HighCPU ;
    noria:documentStatusHistory inst:Event_DB_HighCPU .

inst:TTNote_DB_Tuning_002 a noria:TroubleTicketNote ;
    rdfs:label "DB Tuning Note for TT-002"^^xsd:string ;
    rdfs:comment "Initial diagnosis and actions taken for database performance issue, including query optimization."^^xsd:string ;
    dcterms:isPartOf inst:TT_DB_Performance_002 ;
    dcterms:created "2024-05-01T10:00:00Z"^^xsd:dateTime ;
    dcterms:creator inst:BobWhite ;
    dcterms:description "Identified several slow-running queries. Applying index optimization and refactoring complex joins. Monitoring performance post-changes."^^xsd:string ;
    noria:troubleTicketNoteCommentType inst:TTNoteCommentType_Internal ;
    noria:troubleTicketNoteOperationType inst:TTNoteOperationType_TestsAndMeasurements ;
    noria:troubleTicketNoteCorrelatedExecution inst:Event_DB_HighCPU .

inst:CR_SecurityPatch_EdgeRtr a noria:ChangeRequest ;
    rdfs:label "Security Patch Deployment on Edge Router"^^xsd:string ;
    rdfs:comment "Change request for deploying a critical security patch on London Edge Router 01 to address a known vulnerability."^^xsd:string ;
    noria:documentExternalId "EXT-CR-SEC-001"^^xsd:string ;
    noria:documentHRef "https://itsm.global.com/change/CR-2024-05-03-001"^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-05-03T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-03T02:30:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-05-03T01:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-05-03T02:15:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory inst:CRCategory_InternalIntervention ;
    noria:changeRequestType inst:CRType_Emergency ;
    noria:changeRequestChangeCause inst:CRCause_SoftwareUpgrade ;
    noria:changeRequestImpact inst:Router_Edge_LDN_01 ;
    noria:changeRequestImpact inst:VPN_AccessService ;
    noria:changeRequestOutageDuration "PT1H15M"^^xsd:duration ;
    noria:changeRequestStatusCurrent inst:CRStatus_Implemented ;
    noria:changeRequestSpecification inst:CRSpecification_SecurityPatch ;
    noria:changeRequestInitiatorParty inst:AliceBrown ;
    noria:changeRequestPilotParty inst:AliceBrown ;
    noria:changeRequestActorParty inst:NetworkOps_EU ;
    noria:changeRequestIsRegulated true^^xsd:boolean ;
    noria:documentStatusHistory inst:Event_Security_Alert .

inst:DocAttach_PatchNotes a noria:DocumentAttachment ;
    rdfs:label "Security Patch Release Notes"^^xsd:string ;
    rdfs:comment "Attached document containing release notes and installation instructions for the Juniper OS security patch."^^xsd:string ;
