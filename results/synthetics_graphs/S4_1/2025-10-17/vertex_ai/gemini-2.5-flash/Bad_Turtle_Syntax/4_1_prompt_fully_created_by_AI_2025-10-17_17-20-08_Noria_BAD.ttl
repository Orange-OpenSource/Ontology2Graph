# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan/FiberTroubleshooting a noria:OperationPlan ;
    rdfs:label "Fiber Optic Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving fiber optic link issues."@en .

noria:ActionPreCondition/FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition: A fiber optic network link is reported as down or degraded."@en .

noria:ActionPostCondition/FiberLinkUp a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Up Post-Condition"@en ;
    rdfs:comment "Post-condition: The fiber optic network link is restored to operational status."@en .

noria:OperationPlan/FiberTroubleshooting noria:operationPlanPreCondition noria:ActionPreCondition/FiberLinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition/FiberLinkUp .

noria:OperationPlan/DBLogCleanup a noria:OperationPlan ;
    rdfs:label "Database Log Cleanup Procedure"@en ;
    rdfs:comment "Procedure for routine cleanup and rotation of database log files to prevent disk space issues."@en .

noria:ActionPreCondition/DiskSpaceLow a noria:ActionPreCondition ;
    rdfs:label "Disk Space Low Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Database server disk space usage exceeds 90%."@en .

noria:ActionPostCondition/DiskSpaceNormal a noria:ActionPostCondition ;
    rdfs:label "Disk Space Normal Post-Condition"@en ;
    rdfs:comment "Post-condition: Database server disk space usage is below 80%."@en .

noria:OperationPlan/DBLogCleanup noria:operationPlanPreCondition noria:ActionPreCondition/DiskSpaceLow ;
    noria:operationPlanPostCondition noria:ActionPostCondition/DiskSpaceNormal .

# Link TroubleTicket to OperationPlan via EventRecord (alarmMitigatedBy)
noria:EventRecord/Log_CoreRouter01_InterfaceDown noria:alarmProposedRepairAction noria:OperationPlan/FiberTroubleshooting .
noria:EventRecord/Log_DBServer01_DiskFull noria:alarmProposedRepairAction noria:OperationPlan/DBLogCleanup .

