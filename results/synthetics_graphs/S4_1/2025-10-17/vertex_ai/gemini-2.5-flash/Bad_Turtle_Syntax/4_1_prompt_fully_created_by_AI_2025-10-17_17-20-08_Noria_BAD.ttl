# Add a few more EventRecords to show variety
noria:EventRecord/Log_AppModule_StatusChange a noria:EventRecord ;
    rdfs:label "App Module Status Change Event"@en ;
    rdfs:comment "Event indicating a change in status for an application module."@en ;
    dcterms:type kos-notif:EventType/stateChange ;
    noria:loggingTime "2024-04-19T18:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ApplicationModule/MainWebApp_Dev ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringPlatform ;
    noria:logText "Application module MWAPP_DEV_DC1 status changed to Under Maintenance."@en ;
    noria:alarmSeverity kos-notif:Severity/PerceivedSeverity/Informational .

noria:EventRecord/Log_SecurityAlert_SQLInjection a noria:EventRecord ;
    rdfs:label "Security Alert: SQL Injection Attempt"@en ;
    rdfs:comment "Alert from security system indicating a potential SQL injection attempt."@en ;
    dcterms:type kos-notif:EventType/thresholdExceeded ; # Or a specific security event type
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Application/SecurityServices ;
    noria:logOriginatingManagementSystem noria:Application/SecurityServices ; # Assuming the firewall itself is the system
    noria:logOriginatingAgent foaf:Agent/SecurityTeam ; # SOC team is handling it
    noria:logText "Potential SQL Injection detected from IP 203.0.113.42 targeting MainWebApp."@en ;
    noria:alarmSeverity kos-notif:Severity/PerceivedSeverity/Critical .

noria:TroubleTicket/TT_20240420_004 a noria:TroubleTicket ;
    rdfs:label "SQL Injection Attempt Incident"@en ;
    rdfs:comment "Critical incident opened due to a detected SQL injection attempt on the main web application."@en ;
    noria:documentExternalId "INC-SEC-2024-004" ;
    noria:troubleTicketSeverity kos-tt:severity/Critical ;
    noria:troubleTicketType kos-tt:type/Failure ;
    noria:troubleTicketOrigin kos-tt:origin/Supervision ;
    noria:troubleTicketTrigger noria:EventRecord/Log_SecurityAlert_SQLInjection ;
    noria:troubleTicketStatusCurrent kos-tt:status/InProgress ;
    noria:troubleTicketRelatedService noria:Application/MainWebApp ;
    noria:troubleTicketRelatedParty foaf:Agent/SecurityTeam .

noria:TroubleTicketNote/TT_20240420_004_Note1 a noria:TroubleTicketNote ;
    rdfs:label "SQL Injection Mitigation Steps"@en ;
    dcterms:isPartOf noria:TroubleTicket/TT_20240420_004 ;
    dcterms:created "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent/SecurityTeam ;
    dcterms:description "Blocked source IP at perimeter firewall. Investigating application logs for impact."@en ;
    noria:troubleTicketNoteCommentType kos-tt:commentType/Internal ;
    noria:troubleTicketNoteOperationType kos-tt:operationType/Intervention .

noria:TroubleTicketNote/TT_20240420_004_Note1 noria:troubleTicketNoteCorrelatedExecution noria:ChangeRequest/CR_20240419_001 . # Example of correlation, assuming CR was related to security hardening.

# Final check for connectivity and density:
# - All main entities (Agent, Resource, Application, Service, TT, CR, EventRecord, Location) are instantiated.
# - Most properties from the NORIA vocabulary are used at least once.
# - Entities are interconnected:
#   - Agents manage Resources/AppModules.
#   - Resources are for Applications, located at Locus, have ProductModels, NetworkInterfaces.
#   - Applications have Modules.
#   - Services are composed of AppModules/Resources.
#   - NetworkInterfaces are on Resources and connect to NetworkLinks.
#   - NetworkLinks connect Resources.
#   - EventRecords originate from Resources/Applications/Agents and trigger TroubleTickets.
#   - TroubleTickets relate to Services/Applications/Resources/Agents and have Notes.
#   - ChangeRequests impact Resources/Applications/Services/AppModules and relate to Agents.
#   - OperationPlans have Pre/Post Conditions and are proposed for alarms.
#   - Locations (Site, Room, Locus) are linked.
# - SKOS concepts are defined and used.
# - No ldp prefix.
# - Labels and comments are provided.
# - Syntax is Turtle.

# This graph is quite dense and covers a wide range of NORIA concepts.
