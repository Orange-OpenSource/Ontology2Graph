    rdfs:comment "Specific rack location in DR Server Room."@en ;
    noria:locusLine "DR-A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room/DRServerRoom .

noria:Resource/DRDBServer01 noria:locatedAtLocus noria:Locus/DRRack1 .

# Ensure all applications have modules, and modules are linked to applications
noria:Application/MainWebApp noria:elementProperty noria:ApplicationModule/MainWebApp_Prod .
noria:Application/MainWebApp noria:elementProperty noria:ApplicationModule/MainWebApp_Dev .
noria:Application/MonitoringPlatform noria:elementProperty noria:ApplicationModule/MonitoringPlatform_Prod .

# Ensure all services are composed of something
noria:Service/CustomerWebAccess seas:subSystemOf noria:Resource/WebServer01 .
noria:Service/CustomerWebAccess seas:subSystemOf noria:Resource/LoadBalancer01 .
noria:Service/DatabaseConnectivity seas:subSystemOf noria:Resource/DBServer01 .

# Ensure all trouble tickets and change requests are linked to relevant parties and elements
noria:TroubleTicket/TT_20240420_001 noria:troubleTicketRelatedParty foaf:Agent/AdminTeam .
noria:TroubleTicket/TT_20240420_002 noria:troubleTicketRelatedParty foaf:Agent/DBATeam .
noria:TroubleTicket/TT_20240420_003 noria:troubleTicketRelatedParty foaf:Agent/SecurityTeam .

noria:ChangeRequest/CR_20240419_001 noria:changeRequestInitiatorParty foaf:Agent/SecurityTeam .
noria:ChangeRequest/CR_20240418_002 noria:changeRequestInitiatorParty foaf:Agent/AdminTeam .

