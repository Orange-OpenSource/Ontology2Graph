noria:NetworkInterface/CoreRouter01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting CoreRouter01 to the Firewall01."@en ;
