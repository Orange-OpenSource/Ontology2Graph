    noria:networkInterfaceOf noria:Resource/CoreRouter01 ;
    noria:networkInterfaceAdministrativeStatus kos-res:AdministrativeState/enabled ;
    noria:networkInterfaceOperationalStatus kos-res:OperationalState/up ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkInterface/Firewall01_Eth0 a noria:NetworkInterface ;
