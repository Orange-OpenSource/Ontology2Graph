    noria:networkInterfaceLaserRxOpticalPower -7 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -3 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkLink/LAN_Servers a noria:NetworkLink ;
    rdfs:label "Server LAN Link"@en ;
    rdfs:comment "Local Area Network segment connecting web and database servers."@en ;
    noria:networkLinkId "LAN-PROD-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-10T08:00:00Z"^^xsd:dateTime ;
