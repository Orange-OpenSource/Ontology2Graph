# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# --- Custom KOS for NORIA ---
@prefix kos: <https://w3id.org/noria/kos/> .
@prefix kos-app: <https://w3id.org/noria/kos/application/> .
@prefix kos-res: <https://w3id.org/noria/kos/Resource/> .
@prefix kos-tt: <https://w3id.org/noria/kos/TroubleTicket/> .
@prefix kos-cr: <https://w3id.org/noria/kos/ChangeRequest/> .
@prefix kos-notif: <https://w3id.org/noria/kos/Notification/> .
@prefix kos-org: <https://w3id.org/noria/kos/org/> .
@prefix kos-svc: <https://w3id.org/noria/kos/service/> .

# =============================================================================
# KOS (Knowledge Organization System) - Controlled Vocabularies
# =============================================================================

# Application Types
kos-app:type a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of applications."@en .

kos-app:type/infrastructure a skos:Concept ;
    skos:inScheme kos-app:type ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Applications that provide core infrastructure services."@en .

kos-app:type/business a skos:Concept ;
    skos:inScheme kos-app:type ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "Applications directly supporting business operations."@en .

kos-app:type/monitoring a skos:Concept ;
    skos:inScheme kos-app:type ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "Applications used for system monitoring and alerting."@en .

# Application Business Importance
kos-app:business-importance a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    dcterms:description "A scheme for classifying the business importance of applications."@en .

kos-app:business-importance/high a skos:Concept ;
    skos:inScheme kos-app:business-importance ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for core business functions."@en .

kos-app:business-importance/medium a skos:Concept ;
    skos:inScheme kos-app:business-importance ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application supports important but not critical business functions."@en .

kos-app:business-importance/low a skos:Concept ;
    skos:inScheme kos-app:business-importance ;
    rdfs:label "Low Business Importance"@en ;
    rdfs:comment "Application is non-critical or for internal support."@en .

# Application Status
kos-app:status a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    dcterms:description "A scheme for classifying the operational status of application modules."@en .

kos-app:status/InProduction a skos:Concept ;
    skos:inScheme kos-app:status ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently active and serving users."@en .

kos-app:status/Maintenance a skos:Concept ;
    skos:inScheme kos-app:status ;
    rdfs:label "Under Maintenance"@en ;
    rdfs:comment "The application module is temporarily offline for maintenance."@en .

kos-app:status/Development a skos:Concept ;
    skos:inScheme kos-app:status ;
    rdfs:label "In Development"@en ;
    rdfs:comment "The application module is under active development."@en .

# Resource Types
kos-res:type a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of IT resources."@en .

kos-res:type/server a skos:Concept ;
    skos:inScheme kos-res:type ;
    rdfs:label "Server"@en ;
    rdfs:comment "A physical or virtual server."@en .

kos-res:type/router a skos:Concept ;
    skos:inScheme kos-res:type ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router device."@en .

kos-res:type/firewall a skos:Concept ;
    skos:inScheme kos-res:type ;
    rdfs:label "Firewall"@en ;
    rdfs:comment "A network security firewall device."@en .

kos-res:type/database a skos:Concept ;
    skos:inScheme kos-res:type ;
    rdfs:label "Database Server"@en ;
    rdfs:comment "A server hosting a database."@en .

# Resource Lifecycle State
kos-res:LifecycleState a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    dcterms:description "A scheme for classifying the lifecycle state of resources."@en .

kos-res:LifecycleState/production a skos:Concept ;
    skos:inScheme kos-res:LifecycleState ;
    rdfs:label "Production"@en ;
    rdfs:comment "Resource is in active production use."@en .

kos-res:LifecycleState/staging a skos:Concept ;
    skos:inScheme kos-res:LifecycleState ;
    rdfs:label "Staging"@en ;
    rdfs:comment "Resource is in a pre-production testing environment."@en .

kos-res:LifecycleState/decommissioned a skos:Concept ;
    skos:inScheme kos-res:LifecycleState ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "Resource has been removed from service."@en .

# Resource Operational State
kos-res:OperationalState a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    dcterms:description "A scheme for classifying the operational state of resources."@en .

kos-res:OperationalState/up a skos:Concept ;
    skos:inScheme kos-res:OperationalState ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is operational."@en .

kos-res:OperationalState/down a skos:Concept ;
    skos:inScheme kos-res:OperationalState ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

# Resource Administrative State
kos-res:AdministrativeState a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    dcterms:description "A scheme for classifying the administrative state of resources."@en .

kos-res:AdministrativeState/enabled a skos:Concept ;
    skos:inScheme kos-res:AdministrativeState ;
    rdfs:label "Enabled"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

kos-res:AdministrativeState/disabled a skos:Concept ;
    skos:inScheme kos-res:AdministrativeState ;
    rdfs:label "Disabled"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

# Service Types
kos-svc:type a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of services."@en .

kos-svc:type/CustomerFacingService a skos:Concept ;
    skos:inScheme kos-svc:type ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "Service directly consumed by customers."@en .

kos-svc:type/ResourceFacingService a skos:Concept ;
    skos:inScheme kos-svc:type ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "Service supporting other services or internal operations."@en .

# TroubleTicket Severity
kos-tt:severity a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    dcterms:description "A scheme for classifying the severity of trouble tickets."@en .

kos-tt:severity/Critical a skos:Concept ;
    skos:inScheme kos-tt:severity ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Service is completely down or severely impacted."@en .

kos-tt:severity/Major a skos:Concept ;
    skos:inScheme kos-tt:severity ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant service degradation or partial outage."@en .

kos-tt:severity/Minor a skos:Concept ;
    skos:inScheme kos-tt:severity ;
    rdfs:label "Minor"@en ;
    rdfs:comment "Small impact on service, workaround available."@en .

# TroubleTicket Type
kos-tt:type a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of trouble tickets."@en .

kos-tt:type/Failure a skos:Concept ;
    skos:inScheme kos-tt:type ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Ticket related to a system or service failure."@en .

kos-tt:type/Assistance a skos:Concept ;
    skos:inScheme kos-tt:type ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Ticket requesting user assistance."@en .

# TroubleTicket Criticity (Category)
kos-tt:category a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Criticity Scheme"@en ;
    dcterms:description "A scheme for classifying the criticity of trouble tickets from customer impact."@en .

kos-tt:category/InterruptedService a skos:Concept ;
    skos:inScheme kos-tt:category ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "Service is completely unavailable to the customer."@en .

kos-tt:category/CorruptedService a skos:Concept ;
    skos:inScheme kos-tt:category ;
    rdfs:label "Corrupted Service"@en ;
    rdfs:comment "Service is available but data or functionality is corrupted."@en .

# TroubleTicket Priority
kos-tt:priority a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    dcterms:description "A scheme for classifying the priority of trouble tickets."@en .

kos-tt:priority/P1 a skos:Concept ;
    skos:inScheme kos-tt:priority ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate action required."@en .

kos-tt:priority/P2 a skos:Concept ;
    skos:inScheme kos-tt:priority ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, urgent action required."@en .

# TroubleTicket Origin
kos-tt:origin a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    dcterms:description "A scheme for classifying the origin of trouble tickets."@en .

kos-tt:origin/Customer a skos:Concept ;
    skos:inScheme kos-tt:origin ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Ticket originated from a customer report."@en .

kos-tt:origin/Supervision a skos:Concept ;
    skos:inScheme kos-tt:origin ;
    rdfs:label "Supervision System"@en ;
    rdfs:comment "Ticket originated from an automated monitoring system."@en .

# TroubleTicket Urgency
kos-tt:urgency a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    dcterms:description "A scheme for classifying the urgency of trouble tickets."@en .

kos-tt:urgency/ImmediateIntervention a skos:Concept ;
    skos:inScheme kos-tt:urgency ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Intervention required immediately."@en .

kos-tt:urgency/DeferredIntervention a skos:Concept ;
    skos:inScheme kos-tt:urgency ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Intervention can be scheduled later."@en .

# TroubleTicket Trouble Category
kos-tt:trouble-category a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category Scheme"@en ;
    dcterms:description "A scheme for classifying the technical impact or nature of the incident."@en .

kos-tt:trouble-category/NetworkOutage a skos:Concept ;
    skos:inScheme kos-tt:trouble-category ;
    rdfs:label "Network Outage"@en ;
    rdfs:comment "Complete loss of network connectivity."@en .

kos-tt:trouble-category/ServerFailure a skos:Concept ;
    skos:inScheme kos-tt:trouble-category ;
    rdfs:label "Server Failure"@en ;
    rdfs:comment "A server has failed or is unresponsive."@en .

# TroubleTicket Problem Responsibility
kos-tt:problemResponsibility a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    dcterms:description "A scheme for classifying the responsibility for a problem."@en .

kos-tt:problemResponsibility/InternalIT a skos:Concept ;
    skos:inScheme kos-tt:problemResponsibility ;
    rdfs:label "Internal IT"@en ;
    rdfs:comment "Responsibility lies with internal IT teams."@en .

kos-tt:problemResponsibility/Vendor a skos:Concept ;
    skos:inScheme kos-tt:problemResponsibility ;
    rdfs:label "Vendor"@en ;
    rdfs:comment "Responsibility lies with an external vendor."@en .

# TroubleTicket Status
kos-tt:status a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    dcterms:description "A scheme for classifying the current status of trouble tickets."@en .

kos-tt:status/Initialised a skos:Concept ;
    skos:inScheme kos-tt:status ;
    rdfs:label "Initialised"@en ;
    rdfs:comment "Ticket has been created."@en .

kos-tt:status/InProgress a skos:Concept ;
    skos:inScheme kos-tt:status ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Work is actively being done on the ticket."@en .

kos-tt:status/Resolved a skos:Concept ;
    skos:inScheme kos-tt:status ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue has been resolved."@en .

kos-tt:status/Closed a skos:Concept ;
    skos:inScheme kos-tt:status ;
    rdfs:label "Closed"@en ;
    rdfs:comment "The ticket has been closed."@en .

# TroubleTicket Note Comment Type
kos-tt:commentType a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    dcterms:description "A scheme for classifying the type of comment in a trouble ticket note."@en .

kos-tt:commentType/Internal a skos:Concept ;
    skos:inScheme kos-tt:commentType ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment visible only to internal teams."@en .

kos-tt:commentType/Customer a skos:Concept ;
    skos:inScheme kos-tt:commentType ;
    rdfs:label "Customer Comment"@en ;
    rdfs:comment "Comment visible to the customer."@en .

# TroubleTicket Note Operation Type
kos-tt:operationType a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    dcterms:description "A scheme for classifying the type of operation described in a trouble ticket note."@en .

kos-tt:operationType/Diagnosis a skos:Concept ;
    skos:inScheme kos-tt:operationType ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Note describing diagnostic steps taken."@en .

kos-tt:operationType/Intervention a skos:Concept ;
    skos:inScheme kos-tt:operationType ;
    rdfs:label "Intervention"@en ;
    rdfs:comment "Note describing an intervention or fix applied."@en .

# ChangeRequest Category
kos-cr:category a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    dcterms:description "A scheme for classifying the category of change requests."@en .

kos-cr:category/InternalIntervention a skos:Concept ;
    skos:inScheme kos-cr:category ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change performed by internal teams."@en .

kos-cr:category/CustomerRequest a skos:Concept ;
    skos:inScheme kos-cr:category ;
    rdfs:label "Customer Request"@en ;
    rdfs:comment "Change requested by a customer."@en .

# ChangeRequest Type
kos-cr:type a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    dcterms:description "A scheme for classifying the type of change requests based on impact/risk."@en .

kos-cr:type/Standard a skos:Concept ;
    skos:inScheme kos-cr:type ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Pre-approved, low-risk, routine change."@en .

kos-cr:type/Normal a skos:Concept ;
    skos:inScheme kos-cr:type ;
    rdfs:label "Normal Change"@en ;
    rdfs:comment "Requires assessment and authorization."@en .

# ChangeRequest Cause
kos-cr:cause a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    dcterms:description "A scheme for classifying the cause or reason for change requests."@en .

kos-cr:cause/SoftwareUpgrade a skos:Concept ;
    skos:inScheme kos-cr:cause ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change due to software version upgrade."@en .

kos-cr:cause/ConfigurationChange a skos:Concept ;
    skos:inScheme kos-cr:cause ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change due to modification of system configuration."@en .

# ChangeRequest Status
kos-cr:status a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    dcterms:description "A scheme for classifying the current status of change requests."@en .

kos-cr:status/Planned a skos:Concept ;
    skos:inScheme kos-cr:status ;
    rdfs:label "Planned"@en ;
    rdfs:comment "Change is planned but not yet started."@en .

kos-cr:status/Implemented a skos:Concept ;
    skos:inScheme kos-cr:status ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "Change has been successfully implemented."@en .

# ChangeRequest Specification
kos-cr:specification a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    dcterms:description "A scheme for classifying the specification of change requests."@en .

kos-cr:specification/RoutineMaintenance a skos:Concept ;
    skos:inScheme kos-cr:specification ;
    rdfs:label "Routine Maintenance"@en ;
    rdfs:comment "Change follows a routine maintenance plan."@en .

kos-cr:specification/SecurityPatch a skos:Concept ;
    skos:inScheme kos-cr:specification ;
    rdfs:label "Security Patch Deployment"@en ;
    rdfs:comment "Change involves deploying a security patch."@en .

# Notification Event Type
kos-notif:EventType a skos:ConceptScheme ;
    rdfs:label "Notification Event Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of notification events."@en .

kos-notif:EventType/stateChange a skos:Concept ;
    skos:inScheme kos-notif:EventType ;
    rdfs:label "State Change Event"@en ;
    rdfs:comment "Event indicating a change in operational state."@en .

kos-notif:EventType/thresholdExceeded a skos:Concept ;
    skos:inScheme kos-notif:EventType ;
    rdfs:label "Threshold Exceeded Event"@en ;
    rdfs:comment "Event indicating a monitored metric exceeded a threshold."@en .

kos-notif:EventType/configurationChange a skos:Concept ;
    skos:inScheme kos-notif:EventType ;
    rdfs:label "Configuration Change Event"@en ;
    rdfs:comment "Event indicating a change in configuration."@en .

# Notification Severity (PerceivedSeverity)
kos-notif:Severity/PerceivedSeverity a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Scheme"@en ;
    dcterms:description "A scheme for classifying the perceived severity of notifications."@en .

kos-notif:Severity/PerceivedSeverity/Critical a skos:Concept ;
    skos:inScheme kos-notif:Severity/PerceivedSeverity ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Critical severity notification."@en .

kos-notif:Severity/PerceivedSeverity/Major a skos:Concept ;
    skos:inScheme kos-notif:Severity/PerceivedSeverity ;
    rdfs:label "Major"@en ;
    rdfs:comment "Major severity notification."@en .

kos-notif:Severity/PerceivedSeverity/Warning a skos:Concept ;
    skos:inScheme kos-notif:Severity/PerceivedSeverity ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Warning severity notification."@en .

kos-notif:Severity/PerceivedSeverity/Informational a skos:Concept ;
    skos:inScheme kos-notif:Severity/PerceivedSeverity ;
    rdfs:label "Informational"@en ;
    rdfs:comment "Informational notification."@en .

# Agent Contact Method
kos-org:agent-contact-method a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    dcterms:description "A scheme for classifying preferred contact methods for agents."@en .

kos-org:agent-contact-method/email a skos:Concept ;
    skos:inScheme kos-org:agent-contact-method ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

kos-org:agent-contact-method/phone a skos:Concept ;
    skos:inScheme kos-org:agent-contact-method ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# Application SLA Level
kos-app:sla-level a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    dcterms:description "A scheme for classifying the SLA level of application modules."@en .

kos-app:sla-level/Platinum a skos:Concept ;
    skos:inScheme kos-app:sla-level ;
    rdfs:label "Platinum SLA"@en ;
    rdfs:comment "Highest SLA level with maximum availability and performance guarantees."@en .

kos-app:sla-level/Gold a skos:Concept ;
    skos:inScheme kos-app:sla-level ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "High SLA level with strong availability and performance guarantees."@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent/AdminTeam a foaf:Agent ;
    rdfs:label "Network Admin Team"@en, "Équipe d'Administration Réseau"@fr ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod kos-org:agent-contact-method/email ;
    noria:agentInstructions "For critical issues, call the on-call engineer after sending an email."@en .

foaf:Agent/DBATeam a foaf:Agent ;
    rdfs:label "Database Admin Team"@en, "Équipe d'Administration de Bases de Données"@fr ;
    rdfs:comment "Team responsible for managing database servers and services."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod kos-org:agent-contact-method/phone ;
    noria:agentInstructions "Use the dedicated ticketing system for all requests."@en .

foaf:Agent/AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support L2"@en, "Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support team for business applications."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod kos-org:agent-contact-method/phone ;
    noria:agentInstructions "Escalate P1/P2 incidents directly via phone, P3/P4 via ticket."@en .

foaf:Agent/SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod kos-org:agent-contact-method/email ;
    noria:agentInstructions "All security alerts must be forwarded to the SOC email alias."@en .

foaf:Agent/JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead Network Engineer."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod kos-org:agent-contact-method/phone ;
    noria:agentInstructions "Contact for complex network routing issues."@en .

foaf:Agent/JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Senior Database Administrator."@en ;
    noria:agentWorkingHours "8:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod kos-org:agent-contact-method/email ;
    noria:agentInstructions "Available for database performance tuning and critical data recovery."@en .

org:Organization/AcmeCorp a org:Organization ;
    rdfs:label "Acme Corporation"@en ;
    rdfs:comment "The main organization owning and operating the IT infrastructure."@en .

org:OrganizationalUnit/NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Organizational unit responsible for network operations."@en ;
    org:unitOf org:Organization/AcmeCorp ;
    noria:elementManagedBy foaf:Agent/AdminTeam .

org:OrganizationalUnit/DatabaseOps a org:OrganizationalUnit ;
    rdfs:label "Database Operations Unit"@en ;
    rdfs:comment "Organizational unit responsible for database operations."@en ;
    org:unitOf org:Organization/AcmeCorp ;
    noria:elementManagedBy foaf:Agent/DBATeam .

org:OrganizationalUnit/AppOps a org:OrganizationalUnit ;
    rdfs:label "Application Operations Unit"@en ;
    rdfs:comment "Organizational unit responsible for application operations."@en ;
    org:unitOf org:Organization/AcmeCorp ;
    noria:elementManagedBy foaf:Agent/AppSupportTeam .

