# Locations
# =============================================================================

bot:Site/DC1 a bot:Site ;
    rdfs:label "Main Data Center 1"@en, "Centre de Données Principal 1"@fr ;
    rdfs:comment "Primary data center for critical services."@en ;
    noria:siteId "DC-EAST-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" ;
    noria:sitePrincipalAddressStreet "Tech Avenue" .

bot:Site/DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en, "Site de Reprise après Sinistre"@fr ;
    rdfs:comment "Secondary data center for disaster recovery."@en ;
    noria:siteId "DC-WEST-02" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Boulevard" ;
    noria:sitePrincipalAddressCityName "Gotham" ;
    noria:sitePrincipalAddressPostalCode "90210" ;
    noria:sitePrincipalAddressCountry "US" ;
    noria:sitePrincipalAddressStreet "Backup Boulevard" .

noria:Room/ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room in DC1."@en ;
    bot:hasSpace bot:Site/DC1 .

noria:Room/NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Network equipment room in DC1."@en ;
    bot:hasSpace bot:Site/DC1 .

noria:Locus/RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Specific rack location in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room/ServerRoomA .

noria:Locus/RackB5 a noria:Locus ;
    rdfs:label "Rack B5"@en ;
    rdfs:comment "Specific rack location in Network Room B."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room/NetworkRoomB .

