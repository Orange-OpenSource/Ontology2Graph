# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:APC_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: A fiber optic network link is reported as down or experiencing signal loss."@en .

noria:APOC_FiberLinkUp a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Up_extra_node_1 Post-Condition"@en ;
    rdfs:comment "Expected outcome: The fiber optic network link is operational and stable."@en .

noria:APC_LowDiskSpace a noria:ActionPreCondition ;
    rdfs:label "Low Disk Space Pre-Condition"@en ;
    rdfs:comment "Condition: Server_extra_node_1 disk utilization exceeds a critical_extra_node_1 threshold."@en .

noria:APOC_DiskCapacityIncreased a noria:ActionPostCondition ;
    rdfs:label "Disk Capacity Increased Post-Condition"@en ;
    rdfs:comment "Expected outcome: Server_extra_node_1 disk capacity has been successfully increased and is below threshold."@en .

noria:APC_PendingPatches a noria:ActionPreCondition ;
    rdfs:label "Pending Security Patches Pre-Condition"@en ;
    rdfs:comment "Condition: Identified security vulnerabilities require software patching."@en .

noria:APOC_PatchesApplied a noria:ActionPostCondition ;
    rdfs:label "Security Patches Applied Post-Condition"@en ;
    rdfs:comment "Expected outcome: All required security patches have been successfully applied and verified."@en .

# --- Operation Plans (noria:OperationPlan) ---
noria:OP_CheckFiberConnection a noria:OperationPlan ;
    rdfs:label "Check Fiber Connection Procedure"@en ;
    rdfs:comment "Procedure to diagnose and resolve fiber optic link issues."@en ;
    skos:example "1. Verify physical connection. 2. Check optical power levels. 3. Replace fiber cable if necessary."@en ;
    noria:operationPlanPreCondition noria:APC_FiberLinkDown ;
    noria:operationPlanPostCondition noria:APOC_FiberLinkUp .

noria:OP_IncreaseDiskCapacity a noria:OperationPlan ;
    rdfs:label "Increase Disk Capacity Procedure"@en ;
    rdfs:comment "Procedure for adding or expanding disk storage on a server."@en ;
    skos:example "1. Backup data. 2. Add new disk/expand volume. 3. Verify new capacity."@en ;
    noria:operationPlanPreCondition noria:APC_LowDiskSpace ;
    noria:operationPlanPostCondition noria:APOC_DiskCapacityIncreased .

noria:OP_ApplySecurityPatches a noria:OperationPlan ;
    rdfs:label "Apply Security Patches Procedure"@en ;
    rdfs:comment "Standard_extra_node_1 procedure for applying security updates to servers."@en ;
    skos:example "1. Schedule maintenance window. 2. Apply patches. 3. Reboot and verify services."@en ;
    noria:operationPlanPreCondition noria:APC_PendingPatches ;
    noria:operationPlanPostCondition noria:APOC_PatchesApplied .

