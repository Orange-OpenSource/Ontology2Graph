# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface for DNS server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_Edge01_Ge0_0_0 a noria:NetworkInterface ;
    rdfs:label "edge01.corp.example.com:ge-0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to ISP A."@en ;
    noria:networkInterfaceOf noria:Resource_Router_Edge01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_Edge01_Ge0_0_1 a noria:NetworkInterface ;
    rdfs:label "edge01.corp.example.com:ge-0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting to ISP B (backup)."@en ;
    noria:networkInterfaceOf noria:Resource_Router_Edge01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Down> ;
    noria:networkInterfaceRoutingPriorityMetric 200 ;
    noria:networkInterfaceLaserTxOpticalPower -4 ;
    noria:networkInterfaceLaserRxOpticalPower -30 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface_Core01_Eth1_1 a noria:NetworkInterface ;
