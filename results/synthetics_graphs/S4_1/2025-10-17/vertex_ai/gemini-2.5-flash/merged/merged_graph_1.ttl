    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_VM_Web01_Eth0 a noria:NetworkInterface ;
    rdfs:label "web01.corp.example.com:eth0"@en ;
    rdfs:comment "Virtual Ethernet interface for Web Server VM."@en ;
    noria:networkInterfaceOf noria:Resource_VM_Web01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "db01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface for Database server."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
