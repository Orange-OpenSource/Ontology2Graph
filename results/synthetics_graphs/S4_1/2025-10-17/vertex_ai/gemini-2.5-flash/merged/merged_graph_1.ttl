    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_1> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis_extra_node_1> ;
    dcterms:isPartOf noria:TT_WebSrv01_Performance .

noria:TTN_CR01_Update1 a noria:TroubleTicketNote ;
    rdfs:label "CR01 Interface Outage Update 1"@en ;
    rdfs:comment "Physical inspection of Gi0/0/0 cable. Found damaged fiber. Replacing cable."@en ;
    dcterms:created "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_1> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Intervention_extra_node_1> ;
    dcterms:isPartOf noria:TT_CoreRouter_Outage .

noria:TTN_CR01_Update2 a noria:TroubleTicketNote ;
    rdfs:label "CR01 Interface Outage Update 2"@en ;
    rdfs:comment "Fiber cable replaced. Interface Gi0/0/0 is now up_extra_node_1. Monitoring service restoration."@en ;
    dcterms:created "2024-04-20T10:40:00Z"^^xsd:dateTime ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_1> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Intervention_extra_node_1> ;
    dcterms:isPartOf noria:TT_CoreRouter_Outage ;
    noria:troubleTicketNoteCorrelatedExecution noria:TT_CoreRouter_Outage .

noria:TTN_Security_Update1 a noria:TroubleTicketNote ;
    rdfs:label "Security Incident Update 1"@en ;
    rdfs:comment "Blocked source IP 203.0.113.42 at firewall_extra_node_1. Investigating logs for further compromise."@en ;
    dcterms:created "2024-04-20T11:50:00Z"^^xsd:dateTime ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_1> ;
