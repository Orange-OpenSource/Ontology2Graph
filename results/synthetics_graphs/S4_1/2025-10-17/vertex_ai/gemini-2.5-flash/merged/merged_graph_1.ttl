    noria:operationPlanPostCondition <operationPlan/Internet_Failover_Procedure> .

<actionPreCondition/DDoSAttackDetected> a noria:ActionPreCondition ;
    rdfs:label "DDoS Attack Detected"@en ;
    rdfs:comment "Condition: High volume of suspicious traffic targeting public-facing services."@en ;
    noria:operationPlanPreCondition <operationPlan/DDoS_Mitigation_Procedure> .

<actionPostCondition/TrafficNormalised> a noria:ActionPostCondition ;
    rdfs:label "Traffic Normalized"@en ;
    rdfs:comment "Expected outcome: Inbound traffic volume returns to normal levels, and service is accessible."@en ;
    noria:operationPlanPostCondition <operationPlan/DDoS_Mitigation_Procedure> .

# --- Anomaly Patterns (noria:AnomalyPattern) ---
<anomalyPattern/HighCPULowDisk> a noria:AnomalyPattern ;
    rdfs:label "High CPU and Low Disk Space Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating a potential resource exhaustion issue where a server experiences both high_extra_node_2 CPU usage and critically low disk space, often preceding a crash or service degradation."@en ;
    skos:example "If (CPU > 90% for 5min) AND (Disk_Usage > 95%), then trigger this pattern."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
<documentAttachment/NetworkDiagram_ParisDC> a noria:DocumentAttachment ;
    rdfs:label "Paris DC Network Diagram"@en ;
    rdfs:comment "PDF document containing the network topology diagram for Paris Data Center."@en ;
    dcterms:identifier "DOC-NET-PAR-001" ;
    dcterms:created "2024-01-01T09:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf" ;
    dcterms:source "https://docs.example.com/network/paris_dc_diagram.pdf" ;
    dcterms:isPartOf <troubleTicket/TT_20240420_001> .

<documentAttachment/CR_20240501_002_Plan> a noria:DocumentAttachment ;
    rdfs:label "Router_extra_node_2 OS Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the Edge Router_extra_node_2 01 OS upgrade."@en ;
    dcterms:identifier "DOC-CR-20240501-002-PLAN" ;
    dcterms:created "2024-04-22T11:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:source "https://docs.example.com/changes/CR-20240501-002_plan.docx" ;
