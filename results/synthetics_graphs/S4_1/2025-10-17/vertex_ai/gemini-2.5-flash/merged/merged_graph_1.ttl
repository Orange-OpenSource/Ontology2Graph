# --- Trouble Ticket Notes (noria:TroubleTicketNote) ---
noria:TTN_WebSrv01_Update1 a noria:TroubleTicketNote ;
    rdfs:label "WebSrv01 Performance Update 1"@en ;
    rdfs:comment "Initial investigation shows high_extra_node_1 CPU due to unexpected traffic spike. Scaling up_extra_node_1 resources."@en ;
