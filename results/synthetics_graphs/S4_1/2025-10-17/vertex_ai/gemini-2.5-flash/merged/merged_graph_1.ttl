    rdfs:comment "Procedure for safely updating router_extra_node_4 configurations."@en ;
    noria:operationPlanPreCondition noria:PreCondRouterAccessOK ;
    noria:operationPlanPostCondition noria:PostCondRouterConfigApplied .

noria:PreCondDNSPrimaryDown a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server_extra_node_4 Down"@en ;
    rdfs:comment "Condition: Primary DNS server is confirmed to be unreachable or unresponsive."@en .

noria:PostCondDNSServiceRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS resolution is functional and accessible from all clients."@en .

noria:PreCondRouterAccessOK a noria:ActionPreCondition ;
    rdfs:label "Router_extra_node_4 Access Verified"@en ;
    rdfs:comment "Condition: Secure access to the router_extra_node_4 is established and verified."@en .

noria:PostCondRouterConfigApplied a noria:ActionPostCondition ;
