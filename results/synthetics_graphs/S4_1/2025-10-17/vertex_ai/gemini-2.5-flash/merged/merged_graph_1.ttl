# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
foaf:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_3> ;
    noria:agentInstructions "Contact via email for non-urgent issues, phone_extra_node_3 for critical_extra_node_3 outages."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure_extra_node_3 and connectivity."@en ;
