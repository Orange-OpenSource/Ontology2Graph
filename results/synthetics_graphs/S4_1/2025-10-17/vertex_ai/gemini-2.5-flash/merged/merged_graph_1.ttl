# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
<agent/Team_NetworkOperations> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for the daily operation and maintenance of the network infrastructure_extra_node_2."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_2> ;
    noria:agentInstructions "For critical_extra_node_2 issues, call the hotline first, then open a ticket."@en .

