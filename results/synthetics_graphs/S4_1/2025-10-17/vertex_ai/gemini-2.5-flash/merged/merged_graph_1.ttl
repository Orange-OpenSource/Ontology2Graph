# --- Document Attachments (noria:DocumentAttachment) ---
noria:Doc_NetworkDiagram_DC01 a noria:DocumentAttachment ;
    rdfs:label "DC01 Network Diagram"@en ;
    rdfs:comment "PDF document containing the network topology diagram for Main Data Center."@en ;
    dcterms:created "2023-10-01T09:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf" ;
