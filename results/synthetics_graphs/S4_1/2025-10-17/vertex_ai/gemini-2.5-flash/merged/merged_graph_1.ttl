<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Switch> a skos:Concept ; skos:prefLabel "Switch"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Firewall> a skos:Concept ; skos:prefLabel "Firewall"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine"@en ; skos:inScheme <kos/Resource/type> .

<kos/Resource/LifecycleState> a skos:ConceptScheme ; skos:prefLabel "Resource Lifecycle State Scheme"@en .
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:prefLabel "Decommissioned"@en ; skos:inScheme <kos/Resource/LifecycleState> .

<kos/Resource/OperationalState> a skos:ConceptScheme ; skos:prefLabel "Resource Operational State Scheme"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Up"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down"@en ; skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/AdministrativeState> a skos:ConceptScheme ; skos:prefLabel "Resource Administrative State Scheme"@en .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; skos:prefLabel "Up"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; skos:prefLabel "Down"@en ; skos:inScheme <kos/Resource/AdministrativeState> .

<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ; skos:prefLabel "Perceived Severity Scheme"@en .
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .

<kos/service/type> a skos:ConceptScheme ; skos:prefLabel "Service Type Scheme"@en .
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en ; skos:inScheme <kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en ; skos:inScheme <kos/service/type> .

<kos/org/agent-contact-method> a skos:ConceptScheme ; skos:prefLabel "Agent Contact Method Scheme"@en .
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone"@en ; skos:inScheme <kos/org/agent-contact-method> .

<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ; skos:prefLabel "Application SLA Level Scheme"@en .
<https://w3id.org/noria/kos/application/sla-level/Platinum> a skos:Concept ; skos:prefLabel "Platinum"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; skos:prefLabel "Gold"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; skos:prefLabel "Silver"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# =============================================================================
# Agents (Teams and Individuals)
# =============================================================================

foaf:Agent_NetworkTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency phone line."@en .

foaf:Agent_ServerTeam a foaf:Agent ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team responsible for server and virtual machine management."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Open a ticket for non-critical issues. Call hotline for any server outage."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use internal chat for urgent development-related queries."@en .

foaf:Agent_CustomerSupport a foaf:Agent ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "First line support for customer inquiries."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JohnDoe a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JaneSmith a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Server Administrator."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_AliceJohnson a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

# Organizational Units
org:OrgUnit_ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "Overall IT department responsible for all IT services."@en ;
    org:hasMember foaf:Agent_JohnDoe, foaf:Agent_JaneSmith, foaf:Agent_AliceJohnson .

foaf:Agent_JohnDoe org:memberOf org:OrgUnit_ITDepartment .
foaf:Agent_JaneSmith org:memberOf org:OrgUnit_ITDepartment .
foaf:Agent_AliceJohnson org:memberOf org:OrgUnit_ITDepartment .

foaf:Agent_NetworkTeam org:subOrganizationOf org:OrgUnit_ITDepartment .
foaf:Agent_ServerTeam org:subOrganizationOf org:OrgUnit_ITDepartment .
foaf:Agent_AppDevTeam org:subOrganizationOf org:OrgUnit_ITDepartment .
foaf:Agent_CustomerSupport org:subOrganizationOf org:OrgUnit_ITDepartment .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

noria:CUid_AliceJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Johnson."@en ;
    foaf:accountName "ajohnson" ;
    foaf:holdsAccount foaf:Agent_AliceJohnson .

