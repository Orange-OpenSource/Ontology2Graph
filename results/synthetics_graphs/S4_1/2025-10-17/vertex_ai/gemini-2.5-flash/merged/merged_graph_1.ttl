# Network Links
# =============================================================================

noria:NetworkLink_ISP_A_Link a noria:NetworkLink ;
    rdfs:label "Link to ISP A"@en ;
    rdfs:comment "Primary internet uplink from Edge Router 01 to ISP A."@en ;
    noria:networkLinkId "NL-ISP-A-PAR" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-20T14:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_Edge01_Ge0_0_0 .

noria:NetworkLink_ISP_B_Link a noria:NetworkLink ;
    rdfs:label "Link to ISP B (Backup)"@en ;
    rdfs:comment "Backup internet uplink from Edge Router 01 to ISP B."@en ;
    noria:networkLinkId "NL-ISP-B-PAR" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-20T14:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_Edge01_Ge0_0_1 .

noria:NetworkLink_DC_LAN_Link a noria:NetworkLink ;
    rdfs:label "DC Internal LAN Link"@en ;
    rdfs:comment "Internal LAN link within Paris Data Center, connecting DNS server to core network."@en ;
    noria:networkLinkId "NL-DC-LAN-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-10T09:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Switch_Core01 .

noria:NetworkLink_Lyon_DC_WAN a noria:NetworkLink ;
    rdfs:label "Lyon-Paris WAN Link"@en ;
    rdfs:comment "WAN link connecting Lyon office to Paris Data Center."@en ;
    noria:networkLinkId "NL-LYN-PAR-WAN" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2023-05-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_Core01_Eth1_1 .

noria:NetworkLink_DB_LAN_Link a noria:NetworkLink ;
    rdfs:label "Database LAN Link"@en ;
    rdfs:comment "LAN link connecting Database server to internal network."@en ;
    noria:networkLinkId "NL-DB-LAN-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-06-01T12:00:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetworkInterface_DB01_Eth0 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DBServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Switch_Core01 .

noria:NetworkLink_FW_Internal_Link a noria:NetworkLink ;
    rdfs:label "Firewall Internal Link"@en ;
