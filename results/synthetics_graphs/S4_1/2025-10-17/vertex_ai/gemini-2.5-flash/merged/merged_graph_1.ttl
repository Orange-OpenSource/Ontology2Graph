# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OperationPlan_DNS_Restart a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNS_Unreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNS_Responding .

noria:ActionPreCondition_DNS_Unreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS service (port 53) is not reachable from internal network."@en .

noria:ActionPostCondition_DNS_Responding a noria:ActionPostCondition ;
    rdfs:label "DNS Service Responding"@en ;
    rdfs:comment "Outcome: DNS service (port 53) is responding to queries."@en .

noria:OperationPlan_Router_Firmware_Upgrade a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed procedure for upgrading Juniper router firmware."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_Router_Operational .

noria:ActionPreCondition_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Scheduled Maintenance Window"@en ;
    rdfs:comment "Condition: Operation must be performed during a pre-approved maintenance window."@en .

noria:ActionPostCondition_Router_Operational a noria:ActionPostCondition ;
    rdfs:label "Router Fully Operational"@en ;
    rdfs:comment "Outcome: Router is operational, all interfaces up, and routing protocols converged."@en .

noria:OperationPlan_FeatureDeployment a noria:OperationPlan ;
    rdfs:label "Website Feature Deployment Procedure"@en ;
    rdfs:comment "Procedure for deploying new features to the corporate website production environment."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_CodeReviewApproved ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FeatureLive .

noria:ActionPreCondition_CodeReviewApproved a noria:ActionPreCondition ;
    rdfs:label "Code Review Approved"@en ;
    rdfs:comment "Condition: All code changes for the feature have passed code review and testing."@en .

noria:ActionPostCondition_FeatureLive a noria:ActionPostCondition ;
    rdfs:label "New Feature Live and Functional"@en ;
    rdfs:comment "Outcome: New feature is deployed, accessible to users, and passes functional tests."@en .

# Linking Operation Plans to Change Requests
noria:ChangeRequest_Router_Upgrade_CR001 pep:usedProcedure noria:OperationPlan_Router_Firmware_Upgrade .
noria:ChangeRequest_NewFeature_CR003 pep:usedProcedure noria:OperationPlan_FeatureDeployment .

