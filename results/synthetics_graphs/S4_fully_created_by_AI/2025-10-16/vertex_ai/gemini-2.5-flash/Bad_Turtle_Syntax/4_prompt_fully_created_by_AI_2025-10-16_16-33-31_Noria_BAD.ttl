# Services
# =============================================================================

noria:Service001 a noria:Service ;
    rdfs:label "Corporate Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing network connectivity to all corporate sites."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule001 ; # Corporate Internet Access is a key component
    seas:subSystemOf noria:Resource003 ; # Core Router is a key component
