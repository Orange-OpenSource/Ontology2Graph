# Event Records
# =============================================================================

noria:EventRecord001 a noria:EventRecord ;
    rdfs:label "DNS Server 01 Unreachable Alert"@en ;
    rdfs:comment "Alert generated when DNS Server 01 became unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord002 a noria:EventRecord ;
    rdfs:label "Network Interface xe-0/0/0 Down"@en ;
    rdfs:comment "Log entry indicating that the uplink interface on Core Router R01 went down."@en ;
    noria:loggingTime "2024-04-10T08:58:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource003 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "IF-MIB::ifOperStatus.1 = down (Interface xe-0/0/0 on router01.corp.example.com)"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord003 a noria:EventRecord ;
    rdfs:label "Configuration Change on Core Router R01"@en ;
    rdfs:comment "Log entry for a configuration change applied to Core Router R01 by John Doe."@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource003 ;
    noria:logOriginatingAgent foaf:Agent004 ;
    noria:logText "Configuration changed by user 'jdoe' from 10.0.0.5. Added static route."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord004 a noria:EventRecord ;
    rdfs:label "CRM Database Connection Error"@en ;
    rdfs:comment "Application log indicating a database connection failure for CRM."@en ;
    noria:loggingTime "2024-04-11T14:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Application002 ;
    noria:logOriginatingManagementSystem noria:Application002 ; # Application itself logs
    noria:logText "ERROR: Database connection failed for CRM_PROD module. Check DB server status."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

