# =============================================================================
# Trouble Ticket Notes
# =============================================================================

noria:TroubleTicketNote001 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT001"@en ;
    rdfs:comment "NOC team performed initial checks, confirmed DNS server unreachable from multiple points."@en ;
    dcterms:isPartOf noria:TroubleTicket001 ;
    dcterms:created "2024-04-10T09:05:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote002 a noria:TroubleTicketNote ;
    rdfs:label "Escalation to Infrastructure Team for TT001"@en ;
    rdfs:comment "Issue escalated to Infrastructure Engineering Team due to suspected core network problem."@en ;
    dcterms:isPartOf noria:TroubleTicket001 ;
    dcterms:created "2024-04-10T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote003 a noria:TroubleTicketNote ;
    rdfs:label "Customer Update for TT002"@en ;
    rdfs:comment "Customer informed about the ongoing investigation for CRM connectivity issues."@en ;
    dcterms:isPartOf noria:TroubleTicket002 ;
    dcterms:created "2024-04-11T14:45:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent005 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> .

# =============================================================================
# Change Requests
# =============================================================================

noria:ChangeRequest001 a noria:ChangeRequest ;
    rdfs:label "Core Router R01 Software Upgrade"@en ;
    rdfs:comment "Scheduled software upgrade for Core Router R01 to enhance stability and features."@en ;
    noria:documentExternalId "CR-2024-05-01-001" ;
    noria:documentHRef <http://changemanagement.example.com/cr/CR-2024-05-01-001> ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource003, noria:Service001 ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty foaf:Agent004 ;
    noria:changeRequestPilotParty foaf:Agent003 ;
    noria:changeRequestActorParty foaf:Agent004 ;
    noria:changeRequestIsRegulated "true"^^xsd:boolean .

noria:ChangeRequest002 a noria:ChangeRequest ;
    rdfs:label "CRM Application Module Patch Deployment"@en ;
    rdfs:comment "Deployment of a critical security patch for the CRM production module."@en ;
    noria:documentExternalId "CR-2024-04-15-002" ;
    noria:documentHRef <http://changemanagement.example.com/cr/CR-2024-04-15-002> ;
    noria:changeRequestPlannedStartTime "2024-04-15T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-15T23:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ;
    noria:changeRequestType <kos/ChangeRequest/type/Emergency> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:ApplicationModule002 ;
    noria:changeRequestOutageDuration "PT30M"^^xsd:duration ; # 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/InProgress> ;
    noria:changeRequestInitiatorParty foaf:Agent005 ;
    noria:changeRequestPilotParty foaf:Agent002 ;
    noria:changeRequestActorParty foaf:Agent005 ;
    noria:changeRequestIsRegulated "false"^^xsd:boolean .

# =============================================================================
# Procedural Elements (Operation Plans, Pre/Post Conditions)
# =============================================================================

noria:OperationPlan001 a noria:OperationPlan ;
    rdfs:label "Core Router Software Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the software on core network routers."@en ;
    skos:example "1. Backup configuration. 2. Download new image. 3. Install image. 4. Reboot. 5. Verify connectivity."@en .

noria:ActionPreCondition001 a noria:ActionPreCondition ;
    rdfs:label "Router Backup Completed"@en ;
    rdfs:comment "Ensures that a full configuration backup of the router is completed before starting the upgrade."@en .

noria:ActionPostCondition001 a noria:ActionPostCondition ;
    rdfs:label "Router Connectivity Restored"@en ;
    rdfs:comment "Verifies that all network interfaces are up and routing protocols are converged after the upgrade."@en .

noria:OperationPlan001 noria:operationPlanPreCondition noria:ActionPreCondition001 ;
    noria:operationPlanPostCondition noria:ActionPostCondition001 .

noria:ChangeRequest001 noria:actionCorrelatedOperationPlan noria:OperationPlan001 .

noria:OperationPlan002 a noria:OperationPlan ;
    rdfs:label "DNS Server Troubleshooting Guide"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving DNS server issues."@en ;
    skos:example "1. Check server reachability. 2. Verify DNS service status. 3. Check logs for errors. 4. Restart DNS service."@en .

noria:ActionPreCondition002 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition where DNS resolution is failing or DNS server is not responding."@en .

noria:ActionPostCondition002 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Operational"@en ;
    rdfs:comment "Condition where DNS resolution is successful and DNS server is responding normally."@en .

noria:OperationPlan002 noria:operationPlanPreCondition noria:ActionPreCondition002 ;
    noria:operationPlanPostCondition noria:ActionPostCondition002 .

# Linking TroubleTicket to OperationPlan (implicitly via correlated execution or directly if applicable)
# For simplicity, let's assume the troubleshooting guide is implicitly followed for TT001.
# A more explicit link would be via EventRecord or ProcedureExecutionContainer.
# noria:TroubleTicket001 noria:troubleTicketCharacteristic noria:OperationPlan002 . # This property is for characteristics, not direct procedure link.
# The schema doesn't have a direct property from TroubleTicket to OperationPlan, but it can be inferred via EventRecord or ProcedureExecutionContainer.
# For now, I'll leave it as an implicit relationship or link via a future EventRecord.

# Example of DocumentAttachment
noria:DocumentAttachment001 a noria:DocumentAttachment ;
    rdfs:label "Router R01 Pre-Upgrade Configuration"@en ;
    rdfs:comment "Configuration file backup of Core Router R01 before the software upgrade."@en ;
    dcterms:isPartOf noria:ChangeRequest001 ;
    dcterms:created "2024-05-01T01:30:00Z"^^xsd:dateTime ;
    dcterms:format "text/plain" .

# Example of CorporateUserIdentifier
noria:CorporateUserIdentifier001 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    foaf:accountName "jdoe" ;
    observable:accountIdentifier "jdoe@example.com" ;
    foaf:holdsAccount foaf:Agent004 .

# Example of AnomalyPattern
noria:AnomalyPattern001 a noria:AnomalyPattern ;
    rdfs:label "High Packet Loss Anomaly"@en ;
    rdfs:comment "Pattern indicating high packet loss on a critical network link, often preceding an outage."@en ;
    skos:example "Detection of 100% packet loss on a primary interface for more than 5 minutes."@en .

# Linking EventRecord to AnomalyPattern (if it matches a known pattern)
# This is more of an inference, but we can state it as a relationship if the system identifies it.
# The schema doesn't have a direct property for this, but `dcterms:relation` or `folio:hasFailureMode` could be used.
noria:EventRecord001 folio:hasFailureMode noria:AnomalyPattern001 .

# Further connections to ensure density
noria:Resource001 noria:resourceForApplication noria:Application001 .
noria:Resource002 noria:resourceForApplication noria:Application001 .
noria:Resource003 noria:resourceForApplication noria:Application001 .
noria:Resource004 noria:resourceForApplication noria:Application001 .
noria:Resource005 noria:resourceForApplication noria:Application002 .

# Document status history for TroubleTicket001
noria:EventRecord005 a noria:EventRecord ;
    rdfs:label "TT001 Status Change: InProgress"@en ;
    rdfs:comment "System log for status change of TroubleTicket001 to InProgress."@en ;
    noria:loggingTime "2024-04-10T09:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://ticketing.example.com/system/ITSM> ;
    dcterms:title "InProgress" ;
    dcterms:type <kos/Notification/EventType/stateChange> . # Assuming this concept exists or is implied

noria:EventRecord006 a noria:EventRecord ;
    rdfs:label "TT001 Status Change: Resolved"@en ;
    rdfs:comment "System log for status change of TroubleTicket001 to Resolved."@en ;
    noria:loggingTime "2024-04-10T10:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://ticketing.example.com/system/ITSM> ;
    dcterms:title "Resolved" ;
    dcterms:type <kos/Notification/EventType/stateChange> .

noria:TroubleTicket001 noria:documentStatusHistory noria:EventRecord005, noria:EventRecord006 .

# Document status history for ChangeRequest002
noria:EventRecord007 a noria:EventRecord ;
    rdfs:label "CR002 Status Change: InProgress"@en ;
    rdfs:comment "System log for status change of ChangeRequest002 to InProgress."@en ;
    noria:loggingTime "2024-04-15T22:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://changemanagement.example.com/system/CMDB> ;
    dcterms:title "InProgress" ;
    dcterms:type <kos/Notification/EventType/stateChange> .

noria:EventRecord008 a noria:EventRecord ;
    rdfs:label "CR002 Status Change: Completed"@en ;
    rdfs:comment "System log for status change of ChangeRequest002 to Completed."@en ;
    noria:loggingTime "2024-04-15T22:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://changemanagement.example.com/system/CMDB> ;
    dcterms:title "Completed" ;
    dcterms:type <kos/Notification/EventType/stateChange> .

noria:ChangeRequest002 noria:documentStatusHistory noria:EventRecord007, noria:EventRecord008 .

# Example of a correlated execution for a TroubleTicketNote
noria:ProcedureExecutionContainer001 a pep:ProcedureExecutionContainer ;
    rdfs:label "Troubleshooting steps for DNS outage"@en ;
    rdfs:comment "Container for all actions taken during the DNS outage incident."@en ;
    ldp:member noria:EventRecord003 . # John Doe's config change was part of the resolution

noria:TroubleTicketNote002 noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer001 .

# Example of alarmMitigatedBy
noria:EventRecord001 noria:alarmMitigatedBy noria:ProcedureExecutionContainer001 .

# Add more connections for density
foaf:Agent003 noria:agentManagesResource noria:Resource001, noria:Resource002, noria:Resource003, noria:NetworkLink001, noria:NetworkLink003 .
foaf:Agent001 noria:agentManagesResource noria:Resource004, noria:NetworkLink002 .
foaf:Agent002 noria:agentManagesResource noria:Resource005 .

noria:Application001 seas:subSystemOf noria:Resource001, noria:Resource002, noria:Resource003 .
noria:Application002 seas:subSystemOf noria:Resource005 .
noria:Application003 seas:subSystemOf noria:Resource001, noria:Resource003 . # NMS monitors these resources

# Add more properties to existing entities
noria:Resource003 noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .
noria:Resource004 noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.1> .
noria:Resource005 noria:resourceManagementIPAddress <http://example.com/ip/10.0.1.100> .

noria:NetworkInterface003 noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int .
noria:NetworkInterface004 noria:networkInterfaceRoutingPriorityMetric "120"^^xsd:int .

noria:ApplicationModule001 noria:applicationModuleSupportGroup org:OrgUnit001 .
noria:ApplicationModule002 noria:applicationModuleHotlineGroup org:OrgUnit002 .

# Final check for connectivity:
# Every entity should be linked to at least one other.
# Agents, OrgUnits are linked to each other and to resources/applications/tickets.
# ProductModels are linked to Resources.
# Locations are linked to each other and to Resources.
# Resources are linked to Agents, ProductModels, Locations, NetworkInterfaces, Applications, Services, EventRecords, TroubleTickets, ChangeRequests.
# NetworkInterfaces are linked to Resources and NetworkLinks.
# NetworkLinks are linked to Resources and NetworkInterfaces.
# Applications are linked to Agents, Resources, ApplicationModules, Services, EventRecords, TroubleTickets, ChangeRequests.
# ApplicationModules are linked to Applications, Agents, Services, TroubleTickets, ChangeRequests.
# Services are linked to ApplicationModules, Resources, TroubleTickets, ChangeRequests.
# EventRecords are linked to Resources, Applications, Agents, TroubleTickets, ChangeRequests.
# TroubleTickets are linked to Applications, Services, Resources, Agents, EventRecords, TroubleTicketNotes.
# TroubleTicketNotes are linked to TroubleTickets, Agents, EventRecords.
# ChangeRequests are linked to Applications, Services, Resources, Agents, EventRecords, OperationPlans.
# OperationPlans are linked to ChangeRequests, Pre/PostConditions.
# Pre/PostConditions are linked to OperationPlans.
# DocumentAttachments are linked to ChangeRequests.
# CorporateUserIdentifiers are linked to Agents.
# AnomalyPatterns are linked to EventRecords.

# The graph is quite dense and connected.
