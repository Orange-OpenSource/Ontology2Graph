    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor for virtualized environments."@en ;
    noria:productManufacturedBy <https://www.vmware.com> . # Assuming VMware is an org:Organization

# --- Locations ---
bot:Site_MainDC a bot:Site ;
