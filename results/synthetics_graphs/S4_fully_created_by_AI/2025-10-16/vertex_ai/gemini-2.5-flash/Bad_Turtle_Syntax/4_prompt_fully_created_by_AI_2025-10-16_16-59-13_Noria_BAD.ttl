    rdfs:label "Security Audit Log - User Login"@en ;
    rdfs:comment "Log entry for a successful user login to a critical system."@en ;
    noria:loggingTime "2024-04-20T16:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingAgent noria:CUid_JohnDoe ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "User 'jdoe' successfully logged in to dns01.corp.example.com via SSH." ;
    dcterms:type <kos/Notification/EventType/SecurityLog> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_ApplicationHealthCheckOK a noria:EventRecord ;
    rdfs:label "Application Health Check OK"@en ;
    rdfs:comment "Log entry indicating a successful health check for the Customer Portal application."@en ;
    noria:loggingTime "2024-04-20T12:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ApplicationModule_CSP_Prod ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Customer Portal application health check passed." ;
    dcterms:type <kos/Notification/EventType/ApplicationStatus> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# --- More Trouble Tickets ---
noria:TroubleTicket_TT20240420_006 a noria:TroubleTicket ;
    rdfs:label "Failed Login Attempts on DNS Server"@en ;
    rdfs:comment "Multiple failed login attempts detected on DNS server dns01.corp.example.com."@en ;
    dcterms:identifier "TT20240420-006" ;
    dcterms:created "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/SecurityIncident> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_SecurityAlert ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Splunk" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/SecurityBreachAttempt> ;
    noria:troubleTicketCause "External brute force attack."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketRelatedParty foaf:Agent_SecurityTeam ;
    noria:troubleTicketImpacts noria:Application_CorpInternetAccess .

# --- More Change Requests ---
noria:ChangeRequest_CR20240428_006 a noria:ChangeRequest ;
    rdfs:label "Implement MFA for Admin Access"@en ;
    rdfs:comment "Project to implement Multi-Factor Authentication for all administrative access to critical infrastructure."@en ;
    dcterms:identifier "CR20240428-006" ;
    dcterms:created "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-06-30T17:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Project> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SecurityEnhancement> ;
    noria:changeRequestImpact noria:Resource_DNS01 ;
    noria:changeRequestImpact noria:Resource_CoreRouter1 ;
    noria:changeRequestImpact noria:Application_CorpInternetAccess ;
    noria:changeRequestOutageDuration "PT0H"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/InProgress> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/SecurityProject> ;
    noria:changeRequestInitiatorParty foaf:Agent_SecurityTeam ;
    noria:changeRequestPilotParty foaf:Agent_SecurityTeam ;
    noria:changeRequestActorParty org:OrgUnit_ITOperations ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef <http://changemanagement.example.com/CR20240428-006> .

# --- More Anomaly Patterns ---
noria:AnomalyPattern_BruteForceAttack a noria:AnomalyPattern ;
    rdfs:label "Brute Force Attack Pattern"@en ;
    rdfs:comment "Pattern describing repeated failed login attempts from a single or multiple sources against a target system."@en ;
    skos:example "Multiple 'SecurityAlert - Brute Force Attempt' events from SIEM, followed by potential successful login from an unusual source."@en .

# --- More Operation Plans and Conditions ---
noria:OperationPlan_RespondToBruteForce a noria:OperationPlan ;
    rdfs:label "Respond to Brute Force Attack Procedure"@en ;
    rdfs:comment "Procedure for responding to detected brute force attacks, including blocking IPs and reviewing logs."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_BruteForceDetected ;
    noria:operationPlanPostCondition noria:ActionPostCondition_AttackMitigated .

noria:ActionPreCondition_BruteForceDetected a noria:ActionPreCondition ;
    rdfs:label "Brute Force Detected Pre-Condition"@en ;
    rdfs:comment "Condition where a brute force attack is actively detected against a system."@en ;
    skos:example "SIEM generates a high-severity alert for brute force activity."@en .

noria:ActionPostCondition_AttackMitigated a noria:ActionPostCondition ;
    rdfs:label "Attack Mitigated Post-Condition"@en ;
    rdfs:comment "Expected outcome after responding to a brute force attack."@en ;
    skos:example "Attacking IP addresses are blocked, no further failed login attempts from those sources, and system integrity is confirmed."@en .

# --- Final connections for density and completeness ---
noria:TroubleTicket_TT20240420_006 noria:documentStatusHistory noria:EventRecord_SecurityAlert .
noria:TroubleTicket_TT20240420_006 noria:troubleTicketPartyIntervention foaf:Agent_SecurityTeam .

noria:ChangeRequest_CR20240428_006 noria:documentStatusHistory noria:EventRecord_SecurityAuditLog .

# --- Example of a complex relationship: Service impacting another Service ---
noria:Service_EnterpriseConnectivity seas:subSystem noria:Service_MonitoringAndAlerting . # Monitoring relies on network connectivity

# --- Example of a resource supporting multiple applications/services ---
noria:Resource_DNS01 noria:resourceForApplication noria:Application_CustomerPortal . # Customer portal relies on DNS resolution

# --- Example of a resource being managed by multiple agents/teams for different aspects ---
noria:Resource_DNS01 noria:resourceManagedBy foaf:Agent_SecurityTeam . # Security team also has oversight on critical servers

# --- Example of a TroubleTicketNote leading to a ChangeRequest ---
noria:TroubleTicketNote_TT20240420_002_Note1 dcterms:relation noria:ChangeRequest_CR20240425_003 . # Diagnosis might lead to a change request for optimization

# --- Example of a ChangeRequest being triggered by an AnomalyPattern ---
noria:ChangeRequest_CR20240425_003 dcterms:relation noria:AnomalyPattern_IntermittentDBConn . # CR to optimize DB indexes is related to the intermittent DB connection pattern

# --- Example of an EventRecord being correlated to an AnomalyPattern ---
