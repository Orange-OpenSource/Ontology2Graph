# --- Network Interfaces ---
noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Management interface" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_CR1_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "CR1 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface from Core Router 1 to external network."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter1 ;
    noria:networkInterfaceDescription "WAN Uplink to ISP A" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_CR1_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR1 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface from Core Router 1 to Core Router 2."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter1 ;
    noria:networkInterfaceDescription "Inter-router link to CR2" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -4 .

noria:NetworkInterface_CR2_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR2 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface from Core Router 2 to Core Router 1."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter2 ;
    noria:networkInterfaceDescription "Inter-router link to CR1" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -4 .

noria:NetworkInterface_VM_AppDB_Eth0 a noria:NetworkInterface ;
    rdfs:label "VM AppDB Ethernet 0"@en ;
    rdfs:comment "Network interface for the Application Database VM."@en ;
    noria:networkInterfaceOf noria:Resource_VM_AppDB ;
    noria:networkInterfaceDescription "Application network interface" ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# --- Network Links ---
noria:NetworkLink_CR1_CR2_Direct a noria:NetworkLink ;
    rdfs:label "Link CR1-CR2 Direct"@en ;
    rdfs:comment "Direct fiber link between Core Router 1 and Core Router 2."@en ;
    noria:networkLinkId "NL-CR1-CR2-001" ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter2 ;
    noria:networkLinkInstallationDate "2021-05-20T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR1_Gi0_0_1 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR2_Gi0_0_1 .

noria:NetworkLink_DNS01_CoreNetwork a noria:NetworkLink ;
    rdfs:label "Link DNS01-Core Network"@en ;
    rdfs:comment "Logical link connecting DNS01 to the core network."@en ;
    noria:networkLinkId "NL-DNS01-CORE-001" ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:networkLinkTerminationResource noria:Resource_DNS01 ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter1 ;
    noria:networkLinkInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects noria:NetworkInterface_DNS01_Eth0 .

noria:NetworkLink_VMAppDB_VirtualNetwork a noria:NetworkLink ;
    rdfs:label "Link VM AppDB-Virtual Network"@en ;
    rdfs:comment "Virtual network link for the Application Database VM."@en ;
    noria:networkLinkId "NL-VMAPPDB-VNET-001" ;
