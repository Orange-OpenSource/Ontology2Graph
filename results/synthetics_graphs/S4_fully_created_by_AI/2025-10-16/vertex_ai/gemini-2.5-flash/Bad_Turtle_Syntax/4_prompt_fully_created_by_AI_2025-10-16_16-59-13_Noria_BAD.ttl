    noria:sitePrincipalAddress "123 Main Street"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en, "Site de Reprise après Sinistre"@fr ;
    rdfs:comment "Secondary data center for disaster recovery purposes."@en ;
    noria:siteId "DC-LYO-02" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Avenue"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69001" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the primary data center."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Dedicated room for network equipment in the primary data center."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Specific rack location in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackN5 a noria:Locus ;
    rdfs:label "Rack N5"@en ;
    rdfs:comment "Specific rack location in Network Room B."@en ;
    noria:locusLine "N" ;
    noria:locusRow "5" ;
    bot:hasSpace noria:Room_NetworkRoomB .

