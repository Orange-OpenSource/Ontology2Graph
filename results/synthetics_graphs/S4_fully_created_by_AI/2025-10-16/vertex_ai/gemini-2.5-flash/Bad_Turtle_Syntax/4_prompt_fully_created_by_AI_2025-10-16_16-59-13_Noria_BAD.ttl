# --- Operation Plans, Pre/Post Conditions ---
noria:OperationPlan_CheckFiberLink a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en, "Procédure Vérification Liaison Fibre"@fr ;
    rdfs:comment "Procedure to diagnose and troubleshoot fiber optic link issues."@en ;
    skos:example "Steps include visual inspection, optical power meter readings, and loopback tests."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FiberLinkDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FiberLinkRestored .

noria:ActionPreCondition_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Condition where a fiber optic link is reported as down or degraded."@en ;
    skos:example "Network interface operational status is 'down' and optical power levels are out of range."@en .

noria:ActionPostCondition_FiberLinkRestored a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored Post-Condition"@en ;
    rdfs:comment "Expected outcome after executing the fiber link troubleshooting procedure."@en ;
    skos:example "Network interface operational status is 'up' and optical power levels are within acceptable limits."@en .

noria:OperationPlan_RestartDBService a noria:OperationPlan ;
    rdfs:label "Restart Database Service Procedure"@en, "Procédure Redémarrage Service BD"@fr ;
    rdfs:comment "Standard procedure for restarting a database service on a VM."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBServiceUnresponsive ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBServiceRunning .

noria:ActionPreCondition_DBServiceUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Database Service Unresponsive Pre-Condition"@en ;
    rdfs:comment "Condition where the database service is not responding to application requests."@en ;
    skos:example "Application logs show connection errors, database process is not running or hung."@en .

noria:ActionPostCondition_DBServiceRunning a noria:ActionPostCondition ;
    rdfs:label "Database Service Running Post-Condition"@en ;
    rdfs:comment "Expected outcome after restarting the database service."@en ;
    skos:example "Database service is running, application can connect, and error logs have ceased."@en .

