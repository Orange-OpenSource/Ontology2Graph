# --- Anomaly Patterns ---
noria:AnomalyPattern_DNSFailure a noria:AnomalyPattern ;
    rdfs:label "DNS Service Failure Pattern"@en ;
    rdfs:comment "Pattern describing a complete failure of DNS resolution, often indicated by multiple DNS servers being unreachable or returning errors."@en ;
    skos:example "Multiple critical alarms from monitoring system for DNS servers, coupled with user reports of internet access issues."@en .

noria:AnomalyPattern_IntermittentDBConn a noria:AnomalyPattern ;
    rdfs:label "Intermittent Database Connectivity Pattern"@en ;
    rdfs:comment "Pattern describing sporadic database connection errors, often due to resource contention or network instability."@en ;
    skos:example "Repeated 'database gone away' errors in application logs, high CPU/memory usage on DB server, but service is not fully down."@en .

