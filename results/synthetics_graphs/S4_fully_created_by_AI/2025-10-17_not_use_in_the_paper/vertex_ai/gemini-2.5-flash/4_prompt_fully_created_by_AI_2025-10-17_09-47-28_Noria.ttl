# =============================================================================
# Operation Plans
# =============================================================================

noria:OperationPlan_RouterRestart a noria:OperationPlan ;
    rdfs:label "Router Interface Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network interface on a router."@en ;
    skos:example "CLI commands: 'shutdown interface Gi0/0/0', 'no shutdown interface Gi0/0/0'"@en .

noria:OperationPlan_AppServiceRestart a noria:OperationPlan ;
    rdfs:label "Web Application Service Restart Procedure"@en ;
    rdfs:comment "Procedure for restarting the web application service on a server."@en ;
    skos:example "SSH to server, 'sudo systemctl restart apache2' or 'sudo service nginx restart'"@en .

noria:OperationPlan_DBQueryKill a noria:OperationPlan ;
    rdfs:label "Database Long Query Termination Procedure"@en ;
    rdfs:comment "Procedure to identify and terminate long-running database queries."@en ;
    skos:example "SQL commands: 'SHOW PROCESSLIST;', 'KILL <process_id>'"@en .

noria:OperationPlan_SecurityHardening a noria:OperationPlan ;
    rdfs:label "Server Security Hardening Procedure"@en ;
    rdfs:comment "Standard procedure for applying security hardening configurations to servers."@en ;
    skos:example "Steps include OS patching, firewall rule updates, and access control reviews."@en .

# =============================================================================
# Action Pre/Post Conditions
# =============================================================================

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Pre-condition: The target network interface must be in an operational 'down' state."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_RouterRestart .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Post-condition: The target network interface should transition to an operational 'up' state."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_RouterRestart .

noria:ActionPreCondition_AppServiceUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Web Application Service Unresponsive"@en ;
    rdfs:comment "Pre-condition: The web application service is not responding to requests (e.g., HTTP 503)."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_AppServiceRestart .

noria:ActionPostCondition_AppServiceResponsive a noria:ActionPostCondition ;
    rdfs:label "Web Application Service Responsive"@en ;
    rdfs:comment "Post-condition: The web application service is responding to requests (e.g., HTTP 200)."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_AppServiceRestart .

noria:ActionPreCondition_HighCPU_DB a noria:ActionPreCondition ;
    rdfs:label "Database Server High CPU"@en ;
    rdfs:comment "Pre-condition: Database server CPU utilization is consistently above 80%."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_DBQueryKill .

noria:ActionPostCondition_CPU_Normal_DB a noria:ActionPostCondition ;
    rdfs:label "Database Server CPU Normal"@en ;
    rdfs:comment "Post-condition: Database server CPU utilization returns to normal levels (below 50%)."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_DBQueryKill .

noria:ActionPreCondition_VulnerabilityScanReport a noria:ActionPreCondition ;
    rdfs:label "Vulnerability Scan Report Available"@en ;
    rdfs:comment "Pre-condition: A recent vulnerability scan report indicating critical findings is available."@en ;
    noria:operationPlanPreCondition noria:OperationPlan_SecurityHardening .

noria:ActionPostCondition_VulnerabilityResolved a noria:ActionPostCondition ;
    rdfs:label "Critical Vulnerabilities Resolved"@en ;
    rdfs:comment "Post-condition: All critical vulnerabilities identified in the scan report are resolved."@en ;
    noria:operationPlanPostCondition noria:OperationPlan_SecurityHardening .

# =============================================================================
# Anomaly Patterns
# =============================================================================

noria:AnomalyPattern_HighCPULongQuery a noria:AnomalyPattern ;
    rdfs:label "High CPU due to Long Running Query Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing high CPU utilization on a database server caused by a long-running, inefficient query."@en ;
    folio:hasCause noria:ActionPreCondition_HighCPU_DB .

