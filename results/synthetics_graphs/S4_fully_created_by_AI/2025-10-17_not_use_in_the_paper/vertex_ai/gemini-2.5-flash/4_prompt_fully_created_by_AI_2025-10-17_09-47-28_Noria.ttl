# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_ITOpsTeam a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for general IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via primary hotline for critical issues. Use ticketing system for non-urgent requests."@en .

foaf:Agent_NetworkTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri, on-call for critical issues"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for routine changes, call for network outages."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit all requests via the JIRA ticketing system."@en .

foaf:Agent_DBAdmin a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Critical database issues require immediate phone contact."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC) Team"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlert> ;
    noria:agentInstructions "Automated alerts from SIEM are primary. For manual reports, use secure email."@en .

foaf:Agent_CustomerSupportTeam a foaf:Agent ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "Team handling initial customer contacts."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Person_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    foaf:member foaf:Agent_NetworkTeam .

foaf:Person_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    foaf:member foaf:Agent_AppDevTeam .

foaf:Person_CharlieBrown a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    foaf:phone "+1-555-333-2222" ;
    foaf:member foaf:Agent_SecurityTeam .

foaf:Person_DavidClark a foaf:Person, foaf:Agent ;
    rdfs:label "David Clark"@en ;
    rdfs:comment "IT Operations Team Lead."@en ;
    foaf:mbox <mailto:david.clark@example.com> ;
    foaf:phone "+1-555-777-8888" ;
    foaf:member foaf:Agent_ITOpsTeam .

org:OrgUnit_ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "Main IT department overseeing all IT operations."@en ;
    org:hasMember foaf:Agent_ITOpsTeam, foaf:Agent_NetworkTeam, foaf:Agent_AppDevTeam, foaf:Agent_DBAdmin, foaf:Agent_SecurityTeam .

org:OrganizationalUnit_CustomerSupport a org:OrganizationalUnit ;
    rdfs:label "Customer Support Department"@en ;
    rdfs:comment "First line support for customer inquiries and incidents."@en ;
    org:hasMember foaf:Agent_CustomerSupportTeam .

# =============================================================================
# Corporate User Identifiers (CUids)
# =============================================================================

noria:CUid_AliceSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate login account for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    observable:accountLogin "asmith" ;
    observable:accountIdentifier "U12345" ;
    foaf:holdsAccount foaf:Person_AliceSmith .

noria:CUid_BobJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Corporate login account for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    observable:accountLogin "bjohnson" ;
    observable:accountIdentifier "U67890" ;
    foaf:holdsAccount foaf:Person_BobJohnson .

noria:CUid_CharlieBrown a noria:CorporateUserIdentifier ;
    rdfs:label "Charlie Brown's Corporate User ID"@en ;
    rdfs:comment "Corporate login account for Charlie Brown."@en ;
    foaf:accountName "cbrown" ;
    observable:accountLogin "cbrown" ;
    observable:accountIdentifier "U54321" ;
    foaf:holdsAccount foaf:Person_CharlieBrown .

noria:CUid_DavidClark a noria:CorporateUserIdentifier ;
    rdfs:label "David Clark's Corporate User ID"@en ;
    rdfs:comment "Corporate login account for David Clark."@en ;
    foaf:accountName "dclark" ;
    observable:accountLogin "dclark" ;
    observable:accountIdentifier "U11223" ;
    foaf:holdsAccount foaf:Person_DavidClark .

noria:CUid_GenericUser a noria:CorporateUserIdentifier ;
    rdfs:label "Generic User Account"@en ;
    rdfs:comment "A generic user account for system access."@en ;
    foaf:accountName "generic_user" ;
    observable:accountLogin "generic_user" ;
    observable:accountIdentifier "U99999" .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel_Cisco3850 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 3850"@en ;
    rdfs:comment "Enterprise-class stackable access layer switch."@en ;
