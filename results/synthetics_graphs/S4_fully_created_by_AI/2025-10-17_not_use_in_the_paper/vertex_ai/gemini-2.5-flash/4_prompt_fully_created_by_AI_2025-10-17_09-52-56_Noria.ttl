    noria:logOriginatingManagedObject noria:Resource003 ;
    noria:logOriginatingManagementSystem noria:Application002 ;
    noria:logOriginatingAgent foaf:Agent003 ;
    noria:logText "Policy 'Allow_SSH_NOC' updated on FW01-LYO-RO01."@en .

noria:EventRecord004 a noria:EventRecord ;
