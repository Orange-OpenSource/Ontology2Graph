# =============================================================================
# Agents and Organizational Units
# =============================================================================

foaf:Agent001 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:comment "Primary team responsible for monitoring and initial response to network incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline for critical issues, use ticketing system for non-critical."@en .

foaf:Agent002 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Team responsible for the support of critical business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate via ticketing system, then call on-call engineer."@en .

foaf:Agent003 a foaf:Agent ;
    rdfs:label "Infrastructure Engineering Team"@en ;
    rdfs:comment "Team responsible for design and maintenance of core IT infrastructure."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for routine requests, critical issues via NOC."@en .

foaf:Agent004 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC) Analyst"@en ;
    rdfs:comment "Individual responsible for analyzing security events and incidents."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via internal security platform."@en .

foaf:Agent005 a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use DB-specific ticketing system for requests, call for emergencies."@en .

foaf:Agent006 a foaf:Agent ;
    rdfs:label "Customer Service Representative John Doe"@en ;
    rdfs:comment "Front-line support for customer inquiries and initial incident reporting."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Log all customer issues in CRM, escalate to NOC if technical."@en .

org:OrganizationalUnit001 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department overseeing all IT operational activities."@en ;
    org:hasMember foaf:Agent001, foaf:Agent003, foaf:Agent005 .

org:OrganizationalUnit002 a org:OrganizationalUnit ;
    rdfs:label "Business Applications Division"@en ;
    rdfs:comment "Division responsible for business-critical applications."@en ;
    org:hasMember foaf:Agent002 .

org:OrganizationalUnit003 a org:OrganizationalUnit ;
    rdfs:label "Security Department"@en ;
    rdfs:comment "Department responsible for IT security."@en ;
    org:hasMember foaf:Agent004 .

noria:CorporateUserIdentifier001 a noria:CorporateUserIdentifier ;
