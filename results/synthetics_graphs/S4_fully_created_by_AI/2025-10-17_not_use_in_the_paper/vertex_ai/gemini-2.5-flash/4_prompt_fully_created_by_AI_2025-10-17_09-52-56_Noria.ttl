    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application002 ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/0.100, changed state to down."@en ;
