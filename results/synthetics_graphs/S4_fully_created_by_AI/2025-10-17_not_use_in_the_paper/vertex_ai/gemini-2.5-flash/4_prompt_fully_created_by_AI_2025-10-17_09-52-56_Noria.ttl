noria:ActionPreCondition004 a noria:ActionPreCondition ;
    rdfs:label "SQL Injection Detected"@en ;
    rdfs:comment "Pre-condition for SQL injection response: malicious SQL payload identified."@en .

noria:ActionPostCondition004 a noria:ActionPostCondition ;
    rdfs:label "Threat Mitigated and System Secured"@en ;
    rdfs:comment "Post-condition for SQL injection response: attacker blocked, vulnerability patched, and system integrity verified."@en .

noria:OperationPlan005 noria:operationPlanPreCondition noria:ActionPreCondition004 ;
    noria:operationPlanPostCondition noria:ActionPostCondition004 .

noria:TroubleTicketNote005 noria:troubleTicketNoteCorrelatedExecution noria:OperationPlan005 .

# Add a change request for a security patch
noria:ChangeRequest003 a noria:ChangeRequest ;
    rdfs:label "ERP Application Security Patch Deployment"@en ;
    rdfs:comment "Deployment of a critical security patch for the Corporate ERP System following a detected vulnerability."@en ;
    noria:documentExternalId "CR-20231027-003" ;
    noria:documentHRef "https://changemanagement.example.com/CR-20231027-003"^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2023-10-27T20:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2023-10-27T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/SoftwareUpgrade> ;
    noria:changeRequestType <kos/ChangeRequest/type/Emergency> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SecurityPatch> ;
    noria:changeRequestImpact noria:ApplicationModule001, noria:Service001 ;
    noria:changeRequestOutageDuration "PT0H30M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty foaf:Agent004 ;
    noria:changeRequestPilotParty foaf:Agent002 ;
    noria:changeRequestActorParty foaf:Agent002 ;
    noria:changeRequestIsRegulated true .

noria:OperationPlan006 a noria:OperationPlan ;
    rdfs:label "Application Patch Deployment Procedure"@en ;
    rdfs:comment "Standard procedure for deploying application security patches."@en ;
    skos:example "Steps include backup, patch installation, testing, and rollback plan."@en .

noria:ChangeRequest003 noria:changeRequestSpecification noria:OperationPlan006 .

