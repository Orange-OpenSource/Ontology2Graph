# Example of an anomaly pattern
noria:AnomalyPattern_HighCPUUsage a noria:AnomalyPattern ;
    rdfs:label "High CPU Usage Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU usage on a critical server, potentially leading to performance degradation or outage."@en ;
    folio:hasConsequence "Performance Degradation"@en ;
    folio:hasCause "Software Bug"@en .

# Example of an operation plan linked to an anomaly pattern
noria:OperationPlan_DiagnoseHighCPU a noria:OperationPlan ;
    rdfs:label "Diagnose High CPU Usage Procedure"@en ;
    rdfs:comment "Procedure to investigate and resolve high CPU usage on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_HighCPUAlert .

noria:ActionPreCondition_HighCPUAlert a noria:ActionPreCondition ;
    rdfs:label "High CPU Alert Triggered"@en ;
    rdfs:comment "Condition: An alert for high CPU usage (e.g., >90% for 5 minutes) has been triggered."@en .

noria:AnomalyPattern_HighCPUUsage dcterms:relation noria:OperationPlan_DiagnoseHighCPU .

