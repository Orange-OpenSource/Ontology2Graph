# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (for skos:inScheme ranges)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/business-critical> a skos:Concept ; rdfs:label "Business Critical Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; rdfs:label "Monitoring Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/database> a skos:Concept ; rdfs:label "Database Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/security> a skos:Concept ; rdfs:label "Security Application"@en ; skos:inScheme <kos/application/type> .

<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low Business Importance"@en ; skos:inScheme <kos/application/business-importance> .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; rdfs:label "Maintenance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en ; skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en ; skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en ; skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P3> a skos:Concept ; rdfs:label "Priority 3"@en ; skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision System Origin"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Origin"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Internal> a skos:Concept ; rdfs:label "Internal Origin"@en ; skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en ; skos:inScheme <kos/TroubleTicket/status> .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation"@en ; skos:inScheme <kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; rdfs:label "Resolution Operation"@en ; skos:inScheme <kos/TroubleTicket/operationType> .

<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en ; skos:inScheme <kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Normal> a skos:Concept ; rdfs:label "Normal Change"@en ; skos:inScheme <kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency Change"@en ; skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade Cause"@en ; skos:inScheme <kos/ChangeRequest/cause> .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; rdfs:label "Configuration Change Cause"@en ; skos:inScheme <kos/ChangeRequest/cause> .

<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved Status"@en ; skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented Status"@en ; skos:inScheme <kos/ChangeRequest/status> .

<kos/Resource/OperationalState/up> a skos:Concept ; rdfs:label "Operational State Up"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/down> a skos:Concept ; rdfs:label "Operational State Down"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/degraded> a skos:Concept ; rdfs:label "Operational State Degraded"@en ; skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/AdministrativeState/up> a skos:Concept ; rdfs:label "Administrative State Up"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/down> a skos:Concept ; rdfs:label "Administrative State Down"@en ; skos:inScheme <kos/Resource/AdministrativeState> .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ; rdfs:label "In Production Lifecycle State"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned Lifecycle State"@en ; skos:inScheme <kos/Resource/LifecycleState> .

<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server Resource Type"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router Resource Type"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Switch> a skos:Concept ; rdfs:label "Switch Resource Type"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine Resource Type"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Firewall> a skos:Concept ; rdfs:label "Firewall Resource Type"@en ; skos:inScheme <kos/Resource/type> .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical Perceived Severity"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major Perceived Severity"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor Perceived Severity"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning Perceived Severity"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .

<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email Contact Method"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone Contact Method"@en ; skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email dns-support@example.com for critical issues."@en .

foaf:Agent_NOC_L1 a foaf:Agent ;
    rdfs:label "NOC Level 1 Support"@en ;
    rdfs:comment "First line of defense for network operations, monitoring alerts and initial triage."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline 12345 for all network incidents."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use internal ticketing system for bug reports and feature requests."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate escalation for critical security alerts."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit_ITOperations a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Overall department managing IT infrastructure and services."@en .

org:OrgUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Unit within IT Operations focused on network infrastructure."@en ;
    org:unitOf org:OrgUnit_ITOperations .

org:OrgUnit_AppSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support Unit"@en ;
    rdfs:comment "Unit within IT Operations providing support for business applications."@en ;
    org:unitOf org:OrgUnit_ITOperations .

# =============================================================================
# Locations
# =============================================================================

bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC-PAR-01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75001"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace bot:Site_MainDC .

noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Locus_RackB2_U10 a noria:Locus ;
    rdfs:label "Rack B2, Unit 10"@en ;
    rdfs:comment "Specific location for a network device in Server Room A."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "2"@en ;
    bot:hasSpace noria:Room_ServerRoomA .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> . # Assuming a URI for Dell

noria:ProductModel_CiscoASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Enterprise-grade router for core network infrastructure."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> . # Assuming a URI for Cisco

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for hosting virtual machines."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> . # Assuming a URI for VMware

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, physical host."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ789"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress observable:IPAddress_DNS01_Mgmt .

observable:IPAddress_DNS01_Mgmt a observable:IPAddress ;
    rdfs:label "DNS01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.10"^^xsd:string .

noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy foaf:Agent_NOC_L1 ;
    noria:resourceHostName "cr01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceLogisticId "ASSET-CR-001"@en ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR01-ABC123"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB2_U10 ;
    noria:resourceManagementIPAddress observable:IPAddress_CR01_Mgmt .

observable:IPAddress_CR01_Mgmt a observable:IPAddress ;
    rdfs:label "Core Router 01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.254"^^xsd:string .

noria:Resource_CRM_VM01 a noria:Resource ;
    rdfs:label "CRM Application Virtual Machine 01"@en ;
    rdfs:comment "Virtual machine hosting the CRM application backend."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "crm-vm01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself, but it's a valid link for context.
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:IPAddress_CRM_VM01_Mgmt .

observable:IPAddress_CRM_VM01_Mgmt a observable:IPAddress ;
    rdfs:label "CRM VM01 Management IP"@en ;
    observable:ipAddressValue "172.16.1.10"^^xsd:string .

noria:Resource_Firewall_Edge a noria:Resource ;
    rdfs:label "Edge Firewall"@en ;
    rdfs:comment "Perimeter firewall protecting the corporate network."@en ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:resourceHostName "fw-edge.corp.example.com"@en ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2019-11-01T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:IPAddress_FW_Edge_Mgmt .

observable:IPAddress_FW_Edge_Mgmt a observable:IPAddress ;
    rdfs:label "Edge Firewall Management IP"@en ;
    observable:ipAddressValue "192.168.100.1"^^xsd:string .

# =============================================================================
# Network Interfaces and Links
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetworkInterface_CR01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Uplink interface for Core Router 01 to ISP."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_CR01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Internal interface for Core Router 01 to corporate LAN."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetworkLink_CR01_ISP a noria:NetworkLink ;
    rdfs:label "Core Router 01 to ISP Link"@en ;
    rdfs:comment "External network link connecting Core Router 01 to the Internet Service Provider."@en ;
    noria:networkLinkId "LINK-CR01-ISP-001"@en ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination <http://example.com/ISP_Router> ; # Assuming an external resource
    noria:networkLinkInstallationDate "2020-01-20T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:resourceManagedBy foaf:Agent_NOC_L1 .

noria:NetworkInterface_CR01_Gi0_0_0 noria:networkInterfaceConnects noria:NetworkLink_CR01_ISP .

noria:NetworkLink_DNS01_CR01 a noria:NetworkLink ;
    rdfs:label "DNS01 to Core Router 01 Link"@en ;
    rdfs:comment "Internal network link connecting DNS01 server to Core Router 01."@en ;
    noria:networkLinkId "LINK-DNS01-CR01-001"@en ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ;
    noria:networkLinkInstallationDate "2021-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam .

noria:NetworkInterface_DNS01_Eth0 noria:networkInterfaceConnects noria:NetworkLink_DNS01_CR01 .
noria:NetworkInterface_CR01_Gi0_0_1 noria:networkInterfaceConnects noria:NetworkLink_DNS01_CR01 .

# =============================================================================
# Applications and Modules
# =============================================================================

noria:Application_CorpDNS a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:comment "Provides name resolution services for all internal corporate systems."@en ;
    noria:applicationModelIdentifier "CORP-DNS-V1"@en ;
    noria:applicationNumericalIdentifier 101^^xsd:int ;
    noria:applicationShortIdentifier "CORPDNS"@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
