# Additional Connectivity and Density
# =============================================================================

# Link resources to applications they serve
noria:Resource_DNS01 noria:resourceForApplication noria:Application_CorpDNS .
noria:Resource_CRM_VM01 noria:resourceForApplication noria:Application_CRM .
noria:Resource_CoreRouter01 noria:resourceForApplication noria:Application_CorpDNS . # Router is part of DNS infrastructure
noria:Resource_Firewall_Edge noria:resourceForApplication noria:Application_MonitoringSystem . # Firewall protects monitoring system

# Link agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_DNSAdminTeam noria:agentManagesResource noria:Resource_DNS01 .
foaf:Agent_NOC_L1 noria:agentManagesResource noria:Resource_CoreRouter01 .
foaf:Agent_AppDevTeam noria:agentManagesResource noria:Resource_CRM_VM01 .
foaf:Agent_SecurityTeam noria:agentManagesResource noria:Resource_Firewall_Edge .

# Link applications to resources (more direct relationship)
noria:Application_CorpDNS seas:subSystemOf noria:Resource_DNS01 .
noria:Application_CRM seas:subSystemOf noria:Resource_CRM_VM01 .

# Example of CUid for an agent
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Unique corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"@en ;
    observable:accountLogin "jdoe"@en ;
    observable:accountIdentifier "EMP-JD-001"@en .

foaf:Agent_JohnDoe foaf:holdsAccount noria:CUid_JohnDoe .

# Example of a cluster controller
noria:Resource_VirtualCenter01 a noria:Resource ;
    rdfs:label "VMware vCenter Server 01"@en ;
    rdfs:comment "Centralized management platform for VMware virtual infrastructure."@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceHostName "vcenter01.corp.example.com"@en ;
    noria:resourceManagedBy foaf:Agent_NOC_L1 .

noria:Resource_CRM_VM01 noria:clusterController noria:Resource_VirtualCenter01 .

