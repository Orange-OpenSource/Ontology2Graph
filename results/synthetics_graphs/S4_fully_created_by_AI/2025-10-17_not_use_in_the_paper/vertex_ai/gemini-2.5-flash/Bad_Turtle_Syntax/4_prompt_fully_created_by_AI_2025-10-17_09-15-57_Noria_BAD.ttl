# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_CheckCable a noria:OperationPlan ;
    rdfs:label "Network Cable Replacement Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and replacing faulty network cables."@en ;
    skos:example "Steps include visual inspection, cable testing, and replacement."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up' after intervention."@en .

noria:OperationPlan_RestartDBService a noria:OperationPlan ;
    rdfs:label "Restart Database Service Procedure"@en ;
    rdfs:comment "Procedure to restart the database service for the CRM application."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBError ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBServiceRunning .

noria:ActionPreCondition_DBError a noria:ActionPreCondition ;
    rdfs:label "Database Connection Error"@en ;
    rdfs:comment "Condition: Application logs show database connection pool exhaustion or similar errors."@en .

noria:ActionPostCondition_DBServiceRunning a noria:ActionPostCondition ;
    rdfs:label "Database Service Running and Accessible"@en ;
    rdfs:comment "Expected outcome: Database service is running, and application can connect successfully."@en .

# =============================================================================
# Procedure Executions (linking events to procedures)
# =============================================================================

noria:ProcedureExecutionContainer_CableReplacement a pep:ProcedureExecutionContainer ;
    rdfs:label "Cable Replacement Execution for TT001"@en ;
    rdfs:comment "Container for events related to the cable replacement procedure during DNS outage."@en ;
    dcterms:created "2024-04-20T09:35:00Z"^^xsd:dateTime ;
    pep:usedProcedure noria:OperationPlan_CheckCable ;
    pep:member noria:EventRecord_RouterInterfaceDown . # This event is part of the execution context

noria:ProcedureExecution_CableSwap a pep:ProcedureExecution ;
    rdfs:label "Cable Swap Action"@en ;
    rdfs:comment "Specific action of swapping the network cable."@en ;
    dcterms:created "2024-04-20T09:40:00Z"^^xsd:dateTime ;
    pep:madeBy foaf:Agent_JohnDoe ;
    pep:hasCommand "replace cable Gi0/0/0"@en ;
    pep:hasSimpleResult "Cable replaced successfully."@en ;
    dcterms:isPartOf noria:ProcedureExecutionContainer_CableReplacement .

noria:EventRecord_InterfaceUpAfterFix a noria:EventRecord ;
    rdfs:label "Router Interface Up After Fix Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 came up after cable replacement."@en ;
    noria:loggingTime "2024-04-20T09:46:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    dcterms:isPartOf noria:ProcedureExecutionContainer_CableReplacement .

noria:TroubleTicket_DNSOutage_TT001 noria:documentStatusHistory noria:EventRecord_DNSOutageLog .
noria:TroubleTicket_DNSOutage_TT001 noria:documentStatusHistory noria:EventRecord_InterfaceUpAfterFix .

