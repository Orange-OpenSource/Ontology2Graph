    noria:loggingTime "2024-04-20T11:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_Edge ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
