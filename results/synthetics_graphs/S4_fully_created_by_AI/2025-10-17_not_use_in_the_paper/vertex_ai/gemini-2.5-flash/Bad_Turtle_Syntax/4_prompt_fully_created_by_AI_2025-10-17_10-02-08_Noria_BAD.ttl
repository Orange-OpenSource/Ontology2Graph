    noria:documentExternalId "REQ-20240420-002" ;
    noria:documentHRef <http://ticketing.example.com/REQ-20240420-002> ;
    noria:troubleTicketIsNotificationEnable true .

noria:TroubleTicketNote001 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT001"@en ;
    rdfs:comment "Confirmed DNS service is down on dns01.corp.example.com. Initiated failover to dns02.corp.example.com."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:created "2024-04-20T08:10:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent006 ;
    dcterms:isPartOf noria:TroubleTicket001 .

noria:TroubleTicketNote002 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Step for TT001"@en ;
    rdfs:comment "Restarted DNS service on dns01.corp.example.com. Service restored. Monitoring for stability."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ;
    dcterms:created "2024-04-20T09:25:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent006 ;
    dcterms:isPartOf noria:TroubleTicket001 .

noria:TroubleTicketNote003 a noria:TroubleTicketNote ;
    rdfs:label "Customer Report for TT002"@en ;
    rdfs:comment "Customer reported slow loading times and occasional timeouts on the portal."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
    dcterms:created "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    dcterms:creator <http://example.com/customer/Alice> ; # A customer agent, not necessarily a foaf:Agent in the internal system.
    dcterms:isPartOf noria:TroubleTicket002 .

