# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# SKOS Concepts for controlled vocabularies
# =============================================================================

# Application Types
<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/business-application> a skos:Concept ; rdfs:label "Business Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/monitoring-system> a skos:Concept ; rdfs:label "Monitoring System"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

# Application Module Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; rdfs:label "Maintenance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

# Service Types
<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .

# Trouble Ticket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .

# Trouble Ticket Type
<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .

# Trouble Ticket Origin
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .

# Trouble Ticket Priority
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "P1"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "P2"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ; rdfs:label "Total Breakdown"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/trouble-category/PartialDegradation> a skos:Concept ; rdfs:label "Partial Degradation"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; rdfs:label "Managed Backbone Networks"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/Customer> a skos:Concept ; rdfs:label "Customer"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .

# Trouble Ticket Status
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; rdfs:label "Resolution"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .

# Change Request Category
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .
<kos/ChangeRequest/category/CustomerIntervention> a skos:Concept ; rdfs:label "Customer Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .

# Change Request Type
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .

# Change Request Cause
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; rdfs:label "Configuration Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .

# Change Request Status
<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .

# Change Request Specification
<kos/ChangeRequest/specification/PatchDeployment> a skos:Concept ; rdfs:label "Patch Deployment"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> .
<kos/ChangeRequest/specification/NetworkConfiguration> a skos:Concept ; rdfs:label "Network Configuration"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .

# Resource Administrative State
<kos/Resource/AdministrativeState/Up> a skos:Concept ; rdfs:label "Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .

# Resource Lifecycle State
<kos/Resource/LifecycleState/Production> a skos:Concept ; rdfs:label "Production"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; rdfs:label "Staging"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .

# Resource Type
<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Switch> a skos:Concept ; rdfs:label "Switch"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/DatabaseServer> a skos:Concept ; rdfs:label "Database Server"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .

# Notification Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .

# Notification Event Type
<kos/Notification/EventType/stateChange> a skos:Concept ; rdfs:label "State Change"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/EventType> .
<kos/Notification/EventType/thresholdCrossing> a skos:Concept ; rdfs:label "Threshold Crossing"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/EventType> .
<kos/Notification/EventType/securityAlert> a skos:Concept ; rdfs:label "Security Alert"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/EventType> .

# =============================================================================
# Agents and Organizational Units
# =============================================================================

foaf:Agent001 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe Admin DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution of related incidents."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for P2/P3, direct call for P1."@en .

foaf:Agent002 a foaf:Agent ;
    rdfs:label "WebOps Team"@en, "Équipe Opérations Web"@fr ;
    rdfs:comment "Team managing web servers and application deployments."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use emergency hotline for critical incidents."@en .

foaf:Agent003 a foaf:Agent ;
    rdfs:label "Database Admin"@en, "Admin Base de Données"@fr ;
    rdfs:comment "Individual responsible for database systems."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent004 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en, "Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "First line of defense for network incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent005 a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual engineer from the WebOps Team."@en .

foaf:Agent006 a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Individual engineer from the DNS Admin Team."@en .

org:OrgUnit001 a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en ;
    rdfs:comment "Department overseeing all IT infrastructure."@en ;
    org:hasMember foaf:Agent001, foaf:Agent002, foaf:Agent003, foaf:Agent004 .

org:OrgUnit002 a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second level support for business applications."@en .

noria:CUid001 a noria:CorporateUserIdentifier ;
    rdfs:label "jdoe_corp"@en ;
    rdfs:comment "Corporate User ID for John Doe."@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount foaf:Agent005 .

noria:CUid002 a noria:CorporateUserIdentifier ;
    rdfs:label "jsmith_corp"@en ;
    rdfs:comment "Corporate User ID for Jane Smith."@en ;
    foaf:accountName "jsmith"@en ;
    foaf:holdsAccount foaf:Agent006 .

