bot:Site001 a bot:Site ;
    rdfs:label "Main Data Center Paris"@en, "Centre de Données Principal Paris"@fr ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@fr ;
    noria:sitePrincipalAddressCityName "Paris"@fr ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room001 a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace bot:Site001 .

noria:Room002 a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Network equipment room within the Paris Data Center."@en ;
    bot:hasSpace bot:Site001 .

noria:Locus001 a noria:Locus ;
    rdfs:label "Rack A1, Unit 1-2"@en ;
    rdfs:comment "Location for DNS Server 01."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "1-2" ;
    bot:hasSpace noria:Room001 .

noria:Locus002 a noria:Locus ;
    rdfs:label "Rack A2, Unit 3-4"@en ;
    rdfs:comment "Location for Web Server 01."@en ;
    noria:locusLine "A2" ;
    noria:locusRow "3-4" ;
    bot:hasSpace noria:Room001 .

noria:Locus003 a noria:Locus ;
    rdfs:label "Rack B1, Unit 5-6"@en ;
    rdfs:comment "Location for Core Switch 01."@en ;
    noria:locusLine "B1" ;
    noria:locusRow "5-6" ;
    bot:hasSpace noria:Room002 .

noria:Locus004 a noria:Locus ;
    rdfs:label "Rack A3, Unit 7-8"@en ;
    rdfs:comment "Location for Database Server 01."@en ;
    noria:locusLine "A3" ;
    noria:locusRow "7-8" ;
    bot:hasSpace noria:Room001 .

# =============================================================================
# Resources
# =============================================================================

noria:Resource001 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS Corporatif 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical for internal and external name resolution."@en ;
    noria:resourceManagedBy foaf:Agent001 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel001 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus001 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource002 a noria:Resource ;
    rdfs:label "Corporate DNS Server 02"@en, "Serveur DNS Corporatif 02"@fr ;
    rdfs:comment "Secondary DNS server for corporate network, providing redundancy."@en ;
    noria:resourceManagedBy foaf:Agent001 ;
    noria:resourceHostName "dns02.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel001 ;
    noria:resourceLogisticId "ASSET-DNS-002" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-002-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus001 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.11> .

noria:Resource003 a noria:Resource ;
    rdfs:label "Web Server Frontend 01"@en, "Serveur Web Frontend 01"@fr ;
    rdfs:comment "Frontend web server hosting the customer portal interface."@en ;
    noria:resourceManagedBy foaf:Agent002 ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel001 ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2022-03-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus002 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> .

