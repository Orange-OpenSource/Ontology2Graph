noria:EventRecord001 a noria:EventRecord ;
    rdfs:label "DNS Server 01 Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS Server 01 became unreachable."@en ;
    noria:loggingTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord002 a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alert"@en ;
    rdfs:comment "Alert from monitoring system about high CPU usage on web01."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource003 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "WARNING: CPU usage on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    dcterms:type <kos/Notification/EventType/thresholdCrossing> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord003 a noria:EventRecord ;
    rdfs:label "DNS Service Restored Log"@en ;
    rdfs:comment "Log entry indicating DNS Server 01 service was restored."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "OK: Host dns01.corp.example.com is UP - DNS service reachable."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> . # Major because it indicates recovery from critical.

noria:EventRecord004 a noria:EventRecord ;
    rdfs:label "Configuration Change on Core Switch"@en ;
    rdfs:comment "Log entry for a configuration change applied by an agent on the core switch."@en ;
    noria:loggingTime "2024-04-19T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource005 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logOriginatingAgent foaf:Agent006 ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jsmith (192.168.1.50)"@en ;
    dcterms:type <kos/Notification/EventType/stateChange> .

