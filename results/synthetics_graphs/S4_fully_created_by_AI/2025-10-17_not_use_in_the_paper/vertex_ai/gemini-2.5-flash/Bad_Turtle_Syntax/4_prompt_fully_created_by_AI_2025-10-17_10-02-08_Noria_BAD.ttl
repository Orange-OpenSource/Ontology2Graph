    noria:documentStatusHistory noria:EventRecord001, noria:EventRecord003 ;
    noria:documentExternalId "INC-20240420-001" ;
    noria:documentHRef <http://ticketing.example.com/INC-20240420-001> ;
    noria:troubleTicketIsNotificationEnable true .

noria:TroubleTicket002 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Slow Response"@en, "Portail Client Lent"@fr ;
    rdfs:comment "Customers reporting slow response times on the portal, potentially due to high CPU on web servers."@en ;
