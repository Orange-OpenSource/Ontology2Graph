# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan001 a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting DNS service on a server."@en ;
    skos:example "Steps include checking process status, attempting graceful restart, force killing and restarting if necessary, and verifying service."@en .

noria:ActionPreCondition001 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down"@en ;
    rdfs:comment "Pre-condition: DNS service is confirmed to be non-operational on the target server."@en ;
    noria:operationPlanPreCondition noria:OperationPlan001 .

noria:ActionPostCondition001 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Up and Resolving"@en ;
    rdfs:comment "Post-condition: DNS service is operational and successfully resolving queries."@en ;
    noria:operationPlanPostCondition noria:OperationPlan001 .

noria:OperationPlan002 a noria:OperationPlan ;
    rdfs:label "Web Server CPU Troubleshooting"@en ;
    rdfs:comment "Procedure to diagnose and resolve high CPU usage on web servers."@en ;
    skos:example "Steps include checking running processes, analyzing logs, and scaling resources if needed."@en .

noria:ActionPreCondition002 a noria:ActionPreCondition ;
    rdfs:label "High CPU Alert on Web Server"@en ;
    rdfs:comment "Pre-condition: Monitoring system has triggered a high CPU alert for a web server."@en ;
    noria:operationPlanPreCondition noria:OperationPlan002 .

noria:ActionPostCondition002 a noria:ActionPostCondition ;
    rdfs:label "CPU Usage within Normal Limits"@en ;
    rdfs:comment "Post-condition: CPU usage on the web server has returned to and remains within acceptable thresholds."@en ;
    noria:operationPlanPostCondition noria:OperationPlan002 .

# Link TroubleTicketNote to correlated execution (implicitly, as pep:ProcedureExecutionContainer)
# For example, the resolution steps in TroubleTicketNote002 are guided by OperationPlan001.
# While noria:troubleTicketNoteCorrelatedExecution links to a pep:ProcedureExecutionContainer,
# and noria:OperationPlan is a pep:Procedure, we can imply this by linking the note to the plan.
# A more explicit way would be to create a pep:ProcedureExecutionContainer instance for the actual execution.
# For this example, let's assume the note describes the execution of the plan.
# The schema states: "Note that for actions undoubtedly related to a given trouble ticket note (i.e. that can be asserted without mining for execution context candidates), one can avoid using `troubleTicketNoteCorrelatedExecution` by directly relating the note to `EventRecord` with `ldp:member` as `TroubleTicket` and `TroubleTicketNote` are themselves subclasses of `pep:ProcedureExecutionContainer`."
# So, I'll link the note to the plan via a hypothetical execution container.

# Let's create a ProcedureExecutionContainer for the DNS restart
<http://example.com/pep/execution/DNS_Restart_TT001> a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of DNS Service Restart for TT001"@en ;
    pep:usedProcedure noria:OperationPlan001 ;
    dcterms:created "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    dcterms:description "Actual execution of the DNS service restart procedure."@en ;
