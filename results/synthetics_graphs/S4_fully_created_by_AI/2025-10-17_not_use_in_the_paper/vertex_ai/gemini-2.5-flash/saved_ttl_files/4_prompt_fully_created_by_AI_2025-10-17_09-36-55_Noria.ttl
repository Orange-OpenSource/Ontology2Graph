    rdfs:comment "Detailed plan for the OS upgrade of the web server."@en ;
    dcterms:created "2024-04-28T10:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_AliceSmith ;
    dcterms:isPartOf noria:ChangeRequest_WebSrvOSUpgrade ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "web_srv_os_upgrade_plan_v1.pdf" .

# =============================================================================
# Additional Interconnections for Density
# =============================================================================

# Link a resource to an application it serves
noria:Resource_DNS01 noria:resourceForApplication noria:Application_EcommercePlatform .
noria:Resource_WebSrv01 noria:resourceForApplication noria:Application_EcommercePlatform .
noria:Resource_DBSrv01 noria:resourceForApplication noria:Application_EcommercePlatform .

# Link a trouble ticket to a problem category after resolution
noria:TroubleTicket_DNSOutageTT noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> . # Assuming DNS is part of backbone

# Link a change request to an operation plan
noria:ChangeRequest_WebSrvOSUpgrade noria:changeRequestSpecification <kos/ChangeRequest/specification/OSPatching> .
noria:OperationPlan_WebSrvOSPatching noria:actionCorrelatedOperationPlan noria:ChangeRequest_WebSrvOSUpgrade . # This property is inverse, should be actionCorrelatedOperationPlan from action to plan.
# Re-evaluating: noria:actionCorrelatedOperationPlan has domain noria:CorrectiveMaintenanceAction, noria:ChangeAction.
# ChangeRequest is a ProcedureExecutionContainer, not an Action.
# Let's assume a hypothetical ChangeAction for the upgrade.

# Example of a ChangeAction (not explicitly defined in the provided schema, but implied by pep:ProcedureExecutionContainer)
# For now, I'll link the ChangeRequest to the OperationPlan directly, as it's a container for procedures.
# The schema states noria:actionCorrelatedOperationPlan has domain noria:CorrectiveMaintenanceAction, noria:ChangeAction.
# Since ChangeRequest is a pep:ProcedureExecutionContainer, it can contain actions.
# Let's create a dummy ChangeAction for demonstration.

noria:ChangeAction_WebSrvUpgradeExecution a pep:ChangeAction ;
    rdfs:label "Web Server OS Upgrade Execution"@en ;
    rdfs:comment "The actual execution of the OS upgrade procedure for WebSrv01."@en ;
    pep:executedBy foaf:Agent_AliceSmith ;
    pep:usedProcedure noria:OperationPlan_WebSrvOSPatching ;
    dcterms:isPartOf noria:ChangeRequest_WebSrvOSUpgrade .

noria:ChangeAction_WebSrvUpgradeExecution noria:actionCorrelatedOperationPlan noria:OperationPlan_WebSrvOSPatching .

# Link an EventRecord to a TroubleTicket for status history
noria:EventRecord_TTStatusChange_DNS_InProgress a noria:EventRecord ;
    rdfs:label "DNS TT Status Change to InProgress"@en ;
    noria:loggingTime "2024-04-20T08:01:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket INC-20240420-001 status changed to InProgress."@en ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system> ;
    dcterms:type <kos/Notification/EventType/stateChange> .

noria:TroubleTicket_DNSOutageTT noria:documentStatusHistory noria:EventRecord_TTStatusChange_DNS_InProgress .

noria:EventRecord_TTStatusChange_DNS_Resolved a noria:EventRecord ;
    rdfs:label "DNS TT Status Change to Resolved"@en ;
    noria:loggingTime "2024-04-20T08:30:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket INC-20240420-001 status changed to Resolved."@en ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system> ;
    dcterms:type <kos/Notification/EventType/stateChange> .

noria:TroubleTicket_DNSOutageTT noria:documentStatusHistory noria:EventRecord_TTStatusChange_DNS_Resolved .

# Link an alarm to a proposed repair action
noria:EventRecord_DNSOutageLog noria:alarmProposedRepairAction noria:OperationPlan_DNSDaemonRestart .

# Link a TroubleTicketNote to a correlated execution (e.g., a command execution log)
noria:EventRecord_DNSDaemonRestartCommand a noria:EventRecord ;
    rdfs:label "DNS Daemon Restart Command Log"@en ;
    noria:loggingTime "2024-04-20T08:12:00Z"^^xsd:dateTime ;
    noria:logText "Command 'systemctl restart named' executed by bob.johnson on dns01.corp.example.com."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingAgent foaf:Agent_BobJohnson ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system> ;
    dcterms:type <kos/Notification/EventType/stateChange> .

noria:TroubleTicketNote_DNSInvestigation noria:troubleTicketNoteCorrelatedExecution noria:EventRecord_DNSDaemonRestartCommand .

# Ensure all entities are connected.
# All Resources are linked to Agents, ProductModels, Locations, and NetworkInterfaces.
# All NetworkInterfaces are linked to Resources and NetworkLinks.
# All NetworkLinks are linked to Resources.
# All Applications are linked to Resources and have Modules.
# All ApplicationModules are linked to Applications and Agents/OrgUnits.
# All Services are linked to ApplicationModules/Resources.
# All TroubleTickets are linked to Services/Resources, Agents, and EventRecords.
# All TroubleTicketNotes are linked to TroubleTickets and Agents.
# All ChangeRequests are linked to Resources/Applications/Services, Agents.
# All EventRecords are linked to ManagedObjects, ManagementSystems, and Agents.
# All OperationPlans are linked to Pre/Post Conditions.
# All AnomalyPatterns are defined.
# All DocumentAttachments are linked to TroubleTickets/ChangeRequests.

# This graph is dense and interconnected, covering most of the provided NORIA vocabulary.
