# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_DNSDaemonRestart a noria:OperationPlan ;
    rdfs:label "DNS Daemon Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the DNS service daemon on Linux servers."@en ;
    skos:example "Steps: 1. Check service status. 2. Attempt graceful restart. 3. Force restart if necessary. 4. Verify service functionality."@en ;
    noria:operationPlanPreCondition noria:PreCondition_DNSDaemonCrashed ;
    noria:operationPlanPostCondition noria:PostCondition_DNSServiceRestored .

noria:OperationPlan_WebSrvOSPatching a noria:OperationPlan ;
    rdfs:label "Web Server OS Patching Procedure"@en ;
    rdfs:comment "Procedure for applying OS security patches to web servers, including pre-checks and post-checks."@en ;
    skos:example "Steps: 1. Backup configuration. 2. Apply patches. 3. Reboot. 4. Verify application functionality."@en ;
    noria:operationPlanPreCondition noria:PreCondition_WebSrvReadyForPatch ;
    noria:operationPlanPostCondition noria:PostCondition_WebSrvPatchedAndFunctional .

noria:AnomalyPattern_HighCPUWebSrv a noria:AnomalyPattern ;
    rdfs:label "High CPU on Web Server Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing sustained high CPU usage on web servers, often indicating performance issues or attacks."@en ;
    skos:example "CPU > 90% for more than 5 minutes, combined with increased HTTP error rates."@en .

noria:ActionPreCondition_DNSDaemonCrashed a noria:ActionPreCondition ;
    rdfs:label "DNS Daemon Crashed Pre-Condition"@en ;
    rdfs:comment "Condition where the DNS service daemon is not running or is unresponsive."@en ;
    skos:example "Service status check returns 'stopped' or 'failed'."@en .

noria:PostCondition_DNSServiceRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Post-Condition"@en ;
    rdfs:comment "Expected outcome: DNS service is running and resolving queries correctly."@en ;
    skos:example "Service status check returns 'running', and DNS queries are successful."@en .

noria:PreCondition_WebSrvReadyForPatch a noria:ActionPreCondition ;
    rdfs:label "Web Server Ready for Patch Pre-Condition"@en ;
    rdfs:comment "Condition where the web server is in a state suitable for patching, e.g., maintenance window, backups complete."@en .

noria:PostCondition_WebSrvPatchedAndFunctional a noria:ActionPostCondition ;
    rdfs:label "Web Server Patched and Functional Post-Condition"@en ;
    rdfs:comment "Expected outcome: OS patches applied, server rebooted, and web application is fully functional."@en .

