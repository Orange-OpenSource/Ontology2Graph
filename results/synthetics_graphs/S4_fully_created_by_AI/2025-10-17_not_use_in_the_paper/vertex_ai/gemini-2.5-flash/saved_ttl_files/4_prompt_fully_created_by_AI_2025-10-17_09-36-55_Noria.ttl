# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS (Knowledge Organization System) Concepts - Mocked for demonstration
# In a real scenario, these would be defined in separate SKOS vocabularies.
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application"@en .
<kos/application/type/business> a skos:Concept ; rdfs:label "Business Application"@en .
<kos/application/type/monitoring> a skos:Concept ; rdfs:label "Monitoring Application"@en .
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low Business Importance"@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA Level"@en .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; rdfs:label "Silver SLA Level"@en .

<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en .
<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure Ticket Type"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance Ticket Type"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision Origin"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Origin"@en .
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention Urgency"@en .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention Urgency"@en .
<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ; rdfs:label "Total Breakdown Trouble Category"@en .
<kos/TroubleTicket/trouble-category/ServiceDegradation> a skos:Concept ; rdfs:label "Service Degradation Trouble Category"@en .
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; rdfs:label "Managed Backbone Networks Responsibility"@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress Status"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved Status"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment Type"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment Type"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation Type"@en .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; rdfs:label "Tests and Measurements Operation Type"@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention Category"@en .
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change Type"@en .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade Cause"@en .
<kos/ChangeRequest/status/Scheduled> a skos:Concept ; rdfs:label "Scheduled Status"@en .
<kos/ChangeRequest/status/Completed> a skos:Concept ; rdfs:label "Completed Status"@en .
<kos/ChangeRequest/specification/OSPatching> a skos:Concept ; rdfs:label "OS Patching Specification"@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning Perceived Severity"@en .
<kos/Notification/EventType/stateChange> a skos:Concept ; rdfs:label "State Change Event Type"@en .
<kos/Notification/EventType/thresholdCrossing> a skos:Concept ; rdfs:label "Threshold Crossing Event Type"@en .

<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server Resource Type"@en .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router Resource Type"@en .
<kos/Resource/type/Database> a skos:Concept ; rdfs:label "Database Resource Type"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine Resource Type"@en .
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; rdfs:label "In Production Lifecycle State"@en .
<kos/Resource/LifecycleState/Maintenance> a skos:Concept ; rdfs:label "Maintenance Lifecycle State"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Up Operational State"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Down Operational State"@en .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; rdfs:label "Up Administrative State"@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Down Administrative State"@en .

<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email Contact Method"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone Contact Method"@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution of related incidents."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

foaf:Agent_WebDevTeam a foaf:Agent ;
    rdfs:label "Web Development Team"@en ;
    rdfs:comment "Team responsible for the e-commerce application development and maintenance."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_DBAteam a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_NOC a foaf:Agent ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "First level support for network and infrastructure incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_AliceSmith a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Engineer in the Web Development Team."@en ;
    foaf:mbox <mailto:alice.smith@example.com> .

foaf:Agent_BobJohnson a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Administrator in the DNS Admin Team."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> .

org:OrgUnit_ITOperations a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department overseeing all IT infrastructure and services."@en ;
    org:hasMember foaf:Agent_DNSAdminTeam, foaf:Agent_DBAteam, foaf:Agent_NOC .

org:OrgUnit_SoftwareDev a org:OrganizationalUnit ;
    rdfs:label "Software Development Department"@en ;
    rdfs:comment "Department responsible for all software applications."@en ;
    org:hasMember foaf:Agent_WebDevTeam, foaf:Agent_AliceSmith .

noria:CUid_AliceSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount foaf:Agent_AliceSmith .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model commonly used for critical infrastructure."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch model."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy <https://www.vmware.com> .

# =============================================================================
# Locations
# =============================================================================

bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddressStreet "123 Rue de la Republique" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    seas:subSystemOf bot:Site_MainDC .

noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "23" ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_RackA1_U24 a noria:Locus ;
    rdfs:label "Rack A1, Unit 24"@en ;
    noria:locusLine "A1" ;
    noria:locusRow "24" ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_RackB2_U10 a noria:Locus ;
    rdfs:label "Rack B2, Unit 10"@en ;
    noria:locusLine "B2" ;
    noria:locusRow "10" ;
    seas:subSystemOf noria:Room_ServerRoomA .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, physical host."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "E-commerce Web Server 01"@en ;
    rdfs:comment "Virtual machine hosting the main e-commerce website."@en ;
    noria:resourceManagedBy foaf:Agent_WebDevTeam ;
    noria:resourceHostName "web01.ecommerce.example.com" ;
    noria:resourceLogisticId "LOG-WEB-VM-001" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself, but for simplicity here.
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.101> ;
    noria:clusterController noria:Resource_HypervisorHost01 .

noria:Resource_DBSrv01 a noria:Resource ;
    rdfs:label "E-commerce Database Server 01"@en ;
    rdfs:comment "Physical server hosting the e-commerce database."@en ;
    noria:resourceManagedBy foaf:Agent_DBAteam ;
    noria:resourceHostName "db01.ecommerce.example.com" ;
    noria:resourceLogisticId "LOG-DB-001" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Database> ;
    noria:resourceSerialNumber "SN-DB01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U24 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> .

noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Network Router 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy foaf:Agent_NOC ;
    noria:resourceHostName "router01.corp.example.com" ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-11-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackB2_U10 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.1> .

noria:Resource_HypervisorHost01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical host running virtual machines, including web servers."@en ;
    noria:resourceManagedBy org:OrgUnit_ITOperations ;
    noria:resourceHostName "hypervisor01.corp.example.com" ;
    noria:resourceLogisticId "LOG-HV-001" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-10T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.30> .

# =============================================================================
# Network Interfaces and Links
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Virtual network interface for WebSrv01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Virtual interface for e-commerce web traffic."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_Router01_Gig0_0_1 a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to external network."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to ISP A."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkLink_DNS01_Router01 a noria:NetworkLink ;
    rdfs:label "Link between DNS01 and CoreRouter01"@en ;
    rdfs:comment "Internal network link connecting DNS01 to the core router."@en ;
    noria:networkLinkId "NL-DNS01-RTR01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ;
    noria:resourceManagedBy foaf:Agent_NOC .

noria:NetworkLink_WebSrv01_Router01 a noria:NetworkLink ;
    rdfs:label "Link between WebSrv01 and CoreRouter01"@en ;
    rdfs:comment "Virtual network link for WebSrv01 traffic through the core router."@en ;
    noria:networkLinkId "NL-WEB01-RTR01" ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:networkLinkInstallationDate "2023-03-01T14:45:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ;
    noria:resourceManagedBy foaf:Agent_NOC .

# =============================================================================
# Applications and Application Modules
# =============================================================================

noria:Application_EcommercePlatform a noria:Application ;
    rdfs:label "E-commerce Platform"@en ;
    rdfs:comment "Main application for online sales and customer interactions."@en ;
    noria:applicationModelIdentifier "ECP-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "ECP" ;
    noria:applicationType <kos/application/type/business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Sales and Marketing" ;
    noria:applicationFunctionalSubDomain "Online Retail" ;
    noria:resourceForApplication noria:Resource_WebSrv01, noria:Resource_DBSrv01 .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "Application for collecting and analyzing logs and metrics from IT infrastructure."@en ;
    noria:applicationModelIdentifier "CMS-V3" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "CMS" ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Monitoring and Alerting" .

noria:ApplicationModule_EcommerceProd a noria:ApplicationModule ;
    rdfs:label "E-commerce Production Module"@en ;
    rdfs:comment "Production instance of the E-commerce Platform."@en ;
    noria:applicationModuleOf noria:Application_EcommercePlatform ;
    noria:applicationModuleName "ECP_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleAdministrationTeam org:OrgUnit_SoftwareDev ;
    noria:applicationModuleAdministrationLeader foaf:Agent_AliceSmith ;
    noria:applicationModuleSupportTeam foaf:Agent_WebDevTeam ;
    noria:applicationModuleSupportLeader foaf:Agent_AliceSmith ;
    noria:applicationModuleHotlineGroup foaf:Agent_WebDevTeam .

noria:ApplicationModule_EcommerceDev a noria:ApplicationModule ;
    rdfs:label "E-commerce Development Module"@en ;
    rdfs:comment "Development instance of the E-commerce Platform."@en ;
    noria:applicationModuleOf noria:Application_EcommercePlatform ;
    noria:applicationModuleName "ECP_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> ;
