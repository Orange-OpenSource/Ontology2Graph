# =============================================================================
# Operation Plans, Pre/Post Conditions (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

<https://w3id.org/noria/operationplan/FirewallFirmwareUpgradePlan> a noria:OperationPlan ;
    rdfs:label "Firewall Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading firewall firmware."@en ;
    skos:example "Steps include backup, pre-checks, upgrade execution, and post-checks."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/FirewallUpgradePreCheck> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/FirewallUpgradePostCheck> ;
    .

<https://w3id.org/noria/actionprecondition/FirewallUpgradePreCheck> a noria:ActionPreCondition ;
    rdfs:label "Firewall Upgrade Pre-Check"@en ;
    rdfs:comment "Conditions to verify before starting a firewall firmware upgrade."@en ;
    skos:example "Verify current firmware version, check device health, ensure backup is complete, confirm maintenance window."@en ;
    .

<https://w3id.org/noria/actionpostcondition/FirewallUpgradePostCheck> a noria:ActionPostCondition ;
    rdfs:label "Firewall Upgrade Post-Check"@en ;
    rdfs:comment "Conditions to verify after completing a firewall firmware upgrade."@en ;
    skos:example "Verify new firmware version, check device health, confirm network connectivity, test critical services."@en ;
    .

<https://w3id.org/noria/operationplan/ServerRestartProcedure> a noria:OperationPlan ;
    rdfs:label "Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for safely restarting a production server."@en ;
    skos:example "Steps include notifying stakeholders, gracefully shutting down services, restarting OS, and verifying service restoration."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/ServerRestartPreCheck> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/ServerRestartPostCheck> ;
    .

<https://w3id.org/noria/actionprecondition/ServerRestartPreCheck> a noria:ActionPreCondition ;
    rdfs:label "Server Restart Pre-Check"@en ;
    rdfs:comment "Conditions to verify before restarting a server."@en ;
    skos:example "Confirm maintenance window, notify application owners, check for active user sessions, ensure data synchronization."@en ;
    .

<https://w3id.org/noria/actionpostcondition/ServerRestartPostCheck> a noria:ActionPostCondition ;
    rdfs:label "Server Restart Post-Check"@en ;
    rdfs:comment "Conditions to verify after restarting a server."@en ;
    skos:example "Verify OS boot, check service status, confirm application functionality, monitor resource utilization."@en ;
    .

