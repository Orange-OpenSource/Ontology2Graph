    .

<https://w3id.org/noria/actionpostcondition/LoadBalancerPostCheck> a noria:ActionPostCondition ;
    rdfs:label "Load Balancer Post-Check"@en ;
    rdfs:comment "Confirm traffic distribution, health of all backend servers, and service availability after maintenance."@en ;
    .

