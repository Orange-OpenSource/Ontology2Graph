# Add an anomaly pattern
<https://w3id.org/noria/anomalypattern/HighCPUDatabaseOutage> a noria:AnomalyPattern ;
    rdfs:label "High CPU Database Outage Pattern"@en ;
    rdfs:comment "Pattern describing a database outage preceded by sustained high CPU usage on the hosting server."@en ;
    skos:example "If (ER-CPU-High AND ER-DB-Unreachable) THEN TT-DB-Outage."@en ;
    folio:hasCause <https://w3id.org/noria/troubleticket/TT-20240315-001> ; # This pattern is a cause for this TT
    .

# Link the initial event record to this anomaly pattern
<https://w3id.org/noria/eventrecord/ER-20240315-001> dcterms:relation <https://w3id.org/noria/anomalypattern/HighCPUDatabaseOutage> .
<https://w3id.org/noria/eventrecord/ER-20240315-002> dcterms:relation <https://w3id.org/noria/anomalypattern/HighCPUDatabaseOutage> .

