    noria:agentPreferredContactMethod <kos/org/agent-contact-method/InternalChat> ;
    noria:agentInstructions "Use internal chat for urgent database issues."@en ;
    .

<https://w3id.org/noria/agent/AppSupportTeamA> a foaf:Agent, org:OrganizationalUnit ;
