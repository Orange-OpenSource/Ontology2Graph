<https://w3id.org/noria/agent/TechCorpITOpsTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "TechCorp IT Operations Team"@en ;
    rdfs:comment "Central team responsible for overall IT infrastructure and operations at TechCorp."@en ;
    skos:example "Manages core infrastructure resources and responds to critical incidents."@en ;
    noria:agentWorkingHours "24/7 (on-call rotation)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Pager> ;
    noria:agentInstructions "For critical issues, page the on-call engineer. For non-critical, open a ticket."@en ;
    .

<https://w3id.org/noria/agent/NetworkAdminTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Specialized team managing TechCorp's network devices and connectivity."@en ;
    skos:example "Responsible for routers, switches, firewalls, and network links."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email net-admin@techcorp.com for network-related requests."@en ;
    .

<https://w3id.org/noria/agent/DatabaseAdminTeam> a foaf:Agent, org:OrganizationalUnit ;
