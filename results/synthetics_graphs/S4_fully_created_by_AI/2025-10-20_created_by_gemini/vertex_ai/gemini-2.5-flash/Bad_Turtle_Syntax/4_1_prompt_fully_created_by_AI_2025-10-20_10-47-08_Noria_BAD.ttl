noria:NI_CoreRouter01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 - GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to ISP A."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to ISP A"^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 10^^xsd:int .

noria:NI_CoreRouter01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 - GigabitEthernet0/0/1"@en ;
    rdfs:comment "Link interface from Core Router 01 to Core Router 02."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Inter-router link to CR02"^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 5^^xsd:int .

noria:NI_CoreRouter02_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "Core Router 02 - GigabitEthernet0/0/1"@en ;
    rdfs:comment "Link interface from Core Router 02 to Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter02 ;
    noria:networkInterfaceDescription "Inter-router link to CR01"^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 5^^xsd:int .

noria:NI_AppServerProd01_Eth0 a noria:NetworkInterface ;
    rdfs:label "App Server Prod 01 - Ethernet0"@en ;
    rdfs:comment "Main network interface for App Server Prod 01."@en ;
    noria:networkInterfaceOf noria:Resource_AppServerProd01 ;
    noria:networkInterfaceDescription "Production network interface"^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_FirewallDMZ01_Eth1 a noria:NetworkInterface ;
