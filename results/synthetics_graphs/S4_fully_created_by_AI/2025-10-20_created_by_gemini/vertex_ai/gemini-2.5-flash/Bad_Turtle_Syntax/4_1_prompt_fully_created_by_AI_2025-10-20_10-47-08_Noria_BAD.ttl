# =============================================================================
# Operation Plans (noria:OperationPlan) and Conditions
# =============================================================================

noria:OperationPlan_ISP_Failover a noria:OperationPlan ;
    rdfs:label "ISP Link Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over to a secondary ISP link in case of primary link failure."@en ;
    noria:operationPlanPreCondition noria:PreCondition_PrimaryISPDown ;
    noria:operationPlanPostCondition noria:PostCondition_InternetAccessRestored .

noria:PreCondition_PrimaryISPDown a noria:ActionPreCondition ;
    rdfs:label "Primary ISP Link Down Pre-condition"@en ;
    rdfs:comment "Condition: Primary ISP link is detected as down, impacting internet access."@en ;
    skos:example "Detection of 'LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down' on Core Router 01."@en .

noria:PostCondition_InternetAccessRestored a noria:ActionPostCondition ;
    rdfs:label "Internet Access Restored Post-condition"@en ;
    rdfs:comment "Outcome: Internet access is fully restored via the secondary ISP link."@en ;
    skos:example "Verification of 'LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to up' on Core Router 01 and successful ping to external services."@en .

noria:OperationPlan_AppServer_CPU_Troubleshoot a noria:OperationPlan ;
    rdfs:label "Application Server High CPU Troubleshooting"@en ;
    rdfs:comment "Procedure for diagnosing and resolving high CPU utilization on application servers."@en ;
    noria:operationPlanPreCondition noria:PreCondition_AppServerHighCPU ;
    noria:operationPlanPostCondition noria:PostCondition_AppServerCPUNormal .

noria:PreCondition_AppServerHighCPU a noria:ActionPreCondition ;
    rdfs:label "Application Server High CPU Pre-condition"@en ;
    rdfs:comment "Condition: Application server CPU utilization exceeds a predefined threshold."@en ;
    skos:example "Monitoring system alert: 'CPU utilization on app-prod-01 exceeded 90% for 5 minutes'."@en .

noria:PostCondition_AppServerCPUNormal a noria:ActionPostCondition ;
    rdfs:label "Application Server CPU Normal Post-condition"@en ;
    rdfs:comment "Outcome: Application server CPU utilization returns to normal levels."@en ;
    skos:example "Monitoring system shows CPU utilization below 50% for 15 minutes, and application performance is restored."@en .

noria:OperationPlan_Firewall_BruteForce_Mitigation a noria:OperationPlan ;
    rdfs:label "Firewall Brute Force Mitigation Procedure"@en ;
    rdfs:comment "Procedure for responding to and mitigating brute force attacks on firewalls."@en ;
    noria:operationPlanPreCondition noria:PreCondition_FirewallBruteForceDetected ;
    noria:operationPlanPostCondition noria:PostCondition_BruteForceMitigated .

noria:PreCondition_FirewallBruteForceDetected a noria:ActionPreCondition ;
    rdfs:label "Firewall Brute Force Detected Pre-condition"@en ;
    rdfs:comment "Condition: Multiple failed login attempts detected on a firewall from a suspicious source."@en ;
    skos:example "SIEM alert: 'Multiple failed login attempts from IP 1.2.3.4 on fw-dmz-01'."@en .

noria:PostCondition_BruteForceMitigated a noria:ActionPostCondition ;
    rdfs:label "Brute Force Mitigated Post-condition"@en ;
    rdfs:comment "Outcome: The brute force attack is mitigated, and unauthorized access attempts cease."@en ;
    skos:example "Source IP blocked on firewall, no further failed login attempts from that source for 30 minutes."@en .

