# =============================================================================
# Agents (foaf:Agent) and Corporate User Identifiers (noria:CorporateUserIdentifier)
# =============================================================================

foaf:Agent_NetOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for 24/7 monitoring and management of the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 (Shift-based)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical incidents, call the hotline immediately. For non-critical issues, use the ticketing system."@en .

foaf:Agent_AppSupportL2 a foaf:Agent ;
    rdfs:label "Application Support L2 Team"@en ;
    rdfs:comment "Second-level support team for business-critical applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit a ticket via the internal portal. Escalation to L3 via dedicated channel."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Cyber Security Operations Center (CSOC)"@en ;
    rdfs:comment "Team dedicated to detecting, analyzing, and responding to cybersecurity incidents."@en ;
    noria:agentWorkingHours "24/7 (Shift-based)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> ;
    noria:agentInstructions "Report all security incidents via the dedicated security incident platform."@en .

foaf:Agent_DBA_Team a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all production database systems."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri), on-call for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "Open a ticket for all requests. For urgent matters, follow up with a phone call."@en .

foaf:Agent_CloudOps a foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Manages and maintains cloud infrastructure and services."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Use the cloud platform's support portal for all issues."@en .

foaf:Agent_AliceSmith a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer in the Network Operations Team."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

foaf:Agent_BobJohnson a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer, part of the Application Support L2 Team."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

foaf:Agent_CharlieBrown a foaf:Person ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Database Administrator."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> .

noria:CUid_ASmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within the organization's IT systems."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    foaf:holdsAccount foaf:Agent_AliceSmith .

noria:CUid_BJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Bob Johnson within the organization's IT systems."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    foaf:holdsAccount foaf:Agent_BobJohnson .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_Cisco9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300 Series Switch"@en ;
    rdfs:comment "High-performance enterprise-grade network switch."@en ;
    noria:productManufacturedBy <https://www.cisco.com/organization> .

noria:ProductModel_DellR750 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750 Server"@en ;
    rdfs:comment "Dual-socket 2U rack server for demanding workloads."@en ;
    noria:productManufacturedBy <https://www.dell.com/organization> .

noria:ProductModel_PaloAlto5220 a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220 Firewall"@en ;
    rdfs:comment "Next-generation firewall for data center and large enterprise deployments."@en ;
    noria:productManufacturedBy <https://www.paloaltonetworks.com/organization> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Type-1 hypervisor for virtualizing server hardware."@en ;
    noria:productManufacturedBy <https://www.vmware.com/organization> .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480 Universal Routing Platform"@en ;
    rdfs:comment "Modular router for enterprise and service provider applications."@en ;
    noria:productManufacturedBy <https://www.juniper.net/organization> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_DC_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

bot:Site_Office_Lyon a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office building in Lyon, hosting some local IT infrastructure."@en ;
    noria:siteId "OFF-LYN-01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "69007"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Lyon"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès"^^xsd:string .

noria:Room_DC_Paris_SR01 a noria:Room ;
    rdfs:label "Server Room 01 (Paris DC)"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_DC_Paris_SR01_R01, noria:Locus_DC_Paris_SR01_R02, noria:Locus_DC_Paris_SR01_R03 .

noria:Room_DC_Paris_NCR a noria:Room ;
    rdfs:label "Network Core Room (Paris DC)"@en ;
    rdfs:comment "Dedicated room for core network equipment in Paris DC."@en ;
    bot:hasSpace noria:Locus_DC_Paris_NCR_R01, noria:Locus_DC_Paris_NCR_R02 .

noria:Locus_DC_Paris_SR01_R01 a noria:Locus ;
    rdfs:label "Rack 01A (Server Room 01, Paris DC)"@en ;
    rdfs:comment "First rack in Server Room 01, Paris Data Center."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "01"^^xsd:string .

noria:Locus_DC_Paris_SR01_R02 a noria:Locus ;
    rdfs:label "Rack 02B (Server Room 01, Paris DC)"@en ;
    rdfs:comment "Second rack in Server Room 01, Paris Data Center."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "02"^^xsd:string .

noria:Locus_DC_Paris_SR01_R03 a noria:Locus ;
    rdfs:label "Rack 03C (Server Room 01, Paris DC)"@en ;
    rdfs:comment "Third rack in Server Room 01, Paris Data Center."@en ;
    noria:locusLine "C"^^xsd:string ;
    noria:locusRow "03"^^xsd:string .

noria:Locus_DC_Paris_NCR_R01 a noria:Locus ;
    rdfs:label "Network Rack 01 (Network Core Room, Paris DC)"@en ;
    rdfs:comment "First rack in Network Core Room, Paris Data Center."@en ;
    noria:locusLine "N"^^xsd:string ;
    noria:locusRow "01"^^xsd:string .

noria:Locus_DC_Paris_NCR_R02 a noria:Locus ;
    rdfs:label "Network Rack 02 (Network Core Room, Paris DC)"@en ;
    rdfs:comment "Second rack in Network Core Room, Paris Data Center."@en ;
    noria:locusLine "N"^^xsd:string ;
    noria:locusRow "02"^^xsd:string .

