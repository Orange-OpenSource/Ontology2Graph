    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NL_CoreRouter01_CoreRouter02 a noria:NetworkLink ;
    rdfs:label "Link between Core Router 01 and Core Router 02"@en ;
    rdfs:comment "High-speed fiber link connecting the two core routers for redundancy."@en ;
    noria:networkLinkId "NL-CR01-CR02-01"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter02 ;
    noria:networkInterfaceConnects noria:NI_CoreRouter01_Gi0_0_1, noria:NI_CoreRouter02_Gi0_0_1 ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam .

noria:NL_AppServerProd01_FirewallDMZ01 a noria:NetworkLink ;
    rdfs:label "Link between App Server Prod 01 and DMZ Firewall 01"@en ;
    rdfs:comment "Ethernet link connecting the application server to the DMZ firewall."@en ;
    noria:networkLinkId "NL-AS01-FW01-01"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-01-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_AppServerProd01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_FirewallDMZ01 ;
    noria:networkInterfaceConnects noria:NI_AppServerProd01_Eth0, noria:NI_FirewallDMZ01_Eth1 ;
    noria:resourceManagedBy foaf:Agent_NetOpsTeam .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application_CustomerPortal a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:comment "Web application allowing customers to manage their services and accounts."@en ;
    noria:applicationModelIdentifier "CUSTPORTAL"^^xsd:string ;
