    noria:changeRequestInitiatorParty foaf:Agent_BobJohnson ;
    noria:changeRequestPilotParty foaf:Agent_AppSupportL2 ;
    noria:changeRequestActorParty foaf:Agent_AppSupportL2 .

noria:OperationPlan_LogRotation_Config a noria:OperationPlan ;
    rdfs:label "Log Rotation Configuration Procedure"@en ;
    rdfs:comment "Standard procedure for configuring log rotation on Linux servers."@en ;
    noria:operationPlanPreCondition noria:PreCondition_DiskSpaceWarning ;
    noria:operationPlanPostCondition noria:PostCondition_DiskSpaceNormal .

noria:PreCondition_DiskSpaceWarning a noria:ActionPreCondition ;
    rdfs:label "Disk Space Warning Pre-condition"@en ;
    rdfs:comment "Condition: Disk space on a server is above a warning threshold."@en ;
    skos:example "Monitoring system alert: 'Disk usage on /var/lib/messages on msg-01.corp.example.com is 85%'."@en .

noria:PostCondition_DiskSpaceNormal a noria:ActionPostCondition ;
    rdfs:label "Disk Space Normal Post-condition"@en ;
    rdfs:comment "Outcome: Disk space utilization returns to normal levels after log rotation is configured."@en ;
    skos:example "Monitoring system shows disk usage below 70% and no further warnings."@en .

