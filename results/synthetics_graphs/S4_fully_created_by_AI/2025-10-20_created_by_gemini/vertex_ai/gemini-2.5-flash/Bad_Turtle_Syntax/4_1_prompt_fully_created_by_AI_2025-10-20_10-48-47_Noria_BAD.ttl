    rdfs:label "Virtual Host Manager"@en ;
    rdfs:comment "Centralized management server for virtual hosts."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:resourceHostName "vcenter.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/ManagementServer> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagementIPAddress "10.0.0.25" .

