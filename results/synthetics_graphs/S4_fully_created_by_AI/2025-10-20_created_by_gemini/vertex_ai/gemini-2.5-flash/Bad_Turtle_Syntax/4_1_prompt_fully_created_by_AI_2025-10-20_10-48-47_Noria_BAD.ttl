noria:TTN_DNSOutage_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial DNS Troubleshooting Note"@en ;
    rdfs:comment "Attempted to ping DNS server, no response. Checked service status, found 'named' process stopped. Initiated restart."@en ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution noria:Event_DNSOutageLog . # Linking to the event that triggered the diagnosis

noria:TTN_WANLink_Note1 a noria:TroubleTicketNote ;
    rdfs:label "WAN Link Diagnosis Note"@en ;
    rdfs:comment "Performed optical power check on CR01 GigE 0/0/0. Rx power is -25dBm, which is out of spec. Suspect faulty SFP or fiber."@en ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    noria:troubleTicketNoteCorrelatedExecution noria:Event_WANLinkDegradation .

noria:TTN_CRMAppCrash_Note1 a noria:TroubleTicketNote ;
    rdfs:label "CRM App Restart Note"@en ;
    rdfs:comment "Restarted CRM backend service. Application is now accessible. Monitoring for stability."@en ;
    noria:troubleTicketNoteCommentType <https://w3id.org/noria/kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/CorrectiveAction> ;
    noria:troubleTicketNoteCorrelatedExecution noria:Event_CRMProcessCrash .

