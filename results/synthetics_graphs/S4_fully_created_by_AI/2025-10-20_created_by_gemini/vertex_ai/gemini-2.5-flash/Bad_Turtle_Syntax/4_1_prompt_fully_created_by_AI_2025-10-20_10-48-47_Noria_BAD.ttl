# =============================================================================
# Services
# =============================================================================

noria:Service_CorporateDNS a noria:Service ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:comment "End-to-end service providing DNS resolution for all internal and external corporate needs."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_DNSRes_Prod . # Linking service to its primary application module

noria:Service_CRM_Access a noria:Service ;
    rdfs:label "CRM Application Access Service"@en ;
    rdfs:comment "Service enabling users to access the CRM application."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CRM_Prod .

