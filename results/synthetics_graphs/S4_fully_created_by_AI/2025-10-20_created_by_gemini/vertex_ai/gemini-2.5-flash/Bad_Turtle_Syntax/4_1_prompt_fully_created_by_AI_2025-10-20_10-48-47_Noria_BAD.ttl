    noria:serviceType <https://w3id.org/noria/kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:AppMod_WAN_Core .

# =============================================================================
# Event Records
# =============================================================================

noria:Event_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN. DNS resolution failed."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OP_RestartDNSService .

noria:Event_WANLinkDegradation a noria:EventRecord ;
    rdfs:label "WAN Link High Error Rate Alert"@en ;
    rdfs:comment "Alert indicating high error rates on CR01 GigE 0/0/0 interface."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: Interface CR01 GigE 0/0/0 experiencing 10% packet loss."@en ;
    noria:logOriginatingManagedObject noria:NI_CR01_GigE0_0_0 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:OP_CheckFiberOpticLink .

noria:Event_CRMProcessCrash a noria:EventRecord ;
    rdfs:label "CRM Application Process Crash"@en ;
    rdfs:comment "Log entry indicating a critical process crash in the CRM application."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logText "ERROR: CRM_PROD process 'crm_backend_service' terminated unexpectedly. Restarting..."@en ;
    noria:logOriginatingManagedObject noria:Resource_CRMAppServer ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OP_RestartCRMApp .

noria:Event_FirewallConfigChange a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log entry detailing a configuration change applied to Firewall 01."@en ;
    noria:loggingTime "2024-04-19T14:00:00Z"^^xsd:dateTime ;
    noria:logText "INFO: Configuration changed by admin user 'jsmith' from 192.168.1.100. Rule 'deny_all_from_china' modified."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logOriginatingAgent noria:Person_BobJohnson ; # Assuming Bob made the change
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

noria:Event_VirtualHostCPUAlert a noria:EventRecord ;
    rdfs:label "Virtual Host High CPU Alert"@en ;
    rdfs:comment "Alert indicating sustained high CPU utilization on Virtual Host 01."@en ;
    noria:loggingTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: Virtual Host vhost01.corp.example.com CPU utilization > 90% for 15 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_VirtualHost01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Warning> .

