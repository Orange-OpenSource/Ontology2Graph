noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "Carrier-grade aggregation services router."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Virtualization Platform"@en ;
    rdfs:comment "Hypervisor for virtual machines."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480 Universal Routing Platform"@en ;
    rdfs:comment "Modular router for enterprise and service provider applications."@en ;
    noria:productManufacturedBy noria:Org_Juniper .

noria:ProductModel_HPProLiantDL380 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Versatile 2U rack server for various workloads."@en ;
    noria:productManufacturedBy noria:Org_HP .

# Manufacturers (Organizations)
noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

noria:Org_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "American multinational corporation that develops and markets networking products."@en .

noria:Org_HP a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise (HPE)"@en ;
    rdfs:comment "American multinational enterprise information technology company."@en .

# =============================================================================
# Locations (Sites, Rooms, Loci)
# =============================================================================

# Sites
noria:Site_DC_Paris a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Republique" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_DC_London a bot:Site ;
    rdfs:label "London Data Center"@en ;
    rdfs:comment "Secondary data center facility located in London."@en ;
    noria:siteId "DC-LON-02" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Baker Street" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressPostalCode "SW1A 0AA" ;
    noria:sitePrincipalAddressCountry "UK" .

# Rooms
noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Site_DC_Paris .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Dedicated network equipment room in London Data Center."@en ;
    bot:hasSpace noria:Site_DC_London .

# Loci
noria:Locus_RackA1_U23 a noria:Locus ;
    rdfs:label "Rack A1, Unit 23"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Locus_RackB5_U10 a noria:Locus ;
    rdfs:label "Rack B5, Unit 10"@en ;
    rdfs:comment "Specific location for a router in Network Room B."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" ;
    bot:containsZone noria:Room_NetworkRoomB .

noria:Locus_RackA2_U1 a noria:Locus ;
    rdfs:label "Rack A2, Unit 1"@en ;
    rdfs:comment "Location for a virtual host in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:containsZone noria:Room_ServerRoomA .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy noria:Team_DNSAdmin ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceSerialNumber "SN-R740-001" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_CorporateInternetAccess ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 .

noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main core router in London DC, handling WAN traffic."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ;
    noria:resourceHostName "cr01.lon.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR9K ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceLogisticId "LOG-CR-001" ;
    noria:resourceSerialNumber "SN-ASR9K-001" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_WANConnectivity ;
    noria:resourceManagementIPAddress "172.16.0.1" ;
    noria:locatedAtLocus noria:Locus_RackB5_U10 .

noria:Resource_VirtualHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "ESXi host running multiple virtual machines in Paris DC."@en ;
    noria:resourceManagedBy noria:Team_NetworkOps ; # Assuming Network Ops manages virtual infra hosts
    noria:resourceHostName "vhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_HPProLiantDL380 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualizationHost> ;
    noria:resourceLogisticId "LOG-VH-001" ;
    noria:resourceSerialNumber "SN-DL380-001" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_VirtualizationPlatform ;
    noria:resourceManagementIPAddress "10.0.0.20" ;
    noria:locatedAtLocus noria:Locus_RackA2_U1 .

noria:Resource_CRMAppServer a noria:Resource ;
    rdfs:label "CRM Application Server"@en ;
    rdfs:comment "Server hosting the main CRM application instance."@en ;
    noria:resourceManagedBy noria:Team_AppSupport ;
    noria:resourceHostName "crmapp01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceLogisticId "LOG-CRM-001" ;
    noria:resourceSerialNumber "SN-R740-002" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_CRMSystem ;
    noria:resourceManagementIPAddress "10.0.1.50" ;
    noria:locatedAtLocus noria:Locus_RackA1_U23 .

noria:Resource_Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Primary firewall protecting the corporate network."@en ;
    noria:resourceManagedBy noria:Team_SecurityOps ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ; # Using a router model as a placeholder for a high-end firewall/router
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
    noria:resourceLogisticId "LOG-FW-001" ;
    noria:resourceSerialNumber "SN-MX480-001" ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-01T16:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_CorporateInternetAccess ;
    noria:resourceManagementIPAddress "192.168.1.1" ;
    noria:locatedAtLocus noria:Locus_RackB5_U10 .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

noria:NI_CR01_GigE0_0_0 a noria:NetworkInterface ;
    rdfs:label "CR01 GigE 0/0/0"@en ;
    rdfs:comment "WAN uplink interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Fiber optic link to ISP."@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 5 .

noria:NI_CR01_GigE0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR01 GigE 0/0/1"@en ;
    rdfs:comment "Internal network interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Fiber optic link to internal network."@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 5 .

noria:NI_CRMAppServer_Eth0 a noria:NetworkInterface ;
    rdfs:label "CRMAppServer Ethernet 0"@en ;
    rdfs:comment "Network interface for CRM Application Server."@en ;
    noria:networkInterfaceOf noria:Resource_CRMAppServer ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "Virtual NIC for CRM application."@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NI_FW01_Ext a noria:NetworkInterface ;
    rdfs:label "Firewall 01 External Interface"@en ;
    rdfs:comment "External facing interface of Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connects to the internet uplink."@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

noria:NI_FW01_Int a noria:NetworkInterface ;
    rdfs:label "Firewall 01 Internal Interface"@en ;
    rdfs:comment "Internal facing interface of Firewall 01."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Connects to the corporate LAN."@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links
# =============================================================================

noria:NL_DNS01_LAN a noria:NetworkLink ;
    rdfs:label "DNS01 to Corporate LAN Link"@en ;
    rdfs:comment "Ethernet link connecting DNS01 to the corporate network switch."@en ;
    noria:networkLinkId "NL-DNS01-LAN-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ; # Simplified, assuming CoreRouter is the gateway
    noria:networkInterfaceConnects noria:NI_DNS01_Eth0 .

noria:NL_CR01_WAN a noria:NetworkLink ;
    rdfs:label "CR01 to ISP WAN Link"@en ;
    rdfs:comment "Fiber optic WAN link from Core Router 01 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-CR01-WAN-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01 ; # Simplified, assuming Firewall is next hop
    noria:networkInterfaceConnects noria:NI_CR01_GigE0_0_0 .

noria:NL_CR01_Internal a noria:NetworkLink ;
    rdfs:label "CR01 to Internal Network Link"@en ;
    rdfs:comment "Fiber optic link from Core Router 01 to the internal corporate network."@en ;
    noria:networkLinkId "NL-CR01-INT-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-20T15:10:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_VirtualHost01 ; # Simplified, connecting to a virtual host's network
    noria:networkInterfaceConnects noria:NI_CR01_GigE0_0_1 .

noria:NL_CRMAppServer_LAN a noria:NetworkLink ;
    rdfs:label "CRM App Server to LAN Link"@en ;
    rdfs:comment "Virtual link connecting CRM App Server to the virtual LAN."@en ;
    noria:networkLinkId "NL-CRMAPP-LAN-001" ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:networkLinkInstallationDate "2022-03-10T11:15:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CRMAppServer ;
    noria:networkLinkTerminationResourceDestination noria:Resource_VirtualHost01 ; # Simplified, connecting to the virtual host
    noria:networkInterfaceConnects noria:NI_CRMAppServer_Eth0 .

noria:NL_FW01_Ext_Uplink a noria:NetworkLink ;
    rdfs:label "Firewall 01 External Uplink"@en ;
    rdfs:comment "Link from Firewall 01 external interface to the internet gateway."@en ;
    noria:networkLinkId "NL-FW01-EXT-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-08-01T16:10:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Firewall01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ; # Simplified, connecting to core router
    noria:networkInterfaceConnects noria:NI_FW01_Ext .

noria:NL_FW01_Int_Downlink a noria:NetworkLink ;
    rdfs:label "Firewall 01 Internal Downlink"@en ;
    rdfs:comment "Link from Firewall 01 internal interface to the corporate network."@en ;
    noria:networkLinkId "NL-FW01-INT-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2021-08-01T16:15:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Firewall01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DNS01 ; # Simplified, connecting to DNS server
    noria:networkInterfaceConnects noria:NI_FW01_Int .

