# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OP_RestartDNSService a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the 'named' DNS service on a Linux server."@en ;
    noria:operationPlanPreCondition noria:APC_DNSServiceStopped ;
    noria:operationPlanPostCondition noria:APOC_DNSServiceRunning .

noria:OP_CheckFiberOpticLink a noria:OperationPlan ;
    rdfs:label "Fiber Optic Link Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure to diagnose issues on a fiber optic network link, including SFP checks and optical power measurements."@en ;
    noria:operationPlanPreCondition noria:APC_HighPacketLoss ;
    noria:operationPlanPostCondition noria:APOC_LinkRestored .

noria:OP_RestartCRMApp a noria:OperationPlan ;
    rdfs:label "Restart CRM Application Procedure"@en ;
    rdfs:comment "Procedure to restart the CRM backend application service."@en ;
    noria:operationPlanPreCondition noria:APC_CRMAppCrashed ;
    noria:operationPlanPostCondition noria:APOC_CRMAppRunning .

noria:OP_ReplaceSFP a noria:OperationPlan ;
    rdfs:label "SFP Module Replacement Procedure"@en ;
    rdfs:comment "Detailed steps for safely replacing a Small Form-Factor Pluggable (SFP) module in a network device."@en ;
    noria:operationPlanPreCondition noria:APC_FaultySFPIdentified ;
    noria:operationPlanPostCondition noria:APOC_NewSFPOperational .

# Action Pre-Conditions
noria:APC_DNSServiceStopped a noria:ActionPreCondition ;
    rdfs:label "DNS Service Stopped"@en ;
    rdfs:comment "Condition: The 'named' service is not running on the DNS server."@en .

noria:APC_HighPacketLoss a noria:ActionPreCondition ;
    rdfs:label "High Packet Loss on Link"@en ;
    rdfs:comment "Condition: Network link is experiencing significant packet loss."@en .

noria:APC_CRMAppCrashed a noria:ActionPreCondition ;
    rdfs:label "CRM Application Process Crashed"@en ;
    rdfs:comment "Condition: The main CRM backend process has terminated unexpectedly."@en .

noria:APC_FaultySFPIdentified a noria:ActionPreCondition ;
    rdfs:label "Faulty SFP Module Identified"@en ;
    rdfs:comment "Condition: Diagnosis has confirmed a Small Form-Factor Pluggable (SFP) module is defective."@en .

# Action Post-Conditions
noria:APOC_DNSServiceRunning a noria:ActionPostCondition ;
    rdfs:label "DNS Service Running"@en ;
    rdfs:comment "Expected outcome: The 'named' service is running and DNS resolution is functional."@en .

noria:APOC_LinkRestored a noria:ActionPostCondition ;
    rdfs:label "Network Link Restored"@en ;
    rdfs:comment "Expected outcome: Network link is operational with acceptable packet loss and error rates."@en .

noria:APOC_CRMAppRunning a noria:ActionPostCondition ;
    rdfs:label "CRM Application Running"@en ;
    rdfs:comment "Expected outcome: The CRM application backend service is running and accessible."@en .

noria:APOC_NewSFPOperational a noria:ActionPostCondition ;
    rdfs:label "New SFP Module Operational"@en ;
    rdfs:comment "Expected outcome: The new SFP module is installed and the link is up and stable."@en .

# =============================================================================
# Additional Interconnections for Density
# =============================================================================

# Link resources to applications they support
noria:Resource_DNS01 noria:resourceForApplication noria:App_CorporateInternetAccess .
noria:Resource_CoreRouter01 noria:resourceForApplication noria:App_WANConnectivity .
noria:Resource_VirtualHost01 noria:resourceForApplication noria:App_VirtualizationPlatform .
noria:Resource_CRMAppServer noria:resourceForApplication noria:App_CRMSystem .
noria:Resource_Firewall01 noria:resourceForApplication noria:App_CorporateInternetAccess .

# Link application modules to resources they run on (using seas:subSystemOf as a general part-of relation)
noria:AppMod_DNSRes_Prod seas:subSystemOf noria:Resource_DNS01 .
noria:AppMod_CRM_Prod seas:subSystemOf noria:Resource_CRMAppServer .
noria:AppMod_WAN_Core seas:subSystemOf noria:Resource_CoreRouter01 .
noria:AppMod_Monitoring_Alerting seas:subSystemOf noria:Resource_VirtualHost01 .

# Link agents to resources they manage (inverse of resourceManagedBy)
noria:Team_DNSAdmin noria:agentManagesResource noria:Resource_DNS01 .
noria:Team_NetworkOps noria:agentManagesResource noria:Resource_CoreRouter01 .
noria:Team_NetworkOps noria:agentManagesResource noria:Resource_VirtualHost01 .
