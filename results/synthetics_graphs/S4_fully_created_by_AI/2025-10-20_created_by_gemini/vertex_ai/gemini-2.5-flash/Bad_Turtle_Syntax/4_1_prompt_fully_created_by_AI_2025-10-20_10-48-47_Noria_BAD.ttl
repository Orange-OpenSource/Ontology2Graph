@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix devopsprod: <http://w3id.org/devops-infra/product#> .

# =============================================================================
# Agents (Teams and Persons)
# =============================================================================

# Organizational Units (Teams)
noria:Team_DNSAdmin a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for the management and support of DNS infrastructure."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for routine issues, emergency hotline for critical outages."@en ;
    foaf:mbox "dns-admin@example.com" .

noria:Team_NetworkOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for monitoring and maintaining the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call the NOC hotline for network-related incidents."@en ;
    foaf:mbox "network-ops@example.com" .

noria:Team_AppSupport a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2/L3 support for critical business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri, On-call weekends"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket with detailed logs. For P1 incidents, follow up with a call."@en ;
    foaf:mbox "app-support@example.com" .

noria:Team_SecurityOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring, detecting, analyzing, and responding to cybersecurity incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SIEMAlert> ;
    noria:agentInstructions "Automated alerts are preferred. For manual reporting, use the dedicated security portal."@en ;
    foaf:mbox "soc@example.com" .

noria:Team_ChangeManagement a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Change Management Board"@en ;
    rdfs:comment "Team responsible for reviewing and approving all changes to IT infrastructure and services."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/ChangeRequestSystem> ;
    noria:agentInstructions "All changes must be submitted via the Change Management System at least 7 days in advance."@en ;
    foaf:mbox "cmb@example.com" .

# Individual Persons
noria:Person_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Engineer in the DNS Admin Team."@en ;
    foaf:mbox "alice.smith@example.com" ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en .

noria:Person_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Network Engineer in the Network Operations Team."@en ;
    foaf:mbox "bob.johnson@example.com" ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "Shift A (Mon-Thu)"@en .

noria:Person_CarolWhite a foaf:Person, foaf:Agent ;
    rdfs:label "Carol White"@en ;
    rdfs:comment "Application Manager for the CRM system."@en ;
    foaf:mbox "carol.white@example.com" ;
    foaf:phone "+1-555-111-2222" ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en .

# =============================================================================
# Product Models
