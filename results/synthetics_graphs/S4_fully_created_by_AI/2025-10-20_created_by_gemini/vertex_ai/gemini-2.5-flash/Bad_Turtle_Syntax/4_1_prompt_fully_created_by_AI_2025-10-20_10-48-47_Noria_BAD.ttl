noria:TT_DNSOutage_001 noria:troubleTicketRelatedParty noria:Person_AliceSmith .

# Example of a ChangeRequest having a document attachment (using a placeholder URI for the attachment)
noria:CR_SFPReplacement_001 dcterms:hasPart <https://itsm.example.com/attachments/CR-20240420-001-SFP_spec.pdf> .
<https://itsm.example.com/attachments/CR-20240420-001-SFP_spec.pdf> a noria:DocumentAttachment ;
    rdfs:label "SFP Module Specification Sheet"@en ;
    rdfs:comment "PDF document containing technical specifications for the SFP module to be replaced."@en .

# Example of a TroubleTicketNote having a document attachment
noria:TTN_WANLink_Note1 dcterms:hasPart <https://itsm.example.com/attachments/INC-20240420-002-Optical_Power_Report.pdf> .
<https://itsm.example.com/attachments/INC-20240420-002-Optical_Power_Report.pdf> a noria:DocumentAttachment ;
    rdfs:label "Optical Power Measurement Report"@en ;
    rdfs:comment "PDF report showing the optical power readings for the WAN link."@en .

# Example of a TroubleTicket having a characteristic (using a placeholder for a characteristic class)
# The vocabulary defines noria:troubleTicketCharacteristic as an ObjectProperty, but doesn't define a specific class for the characteristic itself.
# For density, I'll create a generic "Characteristic" class if needed, or just link to a literal if the property was DatatypeProperty.
# Since it's ObjectProperty, I'll create a dummy class for demonstration.
noria:TroubleTicketCharacteristic_ImpactedUsers a owl:Class ;
    rdfs:label "Impacted Users Characteristic"@en ;
    rdfs:comment "A characteristic describing the number or type of users impacted by a trouble ticket."@en .

noria:TT_DNSOutage_001 noria:troubleTicketCharacteristic noria:TTChar_DNSOutage_ImpactedUsers .
noria:TTChar_DNSOutage_ImpactedUsers a noria:TroubleTicketCharacteristic_ImpactedUsers ;
    rdfs:label "All Corporate Users"@en ;
    rdfs:comment "All users across the corporate network are impacted by the DNS outage."@en .

# Example of a TroubleTicket freeze item (linking to an EventRecord that signifies a freeze)
noria:TT_WANLinkDegradation_002 noria:troubleTicketFreezeItem noria:Event_WANLinkFreezeStart .

noria:Event_WANLinkFreezeStart a noria:EventRecord ;
    rdfs:label "WAN Link Incident Freeze Start"@en ;
    rdfs:comment "Incident management for WAN Link Degradation was temporarily frozen due to external dependency."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Incident INC-20240420-002 frozen. Waiting for ISP response."@en ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Informational> .

# Example of an AnomalyPattern
noria:AnomalyPattern_HighRxPower a noria:AnomalyPattern ;
    rdfs:label "High Optical Rx Power Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating unusually high received optical power, potentially due to misconfiguration or faulty equipment."@en ;
    folio:hasCause "Misconfiguration" ;
    folio:hasEffect "Link instability" .

noria:Event_WANLinkDegradation dcterms:relation noria:AnomalyPattern_HighRxPower . # Relate the event to a potential anomaly pattern

