    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Event Management" .

# =============================================================================
# Application Modules
# =============================================================================

noria:AppMod_DNSRes_Prod a noria:ApplicationModule ;
