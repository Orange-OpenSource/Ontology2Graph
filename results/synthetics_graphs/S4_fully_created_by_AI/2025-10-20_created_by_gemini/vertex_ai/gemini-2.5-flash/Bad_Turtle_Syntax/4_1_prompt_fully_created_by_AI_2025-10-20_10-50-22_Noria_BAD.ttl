noria:NetworkInterface_Edge01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "Edge01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface on Edge Router 01 connecting to the Internet Service Provider."@en ;
    noria:networkInterfaceOf noria:Resource_RouterEdge01 ;
