noria:NetworkLink_CoreToEdge a noria:NetworkLink ;
    rdfs:label "Core to Edge Link"@en, "Lien Cœur vers Bordure"@fr ;
    rdfs:comment "High-speed fiber-optic link between Core Router 01 and Edge Router 01."@en ;
