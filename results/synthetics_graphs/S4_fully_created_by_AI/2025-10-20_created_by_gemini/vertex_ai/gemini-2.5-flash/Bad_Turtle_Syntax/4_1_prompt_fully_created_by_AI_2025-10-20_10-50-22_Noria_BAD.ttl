@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents and Organizations ---

noria:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en, "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution of related incidents."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

noria:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for managing network infrastructure, including routers and switches."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Always call the hotline for network-related incidents."@en .

noria:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing level 2 support for business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "Submit a ticket for all application issues. Escalation via team lead."@en .

noria:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center"@en, "Centre Opérations Sécurité"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> ;
    noria:agentInstructions "Follow established security incident response procedures."@en .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Individual member of the DNS Admin Team, specialized in Linux server administration."@en ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Individual member of the Network Operations Team, specialized in Cisco devices."@en ;
    noria:agentWorkingHours "Shift A (06:00-14:00)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

noria:Agent_ExternalAttacker a foaf:Agent ;
    rdfs:label "External Attacker"@en, "Attaquant Externe"@fr ;
    rdfs:comment "Represents an unknown external entity attempting malicious activity against IT systems."@en .

noria:OrgUnit_ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en, "Département Informatique"@fr ;
    rdfs:comment "Main IT department of the company, overseeing all IT operations."@en ;
    org:hasMember noria:Agent_JohnDoe, noria:Agent_JaneSmith ;
    org:unitOf noria:Org_GlobalCorp .

noria:OrgUnit_NetworkOperations a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en, "Unité Opérations Réseau"@fr ;
    rdfs:comment "Sub-unit within IT Department focusing on network infrastructure management and support."@en ;
    org:hasMember noria:Agent_JaneSmith ;
    org:subOrganizationOf noria:OrgUnit_ITDepartment .

noria:Org_GlobalCorp a org:Organization ;
    rdfs:label "GlobalCorp Inc."@en, "GlobalCorp S.A."@fr ;
    rdfs:comment "The main corporate entity, a global technology provider."@en .

noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe, used for system access."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount noria:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for Jane Smith, used for network device access."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount noria:Agent_JaneSmith .

# --- Product Models ---

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model, commonly used for critical applications."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series Switch"@en ;
    rdfs:comment "Data center-grade network switch, known for high throughput and reliability."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading virtualization platform software."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Global technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

# --- Locations ---

noria:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en, "Centre de Données Principal"@fr ;
    rdfs:comment "Primary data center facility for corporate services, located in Metropolis."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue" ;
    noria:sitePrincipalAddressCityName "Metropolis" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" ;
    bot:containsZone noria:Room_ServerRoomA, noria:Room_NetworkRoomB .

noria:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en, "Site de Reprise après Sinistre"@fr ;
    rdfs:comment "Secondary data center for disaster recovery purposes, located in Gotham."@en ;
    noria:siteId "DR01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Road" ;
    noria:sitePrincipalAddressCityName "Gotham" ;
    noria:sitePrincipalAddressPostalCode "20002" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within DC01, housing critical application servers."@en ;
    bot:containsZone noria:Locus_RackA1, noria:Locus_RackA2 .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en, "Salle Réseau B"@fr ;
    rdfs:comment "Network equipment room within DC01, containing core and edge routers."@en ;
    bot:containsZone noria:Locus_RackB5, noria:Locus_RackB6 .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en, "Baie A1"@fr ;
    rdfs:comment "Location of servers in Server Room A, specifically for DNS and Web servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en, "Baie A2"@fr ;
    rdfs:comment "Location of virtualization hosts and database servers in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

noria:Locus_RackB5 a noria:Locus ;
    rdfs:label "Rack B5"@en, "Baie B5"@fr ;
    rdfs:comment "Location of core network devices in Network Room B."@en ;
    noria:locusLine "B" ;
    noria:locusRow "5" .

noria:Locus_RackB6 a noria:Locus ;
    rdfs:label "Rack B6"@en, "Baie B6"@fr ;
    rdfs:comment "Location of edge network devices and firewalls in Network Room B."@en ;
    noria:locusLine "B" ;
    noria:locusRow "6" .

