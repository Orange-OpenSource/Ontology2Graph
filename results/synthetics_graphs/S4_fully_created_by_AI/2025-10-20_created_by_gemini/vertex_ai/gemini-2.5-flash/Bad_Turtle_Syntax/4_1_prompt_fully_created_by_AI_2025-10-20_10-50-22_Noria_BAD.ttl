# --- Event Records ---

noria:EventRecord_DNSOutageAlarm a noria:EventRecord ;
    rdfs:label "DNS Server Outage Alarm"@en, "Alarme Panne Serveur DNS"@fr ;
    rdfs:comment "Automated alarm indicating DNS01 server is unreachable, detected by monitoring system."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartDNSService .

noria:EventRecord_NetworkInterfaceDown a noria:EventRecord ;
    rdfs:label "Network Interface Down Log"@en, "Log Interface Réseau Hors Service"@fr ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down, potentially causing service disruption."@en ;
    noria:loggingTime "2024-04-23T09:58:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_SyslogServer ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_ConfigChangeSuccess a noria:EventRecord ;
    rdfs:label "Configuration Change Success Log"@en, "Log Changement de Configuration Réussi"@fr ;
    rdfs:comment "Log entry confirming a successful configuration change on Edge Router 01 by Jane Smith."@en ;
    noria:loggingTime "2024-04-22T15:30:10Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jsmith (10.0.0.5)"@en ;
    noria:logOriginatingManagedObject noria:Resource_RouterEdge01 ;
    noria:logOriginatingManagementSystem noria:Application_SyslogServer ;
    noria:logOriginatingAgent noria:Agent_JaneSmith ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_DNSOutageStatusChangeInProgress a noria:EventRecord ;
    rdfs:label "DNS TT Status Change to InProgress"@en ;
    rdfs:comment "Event record for the status change of DNS outage ticket to InProgress, logged by ITSM system."@en ;
    noria:loggingTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-2024-04-23-001 status changed to InProgress."@en ;
    noria:logOriginatingManagementSystem noria:Application_ITSMSystem ;
    noria:logOriginatingAgent noria:Agent_JohnDoe ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_CRRouterUpgradeStatusChangeScheduled a noria:EventRecord ;
    rdfs:label "CR Router Upgrade Status Change to Scheduled"@en ;
    rdfs:comment "Event record for the status change of Router Upgrade CR to Scheduled, logged by ITSM system."@en ;
    noria:loggingTime "2024-04-20T16:05:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-2024-04-15-001 status changed to Scheduled."@en ;
    noria:logOriginatingManagementSystem noria:Application_ITSMSystem ;
    noria:logOriginatingAgent noria:Agent_JaneSmith ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_SQLInjectionAttempt a noria:EventRecord ;
    rdfs:label "SQL Injection Attempt Alert"@en, "Alerte Tentative Injection SQL"@fr ;
    rdfs:comment "Alert from WAF indicating a potential SQL injection attempt on web server, originating from an external attacker."@en ;
    noria:loggingTime "2024-04-24T08:15:00Z"^^xsd:dateTime ;
    noria:logText "SECURITY ALERT: SQL Injection detected from IP 203.0.113.42 on web01.corp.example.com."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_WAFSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent noria:Agent_ExternalAttacker .

# --- Trouble Tickets ---

noria:TroubleTicket_DNSOutageTT a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en, "Incident Panne Serveur DNS"@fr ;
    rdfs:comment "Critical incident reported due to primary DNS server being unreachable, impacting corporate services globally."@en ;
    dcterms:created "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DNSOutageAlarm ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/InaccessibleDestination> ;
    noria:troubleTicketCause "Suspected network connectivity issue to DNS server, later confirmed as interface down."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T11:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Agent_DNSAdminTeam, noria:Agent_NetworkOpsTeam ;
    noria:troubleTicketRelatedService noria:Application_CorpDNS ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01, noria:Resource_RouterCore01 ;
    noria:troubleTicketImpacts noria:Application_CorpWebsite, noria:Service_CriticalBusinessService ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-2024-04-23-001" ;
    noria:documentStatusHistory noria:EventRecord_DNSOutageStatusChangeInProgress .

noria:TroubleTicketNote_DNSInvestigation a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Investigation Note"@en, "Note d'Investigation Panne DNS"@fr ;
    rdfs:comment "Initial investigation shows Core Router 01 interface connected to DNS01 is down, requiring network team intervention."@en ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer_NetworkDiag ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutageTT .

noria:TroubleTicketNote_DNSResolution a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Resolution Note"@en, "Note de Résolution Panne DNS"@fr ;
    rdfs:comment "Interface on Core Router 01 brought back up by network team. DNS service restored and verified."@en ;
    dcterms:created "2024-04-23T11:25:00Z"^^xsd:dateTime ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/CorrectiveAction> ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutageTT .

noria:TroubleTicket_WebsiteSlownessTT a noria:TroubleTicket ;
    rdfs:label "Corporate Website Slowness Incident"@en, "Incident Lenteur Site Web d'entreprise"@fr ;
    rdfs:comment "Users reporting slow loading times for the corporate website, impacting user experience."@en ;
    dcterms:created "2024-04-24T09:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Minor> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P3> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/User> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedParty noria:Agent_AppSupportTeam ;
    noria:troubleTicketRelatedService noria:Application_CorpWebsite ;
    noria:troubleTicketRelatedResource noria:Resource_WebSrv01 ;
    noria:documentHRef "https://itsm.example.com/ticket/TT-2024-04-24-002" .

noria:TroubleTicket_SQLInjectionTT a noria:TroubleTicket ;
    rdfs:label "SQL Injection Investigation"@en, "Investigation Injection SQL"@fr ;
    rdfs:comment "Incident opened to investigate a detected SQL injection attempt on the corporate website."@en ;
    dcterms:created "2024-04-24T08:30:00Z"^^xsd:dateTime ;
