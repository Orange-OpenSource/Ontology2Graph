    dcterms:isPartOf noria:TroubleTicket_DNSOutageTT ;
    dcterms:isPartOf noria:ChangeRequest_RouterUpgrade ;
    noria:documentHRef "https://docs.example.com/diagrams/DC01_Network_Diagram_v3.2.pdf" .

noria:DocumentAttachment_PatchPlan a noria:DocumentAttachment ;
    rdfs:label "CRM DB Patching Plan"@en, "Plan de Patching BD CRM"@fr ;
    rdfs:comment "Detailed plan for applying security patches to the CRM database, including rollback procedures."@en ;
    dcterms:created "2024-04-25T11:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:ChangeRequest_DBPatch ;
    noria:documentHRef "https://docs.example.com/plans/CRM_DB_Patching_Plan.docx" .
