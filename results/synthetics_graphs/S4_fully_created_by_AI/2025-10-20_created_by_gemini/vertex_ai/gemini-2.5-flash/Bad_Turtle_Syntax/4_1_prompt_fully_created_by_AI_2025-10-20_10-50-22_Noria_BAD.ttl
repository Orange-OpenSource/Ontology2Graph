# --- Operation Plans and Conditions ---

noria:OperationPlan_RestartDNSService a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en, "Procédure de Redémarrage du Service DNS"@fr ;
    rdfs:comment "Standard operating procedure to restart the DNS service on a server, including verification steps."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSServiceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSServiceUp .

noria:OperationPlan_NetworkInterfaceTroubleshoot a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en, "Procédure de Dépannage Interface Réseau"@fr ;
    rdfs:comment "Procedure for diagnosing and resolving issues with network interfaces, including physical checks and configuration review."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:ActionPreCondition_DNSServiceDown a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down Pre-condition"@en ;
    rdfs:comment "Pre-condition: DNS service is reported as down or unreachable from multiple monitoring points."@en .

noria:ActionPostCondition_DNSServiceUp a noria:ActionPostCondition ;
    rdfs:label "DNS Service Up Post-condition"@en ;
    rdfs:comment "Post-condition: DNS service is confirmed to be running, reachable, and resolving queries correctly."@en .

noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-condition"@en ;
    rdfs:comment "Pre-condition: A network interface is reported as administratively or operationally down, affecting connectivity."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-condition"@en ;
    rdfs:comment "Post-condition: The network interface is confirmed to be administratively and operationally up, with traffic flowing."@en .

noria:ProcedureExecutionContainer_NetworkDiag a pep:ProcedureExecutionContainer ;
    rdfs:label "Network Diagnostic Execution"@en ;
    rdfs:comment "Container for network diagnostic commands executed during DNS outage investigation, including ping and traceroute."@en ;
    pep:hasExecution noria:EventRecord_NetworkInterfaceDown .

# --- Document Attachments ---

noria:DocumentAttachment_NetworkDiagram a noria:DocumentAttachment ;
    rdfs:label "Network Diagram DC01"@en, "Diagramme Réseau DC01"@fr ;
    rdfs:comment "PDF document illustrating the network topology of Main Data Center, version 3.2."@en ;
