    noria:networkLinkInstallationDate "2021-10-25T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterEdge01 ;
    noria:NetworkInterface_Core01_Gi0_0_2 noria:networkInterfaceConnects noria:NetworkLink_CoreToEdge ;
    noria:NetworkInterface_Edge01_Gi0_0_1 noria:networkInterfaceConnects noria:NetworkLink_CoreToEdge .

noria:NetworkLink_DNS01ToCore a noria:NetworkLink ;
    rdfs:label "DNS01 to Core Link"@en, "Lien DNS01 vers Cœur"@fr ;
    rdfs:comment "Ethernet link connecting DNS01 server to Core Router 01."@en ;
