noria:Event_DNS_Down a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Alert"@en ;
    rdfs:comment "Automated alert indicating DNS server dns01.corp.example.com is unreachable."@en ;
    noria:loggingTime "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    dcterms:type <kos/Notification/EventType/HostDown> .

noria:Event_Router_Interface_Down a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical network interface on core router went down."@en ;
    noria:loggingTime "2024-03-15T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Router_Core01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "INTERFACE-5-DOWN: Interface GigabitEthernet0/0/2, changed state to down"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/InterfaceDown> .

noria:Event_DB_HighCPU a noria:EventRecord ;
    rdfs:label "CRM DB High CPU Usage"@en ;
    rdfs:comment "Alert for sustained high CPU usage on CRM database VM."@en ;
    noria:loggingTime "2024-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_VM_CRM_DB ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "WARNING: VM crmdb01.app.example.com CPU usage > 90% for 15 minutes"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:type <kos/Notification/EventType/HighCPU> .

noria:Event_FW_ConfigChange a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log entry indicating a configuration change on the DMZ firewall."@en ;
    noria:loggingTime "2024-03-14T18:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall_DMZ01 ;
    noria:logOriginatingAgent noria:Agent_SecurityTeam ;
    noria:logText "User 'secadmin' committed configuration change: added rule to allow port 8080 to web01."@en ;
    dcterms:type <kos/Notification/EventType/ConfigChange> .

noria:Event_WebSrv_ErrorLog a noria:EventRecord ;
    rdfs:label "Web Server Error Log"@en ;
    rdfs:comment "Error log from production web server indicating application fault."@en ;
    noria:loggingTime "2024-03-15T11:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv_Prod01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "ERROR: Application 'E-Commerce' failed to connect to database. Connection timed out."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:type <kos/Notification/EventType/ApplicationError> .

