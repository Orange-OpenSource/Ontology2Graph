# =============================================================================
# Procedural Elements (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:OP_SFP_Replacement a noria:OperationPlan ;
    rdfs:label "SFP Module Replacement Procedure"@en ;
    rdfs:comment "Standard operating procedure for replacing a Small Form-Factor Pluggable (SFP) module."@en ;
    noria:operationPlanPreCondition noria:APC_SFP_FaultConfirmed ;
    noria:operationPlanPostCondition noria:APOC_LinkUpAndStable .

noria:APC_SFP_FaultConfirmed a noria:ActionPreCondition ;
    rdfs:label "SFP Fault Confirmed"@en ;
    rdfs:comment "Pre-condition: Diagnostic tests confirm SFP module failure (e.g., no light, CRC errors)."@en ;
    skos:example "Interface operational status is 'down', optical power readings are abnormal."@en .

noria:APOC_LinkUpAndStable a noria:ActionPostCondition ;
    rdfs:label "Link Up and Stable"@en ;
    rdfs:comment "Post-condition: Network link is operational, stable, and traffic is flowing as expected."@en ;
    skos:example "Interface operational status is 'up', no errors, ping tests successful, traffic metrics normal."@en .

noria:OP_DB_QueryOptimization a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries."@en ;
    noria:operationPlanPreCondition noria:APC_HighCPU_DB ;
    noria:operationPlanPostCondition noria:APOC_CPU_Normal_DB .

noria:APC_HighCPU_DB a noria:ActionPreCondition ;
    rdfs:label "High CPU on Database"@en ;
    rdfs:comment "Pre-condition: Database server CPU utilization is consistently high, impacting performance."@en ;
    skos:example "Monitoring system reports CPU > 80% for more than 30 minutes on CRMDB01."@en .

noria:APOC_CPU_Normal_DB a noria:ActionPostCondition ;
    rdfs:label "Database CPU Normal"@en ;
    rdfs:comment "Post-condition: Database server CPU utilization returns to normal levels after optimization."@en ;
    skos:example "Monitoring system reports CPU < 50% for 1 hour on CRMDB01, application performance restored."@en .

# =============================================================================
# Additional connections and density
# =============================================================================

# Link Event_DNS_Down to the SFP replacement operation plan (implicitly via TTN)
