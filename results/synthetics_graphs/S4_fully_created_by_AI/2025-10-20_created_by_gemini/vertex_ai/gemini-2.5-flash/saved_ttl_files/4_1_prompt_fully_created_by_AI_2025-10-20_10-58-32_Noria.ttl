# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NL_CoreRtr_to_DMZFW a noria:NetworkLink ;
    rdfs:label "Link Core Router 01 to DMZ Firewall 01"@en ;
    rdfs:comment "Direct link between core router and DMZ firewall in Paris DC."@en ;
    noria:networkLinkId "NL-CR01-FW01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Router_Core01 ;
