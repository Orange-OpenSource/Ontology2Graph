    dcterms:creator noria:Agent_NetworkOpsTeam ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TT_20240315_001 .

noria:TTN_20240315_001_02 a noria:TroubleTicketNote ;
    rdfs:label "Resolution for DNS outage"@en ;
    rdfs:comment "Found faulty SFP module on core-rtr01 Gi0/0/1. Replaced SFP, link is now up. DNS01 reachable."@en ;
    dcterms:created "2024-03-15T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_NetworkOpsTeam ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/CorrectiveAction> ;
    dcterms:isPartOf noria:TT_20240315_001 .

noria:TTN_20240315_002_01 a noria:TroubleTicketNote ;
