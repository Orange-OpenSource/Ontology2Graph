# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# SKOS Concept Schemes and Concepts (for properties with restricted ranges)
# =============================================================================

# Application related KOS
<kos/application/type> a skos:ConceptScheme ; rdfs:label "Application Type Scheme"@en .
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/business> a skos:Concept ; skos:prefLabel "Business Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/ticketing> a skos:Concept ; skos:prefLabel "Ticketing System"@en ; skos:inScheme <kos/application/type> .

<kos/application/business-importance> a skos:ConceptScheme ; rdfs:label "Application Business Importance Scheme"@en .
<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High Business Importance"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium Business Importance"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/low> a skos:Concept ; skos:prefLabel "Low Business Importance"@en ; skos:inScheme <kos/application/business-importance> .

<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ; rdfs:label "Application Module Status Scheme"@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:prefLabel "Maintenance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ; rdfs:label "Application Module SLA Level Scheme"@en .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; skos:prefLabel "Gold SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; skos:prefLabel "Silver SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# Service related KOS
<kos/service/type> a skos:ConceptScheme ; rdfs:label "Service Type Scheme"@en .
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en ; skos:inScheme <kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en ; skos:inScheme <kos/service/type> .

# TroubleTicket related KOS
<kos/TroubleTicket/severity> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Severity Scheme"@en .
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en ; skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/type> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Type Scheme"@en .
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:prefLabel "Failure"@en ; skos:inScheme <kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:prefLabel "Assistance"@en ; skos:inScheme <kos/TroubleTicket/type> .

<kos/TroubleTicket/category> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Criticity Scheme"@en .
<kos/TroubleTicket/category/InterruptedService> a skos:Concept ; skos:prefLabel "Interrupted Service"@en ; skos:inScheme <kos/TroubleTicket/category> .
<kos/TroubleTicket/category/CorruptedService> a skos:Concept ; skos:prefLabel "Corrupted Service"@en ; skos:inScheme <kos/TroubleTicket/category> .
<kos/TroubleTicket/category/PartialDegradation> a skos:Concept ; skos:prefLabel "Partial Degradation"@en ; skos:inScheme <kos/TroubleTicket/category> .

<kos/TroubleTicket/priority> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Priority Scheme"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en ; skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en ; skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P3> a skos:Concept ; skos:prefLabel "Priority 3"@en ; skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/origin> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Origin Scheme"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision System"@en ; skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/urgency> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Urgency Scheme"@en .
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; skos:prefLabel "Immediate Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; skos:prefLabel "Deferred Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .

<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ; rdfs:label "Trouble Category Scheme"@en .
<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ; skos:prefLabel "Total Breakdown"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/trouble-category/PartialDegradation> a skos:Concept ; skos:prefLabel "Partial Degradation"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ; rdfs:label "Problem Responsibility Scheme"@en .
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; skos:prefLabel "Managed Backbone Networks"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/Customer> a skos:Concept ; skos:prefLabel "Customer Responsibility"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .

<kos/TroubleTicket/commentType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Comment Type Scheme"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:prefLabel "Customer Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .

<kos/TroubleTicket/operationType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Operation Type Scheme"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis"@en ; skos:inScheme <kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; skos:prefLabel "Resolution"@en ; skos:inScheme <kos/TroubleTicket/operationType> .

<kos/TroubleTicket/status> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Status Scheme"@en .
<kos/TroubleTicket/status/Initialised> a skos:Concept ; skos:prefLabel "Initialised"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ; skos:prefLabel "Closed"@en ; skos:inScheme <kos/TroubleTicket/status> .

# ChangeRequest related KOS
<kos/ChangeRequest/category> a skos:ConceptScheme ; rdfs:label "Change Request Category Scheme"@en .
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; skos:prefLabel "Internal Intervention"@en ; skos:inScheme <kos/ChangeRequest/category> .
<kos/ChangeRequest/category/CustomerIntervention> a skos:Concept ; skos:prefLabel "Customer Intervention"@en ; skos:inScheme <kos/ChangeRequest/category> .

<kos/ChangeRequest/type> a skos:ConceptScheme ; rdfs:label "Change Request Type Scheme"@en .
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change"@en ; skos:inScheme <kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:prefLabel "Emergency Change"@en ; skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/cause> a skos:ConceptScheme ; rdfs:label "Change Request Cause Scheme"@en .
