<kos/Notification/EventType/SecurityAlert> a skos:Concept ; skos:prefLabel "Security Alert"@en ; skos:inScheme <kos/Notification/EventType> .
<kos/Notification/EventType/ConfigurationChange> a skos:Concept ; skos:prefLabel "Configuration Change"@en ; skos:inScheme <kos/Notification/EventType> .
