# Agent Contact Method KOS
<kos/org/agent-contact-method> a skos:ConceptScheme ; rdfs:label "Agent Contact Method Scheme"@en .
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Chat> a skos:Concept ; skos:prefLabel "Chat"@en ; skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent/NetworkOperationsTeam
    a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call hotline for critical issues, use ticketing system for non-critical."@en .

foaf:Agent/ApplicationSupportTeam_CustomerPortal
    a foaf:Agent ;
    rdfs:label "Customer Portal Application Support Team"@en ;
    rdfs:comment "Team responsible for the Customer Portal application."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email support alias for all issues."@en .

foaf:Agent/DatabaseAdminTeam
    a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database servers."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for urgent requests, ticketing system for others."@en .

foaf:Agent/SecurityOperationsTeam
    a foaf:Agent ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

foaf:Agent/CustomerServiceTeam
    a foaf:Agent ;
    rdfs:label "Customer Service Team"@en ;
    rdfs:comment "Team handling direct customer inquiries and initial incident reports."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent/QA_Team
    a foaf:Agent ;
    rdfs:label "Quality Assurance Team"@en ;
    rdfs:comment "Team responsible for testing applications in staging environments."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent/JohnDoe
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the Network Operations Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent/JaneSmith
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Customer Portal Application Support Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent/AliceBrown
    a foaf:Agent ;
    rdfs:label "Alice Brown"@en ;
    rdfs:comment "Individual member of the Database Admin Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

foaf:Agent/RobertGreen
    a foaf:Agent ;
    rdfs:label "Robert Green"@en ;
    rdfs:comment "Individual member of the Security Operations Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

org:OrganizationalUnit/NetworkOperationsDept
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Department"@en ;
