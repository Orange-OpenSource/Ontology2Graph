noria:EventRecord/Log_DB01_CPU_High
    a noria:EventRecord ;
    rdfs:label "DB01 High CPU Log"@en ;
    rdfs:comment "Log entry indicating high CPU utilization on Database Server 01."@en ;
    noria:loggingTime "2023-10-26T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource/Server_DB01 ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringSystem ;
    noria:logText "CPU utilization on db01.corp.example.com exceeded 90% for 5 minutes."@en ;
    dcterms:type <kos/Notification/EventType/ThresholdExceeded> .

noria:EventRecord/Log_DB01_CPU_High_Cleared
    a noria:EventRecord ;
    rdfs:label "DB01 CPU High Cleared Log"@en ;
    rdfs:comment "Log entry indicating CPU utilization on Database Server 01 returned to normal."@en ;
    noria:loggingTime "2023-10-26T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource/Server_DB01 ;
    noria:logOriginatingManagementSystem noria:Application/MonitoringSystem ;
    noria:logText "CPU utilization on db01.corp.example.com returned to normal levels."@en ;
    dcterms:type <kos/Notification/EventType/ThresholdCleared> ;
    noria:alarmMitigatedBy noria:TroubleTicket/TT_DB01_Performance .

noria:EventRecord/Log_DB01_BackupSuccess
