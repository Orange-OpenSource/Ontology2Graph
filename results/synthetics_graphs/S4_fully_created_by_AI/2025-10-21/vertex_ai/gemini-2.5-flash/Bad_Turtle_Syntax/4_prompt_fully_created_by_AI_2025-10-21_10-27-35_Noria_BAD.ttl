# =============================================================================
# Action Pre/Post Conditions
# =============================================================================

noria:ActionPreCondition/DB_Load_Low
    a noria:ActionPreCondition ;
    rdfs:label "Database Load Low"@en ;
    rdfs:comment "Condition: Database server CPU and I/O load is below 20%."@en ;
    skos:example "CPU < 20%, I/O < 20%".

noria:ActionPostCondition/DB_Load_Normal
    a noria:ActionPostCondition ;
    rdfs:label "Database Load Normal"@en ;
    rdfs:comment "Expected outcome: Database server CPU and I/O load returns to normal operating levels (below 50%)."@en ;
    skos:example "CPU < 50%, I/O < 50%".

noria:ActionPreCondition/Network_Link_Down
    a noria:ActionPreCondition ;
    rdfs:label "Network Link Down"@en ;
    rdfs:comment "Condition: A critical network link is detected as down."@en ;
    skos:example "Interface operational status is 'down'".

noria:ActionPostCondition/Network_Link_Up
    a noria:ActionPostCondition ;
    rdfs:label "Network Link Up"@en ;
    rdfs:comment "Expected outcome: The network link is restored and operational."@en ;
    skos:example "Interface operational status is 'up'".

noria:ActionPreCondition/Disk_Usage_High
    a noria:ActionPreCondition ;
    rdfs:label "Disk Usage High"@en ;
    rdfs:comment "Condition: Disk usage on a server partition exceeds 90%."@en ;
    skos:example "Disk usage > 90%".

noria:ActionPostCondition/Disk_Usage_Normal
    a noria:ActionPostCondition ;
    rdfs:label "Disk Usage Normal"@en ;
    rdfs:comment "Expected outcome: Disk usage on the server partition returns to normal levels (below 70%)."@en ;
    skos:example "Disk usage < 70%".

noria:ActionPostCondition/Backup_Successful
    a noria:ActionPostCondition ;
    rdfs:label "Backup Successful"@en ;
    rdfs:comment "Expected outcome: Database backup completed without errors."@en ;
    skos:example "Backup log shows 'success' status".

noria:ActionPreCondition/Network_Latency_High
    a noria:ActionPreCondition ;
    rdfs:label "Network Latency High"@en ;
    rdfs:comment "Condition: Network latency between two points exceeds acceptable thresholds."@en ;
    skos:example "Ping RTT > 50ms".

noria:ActionPostCondition/Network_Latency_Normal
    a noria:ActionPostCondition ;
    rdfs:label "Network Latency Normal"@en ;
    rdfs:comment "Expected outcome: Network latency returns to normal levels."@en ;
    skos:example "Ping RTT < 10ms".

noria:ActionPreCondition/VM_Unresponsive
    a noria:ActionPreCondition ;
    rdfs:label "VM Unresponsive"@en ;
    rdfs:comment "Condition: Virtual machine is not responding to network or application requests."@en ;
    skos:example "Ping failure, HTTP 500 errors".

noria:ActionPostCondition/VM_Responsive
    a noria:ActionPostCondition ;
    rdfs:label "VM Responsive"@en ;
    rdfs:comment "Expected outcome: Virtual machine is responding normally."@en ;
    skos:example "Ping success, HTTP 200 OK".
