# --- Applications ---
noria:Application001 a noria:Application ;
    rdfs:label "Corporate Web Portal"@en, "Portail Web d'Entreprise"@fr ;
    rdfs:comment "Main public-facing web application for the company, providing information and services to customers."@en ;
