# --- Services ---
noria:Service001 a noria:Service ;
    rdfs:label "Public Web Access Service"@en, "Service d'Accès Web Public"@fr ;
    rdfs:comment "End-to-end service providing public access to the corporate web portal, including load balancing and web servers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:ApplicationModule001 ; # Application module is part of this service
    seas:subSystem noria:Resource002 ; # Web server is part of this service
    seas:subSystem noria:Resource005 . # Load Balancer is part of this service

noria:Service002 a noria:Service ;
    rdfs:label "Internal Database Connectivity Service"@en, "Service de Connectivité Base de Données Interne"@fr ;
    rdfs:comment "Service ensuring connectivity to the main corporate database for internal applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:Resource003 ; # Database server is part of this service
    seas:subSystem noria:ApplicationModule003 . # HR System module relies on this service

noria:Service003 a noria:Service ;
    rdfs:label "Secure Internet Access Service"@en, "Service d'Accès Internet Sécurisé"@fr ;
    rdfs:comment "Service providing secure internet access for internal users and public access to web applications, protected by firewall."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:Resource007 ; # Firewall
    seas:subSystem noria:Resource005 ; # Load Balancer
    seas:subSystem noria:ApplicationModule001 . # Corporate Web Portal Prod Module

# --- Event Records ---
noria:EventRecord001 a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that network interface ge-0/0/0.100 on Core Router R1 went down, impacting primary internet connectivity."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/0.100, changed state to down." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan003 .

noria:EventRecord002 a noria:EventRecord ;
    rdfs:label "Web Server High CPU Usage"@en ;
    rdfs:comment "Warning for high CPU utilization on Web Server WS01, potentially causing performance degradation for the web portal."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource002 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "CPU utilization on web-server-01.example.com exceeded 90% for 5 minutes." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmProposedRepairAction noria:OperationPlan002 .

noria:EventRecord003 a noria:EventRecord ;
    rdfs:label "Database Login Failure"@en ;
    rdfs:comment "Multiple failed login attempts on Database Server DB01, indicating a potential security breach or misconfiguration."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource003 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logOriginatingAgent foaf:Agent004 ; # SOC team might be the agent if they detected it
    noria:logText "Failed login for user 'baduser' from IP 192.168.1.10 (5 attempts)." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord004 a noria:EventRecord ;
    rdfs:label "Configuration Change on Router R1"@en ;
    rdfs:comment "Log entry for a configuration change applied to Core Router R1, specifically enabling an interface."@en ;
    noria:loggingTime "2024-04-19T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logOriginatingAgent foaf:Agent001 ;
    noria:logText "Configuration changed by 'admin' from 10.0.0.5: interface ge-0/0/0.100 no shutdown." .

noria:EventRecord005 a noria:EventRecord ;
    rdfs:label "Web Service Restarted"@en ;
    rdfs:comment "Log entry confirming web service restart on WS01, part of the mitigation for high CPU."@en ;
    noria:loggingTime "2024-04-20T09:41:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource002 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logOriginatingAgent foaf:Agent002 ;
    noria:logText "Apache service restarted successfully." .

noria:EventRecord006 a noria:EventRecord ;
    rdfs:label "Firmware Download Complete"@en ;
    rdfs:comment "Log entry confirming successful firmware download for Core Router R1, preparatory step for upgrade."@en ;
    noria:loggingTime "2024-04-28T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource001 ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "Firmware image 'junos-21.4R1.9.tgz' downloaded to /var/tmp." ;
    dcterms:isPartOf noria:ChangeRequest001 . # Event directly related to CR

noria:EventRecord007 a noria:EventRecord ;
    rdfs:label "TT001 Status Change: InProgress"@en ;
    rdfs:comment "Event recording the status change of Trouble Ticket 001 to InProgress, indicating active work on the incident."@en ;
    noria:loggingTime "2024-04-20T09:06:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application003 ; # Assuming NMS updates TT status
    noria:logText "Trouble Ticket TT001 status changed to InProgress." ;
    dcterms:references noria:TroubleTicket001 .

noria:EventRecord008 a noria:EventRecord ;
    rdfs:label "TT001 Status Change: Resolved"@en ;
    rdfs:comment "Event recording the status change of Trouble Ticket 001 to Resolved, indicating the issue has been fixed."@en ;
    noria:loggingTime "2024-04-20T12:50:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "Trouble Ticket TT001 status changed to Resolved." ;
    dcterms:references noria:TroubleTicket001 .

noria:EventRecord009 a noria:EventRecord ;
    rdfs:label "CR001 Status Change: InProgress"@en ;
    rdfs:comment "Event recording the status change of Change Request 001 to InProgress, indicating the upgrade is underway."@en ;
    noria:loggingTime "2024-05-01T02:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "Change Request CR001 status changed to InProgress." ;
    dcterms:references noria:ChangeRequest001 .

noria:EventRecord010 a noria:EventRecord ;
    rdfs:label "CR001 Status Change: Completed"@en ;
    rdfs:comment "Event recording the status change of Change Request 001 to Completed, indicating successful firmware upgrade."@en ;
    noria:loggingTime "2024-05-01T04:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:Application003 ;
    noria:logText "Change Request CR001 status changed to Completed." ;
    dcterms:references noria:ChangeRequest001 .

noria:EventRecord011 a noria:EventRecord ;
    rdfs:label "Firewall Policy Violation Alert"@en ;
    rdfs:comment "Alert indicating a firewall policy violation detected on FW01, potentially a security threat."@en ;
    noria:loggingTime "2024-04-21T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource007 ;
    noria:logOriginatingManagementSystem noria:Application003 ; # NMS also monitors firewalls
    noria:logOriginatingAgent foaf:Agent004 ;
    noria:logText "Policy violation: Source IP 1.2.3.4 attempted access to internal network." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord012 a noria:EventRecord ;
    rdfs:label "Backup Job Failure"@en ;
    rdfs:comment "Alert indicating a scheduled backup job failed on Backup Server BS01, risking data loss."@en ;
    noria:loggingTime "2024-04-21T03:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource006 ;
    noria:logOriginatingManagementSystem noria:Application004 ; # Backup application itself
    noria:logText "Backup job 'Daily_DB_Backup' failed with error code 123." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

# --- Trouble Tickets ---
noria:TroubleTicket001 a noria:TroubleTicket ;
    rdfs:label "Core Router R1 Uplink Down"@en, "Liaison Montante Routeur Cœur R1 Hors Service"@fr ;
    rdfs:comment "Critical incident: Primary uplink of Core Router R1 to ISP A is down, severely impacting internet connectivity for all corporate services."@en ;
    dcterms:created "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord001 ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "NMS-APP" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Physical fiber cut on ISP A link, confirmed by ISP technician."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent001 ;
    noria:troubleTicketRelatedService noria:Service001 ;
    noria:troubleTicketRelatedResource noria:Resource001 ;
    noria:troubleTicketImpacts noria:Application001, noria:Service001, noria:Resource001 ;
    noria:documentStatusHistory noria:EventRecord007, noria:EventRecord008 .

noria:TroubleTicket002 a noria:TroubleTicket ;
    rdfs:label "Corporate Web Portal Performance Degradation"@en, "Dégradation des Performances du Portail Web d'Entreprise"@fr ;
    rdfs:comment "Users report slow loading times for the corporate web portal due to high CPU on web server, affecting customer experience."@en ;
