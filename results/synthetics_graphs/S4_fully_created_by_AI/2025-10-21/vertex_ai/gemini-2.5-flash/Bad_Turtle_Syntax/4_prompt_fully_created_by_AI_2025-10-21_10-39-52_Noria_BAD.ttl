# --- Network Interfaces ---
noria:NetworkInterface001 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/0.100"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/0, VLAN 100, on Core Router R1, serving as primary uplink to ISP A."@en ;
    noria:networkInterfaceOf noria:Resource001 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to ISP A" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ; # -3 dBm
    noria:networkInterfaceLaserRxOpticalPower -5 ; # -5 dBm
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface002 a noria:NetworkInterface ;
