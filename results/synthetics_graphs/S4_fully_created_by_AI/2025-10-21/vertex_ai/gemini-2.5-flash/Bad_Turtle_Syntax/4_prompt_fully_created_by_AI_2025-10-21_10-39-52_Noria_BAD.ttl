    rdfs:label "eth0-fw-ext"@en ;
    rdfs:comment "External interface for Firewall FW01, connected to the internet gateway."@en ;
    noria:networkInterfaceOf noria:Resource007 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "WAN interface for internet connectivity" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface010 a noria:NetworkInterface ;
    rdfs:label "eth1-fw-int"@en ;
    rdfs:comment "Internal interface for Firewall FW01, connected to the internal network and DMZ."@en ;
    noria:networkInterfaceOf noria:Resource007 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "LAN interface for internal traffic" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# --- Network Links ---
