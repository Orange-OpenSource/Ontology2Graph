    dcterms:created "2024-04-28T10:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent001 ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan001 ;
    dcterms:isPartOf noria:ChangeRequest001 .

