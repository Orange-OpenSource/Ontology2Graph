    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CWP" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Online Presence" .

noria:Application002 a noria:Application ;
    rdfs:label "Internal HR System"@en, "Système RH Interne"@fr ;
