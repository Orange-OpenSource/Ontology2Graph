    rdfs:comment "Execution of steps to resolve high CPU on Web Server WS01, related to Trouble Ticket 002, including service restart."@en ;
    dcterms:isPartOf noria:TroubleTicket002 ;
    pep:usedProcedure noria:OperationPlan002 ;
    pep:member noria:EventRecord005 . # This event is part of the procedure execution

