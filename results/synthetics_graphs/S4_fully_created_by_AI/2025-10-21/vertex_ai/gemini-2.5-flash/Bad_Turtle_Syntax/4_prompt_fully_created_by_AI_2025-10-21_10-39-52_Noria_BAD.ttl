    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/PerformanceDegradation> ;
    noria:troubleTicketCause "Unexpected traffic surge on web portal, possibly due to a marketing campaign."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
