    noria:troubleTicketRelatedService noria:Application001 ;
    noria:troubleTicketRelatedResource noria:Resource002 ;
    noria:troubleTicketImpacts noria:ApplicationModule001 .

noria:TroubleTicket003 a noria:TroubleTicket ;
    rdfs:label "Firewall Policy Violation Incident"@en, "Incident de Violation de Politique de Pare-feu"@fr ;
    rdfs:comment "Security incident: Firewall detected unauthorized access attempt from an external IP, requiring immediate investigation."@en ;
