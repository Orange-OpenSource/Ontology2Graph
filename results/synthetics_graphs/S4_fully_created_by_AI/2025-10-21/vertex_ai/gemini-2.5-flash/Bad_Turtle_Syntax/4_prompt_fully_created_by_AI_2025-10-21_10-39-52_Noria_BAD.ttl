    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:ApplicationModule005 a noria:ApplicationModule ;
    rdfs:label "DBS Production Module"@en, "Module de Production DBS"@fr ;
    rdfs:comment "Production instance of the Data Backup Service, managing daily backup operations."@en ;
    noria:applicationModuleOf noria:Application004 ;
    noria:applicationModuleName "DBS_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam org:OrganizationalUnit001 ;
