    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleAdministrationTeam org:OrganizationalUnit002 ;
    noria:applicationModuleAdministrationLeader foaf:Agent005 ;
    noria:applicationModuleSupportTeam foaf:Agent002 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Bronze> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled false ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InDevelopment> .

noria:ApplicationModule003 a noria:ApplicationModule ;
    rdfs:label "HRS Production Module"@en, "Module de Production HRS"@fr ;
    rdfs:comment "Production instance of the Internal HR System, used by all employees for HR-related tasks."@en ;
    noria:applicationModuleOf noria:Application002 ;
    noria:applicationModuleName "HRS_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam org:OrganizationalUnit002 ;
    noria:applicationModuleSupportTeam foaf:Agent002 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:ApplicationModule004 a noria:ApplicationModule ;
    rdfs:label "NMS Monitoring Engine"@en, "Moteur de Surveillance NMS"@fr ;
    rdfs:comment "Core monitoring engine of the Network Monitoring System, processing all incoming network data."@en ;
    noria:applicationModuleOf noria:Application003 ;
    noria:applicationModuleName "NMS_ENGINE" ;
    noria:applicationModuleIdentifier "ENGINE" ;
    noria:applicationModuleAdministrationTeam org:OrganizationalUnit001 ;
