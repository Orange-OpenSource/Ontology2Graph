    noria:applicationShortIdentifier "HRS" ;
    noria:applicationType <kos/application/type/internal-business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Human Resources" ;
    noria:applicationFunctionalSubDomain "Employee Management" .

noria:Application003 a noria:Application ;
    rdfs:label "Network Monitoring System"@en, "Système de Surveillance Réseau"@fr ;
    rdfs:comment "System for monitoring network devices and services, collecting metrics and generating alerts."@en ;
    noria:applicationModelIdentifier "NMS-APP" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations" ;
    noria:applicationFunctionalSubDomain "Network Management" .

noria:Application004 a noria:Application ;
    rdfs:label "Data Backup Service"@en, "Service de Sauvegarde de Données"@fr ;
