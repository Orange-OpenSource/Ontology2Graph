noria:TroubleTicket004 a noria:TroubleTicket ;
    rdfs:label "Daily DB Backup Failure"@en, "Échec de la Sauvegarde Quotidienne de la BD"@fr ;
    rdfs:comment "Critical incident: Daily database backup job failed, risking data loss and impacting disaster recovery capabilities."@en ;
