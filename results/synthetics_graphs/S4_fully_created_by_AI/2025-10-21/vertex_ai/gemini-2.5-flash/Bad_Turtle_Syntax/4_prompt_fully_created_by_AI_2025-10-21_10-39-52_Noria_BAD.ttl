    noria:applicationModelIdentifier "DBS-APP" ;
    noria:applicationNumericalIdentifier 1004 ;
    noria:applicationShortIdentifier "DBS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Data Management" ;
    noria:applicationFunctionalSubDomain "Backup and Recovery" .

# --- Application Modules ---
noria:ApplicationModule001 a noria:ApplicationModule ;
    rdfs:label "CWP Production Module"@en, "Module de Production CWP"@fr ;
    rdfs:comment "Production instance of the Corporate Web Portal, serving live customer traffic."@en ;
    noria:applicationModuleOf noria:Application001 ;
    noria:applicationModuleName "CWP_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam org:OrganizationalUnit002 ;
    noria:applicationModuleAdministrationLeader foaf:Agent005 ;
    noria:applicationModuleSupportTeam foaf:Agent002 ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> .

noria:ApplicationModule002 a noria:ApplicationModule ;
    rdfs:label "CWP Development Module"@en, "Module de Développement CWP"@fr ;
