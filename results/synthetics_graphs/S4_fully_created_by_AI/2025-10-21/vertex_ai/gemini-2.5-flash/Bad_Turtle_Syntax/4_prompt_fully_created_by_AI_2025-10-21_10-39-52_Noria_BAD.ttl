# --- Procedural Elements ---
noria:OperationPlan001 a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en, "Procédure de Mise à Jour Firmware Routeur"@fr ;
    rdfs:comment "Standard operating procedure for upgrading router firmware, including pre-checks, firmware installation, and post-checks."@en ;
    skos:example "Steps: 1. Backup configuration. 2. Download firmware. 3. Install firmware. 4. Verify connectivity. 5. Verify routing protocols convergence."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition001 ;
    noria:operationPlanPostCondition noria:ActionPostCondition001 .

noria:ActionPreCondition001 a noria:ActionPreCondition ;
    rdfs:label "Router Upgrade Pre-conditions"@en ;
    rdfs:comment "Conditions that must be met before starting a router firmware upgrade to ensure a smooth process."@en ;
    skos:example "Router configuration backed up, maintenance window approved, secondary link active and stable, no critical alarms."@en .

noria:ActionPostCondition001 a noria:ActionPostCondition ;
    rdfs:label "Router Upgrade Post-conditions"@en ;
    rdfs:comment "Expected outcomes after a router firmware upgrade to confirm successful completion."@en ;
    skos:example "Router operational, all interfaces up, routing protocols converged, no packet loss, new firmware version verified."@en .

noria:OperationPlan002 a noria:OperationPlan ;
    rdfs:label "Web Server CPU Spike Mitigation"@en, "Atténuation Pic CPU Serveur Web"@fr ;
    rdfs:comment "Procedure to follow when a web server experiences high CPU usage, aiming to restore normal operation."@en ;
    skos:example "Steps: 1. Check running processes. 2. Analyze access logs. 3. Restart web service. 4. Scale up resources if necessary."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition002 ;
    noria:operationPlanPostCondition noria:ActionPostCondition002 .

noria:ActionPreCondition002 a noria:ActionPreCondition ;
    rdfs:label "CPU Spike Pre-conditions"@en ;
    rdfs:comment "Conditions indicating a web server CPU spike, triggering the mitigation procedure."@en ;
    skos:example "CPU usage > 80% for 5 minutes, application response time > 2s, active user complaints."@en .

noria:ActionPostCondition002 a noria:ActionPostCondition ;
    rdfs:label "CPU Spike Post-conditions"@en ;
    rdfs:comment "Expected outcomes after mitigating a web server CPU spike, confirming resolution."@en ;
    skos:example "CPU usage < 50%, application response time < 1s, no new alerts, user complaints resolved."@en .

noria:OperationPlan003 a noria:OperationPlan ;
    rdfs:label "Network Link Repair Procedure"@en, "Procédure de Réparation Liaison Réseau"@fr ;
    rdfs:comment "Procedure for diagnosing and repairing physical network link issues, such as fiber cuts or faulty transceivers."@en ;
    skos:example "Steps: 1. Verify cable integrity. 2. Test optical power. 3. Replace SFP/cable. 4. Verify link status and connectivity."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition003 ;
    noria:operationPlanPostCondition noria:ActionPostCondition003 .

noria:ActionPreCondition003 a noria:ActionPreCondition ;
    rdfs:label "Link Repair Pre-conditions"@en ;
    rdfs:comment "Conditions indicating a physical link issue, prompting the repair procedure."@en ;
    skos:example "Interface operational status down, no administrative shutdown, optical power out of range, CRC errors detected."@en .

noria:ActionPostCondition003 a noria:ActionPostCondition ;
    rdfs:label "Link Repair Post-conditions"@en ;
    rdfs:comment "Expected outcomes after repairing a network link, confirming successful restoration."@en ;
    skos:example "Interface operational status up, optical power within range, no errors, full connectivity restored."@en .

# --- Procedure Execution Containers and Actions ---
pep:ProcedureExecutionContainer001 a pep:ProcedureExecutionContainer ;
