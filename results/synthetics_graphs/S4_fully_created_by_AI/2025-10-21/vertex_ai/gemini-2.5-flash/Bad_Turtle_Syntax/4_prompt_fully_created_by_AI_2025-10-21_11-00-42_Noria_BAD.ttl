    noria:logOriginatingManagedObject noria:Resource/WebServerVM01 ;
    noria:logOriginatingManagementSystem noria:Application/NetworkMonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
