    noria:logOriginatingManagementSystem noria:Application/ECommercePlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "Failed to connect to database 'ecom_prod' on db-ecom-01.corp.example.com: Connection refused."@en .

noria:EventRecord/RouterConfigChange
    a noria:EventRecord ;
    rdfs:label "Core Router Configuration Change"@en ;
    rdfs:comment "Log entry indicating a configuration change on the Core Router Paris by an administrator."@en ;
    noria:loggingTime "2024-04-19T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource/CoreRouterParis ;
    noria:logOriginatingAgent foaf:Agent/JohnDoe ; # Assuming John Doe has network admin privileges for this example
    noria:logOriginatingManagementSystem noria:Application/NetworkMonitoringSystem ; # NMS might log config changes
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logText "Configuration changed by user 'jdoe' from 192.168.1.100. Added static route."@en .

noria:EventRecord/SecurityAlertSQLi
    a noria:EventRecord ;
    rdfs:label "Security Alert: SQL Injection Attempt"@en ;
    rdfs:comment "Alert from WAF indicating a potential SQL Injection attempt on the E-commerce platform."@en ;
    noria:loggingTime "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ApplicationModule/ECommerceFrontend ;
    noria:logOriginatingManagementSystem noria:Application/NetworkMonitoringSystem ; # Assuming NMS integrates WAF alerts
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "Detected SQL Injection pattern in request to /api/products?category=1' OR '1'='1."@en .

