# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns/> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concept Schemes and Concepts
# =============================================================================

# Application Types
<kos/application/type>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Application Types"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of applications within the NORIA ontology."@en .

<kos/application/type/infrastructure>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Applications that provide core infrastructure services, e.g., DNS, DHCP, monitoring systems."@en .

<kos/application/type/business>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "Applications directly supporting business processes, e.g., CRM, ERP, E-commerce."@en .

<kos/application/type/monitoring>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "Applications used for monitoring IT systems and services."@en .

# Application Business Importance
<kos/application/business-importance>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Application Business Importance"@en ;
    rdfs:comment "A controlled vocabulary for assessing the business importance of applications."@en .

<kos/application/business-importance/high>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for core business operations."@en .

<kos/application/business-importance/medium>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application supports important but not immediately critical business functions."@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Application Module Status"@en ;
    rdfs:comment "A controlled vocabulary for the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

<https://w3id.org/noria/kos/application/status/Development>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Development"@en ;
    rdfs:comment "The application module is under active development or testing."@en .

<https://w3id.org/noria/kos/application/status/Decommissioned>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "The application module has been retired and is no longer in use."@en .

# Service Types
<kos/service/type>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Service Types"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of services."@en .

<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed or perceived by external customers."@en .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations, not directly exposed to customers."@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Severity"@en ;
    rdfs:comment "A controlled vocabulary for the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Service is completely down or severely impacted, affecting a large number of users or critical business functions."@en .

<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant service degradation or outage affecting a moderate number of users or important business functions."@en .

<kos/TroubleTicket/severity/Minor>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor"@en ;
    rdfs:comment "Minor service degradation or isolated issue affecting a small number of users or non-critical functions."@en .

# Trouble Ticket Type
<kos/TroubleTicket/type>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Type"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of trouble tickets."@en .

<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Indicates a system or service failure."@en .

<kos/TroubleTicket/type/Assistance>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Request for help or support."@en .

# Trouble Ticket Category
<kos/TroubleTicket/category>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Category"@en ;
    rdfs:comment "A controlled vocabulary for categorizing trouble tickets based on technical impact."@en .

<kos/TroubleTicket/category/TotalBreakdown>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Complete failure of a system or service."@en .

<kos/TroubleTicket/category/IsolatedCustomerSite>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Isolated Customer Site"@en ;
    rdfs:comment "A specific customer site is experiencing connectivity or service issues."@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Priority"@en ;
    rdfs:comment "A controlled vocabulary for the priority of trouble tickets."@en .

<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, requiring immediate attention."@en .

<kos/TroubleTicket/priority/P2>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, requiring prompt attention."@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Origin"@en ;
    rdfs:comment "A controlled vocabulary for the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer"@en ;
    rdfs:comment "Ticket initiated by a customer."@en .

<kos/TroubleTicket/origin/Supervision>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision"@en ;
    rdfs:comment "Ticket initiated by a monitoring or supervision system."@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Urgency"@en ;
    rdfs:comment "A controlled vocabulary for the urgency of trouble tickets."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action to prevent further impact."@en .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Problem Responsibility"@en ;
    rdfs:comment "A controlled vocabulary for assigning responsibility for a problem."@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility lies with the team managing the core network infrastructure."@en .

# Trouble Ticket Comment Type
<kos/TroubleTicket/commentType>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Comment Type"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of comments on trouble tickets."@en .

<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team use only."@en .

# Trouble Ticket Operation Type
<kos/TroubleTicket/operationType>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Operation Type"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of operations performed on trouble tickets."@en .

<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Operation related to diagnosing the root cause of an issue."@en .

# Change Request Category
<kos/ChangeRequest/category>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Category"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of change requests."@en .

<kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change initiated and executed by internal teams."@en .

# Change Request Type
<kos/ChangeRequest/type>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Type"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of change requests based on impact and risk."@en .

<kos/ChangeRequest/type/Standard>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Pre-approved change with low risk and impact."@en .

# Change Request Cause
<kos/ChangeRequest/cause>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Cause"@en ;
    rdfs:comment "A controlled vocabulary for classifying the causes of change requests."@en .

<kos/ChangeRequest/cause/Configuration>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change related to modifying system configurations."@en .

# Change Request Status
<kos/ChangeRequest/status>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Status"@en ;
    rdfs:comment "A controlled vocabulary for the status of change requests."@en .

<kos/ChangeRequest/status/Planned>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Planned"@en ;
    rdfs:comment "Change request is approved and scheduled."@en .

<kos/ChangeRequest/status/InProgress>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Change request is currently being implemented."@en .

<kos/ChangeRequest/status/Completed>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Completed"@en ;
    rdfs:comment "Change request implementation is finished."@en .

# Change Request Specification
<kos/ChangeRequest/specification>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Specification"@en ;
    rdfs:comment "A controlled vocabulary for specifying types of change request operations."@en .

<kos/ChangeRequest/specification/RoutineMaintenance>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Routine Maintenance"@en ;
    rdfs:comment "Scheduled maintenance activities."@en .

# Resource Operational State
<kos/Resource/OperationalState>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Operational State"@en ;
    rdfs:comment "A controlled vocabulary for the operational state of resources."@en .

<kos/Resource/OperationalState/up>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is fully operational."@en .

<kos/Resource/OperationalState/down>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

<kos/Resource/OperationalState/degraded>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Degraded"@en ;
    rdfs:comment "Resource is operational but with reduced performance or functionality."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Administrative State"@en ;
    rdfs:comment "A controlled vocabulary for the administrative state of resources."@en .

<kos/Resource/AdministrativeState/up>
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative Up"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/down>
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative Down"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

# Resource Type
<kos/Resource/type>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Type"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of IT resources."@en .

<kos/Resource/type/Server>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A physical or virtual server."@en .

<kos/Resource/type/Router>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router device."@en .

<kos/Resource/type/Switch>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network switch device."@en .

<kos/Resource/type/LoadBalancer>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Load Balancer"@en ;
    rdfs:comment "A device or software distributing network traffic."@en .

<kos/Resource/type/DatabaseServer>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Database Server"@en ;
    rdfs:comment "A server hosting database services."@en .

<kos/Resource/type/VirtualMachine>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Virtual Machine"@en ;
    rdfs:comment "A virtualized computing instance."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Lifecycle State"@en ;
    rdfs:comment "A controlled vocabulary for the lifecycle state of resources."@en .

<kos/Resource/LifecycleState/InUse>
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Use"@en ;
    rdfs:comment "Resource is actively being used in production."@en .

<kos/Resource/LifecycleState/Standby>
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Standby"@en ;
    rdfs:comment "Resource is available as a backup or for failover."@en .

# Notification Severity / Perceived Severity
<Notification/Severity/PerceivedSeverity>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Notification Perceived Severity"@en ;
    rdfs:comment "A controlled vocabulary for the perceived severity of notifications/alarms."@en .

<Notification/Severity/PerceivedSeverity/Critical>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Indicates a critical condition requiring immediate attention."@en .

<Notification/Severity/PerceivedSeverity/Major>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Indicates a major condition requiring prompt attention."@en .

<Notification/Severity/PerceivedSeverity/Minor>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Minor"@en ;
    rdfs:comment "Indicates a minor condition that may require attention."@en .

<Notification/Severity/PerceivedSeverity/Warning>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Indicates a potential issue that should be monitored."@en .

# Agent Contact Method
<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    dcterms:title "NORIA Agent Contact Method"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

<kos/org/agent-contact-method/TicketingSystem>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Ticketing System"@en ;
    rdfs:comment "Preferred contact method is via the official ticketing system."@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent/DevOpsTeam
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DevOps Team"@en ;
    rdfs:comment "Team responsible for the development, deployment, and operation of applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "For critical issues, open a P1 ticket and call the on-call engineer."@en .

foaf:Agent/DBAdminTeam
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all database systems and ensuring their performance and availability."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via dedicated hotline for any database-related incidents."@en .

foaf:Agent/NetworkOps
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "Team responsible for monitoring and managing the corporate network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Operations"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email noc@example.com for non-critical network issues."@en .

foaf:Agent/SecurityTeam
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team dedicated to monitoring, detecting, and responding to cybersecurity threats and incidents."@en ;
    noria:agentWorkingHours "24/7 Monitoring"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All security incidents must be reported via the dedicated security ticketing system."@en .

foaf:Agent/JohnDoe
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the DevOps Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:member foaf:Agent/DevOpsTeam .

foaf:Agent/JaneSmith
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead of the Database Administration Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:member foaf:Agent/DBAdminTeam .

noria:CorporateUserIdentifier/jdoe
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
