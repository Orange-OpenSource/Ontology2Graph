    noria:logOriginatingManagementSystem noria:Application/NetworkMonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "Interface GigabitEthernet0/0/1 on cr-par-01.corp.example.com changed state to down."@en .

noria:EventRecord/DBConnectionError
    a noria:EventRecord ;
