# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan/DBFailoverProcedure
    a noria:OperationPlan ;
    rdfs:label "Database Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for initiating a database failover to the secondary replica."@en ;
    skos:example "Steps include: verify replica health, initiate failover, update application connection strings, verify application functionality."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition/DBReplicaHealthy ;
    noria:operationPlanPostCondition noria:ActionPostCondition/DBFailoverSuccessful .

noria:ActionPreCondition/DBReplicaHealthy
    a noria:ActionPreCondition ;
    rdfs:label "Database Replica Healthy Pre-condition"@en ;
    rdfs:comment "Pre-condition: The secondary database replica must be in a healthy and synchronized state before initiating failover."@en .

noria:ActionPostCondition/DBFailoverSuccessful
    a noria:ActionPostCondition ;
    rdfs:label "Database Failover Successful Post-condition"@en ;
    rdfs:comment "Post-condition: The database failover must be successful, with the secondary replica becoming primary and applications connecting to it."@en ;
    skos:example "Application logs show successful database connections; primary database role transferred; no data loss observed."@en .

noria:OperationPlan/RouterFirmwareUpgrade
    a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Procedure for upgrading the firmware on network routers, including pre-checks and post-checks."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition/RouterBackupComplete ;
    noria:operationPlanPostCondition noria:ActionPostCondition/RouterUpgradeSuccessful .

noria:ActionPreCondition/RouterBackupComplete
    a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Complete Pre-condition"@en ;
    rdfs:comment "Pre-condition: A full backup of the router configuration must be completed and verified before starting the firmware upgrade."@en .

noria:ActionPostCondition/RouterUpgradeSuccessful
    a noria:ActionPostCondition ;
    rdfs:label "Router Firmware Upgrade Successful Post-condition"@en ;
    rdfs:comment "Post-condition: Router firmware upgrade completed successfully, device is operational, and network connectivity is restored."@en ;
    skos:example "Router uptime is normal; all interfaces are up; routing protocols are converged; ping tests to critical destinations are successful."@en .

