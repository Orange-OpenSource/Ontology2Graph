# =============================================================================
# Procedural Elements
# =============================================================================

noria:OperationPlan_DNSFailover a noria:OperationPlan ;
    rdfs:label "DNS Server Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over to a secondary DNS server in case of primary server failure."@en ;
    skos:example "Steps include verifying primary server status, activating secondary, updating DNS records, and verifying resolution."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DNSFailover_Pre ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSFailover_Post .

noria:OperationPlan_RouterFirmwareUpgrade a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading firmware on core network routers, including pre-checks, upgrade steps, and post-checks."@en ;
    skos:example "Includes backup configuration, download image, reload, verify version."@en .

noria:ActionPreCondition_DNSFailover_Pre a noria:ActionPreCondition ;
    rdfs:label "DNS Failover Pre-Condition"@en ;
    rdfs:comment "Pre-conditions for initiating DNS failover: Primary DNS server is unreachable, secondary is operational."@en .

noria:ActionPostCondition_DNSFailover_Post a noria:ActionPostCondition ;
    rdfs:label "DNS Failover Post-Condition"@en ;
    rdfs:comment "Post-conditions after DNS failover: DNS resolution is functional, secondary server is active, primary is isolated."@en .

noria:AnomalyPattern_HighDNSErrorRate a noria:AnomalyPattern ;
    rdfs:label "High DNS Error Rate Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential DNS service issue, characterized by a sudden increase in DNS query failures or timeouts."@en ;
    skos:example "Threshold breach on 'DNS_Error_Count' metric for more than 5 minutes."@en .

