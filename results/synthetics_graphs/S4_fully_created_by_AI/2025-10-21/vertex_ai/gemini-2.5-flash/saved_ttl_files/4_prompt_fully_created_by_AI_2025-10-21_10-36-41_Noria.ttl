noria:EventRecord_DNS01_Log1 a noria:EventRecord ;
    rdfs:label "DNS01 Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on DNS01 went down."@en ;
    noria:loggingTime "2024-03-15T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "Interface Eth0 on dns01.corp.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_RouterCore01_Alarm1 a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Alarm"@en ;
    rdfs:comment "Alarm generated by monitoring system for a critical interface on Core Router 01."@en ;
    noria:loggingTime "2024-03-15T10:06:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Interface GigabitEthernet 0/0/1 on router-core01 is DOWN."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_DNSFailover .

noria:EventRecord_MonitoringSystem_Alert1 a noria:EventRecord ;
    rdfs:label "Customer Portal Slow Response Alert"@en ;
    rdfs:comment "Alert indicating high latency for the Customer Portal application."@en ;
    noria:loggingTime "2024-03-15T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Application_CustomerPortal ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "WARNING: Customer Portal response time > 500ms for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_RouterCore01_ConfigChange a noria:EventRecord ;
    rdfs:label "Router Core 01 Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Router Core 01."@en ;
    noria:loggingTime "2024-03-14T23:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_JaneSmith ;
    noria:logText "Configuration changed by Jane Smith: added static route for new subnet."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

