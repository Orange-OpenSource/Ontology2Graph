# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, phone for critical outages."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always use emergency hotline for network incidents."@en .

foaf:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

foaf:Agent_JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the DNS Admin Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" .

foaf:Agent_JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Network Operations Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+33987654321" .

org:OrgUnit_ITOperations a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Main department for IT infrastructure and application operations."@en ;
    org:hasMember foaf:Agent_JohnDoe, foaf:Agent_JaneSmith .

org:OrgUnit_NetworkServices a org:OrganizationalUnit ;
    rdfs:label "Network Services Division"@en ;
    rdfs:comment "Specialized division within IT Operations for network management."@en ;
    org:unitOf org:OrgUnit_ITOperations ;
    org:hasMember foaf:Agent_NetworkOpsTeam .

org:OrgUnit_ApplicationDevelopment a org:OrganizationalUnit ;
    rdfs:label "Application Development Department"@en ;
    rdfs:comment "Department responsible for developing and maintaining business applications."@en .

org:Organization_AcmeCorp a org:Organization ;
    rdfs:label "Acme Corporation"@en ;
    rdfs:comment "The main organization."@en ;
    org:hasUnit org:OrgUnit_ITOperations, org:OrgUnit_ApplicationDevelopment .

noria:CorporateUserIdentifier_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Unique corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    observable:accountIdentifier "jdoe_corp_id_12345" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing and virtualization."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel_CiscoCatalyst9k a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300 Series Switch"@en ;
    rdfs:comment "Enterprise-grade network switch for access layer deployments."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480 Router"@en ;
    rdfs:comment "High-performance edge router for service provider and enterprise applications."@en ;
