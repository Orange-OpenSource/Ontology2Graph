ex:ServiceType_ResourceFacing
    a skos:Concept ;
    skos:inScheme ex:ServiceTypeScheme ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "Service supporting other services, not directly customer-facing."@en .

