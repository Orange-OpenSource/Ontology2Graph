ex:AnomalyPattern_HighLatency
    a noria:AnomalyPattern ;
    rdfs:label "High Latency Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating high network latency, potentially leading to service degradation."@en .

ex:AnomalyPattern_DBDeadlock
    a noria:AnomalyPattern ;
    rdfs:label "Database Deadlock Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating recurring database deadlocks."@en .

ex:OperationPlan_RouterRestart
    a noria:OperationPlan ;
    rdfs:label "Router Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network router."@en .

ex:OperationPlan_DBBackup
    a noria:OperationPlan ;
    rdfs:label "Database Backup Procedure"@en ;
    rdfs:comment "Procedure for performing a full database backup."@en .

ex:OperationPlan_DBOptimization
    a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for optimizing slow database queries."@en .

ex:ActionPreCondition_RouterPingable
    a noria:ActionPreCondition ;
    rdfs:label "Router Pingable Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Router must be pingable before proceeding."@en .

ex:ActionPreCondition_HighCPU
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Usage Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Database server shows sustained high CPU usage."@en .

ex:ActionPostCondition_ServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: Service must be restored and verified."@en .

ex:ActionPostCondition_CPUNormalized
    a noria:ActionPostCondition ;
    rdfs:label "CPU Usage Normalized Post-Condition"@en ;
    rdfs:comment "Post-condition: CPU usage on database server returns to normal levels."@en .

ex:OperationPlan_RouterRestart
    noria:operationPlanPreCondition ex:ActionPreCondition_RouterPingable ;
    noria:operationPlanPostCondition ex:ActionPostCondition_ServiceRestored .

ex:OperationPlan_DBOptimization
    noria:operationPlanPreCondition ex:ActionPreCondition_HighCPU ;
    noria:operationPlanPostCondition ex:ActionPostCondition_CPUNormalized .

ex:ChangeAction_DBPatchApply
    a pep:ChangeAction ;
    rdfs:label "Apply DB Patch Action"@en ;
    rdfs:comment "Action to apply the database security patch."@en ;
    noria:actionCorrelatedOperationPlan ex:OperationPlan_DBBackup .

