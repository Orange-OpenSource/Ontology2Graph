    noria:logText "SYS-5-CONFIG_I: Configured from console by asmith (192.168.1.10)"^^xsd:string ;
    noria:logOriginatingManagedObject ex:Resource_Router1 ;
    noria:logOriginatingAgent ex:Person_Alice ;
    noria:logOriginatingManagementSystem ex:Application_MonitoringSystem ;
    noria:alarmSeverity ex:PerceivedSeverity_Informational .

