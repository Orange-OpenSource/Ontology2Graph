# Core Organizational Entities
# -----------------------------------------------------------------------------

ex:Org_ITDepartment
    a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department."@en ;
    noria:agentWorkingHours "08:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via internal ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod ex:ContactMethod_Email .

ex:Org_CustomerService
    a org:Organization ;
    rdfs:label "Customer Service Department"@en ;
    rdfs:comment "Department handling customer inquiries."@en ;
    noria:agentWorkingHours "07:00-20:00 Mon-Sun"^^xsd:string ;
    noria:agentInstructions "Use dedicated customer support portal or phone line."^^xsd:string ;
    noria:agentPreferredContactMethod ex:ContactMethod_Phone .

ex:Org_Cisco
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

ex:Org_Dell
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server and computing equipment."@en .

ex:Org_HP
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of enterprise hardware."@en .

ex:Org_ISP_A
    a org:Organization ;
    rdfs:label "Internet Service Provider A"@en ;
    rdfs:comment "External Internet Service Provider."@en .

ex:OrgUnit_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure operations."@en ;
    org:unitOf ex:Org_ITDepartment ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "For critical issues, use emergency hotline. For routine, use ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod ex:ContactMethod_Phone .

ex:OrgUnit_AppDev
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining applications."@en ;
    org:unitOf ex:Org_ITDepartment ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Email for non-urgent requests, chat for urgent development queries."^^xsd:string ;
    noria:agentPreferredContactMethod ex:ContactMethod_Chat .

ex:OrgUnit_Helpdesk
    a org:OrganizationalUnit ;
    rdfs:label "IT Helpdesk"@en ;
    rdfs:comment "First level support team."@en ;
    org:unitOf ex:Org_ITDepartment ;
    noria:agentWorkingHours "08:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Initial point of contact for all IT issues."^^xsd:string ;
    noria:agentPreferredContactMethod ex:ContactMethod_Phone .

ex:OrgUnit_OnCallTeam
    a org:OrganizationalUnit ;
    rdfs:label "On-Call Team"@en ;
    rdfs:comment "Team providing 24/7 emergency support."@en ;
    org:unitOf ex:Org_ITDepartment ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentInstructions "Only for critical incidents outside business hours."^^xsd:string ;
    noria:agentPreferredContactMethod ex:ContactMethod_Phone .

ex:Person_Alice
    a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer Alice Smith."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Reach out via email first."^^xsd:string ;
    noria:agentPreferredContactMethod ex:ContactMethod_Email .

ex:Person_Bob
    a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Developer Bob Johnson."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Available on internal chat during working hours."^^xsd:string ;
    noria:agentPreferredContactMethod ex:ContactMethod_Chat .

ex:Person_Carol
    a foaf:Agent ;
    rdfs:label "Carol White"@en ;
    rdfs:comment "Customer Service Representative."@en ;
    foaf:mbox <mailto:carol.white@example.com> ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Direct customer calls to this agent."^^xsd:string ;
    noria:agentPreferredContactMethod ex:ContactMethod_Phone .

ex:CUid_Alice
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "CU-ASMITH-001"^^xsd:string ;
    foaf:holdsAccount ex:Person_Alice .

ex:CUid_Bob
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "CU-BJOHNSON-002"^^xsd:string ;
    foaf:holdsAccount ex:Person_Bob .

ex:CUid_Carol
    a noria:CorporateUserIdentifier ;
    rdfs:label "Carol's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Carol White."@en ;
    foaf:accountName "cwhite"^^xsd:string ;
    observable:accountLogin "cwhite"^^xsd:string ;
    observable:accountIdentifier "CU-CWHITE-003"^^xsd:string ;
    foaf:holdsAccount ex:Person_Carol .

# Location Entities
# -----------------------------------------------------------------------------

ex:Site_MainDC
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility."@en ;
    noria:siteId "DC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

ex:Site_BranchOffice
    a bot:Site ;
    rdfs:label "Branch Office A"@en ;
    rdfs:comment "Remote branch office location."@en ;
    noria:siteId "BO-A"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Business Road"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Gotham"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Business Road"^^xsd:string .

ex:Room_ServerRoom1
