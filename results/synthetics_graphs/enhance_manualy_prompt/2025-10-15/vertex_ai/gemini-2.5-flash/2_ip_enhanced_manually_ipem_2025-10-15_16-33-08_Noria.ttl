    rdfs:label "Platinum SLA"@en ;
    rdfs:comment "Highest Service Level Agreement."@en .

ex:SLA_Gold
    a skos:Concept ;
    skos:inScheme ex:ApplicationSLALevelScheme ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "High Service Level Agreement."@en .

ex:ApplicationStatusScheme
    a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
