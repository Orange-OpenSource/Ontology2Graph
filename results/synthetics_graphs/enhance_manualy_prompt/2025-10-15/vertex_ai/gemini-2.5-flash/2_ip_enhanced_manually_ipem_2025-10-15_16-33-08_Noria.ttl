# Dynamic Elements (Events/Tickets)
# -----------------------------------------------------------------------------

ex:EventRecord_RouterDown
    a noria:EventRecord ;
    rdfs:label "Router Down Alert"@en ;
    rdfs:comment "Alert indicating Core Router 1 went down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject ex:Resource_Router1 ;
    noria:logOriginatingManagementSystem ex:Application_MonitoringSystem ;
    noria:alarmSeverity ex:PerceivedSeverity_Critical ;
    noria:alarmMonitoredAttribute ex:NetworkInterface_Router1_GE001 .

ex:EventRecord_ConfigChange
    a noria:EventRecord ;
    rdfs:label "Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router 1."@en ;
