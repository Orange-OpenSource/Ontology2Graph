ex:AppStatus_Production
    a skos:Concept ;
    skos:inScheme ex:ApplicationStatusScheme ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application is currently in production."@en .

ex:AppStatus_Development
    a skos:Concept ;
    skos:inScheme ex:ApplicationStatusScheme ;
    rdfs:label "In Development"@en ;
    rdfs:comment "Application is under development."@en .

ex:ServiceTypeScheme
