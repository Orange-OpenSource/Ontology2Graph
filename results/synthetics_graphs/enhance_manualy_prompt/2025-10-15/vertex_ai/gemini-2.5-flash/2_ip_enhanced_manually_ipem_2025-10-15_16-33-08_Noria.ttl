    noria:documentHRef "https://ticketing.example.com/TT-2024-04-20-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity ex:TTSeverity_Critical ;
    noria:troubleTicketType ex:TTType_Failure ;
    noria:troubleTicketCriticity ex:TTCriticity_InterruptedService ;
    noria:troubleTicketPriority ex:TTPriority_P1 ;
    noria:troubleTicketOrigin ex:TTOrigin_Supervision ;
    noria:troubleTicketTrigger ex:EventRecord_RouterDown ;
    noria:troubleTicketUrgency ex:TTUrgency_Immediate ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory ex:TTTCategory_TotalBreakdown ;
    noria:problemCategory ex:TTTCategory_TotalBreakdown ;
    noria:troubleTicketCause "Fiber cut detected on uplink."^^xsd:string ;
    noria:problemResponsibility ex:TTResponsibility_ManagedNetwork ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent ex:TTStatus_InProgress ;
    noria:troubleTicketRelatedParty ex:Person_Alice ;
    noria:troubleTicketRelatedResource ex:Resource_Router1 ;
    noria:troubleTicketRelatedService ex:Service_CustomerAccess ;
    noria:troubleTicketImpacts ex:Application_WebAppPortal ;
    noria:troubleTicketImpacts ex:NetworkLink_DC_ISP_Uplink ;
    noria:documentStatusHistory ex:EventRecord_RouterDown ;
