# KOS Concept Schemes and Concepts
# -----------------------------------------------------------------------------

ex:AgentContactMethodScheme
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    dcterms:description "A scheme for classifying preferred contact methods for agents."@en .

ex:ContactMethod_Email
    a skos:Concept ;
    skos:inScheme ex:AgentContactMethodScheme ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method: Email."@en .

ex:ContactMethod_Phone
    a skos:Concept ;
    skos:inScheme ex:AgentContactMethodScheme ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method: Phone."@en .

ex:ContactMethod_Chat
    a skos:Concept ;
    skos:inScheme ex:AgentContactMethodScheme ;
    rdfs:label "Chat"@en ;
    rdfs:comment "Preferred contact method: Chat."@en .

ex:ApplicationTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of applications."@en .

ex:AppType_Web
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Web Application"@en ;
    rdfs:comment "A web-based application."@en .

ex:AppType_Database
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Database System"@en ;
    rdfs:comment "A database management system."@en .

ex:AppType_Monitoring
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Monitoring Tool"@en ;
    rdfs:comment "An application used for system monitoring."@en .

ex:ApplicationBusinessImportanceScheme
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    dcterms:description "A scheme for classifying the business importance of applications."@en .

ex:BizImportance_Critical
    a skos:Concept ;
    skos:inScheme ex:ApplicationBusinessImportanceScheme ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for business operations."@en .

ex:BizImportance_High
    a skos:Concept ;
    skos:inScheme ex:ApplicationBusinessImportanceScheme ;
    rdfs:label "High"@en ;
    rdfs:comment "Application has high business importance."@en .

ex:BizImportance_Medium
    a skos:Concept ;
    skos:inScheme ex:ApplicationBusinessImportanceScheme ;
    rdfs:label "Medium"@en ;
    rdfs:comment "Application has medium business importance."@en .

ex:ApplicationSLALevelScheme
    a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    dcterms:description "A scheme for classifying SLA levels for applications."@en .

ex:SLA_Platinum
    a skos:Concept ;
