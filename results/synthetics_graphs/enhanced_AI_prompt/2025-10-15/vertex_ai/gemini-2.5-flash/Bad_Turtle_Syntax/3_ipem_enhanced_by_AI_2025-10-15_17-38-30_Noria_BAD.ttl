    noria:changeRequestPlannedEndTime "2024-03-20T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-03-20T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-03-20T03:45:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory noria-kos:ChangeRequest/category/InternalIntervention ;
