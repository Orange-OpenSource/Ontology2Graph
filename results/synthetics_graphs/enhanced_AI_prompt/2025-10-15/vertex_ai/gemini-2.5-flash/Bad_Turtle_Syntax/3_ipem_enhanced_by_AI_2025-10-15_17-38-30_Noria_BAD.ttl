# noria:DynamicElement (instantiated via noria:TroubleTicket, noria:TroubleTicketNote, noria:ChangeRequest, noria:DocumentAttachment, noria:EventRecord)
noria-inst:TT20240315-001
    a noria:TroubleTicket, noria:DynamicElement ;
    rdfs:label "TT20240315-001: Billing App Outage" ;
    rdfs:comment "Trouble ticket for a critical outage of the Billing Application." ;
    noria:documentExternalId "EXT-TT-98765"^^xsd:string ;
    noria:documentHRef "https://itsm.example.com/tt/TT20240315-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity noria-kos:TroubleTicket/severity/Major ;
    noria:troubleTicketType noria-kos:TroubleTicket/type/Failure ;
    noria:troubleTicketCriticity noria-kos:TroubleTicket/category/InterruptedService ;
    noria:troubleTicketPriority noria-kos:TroubleTicket/priority/P1 ;
    noria:troubleTicketOrigin noria-kos:TroubleTicket/origin/Supervision ;
    noria:troubleTicketUrgency noria-kos:TroubleTicket/urgency/Immediate ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory noria-kos:TroubleTicket/trouble-category/TotalBreakdown ;
    noria:problemCategory noria-kos:TroubleTicket/trouble-category/TotalBreakdown ;
    noria:troubleTicketCause "Database connection pool exhaustion."^^xsd:string ;
    noria:problemResponsibility noria-kos:TroubleTicket/problemResponsibility/ManagedBackbone ;
    noria:troubleTicketDetectionDateTime "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-15T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-03-15T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent noria-kos:ChangeRequest/status/Implemented ;
    noria:troubleTicketRelatedParty noria-inst:NetworkOperationsTeam ;
    noria:troubleTicketPartyIntervention noria-inst:NetworkOperationsTeam ;
    noria:troubleTicketRelatedService noria-inst:BillingAppModuleProd ;
    noria:troubleTicketRelatedResource noria-inst:Server001 ;
    noria:troubleTicketImpacts noria-inst:BillingAppModuleProd, noria-inst:Server001 ;
    noria:troubleTicketCharacteristic noria-inst:Router001_CPU_Usage ;
    noria:troubleTicketFreezeItem noria-inst:EventRecord_TT_Freeze_001 ;
    noria:troubleTicketTrigger noria-inst:EventRecord_App_Crash ;
    noria:documentStatusHistory noria-inst:EventRecord_TT_StatusChange_001 ;
    noria:elementManagedBy noria-inst:IncidentManager ;
.

noria-inst:TT20240315-001-Note01
    a noria:TroubleTicketNote, noria:DynamicElement ;
    rdfs:label "TT20240315-001 Note 01: Initial Diagnosis" ;
    rdfs:comment "Initial diagnosis of the billing application outage, suspecting database issues." ;
    noria:troubleTicketNoteCommentType noria-kos:TroubleTicket/commentType/Internal ;
    noria:troubleTicketNoteOperationType noria-kos:TroubleTicket/operationType/Diagnosis ;
    noria:troubleTicketNoteCorrelatedExecution noria-inst:ProcedureExecContainer_DB_Check ;
    noria:elementManagedBy noria-inst:BobJohnson ;
.

