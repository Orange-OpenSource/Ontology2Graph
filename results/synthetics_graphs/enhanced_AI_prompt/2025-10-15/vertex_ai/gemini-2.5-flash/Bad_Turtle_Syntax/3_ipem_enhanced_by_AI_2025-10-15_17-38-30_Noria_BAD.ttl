# noria:StructuralElement (instantiated via noria:Resource, noria:NetworkInterface, noria:NetworkLink)
noria-inst:Router001
    a noria:Resource, noria:StructuralElement ;
    rdfs:label "Core Router 001" ;
    rdfs:comment "A critical network router in the core infrastructure." ;
    noria:elementDistinguishedName "router-core-001.example.com"^^xsd:string ;
    noria:structuralElementDistinguishedName "router-core-001.example.com"^^xsd:string ;
    noria:resourceHostName "router-core-001"^^xsd:string ;
    noria:resourceLogisticId "LOG-RTR-001-XYZ"^^xsd:string ;
    noria:resourceSerialNumber "SN-RTR-001-ABC"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceType noria-kos:Resource/type/Router ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/InProduction ;
    noria:resourceManagementIPAddress "192.168.1.1"^^xsd:string ;
    noria:elementManagedBy noria-inst:NetworkOperationsTeam ;
    noria:resourceProductModel noria-inst:CiscoASR9K ;
    noria:locatedAtLocus noria-inst:LocusA1 ;
    noria:virtualServerStatus noria-kos:Resource/OperationalState/Up ;
.

noria-inst:Server001
    a noria:Resource, noria:StructuralElement ;
    rdfs:label "Application Server 001" ;
    rdfs:comment "A server hosting critical business applications." ;
    noria:elementDistinguishedName "app-server-001.example.com"^^xsd:string ;
    noria:structuralElementDistinguishedName "app-server-001.example.com"^^xsd:string ;
    noria:resourceHostName "app-server-001"^^xsd:string ;
    noria:resourceLogisticId "LOG-SRV-001-PQR"^^xsd:string ;
    noria:resourceSerialNumber "SN-SRV-001-DEF"^^xsd:string ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceType noria-kos:Resource/type/Server ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/InProduction ;
    noria:resourceManagementIPAddress "10.0.0.10"^^xsd:string ;
    noria:elementManagedBy noria-inst:ServerAdminTeam ;
    noria:resourceProductModel noria-inst:HPProLiantDL380 ;
    noria:locatedAtLocus noria-inst:LocusB2 ;
    noria:clusterController noria-inst:ClusterController01 ;
    noria:resourceForApplication noria-inst:BillingApp ;
