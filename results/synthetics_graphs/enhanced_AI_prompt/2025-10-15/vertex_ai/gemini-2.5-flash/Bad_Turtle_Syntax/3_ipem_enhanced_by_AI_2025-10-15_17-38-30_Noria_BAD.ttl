noria-inst:EventRecord_App_Crash
    a noria:EventRecord, noria:DynamicElement ;
    rdfs:label "Event: Billing App Crash" ;
    rdfs:comment "Log entry indicating a crash in the Billing Application." ;
    noria:logOriginatingManagedObject noria-inst:BillingAppModuleProd ;
    noria:logOriginatingManagementSystem noria-inst:MonitoringApp ;
    noria:logOriginatingAgent noria-inst:SystemUser ;
    noria:logText "Billing application process 'billingsvc' terminated unexpectedly."^^xsd:string ;
    noria:loggingTime "2024-03-15T08:59:30Z"^^xsd:dateTime ;
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Critical ;
    noria:alarmProposedRepairAction noria-inst:RestartApplicationProcedure ;
    noria:alarmMonitoredAttribute noria-inst:Server001_Disk_IOPS ;
    noria:alarmMitigatedBy noria-inst:ProcedureExecContainer_App_Restart ;
    noria:elementManagedBy noria-inst:MonitoringApp ;
.

noria-inst:EventRecord_TT_StatusChange_001
    a noria:EventRecord, noria:DynamicElement ;
    rdfs:label "Event: TT20240315-001 Status Change to InProgress" ;
    rdfs:comment "Log entry for status change of Trouble Ticket TT20240315-001." ;
    noria:logOriginatingManagedObject noria-inst:TT20240315-001 ;
    noria:logOriginatingManagementSystem noria-inst:ITSMSystem ;
    noria:logOriginatingAgent noria-inst:IncidentManager ;
    noria:logText "Trouble Ticket TT20240315-001 status changed from 'New' to 'InProgress'."^^xsd:string ;
    noria:loggingTime "2024-03-15T09:05:00Z"^^xsd:dateTime ;
    noria:elementManagedBy noria-inst:ITSMSystem ;
.

noria-inst:EventRecord_CR_StatusChange_001
    a noria:EventRecord, noria:DynamicElement ;
    rdfs:label "Event: CR20240310-001 Status Change to Implemented" ;
    rdfs:comment "Log entry for status change of Change Request CR20240310-001." ;
    noria:logOriginatingManagedObject noria-inst:CR20240310-001 ;
    noria:logOriginatingManagementSystem noria-inst:ITSMSystem ;
    noria:logOriginatingAgent noria-inst:ChangeManager ;
    noria:logText "Change Request CR20240310-001 status changed from 'Executing' to 'Implemented'."^^xsd:string ;
    noria:loggingTime "2024-03-20T03:50:00Z"^^xsd:dateTime ;
    noria:elementManagedBy noria-inst:ITSMSystem ;
.

noria-inst:EventRecord_TT_Freeze_001
    a noria:EventRecord, noria:DynamicElement ;
    rdfs:label "Event: TT20240315-001 Freeze Period Start" ;
    rdfs:comment "Log entry indicating the start of a freeze period for TT20240315-001." ;
    noria:logOriginatingManagedObject noria-inst:TT20240315-001 ;
    noria:logOriginatingManagementSystem noria-inst:ITSMSystem ;
    noria:logOriginatingAgent noria-inst:IncidentManager ;
    noria:logText "Trouble Ticket TT20240315-001 entered freeze state due to external dependency."^^xsd:string ;
    noria:loggingTime "2024-03-15T09:30:00Z"^^xsd:dateTime ;
    noria:elementManagedBy noria-inst:ITSMSystem ;
.

# noria:ProceduralElement (instantiated via noria:AnomalyPattern, noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
noria-inst:DBConnectionExhaustionPattern
    a noria:AnomalyPattern, noria:ProceduralObject ;
    rdfs:label "Database Connection Exhaustion Pattern" ;
    rdfs:comment "Pattern indicating database connection pool exhaustion leading to application outage." ;
    noria:elementManagedBy noria-inst:DBAdminTeam ;
.

noria-inst:RestartApplicationProcedure
    a noria:OperationPlan, noria:ProceduralObject ;
    rdfs:label "Restart Application Procedure" ;
    rdfs:comment "Standard operating procedure for restarting a critical application." ;
    noria:operationPlanPreCondition noria-inst:AppDownPreCondition ;
    noria:operationPlanPostCondition noria-inst:AppUpPostCondition ;
    noria:elementManagedBy noria-inst:ApplicationSupportTeam ;
.

noria-inst:RouterFirmwareUpgradePlan
    a noria:OperationPlan, noria:ProceduralObject ;
    rdfs:label "Router Firmware Upgrade Plan" ;
    rdfs:comment "Detailed plan for upgrading router firmware, including backup and rollback steps." ;
    noria:operationPlanPreCondition noria-inst:RouterBackupPreCondition ;
    noria:operationPlanPostCondition noria-inst:RouterOperationalPostCondition ;
    noria:elementManagedBy noria-inst:NetworkOperationsTeam ;
.

noria-inst:AppDownPreCondition
    a noria:ActionPreCondition, noria:ProceduralObject ;
    rdfs:label "Application Down Pre-Condition" ;
    rdfs:comment "Condition: Application process is not running and unresponsive." ;
    noria:elementManagedBy noria-inst:ApplicationSupportTeam ;
.

noria-inst:RouterBackupPreCondition
    a noria:ActionPreCondition, noria:ProceduralObject ;
    rdfs:label "Router Configuration Backup Pre-Condition" ;
    rdfs:comment "Condition: Latest router configuration has been backed up." ;
    noria:elementManagedBy noria-inst:NetworkOperationsTeam ;
.

noria-inst:AppUpPostCondition
    a noria:ActionPostCondition, noria:ProceduralObject ;
    rdfs:label "Application Up Post-Condition" ;
    rdfs:comment "Outcome: Application process is running, responsive, and serving traffic." ;
    noria:elementManagedBy noria-inst:ApplicationSupportTeam ;
.

noria-inst:RouterOperationalPostCondition
    a noria:ActionPostCondition, noria:ProceduralObject ;
    rdfs:label "Router Operational Post-Condition" ;
    rdfs:comment "Outcome: Router is operational, forwarding traffic, and new firmware is active." ;
    noria:elementManagedBy noria-inst:NetworkOperationsTeam ;
.

