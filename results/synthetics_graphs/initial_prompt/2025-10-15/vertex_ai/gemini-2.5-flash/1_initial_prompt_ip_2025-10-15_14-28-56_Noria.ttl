ex:CR20240310-005
    a noria:ChangeRequest ;
    rdfs:label "Core Router OS Upgrade"@en ;
    rdfs:comment "Change request to upgrade the operating system of Core Router 01 to address known vulnerabilities and improve performance."@en ;
    dcterms:identifier "CR20240310-005" ;
    dcterms:created "2024-03-10T14:00:00Z"^^xsd:dateTime ;
    dcterms:title "Upgrade OS on CoreRouter01"@en ;
    dcterms:description "Planned OS upgrade for CoreRouter01 to version 17.3.4. This requires a maintenance window and will cause a brief network outage."@en ;
    noria:documentExternalId "NET-UPG-CR01-2024" ;
    noria:documentHRef <http://itsm.techcorp.com/changes/CR20240310-005> ;
    noria:changeRequestPlannedStartTime "2024-03-20T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-20T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <https://w3id.org/noria/kos/ChangeRequest/category/InternalIntervention> ; # Assuming this KOS exists
    noria:changeRequestType ex:NormalChange ;
    noria:changeRequestChangeCause ex:SoftwareUpgradeCause ;
    noria:changeRequestOutageDuration "PT15M"^^xsd:duration ; # 15 minutes outage
    noria:changeRequestStatusCurrent ex:ApprovedStatus ;
    noria:changeRequestSpecification <https://w3id.org/noria/kos/ChangeRequest/specification/StandardOSUpgrade> ; # Assuming this KOS exists
    noria:changeRequestInitiatorParty ex:AliceSmith ;
    noria:changeRequestPilotParty ex:AliceSmith ;
    noria:changeRequestActorParty ex:NetworkOperationsUnit ;
    noria:changeRequestIsRegulated true ;
    noria:changeRequestImpact ex:CoreRouter01, ex:MonitoringSystemApp .

ex:NetworkDiagramAttachment
    a noria:DocumentAttachment ;
    rdfs:label "Network Diagram for Core Router 01"@en ;
    rdfs:comment "A PDF document containing the network topology diagram relevant to Core Router 01."@en ;
