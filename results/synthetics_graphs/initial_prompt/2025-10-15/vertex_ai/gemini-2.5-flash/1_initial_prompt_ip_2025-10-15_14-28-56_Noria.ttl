    noria:troubleTicketNoteOperationType <https://w3id.org/noria/kos/TroubleTicket/operationType/Diagnosis> . # Assuming this KOS exists

ex:ServerRestartEvent
    a noria:EventRecord ;
    rdfs:label "WebSrv01 Restart Event"@en ;
    rdfs:comment "Log entry indicating a restart command was issued on WebSrv01."@en ;
    noria:loggingTime "2024-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Server restart initiated by bjohnson on websrv01.techcorp.com."@en ;
    noria:logOriginatingManagedObject ex:WebSrv01 ;
    noria:logOriginatingAgent ex:BobJohnson ;
    noria:alarmSeverity ex:WarningSeverityAlarm ;
    dcterms:type <https://w3id.org/noria/kos/Notification/EventType/ConfigurationChange> ; # Assuming this KOS exists
    dcterms:relation ex:TT20240315-001-Note1 . # Correlated with the note

ex:TT20240315-001-Note2
    a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket Note 2 for TT20240315-001"@en ;
