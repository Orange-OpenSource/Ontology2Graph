@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix ex: <http://example.com/noria-kg/> .

# =============================================================================
# SKOS Concept Schemes and Concepts for controlled vocabularies
# =============================================================================

<https://w3id.org/noria/kos/application/type>
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of applications within the NORIA ontology."@en .

ex:ServicePlatform
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "Represents an application that provides a foundational service platform."@en .

ex:InfrastructureApp
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Represents an application primarily managing or supporting infrastructure components."@en .

<https://w3id.org/noria/kos/application/business-importance>
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A controlled vocabulary for assessing the business importance of applications."@en .

ex:CriticalImportance
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "Critical Importance"@en ;
    rdfs:comment "Indicates an application whose failure would have severe business impact."@en .

ex:HighImportance
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "High Importance"@en ;
    rdfs:comment "Indicates an application with significant business impact if it fails."@en .

<https://w3id.org/noria/kos/TroubleTicket/severity>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the severity of trouble tickets."@en .

ex:MajorSeverity
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Indicates a significant service degradation or outage affecting multiple users."@en .

ex:MinorSeverity
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Minor Severity"@en ;
    rdfs:comment "Indicates a minor service degradation or issue affecting a limited number of users."@en .

<https://w3id.org/noria/kos/TroubleTicket/status>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for tracking the lifecycle status of trouble tickets."@en .

ex:InProgressStatus
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

ex:ResolvedStatus
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue described in the trouble ticket has been resolved."@en .

<https://w3id.org/noria/kos/ChangeRequest/status>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for tracking the lifecycle status of change requests."@en .

ex:ApprovedStatus
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "The change request has been approved and is awaiting implementation."@en .

ex:ImplementedStatus
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "The change request has been successfully implemented."@en .

<https://w3id.org/noria/kos/Resource/LifecycleState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for describing the lifecycle state of resources."@en .

ex:InProductionState
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The resource is actively used in a production environment."@en .

ex:MaintenanceState
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ;
    rdfs:label "In Maintenance"@en ;
    rdfs:comment "The resource is currently undergoing maintenance."@en .

<https://w3id.org/noria/kos/Resource/OperationalState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for describing the operational state of resources."@en .

ex:UpState
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "The resource or interface is operational and functioning."@en .

ex:DownState
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "The resource or interface is not operational."@en .

<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity>
    a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the perceived severity of notifications and alarms."@en .

ex:CriticalSeverityAlarm
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Severity Alarm"@en ;
    rdfs:comment "Indicates a critical alarm, requiring immediate attention."@en .

ex:WarningSeverityAlarm
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning Severity Alarm"@en ;
    rdfs:comment "Indicates a warning, potentially leading to a critical issue if not addressed."@en .

<https://w3id.org/noria/kos/TroubleTicket/origin>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the origin of trouble tickets."@en .

ex:CustomerOrigin
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Trouble ticket originated from a customer report."@en .

ex:SupervisionOrigin
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System Origin"@en ;
    rdfs:comment "Trouble ticket originated from an automated supervision system."@en .

<https://w3id.org/noria/kos/ChangeRequest/type>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type of change requests."@en .

ex:StandardChange
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk and impact."@en .

ex:NormalChange
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> ;
    rdfs:label "Normal Change"@en ;
    rdfs:comment "A change requiring assessment and authorization, following a standard process."@en .

<https://w3id.org/noria/kos/ChangeRequest/cause>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the cause or reason for change requests."@en .

ex:SoftwareUpgradeCause
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change requested due to a software upgrade."@en .

ex:ConfigurationChangeCause
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change requested to modify system configuration."@en .

# =============================================================================
# Organizations and People
# =============================================================================

ex:TechCorp
    a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "The main organization operating the IT infrastructure and services."@en ;
    org:hasUnit ex:NetworkOperationsUnit, ex:ApplicationSupportUnit .

ex:NetworkOperationsUnit
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Responsible for the day-to-day operation and maintenance of the network infrastructure."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "Mon-Fri, 9:00-17:00 CET"@en ;
    noria:agentPreferredContactMethod ex:EmailContactMethod ;
    noria:agentInstructions "For critical network issues, use the dedicated hotline and ticketing system."@en .

ex:ApplicationSupportUnit
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Provides support for critical business applications."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "24/7 On-Call Rotation"@en ;
    noria:agentPreferredContactMethod ex:PagerContactMethod ;
    noria:agentInstructions "For P1 incidents, escalate immediately via the incident management platform."@en .

ex:AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer at TechCorp, responsible for core network infrastructure."@en ;
    foaf:mbox <mailto:alice.smith@techcorp.com> ;
    foaf:phone "+1-555-123-4567" ;
    org:memberOf ex:NetworkOperationsUnit ;
    foaf:holdsAccount ex:AliceCUid ;
    noria:agentManagesResource ex:CoreRouter01, ex:EdgeRouter02 .

ex:BobJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Specialist for the Customer Portal at TechCorp."@en ;
    foaf:mbox <mailto:bob.johnson@techcorp.com> ;
    foaf:phone "+1-555-987-6543" ;
    org:memberOf ex:ApplicationSupportUnit ;
    foaf:holdsAccount ex:BobCUid ;
    noria:agentManagesResource ex:WebSrv01, ex:DBServer01 .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    observable:accountLogin "asmith" ;
    observable:accountIdentifier "U12345" .

ex:BobCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    observable:accountLogin "bjohnson" ;
    observable:accountIdentifier "U67890" .

ex:EmailContactMethod
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ; # Assuming this scheme exists or is implied
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via email."@en .

ex:PagerContactMethod
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ; # Assuming this scheme exists or is implied
    rdfs:label "Pager"@en ;
    rdfs:comment "Preferred contact method via pager for urgent alerts."@en .

# =============================================================================
# Locations
# =============================================================================

ex:MainDataCenter
    a bot:Site ;
    rdfs:label "TechCorp Main Data Center"@en ;
    rdfs:comment "The primary data center facility for TechCorp's operations."@en ;
    noria:siteId "DC-NYC-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Way" ;
    noria:sitePrincipalAddressCityName "New York" ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US" ;
    bot:containsZone ex:ServerRoomA .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated server room within the Main Data Center."@en ;
    bot:hasSubSpace ex:Rack12 ;
    bot:hasElement ex:WebSrv01, ex:DBServer01, ex:CoreRouter01 .

ex:Rack12
    a noria:Locus ;
    rdfs:label "Rack 12 in Server Room A"@en ;
    rdfs:comment "A specific rack location within Server Room A, identified by its line and row."@en ;
    noria:locusLine "L" ;
    noria:locusRow "12" ;
    bot:hasElement ex:WebSrv01, ex:DBServer01 .

# =============================================================================
# Applications and Services
# =============================================================================

ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "The main web application allowing customers to manage their accounts and services."@en ;
    noria:applicationModelIdentifier "CP-V2.0" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CustPortal" ;
    noria:applicationType ex:ServicePlatform ;
    noria:applicationBusinessImportance ex:CriticalImportance ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Online Account Management" ;
    seas:subSystem ex:CustomerPortalProdModule, ex:CustomerPortalDevModule .

ex:CustomerPortalProdModule
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "The production instance of the Customer Portal application, serving live customer traffic."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CP-V2.0_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleAdministrationTeam ex:ApplicationSupportUnit ;
    noria:applicationModuleAdministrationLeader ex:BobJohnson ;
    noria:applicationModuleSupportTeam ex:ApplicationSupportUnit ;
    noria:applicationModuleSupportLeader ex:BobJohnson ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ; # Assuming this KOS exists
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleStatus ex:InProductionState ;
    seas:subSystemOf ex:ECommerceService .

ex:CustomerPortalDevModule
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Development Module"@en ;
    rdfs:comment "The development instance of the Customer Portal application, used for testing and new feature development."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CP-V2.0_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleAdministrationTeam ex:ApplicationSupportUnit ;
    noria:applicationModuleAdministrationLeader ex:BobJohnson ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> . # Assuming this KOS exists

ex:ECommerceService
    a noria:Service ;
    rdfs:label "E-commerce Service"@en ;
    rdfs:comment "An end-to-end service encompassing the Customer Portal and its backend systems for online transactions."@en ;
    noria:serviceType <https://w3id.org/noria/kos/service/type/CustomerFacingService> ; # Assuming this KOS exists
    seas:subSystem ex:CustomerPortalProdModule .

ex:MonitoringSystemApp
    a noria:Application ;
    rdfs:label "Infrastructure Monitoring System"@en ;
    rdfs:comment "An application responsible for collecting metrics and logs from IT infrastructure."@en ;
    noria:applicationModelIdentifier "MON-V1.5" ;
    noria:applicationShortIdentifier "MonitorSys" ;
    noria:applicationType ex:InfrastructureApp ;
    noria:applicationBusinessImportance ex:HighImportance ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance and Event Management" .

# =============================================================================
# Infrastructure (Resources, Network Interfaces, Links)
# =============================================================================

ex:HPProLiantModel
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Product model for HP ProLiant DL380 Gen10 servers."@en ;
    noria:productManufacturedBy ex:HPEOrganization .

ex:HPEOrganization
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise (HPE)"@en ;
    rdfs:comment "Manufacturer of the HP ProLiant server models."@en .

ex:CiscoCatalystModel
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300 Series"@en ;
    rdfs:comment "Product model for Cisco Catalyst 9300 series network switches/routers."@en ;
    noria:productManufacturedBy ex:CiscoOrganization .

ex:CiscoOrganization
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of Cisco network equipment."@en .

ex:WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "A web server hosting the Customer Portal application."@en ;
    noria:resourceLogisticId "ASSET-WS01-2022" ;
    noria:resourceHostName "websrv01.techcorp.com" ;
    noria:resourceProductModel ex:HPProLiantModel ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/WebServer> ; # Assuming this KOS exists
    noria:resourceSerialNumber "SN-WS01-XYZ" ;
    noria:resourceUsageState ex:InProductionState ;
    noria:resourceInstallationDate "2022-03-10T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalApp ;
    noria:locatedAtLocus ex:Rack12 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> ; # Example IP URI
    noria:resourceManagedBy ex:ApplicationSupportUnit ;
    seas:hasCommunicationConnectionPoint ex:WebSrv01Eth0 .

ex:DBServer01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "A database server supporting the Customer Portal application."@en ;
    noria:resourceLogisticId "ASSET-DB01-2022" ;
    noria:resourceHostName "dbserver01.techcorp.com" ;
    noria:resourceProductModel ex:HPProLiantModel ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/DatabaseServer> ; # Assuming this KOS exists
    noria:resourceSerialNumber "SN-DB01-ABC" ;
    noria:resourceUsageState ex:InProductionState ;
    noria:resourceInstallationDate "2022-03-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalApp ;
    noria:locatedAtLocus ex:Rack12 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.11> ;
    noria:resourceManagedBy ex:ApplicationSupportUnit ;
    seas:hasCommunicationConnectionPoint ex:DBServer01Eth0 .

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "A core network router providing connectivity for the data center."@en ;
    noria:resourceLogisticId "ASSET-CR01-2021" ;
    noria:resourceHostName "corerouter01.techcorp.com" ;
    noria:resourceProductModel ex:CiscoCatalystModel ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/NetworkRouter> ; # Assuming this KOS exists
    noria:resourceSerialNumber "SN-CR01-DEF" ;
    noria:resourceUsageState ex:InProductionState ;
    noria:resourceInstallationDate "2021-05-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:MonitoringSystemApp ; # Monitoring system relies on core network
    noria:locatedAtLocus ex:ServerRoomA ; # Not in a specific rack, but in the room
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> ;
    noria:resourceManagedBy ex:NetworkOperationsUnit ;
    seas:hasCommunicationConnectionPoint ex:CoreRouter01Gi0_0_1, ex:CoreRouter01Gi0_0_2 .

ex:WebSrv01Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "The primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf ex:WebSrv01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to application VLAN."@en ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Physical> ; # Assuming this KOS exists
    noria:networkInterfaceAdministrativeStatus ex:UpState ;
    noria:networkInterfaceOperationalStatus ex:UpState ;
    noria:networkInterfaceConnects ex:LinkWebDB .

ex:DBServer01Eth0
    a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0"@en ;
    rdfs:comment "The primary network interface for DB Server 01."@en ;
    noria:networkInterfaceOf ex:DBServer01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to database VLAN."@en ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus ex:UpState ;
    noria:networkInterfaceOperationalStatus ex:UpState ;
    noria:networkInterfaceConnects ex:LinkWebDB .

ex:CoreRouter01Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface on Core Router 01 connecting to the server farm switch."@en ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to Server Farm Switch."@en ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus ex:UpState ;
    noria:networkInterfaceOperationalStatus ex:UpState ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects ex:LinkCoreEdge .

ex:CoreRouter01Gi0_0_2
    a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/2"@en ;
    rdfs:comment "Interface on Core Router 01 connecting to the internet edge router."@en ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to Internet Edge Router."@en ;
    noria:networkInterfaceType <https://w3id.org/noria/kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus ex:UpState ;
    noria:networkInterfaceOperationalStatus ex:UpState ;
    noria:networkInterfaceRoutingPriorityMetric 120 ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 ;
    noria:networkInterfaceConnects ex:LinkCoreEdge .

ex:LinkWebDB
    a noria:NetworkLink ;
    rdfs:label "Link between WebSrv01 and DBServer01"@en ;
    rdfs:comment "A logical network link connecting the web server and database server."@en ;
    noria:networkLinkId "LOGICALLINK-WEB-DB" ;
    noria:networkLinkTerminationResourceOrigin ex:WebSrv01 ;
    noria:networkLinkTerminationResourceDestination ex:DBServer01 ;
    noria:networkLinkInstallationDate "2022-03-10T12:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet VLAN" ;
    noria:resourceManagedBy ex:ApplicationSupportUnit .

ex:LinkCoreEdge
    a noria:NetworkLink ;
    rdfs:label "Link from CoreRouter01 to Edge Router"@en ;
    rdfs:comment "A physical network link connecting Core Router 01 to an external edge router."@en ;
    noria:networkLinkId "PHYSICALLINK-CR01-EDGE" ;
    noria:networkLinkTerminationResourceOrigin ex:CoreRouter01 ;
    noria:networkLinkInstallationDate "2021-05-20T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 10Gbps" ;
    noria:resourceManagedBy ex:NetworkOperationsUnit .

# =============================================================================
# Dynamic Elements (Incident Scenario)
# =============================================================================

ex:CPUHighAlertEvent
    a noria:EventRecord ;
    rdfs:label "CPU High Alert on WebSrv01"@en ;
    rdfs:comment "An event record indicating high CPU utilization on Web Server 01, detected by the monitoring system."@en ;
    noria:loggingTime "2024-03-15T09:30:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on websrv01.techcorp.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject ex:WebSrv01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystemApp ;
    noria:alarmSeverity ex:CriticalSeverityAlarm ;
    dcterms:type <https://w3id.org/noria/kos/Notification/EventType/ThresholdExceeded> . # Assuming this KOS exists

ex:TT20240315-001
    a noria:TroubleTicket ;
    rdfs:label "Customer Portal Slow Performance Incident"@en ;
    rdfs:comment "Trouble ticket opened due to reports of slow performance on the Customer Portal, triggered by a high CPU alert."@en ;
    dcterms:identifier "TT20240315-001" ;
    dcterms:created "2024-03-15T09:35:00Z"^^xsd:dateTime ;
    dcterms:title "Customer Portal experiencing slow response times."@en ;
    dcterms:description "Multiple customer reports and internal monitoring alerts indicate degraded performance of the Customer Portal. Initial investigation points to high CPU on websrv01."@en ;
    noria:documentExternalId "CUST-P-12345" ;
    noria:documentHRef <http://itsm.techcorp.com/tickets/TT20240315-001> ;
    noria:troubleTicketSeverity ex:MajorSeverity ;
    noria:troubleTicketType <https://w3id.org/noria/kos/TroubleTicket/type/Failure> ; # Assuming this KOS exists
    noria:troubleTicketCriticity <https://w3id.org/noria/kos/TroubleTicket/category/InterruptedService> ; # Assuming this KOS exists
    noria:troubleTicketPriority <https://w3id.org/noria/kos/TroubleTicket/priority/P1> ; # Assuming this KOS exists
    noria:troubleTicketOrigin ex:SupervisionOrigin ;
    noria:troubleTicketTrigger ex:CPUHighAlertEvent ;
    noria:troubleTicketUrgency <https://w3id.org/noria/kos/TroubleTicket/urgency/ImmediateIntervention> ; # Assuming this KOS exists
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <https://w3id.org/noria/kos/TroubleTicket/trouble-category/PerformanceDegradation> ; # Assuming this KOS exists
    noria:troubleTicketCause "Undetermined, possibly application-related or resource exhaustion."@en ;
    noria:troubleTicketDetectionDateTime "2024-03-15T09:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent ex:InProgressStatus ;
    noria:troubleTicketRelatedParty ex:ApplicationSupportUnit, ex:BobJohnson ;
    noria:troubleTicketRelatedService ex:CustomerPortalProdModule, ex:ECommerceService ;
    noria:troubleTicketRelatedResource ex:WebSrv01 ;
    noria:troubleTicketImpacts ex:WebSrv01, ex:CustomerPortalProdModule .

ex:TT20240315-001-Note1
    a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket Note 1 for TT20240315-001"@en ;
    rdfs:comment "Initial diagnostic steps and findings for the Customer Portal incident."@en ;
    dcterms:created "2024-03-15T09:45:00Z"^^xsd:dateTime ;
    dcterms:creator ex:BobJohnson ;
    dcterms:description "Checked application logs, no immediate errors. CPU on websrv01 remains high. Initiating server restart procedure."@en ;
