# =============================================================================
# Procedural Elements
# =============================================================================

ex:ServerRestartProcedure
    a noria:OperationPlan ;
    rdfs:label "Web Server Restart Procedure"@en ;
    rdfs:comment "A standard operating procedure for restarting web servers."@en ;
    noria:operationPlanPreCondition ex:HighCPULoadDetected ;
    noria:operationPlanPostCondition ex:ServiceRestoredConfirmation .

ex:HighCPULoadDetected
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Load Detected"@en ;
    rdfs:comment "Pre-condition: CPU utilization on the web server exceeds a predefined threshold."@en .

ex:ServiceRestoredConfirmation
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored Confirmation"@en ;
    rdfs:comment "Post-condition: Customer portal is accessible and responsive, CPU utilization is normal."@en .

ex:NetworkFailoverPlan
    a noria:OperationPlan ;
    rdfs:label "Network Failover Procedure"@en ;
    rdfs:comment "Procedure to activate a redundant network path in case of primary link failure."@en ;
    noria:operationPlanPreCondition ex:PrimaryLinkDownAlert ;
    noria:operationPlanPostCondition ex:TrafficReroutedConfirmation .

ex:PrimaryLinkDownAlert
    a noria:ActionPreCondition ;
    rdfs:label "Primary Network Link Down Alert"@en ;
    rdfs:comment "Pre-condition: An alert indicating the primary network link is down."@en .

ex:TrafficReroutedConfirmation
    a noria:ActionPostCondition ;
    rdfs:label "Traffic Rerouted and Connectivity Restored"@en ;
    rdfs:comment "Post-condition: Network traffic is successfully rerouted to the backup link, and connectivity is restored."@en .

ex:RouterOSUpgradePlan
    a noria:OperationPlan ;
    rdfs:label "Core Router OS Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for upgrading the operating system of core network routers."@en ;
    noria:operationPlanPreCondition ex:PreUpgradeChecksCompleted ;
    noria:operationPlanPostCondition ex:PostUpgradeVerificationPassed .

ex:PreUpgradeChecksCompleted
    a noria:ActionPreCondition ;
    rdfs:label "Pre-Upgrade Checks Completed"@en ;
    rdfs:comment "All necessary pre-upgrade checks, including backups and compatibility, have been completed."@en .

ex:PostUpgradeVerificationPassed
    a noria:ActionPostCondition ;
    rdfs:label "Post-Upgrade Verification Passed"@en ;
    rdfs:comment "All post-upgrade tests, including connectivity and functionality, have passed."@en .

ex:HighCPULowThroughputPattern
    a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Throughput Anomaly Pattern"@en ;
    rdfs:comment "A recognized anomaly pattern where a server exhibits high CPU utilization but unexpectedly low network throughput, often indicating a bottleneck or application issue."@en ;
    dcterms:relation ex:CPUHighAlertEvent . # This event matches the pattern

ex:CR20240310-005
    pep:hasProcedure ex:RouterOSUpgradePlan . # Link Change Request to its Operation Plan

ex:TT20240315-001
    noria:alarmProposedRepairAction ex:ServerRestartProcedure . # Suggests a repair action for the incident

