@prefix ex: <http://example.com/data/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# SKOS Concept Schemes and Concepts for Controlled Vocabularies
# =============================================================================

# Application Type Concept Scheme
<kos/application/type>
    a skos:ConceptScheme ;
    rdfs:label "Application Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of applications within an IT ecosystem."@en .

ex:CRMApplicationType
    a skos:Concept ;
    rdfs:label "Customer Relationship Management (CRM) Application"@en ;
    rdfs:comment "An application designed to manage customer interactions and data throughout the customer lifecycle, central to business operations."@en ;
    skos:inScheme <kos/application/type> .

ex:MonitoringApplicationType
    a skos:Concept ;
    rdfs:label "Monitoring Platform Application"@en ;
    rdfs:comment "An application used for real-time surveillance and performance tracking of IT infrastructure and services."@en ;
    skos:inScheme <kos/application/type> .

# Application Business Importance Concept Scheme
<kos/application/business-importance>
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for assessing the business criticality of applications, influencing incident management and prioritization."@en .

ex:CriticalBusinessImportance
    a skos:Concept ;
    rdfs:label "Critical Business Importance"@en ;
    rdfs:comment "Indicates an application whose unavailability would severely impact core business functions and revenue."@en ;
    skos:inScheme <kos/application/business-importance> .

ex:HighBusinessImportance
    a skos:Concept ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Indicates an application whose unavailability would significantly impact business operations, requiring urgent attention."@en ;
    skos:inScheme <kos/application/business-importance> .

# Application Status Concept Scheme
<kos/application/status>
    a skos:ConceptScheme ;
    rdfs:label "Application Status Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for describing the operational status of application modules."@en .

ex:InProductionStatus
    a skos:Concept ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving end-users or business processes."@en ;
    skos:inScheme <kos/application/status> .

ex:InDevelopmentStatus
    a skos:Concept ;
    rdfs:label "In Development"@en ;
    rdfs:comment "The application module is under active development and not yet deployed to production."@en ;
    skos:inScheme <kos/application/status> .

# Service Type Concept Scheme
<kos/service/type>
    a skos:ConceptScheme ;
    rdfs:label "Service Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of IT services, such as customer-facing or resource-facing."@en .

ex:CustomerFacingServiceType
    a skos:Concept ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed or perceived by external customers."@en ;
    skos:inScheme <kos/service/type> .

ex:ResourceFacingServiceType
    a skos:Concept ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations, not directly exposed to customers."@en ;
    skos:inScheme <kos/service/type> .

# Trouble Ticket Severity Concept Scheme
<kos/TroubleTicket/severity>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for defining the criticality of an incident, impacting response and resolution times."@en .

ex:CriticalSeverity
    a skos:Concept ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Indicates a major service outage or severe business impact, requiring immediate attention."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

ex:MajorSeverity
    a skos:Concept ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Indicates a significant service degradation or moderate business impact."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

# Trouble Ticket Status Concept Scheme
<kos/TroubleTicket/status>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for tracking the lifecycle status of a trouble ticket."@en .

ex:InProgressStatus
    a skos:Concept ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being actively worked on by a support team."@en ;
    skos:inScheme <kos/TroubleTicket/status> .

ex:ResolvedStatus
    a skos:Concept ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue described in the trouble ticket has been fixed and verified."@en ;
    skos:inScheme <kos/TroubleTicket/status> .

# Change Request Status Concept Scheme
<kos/ChangeRequest/status>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for tracking the lifecycle status of a change request."@en .

ex:ApprovedStatus
    a skos:Concept ;
    rdfs:label "Approved"@en ;
    rdfs:comment "The change request has been reviewed and approved for implementation."@en ;
    skos:inScheme <kos/ChangeRequest/status> .

ex:ImplementedStatus
    a skos:Concept ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "The change described in the change request has been successfully applied."@en ;
    skos:inScheme <kos/ChangeRequest/status> .

# Notification Severity Perceived Severity Concept Scheme
<Notification/Severity/PerceivedSeverity>
    a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for indicating the perceived severity of an alarm or event notification."@en .

ex:AlarmSeverityCritical
    a skos:Concept ;
    rdfs:label "Critical Alarm Severity"@en ;
    rdfs:comment "Indicates a critical condition requiring immediate and urgent attention, often implying service outage."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

ex:AlarmSeverityMajor
    a skos:Concept ;
    rdfs:label "Major Alarm Severity"@en ;
    rdfs:comment "Indicates a major service degradation or potential for outage, requiring prompt action."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Resource Type Concept Scheme
<kos/Resource/type>
    a skos:ConceptScheme ;
    rdfs:label "Resource Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of IT resources, such as servers, routers, or switches."@en .

ex:ServerResourceType
    a skos:Concept ;
    rdfs:label "Server Resource Type"@en ;
    rdfs:comment "A computing resource providing services to other computers or users, typically hosting applications."@en ;
    skos:inScheme <kos/Resource/type> .

ex:RouterResourceType
    a skos:Concept ;
    rdfs:label "Router Resource Type"@en ;
    rdfs:comment "A network device that forwards data packets between computer networks, creating an overlay internetwork."@en ;
    skos:inScheme <kos/Resource/type> .

ex:SwitchResourceType
    a skos:Concept ;
    rdfs:label "Switch Resource Type"@en ;
    rdfs:comment "A network device that connects devices in a computer network by using packet switching to receive, process, and forward data to the destination device."@en ;
    skos:inScheme <kos/Resource/type> .

# Resource Lifecycle State Concept Scheme
<kos/Resource/LifecycleState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for describing the operational lifecycle state of an IT resource."@en .

ex:InProductionLifecycleState
    a skos:Concept ;
    rdfs:label "In Production Lifecycle State"@en ;
    rdfs:comment "The resource is actively used in the production environment, supporting live services."@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

ex:MaintenanceLifecycleState
    a skos:Concept ;
    rdfs:label "Maintenance Lifecycle State"@en ;
    rdfs:comment "The resource is currently undergoing maintenance or scheduled downtime."@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

# Resource Administrative State Concept Scheme
<kos/Resource/AdministrativeState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for defining the administrative state of a network interface, typically 'up' or 'down'."@en .

ex:AdminStateUp
    a skos:Concept ;
    rdfs:label "Administrative State Up"@en ;
    rdfs:comment "The network interface is administratively enabled and configured to operate."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

ex:AdminStateDown
    a skos:Concept ;
    rdfs:label "Administrative State Down"@en ;
    rdfs:comment "The network interface is administratively disabled and not configured to operate."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

# Resource Operational State Concept Scheme
<kos/Resource/OperationalState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for defining the operational state of a network interface, reflecting its current activity."@en .

ex:OperStateUp
    a skos:Concept ;
    rdfs:label "Operational State Up"@en ;
    rdfs:comment "The network interface is currently active and passing traffic."@en ;
    skos:inScheme <kos/Resource/OperationalState> .

ex:OperStateDown
    a skos:Concept ;
    rdfs:label "Operational State Down"@en ;
    rdfs:comment "The network interface is currently inactive and not passing traffic."@en ;
    skos:inScheme <kos/Resource/OperationalState> .

# Agent Contact Method Concept Scheme
<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents (teams, employees)."@en .

ex:EmailContactMethod
    a skos:Concept ;
    rdfs:label "Email Contact Method"@en ;
    rdfs:comment "Preferred contact method is via email."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

ex:PhoneContactMethod
    a skos:Concept ;
    rdfs:label "Phone Contact Method"@en ;
    rdfs:comment "Preferred contact method is via phone."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Organizational Entities
# =============================================================================

ex:OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "A leading telecommunications operator, providing a wide range of services including mobile, landline, internet, and IT services."@en ;
    org:hasUnit ex:NetworkOperationsTeam, ex:ApplicationSupportTeam .

ex:NetworkOperationsTeam
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Responsible for the day-to-day operation, maintenance, and monitoring of the network infrastructure."@en ;
    org:unitOf ex:OrangeTelecom ;
    org:hasMember ex:AliceSmith ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:EmailContactMethod ;
    noria:agentInstructions "For critical network issues, use the dedicated hotline and ticketing system."^^xsd:string .

ex:ApplicationSupportTeam
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Responsible for the support and maintenance of business-critical applications, ensuring their availability and performance."@en ;
    org:unitOf ex:OrangeTelecom ;
    org:hasMember ex:BobJohnson ;
    noria:agentWorkingHours "8:30 AM - 6:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:PhoneContactMethod ;
    noria:agentInstructions "For application outages, escalate via the incident management platform."^^xsd:string .

ex:AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer at Orange Telecom, specializing in routing and switching infrastructure."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+33 1 23 45 67 89" ;
    foaf:memberOf ex:NetworkOperationsTeam ;
    foaf:holdsAccount ex:AliceCUid .

ex:BobJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Specialist at Orange Telecom, with expertise in CRM systems."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+33 6 98 76 54 32" ;
    foaf:memberOf ex:ApplicationSupportTeam ;
    foaf:holdsAccount ex:BobCUid .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for Alice Smith, used for system access and authentication."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "CUID-ASMITH-001"^^xsd:string .

ex:BobCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for Bob Johnson, used for system access and authentication."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "CUID-BJOHNSON-002"^^xsd:string .

# =============================================================================
# Location Entities
# =============================================================================

ex:DataCenterParis
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris, hosting critical IT infrastructure for Orange Telecom."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Republique"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Republique"^^xsd:string ;
    bot:hasSpace ex:ServerRoomA .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated server room within the Paris Data Center, housing racks of servers and network equipment."@en ;
    bot:hasSpace ex:Rack1_U23 .

ex:Rack1_U23
    a noria:Locus ;
    rdfs:label "Rack 1, Unit 23"@en ;
    rdfs:comment "A specific location within Server Room A, identifying Unit 23 of Rack 1, where a server is installed."@en ;
    noria:locusLine "Rack 1"^^xsd:string ;
    noria:locusRow "U23"^^xsd:string .

# =============================================================================
# Structural Elements
# =============================================================================

ex:Cisco3850
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 3850 Series Switch"@en ;
    rdfs:comment "Product model for a high-performance enterprise-class stackable access layer switch."@en ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:HPProLiantDL380
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10 Server"@en ;
    rdfs:comment "Product model for a versatile 2U rack server, commonly used for enterprise applications."@en ;
    noria:productManufacturedBy ex:HewlettPackardEnterprise .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en ;
    rdfs:comment "A global technology conglomerate that designs, manufactures, and sells networking hardware, software, telecommunications equipment, and other high-technology services and products."@en .

ex:HewlettPackardEnterprise
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise (HPE)"@en ;
    rdfs:comment "An American multinational enterprise information technology company, providing servers, storage, networking, consulting and support services."@en .

ex:RouterA
    a noria:Resource, seas:CommunicationDevice, bot:Element, observable:Device, log:Host ;
    rdfs:label "Core Router A"@en ;
    rdfs:comment "A critical network router in the Paris Data Center, responsible for routing traffic for core services."@en ;
    noria:resourceHostName "router-a.dc-par-01.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-RA-001"^^xsd:string ;
    noria:resourceProductModel ex:Cisco3850 ;
    noria:resourceType ex:RouterResourceType ;
    noria:resourceSerialNumber "ABC12345DEF6"^^xsd:string ;
    noria:resourceUsageState ex:InProductionLifecycleState ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:resourceManagementIPAddress <http://10.0.0.1> ;
    noria:resourceForApplication ex:MonitoringPlatform .

ex:Server1
    a noria:Resource, seas:System, bot:Element, observable:Device, log:Host ;
    rdfs:label "CRM Database Server 1"@en ;
    rdfs:comment "A dedicated server hosting the primary database for the CRM system."@en ;
    noria:resourceHostName "crmdb-s01.dc-par-01.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-S1-002"^^xsd:string ;
    noria:resourceProductModel ex:HPProLiantDL380 ;
    noria:resourceType ex:ServerResourceType ;
    noria:resourceSerialNumber "GHI78901JKL2"^^xsd:string ;
    noria:resourceUsageState ex:InProductionLifecycleState ;
    noria:resourceInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:ApplicationSupportTeam ;
    noria:locatedAtLocus ex:Rack1_U23 ;
    noria:resourceManagementIPAddress <http://10.0.0.10> ;
    noria:resourceForApplication ex:CRMSystem .

ex:SwitchB
    a noria:Resource, seas:CommunicationDevice, bot:Element, observable:Device, log:Host ;
    rdfs:label "Access Switch B"@en ;
    rdfs:comment "An access layer switch connecting servers within Server Room A to the core network."@en ;
    noria:resourceHostName "access-sw-b.dc-par-01.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-SB-003"^^xsd:string ;
    noria:resourceProductModel ex:Cisco3850 ;
    noria:resourceType ex:SwitchResourceType ;
    noria:resourceSerialNumber "MNO34567PQR8"^^xsd:string ;
    noria:resourceUsageState ex:InProductionLifecycleState ;
    noria:resourceInstallationDate "2021-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:resourceManagementIPAddress <http://10.0.0.2> ;
    noria:resourceForApplication ex:MonitoringPlatform .

ex:RouterA_GE0_0_1
    a noria:NetworkInterface, seas:CommunicationConnectionPoint, observable:NetworkInterface ;
    rdfs:label "Router A GigabitEthernet0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface on Router A, connecting to Switch B."@en ;
    noria:networkInterfaceOf ex:RouterA ;
    noria:networkInterfaceDescription "Uplink to Access Switch B"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus ex:AdminStateUp ;
    noria:networkInterfaceOperationalStatus ex:OperStateUp ;
    noria:networkInterfaceRoutingPriorityMetric 10^^xsd:int .

ex:Server1_ETH0
    a noria:NetworkInterface, seas:CommunicationConnectionPoint, observable:NetworkInterface ;
    rdfs:label "Server 1 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface on Server 1, connecting to Switch B."@en ;
    noria:networkInterfaceOf ex:Server1 ;
    noria:networkInterfaceDescription "Main network interface for CRM DB"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus ex:AdminStateUp ;
    noria:networkInterfaceOperationalStatus ex:OperStateUp ;
    noria:networkInterfaceLaserTxOpticalPower -3^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower -5^^xsd:int .

ex:SwitchB_GE0_0_10
    a noria:NetworkInterface, seas:CommunicationConnectionPoint, observable:NetworkInterface ;
    rdfs:label "Switch B GigabitEthernet0/0/10"@en ;
    rdfs:comment "Gigabit Ethernet interface on Switch B, connecting to Router A."@en ;
    noria:networkInterfaceOf ex:SwitchB ;
    noria:networkInterfaceDescription "Downlink from Core Router A"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus ex:AdminStateUp ;
    noria:networkInterfaceOperationalStatus ex:OperStateUp .

ex:SwitchB_GE0_0_20
    a noria:NetworkInterface, seas:CommunicationConnectionPoint, observable:NetworkInterface ;
    rdfs:label "Switch B GigabitEthernet0/0/20"@en ;
    rdfs:comment "Gigabit Ethernet interface on Switch B, connecting to Server 1."@en ;
    noria:networkInterfaceOf ex:SwitchB ;
    noria:networkInterfaceDescription "Uplink to CRM Database Server 1"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus ex:AdminStateUp ;
    noria:networkInterfaceOperationalStatus ex:OperStateUp .

ex:Link_RouterA_SwitchB
    a noria:NetworkLink, seas:CommunicationConnection ;
    rdfs:label "Network Link between Router A and Switch B"@en ;
    rdfs:comment "A physical network link connecting Core Router A to Access Switch B, forming a segment of the data center network backbone."@en ;
    noria:networkLinkId "NL-RA-SB-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2021-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 10GbE"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin ex:RouterA ;
    noria:networkLinkTerminationResourceDestination ex:SwitchB ;
    noria:networkInterfaceConnects ex:RouterA_GE0_0_1, ex:SwitchB_GE0_0_10 .

ex:Link_SwitchB_Server1
    a noria:NetworkLink, seas:CommunicationConnection ;
    rdfs:label "Network Link between Switch B and Server 1"@en ;
    rdfs:comment "A physical network link connecting Access Switch B to CRM Database Server 1."@en ;
    noria:networkLinkId "NL-SB-S1-002"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-01-20T14:45:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Copper 1GbE"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin ex:SwitchB ;
    noria:networkLinkTerminationResourceDestination ex:Server1 ;
    noria:networkInterfaceConnects ex:SwitchB_GE0_0_20, ex:Server1_ETH0 .

# =============================================================================
# Functional Elements
# =============================================================================

ex:CRMSystem
    a noria:Application, seas:System, observable:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:comment "The primary application for managing customer data, sales, and support interactions."@en ;
    noria:applicationModelIdentifier "CRM-V3.2"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001^^xsd:int ;
    noria:applicationShortIdentifier "CRM"^^xsd:string ;
    noria:applicationType ex:CRMApplicationType ;
    noria:applicationBusinessImportance ex:CriticalBusinessImportance ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Sales & Marketing Automation"^^xsd:string .

ex:MonitoringPlatform
    a noria:Application, seas:System, observable:Application ;
    rdfs:label "Network Monitoring Platform"@en ;
    rdfs:comment "An application responsible for collecting, analyzing, and visualizing performance and health data from network devices."@en ;
    noria:applicationModelIdentifier "NMP-V1.5"^^xsd:string ;
    noria:applicationNumericalIdentifier 2002^^xsd:int ;
    noria:applicationShortIdentifier "NMP"^^xsd:string ;
    noria:applicationType ex:MonitoringApplicationType ;
    noria:applicationBusinessImportance ex:HighBusinessImportance ;
    noria:applicationFunctionalDomain "IT Operations Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Network Performance Monitoring"^^xsd:string .

ex:CRMSystem_Prod
    a noria:ApplicationModule, seas:System ;
    rdfs:label "CRM System Production Module"@en ;
    rdfs:comment "The production instance of the CRM system, serving live customer traffic."@en ;
    noria:applicationModuleOf ex:CRMSystem ;
    noria:applicationModuleName "CRM_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:BobJohnson ;
    noria:applicationModuleSupportTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleSupportLeader ex:BobJohnson ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true^^xsd:boolean ;
    noria:applicationModuleStatus ex:InProductionStatus .

ex:CRMSystem_Dev
    a noria:ApplicationModule, seas:System ;
    rdfs:label "CRM System Development Module"@en ;
    rdfs:comment "The development instance of the CRM system, used for testing and new feature development."@en ;
    noria:applicationModuleOf ex:CRMSystem ;
    noria:applicationModuleName "CRM_DEV"^^xsd:string ;
    noria:applicationModuleIdentifier "DEV"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:BobJohnson ;
    noria:applicationModuleStatus ex:InDevelopmentStatus .

ex:CustomerDataService
    a noria:Service, seas:System, devopsprod:ServiceInstance ;
    rdfs:label "Customer Data Access Service"@en ;
    rdfs:comment "An end-to-end service providing access to customer data, underpinned by the CRM system."@en ;
    noria:serviceType ex:CustomerFacingServiceType ;
    seas:subSystemOf ex:CRMSystem_Prod .

# =============================================================================
# Procedural Elements
# =============================================================================

ex:CRMServiceDownPreCond
    a noria:ActionPreCondition ;
    rdfs:label "CRM Service Unresponsive Pre-Condition"@en ;
    rdfs:comment "Pre-condition indicating that the CRM application is not responding to user requests or health checks."@en .

ex:CRMServiceUpPostCond
    a noria:ActionPostCondition ;
    rdfs:label "CRM Service Restored Post-Condition"@en ;
    rdfs:comment "Post-condition confirming that the CRM application has resumed normal operation and is accessible."@en .

ex:RouterInterfaceDownPreCond
    a noria:ActionPreCondition ;
    rdfs:label "Router Interface Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition indicating that a critical network interface on a router is in an operational 'down' state."@en .

ex:RouterInterfaceUpPostCond
    a noria:ActionPostCondition ;
    rdfs:label "Router Interface Up Post-Condition"@en ;
    rdfs:comment "Post-condition confirming that the critical network interface on the router has returned to an operational 'up' state."@en .

ex:RestartCRMServicePlan
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Restart CRM Service Operation Plan"@en ;
    rdfs:comment "A standardized procedure for restarting the CRM application service in case of unresponsiveness or failure."@en ;
    noria:operationPlanPreCondition ex:CRMServiceDownPreCond ;
    noria:operationPlanPostCondition ex:CRMServiceUpPostCond .

ex:RouterFirmwareUpgradePlan
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Router Firmware Upgrade Plan"@en ;
    rdfs:comment "A detailed operation plan for upgrading the firmware of network routers, including pre-checks, execution steps, and post-validation."@en ;
    noria:operationPlanPreCondition ex:RouterInterfaceDownPreCond ; # Example: if interface is down, upgrade might be part of recovery
    noria:operationPlanPostCondition ex:RouterInterfaceUpPostCond .

# =============================================================================
# Dynamic Elements
# =============================================================================

ex:Event_Server1_CPU_High
    a noria:EventRecord, BBO:DocumentResource, pep:ProcedureExecution, observable:EventRecord, log:Event ;
    rdfs:label "Server 1 CPU High Alert"@en ;
    rdfs:comment "An event record indicating high CPU utilization on CRM Database Server 1, detected by the monitoring platform."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on crmdb-s01.dc-par-01.example.com exceeded 90% for 5 minutes."^^xsd:string ;
    noria:logOriginatingManagedObject ex:Server1 ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    noria:alarmSeverity ex:AlarmSeverityMajor .

ex:Event_RouterA_Interface_Down
    a noria:EventRecord, BBO:DocumentResource, pep:ProcedureExecution, observable:EventRecord, log:Event ;
    rdfs:label "Router A Interface Down Alert"@en ;
    rdfs:comment "An event record indicating that GigabitEthernet0/0/1 on Core Router A has gone down, impacting connectivity."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."^^xsd:string ;
    noria:logOriginatingManagedObject ex:RouterA ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    noria:alarmSeverity ex:AlarmSeverityCritical .

ex:TT_2024_001_CRM_Outage
    a noria:TroubleTicket, pep:ProcedureExecutionContainer, BBO:DocumentResource ;
    rdfs:label "Trouble Ticket for CRM System Outage"@en ;
    rdfs:comment "A trouble ticket opened due to the unresponsiveness of the CRM system, triggered by a critical network event."@en ;
    dcterms:identifier "TT-2024-001"^^xsd:string ;
    noria:documentExternalId "CUST-INC-9876"^^xsd:string ;
    noria:documentHRef <http://itsm.example.com/tickets/TT-2024-001> ;
    noria:troubleTicketSeverity ex:CriticalSeverity ;
    noria:troubleTicketStatusCurrent ex:InProgressStatus ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketTrigger ex:Event_RouterA_Interface_Down ;
    noria:troubleTicketRelatedService ex:CRMSystem_Prod ;
    noria:troubleTicketRelatedResource ex:RouterA ;
    noria:troubleTicketRelatedParty ex:NetworkOperationsTeam ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true^^xsd:boolean ;
    noria:troubleTicketSupervisionTool "Monitoring Platform"^^xsd:string ;
    noria:troubleTicketCause "Network interface failure on core router."^^xsd:string ;
    pep:hasProcedure ex:RestartCRMServicePlan . # The plan to resolve the issue

ex:TT_2024_001_Note_1
    a noria:TroubleTicketNote, pep:ProcedureExecutionContainer, BBO:DocumentResource ;
    rdfs:label "Trouble Ticket 2024-001 Note 1: Initial Diagnosis"@en ;
    rdfs:comment "Initial diagnosis note for Trouble Ticket TT-2024-001, detailing the discovery of a downed router interface."@en ;
    dcterms:isPartOf ex:TT_2024_001_CRM_Outage ;
    dcterms:creator ex:AliceSmith ;
    dcterms:created "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    dcterms:description "Confirmed operational status 'down' for interface GigabitEthernet0/0/1 on Router A. Investigating root cause."^^xsd:string ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

ex:TT_2024_001_Note_2
    a noria:TroubleTicketNote, pep:ProcedureExecutionContainer, BBO:DocumentResource ;
    rdfs:label "Trouble Ticket 2024-001 Note 2: Action Taken"@en ;
    rdfs:comment "Note detailing the action taken to restore the router interface, including a command execution."@en ;
    dcterms:isPartOf ex:TT_2024_001_CRM_Outage ;
    dcterms:creator ex:AliceSmith ;
    dcterms:created "2024-04-23T10:45:00Z"^^xsd:dateTime ;
    dcterms:description "Executed 'no shutdown' command on interface GigabitEthernet0/0/1. Interface status is now 'up'."^^xsd:string ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/CorrectiveAction> ;
    noria:troubleTicketNoteCorrelatedExecution ex:Event_RouterA_Interface_Up_Command .

ex:Event_RouterA_Interface_Up_Command
    a noria:EventRecord, pep:ProcedureExecution, log:Event ;
    rdfs:label "Router A Interface Up Command Execution Log"@en ;
    rdfs:comment "Log entry for the command executed by Alice Smith to bring up Router A's interface."@en ;
    noria:loggingTime "2024-04-23T10:40:00Z"^^xsd:dateTime ;
    noria:logText "Configured from console by vty0 (192.168.1.100) - command: 'interface GigabitEthernet0/0/1; no shutdown'"^^xsd:string ;
    noria:logOriginatingManagedObject ex:RouterA ;
    noria:logOriginatingAgent ex:AliceSmith ;
    pep:hasCommand "interface GigabitEthernet0/0/1; no shutdown"^^xsd:string ;
    pep:hasSimpleResult "Interface GigabitEthernet0/0/1, changed state to up"^^xsd:string .

ex:CR_2024_005_RouterA_Upgrade
    a noria:ChangeRequest, pep:ProcedureExecutionContainer, BBO:DocumentResource ;
    rdfs:label "Change Request for Router A Firmware Upgrade"@en ;
    rdfs:comment "A change request to upgrade the firmware of Core Router A to address known vulnerabilities and improve performance."@en ;
    dcterms:identifier "CR-2024-005"^^xsd:string ;
    noria:documentExternalId "PROJ-NET-0123"^^xsd:string ;
    noria:documentHRef <http://itsm.example.com/changes/CR-2024-005> ;
    noria:changeRequestPlannedStartTime "2024-05-10T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-10T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent ex:ApprovedStatus ;
    noria:changeRequestImpact ex:RouterA ;
    noria:changeRequestInitiatorParty ex:AliceSmith ;
    noria:changeRequestPilotParty ex:AliceSmith ;
    noria:changeRequestActorParty ex:NetworkOperationsTeam ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestIsRegulated true^^xsd:boolean ;
    pep:hasProcedure ex:RouterFirmwareUpgradePlan .

ex:CR_2024_005_Actual_Execution
    a noria:EventRecord, pep:ProcedureExecution, log:Event ;
    rdfs:label "Router A Firmware Upgrade Execution Log"@en ;
    rdfs:comment "Log entry detailing the actual execution of the firmware upgrade on Router A as part of CR-2024-005."@en ;
    noria:loggingTime "2024-05-10T02:15:00Z"^^xsd:dateTime ;
    noria:logText "Firmware upgrade initiated on router-a.dc-par-01.example.com from version 16.9.5 to 17.3.4."^^xsd:string ;
    noria:logOriginatingManagedObject ex:RouterA ;
    noria:logOriginatingAgent ex:AliceSmith ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    pep:hasProcedure ex:RouterFirmwareUpgradePlan ;
    pep:hasInput ex:CR_2024_005_RouterA_Upgrade .

ex:CR_2024_005_Completion_Event
    a noria:EventRecord, pep:ProcedureExecution, log:Event ;
    rdfs:label "Router A Firmware Upgrade Completion Event"@en ;
    rdfs:comment "Event record indicating the successful completion of the firmware upgrade on Router A."@en ;
    noria:loggingTime "2024-05-10T03:45:00Z"^^xsd:dateTime ;
    noria:logText "Firmware upgrade completed successfully on router-a.dc-par-01.example.com. System rebooted."^^xsd:string ;
    noria:logOriginatingManagedObject ex:RouterA ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    noria:alarmSeverity ex:AlarmSeverityMajor ; # Could be a warning for a brief outage
    pep:hasProcedure ex:RouterFirmwareUpgradePlan ;
    pep:hasOutput ex:RouterInterfaceUpPostCond .

ex:CR_2024_005_Post_Implementation_Status
    a noria:ChangeRequest ;
    rdfs:label "Change Request for Router A Firmware Upgrade - Post Implementation"@en ;
    rdfs:comment "Updated status of the change request after successful implementation."@en ;
    dcterms:identifier "CR-2024-005"^^xsd:string ;
    noria:changeRequestActualStartTime "2024-05-10T02:10:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-05-10T03:50:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent ex:ImplementedStatus .

