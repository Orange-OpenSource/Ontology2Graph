# =============================================================================
# Additional SKOS Concepts (for completeness)
# =============================================================================

# Trouble Ticket Type Concept Scheme
<kos/TroubleTicket/type>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the nature of a trouble ticket."@en .

<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Indicates a complete or partial failure of a service or component."@en ;
    skos:inScheme <kos/TroubleTicket/type> .

# Trouble Ticket Criticity Concept Scheme
<kos/TroubleTicket/category>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Criticity Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for describing the criticity or impact category of a trouble ticket."@en .

<kos/TroubleTicket/category/TotalBreakdown>
    a skos:Concept ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Indicates a complete loss of service or functionality."@en ;
    skos:inScheme <kos/TroubleTicket/category> .

# Trouble Ticket Origin Concept Scheme
<kos/TroubleTicket/origin>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for identifying the source or initiator of a trouble ticket."@en .

<kos/TroubleTicket/origin/Supervision>
    a skos:Concept ;
    rdfs:label "Supervision System"@en ;
    rdfs:comment "The trouble ticket was automatically generated by a monitoring or supervision system."@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

# Trouble Ticket Urgency Concept Scheme
<kos/TroubleTicket/urgency>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for defining the urgency level of a trouble ticket."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action due to severe impact or critical service disruption."@en ;
    skos:inScheme <kos/TroubleTicket/urgency> .

# Trouble Ticket Problem Responsibility Concept Scheme
<kos/TroubleTicket/problemResponsibility>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for assigning responsibility for the root cause of a problem."@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks>
    a skos:Concept ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility lies with the team managing the core network infrastructure."@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

# Trouble Ticket Note Comment Type Concept Scheme
<kos/TroubleTicket/commentType>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type or provenance of a comment in a trouble ticket note."@en .

<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "A comment intended for internal team communication and not visible to external parties."@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

# Trouble Ticket Note Operation Type Concept Scheme
<kos/TroubleTicket/operationType>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type of operation or activity described in a trouble ticket note."@en .

<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "The note describes diagnostic steps taken or findings during troubleshooting."@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

<kos/TroubleTicket/operationType/CorrectiveAction>
    a skos:Concept ;
    rdfs:label "Corrective Action"@en ;
    rdfs:comment "The note describes actions taken to resolve or mitigate the issue."@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

# Change Request Category Concept Scheme
<kos/ChangeRequest/category>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Category Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the nature or purpose of a change request."@en .

<kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "A change initiated and executed by internal teams for maintenance or improvement."@en ;
    skos:inScheme <kos/ChangeRequest/category> .

# Change Request Type Concept Scheme
<kos/ChangeRequest/type>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Type Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type of change request based on its impact and risk level."@en .

<kos/ChangeRequest/type/StandardChange>
    a skos:Concept ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk and impact, following a defined procedure."@en ;
    skos:inScheme <kos/ChangeRequest/type> .

# Change Request Cause Concept Scheme
<kos/ChangeRequest/cause>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for identifying the reason or trigger for a change request."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "The change is required to upgrade software or firmware versions."@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

# Change Request Specification Concept Scheme
<kos/ChangeRequest/specification>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for referencing standard operation plans or specifications for recurring changes."@en .

<kos/ChangeRequest/specification/FirmwareUpgradeProcedure>
    a skos:Concept ;
    rdfs:label "Firmware Upgrade Procedure"@en ;
    rdfs:comment "Refers to the standard operating procedure for performing firmware upgrades on network devices."@en ;
    skos:inScheme <kos/ChangeRequest/specification> .

# SLA Level Concept Scheme
<https://w3id.org/noria/kos/application/sla-level>
    a skos:ConceptScheme ;
    rdfs:label "Application Module SLA Level Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for defining the Service Level Agreement (SLA) level for application modules."@en .

<https://w3id.org/noria/kos/application/sla-level/Platinum>
    a skos:Concept ;
    rdfs:label "Platinum SLA Level"@en ;
    rdfs:comment "Highest SLA level, indicating maximum availability and fastest response times for critical applications."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
