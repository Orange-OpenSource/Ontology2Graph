# =============================================================================
# Procedural Elements
# =============================================================================

ex:RouterRestartProcedure
    a noria:OperationPlan ;
    rdfs:label "Core Router Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for safely restarting a core router, including pre-checks and post-checks."@en ;
    noria:operationPlanPreCondition ex:RouterConnectivityCheck ;
    noria:operationPlanPostCondition ex:RouterOperationalCheck .

ex:RouterConnectivityCheck
    a noria:ActionPreCondition ;
    rdfs:label "Router Connectivity Check"@en ;
    rdfs:comment "Pre-condition: Verify network connectivity to the router management interface and adjacent devices before initiating a restart."@en .

ex:RouterOperationalCheck
    a noria:ActionPostCondition ;
    rdfs:label "Router Operational Check"@en ;
    rdfs:comment "Post-condition: Verify all interfaces are up, routing protocols converged, and traffic is flowing correctly after a router restart."@en .

ex:HighCPULoadAnomalyPattern
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing a sustained high CPU load on a server, potentially indicating a performance issue, resource exhaustion, or malicious activity."@en ;
    folio:hasConsequence "Service degradation or outage"^^xsd:string .

ex:ScriptOptimizationPlan
    a noria:OperationPlan ;
    rdfs:label "Report Script Optimization Plan"@en ;
    rdfs:comment "Procedure for optimizing the inefficient report generation script on application servers to reduce CPU consumption."@en ;
    noria:operationPlanPreCondition ex:ScriptCodeReview ;
    noria:operationPlanPostCondition ex:ScriptPerformanceValidation .

ex:ScriptCodeReview
    a noria:ActionPreCondition ;
    rdfs:label "Script Code Review"@en ;
    rdfs:comment "Pre-condition: Conduct a thorough code review of the report script to identify and address inefficiencies."@en .

ex:ScriptPerformanceValidation
    a noria:ActionPostCondition ;
    rdfs:label "Script Performance Validation"@en ;
    rdfs:comment "Post-condition: Validate that the optimized script runs efficiently, completes within expected timeframes, and does not cause high CPU load."@en .

ex:CorrectiveAction_CR01_InterfaceReset
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Corrective Action: Core Router 01 Interface Reset"@en ;
    rdfs:comment "Container for the execution of actions taken to reset the interface on Core Router 01 in response to a link down event."@en ;
    dcterms:created "2024-03-15T10:22:00Z"^^xsd:dateTime ;
    dcterms:description "Attempted interface reset on Core Router 01 Gi0/1 as a first troubleshooting step."@en ;
    pep:hasProcedure ex:RouterRestartProcedure .

ex:InterfaceResetCommandExecution
    a noria:EventRecord ;
    rdfs:label "Interface Reset Command Execution Log"@en ;
    rdfs:comment "Log of the command executed by Alice Smith to reset the router interface, part of the corrective action."@en ;
    noria:loggingTime "2024-03-15T10:22:30Z"^^xsd:dateTime ;
    noria:logText "Command 'shutdown' executed on Gi0/1 of CR01 by asmith."^^xsd:string ;
    noria:logOriginatingManagedObject ex:CoreRouter01 ;
    noria:logOriginatingAgent ex:AliceSmith ;
    pep:hasCommand "interface GigabitEthernet0/1; shutdown; no shutdown"^^xsd:string ;
    pep:hasSimpleResult "Interface Gi0/1 administratively down, then up."^^xsd:string ;
    dcterms:isPartOf ex:CorrectiveAction_CR01_InterfaceReset .
