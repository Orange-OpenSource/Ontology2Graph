# Declare prefixes
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix ssn: <http://www.w3.org/ns/ssn/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix saref: <http://ontology.tno.nl/saref#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix devopsprod: <http://w3id.org/devops-infra/product#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix ex: <http://example.com/noria-kg/> .

# =============================================================================
# SKOS Concept Schemes and Concepts (for controlled vocabularies)
# =============================================================================

# Application Types
ex:ApplicationTypeScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Application Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of applications within the NORIA knowledge graph."@en .

ex:ServicePlatform
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    skos:prefLabel "Service Platform"@en ;
    rdfs:comment "An application that provides a platform for other services."@en .

ex:InfrastructureApp
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    skos:prefLabel "Infrastructure Application"@en ;
    rdfs:comment "An application primarily supporting IT infrastructure operations."@en .

ex:BusinessApp
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    skos:prefLabel "Business Application"@en ;
    rdfs:comment "An application directly supporting core business processes."@en .

# Application Business Importance
ex:BusinessImportanceScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Application Business Importance Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the business importance of applications."@en .

ex:CriticalImportance
    a skos:Concept ;
    skos:inScheme ex:BusinessImportanceScheme ;
    skos:prefLabel "Critical"@en ;
    rdfs:comment "Application is critical for business operations, high impact on failure."@en .

ex:HighImportance
    a skos:Concept ;
    skos:inScheme ex:BusinessImportanceScheme ;
    skos:prefLabel "High"@en ;
    rdfs:comment "Application is important for business operations, significant impact on failure."@en .

ex:MediumImportance
    a skos:Concept ;
    skos:inScheme ex:BusinessImportanceScheme ;
    skos:prefLabel "Medium"@en ;
    rdfs:comment "Application has moderate importance for business operations."@en .

# Application Module SLA Level
ex:SlaLevelScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Application Module SLA Level Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying Service Level Agreement (SLA) levels for application modules."@en .

ex:SLA_Platinum
    a skos:Concept ;
    skos:inScheme ex:SlaLevelScheme ;
    skos:prefLabel "Platinum SLA"@en ;
    rdfs:comment "Highest SLA level, maximum availability and performance guarantees."@en .

ex:SLA_Gold
    a skos:Concept ;
    skos:inScheme ex:SlaLevelScheme ;
    skos:prefLabel "Gold SLA"@en ;
    rdfs:comment "High SLA level, strong availability and performance guarantees."@en .

# Application Module Status
ex:ApplicationStatusScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Application Module Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the operational status of application modules."@en .

ex:InProduction
    a skos:Concept ;
    skos:inScheme ex:ApplicationStatusScheme ;
    skos:prefLabel "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

ex:UnderDevelopment
    a skos:Concept ;
    skos:inScheme ex:ApplicationStatusScheme ;
    skos:prefLabel "Under Development"@en ;
    rdfs:comment "The application module is currently being developed or tested."@en .

# Service Types
ex:ServiceTypeScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Service Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of services."@en .

ex:CustomerFacingService
    a skos:Concept ;
    skos:inScheme ex:ServiceTypeScheme ;
    skos:prefLabel "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by external customers."@en .

ex:ResourceFacingService
    a skos:Concept ;
    skos:inScheme ex:ServiceTypeScheme ;
    skos:prefLabel "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations, not directly exposed to customers."@en .

# Trouble Ticket Severity
ex:TTSeverityScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the severity of trouble tickets."@en .

ex:Severity_Critical
    a skos:Concept ;
    skos:inScheme ex:TTSeverityScheme ;
    skos:prefLabel "Critical"@en ;
    rdfs:comment "Service completely down or major business impact."@en .

ex:Severity_Major
    a skos:Concept ;
    skos:inScheme ex:TTSeverityScheme ;
    skos:prefLabel "Major"@en ;
    rdfs:comment "Significant service degradation or partial outage."@en .

ex:Severity_Minor
    a skos:Concept ;
    skos:inScheme ex:TTSeverityScheme ;
    skos:prefLabel "Minor"@en ;
    rdfs:comment "Minor service impact or cosmetic issue."@en .

# Trouble Ticket Type
ex:TTTypeScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of trouble tickets."@en .

ex:FailureType
    a skos:Concept ;
    skos:inScheme ex:TTTypeScheme ;
    skos:prefLabel "Failure"@en ;
    rdfs:comment "Ticket related to a system or service failure."@en .

ex:AssistanceType
    a skos:Concept ;
    skos:inScheme ex:TTTypeScheme ;
    skos:prefLabel "Assistance"@en ;
    rdfs:comment "Ticket requesting user assistance or information."@en .

# Trouble Ticket Priority
<kos/TroubleTicket/priority>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the priority of trouble tickets."@en .

ex:P1
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    skos:prefLabel "Priority 1"@en ;
    rdfs:comment "Highest priority for trouble tickets, requiring immediate attention."@en .

ex:P2
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    skos:prefLabel "Priority 2"@en ;
    rdfs:comment "High priority for trouble tickets, requiring prompt attention."@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the urgency of trouble tickets."@en .

ex:ImmediateIntervention
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    skos:prefLabel "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action due to critical impact."@en .

ex:DeferredIntervention
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    skos:prefLabel "Deferred Intervention"@en ;
    rdfs:comment "Action can be deferred without immediate critical impact."@en .

# Trouble Ticket Status
ex:TTStatusScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the status of trouble tickets."@en .

ex:TT_InProgress
    a skos:Concept ;
    skos:inScheme ex:TTStatusScheme ;
    skos:prefLabel "In Progress"@en ;
    rdfs:comment "Trouble ticket is actively being worked on."@en .

ex:TT_Resolved
    a skos:Concept ;
    skos:inScheme ex:TTStatusScheme ;
    skos:prefLabel "Resolved"@en ;
    rdfs:comment "Trouble ticket issue has been resolved."@en .

# Trouble Ticket Comment Type
<kos/TroubleTicket/commentType>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Comment Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type of comments on trouble tickets."@en .

ex:InternalComment
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    skos:prefLabel "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team members only."@en .

# Trouble Ticket Operation Type
<kos/TroubleTicket/operationType>
    a skos:ConceptScheme ;
    dcterms:title "Trouble Ticket Operation Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the type of operations performed on trouble tickets."@en .

ex:DiagnosisOperation
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    skos:prefLabel "Diagnosis Operation"@en ;
    rdfs:comment "Operation related to diagnosing an issue."@en .

ex:ResolutionOperation
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    skos:prefLabel "Resolution Operation"@en ;
    rdfs:comment "Operation related to resolving an issue."@en .

# Change Request Type
ex:CRTypeScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of change requests."@en .

ex:StandardChange
    a skos:Concept ;
    skos:inScheme ex:CRTypeScheme ;
    skos:prefLabel "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk and impact."@en .

ex:NormalChange
    a skos:Concept ;
    skos:inScheme ex:CRTypeScheme ;
    skos:prefLabel "Normal Change"@en ;
    rdfs:comment "A change requiring assessment and authorization, following a defined process."@en .

# Change Request Category
<kos/ChangeRequest/category>
    a skos:ConceptScheme ;
    dcterms:title "Change Request Category Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the category of change requests."@en .

ex:SoftwareUpgrade
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    skos:prefLabel "Software Upgrade"@en ;
    rdfs:comment "Change category for software upgrades."@en .

ex:ConfigurationChange
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    skos:prefLabel "Configuration Change"@en ;
    rdfs:comment "Change category for configuration modifications."@en .

# Change Request Cause
<kos/ChangeRequest/cause>
    a skos:ConceptScheme ;
    dcterms:title "Change Request Cause Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the cause or reason for change requests."@en .

ex:PreventativeMaintenance
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    skos:prefLabel "Preventative Maintenance"@en ;
    rdfs:comment "Cause of change request related to preventative maintenance."@en .

# Change Request Status
ex:CRStatusScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Change Request Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the status of change requests."@en .

ex:CR_Approved
    a skos:Concept ;
    skos:inScheme ex:CRStatusScheme ;
    skos:prefLabel "Approved"@en ;
    rdfs:comment "Change request has been approved for implementation."@en .

ex:CR_Implemented
    a skos:Concept ;
    skos:inScheme ex:CRStatusScheme ;
    skos:prefLabel "Implemented"@en ;
    rdfs:comment "Change request has been successfully implemented."@en .

# Resource Type
ex:ResourceTypeScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of IT resources."@en .

ex:RouterType
    a skos:Concept ;
    skos:inScheme ex:ResourceTypeScheme ;
    skos:prefLabel "Router"@en ;
    rdfs:comment "A network device that forwards data packets between computer networks."@en .

ex:ServerType
    a skos:Concept ;
    skos:inScheme ex:ResourceTypeScheme ;
    skos:prefLabel "Server"@en ;
    rdfs:comment "A computer program or a device that provides functionality for other programs or devices."@en .

ex:SwitchType
    a skos:Concept ;
    skos:inScheme ex:ResourceTypeScheme ;
    skos:prefLabel "Switch"@en ;
    rdfs:comment "A network device that connects devices in a computer network by using packet switching to receive, process, and forward data to the destination device."@en .

# Resource Operational State
ex:OperationalStateScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Operational State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the operational state of resources."@en .

ex:Operational_Up
    a skos:Concept ;
    skos:inScheme ex:OperationalStateScheme ;
    skos:prefLabel "Up"@en ;
    rdfs:comment "The resource is fully operational."@en .

ex:Operational_Down
    a skos:Concept ;
    skos:inScheme ex:OperationalStateScheme ;
    skos:prefLabel "Down"@en ;
    rdfs:comment "The resource is not operational."@en .

# Resource Administrative State
ex:AdministrativeStateScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Administrative State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the administrative state of resources."@en .

ex:Administrative_Up
    a skos:Concept ;
    skos:inScheme ex:AdministrativeStateScheme ;
    skos:prefLabel "Administrative Up"@en ;
    rdfs:comment "The resource is administratively enabled."@en .

ex:Administrative_Down
    a skos:Concept ;
    skos:inScheme ex:AdministrativeStateScheme ;
    skos:prefLabel "Administrative Down"@en ;
    rdfs:comment "The resource is administratively disabled."@en .

# Resource Lifecycle State
ex:LifecycleStateScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the lifecycle state of resources."@en .

ex:InProductionState
    a skos:Concept ;
    skos:inScheme ex:LifecycleStateScheme ;
    skos:prefLabel "In Production"@en ;
    rdfs:comment "The resource is actively used in production."@en .

ex:DecommissionedState
    a skos:Concept ;
    skos:inScheme ex:LifecycleStateScheme ;
    skos:prefLabel "Decommissioned"@en ;
    rdfs:comment "The resource has been removed from service."@en .

# Notification Severity (PerceivedSeverity)
ex:PerceivedSeverityScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Notification Perceived Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the perceived severity of notifications/alarms."@en .

ex:Alarm_Critical
    a skos:Concept ;
    skos:inScheme ex:PerceivedSeverityScheme ;
    skos:prefLabel "Critical Alarm"@en ;
    rdfs:comment "An alarm indicating a critical condition requiring immediate attention."@en .

ex:Alarm_Major
    a skos:Concept ;
    skos:inScheme ex:PerceivedSeverityScheme ;
    skos:prefLabel "Major Alarm"@en ;
    rdfs:comment "An alarm indicating a major service impact."@en .

ex:Alarm_Warning
    a skos:Concept ;
    skos:inScheme ex:PerceivedSeverityScheme ;
    skos:prefLabel "Warning Alarm"@en ;
    rdfs:comment "An alarm indicating a potential issue that may lead to service impact."@en .

# Agent Contact Method
ex:AgentContactMethodScheme
    a skos:ConceptScheme ;
    dcterms:title "NORIA Agent Contact Method Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

ex:Contact_Email
    a skos:Concept ;
    skos:inScheme ex:AgentContactMethodScheme ;
    skos:prefLabel "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

ex:Contact_Phone
    a skos:Concept ;
    skos:inScheme ex:AgentContactMethodScheme ;
    skos:prefLabel "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# Event Type for Document Status History
<kos/Notification/EventType/stateChange>
    a skos:Concept ;
    skos:prefLabel "State Change Event Type"@en ;
    rdfs:comment "Event type indicating a state change for a document or entity."@en .

<kos/Notification/EventType/freezeStart>
    a skos:Concept ;
    skos:prefLabel "Freeze Start Event Type"@en ;
    rdfs:comment "Event type indicating the start of a freeze period for a document or process."@en .

# =============================================================================
# Organization and Agents
# =============================================================================

ex:OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company, serving as the overarching organization."@en ;
    org:hasUnit ex:NetworkOperationsTeam, ex:ApplicationSupportTeam .

ex:NetworkOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing and maintaining the core network infrastructure."@en ;
    org:unitOf ex:OrangeTelecom ;
    org:hasMember ex:AliceSmith ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:Contact_Phone ;
    noria:agentInstructions "For critical network issues, call the hotline directly. For non-critical, use ticketing system."@en .

ex:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business-critical applications and their underlying servers."@en ;
    org:unitOf ex:OrangeTelecom ;
    org:hasMember ex:BobJohnson ;
    noria:agentWorkingHours "8:30 AM - 4:30 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:Contact_Email ;
    noria:agentInstructions "All application issues must be reported via the internal ticketing portal."@en .

ex:AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, a key member of the Network Operations Team, specializing in routing and switching."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+33123456789" ;
    foaf:holdsAccount ex:AliceCUid .

ex:BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Specialist, a dedicated member of the Application Support Team, focusing on CRM systems."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+33987654321" ;
    foaf:holdsAccount ex:BobCUid .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique corporate identifier for Alice Smith, used for system logins and access."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountIdentifier "asmith_corp_id_123"^^xsd:string .

ex:BobCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique corporate identifier for Bob Johnson, used for system logins and access."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountIdentifier "bjohnson_corp_id_456"^^xsd:string .

# =============================================================================
# Locations
# =============================================================================

ex:DataCenterA
    a bot:Site ;
    rdfs:label "Main Data Center A"@en ;
    rdfs:comment "Primary data center facility for Orange Telecom, located in Innovation City."@en ;
    noria:siteId "DCA-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Innovation City"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    bot:hasSpace ex:ServerRoom1 .

ex:ServerRoom1
    a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "A dedicated room within Data Center A housing critical servers and network equipment, designed for optimal cooling and power."@en ;
    bot:hasZone ex:Rack1Locus, ex:Rack2Locus .

ex:Rack1Locus
    a noria:Locus ;
    rdfs:label "Rack 1, Server Room 1"@en ;
    rdfs:comment "Specific location for Rack 1 within Server Room 1, identified by line A, row 1."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

ex:Rack2Locus
    a noria:Locus ;
    rdfs:label "Rack 2, Server Room 1"@en ;
    rdfs:comment "Specific location for Rack 2 within Server Room 1, identified by line A, row 2."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

# =============================================================================
# Resources and Network Infrastructure
# =============================================================================

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "A multinational technology conglomerate that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

ex:HewlettPackardEnterprise
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "An American multinational enterprise information technology company, known for its servers and enterprise solutions."@en .

ex:CiscoNexus9K
    a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Product model for high-performance data center switches, offering advanced features for modern networks."@en ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:HPProLiantDL380
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Product model for enterprise-grade rack servers, widely used for virtualization and demanding applications."@en ;
    noria:productManufacturedBy ex:HewlettPackardEnterprise .

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary router for the data center network backbone, handling high volumes of traffic and critical routing decisions."@en ;
    noria:resourceHostName "CR01.datacenterA.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-CR01-DCA"^^xsd:string ;
    noria:resourceSerialNumber "SN-CR01-XYZ789"^^xsd:string ;
    noria:resourceType ex:RouterType ;
    noria:resourceProductModel ex:CiscoNexus9K ;
    noria:resourceUsageState ex:InProductionState ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack1Locus ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:resourceManagementIPAddress <http://10.0.0.1> ;
    noria:resourceForApplication ex:MonitoringPlatform .

ex:AppServer01
    a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting critical business applications, including the CRM system, requiring high availability and performance."@en ;
    noria:resourceHostName "APPSRV01.datacenterA.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-AS01-DCA"^^xsd:string ;
    noria:resourceSerialNumber "SN-AS01-ABC123"^^xsd:string ;
    noria:resourceType ex:ServerType ;
    noria:resourceProductModel ex:HPProLiantDL380 ;
    noria:resourceUsageState ex:InProductionState ;
    noria:resourceInstallationDate "2022-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack2Locus ;
    noria:resourceManagedBy ex:ApplicationSupportTeam ;
    noria:resourceManagementIPAddress <http://10.0.0.10> ;
    noria:resourceForApplication ex:CRMSystem ;
    noria:virtualServerStatus ex:Operational_Up ;
    noria:clusterController ex:VirtualCenter01 .

ex:EdgeSwitch01
    a noria:Resource ;
    rdfs:label "Edge Switch 01"@en ;
    rdfs:comment "Network switch connecting servers in Rack 1 to the core network, providing local area network connectivity."@en ;
