ex:SwitchB
    a noria:Resource ;
    rdfs:label "Access Switch B"@en ;
    rdfs:comment "An access layer switch providing connectivity to end-user devices and servers within Server Room A, including Server1."@en ;
    noria:resourceHostName "switch-b.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-SB-003"^^xsd:string ;
    noria:resourceSerialNumber "SN-SB-11223"^^xsd:string ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
