    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus ex:AdminState_Up ;
    noria:networkInterfaceOperationalStatus ex:OperState_Up .

ex:Link_RouterA_SwitchB
    a noria:NetworkLink ;
    rdfs:label "Link between Router A and Switch B"@en ;
    rdfs:comment "A physical network link connecting Router A's GE0/0/1 interface to Switch B's GE0/0/1 interface, forming a critical path in the data center network."@en ;
    noria:networkLinkId "NL-RA-SB-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin ex:RouterA ;
    noria:networkLinkTerminationResourceDestination ex:SwitchB ;
    noria:networkInterfaceConnects ex:RouterA_GE0_0_1, ex:SwitchB_GE0_0_1 .

ex:Link_SwitchB_Server1
    a noria:NetworkLink ;
    rdfs:label "Link between Switch B and Server 1"@en ;
    rdfs:comment "A physical network link connecting Switch B's GE0/0/2 interface to Server 1's ETH0 interface, providing network access for the CRM database."@en ;
    noria:networkLinkId "NL-SB-S1-002"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-01-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin ex:SwitchB ;
    noria:networkLinkTerminationResourceDestination ex:Server1 ;
    noria:networkInterfaceConnects ex:SwitchB_GE0_0_2, ex:Server1_ETH0 .

# --- Functional Elements ---

ex:CRMSystem
    a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:comment "The core application for managing customer data, sales, and support interactions, vital for Orange Telecom's customer service operations."@en ;
    noria:applicationModelIdentifier "CRM-APP-V3"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001^^xsd:int ;
    noria:applicationShortIdentifier "CRM"^^xsd:string ;
    noria:applicationType ex:ApplicationType_CRM ;
    noria:applicationBusinessImportance ex:BusinessImportance_Critical ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Sales & Marketing Automation"^^xsd:string ;
    noria:resourceForApplication ex:Server1 .

ex:MonitoringPlatform
    a noria:Application ;
    rdfs:label "Infrastructure Monitoring Platform"@en ;
    rdfs:comment "Application responsible for collecting metrics, logs, and alerts from IT infrastructure components, providing real-time visibility into system health and performance."@en ;
    noria:applicationModelIdentifier "MON-PLAT-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier 1002^^xsd:int ;
    noria:applicationShortIdentifier "MONITOR"^^xsd:string ;
    noria:applicationType ex:ApplicationType_Monitoring ;
    noria:applicationBusinessImportance ex:BusinessImportance_High ;
    noria:applicationFunctionalDomain "IT Operations Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Performance & Availability Monitoring"^^xsd:string .

ex:CRMSystem_Prod
    a noria:ApplicationModule ;
    rdfs:label "CRM System Production Module"@en ;
    rdfs:comment "The live production instance of the CRM system, serving end-users and processing real-time customer data. It is hosted on Server1."@en ;
    noria:applicationModuleOf ex:CRMSystem ;
    noria:applicationModuleName "CRM_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:BobJohnson ;
    noria:applicationModuleSupportTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleSupportLeader ex:BobJohnson ;
    noria:applicationModuleStatus ex:AppStatus_InProduction ;
    noria:applicationModuleHotlineEnabled true^^xsd:boolean ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime .

ex:CRMSystem_Dev
    a noria:ApplicationModule ;
    rdfs:label "CRM System Development Module"@en ;
    rdfs:comment "The development instance of the CRM system, used by developers for testing new features and bug fixes before deployment to production."@en ;
    noria:applicationModuleOf ex:CRMSystem ;
    noria:applicationModuleName "CRM_DEV"^^xsd:string ;
    noria:applicationModuleIdentifier "DEV"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ApplicationSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:BobJohnson ;
    noria:applicationModuleStatus ex:AppStatus_Development .

ex:CustomerDataService
    a noria:Service ;
    rdfs:label "Customer Data Access Service"@en ;
    rdfs:comment "An end-to-end service providing secure and reliable access to customer information, underpinned by the CRM system's production module."@en ;
    noria:serviceType ex:ServiceType_CustomerFacing ;
    seas:subSystemOf ex:CRMSystem_Prod . # A service can be composed of application modules

# --- Dynamic Elements ---

ex:Event_Server1_CPU_High
    a noria:EventRecord ;
    rdfs:label "Server1 CPU High Alert"@en ;
    rdfs:comment "An event record generated by the Monitoring Platform, indicating sustained high CPU utilization on CRM Database Server 1, potentially impacting CRM performance."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on crmdb01.example.com exceeded 90% for 5 minutes. Current usage: 95%."^^xsd:string ;
    noria:logOriginatingManagedObject ex:Server1 ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    noria:alarmSeverity ex:PerceivedSeverity_Warning .

ex:Event_RouterA_Interface_Down
    a noria:EventRecord ;
    rdfs:label "RouterA Interface Down Alert"@en ;
    rdfs:comment "An event record from the Monitoring Platform, signaling that the GigabitEthernet0/0/1 interface on Core Router A has transitioned to a 'down' operational state."@en ;
    noria:loggingTime "2024-04-23T10:15:30Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1 on router-a.example.com changed state to down. Link to Switch B is lost."^^xsd:string ;
    noria:logOriginatingManagedObject ex:RouterA ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    noria:alarmSeverity ex:PerceivedSeverity_Critical .

ex:TT_2024_001_CRM_Outage
    a noria:TroubleTicket ;
    rdfs:label "CRM System Outage - Critical"@en ;
    rdfs:comment "Trouble ticket opened due to a critical outage of the CRM system, directly impacting customer data access and sales operations. Triggered by high CPU on the database server."@en ;
    noria:documentExternalId "TT-CRM-2024-001"^^xsd:string ;
    noria:documentHRef <http://ticketing.example.com/TT-CRM-2024-001> ;
    noria:troubleTicketSeverity ex:TTSeverity_Critical ;
    noria:troubleTicketStatusCurrent ex:TTStatus_InProgress ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketTrigger ex:Event_Server1_CPU_High ;
    noria:troubleTicketRelatedService ex:CRMSystem_Prod ;
    noria:troubleTicketRelatedResource ex:Server1 ;
    noria:troubleTicketRelatedParty ex:ApplicationSupportTeam ;
    noria:troubleTicketCause "Sustained high CPU on CRM database server (crmdb01.example.com) leading to application unresponsiveness."^^xsd:string ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true^^xsd:boolean .

ex:TT_2024_001_Note_1
    a noria:TroubleTicketNote ;
    rdfs:label "CRM Outage Note - Initial Diagnosis"@en ;
    rdfs:comment "First note on the CRM outage ticket, detailing initial diagnosis steps taken by the Application Support Team."@en ;
    dcterms:isPartOf ex:TT_2024_001_CRM_Outage ;
    dcterms:creator ex:BobJohnson ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    dcterms:description "Initial checks show high CPU on crmdb01. Investigating database processes and application logs. Escalated to DB team for further analysis."^^xsd:string .

ex:CR_2024_005_RouterA_Upgrade
    a noria:ChangeRequest ;
    rdfs:label "Router A Firmware Upgrade"@en ;
    rdfs:comment "Scheduled change request for upgrading the firmware of Core Router A to address critical security vulnerabilities and improve network stability."@en ;
    noria:documentExternalId "CR-NET-2024-005"^^xsd:string ;
    noria:documentHRef <http://changemgmt.example.com/CR-NET-2024-005> ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestStatusCurrent ex:CRStatus_Approved ;
    noria:changeRequestImpact ex:RouterA ;
    noria:changeRequestInitiatorParty ex:AliceSmith ;
    noria:changeRequestPilotParty ex:AliceSmith ;
    noria:changeRequestActorParty ex:NetworkOperationsTeam ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ;
    noria:changeRequestIsRegulated true^^xsd:boolean .

# --- Procedural Elements ---

ex:RestartCRMServicePlan
    a noria:OperationPlan ;
    rdfs:label "Restart CRM Service Operation Plan"@en ;
    rdfs:comment "A standardized procedure for safely restarting the CRM application service in case of unresponsiveness or performance degradation, including steps for verification."@en ;
    noria:operationPlanPreCondition ex:CRMServiceDownPreCond ;
    noria:operationPlanPostCondition ex:CRMServiceUpPostCond .

ex:RouterFirmwareUpgradePlan
    a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Plan"@en ;
    rdfs:comment "A detailed operation plan for safely upgrading the firmware of network routers, including pre-checks, backup procedures, upgrade steps, and post-upgrade verification."@en ;
    noria:operationPlanPreCondition ex:RouterPreUpgradeChecks ;
    noria:operationPlanPostCondition ex:RouterPostUpgradeChecks .

ex:CRMServiceDownPreCond
    a noria:ActionPreCondition ;
    rdfs:label "CRM Service Unresponsive Pre-Condition"@en ;
    rdfs:comment "Condition: The CRM application is not responding to user requests or API calls, and its underlying processes on Server1 show high resource usage (e.g., CPU > 90%)."@en .

ex:CRMServiceUpPostCond
    a noria:ActionPostCondition ;
    rdfs:label "CRM Service Restored Post-Condition"@en ;
    rdfs:comment "Outcome: The CRM application is responsive, all associated services are running, users can access the system without issues, and resource utilization on Server1 is within normal parameters."@en .

ex:RouterPreUpgradeChecks
    a noria:ActionPreCondition ;
    rdfs:label "Router Pre-Upgrade Checks"@en ;
    rdfs:comment "Condition: Verify current firmware version, perform a full configuration backup, check network redundancy paths, and ensure no critical traffic is actively passing through the router before maintenance window."@en .

ex:RouterPostUpgradeChecks
    a noria:ActionPostCondition ;
    rdfs:label "Router Post-Upgrade Checks"@en ;
    rdfs:comment "Outcome: Verify new firmware version, confirm configuration integrity, test network connectivity and routing protocols, and monitor for any anomalies or performance degradation after the upgrade."@en .

# Linking Dynamic Elements to Operation Plans
ex:TT_2024_001_CRM_Outage
    pep:hasProcedure ex:RestartCRMServicePlan .

ex:CR_2024_005_RouterA_Upgrade
    pep:hasProcedure ex:RouterFirmwareUpgradePlan .

# Example of a DocumentAttachment
ex:RouterA_ConfigBackup_Doc
    a noria:DocumentAttachment ;
    rdfs:label "Router A Configuration Backup"@en ;
    rdfs:comment "A backup file of Router A's configuration before the firmware upgrade, stored as a document attachment to the change request."@en ;
    dcterms:isPartOf ex:CR_2024_005_RouterA_Upgrade ;
    dcterms:format "application/octet-stream"^^xsd:string ;
    dcterms:identifier "router-a-config-backup-20240430.cfg"^^xsd:string .

# Example of AnomalyPattern
ex:HighCPULoadAnomaly
    a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Anomaly"@en ;
    rdfs:comment "An anomaly pattern characterized by a server's CPU utilization consistently exceeding a high threshold (e.g., 90%) for an extended period (e.g., 5 minutes), often indicating a runaway process or resource contention that can lead to service degradation."@en ;
    folio:hasConsequence ex:CRMServiceOutageConsequence .

ex:CRMServiceOutageConsequence
    a folio:Consequence ;
    rdfs:label "CRM Service Outage Consequence"@en ;
    rdfs:comment "The direct consequence of the High CPU Load Anomaly, leading to the CRM system becoming unresponsive and unavailable to users, resulting in business impact."@en .

# Linking EventRecord to AnomalyPattern (as a potential detection)
ex:Event_Server1_CPU_High
    dcterms:conformsTo ex:HighCPULoadAnomaly . # Using dcterms:conformsTo as a general way to link an event to a pattern it conforms to.
