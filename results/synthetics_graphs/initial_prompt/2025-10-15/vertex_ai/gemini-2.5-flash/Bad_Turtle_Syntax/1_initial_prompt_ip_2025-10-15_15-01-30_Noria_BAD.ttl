ex:RouterA_GE0_0_1
    a noria:NetworkInterface ;
    rdfs:label "Router A GigabitEthernet0/0/1"@en ;
    rdfs:comment "Physical network interface on Core Router A, configured as an uplink connecting to Access Switch B, carrying critical data center traffic."@en ;
    noria:networkInterfaceOf ex:RouterA ;
    noria:networkInterfaceDescription "Uplink to Switch B"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus ex:AdminState_Up ;
    noria:networkInterfaceOperationalStatus ex:OperState_Up ;
    noria:networkInterfaceRoutingPriorityMetric 10^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower -3^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower -5^^xsd:int .

ex:Server1_ETH0
    a noria:NetworkInterface ;
    rdfs:label "Server 1 Ethernet0"@en ;
    rdfs:comment "Primary network interface on CRM Database Server 1, used for all database and application traffic, connecting to Access Switch B."@en ;
    noria:networkInterfaceOf ex:Server1 ;
    noria:networkInterfaceDescription "Main interface for CRM DB"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus ex:AdminState_Up ;
    noria:networkInterfaceOperationalStatus ex:OperState_Up .

ex:SwitchB_GE0_0_1
    a noria:NetworkInterface ;
    rdfs:label "Switch B GigabitEthernet0/0/1"@en ;
    rdfs:comment "Physical network interface on Access Switch B, configured as a downlink connecting to Core Router A, part of the data center's core network."@en ;
    noria:networkInterfaceOf ex:SwitchB ;
    noria:networkInterfaceDescription "Downlink from Router A"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus ex:AdminState_Up ;
    noria:networkInterfaceOperationalStatus ex:OperState_Up .

ex:SwitchB_GE0_0_2
    a noria:NetworkInterface ;
    rdfs:label "Switch B GigabitEthernet0/0/2"@en ;
    rdfs:comment "Physical network interface on Access Switch B, connecting to CRM Database Server 1."@en ;
