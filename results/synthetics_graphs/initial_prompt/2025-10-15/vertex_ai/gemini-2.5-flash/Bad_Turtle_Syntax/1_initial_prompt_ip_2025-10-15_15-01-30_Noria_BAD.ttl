    noria:resourceUsageState ex:LifecycleState_InProduction ;
    noria:resourceProductModel ex:Cisco3850 ;
    noria:resourceManagedBy ex:NetworkOperationsTeam ;
    noria:locatedAtLocus ex:Rack2_U10 ;
