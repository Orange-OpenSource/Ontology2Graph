    noria:resourceLogisticId "LOG-RA-001"^^xsd:string ;
    noria:resourceSerialNumber "SN-RA-12345"^^xsd:string ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
