# --- SKOS Concept Schemes and Concepts for controlled vocabularies ---

# Application Type
<kos/application/type>
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of applications within the IT system, such as Customer Relationship Management or Monitoring Platforms."@en .

ex:ApplicationType_CRM
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Customer Relationship Management (CRM)"@en ;
    rdfs:comment "An application designed to manage customer interactions and data throughout the customer lifecycle, from initial contact to post-sales support."@en .

ex:ApplicationType_Monitoring
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring Platform"@en ;
    rdfs:comment "A system used to observe and track the performance, health, and security of IT infrastructure, applications, and services, often generating alerts based on predefined thresholds."@en .

# Application Business Importance
<kos/application/business-importance>
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A controlled vocabulary for assessing the business criticality of applications, crucial for risk assessment and incident prioritization."@en .

ex:BusinessImportance_Critical
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Applications whose failure would lead to severe business disruption, significant financial loss, regulatory non-compliance, or major reputational damage, requiring immediate resolution."@en .

ex:BusinessImportance_High
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High"@en ;
    rdfs:comment "Applications important for core business operations, but with less immediate and severe impact than critical ones. Their unavailability can still cause significant operational issues."@en .

# Application Status
<https://w3id.org/noria/kos/application/status>
    a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the operational status of application modules, indicating their current deployment phase or state."@en .

ex:AppStatus_InProduction
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live, fully deployed, and actively serving end-users or other systems in a production environment."@en .

ex:AppStatus_Development
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Development"@en ;
    rdfs:comment "The application module is under active development, testing, or staging, and is not yet released for production use."@en .

# Service Type
<kos/service/type>
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of IT services based on their consumer or purpose."@en .

ex:ServiceType_CustomerFacing
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer-Facing Service"@en ;
    rdfs:comment "A service directly consumed or experienced by external customers, whose performance and availability directly impact customer satisfaction and business revenue."@en .

ex:ServiceType_InternalSupport
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Internal Support Service"@en ;
    rdfs:comment "A service provided to internal organizational units or employees, supporting internal business processes rather than external customers directly."@en .

# Resource Type
<kos/Resource/type>
    a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of IT resources, such as servers, routers, and switches."@en .

ex:ResourceType_Server
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computer program or a device that provides functionality for other programs or devices, called 'clients', typically hosting applications or data."@en .

ex:ResourceType_Router
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A networking device that forwards data packets between computer networks, directing traffic based on IP addresses."@en .

ex:ResourceType_Switch
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A networking device that connects devices on a computer network by using packet switching to receive, process, and forward data to the destination device within a local area network."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the lifecycle state of IT resources, indicating their current operational phase."@en .

ex:LifecycleState_InProduction
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The resource is actively used in the production environment, supporting live services and applications."@en .

ex:LifecycleState_Decommissioned
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "The resource has been removed from active service, is no longer operational, and may be awaiting disposal or repurposing."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the administrative state of network interfaces or resources, reflecting their configured status."@en .

ex:AdminState_Up
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "The administrative state is enabled, meaning the interface or resource is configured to be active."@en .

ex:AdminState_Down
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "The administrative state is disabled, meaning the interface or resource is configured to be inactive."@en .

# Resource Operational State
<kos/Resource/OperationalState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the operational state of network interfaces or resources, reflecting their current real-time status."@en .

ex:OperState_Up
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "The operational state is active and functioning, indicating that the interface or resource is currently passing traffic or performing its intended function."@en .

ex:OperState_Down
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "The operational state is inactive or not functioning, indicating a problem preventing the interface or resource from performing its intended function."@en .

# Agent Contact Method
<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents, such as individuals or teams."@en .

ex:ContactMethod_Email
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via electronic mail, suitable for non-urgent communications and documentation."@en .

ex:ContactMethod_Phone
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via telephone, typically used for urgent communications or direct discussions."@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the severity of trouble tickets, indicating the impact level of an incident."@en .

ex:TTSeverity_Critical
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Highest severity, indicating a major service outage or severe business impact, requiring immediate attention and resources."@en .

ex:TTSeverity_Major
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant service degradation or impact, but not a complete outage. Requires prompt attention to prevent escalation."@en .

# Trouble Ticket Status
<kos/TroubleTicket/status>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the current status of trouble tickets, tracking their progress through the incident management process."@en .

ex:TTStatus_InProgress
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being actively worked on by assigned personnel."@en .

ex:TTStatus_Resolved
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue described in the trouble ticket has been fixed, and the service has been restored or the problem mitigated."@en .

# Change Request Status
<kos/ChangeRequest/status>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the current status of change requests, tracking their progress through the change management lifecycle."@en .

ex:CRStatus_Approved
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "The change request has been formally approved by all necessary stakeholders and is scheduled for implementation."@en .

ex:CRStatus_Implemented
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "The change described in the change request has been successfully implemented and verified."@en .

# Notification Severity / Perceived Severity
<Notification/Severity/PerceivedSeverity>
    a skos:ConceptScheme ;
    rdfs:label "Perceived Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the perceived severity of events and alarms, indicating their urgency and impact."@en .

ex:PerceivedSeverity_Critical
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Indicates a severe, service-impacting event requiring immediate attention and often triggering an incident management process."@en .

ex:PerceivedSeverity_Warning
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Indicates a potential issue that may lead to service degradation if not addressed, serving as an early indicator of a problem."@en .

# Change Request Cause
<kos/ChangeRequest/cause>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the reasons or motivations behind initiating a change request."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "The change is initiated due to a required software or firmware upgrade, often for security, performance, or new features."@en .

# SLA Level
<https://w3id.org/noria/kos/application/sla-level>
    a skos:ConceptScheme ;
    rdfs:label "SLA Level Scheme"@en ;
    rdfs:comment "A controlled vocabulary for Service Level Agreement levels, defining the quality of service expected for an application or service."@en .

<https://w3id.org/noria/kos/application/sla-level/Platinum>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Platinum SLA Level"@en ;
    rdfs:comment "Highest service level agreement, typically implying maximum availability, fastest response times, and most comprehensive support for critical services."@en .

# --- Organizational Entities ---

ex:OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "A leading global telecommunications operator, providing a wide range of fixed, mobile, and internet services to millions of customers worldwide."@en ;
    org:hasUnit ex:NetworkOperationsTeam, ex:ApplicationSupportTeam .

ex:NetworkOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Responsible for the 24/7 monitoring, day-to-day operation, and maintenance of the core network infrastructure, ensuring high availability and performance."@en ;
    org:unitOf ex:OrangeTelecom ;
    org:hasMember ex:AliceSmith ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:ContactMethod_Phone ;
    noria:agentInstructions "For critical network issues, call the 24/7 hotline at +33123456789. For non-critical requests, use the internal ticketing system and assign to 'NETOPS'."^^xsd:string .

ex:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Provides technical support, maintenance, and incident resolution for business-critical applications, ensuring their smooth operation and user satisfaction."@en ;
    org:unitOf ex:OrangeTelecom ;
    org:hasMember ex:BobJohnson ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:ContactMethod_Email ;
    noria:agentInstructions "Submit all application-related issues via the internal support portal at support.example.com. For urgent matters, email appsupport@example.com."^^xsd:string .

ex:AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer and Team Lead for the Network Operations Team, specializing in routing and switching technologies."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+33123456789" ;
    foaf:member ex:NetworkOperationsTeam ;
    foaf:holdsAccount ex:AliceCUid .

ex:BobJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Specialist in the Application Support Team, with expertise in CRM and database systems."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+33987654321" ;
    foaf:member ex:ApplicationSupportTeam ;
    foaf:holdsAccount ex:BobCUid .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for Alice Smith, used for secure access to Orange Telecom's IT resources and systems."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "CUID-ASMITH-001"^^xsd:string .

ex:BobCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for Bob Johnson, enabling his access to application management tools and databases."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "CUID-BJOHNSON-002"^^xsd:string .

# --- Location Entities ---

ex:DataCenterParis
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility located in Paris, France, hosting critical IT infrastructure for Orange Telecom's European operations."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    bot:hasSpace ex:ServerRoomA .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated, climate-controlled room within the Paris Data Center, specifically designed for housing server racks and networking equipment."@en ;
    bot:hasSpace ex:Rack1_U23, ex:Rack2_U10, ex:Rack2_U11 .

ex:Rack1_U23
    a noria:Locus ;
    rdfs:label "Rack 1, Unit 23"@en ;
    rdfs:comment "Specific physical location within Server Room A, Rack 1, Unit 23, where the CRM Database Server 1 is securely installed."@en ;
    noria:locusLine "R1"^^xsd:string ;
    noria:locusRow "U23"^^xsd:string .

ex:Rack2_U10
    a noria:Locus ;
    rdfs:label "Rack 2, Unit 10"@en ;
    rdfs:comment "Specific physical location within Server Room A, Rack 2, Unit 10, designated for the Core Router A."@en ;
    noria:locusLine "R2"^^xsd:string ;
    noria:locusRow "U10"^^xsd:string .

ex:Rack2_U11
    a noria:Locus ;
    rdfs:label "Rack 2, Unit 11"@en ;
    rdfs:comment "Specific physical location within Server Room A, Rack 2, Unit 11, where the Access Switch B is installed, directly below the Core Router A."@en ;
    noria:locusLine "R2"^^xsd:string ;
    noria:locusRow "U11"^^xsd:string .

# --- Structural Elements ---

ex:Cisco3850
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 3850 Series Switch"@en ;
    rdfs:comment "A series of enterprise-class stackable access layer switches that provide full convergence between wired and wireless on a single platform, known for high performance and security features."@en ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:HPProLiantDL380
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10 Server"@en ;
    rdfs:comment "A versatile 2U rack server designed for various workloads and environments, offering a balance of performance, expandability, and reliability for data-intensive applications."@en ;
    noria:productManufacturedBy ex:HewlettPackardEnterprise .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en ;
    rdfs:comment "An American multinational technology conglomerate that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products globally."@en .

ex:HewlettPackardEnterprise
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise (HPE)"@en ;
    rdfs:comment "An American multinational enterprise information technology company that provides servers, storage, networking, consulting and support services to businesses worldwide."@en .

ex:RouterA
    a noria:Resource ;
    rdfs:label "Core Router A"@en ;
