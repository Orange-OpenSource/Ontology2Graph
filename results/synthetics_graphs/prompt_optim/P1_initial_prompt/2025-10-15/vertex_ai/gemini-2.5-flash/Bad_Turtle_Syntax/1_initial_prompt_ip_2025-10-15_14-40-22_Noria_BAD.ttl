@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix ex: <http://example.com/data/> .
@prefix kos: <https://w3id.org/noria/kos/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix gn: <https://www.geonames.org/ontology#> .

# =============================================================================
# SKOS Concept Schemes and Concepts
# =============================================================================

kos:application/type
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of applications."@en .

kos:application/type/CustomerFacing
    a skos:Concept ;
    skos:inScheme kos:application/type ;
    rdfs:label "Customer Facing Application"@en ;
    rdfs:comment "An application directly used by external customers."@en .

kos:application/type/BackendService
    a skos:Concept ;
    skos:inScheme kos:application/type ;
    rdfs:label "Backend Service Application"@en ;
    rdfs:comment "An application providing backend services, not directly exposed to end-users."@en .

kos:application/business-importance
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A controlled vocabulary for assessing the business importance of applications."@en .

kos:application/business-importance/Critical
    a skos:Concept ;
    skos:inScheme kos:application/business-importance ;
    rdfs:label "Critical Business Importance"@en ;
    rdfs:comment "Application is critical for core business operations."@en .

kos:application/status
    a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the operational status of application modules."@en .

kos:application/status/InProduction
    a skos:Concept ;
    skos:inScheme kos:application/status ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

kos:TroubleTicket/severity
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the severity of trouble tickets."@en .

kos:TroubleTicket/severity/Major
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/severity ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "A significant incident impacting service, but not a total outage."@en .

kos:TroubleTicket/type
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of trouble tickets."@en .

kos:TroubleTicket/type/Failure
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/type ;
    rdfs:label "Failure Ticket"@en ;
    rdfs:comment "Indicates a component or service failure."@en .

kos:TroubleTicket/priority
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the priority of trouble tickets."@en .

kos:TroubleTicket/priority/P1
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/priority ;
    rdfs:label "Priority 1 (P1)"@en ;
    rdfs:comment "Highest priority, requiring immediate attention."@en .

kos:TroubleTicket/origin
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the origin of trouble tickets."@en .

kos:TroubleTicket/origin/Supervision
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/origin ;
    rdfs:label "Supervision System Origin"@en ;
    rdfs:comment "Ticket originated from an automated monitoring or supervision system."@en .

kos:TroubleTicket/urgency
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the urgency of trouble tickets."@en .

kos:TroubleTicket/urgency/ImmediateIntervention
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/urgency ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action to resolve the issue."@en .

kos:TroubleTicket/trouble-category
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme"@en ;
    rdfs:comment "A controlled vocabulary for categorizing the nature of trouble."@en .

kos:TroubleTicket/trouble-category/TotalBreakdown
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/trouble-category ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Indicates a complete failure of a system or service."@en .

kos:TroubleTicket/problemResponsibility
    a skos:ConceptScheme ;
    rdfs:label "Problem Responsibility Scheme"@en ;
    rdfs:comment "A controlled vocabulary for assigning responsibility for a problem."@en .

kos:TroubleTicket/problemResponsibility/ManagedBackboneNetworks
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/problemResponsibility ;
    rdfs:label "Managed Backbone Networks Responsibility"@en ;
    rdfs:comment "Responsibility lies with the team managing backbone network infrastructure."@en .

kos:TroubleTicket/status
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the current status of trouble tickets."@en .

kos:TroubleTicket/status/InProgress
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/status ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

kos:TroubleTicket/commentType
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Comment Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of comments on trouble tickets."@en .

kos:TroubleTicket/commentType/Internal
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/commentType ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "A comment intended for internal team use."@en .

kos:TroubleTicket/operationType
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Operation Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of operations performed on trouble tickets."@en .

kos:TroubleTicket/operationType/Diagnosis
    a skos:Concept ;
    skos:inScheme kos:TroubleTicket/operationType ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "An operation related to diagnosing the root cause of an issue."@en .

kos:ChangeRequest/category
    a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A controlled vocabulary for categorizing change requests."@en .

kos:ChangeRequest/category/InternalIntervention
    a skos:Concept ;
    skos:inScheme kos:ChangeRequest/category ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "A change request for an intervention performed by internal teams."@en .

kos:ChangeRequest/type
    a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of change requests."@en .

kos:ChangeRequest/type/Standard
    a skos:Concept ;
    skos:inScheme kos:ChangeRequest/type ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with a low risk and well-defined procedure."@en .

kos:ChangeRequest/cause
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the causes or reasons for change requests."@en .

kos:ChangeRequest/cause/Configuration
    a skos:Concept ;
    skos:inScheme kos:ChangeRequest/cause ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change related to system configuration updates."@en .

kos:ChangeRequest/status
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the current status of change requests."@en .

kos:ChangeRequest/status/Approved
    a skos:Concept ;
    skos:inScheme kos:ChangeRequest/status ;
    rdfs:label "Approved Change"@en ;
    rdfs:comment "The change request has been approved for implementation."@en .

kos:Resource/type
    a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of IT resources."@en .

kos:Resource/type/WebServer
    a skos:Concept ;
    skos:inScheme kos:Resource/type ;
    rdfs:label "Web Server"@en ;
    rdfs:comment "A server hosting web applications."@en .

kos:Resource/type/DatabaseServer
    a skos:Concept ;
    skos:inScheme kos:Resource/type ;
    rdfs:label "Database Server"@en ;
    rdfs:comment "A server hosting database services."@en .

kos:Resource/type/NetworkRouter
    a skos:Concept ;
    skos:inScheme kos:Resource/type ;
    rdfs:label "Network Router"@en ;
    rdfs:comment "A network device that forwards data packets between computer networks."@en .

kos:Resource/LifecycleState
    a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the lifecycle state of resources."@en .

kos:Resource/LifecycleState/InUse
    a skos:Concept ;
    skos:inScheme kos:Resource/LifecycleState ;
    rdfs:label "In Use"@en ;
    rdfs:comment "The resource is actively being used in production."@en .

kos:Resource/OperationalState
    a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the operational state of resources or interfaces."@en .

kos:Resource/OperationalState/Up
    a skos:Concept ;
    skos:inScheme kos:Resource/OperationalState ;
    rdfs:label "Up"@en ;
    rdfs:comment "The resource or interface is operational."@en .

kos:Resource/OperationalState/Down
    a skos:Concept ;
    skos:inScheme kos:Resource/OperationalState ;
    rdfs:label "Down"@en ;
    rdfs:comment "The resource or interface is not operational."@en .

kos:Resource/AdministrativeState
    a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the administrative state of resources or interfaces."@en .

kos:Resource/AdministrativeState/Up
    a skos:Concept ;
    skos:inScheme kos:Resource/AdministrativeState ;
    rdfs:label "Administratively Up"@en ;
    rdfs:comment "The resource or interface is administratively enabled."@en .

kos:Notification/EventType
    a skos:ConceptScheme ;
    rdfs:label "Notification Event Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of event notifications."@en .

kos:Notification/EventType/StateChange
    a skos:Concept ;
    skos:inScheme kos:Notification/EventType ;
    rdfs:label "State Change Event"@en ;
    rdfs:comment "An event indicating a change in the state of a managed object."@en .

kos:Notification/EventType/ThresholdExceeded
    a skos:Concept ;
    skos:inScheme kos:Notification/EventType ;
    rdfs:label "Threshold Exceeded Event"@en ;
    rdfs:comment "An event indicating that a monitored metric has exceeded a defined threshold."@en .

kos:Notification/Severity/PerceivedSeverity
    a skos:ConceptScheme ;
    rdfs:label "Perceived Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the perceived severity of alarms."@en .

kos:Notification/Severity/PerceivedSeverity/Critical
    a skos:Concept ;
    skos:inScheme kos:Notification/Severity/PerceivedSeverity ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Indicates a critical condition requiring immediate corrective action."@en .

kos:Notification/Severity/PerceivedSeverity/Major
    a skos:Concept ;
    skos:inScheme kos:Notification/Severity/PerceivedSeverity ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Indicates a major service-affecting condition."@en .

kos:service/type
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of services."@en .

kos:service/type/CustomerFacingService
    a skos:Concept ;
    skos:inScheme kos:service/type ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by customers."@en .

kos:org/agent-contact-method
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

kos:org/agent-contact-method/Email
    a skos:Concept ;
    skos:inScheme kos:org/agent-contact-method ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

# =============================================================================
# Organizations and Agents
# =============================================================================

ex:TechCorp
    a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "A leading technology company providing digital services."@en ;
    org:hasUnit ex:NetOpsTeam, ex:AppSupportTeam .

ex:NetOpsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Responsible for the maintenance and operation of the network infrastructure."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. For non-critical, open a ticket."^^xsd:string .

ex:AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Responsible for the support and maintenance of business applications."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email ;
    noria:agentInstructions "All application issues must be reported via the ticketing system."^^xsd:string .

ex:AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer, member of the Network Operations Team."@en ;
    org:memberOf ex:NetOpsTeam ;
    foaf:mbox <mailto:alice.smith@techcorp.com> ;
    foaf:holdsAccount ex:AliceCUid ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email .

ex:BobJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Specialist, member of the Application Support Team."@en ;
    org:memberOf ex:AppSupportTeam ;
    foaf:mbox <mailto:bob.johnson@techcorp.com> ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod kos:org/agent-contact-method/Email .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "The corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "U12345"^^xsd:string .

# =============================================================================
# Locations
# =============================================================================

ex:MainDataCenter
    a bot:Site ;
    rdfs:label "TechCorp Main Data Center"@en ;
    rdfs:comment "The primary data center facility for TechCorp's operations."@en ;
    noria:siteId "DC-MAIN-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 TechCorp Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    bot:containsZone ex:ServerRoomA .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated server room within the Main Data Center."@en ;
    bot:hasSubSpace ex:Rack12Locus .

ex:Rack12Locus
    a noria:Locus ;
    rdfs:label "Rack 12 Locus"@en ;
    rdfs:comment "Specific location within Server Room A, Rack 12."@en ;
    noria:locusLine "L"^^xsd:string ;
    noria:locusRow "12"^^xsd:string .

# =============================================================================
# Applications and Services
# =============================================================================

ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "The main web application for customer interaction and service management."@en ;
    noria:applicationModelIdentifier "CP-V2.0"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001^^xsd:int ;
    noria:applicationShortIdentifier "CPORTAL"^^xsd:string ;
    noria:applicationType kos:application/type/CustomerFacing ;
    noria:applicationBusinessImportance kos:application/business-importance/Critical ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Customer Self-Service"@en .

ex:CustomerPortalProdModule
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "The production instance of the Customer Portal Application."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "CPORTAL_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-01"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:AppSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:BobJohnson ;
    noria:applicationModuleSupportTeam ex:AppSupportTeam ;
    noria:applicationModuleSupportLeader ex:BobJohnson ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true^^xsd:boolean ;
    noria:applicationModuleStatus kos:application/status/InProduction .

ex:WebAccessService
    a noria:Service ;
    rdfs:label "Web Access Service"@en ;
    rdfs:comment "An end-to-end service providing web access to customers, underpinned by the Customer Portal."@en ;
    noria:serviceType kos:service/type/CustomerFacingService ;
    seas:subSystemOf ex:CustomerPortalProdModule . # A service can be a subsystem of an application module.

# =============================================================================
# Infrastructure (Resources, Product Models, Network Interfaces, Links)
# =============================================================================

ex:HPProLiantDL380
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Product model for a standard enterprise server."@en ;
    noria:productManufacturedBy ex:HewlettPackardEnterprise .

ex:HewlettPackardEnterprise
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

ex:CiscoCatalyst9k
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300 Series"@en ;
    rdfs:comment "Product model for a high-performance network switch/router."@en ;
    noria:productManufacturedBy ex:CiscoSystems .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

ex:WebServer01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "A server hosting the Customer Portal application."@en ;
    noria:resourceLogisticId "ASSET-WEB-001"^^xsd:string ;
    noria:resourceHostName "webserver01.techcorp.com"^^xsd:string ;
    noria:resourceProductModel ex:HPProLiantDL380 ;
    noria:resourceType kos:Resource/type/WebServer ;
    noria:resourceSerialNumber "SN123456789"^^xsd:string ;
    noria:resourceUsageState kos:Resource/LifecycleState/InUse ;
    noria:resourceInstallationDate "2022-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalApp ;
    noria:locatedAtLocus ex:Rack12Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> ;
    noria:resourceManagedBy ex:AppSupportTeam ;
    bot:hasElement ex:Rack12Locus . # Inverse of locatedAtLocus, but bot:hasElement is from bot:Space to bot:Element.

ex:DatabaseServer01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "A server hosting the database for the Customer Portal application."@en ;
    noria:resourceLogisticId "ASSET-DB-001"^^xsd:string ;
    noria:resourceHostName "dbserver01.techcorp.com"^^xsd:string ;
    noria:resourceProductModel ex:HPProLiantDL380 ;
    noria:resourceType kos:Resource/type/DatabaseServer ;
    noria:resourceSerialNumber "SN987654321"^^xsd:string ;
    noria:resourceUsageState kos:Resource/LifecycleState/InUse ;
    noria:resourceInstallationDate "2022-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication ex:CustomerPortalApp ;
    noria:locatedAtLocus ex:Rack12Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.11> ;
    noria:resourceManagedBy ex:AppSupportTeam .

ex:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "A core network router providing connectivity for the data center."@en ;
    noria:resourceLogisticId "ASSET-RTR-001"^^xsd:string ;
    noria:resourceHostName "corerouter01.techcorp.com"^^xsd:string ;
    noria:resourceProductModel ex:CiscoCatalyst9k ;
    noria:resourceType kos:Resource/type/NetworkRouter ;
    noria:resourceSerialNumber "SNABCDEF123"^^xsd:string ;
    noria:resourceUsageState kos:Resource/LifecycleState/InUse ;
    noria:resourceInstallationDate "2021-06-15T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack12Locus ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> ;
    noria:resourceManagedBy ex:NetOpsTeam .

ex:WebServer01Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebServer01 Ethernet 0"@en ;
    rdfs:comment "The primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf ex:WebServer01 ;
    noria:networkInterfaceDescription "Primary interface to application network"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up .

ex:DatabaseServer01Eth0
    a noria:NetworkInterface ;
    rdfs:label "DatabaseServer01 Ethernet 0"@en ;
    rdfs:comment "The primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf ex:DatabaseServer01 ;
    noria:networkInterfaceDescription "Primary interface to application network"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up .

ex:CoreRouter01Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "An uplink interface on Core Router 01."@en ;
    noria:networkInterfaceOf ex:CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to Internet Service Provider"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus kos:Resource/AdministrativeState/Up ;
    noria:networkInterfaceOperationalStatus kos:Resource/OperationalState/Up ;
    noria:networkInterfaceRoutingPriorityMetric 100^^xsd:int .

ex:LinkWebServerDB
    a noria:NetworkLink ;
    rdfs:label "Link between WebServer01 and DatabaseServer01"@en ;
    rdfs:comment "A direct network link connecting the web server to the database server."@en ;
    noria:networkLinkId "LINK-WEB-DB-01"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin ex:WebServer01 ;
    noria:networkLinkTerminationResourceDestination ex:DatabaseServer01 ;
    noria:networkLinkInstallationDate "2022-03-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"^^xsd:string ;
    noria:networkInterfaceConnects ex:WebServer01Eth0, ex:DatabaseServer01Eth0 ;
    noria:resourceManagedBy ex:NetOpsTeam .

ex:LinkRouterToInternet
    a noria:NetworkLink ;
    rdfs:label "Link from CoreRouter01 to Internet"@en ;
    rdfs:comment "The primary internet uplink from the data center core router."@en ;
    noria:networkLinkId "LINK-RTR-ISP-01"^^xsd:string ;
    noria:networkLinkTerminationResource ex:CoreRouter01 ;
    noria:networkLinkInstallationDate "2021-06-15T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:networkInterfaceConnects ex:CoreRouter01Gi0_0_1 ;
    noria:resourceManagedBy ex:NetOpsTeam .

