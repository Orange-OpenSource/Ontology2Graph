ex:RestartWebServerProcedure
    a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "A standard operating procedure to restart the web server application services."@en ;
    noria:operationPlanPreCondition ex:HighCPULoadPrecondition ;
    noria:operationPlanPostCondition ex:CPULoadNormalPostcondition .

ex:HighCPULoadPrecondition
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Load Precondition"@en ;
    rdfs:comment "Condition where the CPU utilization on a web server is consistently above a high threshold."@en .

ex:CPULoadNormalPostcondition
    a noria:ActionPostCondition ;
    rdfs:label "CPU Load Normal Postcondition"@en ;
    rdfs:comment "Condition where the CPU utilization on a web server returns to normal operating levels."@en .

ex:HighCPULoadAnomalyPattern
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "A pattern describing a recurring anomaly of high CPU load, potentially indicating a software bug or resource exhaustion."@en ;
    folio:hasCause ex:SoftwareBugCause . # Assuming a new concept for Software Bug Cause

ex:SoftwareBugCause
    a folio:Cause ;
    rdfs:label "Software Bug Cause"@en ;
    rdfs:comment "A cause indicating a defect in software code."@en .

