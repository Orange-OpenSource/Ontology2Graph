ex:WebAccessService
    a noria:Service ;
    rdfs:label "Customer Web Access Service"@en ;
    rdfs:comment "The end-to-end service enabling customers to access their portal online."@en ;
    noria:serviceType ex:kos/service/type/CustomerFacingService ;
    seas:subSystemOf ex:CustomerPortalProdModule . # A service can be composed of application modules

# Link resources to applications
ex:WebServer01 noria:resourceForApplication ex:CustomerPortalApp .
ex:DBServer01 noria:resourceForApplication ex:CustomerPortalApp .

# --- Events and Documentation ---

ex:CPUAlertWebServer
    a noria:EventRecord ;
    rdfs:label "High CPU Alert on WebServer01"@en ;
    rdfs:comment "An event record indicating high CPU utilization on WebServer01, detected by the monitoring system."@en ;
    noria:loggingTime "2024-04-23T14:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on webserver01.techcorp.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject ex:WebServer01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystem ;
    noria:alarmSeverity ex:kos/Notification/Severity/PerceivedSeverity/Critical .

ex:TT_CustomerPortal_HighCPU
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket: High CPU on Customer Portal Web Server"@en ;
    rdfs:comment "An incident ticket opened due to critical CPU alert affecting the Customer Portal."@en ;
    dcterms:identifier "TT-20240423-001"^^xsd:string ;
    dcterms:created "2024-04-23T14:10:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CUSTPORTAL-INC-001"^^xsd:string ;
    noria:documentHRef <http://itsm.techcorp.com/tickets/TT-20240423-001> ;
    noria:troubleTicketSeverity ex:kos/TroubleTicket/severity/Major ;
    noria:troubleTicketType ex:kos/TroubleTicket/type/Incident ;
    noria:troubleTicketStatusCurrent ex:kos/TroubleTicket/status/InProgress ;
    noria:troubleTicketTrigger ex:CPUAlertWebServer ;
    noria:troubleTicketRelatedService ex:CustomerPortalProdModule ;
    noria:troubleTicketRelatedResource ex:WebServer01 ;
    noria:troubleTicketDetectionDateTime "2024-04-23T14:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T16:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedParty ex:ITOperationsTeam .

ex:TTNote_Diagnosis
    a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket Note: Initial Diagnosis"@en ;
    rdfs:comment "Initial diagnosis steps performed for the high CPU incident."@en ;
    dcterms:created "2024-04-23T14:20:00Z"^^xsd:dateTime ;
    dcterms:creator ex:JohnDoe ;
    dcterms:isPartOf ex:TT_CustomerPortal_HighCPU ;
    noria:logText "Checked running processes, identified a runaway script. Terminated the script. CPU returned to normal."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ; # Assuming this KOS exists in Noria
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> . # Assuming this KOS exists in Noria

ex:CR_WebServerPatch
    a noria:ChangeRequest ;
    rdfs:label "Change Request: Apply Patch to WebServer01"@en ;
    rdfs:comment "Change request to apply a critical security patch to WebServer01 to prevent future high CPU incidents."@en ;
    dcterms:identifier "CR-20240425-001"^^xsd:string ;
    dcterms:created "2024-04-25T09:00:00Z"^^xsd:dateTime ;
    noria:documentExternalId "SEC-PATCH-WS01"^^xsd:string ;
    noria:documentHRef <http://itsm.techcorp.com/changes/CR-20240425-001> ;
    noria:changeRequestType ex:kos/ChangeRequest/type/Standard ;
    noria:changeRequestStatusCurrent ex:kos/ChangeRequest/status/Approved ;
    noria:changeRequestCause ex:kos/ChangeRequest/cause/SoftwareUpgrade ;
    noria:changeRequestImpact ex:WebServer01 ;
    noria:changeRequestPlannedStartTime "2024-04-28T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-28T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestOutageDuration "PT1H"^^xsd:duration ;
    noria:changeRequestInitiatorParty ex:JaneSmith ;
    noria:changeRequestPilotParty ex:JohnDoe .

ex:PatchingProcedure
    a noria:OperationPlan ;
    rdfs:label "Web Server Patching Procedure"@en ;
    rdfs:comment "A standardized procedure for applying security patches to web servers."@en ;
    noria:operationPlanPreCondition ex:PreCond_Backup ;
    noria:operationPlanPostCondition ex:PostCond_ServiceRestored .

ex:PreCond_Backup
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: System Backup Completed"@en ;
    rdfs:comment "Ensures a full system backup is completed before starting the patching operation."@en .

ex:PostCond_ServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Service Functionality Restored"@en ;
    rdfs:comment "Verifies that the web service is fully functional and accessible after patching."@en .

ex:CR_WebServerPatch noria:actionCorrelatedOperationPlan ex:PatchingProcedure .

ex:PatchLogAttachment
    a noria:DocumentAttachment ;
    rdfs:label "Patching Log File"@en ;
    rdfs:comment "Log file detailing the steps and output of the web server patching process."@en ;
    dcterms:identifier "patch-log-WS01-20240428.txt"^^xsd:string ;
    dcterms:isPartOf ex:CR_WebServerPatch .

