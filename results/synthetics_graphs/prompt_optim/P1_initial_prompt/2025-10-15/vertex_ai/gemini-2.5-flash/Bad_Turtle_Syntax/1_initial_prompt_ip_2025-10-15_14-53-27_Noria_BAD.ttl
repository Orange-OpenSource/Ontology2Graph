# --- Applications and Services ---

ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "Customer Portal Application"@en ;
    rdfs:comment "The main web application allowing customers to manage their accounts and services."@en ;
    noria:applicationModelIdentifier "CP-V2.0"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001^^xsd:int ;
    noria:applicationShortIdentifier "CustPortal"^^xsd:string ;
    noria:applicationType ex:kos/application/type/WebApplication ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ; # Assuming this KOS exists in Noria
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Online Account Management"@en .

ex:MonitoringSystem
    a noria:Application ;
    rdfs:label "Infrastructure Monitoring System"@en ;
    rdfs:comment "The system responsible for collecting metrics and generating alerts for IT infrastructure."@en ;
    noria:applicationModelIdentifier "Zabbix-Prod"^^xsd:string ;
    noria:applicationShortIdentifier "Zabbix"^^xsd:string ;
    noria:applicationType ex:kos/application/type/MonitoringSystem .

ex:CustomerPortalProdModule
    a noria:ApplicationModule ;
