# --- SKOS Concepts for controlled vocabularies ---

# Application Types
ex:kos/application/type/WebApplication
    a skos:Concept ;
    rdfs:label "Web Application"@en ;
    rdfs:comment "A software application accessible over a network, typically via a web browser."@en .

ex:kos/application/type/MonitoringSystem
    a skos:Concept ;
    rdfs:label "Monitoring System"@en ;
    rdfs:comment "An application designed to observe and track the status and performance of other systems or resources."@en .

# Trouble Ticket Severity
ex:kos/TroubleTicket/severity/Major
    a skos:Concept ;
    rdfs:label "Major"@en ;
    rdfs:comment "Indicates a significant service degradation or outage affecting a substantial number of users or critical business functions."@en .

# Trouble Ticket Type
ex:kos/TroubleTicket/type/Incident
    a skos:Concept ;
    rdfs:label "Incident"@en ;
    rdfs:comment "An unplanned interruption to an IT service or reduction in the quality of an IT service."@en .

# Trouble Ticket Status
ex:kos/TroubleTicket/status/InProgress
    a skos:Concept ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being actively worked on by a support team."@en .

# Change Request Type
ex:kos/ChangeRequest/type/Standard
    a skos:Concept ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-authorized change that is low risk, relatively common, and follows a procedure or work instruction."@en .

# Change Request Status
ex:kos/ChangeRequest/status/Approved
    a skos:Concept ;
    rdfs:label "Approved"@en ;
    rdfs:comment "The change request has been reviewed and authorized for implementation."@en .

# Change Request Cause
ex:kos/ChangeRequest/cause/SoftwareUpgrade
    a skos:Concept ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "The change is necessitated by an upgrade to software components."@en .

# Resource Types
ex:kos/Resource/type/WebServer
    a skos:Concept ;
    rdfs:label "Web Server"@en ;
    rdfs:comment "A server that hosts websites and web applications."@en .

ex:kos/Resource/type/DatabaseServer
    a skos:Concept ;
    rdfs:label "Database Server"@en ;
    rdfs:comment "A server dedicated to running database management systems and storing data."@en .

ex:kos/Resource/type/NetworkRouter
    a skos:Concept ;
    rdfs:label "Network Router"@en ;
    rdfs:comment "A networking device that forwards data packets between computer networks."@en .

# Resource Lifecycle State
ex:kos/Resource/LifecycleState/InProduction
    a skos:Concept ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The resource is actively used in a live operational environment."@en .

# Resource Operational State
ex:kos/Resource/OperationalState/Up
    a skos:Concept ;
    rdfs:label "Up"@en ;
    rdfs:comment "The resource or component is currently operational and functioning as expected."@en .

ex:kos/Resource/OperationalState/Down
    a skos:Concept ;
    rdfs:label "Down"@en ;
    rdfs:comment "The resource or component is currently not operational or functioning."@en .

# Resource Administrative State
ex:kos/Resource/AdministrativeState/Up
    a skos:Concept ;
    rdfs:label "Administrative Up"@en ;
    rdfs:comment "The resource or component is administratively enabled."@en .

# Service Type
ex:kos/service/type/CustomerFacingService
    a skos:Concept ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed or experienced by external customers."@en .

# Notification Severity
ex:kos/Notification/Severity/PerceivedSeverity/Critical
    a skos:Concept ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Indicates a severe condition requiring immediate attention, often leading to service outage."@en .

# --- Organizations and People ---

ex:TechCorp
    a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "A leading technology company providing innovative digital services."@en .

ex:ITOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "The team responsible for the day-to-day operation and maintenance of TechCorp's IT infrastructure."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "9:00 AM - 5:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "For critical issues, use the emergency hotline. Otherwise, open a ticket in the ITSM system."@en .

ex:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior System Administrator at TechCorp, specializing in web infrastructure."@en ;
    org:memberOf ex:ITOperationsTeam .

ex:JohnDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"@en ;
    foaf:holdsAccount ex:JohnDoe .

ex:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network Engineer at TechCorp, responsible for core network infrastructure."@en ;
    org:memberOf ex:ITOperationsTeam .

ex:JaneSmithCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "The unique corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"@en ;
    foaf:holdsAccount ex:JaneSmith .

# --- Locations ---

