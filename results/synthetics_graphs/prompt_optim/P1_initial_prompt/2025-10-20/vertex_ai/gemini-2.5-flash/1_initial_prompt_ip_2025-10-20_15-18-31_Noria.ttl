# =============================================================================
# Procedural Elements
# =============================================================================

ex:RouterFailoverPlan a noria:OperationPlan ;
    rdfs:label "Core Router Failover Procedure"@en ;
    rdfs:comment "A documented procedure for handling failover scenarios on core routers."@en .

ex:CRMRestartProcedure a noria:OperationPlan ;
    rdfs:label "CRM Application Restart Procedure"@en ;
    rdfs:comment "A documented procedure for restarting the CRM application services."@en .

ex:RouterDownPreCond a noria:ActionPreCondition ;
    rdfs:label "Router Interface Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition: A critical router interface is in a 'down' operational state."@en .

ex:ServiceRestoredPostCond a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: The affected service is fully restored and operational."@en .

ex:HighLatencyAnomaly a noria:AnomalyPattern ;
    rdfs:label "High Latency Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating network latency exceeding predefined thresholds, potentially affecting critical services."@en .

ex:RouterFailoverPlan noria:operationPlanPreCondition ex:RouterDownPreCond ;
    noria:operationPlanPostCondition ex:ServiceRestoredPostCond .

# Linking events to procedures and tickets
ex:SFPReplacementAction a pep:CorrectiveMaintenanceAction ;
    rdfs:label "SFP Module Replacement Action"@en ;
    rdfs:comment "Action taken to replace a faulty SFP module, resolving the router interface issue."@en ;
    noria:actionCorrelatedOperationPlan ex:RouterFailoverPlan ;
    dcterms:isPartOf ex:TT_20240315_001 .

ex:SFPReplacementExecutionContainer a pep:ProcedureExecutionContainer ;
    rdfs:label "SFP Replacement Execution Container"@en ;
    rdfs:comment "Container for the SFP replacement action related to TT-20240315-001."@en ;
    pep:hasExecution ex:SFPReplacementAction .

ex:RouterDownEvent noria:alarmMitigatedBy ex:TT_20240315_001 .
ex:TT_20240315_001_Note2 noria:troubleTicketNoteCorrelatedExecution ex:SFPReplacementExecutionContainer .

