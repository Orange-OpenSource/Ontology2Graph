# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/> .  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/> .  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/> .  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#> .  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# --- Example.com ---
@prefix ex: <http://example.com/noria-kg/> .

# =============================================================================
# SKOS Concept Schemes (as referenced in NORIA schema)
# =============================================================================

<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Application Types."@en .

<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Application Business Importance."@en .

<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Trouble Ticket Severity."@en .

<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Trouble Ticket Types."@en .

<kos/TroubleTicket/priority> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Trouble Ticket Priority."@en .

<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Trouble Ticket Origin."@en .

<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Trouble Ticket Status."@en .

<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Comment Type KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Trouble Ticket Comment Types."@en .

<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Operation Type KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Trouble Ticket Operation Types."@en .

<kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Change Request Categories."@en .

<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Change Request Causes."@en .

<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Change Request Types."@en .

<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Change Request Status."@en .

<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Resource Types."@en .

<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Resource Lifecycle States."@en .

<kos/application/sla-level> a skos:ConceptScheme ;
    rdfs:label "Application SLA Level KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Application SLA Levels."@en .

<kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Status KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Application Status."@en .

<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Service Types."@en .

<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Resource Operational States."@en .

<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Resource Administrative States."@en .

<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Notification Perceived Severity."@en .

<kos/Notification/EventType/stateChange> a skos:ConceptScheme ;
    rdfs:label "Notification Event Type State Change KOS"@en ;
    dcterms:description "Knowledge Organization System for NORIA Notification Event Type State Change."@en .

# =============================================================================
# SKOS Concepts for controlled vocabularies
# =============================================================================

# Application Types
ex:ServicePlatform a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "An application that provides a platform for other services."@en .

ex:InfrastructureApp a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application managing core IT infrastructure components."@en .

ex:BusinessApp a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "An application directly supporting business operations."@en .

# Application Business Importance
ex:CriticalImportance a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for business operations, high impact on failure."@en .

ex:HighImportance a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High"@en ;
    rdfs:comment "Application is important for business operations, significant impact on failure."@en .

# Resource Types
ex:RouterType a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network device that forwards data packets between computer networks."@en .

ex:ServerType a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computer program or a device that provides functionality for other programs or devices, called 'clients'."@en .

ex:SwitchType a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network device that connects devices in a computer network by using packet switching to receive, process, and forward data to the destination device."@en .

# Trouble Ticket Severity
ex:CriticalSeverity a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Highest severity, immediate business impact."@en .

ex:MajorSeverity a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major"@en ;
    rdfs:comment "Significant business impact, requires urgent attention."@en .

ex:MinorSeverity a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor"@en ;
    rdfs:comment "Low business impact, can be addressed during normal operations."@en .

# Trouble Ticket Type
ex:FailureType a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Indicates a system or component failure."@en .

ex:AssistanceType a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Request for help or support."@en .

# Trouble Ticket Priority
ex:P1Priority a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "P1 - Urgent"@en ;
    rdfs:comment "Highest priority, requires immediate resolution."@en .

ex:P2Priority a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "P2 - High"@en ;
    rdfs:comment "High priority, requires resolution within a defined SLA."@en .

# Trouble Ticket Status
ex:InProgressStatus a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

ex:ResolvedStatus a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue described in the trouble ticket has been resolved."@en .

# Change Request Type
ex:StandardChange a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk and impact."@en .

ex:NormalChange a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Normal Change"@en ;
    rdfs:comment "A change that requires assessment and authorization."@en .

# Change Request Status
ex:ApprovedStatus a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "The change request has been approved for implementation."@en .

ex:ImplementedStatus a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "The change described in the change request has been implemented."@en .

# Service Type
ex:CustomerFacingService a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly visible and usable by a customer."@en .

ex:ResourceFacingService a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports customer-facing services but is not directly visible to customers."@en .

# Agent Contact Method
ex:EmailContact a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ; # This KOS is defined in the schema's range for noria:agentPreferredContactMethod
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

ex:PhoneContact a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# Operational State
ex:UpState a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "The component is operational and functioning."@en .

ex:DownState a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "The component is not operational."@en .

# Administrative State
ex:AdminUpState a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Admin Up"@en ;
    rdfs:comment "The interface is administratively enabled."@en .

ex:AdminDownState a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Admin Down"@en ;
    rdfs:comment "The interface is administratively disabled."@en .

# Notification Severity
ex:CriticalNotificationSeverity a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Notification Severity"@en ;
    rdfs:comment "Highest severity for an event notification."@en .

ex:MajorNotificationSeverity a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Major Notification Severity"@en ;
    rdfs:comment "Major severity for an event notification."@en .

ex:InformationalNotificationSeverity a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Informational Notification Severity"@en ;
    rdfs:comment "Informational severity for an event notification."@en .

# Notification Event Type
ex:StateChangeEventType a skos:Concept ;
    skos:inScheme <kos/Notification/EventType/stateChange> ;
    rdfs:label "State Change Event Type"@en ;
    rdfs:comment "Event type indicating a change in state."@en .

# Trouble Ticket Origin
ex:SupervisionOrigin a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System Origin"@en ;
    rdfs:comment "Trouble ticket originated from a supervision or monitoring system."@en .

# Trouble Ticket Comment Type
ex:InternalCommentType a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment Type"@en ;
    rdfs:comment "Comment intended for internal team use."@en .

# Trouble Ticket Operation Type
ex:DiagnosisOperationType a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation Type"@en ;
    rdfs:comment "Operation type related to diagnosing an issue."@en .

ex:CorrectiveActionOperationType a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Corrective Action Operation Type"@en ;
    rdfs:comment "Operation type related to taking corrective action."@en .

# Change Request Category
ex:SoftwareUpgradeCategory a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Software Upgrade Category"@en ;
    rdfs:comment "Change request category for software upgrades."@en .

# Change Request Cause
ex:SoftwareUpgradeCause a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade Cause"@en ;
    rdfs:comment "Cause of change request is a software upgrade."@en .

# Application SLA Level
ex:GoldSlaLevel a skos:Concept ;
    skos:inScheme <kos/application/sla-level> ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement tier."@en .

ex:BronzeSlaLevel a skos:Concept ;
    skos:inScheme <kos/application/sla-level> ;
    rdfs:label "Bronze SLA Level"@en ;
    rdfs:comment "Lowest Service Level Agreement tier."@en .

# Application Status
ex:InProductionStatus a skos:Concept ;
    skos:inScheme <kos/application/status> ;
    rdfs:label "In Production Status"@en ;
    rdfs:comment "Application module is currently in production."@en .

ex:DevelopmentStatus a skos:Concept ;
    skos:inScheme <kos/application/status> ;
    rdfs:label "Development Status"@en ;
    rdfs:comment "Application module is currently in development."@en .

# Resource Lifecycle State
ex:InProductionLifecycleState a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Production Lifecycle State"@en ;
    rdfs:comment "Resource is currently in production use."@en .

# =============================================================================
# Organizations and Agents
# =============================================================================

ex:OrangeTelecom a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company."@en ;
    noria:elementDistinguishedName "Orange Telecom Group"^^xsd:string .

ex:NetworkOperationsTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the network infrastructure."@en ;
    org:unitOf ex:OrangeTelecom ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod ex:EmailContact ;
    noria:agentInstructions "Contact via ticketing system for all issues."^^xsd:string .

ex:ApplicationSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    org:unitOf ex:OrangeTelecom ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentPreferredContactMethod ex:PhoneContact ;
    noria:agentInstructions "For critical issues, call the hotline immediately."^^xsd:string .

ex:AliceSmith a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Engineer at Orange Telecom."@en ;
    org:memberOf ex:NetworkOperationsTeam ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+33123456789"^^xsd:string .

ex:AliceCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique corporate identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountIdentifier "asmith_corp_id_123"^^xsd:string ;
    foaf:holdsAccount ex:AliceSmith .

ex:BobJohnson a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead Application Support Engineer at Orange Telecom."@en ;
    org:memberOf ex:ApplicationSupportTeam ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+33987654321"^^xsd:string .

ex:BobCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique corporate identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountIdentifier "bjohnson_corp_id_456"^^xsd:string ;
    foaf:holdsAccount ex:BobJohnson .

# =============================================================================
# Locations
# =============================================================================

ex:DataCenterA a bot:Site ;
    rdfs:label "Main Data Center A"@en ;
    rdfs:comment "Primary data center facility for Orange Telecom."@en ;
    noria:siteId "DCA-01"^^xsd:string ;
    noria:siteType "Data Center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string .

ex:ServerRoom1 a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "A dedicated server room within Data Center A."@en ;
    bot:hasSubSpace ex:DataCenterA .

ex:Rack1Locus a noria:Locus ;
    rdfs:label "Rack 1, Server Room 1"@en ;
    rdfs:comment "Specific location of Rack 1 within Server Room 1."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSubSpace ex:ServerRoom1 .

# =============================================================================
# Product Models and Manufacturers
# =============================================================================

ex:Cisco a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

ex:Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of servers and IT hardware."@en .

ex:CiscoNexus9KModel a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Product model for high-performance data center switches."@en ;
    noria:productManufacturedBy ex:Cisco .

ex:DellPowerEdgeR740Model a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Product model for a 2U rack server."@en ;
    noria:productManufacturedBy ex:Dell .

# =============================================================================
# IP Addresses (as observable:IPAddress instances)
# =============================================================================

ex:IP_10_0_0_1 a observable:IPAddress ;
    rdfs:label "IP Address 10.0.0.1"@en ;
    observable:ipAddressValue "10.0.0.1"^^xsd:string .

ex:IP_10_0_0_2 a observable:IPAddress ;
    rdfs:label "IP Address 10.0.0.2"@en ;
    observable:ipAddressValue "10.0.0.2"^^xsd:string .

ex:IP_10_0_0_3 a observable:IPAddress ;
    rdfs:label "IP Address 10.0.0.3"@en ;
    observable:ipAddressValue "10.0.0.3"^^xsd:string .

# =============================================================================
# Resources
# =============================================================================

ex:CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "A critical core router in the network infrastructure."@en ;
    noria:resourceLogisticId "CR01-LOG-XYZ"^^xsd:string ;
    noria:resourceHostName "core-router-01.example.com"^^xsd:string ;
    noria:resourceProductModel ex:CiscoNexus9KModel ;
    noria:resourceType ex:RouterType ;
    noria:resourceSerialNumber "SN-CR01-12345"^^xsd:string ;
    noria:resourceUsageState ex:InProductionLifecycleState ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack1Locus ;
    noria:resourceManagementIPAddress ex:IP_10_0_0_1 ;
    noria:resourceManagedBy ex:NetworkOperationsTeam .

ex:AppServer01 a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting the CRM application."@en ;
    noria:resourceLogisticId "AS01-LOG-ABC"^^xsd:string ;
    noria:resourceHostName "app-server-01.example.com"^^xsd:string ;
    noria:resourceProductModel ex:DellPowerEdgeR740Model ;
    noria:resourceType ex:ServerType ;
    noria:resourceSerialNumber "SN-AS01-67890"^^xsd:string ;
    noria:resourceUsageState ex:InProductionLifecycleState ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus ex:Rack1Locus ;
    noria:resourceManagementIPAddress ex:IP_10_0_0_2 ;
    noria:resourceManagedBy ex:ApplicationSupportTeam .

