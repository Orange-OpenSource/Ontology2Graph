# Event Records
ex:RouterDownEvent a noria:EventRecord ;
    rdfs:label "Core Router 01 Interface Down Event"@en ;
    rdfs:comment "An event indicating that an interface on Core Router 01 went down."@en ;
    noria:logOriginatingManagedObject ex:CoreRouter01_Eth0_1 ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    noria:loggingTime "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1 on core-router-01 changed state to down."^^xsd:string ;
    noria:alarmSeverity ex:CriticalNotificationSeverity .

ex:CRMSlowEvent a noria:EventRecord ;
    rdfs:label "CRM System Performance Degradation Event"@en ;
    rdfs:comment "An event indicating slow response times for the CRM system."@en ;
    noria:logOriginatingManagedObject ex:AppServer01 ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    noria:loggingTime "2024-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:logText "CRM application response time exceeding threshold on app-server-01."^^xsd:string ;
    noria:alarmSeverity ex:MajorNotificationSeverity .

ex:ConfigChangeEvent a noria:EventRecord ;
    rdfs:label "Router Configuration Change Event"@en ;
    rdfs:comment "An event recording a configuration change on Core Router 01 by Alice Smith."@en ;
    noria:logOriginatingManagedObject ex:CoreRouter01 ;
    noria:logOriginatingManagementSystem ex:MonitoringPlatform ;
    noria:logOriginatingAgent ex:AliceSmith ;
    noria:loggingTime "2024-03-14T16:00:00Z"^^xsd:dateTime ;
    noria:logText "Configuration change applied by asmith: 'interface GigabitEthernet0/0/1; shutdown'."^^xsd:string ;
    noria:alarmSeverity ex:InformationalNotificationSeverity .

# Trouble Ticket
ex:TT_20240315_001 a noria:TroubleTicket ;
    rdfs:label "Critical Outage: Core Router 01 Interface Down"@en ;
    rdfs:comment "Trouble ticket opened due to a critical interface outage on Core Router 01."@en ;
    dcterms:identifier "TT-20240315-001"^^xsd:string ;
    dcterms:created "2024-03-15T09:05:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CUST-INC-9876"^^xsd:string ;
    noria:documentHRef <http://ticketing.example.com/TT-20240315-001> ;
    noria:troubleTicketSeverity ex:CriticalSeverity ;
    noria:troubleTicketType ex:FailureType ;
    noria:troubleTicketPriority ex:P1Priority ;
    noria:troubleTicketOrigin ex:SupervisionOrigin ;
    noria:troubleTicketTrigger ex:RouterDownEvent ;
    noria:troubleTicketStatusCurrent ex:InProgressStatus ;
    noria:troubleTicketRelatedParty ex:NetworkOperationsTeam ;
    noria:troubleTicketRelatedResource ex:CoreRouter01 ;
    noria:troubleTicketRelatedService ex:CustomerDataService ;
    noria:troubleTicketDetectionDateTime "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true .

ex:TT_20240315_001_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for TT-20240315-001"@en ;
    rdfs:comment "First note on the trouble ticket, detailing initial diagnosis steps."@en ;
    dcterms:created "2024-03-15T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator ex:AliceSmith ;
    dcterms:description "Confirmed interface down. Initiated remote troubleshooting. Suspect fiber cut or hardware failure."^^xsd:string ;
    noria:troubleTicketNoteCommentType ex:InternalCommentType ;
    noria:troubleTicketNoteOperationType ex:DiagnosisOperationType ;
    dcterms:isPartOf ex:TT_20240315_001 .

ex:TT_20240315_001_Note2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Note for TT-20240315-001"@en ;
    rdfs:comment "Note detailing the resolution steps for the trouble ticket."@en ;
    dcterms:created "2024-03-15T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator ex:AliceSmith ;
    dcterms:description "Replaced faulty SFP module on Core Router 01. Interface is now up and stable. Service restored."^^xsd:string ;
    noria:troubleTicketNoteCommentType ex:InternalCommentType ;
    noria:troubleTicketNoteOperationType ex:CorrectiveActionOperationType ;
    dcterms:isPartOf ex:TT_20240315_001 .

