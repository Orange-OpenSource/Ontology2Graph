# --- Network Interfaces ---

ex:WebServer01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebServer01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface 0 on Web Server 01."@en ;
    noria:networkInterfaceOf ex:WebServer01 ;
    noria:networkInterfaceType ex:NetworkInterfaceType_Physical ;
    noria:networkInterfaceDescription "Main network interface for web traffic."^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus ex:AdministrativeState_Up ;
    noria:networkInterfaceOperationalStatus ex:OperationalState_Up ;
    noria:networkInterfaceConnects ex:Link_Web_DB .

ex:DBServer01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface 0 on Database Server 01."@en ;
    noria:networkInterfaceOf ex:DBServer01 ;
    noria:networkInterfaceType ex:NetworkInterfaceType_Physical ;
    noria:networkInterfaceDescription "Main network interface for database traffic."^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus ex:AdministrativeState_Up ;
    noria:networkInterfaceOperationalStatus ex:OperationalState_Up ;
    noria:networkInterfaceConnects ex:Link_Web_DB .

ex:RouterCore01_GigE0_0
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0 on Core Router 01."@en ;
    noria:networkInterfaceOf ex:RouterCore01 ;
    noria:networkInterfaceType ex:NetworkInterfaceType_Physical ;
    noria:networkInterfaceDescription "Uplink to external network."^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus ex:AdministrativeState_Up ;
    noria:networkInterfaceOperationalStatus ex:OperationalState_Up ;
    noria:networkInterfaceRoutingPriorityMetric 100^^xsd:int ;
    noria:networkInterfaceConnects ex:Link_Router_Web .

# --- Network Links ---

ex:Link_Web_DB
    a noria:NetworkLink ;
    rdfs:label "Link between WebServer01 and DBServer01"@en ;
    rdfs:comment "A logical network link facilitating communication between the web server and the database server."@en ;
    noria:networkLinkId "NL-WEB-DB-001"^^xsd:string ;
    noria:networkLinkType "Ethernet VLAN"^^xsd:string ;
    noria:networkLinkInstallationDate "2023-01-15T12:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin ex:WebServer01 ;
    noria:networkLinkTerminationResourceDestination ex:DBServer01 ;
    noria:resourceManagedBy ex:ITOperationsTeam .

ex:Link_Router_Web
    a noria:NetworkLink ;
    rdfs:label "Link between RouterCore01 and WebServer01"@en ;
    rdfs:comment "A physical network link connecting the core router to the web server."@en ;
    noria:networkLinkId "NL-RT-WEB-001"^^xsd:string ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-10-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin ex:RouterCore01 ;
    noria:networkLinkTerminationResourceDestination ex:WebServer01 ;
    noria:resourceManagedBy ex:ITOperationsTeam .

# --- Application and Service Entities ---

ex:CustomerPortalApp
    a noria:Application ;
    rdfs:label "TechCorp Customer Portal Application"@en ;
    rdfs:comment "The main web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CP-V2.0"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001^^xsd:int ;
    noria:applicationShortIdentifier "TCPORTAL"^^xsd:string ;
    noria:applicationType ex:ApplicationType_Web ;
    noria:applicationBusinessImportance ex:BusinessImportance_High ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Customer Self-Service"@en ;
    noria:elementManagedBy ex:ITOperationsTeam .

ex:CustomerPortalProdModule
    a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "The production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf ex:CustomerPortalApp ;
    noria:applicationModuleName "TCPORTAL_PROD"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-001"^^xsd:string ;
    noria:applicationModuleAdministrationTeam ex:ITOperationsTeam ;
    noria:applicationModuleAdministrationLeader ex:JohnDoe ;
    noria:applicationModuleSupportTeam ex:ITOperationsTeam ;
    noria:applicationModuleSupportLeader ex:JaneSmith ;
    noria:applicationModuleHotlineEnabled true^^xsd:boolean ;
    noria:applicationModuleSlaLevel ex:SlaLevel_Gold ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleStatus ex:ApplicationStatus_InProduction ;
    noria:elementManagedBy ex:ITOperationsTeam .

ex:CustomerFacingService
    a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "An end-to-end service providing access to the Customer Portal for external users."@en ;
    noria:serviceType ex:ServiceType_CustomerFacing ;
    noria:elementManagedBy ex:ITOperationsTeam .

# --- Procedural Elements ---

ex:WebServerRestartProcedure
    a noria:OperationPlan ;
    rdfs:label "Web Server Restart Procedure"@en ;
    rdfs:comment "A standardized procedure for restarting the web server in case of issues."@en ;
    noria:operationPlanPreCondition ex:WebServerDownPreCond ;
    noria:operationPlanPostCondition ex:WebServerUpPostCond .

ex:FirmwareUpgradeProcedure
    a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "A standardized procedure for upgrading the firmware on network routers."@en .

ex:WebServerDownPreCond
    a noria:ActionPreCondition ;
    rdfs:label "Web Server Down Pre-Condition"@en ;
    rdfs:comment "Condition indicating that the web server is currently unresponsive or down."@en .

ex:WebServerUpPostCond
    a noria:ActionPostCondition ;
    rdfs:label "Web Server Up Post-Condition"@en ;
    rdfs:comment "Condition indicating that the web server has successfully restarted and is operational."@en .

# --- Dynamic Elements (Events, Tickets, Changes) ---

ex:LogEvent_WebServerCrash
    a noria:EventRecord ;
    rdfs:label "Web Server Crash Log Event"@en ;
    rdfs:comment "An event record indicating an unexpected crash of Web Server 01."@en ;
    noria:loggingTime "2024-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: WebServer01 process terminated unexpectedly. Restarting..."^^xsd:string ;
    noria:logOriginatingManagedObject ex:WebServer01 ;
    noria:logOriginatingManagementSystem ex:MonitoringSystem ;
    noria:alarmSeverity ex:AlarmSeverity_Critical ;
    dcterms:type ex:EventType_StateChange .

ex:LogEvent_FirmwareUpdateSuccess
    a noria:EventRecord ;
    rdfs:label "Router Firmware Update Success Log Event"@en ;
    rdfs:comment "An event record confirming the successful firmware update on RouterCore01."@en ;
    noria:loggingTime "2024-03-21T03:15:00Z"^^xsd:dateTime ;
    noria:logText "INFO: Firmware update completed successfully on RouterCore01."^^xsd:string ;
    noria:logOriginatingManagedObject ex:RouterCore01 ;
    noria:logOriginatingManagementSystem ex:ConfigurationManagementSystem ;
    noria:logOriginatingAgent ex:JohnDoe ;
    dcterms:type ex:EventType_ConfigurationChange .

ex:MonitoringSystem
    a noria:Application ;
    rdfs:label "TechCorp Monitoring System"@en ;
    rdfs:comment "Application responsible for monitoring the health and performance of IT infrastructure."@en ;
    noria:applicationShortIdentifier "MONSYS"^^xsd:string ;
    noria:elementManagedBy ex:ITOperationsTeam .

ex:ConfigurationManagementSystem
    a noria:Application ;
    rdfs:label "TechCorp Configuration Management System"@en ;
    rdfs:comment "Application used for managing and deploying configurations across IT infrastructure."@en ;
    noria:applicationShortIdentifier "CMS"^^xsd:string ;
    noria:elementManagedBy ex:ITOperationsTeam .

ex:TT-2024-001
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket 2024-001: Customer Portal Outage"@en ;
    rdfs:comment "Incident ticket raised due to an outage of the Customer Portal application."@en ;
    dcterms:identifier "TT-2024-001"^^xsd:string ;
    dcterms:created "2024-03-20T14:35:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CUST-P-OUTAGE-001"^^xsd:string ;
    noria:documentHRef <http://itsm.techcorp.com/tickets/TT-2024-001> ;
    noria:troubleTicketSeverity ex:TT_Severity_Critical ;
    noria:troubleTicketType ex:TT_Type_Failure ;
    noria:troubleTicketPriority ex:TT_Priority_P1 ;
    noria:troubleTicketUrgency ex:TT_Urgency_Immediate ;
    noria:troubleTicketOrigin ex:TT_Origin_Supervision ;
    noria:troubleTicketSupervisionTool "TechCorp Monitoring System"^^xsd:string ;
    noria:troubleTicketCategory ex:TT_Category_TotalBreakdown ;
    noria:troubleTicketStatusCurrent ex:TT_Status_InProgress ;
    noria:troubleTicketDetectionDateTime "2024-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-20T16:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true^^xsd:boolean ;
    noria:troubleTicketTrigger ex:LogEvent_WebServerCrash ;
    noria:troubleTicketRelatedService ex:CustomerFacingService ;
    noria:troubleTicketRelatedResource ex:WebServer01 ;
    noria:troubleTicketRelatedParty ex:ITOperationsTeam ;
    noria:documentStatusHistory ex:LogEvent_TT_StatusChange_InProgress .

ex:LogEvent_TT_StatusChange_InProgress
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket Status Change to InProgress"@en ;
    rdfs:comment "An event recording the status change of TT-2024-001 to InProgress."@en ;
    noria:loggingTime "2024-03-20T14:36:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-2024-001 status changed to InProgress."^^xsd:string ;
    noria:logOriginatingManagementSystem ex:MonitoringSystem ;
    dcterms:type ex:EventType_StateChange .

ex:TT-2024-001-Note1
    a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket 2024-001 Note 1: Initial Diagnosis"@en ;
    rdfs:comment "First note detailing the initial diagnosis and actions taken for TT-2024-001."@en ;
    dcterms:isPartOf ex:TT-2024-001 ;
    dcterms:created "2024-03-20T14:40:00Z"^^xsd:dateTime ;
    dcterms:creator ex:JohnDoe ;
    dcterms:description "Initial diagnosis indicates web server process crash. Attempting restart of WebServer01."^^xsd:string ;
    noria:troubleTicketNoteCommentType ex:TT_CommentType_Internal ;
    noria:troubleTicketNoteOperationType ex:TT_OperationType_Diagnosis ;
    noria:troubleTicketNoteCorrelatedExecution ex:WebServerRestartProcedure .

ex:TT-2024-001-Note2
    a noria:TroubleTicketNote ;
    rdfs:label "Trouble Ticket 2024-001 Note 2: Resolution"@en ;
    rdfs:comment "Second note detailing the resolution of TT-2024-001."@en ;
    dcterms:isPartOf ex:TT-2024-001 ;
    dcterms:created "2024-03-20T15:10:00Z"^^xsd:dateTime ;
    dcterms:creator ex:JohnDoe ;
    dcterms:description "Web server restarted successfully. Service restored. Monitoring for stability."^^xsd:string ;
    noria:troubleTicketNoteCommentType ex:TT_CommentType_Internal ;
    noria:troubleTicketNoteOperationType ex:TT_OperationType_Resolution .

ex:CR-2024-005
    a noria:ChangeRequest ;
    rdfs:label "Change Request 2024-005: Router Firmware Upgrade"@en ;
    rdfs:comment "Scheduled change request for upgrading the firmware on Core Router 01."@en ;
    dcterms:identifier "CR-2024-005"^^xsd:string ;
