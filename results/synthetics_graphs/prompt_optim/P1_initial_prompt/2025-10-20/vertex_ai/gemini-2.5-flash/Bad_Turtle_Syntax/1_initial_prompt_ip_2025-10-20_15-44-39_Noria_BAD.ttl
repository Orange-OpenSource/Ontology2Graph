# =============================================================================
# Knowledge Graph Instances for TechCorp Infrastructure
# =============================================================================

# --- Organizational Entities ---

ex:TechCorp
    a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "A leading technology company providing cloud services and IT solutions."@en ;
    org:hasUnit ex:ITOperationsTeam .

ex:ITOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "The team responsible for managing TechCorp's core IT infrastructure and applications."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "9:00 AM - 6:00 PM (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "For critical issues, use the dedicated incident management hotline."^^xsd:string .

ex:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior Systems Administrator in the IT Operations Team."@en ;
    org:memberOf ex:ITOperationsTeam ;
    foaf:mbox <mailto:john.doe@techcorp.com> ;
    noria:agentPreferredContactMethod ex:ContactMethod_Email .

ex:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network Engineer in the IT Operations Team."@en ;
    org:memberOf ex:ITOperationsTeam ;
    foaf:mbox <mailto:jane.smith@techcorp.com> ;
    noria:agentPreferredContactMethod ex:ContactMethod_Phone .

ex:JohnDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "The unique corporate identifier for John Doe, used for system access."@en ;
    foaf:holdsAccount ex:JohnDoe ;
    foaf:accountName "jdoe"@en ;
    observable:accountIdentifier "jdoe-techcorp-12345"@en .

ex:Dell
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

ex:Cisco
    a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking equipment."@en .

# --- Location Entities ---

ex:MainDataCenter
    a bot:Site ;
    rdfs:label "TechCorp Main Data Center"@en ;
    rdfs:comment "The primary data center facility for TechCorp's operations."@en ;
    noria:siteId "DC-NYC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 TechCorp Avenue"@en ;
    noria:sitePrincipalAddressCityName "New York"@en ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    bot:containsZone ex:ServerRoomA .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated server room within the Main Data Center."@en ;
    bot:containsZone ex:Rack12Locus .

ex:Rack12Locus
    a noria:Locus ;
    rdfs:label "Rack 12 Location"@en ;
    rdfs:comment "Specific location within Server Room A, identified as Rack 12."@en ;
    noria:locusLine "R12"^^xsd:string ;
    noria:locusRow "A"^^xsd:string .

