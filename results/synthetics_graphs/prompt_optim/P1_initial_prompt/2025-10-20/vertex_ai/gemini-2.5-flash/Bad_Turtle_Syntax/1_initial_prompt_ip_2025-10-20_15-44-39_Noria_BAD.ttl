# --- SKOS Concepts for KOS (Knowledge Organization System) ---

ex:ContactMethod_Email
    a skos:Concept ;
    rdfs:label "Email Contact Method"@en ;
    rdfs:comment "Preferred contact method via email."@en .

ex:ContactMethod_Phone
    a skos:Concept ;
    rdfs:label "Phone Contact Method"@en ;
    rdfs:comment "Preferred contact method via phone."@en .

ex:ApplicationType_Web
    a skos:Concept ;
    rdfs:label "Web Application Type"@en ;
    rdfs:comment "Categorizes an application as a web-based service."@en .

ex:BusinessImportance_High
    a skos:Concept ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Indicates a high business impact if the application is unavailable."@en .

ex:SlaLevel_Gold
    a skos:Concept ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement tier, implying strict availability and performance targets."@en .

ex:ApplicationStatus_InProduction
    a skos:Concept ;
    rdfs:label "In Production Status"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

ex:ServiceType_CustomerFacing
    a skos:Concept ;
    rdfs:label "Customer Facing Service Type"@en ;
    rdfs:comment "A service directly consumed or interacted with by end customers."@en .

ex:TT_Severity_Critical
    a skos:Concept ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Indicates a severe incident with major impact on services."@en .

ex:TT_Type_Failure
    a skos:Concept ;
    rdfs:label "Failure Trouble Ticket Type"@en ;
    rdfs:comment "Categorizes a trouble ticket as a system or service failure."@en .

ex:TT_Priority_P1
    a skos:Concept ;
    rdfs:label "Priority 1 (P1)"@en ;
    rdfs:comment "Highest priority for incident resolution."@en .

ex:TT_Urgency_Immediate
    a skos:Concept ;
    rdfs:label "Immediate Intervention Urgency"@en ;
    rdfs:comment "Requires immediate action to resolve the issue."@en .

ex:TT_Origin_Supervision
    a skos:Concept ;
    rdfs:label "Supervision Origin"@en ;
    rdfs:comment "Trouble ticket originated from automated monitoring or supervision systems."@en .

ex:TT_Category_TotalBreakdown
    a skos:Concept ;
    rdfs:label "Total Breakdown Category"@en ;
    rdfs:comment "Incident category indicating a complete failure of a system or service."@en .

ex:TT_Status_InProgress
    a skos:Concept ;
    rdfs:label "In Progress Status"@en ;
    rdfs:comment "The trouble ticket is currently being actively worked on."@en .

ex:TT_CommentType_Internal
    a skos:Concept ;
    rdfs:label "Internal Comment Type"@en ;
    rdfs:comment "A comment intended for internal team communication."@en .

ex:TT_OperationType_Diagnosis
    a skos:Concept ;
    rdfs:label "Diagnosis Operation Type"@en ;
    rdfs:comment "Describes an action related to diagnosing the root cause of an issue."@en .

ex:TT_OperationType_Resolution
    a skos:Concept ;
    rdfs:label "Resolution Operation Type"@en ;
    rdfs:comment "Describes an action related to resolving an issue."@en .

ex:CR_Category_InternalIntervention
    a skos:Concept ;
    rdfs:label "Internal Intervention Category"@en ;
    rdfs:comment "Change request involving internal IT team intervention."@en .

ex:CR_Type_Standard
    a skos:Concept ;
    rdfs:label "Standard Change Type"@en ;
