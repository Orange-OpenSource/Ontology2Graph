    noria:resourceType ex:ResourceType_Router ;
    noria:resourceSerialNumber "SN-RT-001-DEF"^^xsd:string ;
    noria:resourceUsageState ex:LifecycleState_Production ;
    noria:resourceInstallationDate "2022-10-01T09:00:00Z"^^xsd:dateTime ;
