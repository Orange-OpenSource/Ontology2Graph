    noria:changeRequestPlannedEndTime "2024-03-21T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-03-21T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-03-21T03:15:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory ex:CR_Category_InternalIntervention ;
