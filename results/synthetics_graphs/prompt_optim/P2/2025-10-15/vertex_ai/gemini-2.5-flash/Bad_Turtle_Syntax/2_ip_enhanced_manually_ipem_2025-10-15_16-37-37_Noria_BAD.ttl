# Organizations and Agents
org:OrgUnit1
    a org:OrganizationalUnit ;
    rdfs:label "Organizational Unit 1"@en ;
    rdfs:comment "A synthetic organizational unit for testing purposes."@en ;
    org:unitOf <org:ParentOrg> ;
    org:hasMember foaf:Person1 ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Ensure all critical systems are monitored 24/7. Escalate major incidents immediately."^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
.

org:OrgUnit2
    a org:OrganizationalUnit ;
    rdfs:label "Organizational Unit 2"@en ;
    rdfs:comment "A synthetic organizational unit for testing purposes."@en ;
    org:unitOf <org:ParentOrg> ;
    org:hasMember foaf:Person2 ;
    noria:agentWorkingHours "24/7 Support"^^xsd:string ;
    noria:agentInstructions "Follow standard operating procedures for all change requests. Document all actions."^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
.

org:OrgUnit3
    a org:OrganizationalUnit ;
    rdfs:label "Organizational Unit 3"@en ;
    rdfs:comment "A synthetic organizational unit for testing purposes."@en ;
    org:unitOf <org:ParentOrg> ;
    org:hasMember foaf:Person3 ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Perform daily health checks on all database servers. Report any anomalies."^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
.

foaf:Person1
    a foaf:Person ;
    rdfs:label "Person 1"@en ;
    rdfs:comment "A synthetic person acting as an agent."@en ;
    foaf:mbox <mailto:person1@example.com> ;
    foaf:phone "+1-555-1234"^^xsd:string ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters. Use phone for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    foaf:holdsAccount noria:CUid1 ;
.

foaf:Person2
