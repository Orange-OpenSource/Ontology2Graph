# --- Procedural Elements (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition, noria:AnomalyPattern) ---

<https://w3id.org/noria/data/operationplan/RouterInterfaceTroubleshooting>
    a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving router interface issues."@en ;
.

<https://w3id.org/noria/data/actionprecondition/InterfaceDownDetected>
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Detected"@en ;
    rdfs:comment "Condition: A network interface reports an 'administratively down' or 'operational down' state."@en ;
.

<https://w3id.org/noria/data/actionpostcondition/InterfaceUpAndStable>
    a noria:ActionPostCondition ;
    rdfs:label "Interface Up and Stable"@en ;
    rdfs:comment "Expected outcome: The network interface is in an 'up' operational state and remains stable for a defined period."@en ;
.

<https://w3id.org/noria/data/operationplan/RouterInterfaceTroubleshooting>
    noria:operationPlanPreCondition <https://w3id.org/noria/data/actionprecondition/InterfaceDownDetected> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/data/actionpostcondition/InterfaceUpAndStable> ;
.

<https://w3id.org/noria/data/anomalypattern/HighCPULowThroughput>
    a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Throughput Anomaly"@en ;
    rdfs:comment "Describes a pattern where a server experiences high CPU usage but low network throughput, indicating a potential bottleneck or application issue."@en ;
    folio:hasCause "Application misconfiguration or resource contention"^^xsd:string ;
    folio:hasEffect "Degraded application performance"^^xsd:string ;
.

<https://w3id.org/noria/data/operationplan/WebServerOptimization>
    a noria:OperationPlan ;
    rdfs:label "Web Server Performance Optimization Procedure"@en ;
    rdfs:comment "Procedure to optimize web server performance in case of high CPU or low throughput."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/data/anomalypattern/HighCPULowThroughput> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/data/actionpostcondition/WebServerPerformanceRestored> ;
.

<https://w3id.org/noria/data/actionpostcondition/WebServerPerformanceRestored>
    a noria:ActionPostCondition ;
    rdfs:label "Web Server Performance Restored"@en ;
    rdfs:comment "Expected outcome: Web server CPU utilization and network throughput return to normal operating levels."@en ;
.

