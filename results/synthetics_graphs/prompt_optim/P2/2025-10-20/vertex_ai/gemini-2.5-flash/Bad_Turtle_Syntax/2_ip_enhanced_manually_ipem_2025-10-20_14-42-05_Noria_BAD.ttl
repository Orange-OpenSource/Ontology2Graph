# --- Agents and Organizations ---

noria-data:Org_IT_Operations
    a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The central department responsible for IT infrastructure and services."@en ;
    noria:agentWorkingHours "08:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:contactMethod/Email .

noria-data:OrgUnit_NetworkTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf noria-data:Org_IT_Operations ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentInstructions "For critical issues, use emergency hotline."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:contactMethod/Phone .

noria-data:OrgUnit_AppSupport
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    org:unitOf noria-data:Org_IT_Operations ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Submit a ticket via the internal portal."^^xsd:string ;
    noria:agentPreferredContactMethod noria-data:contactMethod/Email .

noria-data:Person_AliceSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Team Lead."@en ;
    foaf:name "Alice Smith"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 Mon-Fri"^^xsd:string ;
