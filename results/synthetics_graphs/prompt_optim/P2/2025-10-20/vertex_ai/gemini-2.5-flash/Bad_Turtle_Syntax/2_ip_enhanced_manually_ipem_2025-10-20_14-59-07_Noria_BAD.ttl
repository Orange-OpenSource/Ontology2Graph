# SKOS Concept Schemes and Concepts
# =============================================================================

# Agent Contact Method
<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    dcterms:title "Agent Contact Method"@en ;
    rdfs:comment "A controlled vocabulary for methods to contact an agent."@en ;
.
noria:ContactMethod_Email
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Contact via electronic mail."@en ;
.
noria:ContactMethod_Phone
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Contact via telephone."@en ;
.
noria:ContactMethod_Chat
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Chat"@en ;
    rdfs:comment "Contact via instant messaging or chat platform."@en ;
.

