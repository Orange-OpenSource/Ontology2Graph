    dcterms:identifier "cr001_upgrade_plan.pdf"^^xsd:string ;
.

# =============================================================================
# Procedural Elements
# =============================================================================

# Operation Plans
noria:OperationPlan_RestartInterface
    a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a network interface."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp ;
    noria:elementManagedBy noria:Team_NOC ;
.

noria:OperationPlan_SoftwareUpgrade
    a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Procedure for upgrading router operating system software."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_BackupComplete ;
    noria:operationPlanPostCondition noria:ActionPostCondition_SoftwareUpdated ;
    noria:elementManagedBy noria:Team_NOC ;
.

# Anomaly Patterns
noria:AnomalyPattern_HighCPU_LowTraffic
    a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Traffic Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential issue where CPU is high but network traffic is low, suggesting a process loop or misconfiguration."@en ;
    folio:hasCause noria:AnomalyPattern_ProcessLoop ;
.

noria:AnomalyPattern_ProcessLoop
    a noria:AnomalyPattern ;
    rdfs:label "Process Loop Anomaly"@en ;
    rdfs:comment "A specific failure mode where a process enters an infinite loop, consuming CPU without productive work."@en ;
.

# Action Pre-Conditions
noria:ActionPreCondition_InterfaceDown
    a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Pre-condition: the target network interface must be in a 'down' operational state."@en ;
.

noria:ActionPreCondition_BackupComplete
    a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup Complete"@en ;
    rdfs:comment "Pre-condition: a full backup of the device configuration must be completed before proceeding."@en ;
.

# Action Post-Conditions
noria:ActionPostCondition_InterfaceUp
    a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Post-condition: the target network interface should be in an 'up' operational state."@en ;
.

noria:ActionPostCondition_SoftwareUpdated
    a noria:ActionPostCondition ;
    rdfs:label "Software Version Updated"@en ;
    rdfs:comment "Post-condition: the device's software version should match the target version."@en ;
.

# =============================================================================
# Corrective Maintenance Actions and Change Actions
# =============================================================================

noria:CorrectiveMaintenanceAction_RestartCR01_Ge000
    a noria:CorrectiveMaintenanceAction ;
    rdfs:label "Restart ge-0/0/0 on Core Router 01"@en ;
    rdfs:comment "Action taken to restart the problematic interface on Core Router 01."@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_RestartInterface ;
    pep:madeBy noria:Agent_Alice ;
    pep:hasCommand "restart interface ge-0/0/0"^^xsd:string ;
    pep:hasResult "Interface ge-0/0/0 restarted successfully."^^xsd:string ;
    dcterms:created "2024-03-15T10:10:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:TroubleTicket_001 ;
.

noria:ChangeAction_UpgradeCR01
    a noria:ChangeAction ;
    rdfs:label "Execute Software Upgrade on Core Router 01"@en ;
    rdfs:comment "Action to perform the software upgrade on Core Router 01 as per CR-001."@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_SoftwareUpgrade ;
    pep:madeBy noria:Agent_Alice ;
    pep:hasCommand "install software new-version.img"^^xsd:string ;
    pep:hasResult "Software upgrade completed, device rebooted."^^xsd:string ;
    dcterms:created "2024-04-01T02:30:00Z"^^xsd:dateTime ;
    dcterms:isPartOf noria:ChangeRequest_001 ;
.

