    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Indicates a critical condition requiring immediate attention."@en ;
.
noria:PerceivedSeverity_Warning
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Indicates a potential issue that may require attention."@en ;
.
noria:PerceivedSeverity_Informational
    a skos:Concept ;
skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Informational"@en ;
    rdfs:comment "Provides information about an event, no immediate action required."@en ;
.

# Network Interface Type (custom scheme as per TODO in schema)
<kos/NetworkInterface/type>
    a skos:ConceptScheme ;
    dcterms:title "Network Interface Type"@en ;
    rdfs:comment "A controlled vocabulary for types of network interfaces."@en ;
.
noria:NetworkInterfaceType_Physical
    a skos:Concept ;
    skos:inScheme <kos/NetworkInterface/type> ;
    rdfs:label "Physical Interface"@en ;
    rdfs:comment "A hardware network interface."@en ;
.
noria:NetworkInterfaceType_Virtual
    a skos:Concept ;
    skos:inScheme <kos/NetworkInterface/type> ;
    rdfs:label "Virtual Interface"@en ;
    rdfs:comment "A software-defined network interface."@en ;
.

# =============================================================================
# Organizations and Agents
# =============================================================================

# Organizations
noria:Org_ITOperations
    a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The central department responsible for IT infrastructure and services."@en ;
    noria:elementDistinguishedName "IT-OPS-DEPT-001"^^xsd:string ;
.

noria:Org_NetworkServices
    a org:Organization ;
    rdfs:label "Network Services Division"@en ;
    rdfs:comment "Specialized division managing network infrastructure."@en ;
    noria:elementDistinguishedName "NET-SVC-DIV-001"^^xsd:string ;
.

noria:Org_ApplicationDevelopment
    a org:Organization ;
    rdfs:label "Application Development Unit"@en ;
    rdfs:comment "Unit responsible for developing and maintaining applications."@en ;
    noria:elementDistinguishedName "APP-DEV-UNIT-001"^^xsd:string ;
.

# Organizational Units (Teams)
noria:Team_NOC
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Team"@en ;
    rdfs:comment "Team responsible for 24/7 network monitoring and initial incident response."@en ;
    org:unitOf noria:Org_NetworkServices ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "For critical issues, call hotline immediately. For minor issues, open a ticket."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Phone ;
.

noria:Team_AppSupportL2
    a org:OrganizationalUnit ;
    rdfs:label "Application Support L2 Team"@en ;
    rdfs:comment "Second-level support team for critical business applications."@en ;
    org:unitOf noria:Org_ApplicationDevelopment ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Escalate to L3 after 4 hours if no resolution."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email ;
.

noria:Team_InfraOps
    a org:OrganizationalUnit ;
    rdfs:label "Infrastructure Operations Team"@en ;
    rdfs:comment "Team managing physical and virtual infrastructure."@en ;
    org:unitOf noria:Org_ITOperations ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Follow documented change procedures for all modifications."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Chat ;
.

# Foaf Agents (Persons)
noria:Agent_Alice
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact for complex network routing issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Phone ;
.

noria:Agent_Bob
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Specialist."@en ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Responsible for database performance tuning."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email ;
.

noria:Agent_Charlie
    a foaf:Person ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "IT Operations Manager."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Approve all major changes and incident reports."^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Phone ;
.

# Corporate User Identifiers
noria:CUid_Alice
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "CU-ASMITH-001"^^xsd:string ;
.
noria:Agent_Alice foaf:holdsAccount noria:CUid_Alice .

noria:CUid_Bob
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "CU-BJOHNSON-002"^^xsd:string ;
.
noria:Agent_Bob foaf:holdsAccount noria:CUid_Bob .

