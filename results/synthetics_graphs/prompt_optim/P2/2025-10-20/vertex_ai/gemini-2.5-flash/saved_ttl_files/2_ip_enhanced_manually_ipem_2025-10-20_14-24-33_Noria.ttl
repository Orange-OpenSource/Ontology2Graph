# --- noria:OperationPlan entities ---

<operationplan/InterfaceTroubleshooting>
    a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    noria:operationPlanPreCondition <actionprecondition/InterfaceDownDetected> ;
    noria:operationPlanPostCondition <actionpostcondition/InterfaceRestored> .

<operationplan/ServerPerformanceCheck>
    a noria:OperationPlan ;
    rdfs:label "Server Performance Check Procedure"@en ;
    rdfs:comment "Procedure to investigate and resolve high CPU/memory usage on application servers."@en ;
    noria:operationPlanPreCondition <actionprecondition/HighCPUAlert> ;
    noria:operationPlanPostCondition <actionpostcondition/PerformanceNormalized> .

<operationplan/RouterSoftwareUpgrade>
    a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading router operating system software."@en ;
    noria:operationPlanPreCondition <actionprecondition/MaintenanceWindowApproved> ;
    noria:operationPlanPostCondition <actionpostcondition/SoftwareUpgradeCompleted> .

# --- noria:ActionPreCondition entities ---

<actionprecondition/InterfaceDownDetected>
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Detected"@en ;
    rdfs:comment "Condition: A network interface is reported as being in a 'down' state."@en .

<actionprecondition/HighCPUAlert>
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Alert Triggered"@en ;
    rdfs:comment "Condition: Monitoring system has triggered an alert for high CPU usage."@en .

<actionprecondition/MaintenanceWindowApproved>
    a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Approved"@en ;
    rdfs:comment "Condition: A scheduled maintenance window has been approved for the change."@en .

# --- noria:ActionPostCondition entities ---

<actionpostcondition/InterfaceRestored>
    a noria:ActionPostCondition ;
    rdfs:label "Interface Restored"@en ;
    rdfs:comment "Expected outcome: The network interface is back in an 'up' state and traffic is flowing."@en .

<actionpostcondition/PerformanceNormalized>
    a noria:ActionPostCondition ;
    rdfs:label "Performance Normalized"@en ;
    rdfs:comment "Expected outcome: CPU and memory utilization return to normal levels."@en .

<actionpostcondition/SoftwareUpgradeCompleted>
    a noria:ActionPostCondition ;
    rdfs:label "Software Upgrade Completed"@en ;
    rdfs:comment "Expected outcome: Router software successfully upgraded and verified."@en .

# --- noria:AnomalyPattern entities ---

<anomalypattern/RepeatedInterfaceFlap>
    a noria:AnomalyPattern ;
    rdfs:label "Repeated Interface Flap Pattern"@en ;
    rdfs:comment "Pattern indicating an interface repeatedly goes up and down, suggesting a physical layer issue or faulty transceiver."@en ;
    folio:hasCause "Faulty Transceiver"^^xsd:string .

<anomalypattern/HighCPUFollowedByApplicationErrors>
    a noria:AnomalyPattern ;
    rdfs:label "High CPU followed by Application Errors"@en ;
    rdfs:comment "Pattern where sustained high CPU usage on a server is quickly followed by application-specific error messages, indicating resource exhaustion."@en ;
    folio:hasCause "Resource Exhaustion"^^xsd:string .

# --- pep:ProcedureExecutionContainer and pep:ProcedureExecution (for noria:EventRecord) ---

<pep/ExecutionContainer_TT001_Diag>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution Container for TT-20240423-001 Diagnosis"@en ;
    rdfs:comment "Container for actions taken during diagnosis of TT-20240423-001."@en ;
    pep:member <event/Router_NYC_01_InterfaceDown> . # Linking the initial event as a member

<pep/ExecutionContainer_CR001_Upgrade>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution Container for CR-20240425-001 Upgrade"@en ;
    rdfs:comment "Container for actions taken during the software upgrade of CR-20240425-001."@en ;
    pep:member <event/CR_20240425_001_StatusChange> . # Example of an event related to the CR execution

<event/CR_20240425_001_StatusChange>
    a noria:EventRecord, pep:ProcedureExecution ;
    rdfs:label "CR-20240425-001 Status Change Event"@en ;
    rdfs:comment "Event recording the status change of CR-20240425-001 to 'Implemented'."@en ;
    noria:loggingTime "2024-04-25T03:45:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-20240425-001 status changed to Implemented."^^xsd:string ;
    noria:logOriginatingManagedObject <resource/Router_NYC_01> ;
    noria:logOriginatingManagementSystem <application/NetworkMonitoringSystem> ;
    noria:logOriginatingAgent <agent/JohnDoe> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmMitigatedBy <pep/ExecutionContainer_CR001_Upgrade> ;
    pep:usedProcedure <operationplan/RouterSoftwareUpgrade> .

