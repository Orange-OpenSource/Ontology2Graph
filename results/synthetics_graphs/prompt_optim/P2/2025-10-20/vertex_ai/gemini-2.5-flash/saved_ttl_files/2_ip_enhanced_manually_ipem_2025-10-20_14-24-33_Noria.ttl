# --- foaf:Agent and org:Organization/OrganizationalUnit entities ---

<agent/JohnDoe>
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A key individual responsible for network operations."@en ;
    foaf:name "John Doe"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<agent/JaneSmith>
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead engineer for application development."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Call directly for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<agent/AliceJohnson>
    a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "System administrator for core infrastructure."@en ;
    foaf:name "Alice Johnson"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use chat for quick questions."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

<org/NetworkOperations>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf <org/GlobalIT> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "Follow incident management procedures."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<org/ApplicationSupport>
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for critical business applications."@en ;
    org:unitOf <org/GlobalIT> ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Sat)"^^xsd:string ;
    noria:agentInstructions "Escalate to L3 for complex issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<org/GlobalIT>
    a org:Organization, foaf:Agent ;
    rdfs:label "Global IT Department"@en ;
    rdfs:comment "The overarching IT organization."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Refer to corporate guidelines."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<org/VendorTechSolutions>
    a org:Organization, foaf:Agent ;
    rdfs:label "Vendor Tech Solutions Inc."@en ;
    rdfs:comment "A third-party vendor providing hardware and software."@en ;
    noria:agentWorkingHours "24/7 Support"^^xsd:string ;
    noria:agentInstructions "Open a ticket via their portal."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

# --- noria:CorporateUserIdentifier entities ---

<cuid/johndoe_corp>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "johndoe"^^xsd:string ;
    foaf:holdsAccount <agent/JohnDoe> .

<cuid/janesmith_corp>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "janesmith"^^xsd:string ;
    foaf:holdsAccount <agent/JaneSmith> .

# --- bot:Site, noria:Room, noria:Locus entities ---

<site/DataCenter_NYC>
    a bot:Site ;
    rdfs:label "NYC Data Center"@en ;
    rdfs:comment "Main data center located in New York City."@en ;
    noria:siteId "DC-NYC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "New York"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string .

<site/Office_London>
