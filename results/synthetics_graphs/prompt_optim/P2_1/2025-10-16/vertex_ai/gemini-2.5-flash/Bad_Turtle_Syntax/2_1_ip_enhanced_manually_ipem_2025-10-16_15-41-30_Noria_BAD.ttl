<operationplan/router-firmware-upgrade>
    a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware."@en ;
    noria:operationPlanPreCondition <actionprecondition/router-reachability-check> ;
    noria:operationPlanPostCondition <actionpostcondition/router-operational-check> .

<actionprecondition/router-reachability-check>
    a noria:ActionPreCondition ;
    rdfs:label "Router Reachability Check"@en ;
    rdfs:comment "Pre-condition: Ensure router is reachable via management interface."@en .

<actionpostcondition/router-operational-check>
    a noria:ActionPostCondition ;
    rdfs:label "Router Operational Check"@en ;
    rdfs:comment "Post-condition: Verify router is operational and services restored."@en .

<anomalypattern/interface-flapping>
    a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating frequent up/down transitions on a network interface."@en ;
    folio:hasCause "Faulty cable or transceiver"^^xsd:string .

<pep/corrective-action-001>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Corrective Action for Interface Flapping"@en ;
    rdfs:comment "Procedure execution container for actions taken to resolve interface flapping."@en .

<pep/change-action-001>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Change Action for Router Upgrade"@en ;
    rdfs:comment "Procedure execution container for actions taken during router upgrade."@en .

<eventrecord/log-router-interface-down>
    noria:alarmProposedRepairAction <operationplan/router-firmware-upgrade> ;
    noria:alarmMonitoredAttribute <http://example.com/attribute/interface-status> ;
    noria:alarmMitigatedBy <pep/corrective-action-001> .

<http://example.com/attribute/interface-status>
    a ssn:Property ;
    rdfs:label "Interface Status Attribute"@en ;
    rdfs:comment "Monitored attribute for network interface status."@en .

<changerequest/cr-20240424-001>
    noria:actionCorrelatedOperationPlan <operationplan/router-firmware-upgrade> .

<troubleticketnote/tt-20240423-001-note-01>
    noria:troubleTicketNoteCorrelatedExecution <pep/corrective-action-001> .

