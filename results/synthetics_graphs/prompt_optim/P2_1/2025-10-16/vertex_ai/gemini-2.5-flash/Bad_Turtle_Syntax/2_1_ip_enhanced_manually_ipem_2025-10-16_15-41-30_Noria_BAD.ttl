<eventrecord/log-router-interface-down>
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject <resource/router-core-01> ;
    noria:logOriginatingManagementSystem <application/network-monitoring-system> ;
    noria:logOriginatingAgent <agent/john.doe> ; # Assuming John Doe was performing maintenance
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

