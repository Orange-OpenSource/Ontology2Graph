# --- KOS Concepts for various properties ---

<kos/application/type/WebApplication>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Web Application"@en ;
    rdfs:comment "A software application that runs on a web server and is accessed by users through a web browser."@en .

<kos/application/type/DatabaseService>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Database Service"@en ;
    rdfs:comment "A service providing access to a database system."@en .

<kos/application/type/MonitoringSystem>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring System"@en ;
    rdfs:comment "An application used for monitoring the health and performance of IT infrastructure."@en .

<kos/application/business-importance/High>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for core business operations."@en .

<kos/application/business-importance/Medium>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application supports important but not core business operations."@en .

<kos/application/sla-level/Gold>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement, 99.99% availability."@en .

<kos/application/sla-level/Silver>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Standard Service Level Agreement, 99.9% availability."@en .

<kos/application/status/InProduction>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently active and serving users."@en .

<kos/application/status/Staging>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Staging Environment"@en ;
    rdfs:comment "The application module is deployed in a staging environment for testing."@en .

<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by external customers."@en .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations, not directly exposed to customers."@en .

<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Incident causing severe impact on service availability or functionality."@en .

<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Incident causing significant impact, but not total outage."@en .

<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure Ticket"@en ;
    rdfs:comment "Ticket reporting a system or service failure."@en .

<kos/TroubleTicket/type/Assistance>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance Ticket"@en ;
    rdfs:comment "Ticket requesting assistance or support."@en .

<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate attention required."@en .

<kos/TroubleTicket/priority/P2>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, urgent attention required."@en .

<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Trouble ticket initiated by a customer."@en .

<kos/TroubleTicket/origin/Supervision>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision Origin"@en ;
    rdfs:comment "Trouble ticket initiated by a monitoring or supervision system."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Action required without delay."@en .

<kos/TroubleTicket/urgency/DeferredIntervention>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Action can be scheduled for a later time."@en .

<kos/TroubleTicket/trouble-category/TotalBreakdown>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Complete failure of a system or service."@en .

<kos/TroubleTicket/trouble-category/DegradedPerformance>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Degraded Performance"@en ;
    rdfs:comment "Service is operational but performing below expected levels."@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility lies with the team managing backbone network infrastructure."@en .

<kos/TroubleTicket/problemResponsibility/ApplicationTeam>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Application Team"@en ;
    rdfs:comment "Responsibility lies with the application development or support team."@en .

<kos/TroubleTicket/status/InProgress>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being worked on."@en .

<kos/TroubleTicket/status/Resolved>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue described in the trouble ticket has been resolved."@en .

<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team members."@en .

<kos/TroubleTicket/commentType/Customer>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer Comment"@en ;
    rdfs:comment "Comment provided by the customer."@en .

<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Operation related to diagnosing the root cause of an issue."@en .

<kos/TroubleTicket/operationType/Restoration>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Restoration Operation"@en ;
    rdfs:comment "Operation related to restoring service functionality."@en .

<kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request for internal system modifications."@en .

<kos/ChangeRequest/category/CustomerIntervention>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Customer Intervention"@en ;
    rdfs:comment "Change request requiring customer involvement."@en .

<kos/ChangeRequest/type/Standard>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk and impact."@en .

<kos/ChangeRequest/type/Normal>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Normal Change"@en ;
    rdfs:comment "A change that requires assessment and authorization."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change initiated due to a software upgrade requirement."@en .

<kos/ChangeRequest/cause/ConfigurationChange>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Change initiated to modify system configuration."@en .

<kos/ChangeRequest/status/Approved>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved Status"@en ;
    rdfs:comment "The change request has been approved and is awaiting implementation."@en .

<kos/ChangeRequest/status/Implemented>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented Status"@en ;
    rdfs:comment "The change request has been successfully implemented."@en .

<kos/ChangeRequest/specification/StandardProcedure>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Standard Procedure"@en ;
    rdfs:comment "A predefined and documented procedure for implementing the change."@en .

<kos/Resource/OperationalState/Up>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Operational State Up"@en ;
    rdfs:comment "The resource is fully operational."@en .

<kos/Resource/OperationalState/Down>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Operational State Down"@en ;
    rdfs:comment "The resource is not operational."@en .

<kos/Resource/AdministrativeState/Enabled>
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative State Enabled"@en ;
    rdfs:comment "The network interface is administratively enabled."@en .

<kos/Resource/AdministrativeState/Disabled>
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative State Disabled"@en ;
    rdfs:comment "The network interface is administratively disabled."@en .

<kos/Resource/LifecycleState/Production>
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Production Lifecycle State"@en ;
    rdfs:comment "The resource is in active production use."@en .

<kos/Resource/LifecycleState/Staging>
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Staging Lifecycle State"@en ;
    rdfs:comment "The resource is used in a staging environment."@en .

<kos/Resource/type/Server>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server Resource Type"@en ;
    rdfs:comment "A computing resource providing services to other computers."@en .

<kos/Resource/type/Router>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router Resource Type"@en ;
    rdfs:comment "A networking device that forwards data packets between computer networks."@en .

<kos/Resource/type/Firewall>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Firewall Resource Type"@en ;
    rdfs:comment "A network security system that monitors and controls incoming and outgoing network traffic."@en .

<Notification/Severity/PerceivedSeverity/Warning>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning Severity"@en ;
    rdfs:comment "An event indicating a potential problem that is not service-affecting."@en .

<Notification/Severity/PerceivedSeverity/Critical>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "An event indicating a severe service-affecting problem."@en .

<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email Contact Method"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone Contact Method"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# --- Organizational Entities ---

noria:person/JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee at Orange, responsible for network operations."@en ;
    foaf:name "John Doe"^^xsd:string ;
    foaf:mbox "john.doe@example.com"^^xsd:string ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string .

noria:person/JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead developer for the Inventory Management Application."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    foaf:mbox "jane.smith@example.com"^^xsd:string ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call for urgent application issues."^^xsd:string .

noria:person/AliceJohnson
    a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Security analyst responsible for firewall configurations."@en ;
    foaf:name "Alice Johnson"^^xsd:string ;
    foaf:mbox "alice.johnson@example.com"^^xsd:string ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For security incidents, use the dedicated incident response channel."^^xsd:string .

noria:org/NetworkOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the core network infrastructure."@en ;
    org:unitOf noria:org/OrangeTelecom ;
    org:hasMember noria:person/JohnDoe ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use ticketing system for all requests, escalate via phone for P1 incidents."^^xsd:string .

noria:org/ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing level 2 support for critical business applications."@en ;
    org:unitOf noria:org/OrangeTelecom ;
    org:hasMember noria:person/JaneSmith ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit all application issues via the dedicated support portal."^^xsd:string .

noria:org/SecurityOperationsCenter
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    org:unitOf noria:org/OrangeTelecom ;
    org:hasMember noria:person/AliceJohnson ;
    noria:agentWorkingHours "24/7 Monitoring"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate notification for critical security alerts."^^xsd:string .

noria:org/OrangeTelecom
    a org:Organization ;
    rdfs:label "Orange Telecom"@en ;
    rdfs:comment "The main telecommunications company."@en ;
    org:hasUnit noria:org/NetworkOperationsTeam, noria:org/ApplicationSupportTeam, noria:org/SecurityOperationsCenter .

noria:org/CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:org/HewlettPackardEnterprise
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of enterprise IT products and services."@en .

noria:org/PaloAltoNetworks
    a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "Manufacturer of cybersecurity platforms."@en .

noria:cuid/JohnDoeNetOps
    a noria:CorporateUserIdentifier, foaf:OnlineAccount, observable:UserAccount ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for John Doe within the corporate IT system."@en ;
    foaf:accountName "jdoe_netops"^^xsd:string ;
    observable:accountLogin "jdoe_netops"^^xsd:string ;
    observable:accountIdentifier "CUID-JD-001"^^xsd:string ;
    foaf:holdsAccount noria:person/JohnDoe .

noria:cuid/JaneSmithAppDev
    a noria:CorporateUserIdentifier, foaf:OnlineAccount, observable:UserAccount ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Jane Smith within the corporate IT system."@en ;
    foaf:accountName "jsmith_appdev"^^xsd:string ;
    observable:accountLogin "jsmith_appdev"^^xsd:string ;
    observable:accountIdentifier "CUID-JS-002"^^xsd:string ;
    foaf:holdsAccount noria:person/JaneSmith .

# --- Location Entities ---

noria:site/ParisDataCenter
    a bot:Site, org:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Republique"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Republique"^^xsd:string ;
    bot:hasSpace noria:room/ServerRoomA, noria:room/SecurityRoom .

noria:room/ServerRoomA
    a noria:Room, bot:Space ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace noria:locus/RackA1, noria:locus/RackA2 .

noria:room/SecurityRoom
    a noria:Room, bot:Space ;
    rdfs:label "Security Room"@en ;
    rdfs:comment "Dedicated room for security appliances in the Paris Data Center."@en ;
    bot:hasSpace noria:locus/RackS1 .

noria:locus/RackA1
    a noria:Locus, bot:Space ;
    rdfs:label "Rack A1 in Server Room A"@en ;
    rdfs:comment "Specific location for equipment within Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

noria:locus/RackA2
    a noria:Locus, bot:Space ;
    rdfs:label "Rack A2 in Server Room A"@en ;
    rdfs:comment "Specific location for equipment within Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

noria:locus/RackS1
    a noria:Locus, bot:Space ;
    rdfs:label "Rack S1 in Security Room"@en ;
    rdfs:comment "Specific location for security equipment within Security Room."@en ;
    noria:locusLine "S"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

# --- Product Model ---

noria:productModel/CiscoASR9K
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "Product model for Cisco ASR 9000 series routers."@en ;
    noria:productManufacturedBy noria:org/CiscoSystems .

noria:productModel/HPProLiantDL380
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Server"@en ;
    rdfs:comment "Product model for HP ProLiant DL380 servers."@en ;
    noria:productManufacturedBy noria:org/HewlettPackardEnterprise .

noria:productModel/PaloAltoFirewall
    a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5000 Series Firewall"@en ;
    rdfs:comment "Product model for Palo Alto Networks PA-5000 series firewalls."@en ;
    noria:productManufacturedBy noria:org/PaloAltoNetworks .

# --- Structural Elements ---

noria:resource/Router01
    a noria:Resource, seas:System, seas:CommunicationDevice, bot:Element, observable:Device, log:Host ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "A core network router in the Paris Data Center."@en ;
    noria:resourceLogisticId "RTR-PAR-01-LID"^^xsd:string ;
    noria:resourceHostName "router01.paris.example.com"^^xsd:string ;
    noria:resourceProductModel noria:productModel/CiscoASR9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-XYZ123"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:org/NetworkOperationsTeam ;
    noria:locatedAtLocus noria:locus/RackA1 ;
    noria:resourceManagementIPAddress observable:ipAddress/192.168.1.1 ;
    noria:agentManagesResource noria:org/NetworkOperationsTeam ;
    bot:hasElement noria:locus/RackA1 ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

noria:resource/Router02
