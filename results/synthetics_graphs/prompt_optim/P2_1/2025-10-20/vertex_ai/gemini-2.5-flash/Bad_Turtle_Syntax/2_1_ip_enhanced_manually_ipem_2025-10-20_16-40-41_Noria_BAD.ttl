# --- Procedural Elements ---

noria:anomalyPattern/HighCPULoad
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization, potentially leading to service degradation."@en ;
    folio:hasCause "Excessive requests or inefficient code execution."^^xsd:string .

noria:anomalyPattern/NetworkLatencySpike
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "Network Latency Spike Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sudden increase in network latency, affecting service responsiveness."@en ;
    folio:hasCause "Network congestion or faulty hardware."^^xsd:string .

noria:operationPlan/TroubleshootLinkFailure
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Troubleshoot Network Link Failure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network link failures."@en ;
    noria:operationPlanPreCondition noria:actionPreCondition/LinkDownDetected ;
    noria:operationPlanPostCondition noria:actionPostCondition/LinkRestored .

noria:operationPlan/WebAppUpgradeProcedure
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Web Application Upgrade Procedure"@en ;
    rdfs:comment "Procedure for upgrading the Customer Web Portal application."@en ;
    noria:operationPlanPreCondition noria:actionPreCondition/MaintenanceWindowApproved ;
    noria:operationPlanPostCondition noria:actionPostCondition/WebAppUpgraded .

noria:operationPlan/FirewallRuleDeployment
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Firewall Rule Deployment Procedure"@en ;
    rdfs:comment "Procedure for deploying new or updated firewall rules."@en ;
    noria:operationPlanPreCondition noria:actionPreCondition/RuleSetApproved ;
    noria:operationPlanPostCondition noria:actionPostCondition/RulesDeployedAndVerified .

noria:actionPreCondition/LinkDownDetected
    a noria:ActionPreCondition ;
    rdfs:label "Link Down Detected Pre-Condition"@en ;
    rdfs:comment "Pre-condition: A network link down event has been detected."@en .

noria:actionPostCondition/LinkRestored
    a noria:ActionPostCondition ;
    rdfs:label "Link Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: The network link has been successfully restored to operational state."@en .

noria:actionPreCondition/MaintenanceWindowApproved
    a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Approved Pre-Condition"@en ;
    rdfs:comment "Pre-condition: A maintenance window for the upgrade has been approved."@en .

noria:actionPostCondition/WebAppUpgraded
    a noria:ActionPostCondition ;
    rdfs:label "Web Application Upgraded Post-Condition"@en ;
    rdfs:comment "Post-condition: The web application has been successfully upgraded and verified."@en .

noria:actionPreCondition/RuleSetApproved
    a noria:ActionPreCondition ;
    rdfs:label "Firewall Rule Set Approved Pre-Condition"@en ;
    rdfs:comment "Pre-condition: The new firewall rule set has been approved by security."@en .

noria:actionPostCondition/RulesDeployedAndVerified
    a noria:ActionPostCondition ;
    rdfs:label "Firewall Rules Deployed and Verified Post-Condition"@en ;
    rdfs:comment "Post-condition: New firewall rules have been deployed and their functionality verified."@en .

noria:correctiveMaintenanceAction/RestoreRouterLink
    a pep:CorrectiveMaintenanceAction ;
    rdfs:label "Restore Router Link Action"@en ;
    rdfs:comment "An action taken to restore a router link."@en ;
    noria:actionCorrelatedOperationPlan noria:operationPlan/TroubleshootLinkFailure .

noria:changeAction/PerformWebAppUpgrade
    a pep:ChangeAction ;
    rdfs:label "Perform WebApp Upgrade Action"@en ;
    rdfs:comment "An action taken to perform the web application upgrade."@en ;
    noria:actionCorrelatedOperationPlan noria:operationPlan/WebAppUpgradeProcedure .

noria:changeAction/DeployFirewallRules
    a pep:ChangeAction ;
    rdfs:label "Deploy Firewall Rules Action"@en ;
    rdfs:comment "An action taken to deploy new firewall rules."@en ;
    noria:actionCorrelatedOperationPlan noria:operationPlan/FirewallRuleDeployment .

