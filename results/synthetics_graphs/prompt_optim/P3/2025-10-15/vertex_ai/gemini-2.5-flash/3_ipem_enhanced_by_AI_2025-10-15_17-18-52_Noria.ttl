# =============================================================================
# Core Organizational Entities
# =============================================================================

noria:Org_GlobalCorp a org:Organization ;
    rdfs:label "GlobalCorp Inc." ;
    rdfs:comment "A global telecommunications company." .

noria:Org_CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems" ;
    rdfs:comment "Manufacturer of network equipment." .

noria:Org_HPE a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise" ;
    rdfs:comment "Manufacturer of enterprise hardware." .

noria:OrgUnit_NetworkOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Team responsible for managing network infrastructure." ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email ;
    noria:agentInstructions "Contact via ticketing system for critical issues."^^xsd:string .

noria:OrgUnit_AppSupport a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support L2" ;
    rdfs:comment "Second-level support for critical applications." ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Phone ;
    noria:agentInstructions "Call hotline for P1/P2 incidents."^^xsd:string .

noria:Person_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith" ;
    rdfs:comment "Network Engineer, Team Lead for Network Operations." ;
    foaf:mbox <mailto:alice.smith@globalcorp.com> ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email ;
    noria:agentInstructions "Email for non-urgent matters."^^xsd:string .

noria:Person_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson" ;
    rdfs:comment "Application Specialist, L2 Support for Billing System." ;
    foaf:mbox <mailto:bob.johnson@globalcorp.com> ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Phone ;
    noria:agentInstructions "Available for urgent application issues."^^xsd:string .

noria:CorporateUserIdentifier_AliceCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID" ;
    rdfs:comment "Corporate user identifier for Alice Smith." ;
    foaf:accountName "asmith"^^xsd:string .

noria:CorporateUserIdentifier_BobCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID" ;
    rdfs:comment "Corporate user identifier for Bob Johnson." ;
    foaf:accountName "bjohnson"^^xsd:string .

noria:Person_AliceSmith foaf:holdsAccount noria:CorporateUserIdentifier_AliceCUid .
noria:Person_BobJohnson foaf:holdsAccount noria:CorporateUserIdentifier_BobCUid .

# =============================================================================
# Location Entities
# =============================================================================

noria:Site_DataCenter_Paris a bot:Site ;
    rdfs:label "Paris Data Center" ;
    rdfs:comment "Main data center facility in Paris." ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

noria:Room_ServerRoom_A1 a noria:Room ;
    rdfs:label "Server Room A1" ;
    rdfs:comment "Primary server room within the Paris Data Center." .

noria:Locus_Rack_R12_U24 a noria:Locus ;
    rdfs:label "Rack R12, Unit 24" ;
    rdfs:comment "Specific location for a server in Server Room A1." ;
    noria:locusLine "R12"^^xsd:string ;
    noria:locusRow "U24"^^xsd:string .

noria:Locus_Rack_R15_U10 a noria:Locus ;
    rdfs:label "Rack R15, Unit 10" ;
    rdfs:comment "Specific location for a network device in Server Room A1." ;
    noria:locusLine "R15"^^xsd:string ;
    noria:locusRow "U10"^^xsd:string .

# =============================================================================
# Structural Elements
# =============================================================================

noria:ProductModel_Cisco_ASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series" ;
    rdfs:comment "Product model for high-end Cisco routers." ;
    noria:productManufacturedBy noria:Org_CiscoSystems .

noria:ProductModel_HP_ProLiant_DL380 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10" ;
    rdfs:comment "Product model for HP enterprise servers." ;
    noria:productManufacturedBy noria:Org_HPE .

noria:Resource_Router_Edge01 a noria:Resource ;
    rdfs:label "Edge Router 01" ;
    rdfs:comment "Core edge router for internet connectivity." ;
    noria:elementDistinguishedName "router-edge-01.globalcorp.net"^^xsd:string ;
    noria:structuralElementDistinguishedName "router-edge-01.globalcorp.net"^^xsd:string ;
    noria:resourceLogisticId "LOG-RTR-001-PAR"^^xsd:string ;
    noria:resourceHostName "edge01.par.globalcorp.net"^^xsd:string ;
    noria:resourceSerialNumber "FOC12345678"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.1"^^observable:IPAddress ;
    noria:resourceManagedBy noria:OrgUnit_NetworkOps ;
    noria:resourceProductModel noria:ProductModel_Cisco_ASR9K ;
    noria:resourceType noria:ResourceType_Router ;
    noria:resourceUsageState noria:ResourceState_Production ;
    noria:locatedAtLocus noria:Locus_Rack_R15_U10 .

noria:Resource_Server_AppHost01 a noria:Resource ;
    rdfs:label "Application Host Server 01" ;
    rdfs:comment "Server hosting critical business applications." ;
    noria:elementDistinguishedName "apphost-01.globalcorp.net"^^xsd:string ;
    noria:structuralElementDistinguishedName "apphost-01.globalcorp.net"^^xsd:string ;
    noria:resourceLogisticId "LOG-SRV-001-PAR"^^xsd:string ;
    noria:resourceHostName "apphost01.par.globalcorp.net"^^xsd:string ;
    noria:resourceSerialNumber "ABC98765432"^^xsd:string ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.10"^^observable:IPAddress ;
    noria:resourceManagedBy noria:OrgUnit_AppSupport ;
    noria:resourceProductModel noria:ProductModel_HP_ProLiant_DL380 ;
    noria:resourceType noria:ResourceType_Server ;
    noria:resourceUsageState noria:ResourceState_Production ;
    noria:locatedAtLocus noria:Locus_Rack_R12_U24 .

noria:Resource_VirtualMachine_DB01 a noria:Resource ;
