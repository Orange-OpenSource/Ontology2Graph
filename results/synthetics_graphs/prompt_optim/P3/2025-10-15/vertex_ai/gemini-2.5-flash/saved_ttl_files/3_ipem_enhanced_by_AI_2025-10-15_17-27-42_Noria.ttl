noria-inst:AlarmEvent_NI_Down
    a noria:EventRecord ;
    rdfs:label "Network Interface Down Alarm"@en ;
    rdfs:comment "An event record indicating a network interface went down."@en ;
    noria:logOriginatingManagedObject noria-inst:CoreRouter01 ;
    noria:logOriginatingManagementSystem noria-inst:InternalMonitoringService ;
    noria:logOriginatingAgent noria-inst:NetworkOperationsTeam ;
    noria:logText "Interface Gig0/0/1 on corerouter01.example.com changed state to down."^^xsd:string ;
    noria:loggingTime "2024-03-15T14:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity noria-kos:PerceivedSeverity_Critical ;
    noria:alarmProposedRepairAction noria-inst:RestartInterfaceProcedure ;
    noria:alarmMonitoredAttribute noria-inst:CoreRouter01_Gig0_0_1 ;
.

noria-inst:ConfigChangeEvent_Router
    a noria:EventRecord ;
    rdfs:label "Router Configuration Change Event"@en ;
    rdfs:comment "An event record detailing a configuration change on a router."@en ;
    noria:logOriginatingManagedObject noria-inst:CoreRouter01 ;
    noria:logOriginatingManagementSystem noria-inst:InternalMonitoringService ;
    noria:logOriginatingAgent noria-inst:JohnDoe ;
    noria:logText "Configuration applied by jdoe: interface Gig0/0/1 no shutdown."^^xsd:string ;
    noria:loggingTime "2024-03-15T14:15:00Z"^^xsd:dateTime ;
.

