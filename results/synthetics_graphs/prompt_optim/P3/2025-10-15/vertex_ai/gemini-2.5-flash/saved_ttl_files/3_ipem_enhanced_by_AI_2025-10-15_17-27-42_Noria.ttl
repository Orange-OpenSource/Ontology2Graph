# =============================================================================
# Agents (foaf:Person, org:OrganizationalUnit)
# =============================================================================

noria-inst:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee responsible for network operations."@en ;
    foaf:name "John Doe"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:AgentContactMethod_Email ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
.

noria-inst:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An employee leading the application support team."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:AgentContactMethod_Phone ;
    noria:agentInstructions "Always call for immediate support."^^xsd:string ;
.

noria-inst:NetworkOperationsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf noria-inst:ITDepartment ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:AgentContactMethod_Phone ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
.

noria-inst:ApplicationSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    org:unitOf noria-inst:ITDepartment ;
    noria:agentWorkingHours "8:00-18:00 Mon-Sat"^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:AgentContactMethod_Email ;
    noria:agentInstructions "Submit a ticket via the portal."^^xsd:string ;
.

noria-inst:ITDepartment
    a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department of the organization."@en ;
.

# =============================================================================
# Corporate User Identifiers
# =============================================================================

noria-inst:JohnDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "CU-JD-001"^^xsd:string ;
.

noria-inst:JaneSmithCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountLogin "jsmith"^^xsd:string ;
    observable:accountIdentifier "CU-JS-002"^^xsd:string ;
.

# =============================================================================
# Location related (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria-inst:MainDataCenterSite
    a bot:Site ;
    rdfs:label "Main Data Center Site"@en ;
    rdfs:comment "The primary data center location."@en ;
    noria:siteId "DC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string ;
.

noria-inst:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the main data center."@en ;
    bot:hasSpace noria-inst:MainDataCenterSite ; # bot:hasSpace is inverse of bot:containsZone, so bot:hasSpace noria-inst:MainDataCenterSite means noria-inst:MainDataCenterSite bot:containsZone noria-inst:ServerRoomA
.

noria-inst:RackLocus_A1_R1
    a noria:Locus ;
    rdfs:label "Rack A1, Row 1 Locus"@en ;
    rdfs:comment "Specific location for Rack A1 in Row 1."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace noria-inst:ServerRoomA ; # noria-inst:ServerRoomA bot:containsZone noria-inst:RackLocus_A1_R1
.

noria-inst:RackLocus_B2_R3
    a noria:Locus ;
    rdfs:label "Rack B2, Row 3 Locus"@en ;
    rdfs:comment "Specific location for Rack B2 in Row 3."@en ;
    noria:locusLine "B2"^^xsd:string ;
    noria:locusRow "3"^^xsd:string ;
    bot:hasSpace noria-inst:ServerRoomA ;
.

# =============================================================================
# Product Models
# =============================================================================

noria-inst:DellPowerEdgeR740
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Product model for Dell PowerEdge R740 server."@en ;
    noria:productManufacturedBy noria-inst:DellCorporation ;
.

noria-inst:CiscoCatalyst9300
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Product model for Cisco Catalyst 9300 switch."@en ;
    noria:productManufacturedBy noria-inst:CiscoSystems ;
.

noria-inst:DellCorporation
    a org:Organization ;
    rdfs:label "Dell Corporation"@en ;
    rdfs:comment "Manufacturer of Dell products."@en ;
.

noria-inst:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of Cisco products."@en ;
.

# =============================================================================
# Applications and Services
# =============================================================================

noria-inst:WebPortalApp
    a noria:Application ;
    rdfs:label "Customer Web Portal"@en ;
    rdfs:comment "Main application for customer interaction."@en ;
    noria:applicationModelIdentifier "CWP-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CWP"^^xsd:string ;
    noria:applicationType noria-kos:ApplicationType_Web ;
    noria:applicationBusinessImportance noria-kos:ApplicationBusinessImportance_High ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Online Self-Service"^^xsd:string ;
    noria:elementManagedBy noria-inst:ApplicationSupportTeam ;
.

noria-inst:DatabaseServiceApp
    a noria:Application ;
    rdfs:label "Core Database Service"@en ;
    rdfs:comment "Backend database service supporting multiple applications."@en ;
    noria:applicationModelIdentifier "DBS-V1"^^xsd:string ;
    noria:applicationNumericalIdentifier "2002"^^xsd:int ;
    noria:applicationShortIdentifier "DBS"^^xsd:string ;
    noria:applicationType noria-kos:ApplicationType_Database ;
    noria:applicationBusinessImportance noria-kos:ApplicationBusinessImportance_High ;
    noria:applicationFunctionalDomain "Data Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Transactional Database"^^xsd:string ;
    noria:elementManagedBy noria-inst:ApplicationSupportTeam ;
.

noria-inst:WebPortalProdModule
    a noria:ApplicationModule ;
    rdfs:label "Web Portal Production Module"@en ;
    rdfs:comment "Production instance of the Customer Web Portal."@en ;
    noria:applicationModuleOf noria-inst:WebPortalApp ;
    noria:applicationModuleName "CWP_PROD_01"^^xsd:string ;
    noria:applicationModuleIdentifier "PROD-01"^^xsd:string ;
    noria:applicationModuleAdministrationTeam noria-inst:ApplicationSupportTeam ;
    noria:applicationModuleAdministrationLeader noria-inst:JaneSmith ;
    noria:applicationModuleSupportTeam noria-inst:ApplicationSupportTeam ;
    noria:applicationModuleSupportLeader noria-inst:JaneSmith ;
    noria:applicationModuleSupportGroup noria-inst:ApplicationSupportTeam ;
    noria:applicationModuleHotlineGroup noria-inst:NetworkOperationsTeam ;
    noria:applicationModuleSlaLevel noria-kos:ApplicationSlaLevel_Gold ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleStatus noria-kos:ApplicationStatus_Production ;
    noria:elementManagedBy noria-inst:ApplicationSupportTeam ;
.

noria-inst:WebPortalDevModule
    a noria:ApplicationModule ;
    rdfs:label "Web Portal Development Module"@en ;
    rdfs:comment "Development instance of the Customer Web Portal."@en ;
    noria:applicationModuleOf noria-inst:WebPortalApp ;
    noria:applicationModuleName "CWP_DEV_01"^^xsd:string ;
    noria:applicationModuleIdentifier "DEV-01"^^xsd:string ;
    noria:applicationModuleAdministrationTeam noria-inst:ApplicationSupportTeam ;
    noria:applicationModuleAdministrationLeader noria-inst:JaneSmith ;
    noria:applicationModuleSlaLevel noria-kos:ApplicationSlaLevel_Silver ;
    noria:applicationModuleSlaLevelDate "2023-03-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "false"^^xsd:boolean ;
    noria:applicationModuleStatus noria-kos:ApplicationStatus_Development ;
    noria:elementManagedBy noria-inst:ApplicationSupportTeam ;
.

noria-inst:CustomerConnectivityService
    a noria:Service ;
    rdfs:label "Customer Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing internet connectivity to customers."@en ;
    noria:serviceType noria-kos:ServiceType_CustomerFacing ;
    seas:subSystemOf noria-inst:WebPortalProdModule ; # Example of linking a service to an application module
    noria:elementManagedBy noria-inst:NetworkOperationsTeam ;
.

noria-inst:InternalMonitoringService
    a noria:Service ;
    rdfs:label "Internal Monitoring Service"@en ;
    rdfs:comment "Service for monitoring internal infrastructure and applications."@en ;
    noria:serviceType noria-kos:ServiceType_Internal ;
    noria:elementManagedBy noria-inst:NetworkOperationsTeam ;
.

