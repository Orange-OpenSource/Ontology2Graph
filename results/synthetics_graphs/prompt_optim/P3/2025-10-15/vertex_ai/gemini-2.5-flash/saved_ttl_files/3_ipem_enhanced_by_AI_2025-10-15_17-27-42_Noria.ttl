noria-inst:TroubleTicket_001
    a noria:TroubleTicket ;
    rdfs:label "Web Portal Outage Ticket"@en ;
    rdfs:comment "Trouble ticket for a critical outage of the customer web portal."@en ;
    noria:documentExternalId "EXT-TT-98765"^^xsd:string ;
    noria:documentHRef "https://ticketing.example.com/TT-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity noria-kos:TroubleTicketSeverity_Major ;
    noria:troubleTicketType noria-kos:TroubleTicketType_Failure ;
    noria:troubleTicketCriticity noria-kos:TroubleTicketCriticity_InterruptedService ;
    noria:troubleTicketPriority noria-kos:TroubleTicketPriority_P1 ;
    noria:troubleTicketOrigin noria-kos:TroubleTicketOrigin_Supervision ;
    noria:troubleTicketTrigger noria-inst:AlarmEvent_NI_Down ;
    noria:troubleTicketUrgency noria-kos:TroubleTicketUrgency_Immediate ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory noria-kos:TroubleTicketTroubleCategory_NetworkOutage ;
    noria:problemCategory noria-kos:TroubleTicketTroubleCategory_NetworkOutage ;
    noria:troubleTicketCause "Network interface on core router went down, impacting web server connectivity."^^xsd:string ;
    noria:problemResponsibility noria-kos:TroubleTicketProblemResponsibility_ManagedBackbone ;
    noria:troubleTicketDetectionDateTime "2024-03-15T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T15:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-15T14:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-03-15T16:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent noria-kos:TroubleTicketStatus_InProgress ;
    noria:troubleTicketRelatedParty noria-inst:NetworkOperationsTeam, noria-inst:JohnDoe ;
    noria:troubleTicketRelatedService noria-inst:WebPortalProdModule ;
    noria:troubleTicketRelatedResource noria-inst:CoreRouter01, noria-inst:WebServer01 ;
    noria:troubleTicketImpacts noria-inst:WebPortalProdModule, noria-inst:CustomerConnectivityService ;
    noria:troubleTicketCharacteristic noria-inst:TroubleTicketCharacteristic_HighImpact ;
    noria:troubleTicketFreezeItem noria-inst:EventRecord_TT_Freeze_001 ;
    noria:documentStatusHistory noria-inst:EventRecord_TT_StatusChange_InProgress ;
    noria:eventRelatedElement noria-inst:WebPortalProdModule ; # Example of using abstract property
    noria:eventRelatedParty noria-inst:NetworkOperationsTeam ; # Example of using abstract property
.

