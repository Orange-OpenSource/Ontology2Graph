# =============================================================================
# Anomaly Patterns, Operation Plans, Action Pre/Post Conditions
# =============================================================================

noria-inst:NetworkInterfaceDownAnomaly
    a noria:AnomalyPattern ;
    rdfs:label "Network Interface Down Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing a network interface going down unexpectedly."@en ;
    folio:hasFailureModeType "Operational Failure"^^xsd:string ;
.

noria-inst:RestartInterfaceProcedure
    a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a network interface."@en ;
    noria:operationPlanPreCondition noria-inst:InterfaceDownPreCondition ;
    noria:operationPlanPostCondition noria-inst:InterfaceUpPostCondition ;
.

noria-inst:InterfaceDownPreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Network interface is in a down state."@en ;
.

noria-inst:InterfaceUpPostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Interface Up Post-Condition"@en ;
    rdfs:comment "Post-condition: Network interface is in an up state."@en ;
.

noria-inst:DiagnosisProcedureExecution
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Diagnosis Procedure Execution for TT-001"@en ;
    rdfs:comment "Container for the execution of diagnosis steps related to TT-001."@en ;
    pep:hasProcedure noria-inst:RestartInterfaceProcedure ;
    noria:alarmMitigatedBy noria-inst:DiagnosisProcedureExecution ; # Example of linking back
.

