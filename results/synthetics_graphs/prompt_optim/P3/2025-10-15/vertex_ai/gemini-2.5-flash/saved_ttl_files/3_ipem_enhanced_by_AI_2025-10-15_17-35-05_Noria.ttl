noria:ServiceType_ResourceFacing
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "Service managing internal resources."@en .

<kos/TroubleTicket/severity>
