noria:TTCriticity_Interrupted
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "Service is completely unavailable."@en .

noria:TTCriticity_Corrupted
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Corrupted Service"@en ;
    rdfs:comment "Service is available but data integrity is compromised."@en .

<kos/TroubleTicket/priority>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "Defines the priority levels for trouble ticket management."@en .

noria:TTPriority_P1
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate action required."@en .

noria:TTPriority_P2
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, urgent action required."@en .

<kos/TroubleTicket/origin>
