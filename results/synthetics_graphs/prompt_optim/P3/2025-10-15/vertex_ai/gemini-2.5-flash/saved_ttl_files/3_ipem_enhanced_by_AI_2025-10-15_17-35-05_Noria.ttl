    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "Defines the severity levels for trouble tickets."@en .

noria:TTSeverity_Major
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Significant impact on service."@en .

noria:TTSeverity_Minor
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor Severity"@en ;
    rdfs:comment "Limited impact on service."@en .

<kos/TroubleTicket/type>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "Categorizes types of trouble tickets."@en .

noria:TTType_Failure
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure Ticket"@en ;
    rdfs:comment "Ticket reporting a system failure."@en .

noria:TTType_Assistance
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance Request"@en ;
    rdfs:comment "Ticket requesting technical assistance."@en .

<kos/TroubleTicket/category>
