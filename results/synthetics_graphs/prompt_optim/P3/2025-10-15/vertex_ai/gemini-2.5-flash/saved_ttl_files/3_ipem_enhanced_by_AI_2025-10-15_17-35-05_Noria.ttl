# =============================================================================
# Agent Instances (foaf:Person, org:OrganizationalUnit)
# =============================================================================

noria:Person_AliceSmith
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "An employee responsible for network operations."@en ;
    foaf:name "Alice Smith"^^xsd:string ;
    foaf:mbox "mailto:alice.smith@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    .

noria:Person_BobJohnson
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "A senior network engineer."@en ;
    foaf:name "Bob Johnson"^^xsd:string ;
    foaf:mbox "mailto:bob.johnson@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Phone ;
    noria:agentInstructions "Always call for immediate support."^^xsd:string ;
    .

noria:OrgUnit_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf <https://www.example.com/organization/ITDept> ;
    noria:agentWorkingHours "24/7 coverage"^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Phone ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    .

noria:OrgUnit_AppSupport
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for critical applications."@en ;
    org:unitOf <https://www.example.com/organization/ITDept> ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Sat)"^^xsd:string ;
    noria:agentPreferredContactMethod noria:ContactMethod_Email ;
    noria:agentInstructions "Submit tickets via portal, email for follow-up."^^xsd:string ;
    .

# =============================================================================
# noria:CorporateUserIdentifier Instances
# =============================================================================

noria:CUid_ASmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "CU-AS-001"^^xsd:string ;
    .

noria:CUid_BJohnson
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Corporate user identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "CU-BJ-002"^^xsd:string ;
    .

