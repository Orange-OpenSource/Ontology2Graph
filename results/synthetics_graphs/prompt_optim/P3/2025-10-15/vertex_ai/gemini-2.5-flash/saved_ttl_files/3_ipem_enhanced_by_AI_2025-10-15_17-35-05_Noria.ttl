# =============================================================================
# SKOS Concept Schemes and Concepts
# =============================================================================

<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "Defines methods for contacting agents."@en .

noria:ContactMethod_Email
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via email."@en .

noria:ContactMethod_Phone
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via phone."@en .

<kos/application/type>
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "Categorizes types of applications."@en .

noria:AppType_ServicePlatform
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "An application acting as a service platform."@en .

noria:AppType_Infrastructure
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application managing infrastructure components."@en .

<kos/application/business-importance>
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "Defines the business importance level of an application."@en .

noria:BizImportance_High
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for business operations."@en .

noria:BizImportance_Medium
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application has moderate business impact."@en .

<kos/application/sla-level>
    a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "Defines Service Level Agreement levels for applications."@en .

noria:SLA_Gold
    a skos:Concept ;
