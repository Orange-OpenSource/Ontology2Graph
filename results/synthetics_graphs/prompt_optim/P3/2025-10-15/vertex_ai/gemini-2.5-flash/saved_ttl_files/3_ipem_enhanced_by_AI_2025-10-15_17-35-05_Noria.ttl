    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest service level agreement."@en .

noria:SLA_Silver
    a skos:Concept ;
    skos:inScheme <kos/application/sla-level> ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Standard service level agreement."@en .

<kos/application/status>
    a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
