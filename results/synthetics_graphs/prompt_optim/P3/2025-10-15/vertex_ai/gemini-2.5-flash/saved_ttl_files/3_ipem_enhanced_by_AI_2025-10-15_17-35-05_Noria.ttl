# =============================================================================
# noria:Room and noria:Locus Instances
# =============================================================================

noria:Site_MainDataCenter
    a bot:Site ;
    rdfs:label "Main Data Center Site"@en ;
    rdfs:comment "The primary data center facility."@en ;
    noria:siteId "DC-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string ;
    .

noria:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the main data center."@en ;
    bot:hasSpace noria:Locus_RackA1 ;
    bot:hasSpace noria:Locus_RackA2 ;
    bot:hasSubSpace noria:Site_MainDataCenter ; # Assuming bot:hasSubSpace can link to a site
    .

noria:Locus_RackA1
    a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Specific location for equipment in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    .

noria:Locus_RackA2
    a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Specific location for equipment in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    .

