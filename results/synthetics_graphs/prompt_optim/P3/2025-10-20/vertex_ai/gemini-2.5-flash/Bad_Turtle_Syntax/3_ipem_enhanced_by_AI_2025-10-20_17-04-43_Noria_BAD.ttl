noria:ProceduralObject
    a owl:Class ;
    rdfs:label "Procedural Object"@en ;
    rdfs:comment "An abstract class for objects related to procedures and processes, serving as a base for anomaly patterns and operation plans."@en ;
    rdfs:subClassOf noria:ManagedElement ;
.

noria:StructuralProperty
    a owl:Class ;
    rdfs:label "Structural Property"@en ;
    rdfs:comment "An abstract class for properties of structural elements, such as product models."@en ;
    rdfs:subClassOf noria:Property ;
.

noria:CorrectiveMaintenanceAction
    a owl:Class ;
    rdfs:label "Corrective Maintenance Action"@en ;
    rdfs:comment "An action taken to correct a fault or issue, often part of a Trouble Ticket resolution."@en ;
    rdfs:subClassOf pep:ProcedureExecution ;
.

noria:ChangeAction
    a owl:Class ;
    rdfs:label "Change Action"@en ;
    rdfs:comment "An action taken as part of a change request, detailing specific steps or modifications."@en ;
    rdfs:subClassOf pep:ProcedureExecution ;
.

