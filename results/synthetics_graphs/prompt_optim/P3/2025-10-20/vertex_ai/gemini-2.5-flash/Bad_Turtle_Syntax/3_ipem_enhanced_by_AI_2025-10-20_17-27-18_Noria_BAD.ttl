# --- SKOS Concept Schemes and Concepts ---

kos:org/agent-contact-method
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

kos:ContactMethod_Email
    a skos:Concept ;
    skos:inScheme kos:org/agent-contact-method ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via email."@en .

kos:ContactMethod_Phone
    a skos:Concept ;
    skos:inScheme kos:org/agent-contact-method ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via phone."@en .

kos:application/type
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for types of applications."@en .

kos:AppType_Web
    a skos:Concept ;
    skos:inScheme kos:application/type ;
    rdfs:label "Web Application"@en ;
    rdfs:comment "An application accessible via a web browser."@en .

kos:AppType_Backend
    a skos:Concept ;
    skos:inScheme kos:application/type ;
    rdfs:label "Backend Service"@en ;
    rdfs:comment "A service running on the server-side, typically without a direct user interface."@en .

kos:AppType_Database
    a skos:Concept ;
    skos:inScheme kos:application/type ;
    rdfs:label "Database System"@en ;
    rdfs:comment "A system primarily for storing and retrieving data."@en .

kos:application/business-importance
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the business importance of applications."@en .

kos:BizImp_Critical
    a skos:Concept ;
    skos:inScheme kos:application/business-importance ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for core business operations."@en .

kos:BizImp_High
    a skos:Concept ;
    skos:inScheme kos:application/business-importance ;
    rdfs:label "High"@en ;
    rdfs:comment "Application has high business importance."@en .

kos:application/sla-level
    a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "A controlled vocabulary for Service Level Agreement levels for applications."@en .

kos:SLA_Gold
    a skos:Concept ;
    skos:inScheme kos:application/sla-level ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "Highest Service Level Agreement tier."@en .

kos:SLA_Silver
    a skos:Concept ;
    skos:inScheme kos:application/sla-level ;
    rdfs:label "Silver SLA"@en ;
    rdfs:comment "Mid-tier Service Level Agreement."@en .

kos:application/status
    a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the operational status of application modules."@en .

kos:AppStatus_Production
    a skos:Concept ;
    skos:inScheme kos:application/status ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application module is currently live and serving users."@en .

kos:AppStatus_Development
    a skos:Concept ;
    skos:inScheme kos:application/status ;
    rdfs:label "In Development"@en ;
    rdfs:comment "Application module is under active development."@en .

kos:service/type
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for types of services."@en .

kos:ServiceType_CustomerFacing
    a skos:Concept ;
    skos:inScheme kos:service/type ;
    rdfs:label "Customer-Facing Service"@en ;
    rdfs:comment "A service directly consumed by external customers."@en .

kos:ServiceType_Internal
    a skos:Concept ;
    skos:inScheme kos:service/type ;
    rdfs:label "Internal Service"@en ;
    rdfs:comment "A service used internally within the organization."@en .

