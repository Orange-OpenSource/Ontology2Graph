    noria:eventRelatedElement inst:WebServer_01, inst:DBServer_01 ;
    noria:eventRelatedParty inst:Person_Alice .

inst:NetworkMonitoringService
    noria:elementManagedBy inst:Org_NetworkOps ;
    noria:eventRelatedElement inst:Router_Core_01, inst:Switch_Access_01 ;
    noria:eventRelatedParty inst:Person_Bob .

inst:TT_001
    noria:troubleTicketCharacteristic inst:HighCPUAnomaly .

inst:CR_001
    noria:changeRequestImpact inst:App_CRM, inst:CustomerServicePortal .

inst:Org_ITDept
    noria:agentManagesResource inst:WebServer_01, inst:DBServer_01, inst:App_CRM, inst:CRM_Frontend, inst:CRM_Backend, inst:CustomerServicePortal .

inst:Org_NetworkOps
    noria:agentManagesResource inst:Router_Core_01, inst:Switch_Access_01, inst:Link_WebDB, inst:Link_RouterSwitch, inst:App_Monitoring, inst:NetworkMonitoringService .

inst:Person_Alice
    noria:agentManagesResource inst:App_CRM, inst:CRM_Frontend, inst:CRM_Backend .

inst:Person_Bob
    noria:agentManagesResource inst:Router_Core_01, inst:Switch_Access_01, inst:Link_RouterSwitch, inst:App_Monitoring .

inst:CPUUsage
    noria:structuralObservableOf inst:WebServer_01 .

inst:MemoryLoad
    noria:structuralObservableOf inst:WebServer_01 .

inst:DiskIOPS
    noria:structuralObservableOf inst:DBServer_01 .

inst:NetworkLatency
    noria:structuralObservableOf inst:Router_Core_01 .

