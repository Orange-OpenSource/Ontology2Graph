# --- Anomaly Pattern Instances ---

inst:HighCPUAnomaly
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Usage Anomaly Pattern"@en ;
    rdfs:comment "A pattern indicating abnormally high CPU usage, potentially leading to service degradation."@en ;
    folio:hasCause "Inefficient application code or resource contention."^^xsd:string ;
    folio:hasEffect "Service unresponsiveness, system crash."^^xsd:string .

inst:NetworkOutagePattern
    a noria:AnomalyPattern ;
    rdfs:label "Network Outage Anomaly Pattern"@en ;
    rdfs:comment "A pattern indicating a complete loss of network connectivity."@en ;
    folio:hasCause "Fiber cut, device failure, misconfiguration."^^xsd:string ;
    folio:hasEffect "Complete service disruption, data loss."^^xsd:string .

# --- Operation Plan Instances ---

inst:ServerRestartPlan
    a noria:OperationPlan ;
    rdfs:label "Server Restart Operation Plan"@en ;
    rdfs:comment "A standardized procedure for safely restarting a server."@en ;
    pep:hasInput "Server identifier, confirmation from owner."^^xsd:string ;
    pep:hasOutput "Server restarted, services restored."^^xsd:string ;
    noria:operationPlanPreCondition inst:ServerReachable ;
    noria:operationPlanPostCondition inst:ServiceRestored .

inst:NetworkFailoverPlan
    a noria:OperationPlan ;
    rdfs:label "Network Failover Operation Plan"@en ;
    rdfs:comment "A standardized procedure for activating network redundancy in case of a link failure."@en ;
    pep:hasInput "Affected link identifier, backup link status."^^xsd:string ;
    pep:hasOutput "Traffic rerouted, primary link isolated."^^xsd:string ;
    noria:operationPlanPreCondition inst:BackupReady ;
    noria:operationPlanPostCondition inst:TrafficRerouted .

# --- Action Pre/Post Condition Instances ---

inst:ServerReachable
    a noria:ActionPreCondition ;
    rdfs:label "Server Reachable Pre-Condition"@en ;
    rdfs:comment "Condition: The target server must be reachable via ping or SSH."@en .

inst:BackupReady
    a noria:ActionPreCondition ;
    rdfs:label "Backup Link Ready Pre-Condition"@en ;
    rdfs:comment "Condition: The redundant network link must be operational and ready for traffic."@en .

inst:ServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Outcome: The affected service is fully operational and accessible."@en .

inst:TrafficRerouted
    a noria:ActionPostCondition ;
    rdfs:label "Traffic Rerouted Post-Condition"@en ;
    rdfs:comment "Outcome: Network traffic has successfully shifted to the backup path."@en .

# --- Linking EventRecords to OperationPlans (via actionCorrelatedOperationPlan) ---
# Note: noria:EventRecord is a subclass of pep:ProcedureExecution, which is a valid domain for actionCorrelatedOperationPlan.

inst:Event_CPUAlert
    noria:actionCorrelatedOperationPlan inst:ServerRestartPlan .

inst:Event_LinkDown
    noria:actionCorrelatedOperationPlan inst:NetworkFailoverPlan .

# --- Linking TroubleTickets/ChangeRequests to EventRecords (via alarmMitigatedBy) ---
# Note: noria:TroubleTicket and noria:ChangeRequest are subclasses of pep:ProcedureExecutionContainer.

inst:Event_CPUAlert
    noria:alarmMitigatedBy inst:TT_001 .

inst:Event_LinkDown
    noria:alarmMitigatedBy inst:TT_002 .

inst:Event_ConfigChange
    noria:alarmMitigatedBy inst:CR_001 .

