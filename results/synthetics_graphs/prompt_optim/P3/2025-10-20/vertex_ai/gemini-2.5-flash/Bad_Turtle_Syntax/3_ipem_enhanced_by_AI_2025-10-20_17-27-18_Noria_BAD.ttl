# --- Agent and Organization Instances ---

inst:Org_ITDept
    a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The central Information Technology department responsible for infrastructure and applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod kos:ContactMethod_Email .

inst:Org_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "The team responsible for monitoring and managing the network infrastructure."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "For critical issues, use hotline. For non-critical, email."^^xsd:string ;
    noria:agentPreferredContactMethod kos:ContactMethod_Phone ;
    org:unitOf inst:Org_ITDept .

inst:Org_SecurityTeam
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "The team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Report all security incidents via dedicated portal."^^xsd:string ;
    noria:agentPreferredContactMethod kos:ContactMethod_Email ;
    org:unitOf inst:Org_ITDept .

inst:Person_Alice
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead DevOps Engineer."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Email for general queries, Slack for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod kos:ContactMethod_Email ;
    org:memberOf inst:Org_ITDept .

inst:Person_Bob
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Call during working hours for network issues."^^xsd:string ;
    noria:agentPreferredContactMethod kos:ContactMethod_Phone ;
    org:memberOf inst:Org_NetworkOps .

inst:Person_Charlie
    a foaf:Person ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    noria:agentWorkingHours "10:00 am - 7:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Available via internal chat for application support."^^xsd:string ;
    noria:agentPreferredContactMethod kos:ContactMethod_Email ;
    org:memberOf inst:Org_ITDept .

inst:CUid_Alice
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within the corporate IT system."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountLogin "asmith"^^xsd:string ;
    observable:accountIdentifier "U-ASMITH-001"^^xsd:string ;
    foaf:holdsAccount inst:Person_Alice .

inst:CUid_Bob
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Bob Johnson within the corporate IT system."@en ;
    foaf:accountName "bjohnson"^^xsd:string ;
    observable:accountLogin "bjohnson"^^xsd:string ;
    observable:accountIdentifier "U-BJOHNSON-002"^^xsd:string ;
    foaf:holdsAccount inst:Person_Bob .

# --- Location Instances ---

inst:Site_MainDC
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "The primary data center facility."@en ;
    noria:siteId "DC-MAIN-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue, Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue"^^xsd:string ;
    wgs84_pos:lat "34.0522"^^xsd:decimal ;
    wgs84_pos:long "-118.2437"^^xsd:decimal .

inst:Site_DRC
    a bot:Site ;
    rdfs:label "Disaster Recovery Center"@en ;
    rdfs:comment "The secondary data center for disaster recovery."@en ;
    noria:siteId "DC-DR-02"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "456 Backup Boulevard, Gotham"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "20002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Gotham"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "456 Backup Boulevard"^^xsd:string ;
    wgs84_pos:lat "40.7128"^^xsd:decimal ;
    wgs84_pos:long "-74.0060"^^xsd:decimal .

inst:ServerRoom_A
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Main Data Center."@en ;
    bot:hasSpace inst:Rack_A1_U10 ;
    bot:hasSpace inst:Rack_A2_U15 ;
    bot:locatedIn inst:Site_MainDC .

inst:DataCenter_HallB
    a noria:Room ;
    rdfs:label "Data Center Hall B"@en ;
    rdfs:comment "A large hall in the Disaster Recovery Center."@en ;
    bot:hasSpace inst:Rack_B5_U22 ;
    bot:locatedIn inst:Site_DRC .

inst:Rack_A1_U10
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "10"^^xsd:string ;
    bot:locatedIn inst:ServerRoom_A .

inst:Rack_A2_U15
    a noria:Locus ;
    rdfs:label "Rack A2, Unit 15"@en ;
    rdfs:comment "Specific location for a database server in Server Room A."@en ;
    noria:locusLine "A2"^^xsd:string ;
    noria:locusRow "15"^^xsd:string ;
    bot:locatedIn inst:ServerRoom_A .

inst:Rack_B5_U22
    a noria:Locus ;
    rdfs:label "Rack B5, Unit 22"@en ;
    rdfs:comment "Specific location for a network device in Data Center Hall B."@en ;
    noria:locusLine "B5"^^xsd:string ;
    noria:locusRow "22"^^xsd:string ;
    bot:locatedIn inst:DataCenter_HallB .

