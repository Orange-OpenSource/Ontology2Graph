noria:ProceduralObject
    a owl:Class ;
    rdfs:label "Procedural Object"@en ;
    rdfs:comment "An abstract class for objects related to procedures and operations."@en ;
    rdfs:subClassOf noria:ProceduralElement ;
.

noria:StructuralProperty
    a owl:Class ;
    rdfs:label "Structural Property"@en ;
    rdfs:comment "An abstract class for properties related to structural elements."@en ;
    rdfs:subClassOf noria:Property ;
.

observable:IPAddress
    a owl:Class ;
    rdfs:label "IP Address Entity"@en ;
    rdfs:comment "Represents an IP address as an entity, allowing it to be the object of an object property."@en ;
.

