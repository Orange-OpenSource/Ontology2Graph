    noria:elementDistinguishedName "AppServerOptimization_DN"^^xsd:string ;
    noria:elementManagedBy <noria:instance/Group/ApplicationSupportTeam> .

<noria:instance/OperationPlan/NetworkUpgradeProcedure>
