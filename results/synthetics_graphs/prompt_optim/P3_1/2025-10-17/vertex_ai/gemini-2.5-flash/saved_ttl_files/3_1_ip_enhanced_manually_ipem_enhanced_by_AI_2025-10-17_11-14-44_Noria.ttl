# --- noria:AnomalyPattern Instances ---

<noria:instance/AnomalyPattern/HighCPULowThroughput>
    a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Throughput Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential performance bottleneck or application issue: high CPU usage on a server combined with unexpectedly low network throughput."@en ;
    folio:hasConsequence <noria:instance/TroubleTicket/TT-20240420-002> ;
    noria:elementDistinguishedName "HighCPULowThroughput_DN"^^xsd:string ;
    noria:elementProperty <noria:instance/EventRecord/AppServerCPUHigh> .

<noria:instance/AnomalyPattern/LinkFlap>
    a noria:AnomalyPattern ;
    rdfs:label "Network Link Flap Anomaly"@en ;
    rdfs:comment "Pattern indicating an unstable network link: interface repeatedly goes up and down in a short period."@en ;
    folio:hasConsequence <noria:instance/TroubleTicket/TT-20240420-001> ;
    noria:elementDistinguishedName "LinkFlap_DN"^^xsd:string .

<noria:instance/AnomalyPattern/BackupStorageFull>
    a noria:AnomalyPattern ;
    rdfs:label "Backup Storage Full Anomaly"@en ;
    rdfs:comment "Pattern indicating backup failures due to insufficient storage space."@en ;
    folio:hasConsequence <noria:instance/TroubleTicket/TT-20240420-003> ;
    noria:elementDistinguishedName "BackupStorageFull_DN"^^xsd:string .

# --- noria:OperationPlan Instances ---

<noria:instance/OperationPlan/RouterTroubleshootingGuide>
