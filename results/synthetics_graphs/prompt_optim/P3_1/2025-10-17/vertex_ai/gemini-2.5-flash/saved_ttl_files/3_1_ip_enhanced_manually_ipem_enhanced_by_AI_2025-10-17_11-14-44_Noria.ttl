# --- foaf:Agent (Person and Group) Instances ---

<noria:instance/Person/JohnDoe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A senior network engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:elementDistinguishedName "JohnDoe_DN"^^xsd:string .

<noria:instance/Person/JaneSmith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An application support specialist."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Use ticketing system first, then phone."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:elementDistinguishedName "JaneSmith_DN"^^xsd:string .

<noria:instance/Person/AliceWonder>
    a foaf:Person ;
    rdfs:label "Alice Wonder"@en ;
    rdfs:comment "Junior network engineer."@en ;
    foaf:mbox <mailto:alice.wonder@example.com> ;
    foaf:phone "+1-555-111-2222" ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Shadow John Doe for network issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:elementDistinguishedName "AliceWonder_DN"^^xsd:string .

<noria:instance/Group/NetworkOperationsTeam>
    a foaf:Group ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentInstructions "Open a P1 ticket for immediate attention."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentManagesResource <noria:instance/Resource/RouterCore01> ;
    noria:agentManagesResource <noria:instance/NetworkLink/BackboneLinkParisLondon> ;
    noria:elementDistinguishedName "NetworkOperationsTeam_DN"^^xsd:string .

<noria:instance/Group/ApplicationSupportTeam>
    a foaf:Group ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for critical business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Submit a ticket via the portal."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource <noria:instance/Resource/ServerApp01> ;
    noria:agentManagesResource <noria:instance/Resource/VirtualServerDB01> ;
    noria:agentManagesResource <noria:instance/NetworkLink/ServerToSwitchLink> ;
    noria:elementDistinguishedName "ApplicationSupportTeam_DN"^^xsd:string .

<noria:instance/Group/SecurityOperationsCenter>
    a foaf:Group ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Alert via dedicated security incident platform."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentManagesResource <noria:instance/Application/MonitoringDashboard> ;
    noria:elementDistinguishedName "SecurityOperationsCenter_DN"^^xsd:string .

