    rdfs:comment "Standard operating procedure for diagnosing and resolving router issues."@en ;
    noria:operationPlanPreCondition <noria:instance/ActionPreCondition/RouterUnreachable> ;
    noria:operationPlanPostCondition <noria:instance/ActionPostCondition/RouterRestored> ;
    noria:elementDistinguishedName "RouterTroubleshootingGuide_DN"^^xsd:string ;
