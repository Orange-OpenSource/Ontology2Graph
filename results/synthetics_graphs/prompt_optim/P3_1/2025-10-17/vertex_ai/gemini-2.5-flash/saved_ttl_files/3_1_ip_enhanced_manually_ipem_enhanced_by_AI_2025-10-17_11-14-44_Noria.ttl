    noria:operationPlanPostCondition <noria:instance/ActionPostCondition/SoftwareUpgradeCompleted> ;
    noria:elementDistinguishedName "NetworkUpgradeProcedure_DN"^^xsd:string .

<noria:instance/OperationPlan/BackupTroubleshootingGuide>
    a noria:OperationPlan ;
    rdfs:label "Backup System Troubleshooting Guide"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving backup system issues."@en ;
    noria:operationPlanPreCondition <noria:instance/ActionPreCondition/BackupFailureDetected> ;
    noria:operationPlanPostCondition <noria:instance/ActionPostCondition/BackupRestored> ;
    noria:elementDistinguishedName "BackupTroubleshootingGuide_DN"^^xsd:string .

