# --- KOS Concepts (for ranges of Object Properties) ---

<kos/application/type/ServicePlatform>
    a skos:Concept ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "A platform providing various services."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/Infrastructure>
    a skos:Concept ;
    rdfs:label "Infrastructure"@en ;
    rdfs:comment "Core infrastructure application."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/MonitoringTool>
    a skos:Concept ;
    rdfs:label "Monitoring Tool"@en ;
    rdfs:comment "An application used for monitoring systems."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/business-importance/Critical>
    a skos:Concept ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for business operations."@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/business-importance/High>
    a skos:Concept ;
    rdfs:label "High"@en ;
    rdfs:comment "Application has high business importance."@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/sla-level/Platinum>
