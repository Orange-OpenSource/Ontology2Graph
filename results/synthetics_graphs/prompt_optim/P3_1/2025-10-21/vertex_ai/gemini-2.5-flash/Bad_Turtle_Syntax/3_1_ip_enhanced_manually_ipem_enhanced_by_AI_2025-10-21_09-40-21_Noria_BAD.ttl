    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via corporate email for non-urgent matters. For critical incidents, use the emergency hotline."^^xsd:string ;
    noria:agentManagesResource <https://w3id.org/noria/data/resource/router_core_01> ;
    noria:agentManagesResource <https://w3id.org/noria/data/resource/server_app_01> ;
    foaf:mbox "john.doe@example.com"^^xsd:string ;
    foaf:phone "+1-555-123-4567"^^xsd:string .

