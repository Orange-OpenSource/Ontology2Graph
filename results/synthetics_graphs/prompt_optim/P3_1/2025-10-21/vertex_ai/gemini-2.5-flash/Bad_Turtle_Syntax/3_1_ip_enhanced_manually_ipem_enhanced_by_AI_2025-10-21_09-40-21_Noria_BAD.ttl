    rdfs:comment "A synthetic instance representing Jane Smith, an application support specialist. She oversees the 'Customer Portal' application and its modules."@en ;
    noria:agentWorkingHours "08:30 - 16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
