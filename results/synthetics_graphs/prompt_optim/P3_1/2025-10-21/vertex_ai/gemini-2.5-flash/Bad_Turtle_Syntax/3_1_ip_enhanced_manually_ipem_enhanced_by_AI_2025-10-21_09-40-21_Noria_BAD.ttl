# =============================================================================
# Knowledge Organization System (KOS) Concepts
# =============================================================================

<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    rdfs:label "Email Contact Method"@en ;
    rdfs:comment "Represents email as a preferred contact method for an agent."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    rdfs:label "Phone Contact Method"@en ;
    rdfs:comment "Represents phone as a preferred contact method for an agent."@en ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/application/type/ServicePlatform>
    a skos:Concept ;
    rdfs:label "Service Platform Application Type"@en ;
    rdfs:comment "Categorizes an application as a service platform."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/Infrastructure>
    a skos:Concept ;
    rdfs:label "Infrastructure Application Type"@en ;
    rdfs:comment "Categorizes an application as an infrastructure component."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/business-importance/High>
    a skos:Concept ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Indicates a high level of business importance for an application, critical for core operations."@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/business-importance/Medium>
    a skos:Concept ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Indicates a medium level of business importance for an application, supporting key operations but not critical."@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/sla-level/Gold>
    a skos:Concept ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Represents a premium Service Level Agreement with stringent performance and availability targets."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<kos/application/status/InProduction>
    a skos:Concept ;
    rdfs:label "In Production Status"@en ;
    rdfs:comment "Indicates that an application module is currently live and serving users."@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    rdfs:label "Customer Facing Service Type"@en ;
    rdfs:comment "Defines a service that is directly consumed or perceived by end-customers."@en ;
    skos:inScheme <kos/service/type> .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    rdfs:label "Resource Facing Service Type"@en ;
    rdfs:comment "Defines a service that manages or provides resources for other services, not directly exposed to customers."@en ;
    skos:inScheme <kos/service/type> .

<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Indicates a critical impact on service, requiring immediate attention."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    rdfs:label "Failure Ticket Type"@en ;
    rdfs:comment "Categorizes a trouble ticket as a system or component failure."@en ;
    skos:inScheme <kos/TroubleTicket/type> .

<kos/TroubleTicket/category/InterruptedService>
    a skos:Concept ;
    rdfs:label "Interrupted Service Category"@en ;
    rdfs:comment "Describes a trouble ticket where a service has been completely interrupted."@en ;
    skos:inScheme <kos/TroubleTicket/category> .

<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    rdfs:label "Priority 1 (P1)"@en ;
    rdfs:comment "Highest priority, typically for critical incidents affecting core business functions."@en ;
    skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Indicates that the trouble ticket was initiated by a customer."@en ;
    skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    rdfs:label "Immediate Intervention Urgency"@en ;
    rdfs:comment "Requires immediate action due to severe impact or potential for escalation."@en ;
    skos:inScheme <kos/TroubleTicket/urgency> .

<kos/TroubleTicket/trouble-category/TotalBreakdown>
    a skos:Concept ;
    rdfs:label "Total Breakdown Trouble Category"@en ;
    rdfs:comment "Signifies a complete failure of a system or service."@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks>
    a skos:Concept ;
    rdfs:label "Managed Backbone Networks Responsibility"@en ;
    rdfs:comment "Assigns responsibility for the problem to the team managing backbone network infrastructure."@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    rdfs:label "Internal Comment Type"@en ;
    rdfs:comment "Indicates that a trouble ticket note is for internal team communication only."@en ;
    skos:inScheme <kos/TroubleTicket/commentType> .

<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    rdfs:label "Diagnosis Operation Type"@en ;
    rdfs:comment "Categorizes a trouble ticket note as related to diagnostic activities."@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

<kos/TroubleTicket/status/InProgress>
    a skos:Concept ;
    rdfs:label "In Progress Status"@en ;
    rdfs:comment "Indicates that work is actively being done on the trouble ticket."@en ;
    skos:inScheme <kos/TroubleTicket/status> .

<kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    rdfs:label "Internal Intervention Category"@en ;
    rdfs:comment "Categorizes a change request as an internal operational intervention."@en ;
    skos:inScheme <kos/ChangeRequest/category> .

<kos/ChangeRequest/type/Standard>
    a skos:Concept ;
    rdfs:label "Standard Change Type"@en ;
    rdfs:comment "Defines a routine, pre-approved change with low risk."@en ;
    skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    rdfs:label "Software Upgrade Cause"@en ;
    rdfs:comment "Indicates that the change request is due to a software upgrade."@en ;
    skos:inScheme <kos/ChangeRequest/cause> .

<kos/ChangeRequest/status/Approved>
    a skos:Concept ;
    rdfs:label "Approved Status"@en ;
    rdfs:comment "Indicates that the change request has been approved and is awaiting scheduling or execution."@en ;
    skos:inScheme <kos/ChangeRequest/status> .

<kos/ChangeRequest/specification/NetworkConfiguration>
    a skos:Concept ;
    rdfs:label "Network Configuration Specification"@en ;
    rdfs:comment "Specifies that the change request involves network configuration adjustments."@en ;
    skos:inScheme <kos/ChangeRequest/specification> .

<kos/Resource/OperationalState/Up>
    a skos:Concept ;
    rdfs:label "Operational State Up"@en ;
    rdfs:comment "Indicates that a resource or network interface is fully operational and functioning."@en ;
    skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/OperationalState/Down>
    a skos:Concept ;
    rdfs:label "Operational State Down"@en ;
    rdfs:comment "Indicates that a resource or network interface is not operational."@en ;
    skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/AdministrativeState/Up>
    a skos:Concept ;
    rdfs:label "Administrative State Up"@en ;
    rdfs:comment "Indicates that a network interface is administratively enabled."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

<kos/Resource/AdministrativeState/Down>
    a skos:Concept ;
    rdfs:label "Administrative State Down"@en ;
    rdfs:comment "Indicates that a network interface is administratively disabled."@en ;
    skos:inScheme <kos/Resource/AdministrativeState> .

<Notification/Severity/PerceivedSeverity/Critical>
    a skos:Concept ;
    rdfs:label "Perceived Severity Critical"@en ;
    rdfs:comment "Represents a critical perceived severity for an alarm notification."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Warning>
    a skos:Concept ;
    rdfs:label "Perceived Severity Warning"@en ;
    rdfs:comment "Represents a warning perceived severity for an alarm notification."@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<kos/Resource/type/Router>
    a skos:Concept ;
    rdfs:label "Router Resource Type"@en ;
    rdfs:comment "Classifies a resource as a network router."@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/Server>
    a skos:Concept ;
    rdfs:label "Server Resource Type"@en ;
    rdfs:comment "Classifies a resource as a server."@en ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/LifecycleState/InUse>
    a skos:Concept ;
    rdfs:label "In Use Lifecycle State"@en ;
    rdfs:comment "Indicates that a resource is actively being used in production."@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

<kos/Resource/LifecycleState/Decommissioned>
    a skos:Concept ;
    rdfs:label "Decommissioned Lifecycle State"@en ;
    rdfs:comment "Indicates that a resource has been removed from service."@en ;
    skos:inScheme <kos/Resource/LifecycleState> .

