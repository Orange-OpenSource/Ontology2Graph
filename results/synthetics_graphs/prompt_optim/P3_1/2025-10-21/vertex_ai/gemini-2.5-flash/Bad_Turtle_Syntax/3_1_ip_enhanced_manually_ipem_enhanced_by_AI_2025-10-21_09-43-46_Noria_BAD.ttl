    rdfs:label "Router Configuration Backup for CR-20240325-001"@en ;
    rdfs:comment "A backup of the configuration file for Edge Router 01, created prior to the OS upgrade as a rollback point."@en ;
    noria:eventRelatedElement <resource/Router_Edge_01> ;
    noria:eventRelatedParty <agent/NetworkOperationsTeam> .

<documentattachment/CBS_PatchNotes_CR1002>
    a noria:DocumentAttachment ;
    rdfs:label "CBS Patch Notes for CR-20240326-002"@en ;
    rdfs:comment "Official release notes and detailed instructions for the Core Banking System emergency configuration update."@en ;
    noria:eventRelatedElement <application/CoreBankingSystem> ;
    noria:eventRelatedParty <agent/JaneSmith> .

# --- noria:AnomalyPattern Instances ---

<anomalypattern/HighCPU_LowThroughput>
    a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Throughput Anomaly Pattern"@en ;
    rdfs:comment "A detected anomaly pattern where a server exhibits unusually high CPU utilization concurrently with unexpectedly low network throughput, suggesting a processing bottleneck or application stall."@en .

<anomalypattern/InterfaceFlap_HighErrorRate>
    a noria:AnomalyPattern ;
    rdfs:label "Interface Flap with High Error Rate Anomaly Pattern"@en ;
    rdfs:comment "A critical anomaly pattern characterized by frequent and rapid changes in a network interface's operational state (flapping) coupled with a high rate of packet errors, indicating an unstable or faulty physical link."@en .

# --- noria:OperationPlan Instances ---

<operationplan/InterfaceTroubleshooting>
    a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "A standardized operational procedure for diagnosing and resolving common issues related to network interfaces, including link status and error rates."@en ;
    noria:operationPlanPreCondition <actionprecondition/InterfaceDownConfirmed> ;
    noria:operationPlanPostCondition <actionpostcondition/InterfaceUpConfirmed> .

<operationplan/AppServerPerformanceCheck>
    a noria:OperationPlan ;
    rdfs:label "Application Server Performance Check Procedure"@en ;
    rdfs:comment "A detailed procedure to investigate and optimize application server performance issues, typically triggered by high resource utilization alerts."@en ;
    noria:operationPlanPreCondition <actionprecondition/HighCPUAlertReceived> ;
    noria:operationPlanPostCondition <actionpostcondition/CPUNormalized> .

# --- noria:ActionPreCondition Instances ---

<actionprecondition/InterfaceDownConfirmed>
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Confirmed Pre-Condition"@en ;
    rdfs:comment "A pre-condition for network interface troubleshooting: the network interface's operational status is confirmed to be 'down' and it is not administratively disabled."@en .

<actionprecondition/HighCPUAlertReceived>
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Alert Received Pre-Condition"@en ;
    rdfs:comment "A pre-condition for application server performance checks: an alert indicating sustained high CPU utilization on a critical application server has been received and validated."@en .

# --- noria:ActionPostCondition Instances ---

<actionpostcondition/InterfaceUpConfirmed>
    a noria:ActionPostCondition ;
    rdfs:label "Interface Up Confirmed Post-Condition"@en ;
    rdfs:comment "A post-condition for network interface troubleshooting: the network interface's operational status is confirmed to be 'up' and stable, indicating successful resolution."@en .

<actionpostcondition/CPUNormalized>
    a noria:ActionPostCondition ;
    rdfs:label "CPU Normalized Post-Condition"@en ;
    rdfs:comment "A post-condition for application server performance checks: CPU utilization on the application server has returned to normal operating levels and remains stable."@en .

# --- Linking EventRecords to TroubleTickets and ChangeRequests ---

<troubleticket/TT_20240320_001>
    noria:documentStatusHistory <eventrecord/TT_20240320_001_StatusChange_InProgress> .

<eventrecord/TT_20240320_001_StatusChange_InProgress>
    a noria:EventRecord ;
    rdfs:label "TT-20240320-001 Status Change: In Progress Event"@en ;
    rdfs:comment "An event recording the automatic status change of Trouble Ticket TT-20240320-001 to 'In Progress' after initial assessment."^^xsd:string ;
    noria:loggingTime "2024-03-20T10:35:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240320-001 status changed to In Progress by system automation."^^xsd:string ;
    noria:logOriginatingManagementSystem <application/MonitoringDashboard> ;
    noria:eventRelatedElement <troubleticket/TT_20240320_001> .

<troubleticket/TT_20240320_001>
    noria:troubleTicketFreezeItem <eventrecord/TT_20240320_001_FreezeStart> .

<eventrecord/TT_20240320_001_FreezeStart>
    a noria:EventRecord ;
    rdfs:label "TT-20240320-001 Freeze Start Event"@en ;
    rdfs:comment "An event recording the initiation of a freeze period for Trouble Ticket TT-20240320-001 due to an external vendor dependency for fiber repair."^^xsd:string ;
    noria:loggingTime "2024-03-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240320-001 entered freeze state due to vendor dependency for fiber repair. Awaiting external team."^^xsd:string ;
    noria:logOriginatingManagementSystem <application/MonitoringDashboard> ;
    noria:eventRelatedElement <troubleticket/TT_20240320_001> .

<changerequest/CR_20240325_001>
    noria:documentStatusHistory <eventrecord/CR_20240325_001_StatusChange_Approved> .

<eventrecord/CR_20240325_001_StatusChange_Approved>
    a noria:EventRecord ;
    rdfs:label "CR-20240325-001 Status Change: Approved Event"@en ;
    rdfs:comment "An event recording the formal approval of Change Request CR-20240325-001 by the Change Advisory Board (CAB)."@en ;
    noria:loggingTime "2024-03-24T15:00:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-20240325-001 approved by CAB for scheduled implementation."^^xsd:string ;
    noria:logOriginatingManagementSystem <application/MonitoringDashboard> ;
    noria:eventRelatedElement <changerequest/CR_20240325_001> .

# --- Linking TroubleTicketNote to correlated execution ---

<troubleticketnote/TT_20240320_001_Note1>
    noria:troubleTicketNoteCorrelatedExecution <eventrecord/RouterInterfaceRestartAttempt> .

<eventrecord/RouterInterfaceRestartAttempt>
    a noria:EventRecord ;
    rdfs:label "Router Interface Restart Attempt Event"@en ;
    rdfs:comment "An event recording a manual attempt by the Network Operations Team to restart the router interface GE0/0/1 as part of initial troubleshooting steps."@en ;
    noria:loggingTime "2024-03-20T10:45:00Z"^^xsd:dateTime ;
    noria:logText "Attempted 'shutdown' then 'no shutdown' on interface GE0/0/1 of edge-rtr-01. No change in link status observed."^^xsd:string ;
    noria:logOriginatingManagedObject <resource/Router_Edge_01> ;
    noria:logOriginatingAgent <agent/NetworkOperationsTeam> ;
    noria:eventRelatedElement <networkinterface/Router_Edge_01_GE0_0_1> .

# --- Linking OperationPlan to actions (EventRecord as pep:ProcedureExecution) ---

<operationplan/InterfaceTroubleshooting>
    noria:actionCorrelatedOperationPlan <eventrecord/RouterInterfaceRestartAttempt> .

# --- Additional links to ensure all object properties are used ---

<agent/JohnDoe>
    noria:agentManagesResource <resource/Server_App_01> .

<agent/JaneSmith>
    noria:agentManagesResource <resource/Cluster_Controller_01> .

<agent/NetworkOperationsTeam>
    noria:agentManagesResource <resource/Router_Edge_01> .

<networkinterface/Router_Edge_01_GE0_0_1>
    noria:networkInterfaceConnects <networklink/Core_Link_A_B> .

<networkinterface/Server_App_01_Eth0>
    noria:networkInterfaceConnects <networklink/Server_App_Link> .

<networklink/Core_Link_A_B>
    noria:networkLinkTerminationResource <resource/Router_Core_01> .

<networklink/Server_App_Link>
    noria:networkLinkTerminationResource <resource/Server_App_01> .

<observable/RouterGE0_0_1_OperationalStatus>
    a noria:StructuralObservable ;
    rdfs:label "Router GE0/0/1 Operational Status Observable"@en ;
    rdfs:comment "An observable representing the real-time operational status of the GigabitEthernet0/0/1 interface on Edge Router 01."@en ;
    noria:structuralObservableOf <networkinterface/Router_Edge_01_GE0_0_1> .

<networkinterface/Router_Edge_01_GE0_0_1>
    noria:structuralElementObservable <observable/RouterGE0_0_1_OperationalStatus> .

<troubleticket/TT_20240320_001>
    noria:troubleTicketPartyIntervention <eventrecord/TT_20240320_001_PartyIntervention_NetOps> .

<eventrecord/TT_20240320_001_PartyIntervention_NetOps>
    a noria:EventRecord ;
    rdfs:label "TT-20240320-001 Network Operations Intervention Log"@en ;
    rdfs:comment "Log entry detailing the Network Operations Team's initial intervention and ownership transfer for Trouble Ticket TT-20240320-001."@en ;
    noria:loggingTime "2024-03-20T10:50:00Z"^^xsd:dateTime ;
    noria:logOriginatingAgent <agent/NetworkOperationsTeam> ;
    noria:logText "Network Operations Team took ownership and began fiber link diagnostics. Escalated to field team for physical inspection."^^xsd:string ;
    noria:eventRelatedElement <troubleticket/TT_20240320_001> .

<eventrecord/AppServerHighCPU_20240320>
    noria:alarmMonitoredAttribute <observable/ServerApp01_CPULoad> .

<observable/ServerApp01_CPULoad>
    a noria:StructuralObservable ;
    rdfs:label "Server App 01 CPU Load Observable"@en ;
    rdfs:comment "An observable representing the current CPU load percentage of Application Server 01, a key performance indicator."@en .

<eventrecord/RouterInterfaceDown_20240320>
    noria:alarmMitigatedBy <eventrecord/RouterInterfaceRestartAttempt> .
