# --- KOS Concepts (Knowledge Organization System) ---

# KOS for agent-contact-method
<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email Contact Method"@en ;
    rdfs:comment "Represents email as a preferred contact method for an agent."@en .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone Contact Method"@en ;
    rdfs:comment "Represents phone as a preferred contact method for an agent."@en .

# KOS for application/type
<kos/application/type/ServicePlatform>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Service Platform Application Type"@en ;
    rdfs:comment "Categorizes applications that serve as platforms for other services or functionalities."@en .

<kos/application/type/Infrastructure>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Infrastructure Application Type"@en ;
    rdfs:comment "Categorizes applications that provide foundational infrastructure services."@en .

# KOS for application/business-importance
<kos/application/business-importance/Critical>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Critical Business Importance"@en ;
    rdfs:comment "Indicates that an application is absolutely essential for core business operations, with any downtime leading to severe impact."@en .

<kos/application/business-importance/High>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Indicates that an application is very important for business operations, with downtime leading to significant impact."@en .

# KOS for application/sla-level
<kos/application/sla-level/Platinum>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Platinum SLA Level"@en ;
    rdfs:comment "The highest Service Level Agreement tier, guaranteeing maximum availability, performance, and rapid incident response times."@en .

<kos/application/sla-level/Gold>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "A high Service Level Agreement tier, offering strong guarantees for availability and performance, suitable for important but not hyper-critical systems."@en .

# KOS for application/status
<kos/application/status/InProduction>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production Status"@en ;
    rdfs:comment "Indicates that an application module is currently live, fully operational, and actively serving its intended users or functions."@en .

<kos/application/status/Maintenance>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Under Maintenance Status"@en ;
    rdfs:comment "Indicates that an application module is temporarily offline or operating in a reduced capacity due to scheduled or unscheduled maintenance activities."@en .

# KOS for service/type
<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service Type"@en ;
    rdfs:comment "A service type that is directly consumed, experienced, or interacted with by external customers or end-users."@en .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service Type"@en ;
    rdfs:comment "A service type that provides underlying support or infrastructure for other services, typically not directly exposed to end-users."@en .

# KOS for TroubleTicket/severity
<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical Trouble Ticket Severity"@en ;
    rdfs:comment "Represents the highest severity level for a trouble ticket, indicating a major incident with widespread impact on critical services or business functions."@en .

<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major Trouble Ticket Severity"@en ;
    rdfs:comment "Represents a significant severity level for a trouble ticket, indicating an incident with noticeable impact on services or business functions, but not necessarily a complete outage."@en .

# KOS for TroubleTicket/type
<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure Trouble Ticket Type"@en ;
    rdfs:comment "Categorizes trouble tickets that report a malfunction, breakdown, or complete failure of a system, component, or service."@en .

<kos/TroubleTicket/type/Assistance>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance Trouble Ticket Type"@en ;
    rdfs:comment "Categorizes trouble tickets that are requests for help, guidance, or support from users regarding a system or service."@en .

# KOS for TroubleTicket/category
<kos/TroubleTicket/category/ServiceInterruption>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Service Interruption Category"@en ;
    rdfs:comment "A category for trouble tickets where the primary impact is a complete or partial cessation of a service."@en .

<kos/TroubleTicket/category/PerformanceDegradation>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Performance Degradation Category"@en ;
    rdfs:comment "A category for trouble tickets where the primary impact is a noticeable reduction in the speed, efficiency, or responsiveness of a service."@en .

# KOS for TroubleTicket/priority
<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1 (P1) Trouble Ticket"@en ;
    rdfs:comment "The highest priority level for a trouble ticket, demanding immediate attention and resolution due to severe business impact."@en .

<kos/TroubleTicket/priority/P2>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2 (P2) Trouble Ticket"@en ;
    rdfs:comment "A high priority level for a trouble ticket, requiring urgent attention and resolution due to significant business impact, but not as immediate as P1."@en .

# KOS for TroubleTicket/origin
<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin Trouble Ticket"@en ;
    rdfs:comment "Indicates that the trouble ticket was initiated by an external customer or end-user."@en .

<kos/TroubleTicket/origin/Supervision>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System Origin Trouble Ticket"@en ;
    rdfs:comment "Indicates that the trouble ticket was automatically generated or initiated by an automated monitoring or supervision system."@en .

# KOS for TroubleTicket/urgency
<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention Urgency"@en ;
    rdfs:comment "Specifies that the issue requires immediate and unscheduled intervention to prevent further damage or restore critical services."@en .

<kos/TroubleTicket/urgency/DeferredIntervention>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Deferred Intervention Urgency"@en ;
    rdfs:comment "Specifies that the issue can be addressed during a planned maintenance window or at a later, scheduled time, without immediate critical impact."@en .

# KOS for TroubleTicket/trouble-category
<kos/TroubleTicket/trouble-category/TotalBreakdown>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Total Breakdown Trouble Category"@en ;
    rdfs:comment "A specific trouble category indicating a complete and widespread failure of a system or service, rendering it entirely unusable."@en .

<kos/TroubleTicket/trouble-category/InaccessibleDestination>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Inaccessible Destination Trouble Category"@en ;
    rdfs:comment "A specific trouble category indicating that a network destination or service endpoint cannot be reached."@en .

# KOS for TroubleTicket/problemResponsibility
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks Responsibility"@en ;
    rdfs:comment "Assigns responsibility for the problem to the team or entity managing the core backbone network infrastructure."@en .

<kos/TroubleTicket/problemResponsibility/Customer>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Customer Responsibility"@en ;
    rdfs:comment "Assigns responsibility for the problem to the customer, indicating the issue originates from their side or usage."@en .

# KOS for TroubleTicket/status
<kos/TroubleTicket/status/InProgress>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress Trouble Ticket Status"@en ;
    rdfs:comment "Indicates that active work is being performed to diagnose and resolve the issue described in the trouble ticket."@en .

<kos/TroubleTicket/status/Resolved>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved Trouble Ticket Status"@en ;
    rdfs:comment "Indicates that the issue described in the trouble ticket has been successfully addressed and a solution has been implemented."@en .

# KOS for TroubleTicket/commentType
<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment Type"@en ;
    rdfs:comment "Designates a comment within a trouble ticket note as being for internal team communication only, not visible to external parties."@en .

<kos/TroubleTicket/commentType/CustomerFacing>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer Facing Comment Type"@en ;
    rdfs:comment "Designates a comment within a trouble ticket note as being intended for communication with the customer, providing updates or information."@en .

# KOS for TroubleTicket/operationType
<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation Type"@en ;
    rdfs:comment "Categorizes an operation within a trouble ticket note as being related to the process of identifying the root cause of an issue."@en .

<kos/TroubleTicket/operationType/TestsAndMeasurements>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Tests and Measurements Operation Type"@en ;
    rdfs:comment "Categorizes an operation within a trouble ticket note as involving the execution of tests and collection of measurements to assess system behavior or verify a fix."@en .

# KOS for ChangeRequest/category
<kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention Change Request Category"@en ;
    rdfs:comment "Categorizes change requests that involve modifications or actions performed solely by internal teams, without direct customer interaction."@en .

<kos/ChangeRequest/category/CustomerRequested>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Customer Requested Change Request Category"@en ;
    rdfs:comment "Categorizes change requests that are initiated directly by a customer, often in response to a new requirement or issue."@en .

# KOS for ChangeRequest/type
<kos/ChangeRequest/type/Standard>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change Request Type"@en ;
    rdfs:comment "A type of change request for routine, pre-authorized changes with a low risk and impact, following a defined procedure."@en .

<kos/ChangeRequest/type/Emergency>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Emergency Change Request Type"@en ;
    rdfs:comment "A type of change request for urgent changes required to restore service, resolve a critical incident, or implement a security fix, bypassing normal change procedures."@en .

# KOS for ChangeRequest/cause
<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade Change Cause"@en ;
    rdfs:comment "Identifies the cause of a change request as being a necessary upgrade to software components or operating systems."@en .

<kos/ChangeRequest/cause/Configuration>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change Cause"@en ;
    rdfs:comment "Identifies the cause of a change request as being a modification to system or application configurations."@en .

# KOS for ChangeRequest/status
<kos/ChangeRequest/status/Approved>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved Change Request Status"@en ;
    rdfs:comment "Indicates that a change request has received all necessary approvals and is authorized for implementation."@en .

<kos/ChangeRequest/status/Implemented>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented Change Request Status"@en ;
    rdfs:comment "Indicates that a change request has been successfully executed and its intended modifications are now active in the system."@en .

# KOS for ChangeRequest/specification
<kos/ChangeRequest/specification/RoutineMaintenance>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Routine Maintenance Specification"@en ;
    rdfs:comment "Specifies that a change request pertains to routine, scheduled maintenance activities designed to ensure system health and longevity."@en .

<kos/ChangeRequest/specification/SecurityPatch>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Security Patch Deployment Specification"@en ;
    rdfs:comment "Specifies that a change request involves the deployment of security patches to address vulnerabilities."@en .

# KOS for Notification/Severity/PerceivedSeverity
<kos/Notification/Severity/PerceivedSeverity/Critical>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Perceived Severity for Notification"@en ;
    rdfs:comment "The highest level of perceived severity for a notification, indicating an immediate and severe impact requiring urgent attention."@en .

<kos/Notification/Severity/PerceivedSeverity/Warning>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning Perceived Severity for Notification"@en ;
    rdfs:comment "A moderate level of perceived severity for a notification, indicating a potential issue or condition that requires monitoring but not immediate critical action."@en .

# KOS for Resource/OperationalState
<kos/Resource/OperationalState/Up>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Operational State Up"@en ;
    rdfs:comment "Indicates that a resource is currently functioning correctly and is available for use."@en .

<kos/Resource/OperationalState/Down>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Operational State Down"@en ;
    rdfs:comment "Indicates that a resource is currently not functioning or is unavailable for use."@en .

# KOS for Resource/AdministrativeState
<kos/Resource/AdministrativeState/Enabled>
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative State Enabled"@en ;
    rdfs:comment "Indicates that a resource has been configured by an administrator to be active and operational."@en .

<kos/Resource/AdministrativeState/Disabled>
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative State Disabled"@en ;
    rdfs:comment "Indicates that a resource has been configured by an administrator to be inactive or non-operational."@en .

# KOS for Resource/type
<kos/Resource/type/Router>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router Resource Type"@en ;
    rdfs:comment "Categorizes a resource as a network router, responsible for forwarding data packets between computer networks."@en .

<kos/Resource/type/Server>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server Resource Type"@en ;
    rdfs:comment "Categorizes a resource as a server, providing services or resources to other computers or programs."@en .

# KOS for Resource/LifecycleState
<kos/Resource/LifecycleState/InProduction>
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Production Lifecycle State"@en ;
    rdfs:comment "Indicates that a resource is currently in active use within the production environment, supporting live services."@en .

<kos/Resource/LifecycleState/Decommissioned>
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Decommissioned Lifecycle State"@en ;
    rdfs:comment "Indicates that a resource has been formally removed from service and is no longer operational or supported."@en .

# --- foaf:Agent Instances ---

<agent/JohnDoe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A fictional employee, acting as an agent in the system, responsible for application support."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via corporate email for all inquiries during working hours. For urgent issues, escalate to the team lead."^^xsd:string .

<agent/JaneSmith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Another fictional employee, a key agent for critical systems and a team leader."@en ;
    noria:agentWorkingHours "08:30-17:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For urgent matters, call directly on the provided mobile number. Otherwise, send an email for documentation."^^xsd:string .

<agent/NetworkOperationsTeam>
    a foaf:Group ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "The dedicated team responsible for 24/7 management and maintenance of the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use the dedicated hotline for immediate support and incident reporting. Ensure a ticket number is provided."^^xsd:string .

# --- org:Organization and org:OrganizationalUnit Instances ---

<org/GlobalTelecom>
    a org:Organization ;
    rdfs:label "Global Telecom Inc."@en ;
    rdfs:comment "A major international telecommunications company providing a wide range of network and IT services."@en .

<org/CoreServicesDivision>
    a org:OrganizationalUnit ;
    rdfs:label "Core Services Division"@en ;
    rdfs:comment "A key division within Global Telecom Inc. overseeing the development, deployment, and operation of essential IT services."@en ;
    org:unitOf <org/GlobalTelecom> .

<org/NetworkInfrastructureUnit>
    a org:OrganizationalUnit ;
    rdfs:label "Network Infrastructure Unit"@en ;
    rdfs:comment "A specialized unit within the Core Services Division, focused on the design, implementation, and maintenance of the company's network assets."@en ;
    org:unitOf <org/CoreServicesDivision> .

<org/ApplicationSupportUnit>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Unit"@en ;
    rdfs:comment "A unit within the Core Services Division dedicated to providing technical support and administration for various business applications."@en ;
    org:unitOf <org/CoreServicesDivision> .

# --- noria:CorporateUserIdentifier Instances ---

<cuid/johndoe_corp>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User Identifier"@en ;
    rdfs:comment "The unique corporate user identifier (CUID) assigned to John Doe for accessing organizational IT resources and systems."@en ;
    foaf:accountName "jdoe_corp"@en ;
    observable:accountLogin "jdoe_login_id"@en ;
    observable:accountIdentifier "CUID-JD-7890-ABC"@en .

<cuid/janesmith_corp>
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User Identifier"@en ;
    rdfs:comment "The unique corporate user identifier (CUID) assigned to Jane Smith, enabling her access to critical management and operational platforms."@en ;
    foaf:accountName "jsmith_corp"@en ;
    observable:accountLogin "jsmith_login_id"@en ;
    observable:accountIdentifier "CUID-JS-1234-XYZ"@en .

# --- bot:Site, noria:Room, noria:Locus Instances ---

<site/MainDataCenter>
    a bot:Site ;
    rdfs:label "Main Data Center Site"@en ;
    rdfs:comment "The primary data center facility for Global Telecom Inc., housing critical servers and network equipment."@en ;
    noria:siteId "DC-01-MAIN-SITE"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue, Metropolis, 90210, US"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "90210"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "123 Tech Avenue"^^xsd:string .

<room/ServerRoomA>
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated server room located within the Main Data Center, optimized for high-density server racks."@en ;
    bot:hasSpace <site/MainDataCenter> .

<locus/RackA1_U1>
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 1 Locus"@en ;
    rdfs:comment "The precise physical location within Server Room A, specifically Rack A1, Unit 1, where a resource is installed."@en ;
