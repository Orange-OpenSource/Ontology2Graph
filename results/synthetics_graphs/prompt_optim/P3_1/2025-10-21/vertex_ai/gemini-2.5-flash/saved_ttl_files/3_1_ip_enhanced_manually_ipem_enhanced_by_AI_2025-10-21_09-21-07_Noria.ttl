# =============================================================================
# Procedural Elements (Anomaly Patterns, Operation Plans, Pre/Post Conditions)
# =============================================================================

<anomalypattern/ddos_attack_signature>
    a noria:AnomalyPattern ;
    rdfs:label "DDoS Attack Signature"@en ;
    rdfs:comment "A pattern of network traffic and resource utilization indicative of a Distributed Denial of Service attack."@en ;
    folio:hasCause "Malicious external traffic"^^xsd:string ;
    folio:hasEffect "Service unavailability"^^xsd:string .

<anomalypattern/resource_exhaustion_pattern>
    a noria:AnomalyPattern ;
    rdfs:label "Resource Exhaustion Pattern"@en ;
    rdfs:comment "A pattern of sustained high CPU/memory usage and low disk space, leading to system instability."@en ;
    folio:hasCause "Inefficient application code or memory leak"^^xsd:string ;
    folio:hasEffect "System crash or unresponsiveness"^^xsd:string .

<operationplan/interface_troubleshooting>
    a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving issues with network interfaces."@en ;
    noria:operationPlanPreCondition <actionprecondition/interface_down_observed> ;
    noria:operationPlanPostCondition <actionpostcondition/interface_operational> ;
    pep:hasInput "Interface name, device IP"^^xsd:string ;
    pep:hasOutput "Interface status, root cause"^^xsd:string .

<operationplan/app_service_restart>
    a noria:OperationPlan ;
    rdfs:label "Application Service Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting a critical application service to restore functionality."@en ;
    noria:operationPlanPreCondition <actionprecondition/app_unresponsive> ;
    noria:operationPlanPostCondition <actionpostcondition/app_service_restored> ;
    pep:hasInput "Application name, server hostname"^^xsd:string ;
    pep:hasOutput "Service status, log confirmation"^^xsd:string .

<actionprecondition/interface_down_observed>
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Observed"@en ;
    rdfs:comment "Pre-condition: A network interface is reported as being in a 'down' operational state."@en .

<actionprecondition/app_unresponsive>
    a noria:ActionPreCondition ;
    rdfs:label "Application Unresponsive"@en ;
    rdfs:comment "Pre-condition: The application is not responding to requests or showing high error rates."@en .

<actionprecondition/backup_completed>
    a noria:ActionPreCondition ;
    rdfs:label "Backup Completed"@en ;
    rdfs:comment "Pre-condition: A full system backup has been successfully completed and verified."@en .

<actionpostcondition/interface_operational>
    a noria:ActionPostCondition ;
    rdfs:label "Interface Operational"@en ;
    rdfs:comment "Post-condition: The network interface is restored to an 'up' operational state."@en .

<actionpostcondition/app_service_restored>
    a noria:ActionPostCondition ;
    rdfs:label "Application Service Restored"@en ;
    rdfs:comment "Post-condition: The application service is running, accessible, and functioning correctly."@en .

<actionpostcondition/system_stable>
    a noria:ActionPostCondition ;
    rdfs:label "System Stable"@en ;
    rdfs:comment "Post-condition: The system is operating within normal parameters after a change or incident."@en .

# Example of using actionCorrelatedOperationPlan
<pep/corrective_action_tt001>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Corrective Action for TT-001"@en ;
    rdfs:comment "Container for the procedure executions related to resolving Trouble Ticket 20240315_001."@en ;
    noria:actionCorrelatedOperationPlan <operationplan/app_service_restart> .

<pep/change_action_cr001>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Change Action for CR-001"@en ;
    rdfs:comment "Container for the procedure executions related to implementing Change Request 20240316_001."@en ;
    noria:actionCorrelatedOperationPlan <operationplan/interface_troubleshooting> .

