# =============================================================================
# SKOS Concepts for controlled vocabularies
# =============================================================================

<kos/application/type/WebApplication>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Web Application"@en ;
    rdfs:comment "A software application that runs on a web server and is accessed by users through a web browser."@en .

<kos/application/type/DatabaseService>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Database Service"@en ;
    rdfs:comment "A service providing data storage and retrieval capabilities."@en .

<kos/application/type/MonitoringSystem>
    a skos:Concept ;
    skos:inScheme <kos/application/type> ;
    rdfs:label "Monitoring System"@en ;
    rdfs:comment "An application designed to observe and report on the status and performance of IT infrastructure."@en .

<kos/application/business-importance/High>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application is critical for core business operations, with significant impact if unavailable."@en .

<kos/application/business-importance/Medium>
    a skos:Concept ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application supports important business functions, with moderate impact if unavailable."@en .

<kos/application/sla-level/Gold>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement, ensuring maximum availability and performance."@en .

<kos/application/sla-level/Silver>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Standard Service Level Agreement, offering good availability and performance."@en .

<kos/application/status/InProduction>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

<kos/application/status/Development>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Development"@en ;
    rdfs:comment "The application module is under active development and not yet in production."@en .

<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed or experienced by external customers."@en .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations, not directly exposed to customers."@en .

<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Highest severity, indicating a complete service outage or major business impact."@en .

<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Significant service degradation or partial outage affecting a large number of users."@en .

<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Ticket type indicating a system or component failure."@en .

<kos/TroubleTicket/type/Assistance>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Ticket type for user assistance or general inquiries."@en .

<kos/TroubleTicket/category/TotalBreakdown>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "The system or service is completely inoperable."@en .

<kos/TroubleTicket/category/DegradedPerformance>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:label "Degraded Performance"@en ;
    rdfs:comment "The system or service is operating below expected performance levels."@en .

<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, requiring immediate attention and resolution."@en .

<kos/TroubleTicket/priority/P2>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, requiring prompt attention to prevent escalation."@en .

<kos/TroubleTicket/origin/Supervision>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System"@en ;
    rdfs:comment "Ticket originated from an automated monitoring or supervision system."@en .

<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Report"@en ;
    rdfs:comment "Ticket originated from a direct report by a customer."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action due to severe impact or risk."@en .

<kos/TroubleTicket/urgency/DeferredIntervention>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Action can be scheduled for a later time without critical impact."@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Backbone Networks"@en ;
    rdfs:comment "Responsibility for the problem lies with the team managing the core network infrastructure."@en .

<kos/TroubleTicket/problemResponsibility/ApplicationTeam>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Application Team"@en ;
    rdfs:comment "Responsibility for the problem lies with the application development or support team."@en .

<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "A comment intended for internal team members only."@en .

<kos/TroubleTicket/commentType/Customer>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer Comment"@en ;
    rdfs:comment "A comment visible to the customer."@en .

<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis"@en ;
    rdfs:comment "Operation type related to problem diagnosis and root cause analysis."@en .

<kos/TroubleTicket/operationType/Resolution>
    a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Resolution"@en ;
    rdfs:comment "Operation type related to implementing a solution or fix."@en .

<kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "A change initiated and executed by internal teams."@en .

<kos/ChangeRequest/category/CustomerRequested>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Customer Requested"@en ;
    rdfs:comment "A change requested by an external customer."@en .

<kos/ChangeRequest/type/Standard>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk and impact, following a defined procedure."@en .

<kos/ChangeRequest/type/Major>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Major Change"@en ;
    rdfs:comment "A high-risk, high-impact change requiring extensive planning and approval."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "The change is due to a planned software version upgrade."@en .

<kos/ChangeRequest/cause/ConfigurationChange>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "The change involves modifying system configurations."@en .

<kos/ChangeRequest/status/Approved>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "The change request has been approved and is awaiting implementation."@en .

<kos/ChangeRequest/status/Implemented>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "The change request has been successfully implemented."@en .

<kos/ChangeRequest/specification/NetworkMaintenance>
    a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Network Maintenance"@en ;
    rdfs:comment "Specification for routine network maintenance activities."@en .

<kos/Resource/OperationalState/Up>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "The resource or interface is currently operational and functioning."@en .

<kos/Resource/OperationalState/Down>
    a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "The resource or interface is currently not operational."@en .

<kos/Resource/AdministrativeState/Enabled>
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Enabled"@en ;
    rdfs:comment "The resource or interface is administratively enabled."@en .

<kos/Resource/AdministrativeState/Disabled>
    a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Disabled"@en ;
    rdfs:comment "The resource or interface is administratively disabled."@en .

<kos/Resource/type/Router>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network device that forwards data packets between computer networks."@en .

<kos/Resource/type/Server>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computer program or a device that provides functionality for other programs or devices."@en .

<kos/Resource/type/Firewall>
    a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Firewall"@en ;
    rdfs:comment "A network security system that monitors and controls incoming and outgoing network traffic."@en .

<kos/Resource/LifecycleState/Production>
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Production"@en ;
    rdfs:comment "The resource is in active production use."@en .

<kos/Resource/LifecycleState/Staging>
    a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "Staging"@en ;
    rdfs:comment "The resource is in a staging environment, preparing for production."@en .

<Notification/Severity/PerceivedSeverity/Critical>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Perceived Severity"@en ;
    rdfs:comment "The most severe level of alarm, indicating immediate and severe impact."@en .

<Notification/Severity/PerceivedSeverity/Warning>
    a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning Perceived Severity"@en ;
    rdfs:comment "An alarm indicating a potential issue that requires attention but is not yet critical."@en .

<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# =============================================================================
# Organizational Entities
# =============================================================================

<agent/john_doe>
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An IT operations engineer responsible for network infrastructure."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentInstructions "Contact via email for non-urgent issues, phone for critical alerts."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource <resource/core_router_01>, <resource/web_server_01> .

<agent/jane_smith>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A senior application support specialist."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"@en ;
    noria:agentInstructions "Available for application-specific issues, escalate to her team for general infrastructure."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentManagesResource <application/crm_system>, <application/erp_suite> .

<agent/it_ops_team>
    a org:OrganizationalUnit, foaf:Group, foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "The primary team responsible for day-to-day IT infrastructure operations."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentInstructions "Use ticketing system for all requests. For emergencies, call the hotline."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource <resource/core_router_01>, <resource/web_server_01>, <resource/firewall_dmz_01> .

<agent/app_support_team>
    a org:OrganizationalUnit, foaf:Group, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team dedicated to supporting business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentInstructions "Submit tickets via the internal portal. For critical app issues, contact the on-call lead."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource <application/crm_system>, <application/erp_suite> .

<agent/security_bot>
    a foaf:Agent ;
    rdfs:label "Security Monitoring Bot"@en ;
    rdfs:comment "Automated agent responsible for detecting and reporting security incidents."@en ;
    noria:agentWorkingHours "24/7 Automated Monitoring"@en ;
    noria:agentInstructions "Alerts are automatically generated and routed to the Security Operations Center."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<org/manufacturer_cisco>
    a org:Organization ;
    rdfs:label "Cisco Systems, Inc."@en ;
    rdfs:comment "A global technology conglomerate that designs, manufactures, and sells networking hardware, software, telecommunications equipment, and other high-technology services and products."@en .

<org/manufacturer_hp>
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "An American multinational enterprise information technology company."@en .

<org/it_department>
    a org:Organization ;
    rdfs:label "Global IT Department"@en ;
    rdfs:comment "The overarching IT department responsible for all technology services within the company."@en .

# =============================================================================
# Location Entities
# =============================================================================

<site/paris_datacenter>
    a bot:Site ;
    rdfs:label "Paris Datacenter Site"@en ;
    rdfs:comment "Main datacenter facility located in Paris, France."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

<site/london_office>
    a bot:Site ;
    rdfs:label "London Office Site"@en ;
    rdfs:comment "Corporate office building located in London, UK."@en ;
    noria:siteId "OFF-LDN-01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "456 Baker Street"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE"^^xsd:string ;
    noria:sitePrincipalAddressCityName "London"^^xsd:string ;
    noria:sitePrincipalAddressCountry "GB"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Baker Street"^^xsd:string .

<room/server_room_a>
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room within the Paris Datacenter."@en ;
    bot:hasSpace <locus/rack_a1>, <locus/rack_a2> .

<room/network_room_b>
    a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Dedicated network equipment room in the London Office."@en ;
    bot:hasSpace <locus/rack_b1>, <locus/rack_b2> .

<locus/rack_a1>
    a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Specific rack location in Server Room A, Paris Datacenter."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

<locus/rack_a2>
    a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Specific rack location in Server Room A, Paris Datacenter."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

<locus/rack_b1>
    a noria:Locus ;
    rdfs:label "Rack B1"@en ;
    rdfs:comment "Specific rack location in Network Room B, London Office."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

# =============================================================================
# Structural Elements (Resources, Network Interfaces, Network Links)
# =============================================================================

<productmodel/cisco_asr_9000>
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series"@en ;
    rdfs:comment "Product model for high-end aggregation services routers."@en ;
    noria:productManufacturedBy <org/manufacturer_cisco> .

<productmodel/hp_proliant_dl380>
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Product model for enterprise-grade rack servers."@en ;
    noria:productManufacturedBy <org/manufacturer_hp> .

<resource/core_router_01>
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router in the Paris Datacenter, handling backbone traffic."@en ;
    noria:resourceHostName "router-core-01.dc-par.example.com"^^xsd:string ;
    noria:structuralElementDistinguishedName "router-core-01.dc-par.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-CR01-PAR-2023"^^xsd:string ;
    noria:resourceSerialNumber "FOC21234567"^^xsd:string ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> ;
    noria:resourceProductModel <productmodel/cisco_asr_9000> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:locatedAtLocus <locus/rack_a1> ;
    noria:resourceManagedBy <agent/it_ops_team> ;
    noria:resourceForApplication <application/network_infra_management> .

<resource/web_server_01>
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Server hosting the main web application in the Paris Datacenter."@en ;
    noria:resourceHostName "web-server-01.dc-par.example.com"^^xsd:string ;
    noria:structuralElementDistinguishedName "web-server-01.dc-par.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-WS01-PAR-2022"^^xsd:string ;
    noria:resourceSerialNumber "FOC20987654"^^xsd:string ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> ;
    noria:resourceProductModel <productmodel/hp_proliant_dl380> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:locatedAtLocus <locus/rack_a2> ;
    noria:resourceManagedBy <agent/app_support_team> ;
    noria:resourceForApplication <application/crm_system> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

<resource/firewall_dmz_01>
    a noria:Resource ;
    rdfs:label "DMZ Firewall 01"@en ;
    rdfs:comment "Firewall protecting the DMZ segment in the Paris Datacenter."@en ;
    noria:resourceHostName "fw-dmz-01.dc-par.example.com"^^xsd:string ;
    noria:structuralElementDistinguishedName "fw-dmz-01.dc-par.example.com"^^xsd:string ;
    noria:resourceLogisticId "LOG-FW01-PAR-2023"^^xsd:string ;
    noria:resourceSerialNumber "FOC21876543"^^xsd:string ;
    noria:resourceInstallationDate "2023-02-01T09:00:00Z"^^xsd:dateTime ;
