noria:EventRecord001 a noria:EventRecord ;
    rdfs:label "DNS Server CPU Spike Alert"@en ;
    rdfs:comment "High CPU utilization detected on dns01.corp.example.com, exceeding 90% for 5 minutes."@en ;
