    dcterms:identifier "EVT-20240420-008" ;
    noria:loggingTime "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ChangeRequest001 ;
    noria:logOriginatingManagementSystem <http://example.com/change-management-system> ;
    noria:logOriginatingAgent foaf:Agent006 ;
    noria:logText "CR-20240501-001 status: Planned" .

# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OperationPlan001 a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a corporate DNS server."@en ;
    skos:example "Steps include: verify service impact, notify stakeholders, execute restart command, verify service restoration, close incident."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition001 ;
    noria:operationPlanPostCondition noria:ActionPostCondition001 .

noria:OperationPlan002 a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Guide"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues with router interfaces."@en ;
    skos:example "Steps include: check cable, verify configuration, check optical levels, replace SFP, escalate to vendor."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition002 ;
    noria:operationPlanPostCondition noria:ActionPostCondition002 .

noria:OperationPlan003 a noria:OperationPlan ;
    rdfs:label "Web Server Deployment Procedure"@en ;
    rdfs:comment "Procedure for deploying new web application servers."@en ;
    skos:example "Steps include: provision VM, install OS, install web server software, deploy application code, configure firewall, test access."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition003 ;
    noria:operationPlanPostCondition noria:ActionPostCondition003 .

noria:ActionPreCondition001 a noria:ActionPreCondition ;
    rdfs:label "DNS Restart Pre-check"@en ;
    rdfs:comment "Verify that the secondary DNS server is operational and handling queries before restarting the primary."@en .

noria:ActionPostCondition001 a noria:ActionPostCondition ;
    rdfs:label "DNS Restart Post-check"@en ;
    rdfs:comment "Verify DNS service is responding on port 53, check logs for errors, confirm internet access from client machines."@en .

noria:ActionPreCondition002 a noria:ActionPreCondition ;
    rdfs:label "Router Interface Troubleshooting Pre-check"@en ;
    rdfs:comment "Verify physical access to the router and availability of a console connection. Check if any related alarms are active."@en .

noria:ActionPostCondition002 a noria:ActionPostCondition ;
    rdfs:label "Router Interface Troubleshooting Post-check"@en ;
    rdfs:comment "Verify interface status is 'up/up', check routing table, confirm connectivity to connected devices, clear alarms."@en .

noria:ActionPreCondition003 a noria:ActionPreCondition ;
    rdfs:label "Web Server Deployment Pre-check"@en ;
    rdfs:comment "Ensure VM resources are allocated, network configuration is planned, and application package is ready."@en .

noria:ActionPostCondition003 a noria:ActionPostCondition ;
    rdfs:label "Web Server Deployment Post-check"@en ;
    rdfs:comment "Verify web server is reachable, application is running, and basic functionality tests pass."@en .

# =============================================================================
# Additional connections for density
# =============================================================================

# Link more resources to applications
noria:Resource001 noria:resourceForApplication noria:Application001 .
noria:Resource002 noria:resourceForApplication noria:Application002 .
noria:Resource003 noria:resourceForApplication noria:Application001 .
noria:Resource004 noria:resourceForApplication noria:Application003 .
noria:Resource005 noria:resourceForApplication noria:Application001 .

# Link agents to managing resources
foaf:Agent001 noria:agentManagesResource noria:Resource001 .
foaf:Agent002 noria:agentManagesResource noria:Resource003, noria:Resource005, noria:NetworkLink001, noria:NetworkLink002 .
foaf:Agent003 noria:agentManagesResource noria:Resource002, noria:Resource004 .
foaf:Agent005 noria:agentManagesResource noria:Resource005 .

# Link applications to services
noria:Application001 seas:subSystemOf noria:Service002 .
noria:Application002 seas:subSystemOf noria:Service001 .
noria:Application003 seas:subSystemOf noria:Service001 .

# Link more event records to trouble tickets
noria:TroubleTicket001 dcterms:relation noria:EventRecord005 .
noria:TroubleTicket002 dcterms:relation noria:EventRecord006 .
noria:TroubleTicket003 dcterms:relation noria:EventRecord007 .

# Link change requests to event records
noria:ChangeRequest001 dcterms:relation noria:EventRecord004 . # Router config change might be related to CR001
noria:ChangeRequest001 dcterms:relation noria:EventRecord008 .

# Link trouble tickets to change requests (e.g., a CR was created to fix a recurring TT)
noria:TroubleTicket002 dcterms:relation noria:ChangeRequest002 . # DB migration might be a permanent fix for portal slowdown

