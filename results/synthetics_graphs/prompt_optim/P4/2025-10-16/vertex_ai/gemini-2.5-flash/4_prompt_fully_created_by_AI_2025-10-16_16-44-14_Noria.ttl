    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for John Doe within the corporate IT systems."@en ;
    foaf:accountName "jdoe" ;
    observable:accountIdentifier "jdoe-corp-id-12345" .

foaf:Person001 a foaf:Person ;
    rdfs:label "John Doe"@en ;
    foaf:holdsAccount <http://example.com/cuid/jdoe> ;
    foaf:member org:OrganizationalUnit001 .

