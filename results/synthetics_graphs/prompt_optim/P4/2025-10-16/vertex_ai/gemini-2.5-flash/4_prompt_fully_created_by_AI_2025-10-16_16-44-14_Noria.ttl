# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (for illustration, not exhaustive)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<kos/application/type/business-critical> a skos:Concept ;
    skos:prefLabel "Business Critical Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> .

<kos/application/business-importance/high> a skos:Concept ;
    skos:prefLabel "High Business Importance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:prefLabel "Medium Business Importance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:prefLabel "En Production"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:prefLabel "Development"@en ;
    skos:prefLabel "En Développement"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:prefLabel "Critical Severity"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:prefLabel "Major Severity"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:prefLabel "Minor Severity"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .

<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:prefLabel "In Progress"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:prefLabel "Resolved"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:prefLabel "Supervision System"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:prefLabel "Customer Report"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .

<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ;
    skos:prefLabel "Total Breakdown"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/trouble-category/PerformanceDegradation> a skos:Concept ;
    skos:prefLabel "Performance Degradation"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:prefLabel "Diagnosis"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .

<kos/TroubleTicket/operationType/Resolution> a skos:Concept ;
    skos:prefLabel "Resolution"@en ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .

<kos/ChangeRequest/status/Planned> a skos:Concept ;
    skos:prefLabel "Planned"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:prefLabel "Implemented"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:prefLabel "Standard Change"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:prefLabel "Software Upgrade"@en ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .

<kos/Resource/type/Server> a skos:Concept ;
    skos:prefLabel "Server"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

<kos/Resource/type/Router> a skos:Concept ;
    skos:prefLabel "Router"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

<kos/Resource/type/Firewall> a skos:Concept ;
    skos:prefLabel "Firewall"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:prefLabel "Decommissioned"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .

<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:prefLabel "Up"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:prefLabel "Down"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .

<kos/Resource/AdministrativeState/Up> a skos:Concept ;
    skos:prefLabel "Administrative Up"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .

<kos/Resource/AdministrativeState/Down> a skos:Concept ;
    skos:prefLabel "Administrative Down"@en ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:prefLabel "Critical Perceived Severity"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:prefLabel "Major Perceived Severity"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:prefLabel "Warning Perceived Severity"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# =============================================================================
# Agents and Organizational Units
# =============================================================================

foaf:Agent001 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for non-urgent issues, phone for critical outages."@en .

foaf:Agent002 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call the hotline for network-related issues."@en .

foaf:Agent003 a foaf:Agent ;
    rdfs:label "Application Development Lead"@en ;
    rdfs:comment "Lead developer for the Customer Portal application."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent004 a foaf:Agent ;
    rdfs:label "Customer Support Tier 1"@en ;
    rdfs:comment "First line of support for customer-reported issues."@en ;
    noria:agentWorkingHours "7:00 am - 10:00 pm (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

foaf:Agent005 a foaf:Agent ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SecureChat> .

foaf:Agent006 a foaf:Agent ;
    rdfs:label "Change Management Coordinator"@en ;
    rdfs:comment "Coordinates all IT changes to minimize disruption."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrganizationalUnit001 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Overall department managing IT infrastructure and services."@en ;
    org:hasMember foaf:Agent001, foaf:Agent002 .

org:OrganizationalUnit002 a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team for network design and advanced troubleshooting."@en ;
    org:hasMember foaf:Agent002 .

org:OrganizationalUnit003 a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second level support for business applications."@en ;
    org:hasMember foaf:Agent003 .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel001 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for critical infrastructure services."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel002 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Cisco enterprise-grade network switch/router."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel003 a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for hosting virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com> .

noria:ProductModel004 a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy <https://www.paloaltonetworks.com> .

# =============================================================================
# Locations
# =============================================================================

bot:Site001 a bot:Site ;
    rdfs:label "Main Data Center Paris"@en ;
    rdfs:comment "Primary data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site002 a bot:Site ;
    rdfs:label "Branch Office Lyon"@en ;
    rdfs:comment "Regional office in Lyon with local IT infrastructure."@en ;
    noria:siteId "BO-LYO-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddressStreet "45 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room001 a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace bot:Site001 .

noria:Room002 a noria:Room ;
    rdfs:label "Network Rack Room"@en ;
    rdfs:comment "Dedicated room for network equipment in Lyon Branch Office."@en ;
    bot:hasSpace bot:Site002 .

noria:Locus001 a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "10" ;
    bot:hasSpace noria:Room001 .

noria:Locus002 a noria:Locus ;
    rdfs:label "Rack B5, Unit 2"@en ;
    rdfs:comment "Specific location for a router in Network Rack Room."@en ;
    noria:locusLine "B5" ;
    noria:locusRow "2" ;
    bot:hasSpace noria:Room002 .

noria:Locus003 a noria:Locus ;
    rdfs:label "Rack C3, Unit 15"@en ;
    rdfs:comment "Location for a firewall in Server Room A."@en ;
    noria:locusLine "C3" ;
    noria:locusRow "15" ;
    bot:hasSpace noria:Room001 .

# =============================================================================
# Resources
# =============================================================================

noria:Resource001 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent001 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel001 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus001 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> .

noria:Resource002 a noria:Resource ;
    rdfs:label "Web Application Server 01"@en ;
    rdfs:comment "Virtual machine hosting the customer portal application."@en ;
    noria:resourceManagedBy org:OrganizationalUnit003 ;
    noria:resourceHostName "web01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel003 ; # ESXi host
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "VM-WEB-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.1.20> ;
    noria:clusterController noria:Resource006 . # Link to a virtual cluster controller

noria:Resource003 a noria:Resource ;
    rdfs:label "Core Router Lyon 01"@en ;
    rdfs:comment "Main router for the Lyon branch office, connecting to the corporate network."@en ;
    noria:resourceManagedBy foaf:Agent002 ;
    noria:resourceHostName "lyon-cr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel002 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-LYN-CR-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus002 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.2.1> .

noria:Resource004 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Virtual machine hosting the database for the internal CRM application."@en ;
    noria:resourceManagedBy org:OrganizationalUnit001 ;
    noria:resourceHostName "db01.crm.example.com" ;
    noria:resourceProductModel noria:ProductModel003 ; # ESXi host
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "VM-DB-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.3.30> ;
    noria:clusterController noria:Resource006 .

noria:Resource005 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Main firewall protecting the corporate network perimeter."@en ;
    noria:resourceManagedBy foaf:Agent005 ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel004 ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW-001-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T16:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus003 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.5> .

noria:Resource006 a noria:Resource ;
    rdfs:label "VMware vCenter Cluster Controller"@en ;
    rdfs:comment "Virtual machine managing the ESXi cluster for virtual resources."@en ;
    noria:resourceManagedBy org:OrganizationalUnit001 ;
    noria:resourceHostName "vcenter.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel003 ; # It's a VM, but represents the control plane
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-10-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.50> .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetworkInterface001 a noria:NetworkInterface ;
    rdfs:label "eth0 on DNS Server 01"@en ;
    rdfs:comment "Ethernet interface for corporate network access on DNS server."@en ;
    noria:networkInterfaceOf noria:Resource001 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary network interface" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink001 .

noria:NetworkInterface002 a noria:NetworkInterface ;
    rdfs:label "vNIC0 on Web App Server 01"@en ;
    rdfs:comment "Virtual network interface for web application server."@en ;
    noria:networkInterfaceOf noria:Resource002 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "Virtual NIC for web traffic" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink003 . # New link for web server

noria:NetworkInterface003 a noria:NetworkInterface ;
    rdfs:label "Gi0/0/1 on Core Router Lyon 01"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting Lyon router to corporate backbone."@en ;
    noria:networkInterfaceOf noria:Resource003 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to corporate network" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects noria:NetworkLink002 .

noria:NetworkInterface004 a noria:NetworkInterface ;
    rdfs:label "Gi0/0/2 on Core Router Lyon 01"@en ;
    rdfs:comment "Gigabit Ethernet interface connecting Lyon router to local office network."@en ;
    noria:networkInterfaceOf noria:Resource003 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Local office network downlink" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 ;
    noria:networkInterfaceConnects noria:NetworkLink004 . # New link for local office

noria:NetworkInterface005 a noria:NetworkInterface ;
    rdfs:label "vNIC0 on DB Server 01"@en ;
    rdfs:comment "Virtual network interface for database server."@en ;
    noria:networkInterfaceOf noria:Resource004 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "Virtual NIC for database traffic" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink005 . # New link for DB server

noria:NetworkInterface006 a noria:NetworkInterface ;
    rdfs:label "eth1 on Perimeter Firewall 01 (External)"@en ;
    rdfs:comment "External interface of the perimeter firewall."@en ;
    noria:networkInterfaceOf noria:Resource005 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "WAN facing interface" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink006 . # New link for WAN

noria:NetworkInterface007 a noria:NetworkInterface ;
