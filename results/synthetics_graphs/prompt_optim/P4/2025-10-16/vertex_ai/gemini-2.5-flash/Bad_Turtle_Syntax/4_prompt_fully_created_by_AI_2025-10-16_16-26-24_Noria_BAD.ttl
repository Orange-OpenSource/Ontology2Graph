# =============================================================================
# Procedural Entities (OperationPlan, ActionPreCondition, ActionPostCondition)
# =============================================================================

noria:OpPlan_DNS_Restart a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS service."@en ;
    skos:example "Steps: 1. SSH to DNS server. 2. Check service status. 3. Restart service. 4. Verify service."@en ;
    noria:operationPlanPreCondition noria:PreCond_DNS_ServiceDown ;
    noria:operationPlanPostCondition noria:PostCond_DNS_ServiceUp .

noria:PreCond_DNS_ServiceDown a noria:ActionPreCondition ;
    rdfs:label "DNS Service is Down"@en ;
    rdfs:comment "Condition: DNS service is not responding or is in a failed state."@en .

noria:PostCond_DNS_ServiceUp a noria:ActionPostCondition ;
    rdfs:label "DNS Service is Up"@en ;
    rdfs:comment "Expected outcome: DNS service is running and responding to queries."@en .

noria:OpPlan_WAN_Failover a noria:OperationPlan ;
    rdfs:label "WAN Link Failover Procedure"@en ;
    rdfs:comment "Procedure to activate a backup WAN link in case of primary link failure."@en ;
    skos:example "Steps: 1. Verify primary link status. 2. Activate backup interface. 3. Verify traffic flow."@en ;
    noria:operationPlanPreCondition noria:PreCond_WAN_LinkDown ;
    noria:operationPlanPostCondition noria:PostCond_WAN_TrafficRestored .

noria:PreCond_WAN_LinkDown a noria:ActionPreCondition ;
    rdfs:label "WAN Link is Down"@en ;
    rdfs:comment "Condition: Primary WAN link is not operational."@en .

noria:PostCond_WAN_TrafficRestored a noria:ActionPostCondition ;
    rdfs:label "WAN Traffic Restored"@en ;
    rdfs:comment "Expected outcome: Network traffic is flowing over the backup WAN link."@en .

# Example of an EventRecord being mitigated by a procedure execution
noria:Event_DNSOutageLog
    noria:alarmMitigatedBy noria:ProcExecCont_DNS_Restart_TT001 .

noria:ProcExecCont_DNS_Restart_TT001 a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS Restart Execution for TT-20240420-001"@en ;
    rdfs:comment "Container for actions taken to restart DNS service for the outage ticket."@en ;
    dcterms:isPartOf noria:TT_DNSOutage_20240420 ;
    pep:hasProcedure noria:OpPlan_DNS_Restart ;
    # Example of a specific action within this container
    pep:member noria:Event_DNS_ServiceRestarted .

noria:Event_DNS_ServiceRestarted a noria:EventRecord ;
    rdfs:label "DNS Service Restarted Log"@en ;
    rdfs:comment "Log entry confirming the DNS service was restarted."@en ;
    noria:loggingTime "2024-04-20T09:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logOriginatingAgent noria:Agent_NOC_L1 ;
    noria:logText "INFO: DNS service 'named' restarted successfully."@en ;
    dcterms:isPartOf noria:ProcExecCont_DNS_Restart_TT001 .

