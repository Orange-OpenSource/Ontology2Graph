# Link resources to applications they serve
noria:Resource_DNS01 noria:resourceForApplication noria:App_CorpInternetAccess .
noria:Resource_WebSrv01 noria:resourceForApplication noria:App_CustomerPortal .
noria:Resource_RouterCore01 noria:resourceForApplication noria:App_CorpInternetAccess .
noria:Resource_SwitchLyon01 noria:resourceForApplication noria:App_CorpInternetAccess .

# Link application modules to resources they use (implicitly via seas:subSystemOf)
