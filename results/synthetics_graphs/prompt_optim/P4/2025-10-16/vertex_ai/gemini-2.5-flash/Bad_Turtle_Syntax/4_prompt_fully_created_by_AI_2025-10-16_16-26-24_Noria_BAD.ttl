# Event Records
noria:Event_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on cr-par-01 went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:NetIF_CR01_Gig0_0_1 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_WebSrvCPUHigh a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "ALERT: CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_UserLoginFailed a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on a system."@en ;
    noria:loggingTime "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logOriginatingAgent noria:Agent_ExternalUser ;
    noria:logText "Failed login attempt for user 'baduser' from IP 203.0.113.42."@en .

noria:Agent_ExternalUser a foaf:Agent ;
    rdfs:label "External User"@en ;
    rdfs:comment "Represents an external user attempting to log in."@en .

