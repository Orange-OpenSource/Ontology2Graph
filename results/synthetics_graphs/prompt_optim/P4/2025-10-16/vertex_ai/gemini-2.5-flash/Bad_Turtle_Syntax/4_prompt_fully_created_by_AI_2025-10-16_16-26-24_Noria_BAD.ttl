noria:AppMod_CIA_Prod seas:subSystemOf noria:Resource_RouterCore01 .
noria:AppMod_CP_Prod seas:subSystemOf noria:Resource_WebSrv01 .

# Link events to related parties
noria:Event_DNSOutageLog noria:eventRelatedParty noria:Agent_NOC_L1 .
noria:Event_RouterInterfaceDown noria:eventRelatedParty noria:OrgUnit_NetworkOps .

# Link trouble tickets to document status history (event records)
noria:TT_DNSOutage_20240420 noria:documentStatusHistory noria:Event_DNSOutageLog .
noria:TT_DNSOutage_20240420 noria:documentStatusHistory noria:Event_DNS_ServiceRestarted .

# Link change requests to document status history
noria:CR_DNSUpgrade_20240501 noria:documentStatusHistory noria:Event_CR_DNSUpgrade_Approved .

noria:Event_CR_DNSUpgrade_Approved a noria:EventRecord ;
    rdfs:label "CR DNS Upgrade Approved Event"@en ;
