    noria:loggingTime "2024-04-28T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ; # Assuming monitoring system logs CR status changes
    noria:logText "Change Request CR-20240501-001 (DNS Server Software Upgrade) status changed to Approved."@en .

