    dcterms:source "https://docs.example.com/plans/dns_upgrade_plan.docx"^^xsd:anyURI .

# Further linking of Application Modules to support groups
noria:AppMod_CIA_Prod noria:applicationModuleSupportGroup noria:OrgUnit_NOC_L1_Group .
noria:OrgUnit_NOC_L1_Group a org:OrganizationalUnit ;
    rdfs:label "NOC Level 1 Group"@en ;
    rdfs:comment "The organizational unit for NOC Level 1 support."@en ;
    org:hasMember noria:Agent_NOC_L1 .

noria:AppMod_CIA_Prod noria:applicationModuleHotlineGroup noria:OrgUnit_NOC_Hotline .
noria:OrgUnit_NOC_Hotline a org:OrganizationalUnit ;
    rdfs:label "NOC Hotline Group"@en ;
    rdfs:comment "Dedicated hotline team for critical incidents."@en .

# Link a TroubleTicket to a problem category and responsibility
<kos/TroubleTicket/trouble-category/ServiceInterruption> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:label "Service Interruption"@en ;
    rdfs:comment "Category for incidents causing complete service outage."@en .

<kos/TroubleTicket/problemResponsibility/ManagedNetwork> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Network Responsibility"@en ;
    rdfs:comment "Responsibility lies with the internal network management team."@en .

noria:TT_DNSOutage_20240420 noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServiceInterruption> ;
    noria:TT_DNSOutage_20240420 noria:problemCategory <kos/TroubleTicket/trouble-category/ServiceInterruption> ;
    noria:TT_DNSOutage_20240420 noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedNetwork> .

# Link a ChangeRequest to a specification
<kos/ChangeRequest/specification/StandardMaintenance> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:label "Standard Maintenance"@en ;
    rdfs:comment "Specification for routine maintenance activities."@en .

noria:CR_DNSUpgrade_20240501 noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardMaintenance> .

# Example of a virtual server status
noria:Resource_WebSrv01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Example of network interface optical power thresholds
noria:NetIF_CR01_Gig0_0_1 noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Example of a correlated execution for a trouble ticket note
noria:TTNote_DNSDiag_01 noria:troubleTicketNoteCorrelatedExecution noria:ProcExecCont_DNS_Restart_TT001 .

