@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# =============================================================================
# KOS Concepts (Knowledge Organization System)
# These are not part of the NORIA ontology itself but are referenced by its properties.
# We define some instances here to satisfy the range restrictions.
# =============================================================================

# Application Type KOS
<kos/application/type/infrastructure> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "Represents an application that provides core infrastructure services."@en .

<kos/application/type/business-critical> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Business Critical Application"@en ;
    rdfs:comment "Represents an application essential for core business operations."@en .

<kos/application/type/monitoring> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Monitoring Application"@en ;
    rdfs:comment "Represents an application used for system monitoring and alerting."@en .

# Application Business Importance KOS
<kos/application/business-importance/high> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application has a high impact on business operations if unavailable."@en .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application has a medium impact on business operations if unavailable."@en .

# Application Module Status KOS
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Development"@en ;
    rdfs:comment "The application module is under active development."@en .

# Service Type KOS
<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by external customers."@en .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:inScheme <kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that manages underlying resources, not directly exposed to customers."@en .

# Trouble Ticket Severity KOS
<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Highest severity, immediate business impact."@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Significant business impact, but not critical."@en .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:label "Minor Severity"@en ;
    rdfs:comment "Low business impact, can be addressed later."@en .

# Trouble Ticket Type KOS
<kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Failure Ticket"@en ;
    rdfs:comment "Indicates a system or service failure."@en .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:label "Assistance Request"@en ;
    rdfs:comment "Request for help or support."@en .

# Trouble Ticket Origin KOS
<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Trouble ticket initiated by a customer."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:label "Supervision Origin"@en ;
    rdfs:comment "Trouble ticket initiated by a monitoring system."@en .

# Trouble Ticket Status KOS
<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Trouble ticket is currently being worked on."@en .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "Trouble ticket issue has been resolved."@en .

# Trouble Ticket Comment Type KOS
<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment visible only to internal teams."@en .

<kos/TroubleTicket/commentType/Customer> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:label "Customer Comment"@en ;
    rdfs:comment "Comment visible to the customer."@en .

# Trouble Ticket Operation Type KOS
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Operation related to diagnosing the issue."@en .

<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:label "Tests and Measurements Operation"@en ;
    rdfs:comment "Operation involving testing and taking measurements."@en .

# Change Request Category KOS
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request involving internal teams."@en .

# Change Request Type KOS
<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk."@en .

# Change Request Cause KOS
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change caused by a software upgrade."@en .

# Change Request Status KOS
<kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "Change request has been approved."@en .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "Change request has been successfully implemented."@en .

# Resource Type KOS
<kos/Resource/type/Server> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A physical or virtual server resource."@en .

<kos/Resource/type/Router> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router resource."@en .

<kos/Resource/type/Switch> a skos:Concept ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network switch resource."@en .

# Resource Lifecycle State KOS
<kos/Resource/LifecycleState/InProduction> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Resource is currently active in production."@en .

<kos/Resource/LifecycleState/Maintenance> a skos:Concept ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:label "In Maintenance"@en ;
    rdfs:comment "Resource is currently undergoing maintenance."@en .

# Resource Operational State KOS
<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is operational."@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

# Resource Administrative State KOS
<kos/Resource/AdministrativeState/Up> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative Up"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Down> a skos:Concept ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:label "Administrative Down"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

# Notification Severity KOS
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Perceived Severity"@en ;
    rdfs:comment "Highest perceived severity for an event."@en .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Major Perceived Severity"@en ;
    rdfs:comment "Major perceived severity for an event."@en .

# Agent Contact Method KOS
<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# =============================================================================
# Organizational Entities (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

noria:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and network infrastructure."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

noria:Agent_NOC_L1 a foaf:Agent ;
    rdfs:label "NOC Level 1 Support"@en ;
    rdfs:comment "First line of defense for incident detection and initial response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Follow standard operating procedures for incident triage. Escalate to L2 if unresolved within 30 minutes."@en .

noria:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining the Customer Portal application."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit change requests via Jira. For production issues, contact NOC L2."@en .

noria:Agent_JohnDoe a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead engineer for network operations."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Available for critical network issues."@en .

noria:OrgUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Department"@en ;
    rdfs:comment "Department overseeing all network infrastructure and services."@en ;
    org:hasMember noria:Agent_JohnDoe .

noria:OrgUnit_SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing and virtualization."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "High-end router series for enterprise and service provider edge."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_HPProCurve2920 a noria:ProductModel ;
    rdfs:label "HP ProCurve 2920 Switch"@en ;
    rdfs:comment "Managed Layer 2/3 switch for enterprise networks."@en ;
    noria:productManufacturedBy noria:Org_HP .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware and software."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware and software."@en .

noria:Org_HP a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of enterprise IT products and services."@en .

# =============================================================================
# Location Entities (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "Data Center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Site_ParisDC . # Assuming bot:hasSpace can link a room to a site.

noria:Locus_RackA12 a noria:Locus ;
    rdfs:label "Rack A12"@en ;
    rdfs:comment "Specific rack location in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "12" ;
    bot:hasSpace noria:Room_ServerRoomA . # Assuming bot:hasSpace can link a locus to a room.

noria:Site_LyonOffice a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office in Lyon with local IT infrastructure."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "Office Building" ;
    noria:sitePrincipalAddressStreet "45 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_CommsRoom a noria:Room ;
    rdfs:label "Communications Room"@en ;
    rdfs:comment "Small IT room in the Lyon office."@en ;
    bot:hasSpace noria:Site_LyonOffice .

noria:Locus_WallMount a noria:Locus ;
    rdfs:label "Wall Mount Cabinet"@en ;
    rdfs:comment "Wall-mounted network cabinet in the Communications Room."@en ;
    noria:locusLine "WM" ;
    noria:locusRow "1" ;
    bot:hasSpace noria:Room_CommsRoom .

# =============================================================================
# Structural Entities (Resource, NetworkInterface, NetworkLink)
# =============================================================================

# Resources
noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceSerialNumber "SN-R740-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA12 ;
    noria:resourceManagementIPAddress observable:IPAddress_DNS01_MGMT .

observable:IPAddress_DNS01_MGMT a observable:IPAddress ;
    rdfs:label "DNS01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.10" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router Paris 01"@en ;
    rdfs:comment "Main core router in Paris Data Center, handling inter-site traffic."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ; # Assuming DNS Admin Team also manages core network
    noria:resourceHostName "cr-par-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceLogisticId "ASSET-CR-001" ;
    noria:resourceSerialNumber "SN-ASR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA12 ;
    noria:resourceManagementIPAddress observable:IPAddress_CRPAR01_MGMT .

observable:IPAddress_CRPAR01_MGMT a observable:IPAddress ;
    rdfs:label "Core Router Paris 01 Management IP"@en ;
    observable:ipAddressValue "10.0.0.20" .

noria:Resource_SwitchLyon01 a noria:Resource ;
    rdfs:label "Lyon Office Switch 01"@en ;
    rdfs:comment "Access switch in Lyon regional office."@en ;
    noria:resourceManagedBy noria:OrgUnit_NetworkOps ;
    noria:resourceHostName "sw-lyn-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_HPProCurve2920 ;
    noria:resourceLogisticId "ASSET-SW-001" ;
    noria:resourceSerialNumber "SN-HP-001" ;
    noria:resourceType <kos/Resource/type/Switch> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_WallMount ;
    noria:resourceManagementIPAddress observable:IPAddress_SWLYN01_MGMT .

observable:IPAddress_SWLYN01_MGMT a observable:IPAddress ;
    rdfs:label "Lyon Switch 01 Management IP"@en ;
    observable:ipAddressValue "192.168.10.1" .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Server hosting the corporate customer portal."@en ;
    noria:resourceManagedBy noria:Agent_AppDevTeam ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-06-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA12 .

# Network Interfaces
noria:NetIF_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetIF_CR01_Gig0_0_0 a noria:NetworkInterface ;
    rdfs:label "CR-PAR-01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router Paris 01 to the corporate LAN."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to internal network segment."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetIF_CR01_Gig0_0_1 a noria:NetworkInterface ;
    rdfs:label "CR-PAR-01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router Paris 01 to Lyon Office."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "WAN link to Lyon Office."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 .

noria:NetIF_SWLYN01_Uplink a noria:NetworkInterface ;
    rdfs:label "SW-LYN-01 Uplink"@en ;
    rdfs:comment "Uplink interface for Lyon Office Switch 01."@en ;
    noria:networkInterfaceOf noria:Resource_SwitchLyon01 ;
    noria:networkInterfaceDescription "Uplink to WAN router in Lyon."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetIF_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to DMZ LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# Network Links
noria:NetLink_ParisLAN a noria:NetworkLink ;
    rdfs:label "Paris Data Center LAN"@en ;
    rdfs:comment "Local Area Network segment in Paris DC connecting servers and core router."@en ;
    noria:networkLinkId "LAN-PAR-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2021-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_DNS01 ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv01 ;
    noria:resourceManagedBy noria:OrgUnit_NetworkOps .

noria:NetLink_WAN_Paris_Lyon a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-Lyon"@en ;
    rdfs:comment "Wide Area Network link connecting Paris DC to Lyon Office."@en ;
    noria:networkLinkId "WAN-PAR-LYN-01" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2021-07-01T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_SwitchLyon01 ;
    noria:networkInterfaceConnects noria:NetIF_CR01_Gig0_0_1 ;
    noria:networkInterfaceConnects noria:NetIF_SWLYN01_Uplink ;
    noria:resourceManagedBy noria:OrgUnit_NetworkOps .

# =============================================================================
# Functional Entities (Application, ApplicationModule, Service)
# =============================================================================

# Applications
noria:App_CorpInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet access for all corporate users."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
