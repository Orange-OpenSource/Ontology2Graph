    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via corporate email for non-urgent matters. For critical issues, use emergency hotline."@en .

:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "Lead developer for the Customer Portal application."@en ;
    noria:agentWorkingHours "10:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Ping on internal chat for quick questions. For bugs, create a ticket."@en .

:OrgUnit_NetworkOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en, "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for the daily operation and maintenance of the corporate network infrastructure."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "All network incidents must be reported via the central ticketing system."@en .

:OrgUnit_AppSupportL2 a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en, "Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support team for business applications."@en ;
    noria:agentWorkingHours "8:00-20:00 (Mon-Sat)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Call the dedicated support line for immediate application issues."@en .

:OrgUnit_SecurityTeam a org:OrganizationalUnit ;
