# --- Event Records ---
:EventRecord_DB_CPU_Alert a noria:EventRecord ;
    rdfs:label "Database CPU High Alert"@en ;
    rdfs:comment "Alert: Database VM CPU utilization exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-03-15T09:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_VirtualMachineDB ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "CPU_UTILIZATION_HIGH: dbvm01.par.example.com CPU usage 95%"@en ;
    dcterms:type <kos/Notification/EventType/ThresholdCrossed> ;
    noria:alarmProposedRepairAction :OperationPlan_RestartDBService ;
    noria:alarmMonitoredAttribute <http://example.com/metric/cpu_utilization> .

:EventRecord_Interface_Down a noria:EventRecord ;
    rdfs:label "Network Interface Down Event"@en ;
    rdfs:comment "Log: Interface GigabitEthernet0/1 on es01.lyn.example.com changed state to down."@en ;
    noria:loggingTime "2024-03-15T13:50:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_EdgeSwitch01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/1, changed state to down"@en ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:alarmProposedRepairAction :OperationPlan_CheckPhysicalLink ;
    noria:alarmMonitoredAttribute <http://example.com/metric/interface_status> .

:EventRecord_Firewall_Config_Change a noria:EventRecord ;
    rdfs:label "Firewall Configuration Change Log"@en ;
    rdfs:comment "Log: Configuration change applied to fw01.par.example.com by admin user."@en ;
    noria:loggingTime "2024-03-19T09:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Firewall01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logOriginatingAgent :Agent_JohnDoe ;
    noria:logText "CONFIG_CHANGE: User 'jdoe' applied new firewall policy 'APP_X_ACCESS'"@en ;
    dcterms:type <kos/Notification/EventType/ConfigurationChange> .

:EventRecord_DB_Service_Restarted a noria:EventRecord ;
    rdfs:label "Database Service Restarted Log"@en ;
    rdfs:comment "Log: Database service on dbvm01.par.example.com restarted successfully."@en ;
    noria:loggingTime "2024-03-15T10:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_VirtualMachineDB ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logOriginatingAgent :Agent_JaneSmith ;
    noria:logText "SERVICE_STATUS: PostgreSQL service on dbvm01 restarted. Status: Running."@en ;
    dcterms:type <kos/Notification/EventType/ServiceStatus> ;
    noria:alarmMitigatedBy :TroubleTicket_TT20240315_001 . # This event is part of the resolution for TT20240315_001

# --- Operation Plans ---
:OperationPlan_RestartDBService a noria:OperationPlan ;
    rdfs:label "Restart Database Service Procedure"@en, "Procédure Redémarrage Service Base de Données"@fr ;
    rdfs:comment "Standard operating procedure for restarting the database service on a VM."@en ;
    noria:operationPlanPreCondition :PreCond_DBHighCPU ;
    noria:operationPlanPostCondition :PostCond_DBServiceRunning .

:OperationPlan_CheckPhysicalLink a noria:OperationPlan ;
    rdfs:label "Check Physical Network Link Procedure"@en, "Procédure Vérification Lien Physique Réseau"@fr ;
    rdfs:comment "Procedure to diagnose and resolve physical network link issues."@en ;
    noria:operationPlanPreCondition :PreCond_InterfaceDown ;
    noria:operationPlanPostCondition :PostCond_InterfaceUp .

:OperationPlan_UpdateFirewallRules a noria:OperationPlan ;
    rdfs:label "Update Firewall Rules Procedure"@en, "Procédure Mise à Jour Règles Pare-feu"@fr ;
    rdfs:comment "Procedure for safely updating firewall rules."@en ;
    noria:operationPlanPreCondition :PreCond_NewAppTraffic ;
    noria:operationPlanPostCondition :PostCond_TrafficFlowing .

# --- Action Pre-Conditions ---
:PreCond_DBHighCPU a noria:ActionPreCondition ;
    rdfs:label "Database High CPU Pre-Condition"@en ;
    rdfs:comment "Condition: Database server CPU utilization is consistently above 90%."@en ;
    skos:example "EventRecord(DB_CPU_Alert) is present."@en .

:PreCond_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Condition: A critical network interface is reported as 'down'."@en ;
    skos:example "EventRecord(Interface_Down) is present."@en .

:PreCond_NewAppTraffic a noria:ActionPreCondition ;
    rdfs:label "New Application Traffic Pre-Condition"@en ;
    rdfs:comment "Condition: A new application requires specific firewall rules for traffic flow."@en ;
    skos:example "ChangeRequest(CR20240322_002) is approved and scheduled."@en .

# --- Action Post-Conditions ---
:PostCond_DBServiceRunning a noria:ActionPostCondition ;
    rdfs:label "Database Service Running Post-Condition"@en ;
    rdfs:comment "Expected outcome: Database service is running and CPU utilization is normal."@en ;
    skos:example "EventRecord(DB_Service_Restarted) is present and CPU metrics are below 50%."@en .

:PostCond_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-Condition"@en ;
    rdfs:comment "Expected outcome: The network interface is operational ('up')."@en ;
    skos:example "NetworkInterface(NetInt_ES01_Gig0_1).noria:networkInterfaceOperationalStatus is 'up'."@en .

:PostCond_TrafficFlowing a noria:ActionPostCondition ;
    rdfs:label "Application Traffic Flowing Post-Condition"@en ;
    rdfs:comment "Expected outcome: New application traffic is successfully flowing through the firewall."@en ;
    skos:example "Monitoring confirms traffic flow for the new application."@en .

# --- Additional Connections for Density ---

# Link more resources to applications
:Resource_CoreRouter01 noria:resourceForApplication :App_MonitoringSystem .
:Resource_Firewall01 noria:resourceForApplication :App_MonitoringSystem .
:Resource_EdgeSwitch01 noria:resourceForApplication :App_MonitoringSystem .

# Link applications to services (more explicitly if needed, or via modules)
:App_CustomerPortal seas:subSystemOf :Service_E2ECustomerAccess .
:App_CorporateNetwork seas:subSystemOf :Service_E2ECustomerAccess .

# Link trouble tickets to event records as triggers
:TroubleTicket_TT20240315_001 noria:troubleTicketTrigger :EventRecord_DB_CPU_Alert .
:TroubleTicket_TT20240315_002 noria:troubleTicketTrigger :EventRecord_Interface_Down .

# Link change requests to event records (e.g., for status history)
:ChangeRequest_CR20240322_002 noria:documentStatusHistory :EventRecord_Firewall_Config_Change .

# Link trouble ticket notes to correlated executions (if any)
# For example, if a specific action was taken and logged, it could be linked here.
# Let's assume a hypothetical event record for a database restart action.
:EventRecord_DB_Restart_Action a noria:EventRecord ;
    rdfs:label "Database Restart Command Executed"@en ;
    noria:loggingTime "2024-03-15T10:35:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_VirtualMachineDB ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logOriginatingAgent :Agent_JaneSmith ;
    noria:logText "Command 'systemctl restart postgresql' executed on dbvm01."@en ;
    dcterms:type <kos/Notification/EventType/CommandExecution> .

:TroubleTicketNote_TT20240315_001_Note3 a noria:TroubleTicketNote ;
    rdfs:label "Database Restart Action"@en ;
    rdfs:comment "Attempted to restart the PostgreSQL service on the database VM."@en ;
    dcterms:created "2024-03-15T10:36:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_JaneSmith ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf :TroubleTicket_TT20240315_001 ;
    noria:troubleTicketNoteCorrelatedExecution :EventRecord_DB_Restart_Action .

# Link agents to resources they manage (inverse of resourceManagedBy)
:OrgUnit_NetworkOps noria:agentManagesResource :Resource_CoreRouter01, :Resource_EdgeSwitch01, :NetLink_CR01_ISP_A, :NetLink_CR01_AppServer01, :NetLink_FW01_ISP_B, :NetLink_ES01_CoreNet .
:Agent_JohnDoe noria:agentManagesResource :Resource_AppServer01 .
:Agent_JaneSmith noria:agentManagesResource :Resource_VirtualMachineDB, :NetLink_AppServer01_DBVM01 .
:OrgUnit_SecurityTeam noria:agentManagesResource :Resource_Firewall01 .

# Link applications to resources (more specific than resourceForApplication)
:App_CustomerPortal seas:hasSubSystem :Resource_AppServer01, :Resource_VirtualMachineDB .
:App_CorporateNetwork seas:hasSubSystem :Resource_CoreRouter01, :Resource_Firewall01 .
:App_OfficeNetwork seas:hasSubSystem :Resource_EdgeSwitch01 .

# Link application modules to resources (more specific)
:AppModule_CustomerPortal_Prod seas:hasSubSystem :Resource_AppServer01, :Resource_VirtualMachineDB .

