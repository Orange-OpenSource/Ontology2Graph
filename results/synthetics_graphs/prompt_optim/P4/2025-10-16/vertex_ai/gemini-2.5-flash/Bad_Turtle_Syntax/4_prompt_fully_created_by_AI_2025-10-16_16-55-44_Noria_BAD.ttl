:Resource_CoreRouter01 noria:elementDistinguishedName "cr01.par.example.com" .
:App_CustomerPortal noria:functionalElementDistinguishedName "CUSTPORT" .

# Example of noria:structuralElementObservableData
:NetInt_CR01_Eth0_0_1 noria:structuralElementObservableData "LinkSpeed:10Gbps"^^xsd:string .

# Example of noria:structuralElementObservable (linking to a class)
:NetInt_CR01_Eth0_0_1 noria:structuralElementObservable :NetInt_CR01_Eth0_0_1_Status .

:NetInt_CR01_Eth0_0_1_Status a noria:StructuralObservable ;
    rdfs:label "Network Interface Status for CR01 Eth0/0/1"@en ;
    rdfs:comment "Current operational status of the interface."@en ;
    noria:structuralObservableOf :NetInt_CR01_Eth0_0_1 ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

