    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ;
    noria:changeRequestImpact :App_OfficeNetwork ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty :OrgUnit_NetworkOps ;
    noria:changeRequestActorParty :OrgUnit_NetworkOps .

# Event Record for a successful change
:EventRecord_Firewall_Policy_Applied a noria:EventRecord ;
    rdfs:label "Firewall Policy Applied Successfully"@en ;
    rdfs:comment "Log: New firewall policy 'APP_X_ACCESS' successfully applied and verified."@en ;
    noria:loggingTime "2024-03-22T18:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_Firewall01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logOriginatingAgent :Agent_JohnDoe ;
    noria:logText "FIREWALL_POLICY_UPDATE: Policy 'APP_X_ACCESS' activated. Verification successful."@en ;
    dcterms:type <kos/Notification/EventType/ConfigurationChange> ;
    noria:alarmMitigatedBy :ChangeRequest_CR20240322_002 . # This event is part of the successful execution of the CR

# Event Record for a resource going offline
:EventRecord_Server_Offline a noria:EventRecord ;
    rdfs:label "Application Server Offline Alert"@en ;
    rdfs:comment "Alert: app01.par.example.com is unreachable."@en ;
    noria:loggingTime "2024-03-17T01:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_AppServer01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logText "HOST_UNREACHABLE: app01.par.example.com is not responding to pings."@en ;
    dcterms:type <kos/Notification/EventType/HostUnreachable> .

# Trouble Ticket triggered by the server offline event
:TroubleTicket_TT20240317_004 a noria:TroubleTicket ;
    rdfs:label "Application Server 01 Unreachable"@en ;
    rdfs:comment "Critical incident: Application Server 01 is offline, impacting multiple services."@en ;
    dcterms:created "2024-03-17T01:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedResource :Resource_AppServer01 ;
    noria:troubleTicketRelatedService :App_CustomerPortal, :Service_E2ECustomerAccess ;
    noria:troubleTicketTrigger :EventRecord_Server_Offline ;
    noria:troubleTicketRelatedParty :Agent_JohnDoe, :OrgUnit_AppSupportL2 .

# Another Operation Plan
:OperationPlan_ServerReboot a noria:OperationPlan ;
    rdfs:label "Server Reboot Procedure"@en ;
    rdfs:comment "Standard procedure for safely rebooting a physical or virtual server."@en ;
    noria:operationPlanPreCondition :PreCond_ServerUnreachable ;
    noria:operationPlanPostCondition :PostCond_ServerOnline .

:PreCond_ServerUnreachable a noria:ActionPreCondition ;
    rdfs:label "Server Unreachable Pre-Condition"@en ;
    rdfs:comment "Condition: A critical server is reported as unreachable."@en ;
    skos:example "EventRecord(Server_Offline) is present."@en .

:PostCond_ServerOnline a noria:ActionPostCondition ;
    rdfs:label "Server Online Post-Condition"@en ;
    rdfs:comment "Expected outcome: The server is online and responding to network requests."@en ;
    skos:example "Monitoring confirms server is reachable and services are running."@en .

# Link Operation Plan to a Trouble Ticket Note (as a proposed action)
:TroubleTicketNote_TT20240317_004_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Proposed Action: Server Reboot"@en ;
    rdfs:comment "Proposing a server reboot as the first troubleshooting step for unreachable server."@en ;
    dcterms:created "2024-03-17T01:15:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_JohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf :TroubleTicket_TT20240317_004 ;
    noria:troubleTicketNoteCorrelatedExecution :OperationPlan_ServerReboot . # Linking to the plan itself as a proposed action

# Example of documentStatusHistory
:EventRecord_TT20240315_001_StatusChange1 a noria:EventRecord ;
    rdfs:label "TT20240315_001 Status Change: Initialised to InProgress"@en ;
    noria:loggingTime "2024-03-15T09:35:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system/TicketingSystem> ;
    noria:logOriginatingAgent :Agent_JaneSmith ;
    noria:logText "Trouble Ticket TT20240315_001 status changed from Initialised to InProgress."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> .

:TroubleTicket_TT20240315_001 noria:documentStatusHistory :EventRecord_TT20240315_001_StatusChange1 .

# Example of a freeze item
:EventRecord_TT20240315_001_Freeze1 a noria:EventRecord ;
    rdfs:label "TT20240315_001 Freeze: Waiting for Vendor"@en ;
    noria:loggingTime "2024-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem <http://itsm.example.com/system/TicketingSystem> ;
    noria:logOriginatingAgent :Agent_JaneSmith ;
    noria:logText "Trouble Ticket TT20240315_001 frozen, waiting for vendor response on database issue."@en ;
    dcterms:type <kos/Notification/EventType/Freeze> .

:TroubleTicket_TT20240315_001 noria:troubleTicketFreezeItem :EventRecord_TT20240315_001_Freeze1 .

