:NetInt_ES01_Gig0_1 noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 .
:NetInt_ES01_Gig0_1 noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Example of noria:alarmMonitoredAttribute (as a literal for simplicity, or could be a URI)
:EventRecord_DB_CPU_Alert noria:alarmMonitoredAttribute "CPU_Usage_Percent"^^xsd:string .

# Example of noria:actionCorrelatedOperationPlan
# If a specific action was taken as part of a TroubleTicketNote, and that action followed an OperationPlan.
:TroubleTicketNote_TT20240315_001_Note3 noria:troubleTicketNoteCorrelatedExecution :EventRecord_DB_Restart_Action .
:EventRecord_DB_Restart_Action pep:usedProcedure :OperationPlan_RestartDBService . # This is how pep:usedProcedure would be used.
# The noria:actionCorrelatedOperationPlan property is for actions, not event records directly.
# Let's create an action instance for clarity.
:Action_DB_Restart a pep:Action ;
    rdfs:label "Database Restart Action"@en ;
    pep:hasInput :PreCond_DBHighCPU ;
    pep:hasOutput :PostCond_DBServiceRunning ;
    noria:actionCorrelatedOperationPlan :OperationPlan_RestartDBService .

# This action could then be linked to the event record or the note.
# For example, the EventRecord_DB_Restart_Action could be seen as the execution of this Action_DB_Restart.
:EventRecord_DB_Restart_Action pep:isExecutionOf :Action_DB_Restart .

# Ensure all entities are connected.
# The graph is now quite dense and interconnected.
