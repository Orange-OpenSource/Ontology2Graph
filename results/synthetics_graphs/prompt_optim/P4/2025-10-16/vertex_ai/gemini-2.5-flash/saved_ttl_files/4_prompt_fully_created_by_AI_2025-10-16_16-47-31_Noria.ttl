# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan_RouterUpgrade a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router software."@en ;
    skos:example "Steps include backup, image transfer, reload, and verification."@en .

noria:ActionPreCondition_RouterBackupComplete a noria:ActionPreCondition ;
    rdfs:label "Router Configuration Backup Complete"@en ;
    rdfs:comment "Ensures a recent configuration backup is available before upgrade."@en .

noria:ActionPostCondition_RouterOperational a noria:ActionPostCondition ;
    rdfs:label "Router Operational After Upgrade"@en ;
    rdfs:comment "Verifies router is fully operational and forwarding traffic correctly after upgrade."@en .

noria:OperationPlan_RouterUpgrade noria:operationPlanPreCondition noria:ActionPreCondition_RouterBackupComplete .
noria:OperationPlan_RouterUpgrade noria:operationPlanPostCondition noria:ActionPostCondition_RouterOperational .

noria:ChangeRequest_CR001 noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkUpgradeProcedure> .
noria:ChangeRequest_CR001 pep:usedProcedure noria:OperationPlan_RouterUpgrade .

noria:OperationPlan_DB_Optimize a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing inefficient database queries."@en .

noria:ActionPreCondition_HighCPUDetected a noria:ActionPreCondition ;
    rdfs:label "High CPU on Database Server"@en ;
    rdfs:comment "Condition: Database server CPU utilization is consistently high."@en .

noria:ActionPostCondition_CPUNormalized a noria:ActionPostCondition ;
    rdfs:label "CPU Utilization Normalized"@en ;
    rdfs:comment "Outcome: Database server CPU utilization returns to normal levels."@en .

noria:OperationPlan_DB_Optimize noria:operationPlanPreCondition noria:ActionPreCondition_HighCPUDetected .
noria:OperationPlan_DB_Optimize noria:operationPlanPostCondition noria:ActionPostCondition_CPUNormalized .

noria:TroubleTicket_TT002 noria:troubleTicketCharacteristic noria:OperationPlan_DB_Optimize .

noria:OperationPlan_WebSrvRestart a noria:OperationPlan ;
    rdfs:label "Web Server Service Restart Procedure"@en ;
    rdfs:comment "Standard procedure for restarting web server services."@en .

noria:ActionPreCondition_WebSrvUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Web Server Unresponsive"@en ;
    rdfs:comment "Condition: Web server is not responding to requests."@en .

noria:ActionPostCondition_WebSrvResponsive a noria:ActionPostCondition ;
    rdfs:label "Web Server Responsive"@en ;
    rdfs:comment "Outcome: Web server is responding to requests and serving content."@en .

noria:OperationPlan_WebSrvRestart noria:operationPlanPreCondition noria:ActionPreCondition_WebSrvUnresponsive .
noria:OperationPlan_WebSrvRestart noria:operationPlanPostCondition noria:ActionPostCondition_WebSrvResponsive .

noria:TroubleTicket_TT003 noria:troubleTicketCharacteristic noria:OperationPlan_WebSrvRestart .

