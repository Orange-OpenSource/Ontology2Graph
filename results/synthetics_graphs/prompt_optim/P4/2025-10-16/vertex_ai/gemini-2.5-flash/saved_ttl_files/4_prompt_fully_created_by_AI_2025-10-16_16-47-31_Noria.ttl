noria:EventRecord_NetDown_R1_Gi0_0_1 a noria:EventRecord ;
    rdfs:label "Network Interface Down Event"@en ;
    rdfs:comment "Log entry indicating that Core Router R1's uplink interface went down."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter_R1 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_DB_HighCPU a noria:EventRecord ;
    rdfs:label "Database High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on the database server."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on dbsrv01 exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_DB_Srv01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_LoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Security event: multiple failed login attempts on Web Server 01."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Failed login for user 'admin' from IP 1.2.3.4 (5 attempts)."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:logOriginatingAgent <http://example.com/attacker/1.2.3.4> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_WebSrv_Restart a noria:EventRecord ;
    rdfs:label "Web Server Restart Event"@en ;
    rdfs:comment "Log entry indicating a planned restart of Web Server 01."@en ;
    noria:loggingTime "2024-04-19T23:00:00Z"^^xsd:dateTime ;
    noria:logText "System reboot initiated by IT Operations."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_Monitoring_Platform ;
    noria:logOriginatingAgent foaf:Agent_IT_Ops_Team ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

