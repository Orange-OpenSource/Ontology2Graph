# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent_IT_Ops_Team a foaf:Agent ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "The primary team responsible for day-to-day IT operations and infrastructure management."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency hotline."@en .

foaf:Agent_Network_Team a foaf:Agent ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Team specializing in network infrastructure design, deployment, and maintenance."@en ;
    noria:agentWorkingHours "24/7 On-Call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For network-related incidents, open a P1 ticket and call the on-call engineer."@en .

foaf:Agent_App_Dev_Team a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit bug reports and feature requests via Jira."@en .

foaf:Agent_Security_Team a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report all security concerns immediately to security@example.com."@en .

foaf:Person_Alice_Smith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> .

foaf:Person_Bob_Johnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> .

foaf:Person_Charlie_Davis a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Davis"@en ;
    rdfs:comment "IT Operations Specialist."@en ;
    foaf:mbox <mailto:charlie.davis@example.com> .

org:OrgUnit_IT_Infrastructure a org:OrganizationalUnit ;
    rdfs:label "IT Infrastructure Department"@en ;
    rdfs:comment "Department managing all IT infrastructure components."@en ;
    org:hasMember foaf:Person_Alice_Smith ;
    org:hasMember foaf:Person_Charlie_Davis .

org:OrgUnit_Software_Dev a org:OrganizationalUnit ;
    rdfs:label "Software Development Department"@en ;
    rdfs:comment "Department responsible for software development."@en ;
    org:hasMember foaf:Person_Bob_Johnson .

noria:CUid_Alice_Smith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for Alice Smith."@en ;
    foaf:accountName "asmith"@en .

noria:CUid_Bob_Johnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for Bob Johnson."@en ;
    foaf:accountName "bjohnson"@en .

foaf:Person_Alice_Smith foaf:holdsAccount noria:CUid_Alice_Smith .
foaf:Person_Bob_Johnson foaf:holdsAccount noria:CUid_Bob_Johnson .

# =============================================================================
# Locations
# =============================================================================

bot:Site_DC_Paris a bot:Site ;
