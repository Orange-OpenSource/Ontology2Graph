# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns/> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# SKOS Concept Schemes and Concepts
# =============================================================================

# Application Type Scheme
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en ;
    skos:inScheme <kos/application/type> ;
    rdfs:comment "Applications that provide core infrastructure services."@en .

<kos/application/type/business> a skos:Concept ;
    skos:prefLabel "Business Application"@en ;
    skos:inScheme <kos/application/type> ;
    rdfs:comment "Applications directly supporting business processes."@en .

<kos/application/type/monitoring> a skos:Concept ;
    skos:prefLabel "Monitoring Application"@en ;
    skos:inScheme <kos/application/type> ;
    rdfs:comment "Applications used for system monitoring and alerting."@en .

# Application Business Importance Scheme
<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

<kos/application/business-importance/high> a skos:Concept ;
    skos:prefLabel "High Business Importance"@en ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:comment "Applications critical to core business operations."@en .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:prefLabel "Medium Business Importance"@en ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:comment "Applications important but not immediately critical to core business operations."@en .

<kos/application/business-importance/low> a skos:Concept ;
    skos:prefLabel "Low Business Importance"@en ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:comment "Applications with minimal impact on core business operations."@en .

# Application Status Scheme
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:comment "The application module is currently active and serving users."@en .

<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ;
    skos:prefLabel "In Maintenance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:comment "The application module is undergoing scheduled maintenance."@en .

<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ;
    skos:prefLabel "In Development"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:comment "The application module is under active development."@en .

# Service Type Scheme
<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:prefLabel "Customer Facing Service"@en ;
    skos:inScheme <kos/service/type> ;
    rdfs:comment "Services directly consumed by external customers."@en .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:prefLabel "Resource Facing Service"@en ;
    skos:inScheme <kos/service/type> ;
    rdfs:comment "Services that manage or provide resources for other services."@en .

# Trouble Ticket Severity Scheme
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:comment "Service completely down or major business impact."@en .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:prefLabel "Major"@en ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:comment "Significant service degradation or partial outage."@en .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:comment "Small impact, workaround available, or non-critical issue."@en .

# Trouble Ticket Type Scheme
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of trouble tickets."@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:prefLabel "Failure"@en ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:comment "Indicates a system or service failure."@en .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:prefLabel "Assistance"@en ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:comment "Request for help or guidance."@en .

# Trouble Ticket Category Scheme
<kos/TroubleTicket/category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the category of trouble tickets."@en .

<kos/TroubleTicket/category/InterruptedService> a skos:Concept ;
    skos:prefLabel "Interrupted Service"@en ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:comment "Service is completely unavailable."@en .

<kos/TroubleTicket/category/PerformanceDegradation> a skos:Concept ;
    skos:prefLabel "Performance Degradation"@en ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:comment "Service is available but performing poorly."@en .

# Trouble Ticket Origin Scheme
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:prefLabel "Customer"@en ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:comment "Ticket initiated by a customer."@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:prefLabel "Supervision System"@en ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:comment "Ticket initiated by an automated monitoring system."@en .

# Trouble Ticket Urgency Scheme
<kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A scheme for classifying the urgency of trouble tickets."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:prefLabel "Immediate Intervention"@en ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:comment "Requires immediate action."@en .

<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ;
    skos:prefLabel "Deferred Intervention"@en ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:comment "Can be addressed later."@en .

# Trouble Ticket Status Scheme
<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the current status of trouble tickets."@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:prefLabel "In Progress"@en ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:comment "Ticket is actively being worked on."@en .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:prefLabel "Resolved"@en ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:comment "Issue has been resolved, awaiting closure."@en .

<kos/TroubleTicket/status/Closed> a skos:Concept ;
    skos:prefLabel "Closed"@en ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:comment "Ticket has been closed."@en .

# Trouble Ticket Problem Responsibility Scheme
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying the responsibility for a problem."@en .

<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ;
    skos:prefLabel "Internal IT"@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:comment "Responsibility lies with internal IT teams."@en .

<kos/TroubleTicket/problemResponsibility/Vendor> a skos:Concept ;
    skos:prefLabel "Vendor"@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:comment "Responsibility lies with an external vendor."@en .

# Trouble Ticket Note Comment Type Scheme
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of comments in trouble ticket notes."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:prefLabel "Internal Comment"@en ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:comment "Comment intended for internal team members only."@en .

<kos/TroubleTicket/commentType/CustomerFacing> a skos:Concept ;
    skos:prefLabel "Customer Facing Comment"@en ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:comment "Comment visible to the customer."@en .

# Trouble Ticket Note Operation Type Scheme
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the operation type of trouble ticket notes."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:prefLabel "Diagnosis"@en ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:comment "Note detailing diagnostic steps and findings."@en .

<kos/TroubleTicket/operationType/ResolutionStep> a skos:Concept ;
    skos:prefLabel "Resolution Step"@en ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:comment "Note detailing a step taken towards resolution."@en .

# Change Request Category Scheme
<kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the category of change requests."@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    skos:prefLabel "Internal Intervention"@en ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:comment "Change initiated and performed by internal teams."@en .

<kos/ChangeRequest/category/CustomerRequested> a skos:Concept ;
    skos:prefLabel "Customer Requested"@en ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:comment "Change requested by a customer."@en .

# Change Request Type Scheme
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of change requests."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:prefLabel "Standard Change"@en ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:comment "Pre-approved, low-risk changes."@en .

<kos/ChangeRequest/type/Normal> a skos:Concept ;
    skos:prefLabel "Normal Change"@en ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:comment "Requires assessment and authorization."@en .

# Change Request Cause Scheme
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying the cause of change requests."@en .

<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ;
    skos:prefLabel "Software Upgrade"@en ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:comment "Change due to software version upgrade."@en .

<kos/ChangeRequest/cause/ConfigurationChange> a skos:Concept ;
    skos:prefLabel "Configuration Change"@en ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:comment "Change due to modification of system configuration."@en .

# Change Request Status Scheme
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the status of change requests."@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:prefLabel "Approved"@en ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:comment "Change request has been approved for implementation."@en .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:prefLabel "Implemented"@en ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:comment "Change has been successfully implemented."@en .

# Change Request Specification Scheme
<kos/ChangeRequest/specification> a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    rdfs:comment "A scheme for classifying the specification of change requests."@en .

<kos/ChangeRequest/specification/RoutineMaintenance> a skos:Concept ;
    skos:prefLabel "Routine Maintenance"@en ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:comment "Standard, recurring maintenance activity."@en .

# Resource Type Scheme
<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of IT resources."@en .

<kos/Resource/type/Server> a skos:Concept ;
    skos:prefLabel "Server"@en ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:comment "A physical or virtual server."@en .

<kos/Resource/type/Router> a skos:Concept ;
    skos:prefLabel "Router"@en ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:comment "A network router."@en .

<kos/Resource/type/Switch> a skos:Concept ;
    skos:prefLabel "Switch"@en ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:comment "A network switch."@en .

<kos/Resource/type/VirtualMachine> a skos:Concept ;
    skos:prefLabel "Virtual Machine"@en ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:comment "A virtualized computing instance."@en .

# Resource Lifecycle State Scheme
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying the lifecycle state of IT resources."@en .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:comment "Resource is actively used in production."@en .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:prefLabel "Decommissioned"@en ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:comment "Resource has been removed from service."@en .

# Resource Operational State Scheme
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of IT resources."@en .

<kos/Resource/OperationalState/Up> a skos:Concept ;
    skos:prefLabel "Up"@en ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:comment "Resource is operational."@en .

<kos/Resource/OperationalState/Down> a skos:Concept ;
    skos:prefLabel "Down"@en ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:comment "Resource is not operational."@en .

# Resource Administrative State Scheme
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of IT resources."@en .

<kos/Resource/AdministrativeState/Enabled> a skos:Concept ;
    skos:prefLabel "Enabled"@en ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:comment "Resource is administratively enabled."@en .

<kos/Resource/AdministrativeState/Disabled> a skos:Concept ;
    skos:prefLabel "Disabled"@en ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:comment "Resource is administratively disabled."@en .

# Notification Severity Perceived Severity Scheme
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Notification Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the perceived severity of notifications."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:comment "Indicates a critical condition requiring immediate attention."@en .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:prefLabel "Major"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:comment "Indicates a major condition impacting service."@en .

<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ;
    skos:prefLabel "Minor"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:comment "Indicates a minor condition, potentially a precursor to a larger issue."@en .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:prefLabel "Warning"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:comment "Indicates a potential issue that needs monitoring."@en .

# Agent Contact Method Scheme
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:prefLabel "Email"@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:comment "Preferred contact method is email."@en .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:prefLabel "Phone"@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:comment "Preferred contact method is phone."@en .

# Application SLA Level Scheme
<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
    rdfs:label "Application Module SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying the SLA level of application modules."@en .

<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ;
    skos:prefLabel "Gold SLA"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:comment "Highest SLA level with maximum availability and performance guarantees."@en .

<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ;
    skos:prefLabel "Silver SLA"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:comment "Medium SLA level with good availability and performance."@en .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "8:00 am - 12:00 am / 1:00 pm - 5:30 pm (Mon --> Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use the Ticketing system + hotline phone number for national L2 and L3 issues."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, call directly. For non-critical, open a ticket."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon --> Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual IT Administrator."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon --> Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead Developer for Customer Portal."@en ;
