# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Server CPU High Alert"@en ;
    rdfs:comment "CPU utilization on DNS server dns01.corp.example.com exceeded 90%."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application3 ; # Centralized Logging System
    noria:logText "CPU_UTILIZATION_HIGH: Host dns01.corp.example.com, CPU usage 95%."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Network interface ge-0/0/1 on Core Router R01 went down."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application1 ; # Corporate Internet Access (as it monitors its own infra)
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan1 . # Link to a repair plan

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "Customer Portal Login Failure"@en ;
    rdfs:comment "Multiple failed login attempts on Customer Portal from a single IP."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ApplicationModule2 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logText "SECURITY_ALERT: Multiple failed logins for user 'testuser' from IP 203.0.113.45."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent noria:CUid_JohnDoe . # Assuming John Doe was investigating or involved

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "ESXi Host Disk Usage Warning"@en ;
    rdfs:comment "Disk usage on ESXi-01 host reached 80%."@en ;
    noria:loggingTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logText "DISK_USAGE_WARNING: Host esxi01.corp.example.com, /dev/sda1 usage 80%."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

