# =============================================================================
# Procedural Elements (Operation Plans, Pre/Post Conditions)
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    skos:example "Steps include checking cable, port status, configuration, and physical inspection."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Customer Portal Database Maintenance"@en ;
    rdfs:comment "Procedure for routine database maintenance on the Customer Portal."@en ;
    skos:example "Includes index rebuilds, statistics updates, and query optimization."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "Interface Down Pre-Condition"@en ;
    rdfs:comment "Network interface is reported as 'down' by monitoring system."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "Interface Up Post-Condition"@en ;
    rdfs:comment "Network interface operational status is 'up' and traffic is flowing."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Database Performance Degradation Pre-Condition"@en ;
    rdfs:comment "Database response times are above threshold or customer reports slow performance."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Database Performance Restored Post-Condition"@en ;
    rdfs:comment "Database response times are within acceptable limits and customer reports positive experience."@en .

# Linking actions to operation plans
noria:ProcedureExecutionContainer1 a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Interface Up Command"@en ;
    rdfs:comment "Container for events related to bringing up a network interface."@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan1 .

# Example of an EventRecord being a member of a ProcedureExecutionContainer
# This would typically be a log entry from the device confirming the command execution
<http://example.com/event/log_interface_up_command> a noria:EventRecord ;
    rdfs:label "Command 'no shutdown' executed"@en ;
    noria:loggingTime "2024-04-20T10:54:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingAgent foaf:Agent2 ;
    noria:logText "CLI_COMMAND: 'no shutdown' executed on ge-0/0/1 by Agent2."@en ;
    dcterms:isPartOf noria:ProcedureExecutionContainer1 .

# =============================================================================
# Connectivity and Density Check
# =============================================================================
# All entities created are linked:
# - Agents/OrgUnits: manage resources/applications, members of org units, hold accounts.
# - ProductModels: manufactured by orgs, used by resources.
# - Locations: sites contain rooms, rooms contain loci, resources located at loci.
# - Resources: managed by agents, have product models, logistic IDs, types, serials, usage states, installation dates, located at loci, management IPs, cluster controllers, serve applications.
# - NetworkInterfaces: part of resources, connect to network links, have admin/op status, routing metrics, optical powers.
# - NetworkLinks: terminate at resources, have IDs, installation dates, types, managed by agents.
# - Applications: have types, business importance, identifiers, functional domains, managed by agents, resources for applications.
# - ApplicationModules: part of applications, have names, IDs, status, admin/support teams/leaders, SLA levels, hotline status.
# - Services: have types, composed of application modules.
# - EventRecords: originate from managed objects/systems/agents, have logging time, text, severity, proposed actions.
# - TroubleTickets: have severity, type, criticity, priority, origin, trigger (event), urgency, supervision tool, category, cause, responsibility, detection/restoration dates, notification status, current status, related parties, related services/resources, impacts. Linked to notes and attachments.
# - TroubleTicketNotes: part of trouble tickets, have comment/operation types, creation date, creator, correlated executions.
# - DocumentAttachments: part of trouble tickets/change requests.
# - ChangeRequests: have planned/actual times, category, type, cause, impact, outage duration, status, specification, initiator/pilot/actor parties, regulation status.
# - OperationPlans: have pre/post conditions.
# - ActionPre/PostConditions: linked to operation plans.
# - CorporateUserIdentifiers: held by agents.

# This graph is dense and connected, covering various aspects of the NORIA ontology.
