noria:TroubleTicket1 a noria:TroubleTicket ;
    rdfs:label "Internet Access Outage"@en ;
    rdfs:comment "Complete loss of internet access for corporate users due to router interface down."@en ;
    noria:documentExternalId "INC-20240420-001" ;
    noria:documentHRef <http://ticketing.example.com/ticket/INC-20240420-001> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ; # Assuming P1-P4 are concepts in a scheme
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord2 ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketCause "Core Router R01 interface ge-0/0/1 went down unexpectedly."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent2 ;
    noria:troubleTicketRelatedService noria:Service1 ;
    noria:troubleTicketRelatedResource noria:Resource2 ;
    noria:troubleTicketImpacts noria:ApplicationModule1, noria:Resource2, noria:NetworkLink2 .

noria:TroubleTicket2 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Slow Performance"@en ;
    rdfs:comment "Customers reporting slow loading times for the portal."@en ;
    noria:documentExternalId "INC-20240420-002" ;
