# Trouble Ticket Notes
noria:TroubleTicketNote1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT1"@en ;
    rdfs:comment "Confirmed ge-0/0/1 interface on cr01 is physically down. Initiating remote troubleshooting."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:created "2024-04-20T10:20:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent2 ;
    dcterms:isPartOf noria:TroubleTicket1 .

noria:TroubleTicketNote2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Step for TT1"@en ;
    rdfs:comment "Executed 'no shutdown' command on interface ge-0/0/1. Interface is now up. Monitoring service."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/ResolutionStep> ;
    dcterms:created "2024-04-20T10:55:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent2 ;
    dcterms:isPartOf noria:TroubleTicket1 ;
    noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer1 .

noria:TroubleTicketNote3 a noria:TroubleTicketNote ;
    rdfs:label "Customer Update for TT2"@en ;
    rdfs:comment "Informed customer that we are investigating the performance issue and will provide an update within 2 hours."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/CustomerFacing> ;
    dcterms:created "2024-04-20T11:45:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent3 ;
    dcterms:isPartOf noria:TroubleTicket2 .

