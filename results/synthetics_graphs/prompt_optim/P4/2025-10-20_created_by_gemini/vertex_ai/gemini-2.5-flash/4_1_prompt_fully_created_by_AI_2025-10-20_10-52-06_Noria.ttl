# --- Operation Plans (noria:OperationPlan) ---
<https://w3id.org/noria/operationplan/DNSServerRestartProcedure> a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for safely restarting the corporate DNS server."@en ;
    skos:example "Steps include checking service status, graceful shutdown, power cycle, and verification."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/DNSServiceDown> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/DNSServiceRestored> .

<https://w3id.org/noria/operationplan/CoreRouterInterfaceTroubleshooting> a noria:OperationPlan ;
    rdfs:label "Core Router Interface Troubleshooting"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues with core router network interfaces."@en ;
    skos:example "Includes checking cable, port status, configuration, and physical replacement."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/NetworkInterfaceStatusDown> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/NetworkInterfaceStatusUp> .

<https://w3id.org/noria/operationplan/FirewallRuleDeploymentGuide> a noria:OperationPlan ;
    rdfs:label "Firewall Rule Deployment Guide"@en ;
    rdfs:comment "Standardized guide for deploying new firewall rules or modifying existing ones."@en ;
    skos:example "Steps include rule definition, testing in staging, change request submission, and production deployment."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/NewServiceRequiresPort8443> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/Port8443AccessibleFromDMZ> .

<https://w3id.org/noria/operationplan/DatabaseOSPatchingProcedure> a noria:OperationPlan ;
    rdfs:label "Database OS Patching Procedure"@en ;
    rdfs:comment "Procedure for applying operating system patches to production database servers."@en ;
    skos:example "Includes backup, patch application, testing, and rollback plan."@en .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
<https://w3id.org/noria/actionprecondition/DNSServiceDown> a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down"@en ;
    rdfs:comment "Condition: The DNS resolution service is not operational or responding."@en .

<https://w3id.org/noria/actionpostcondition/DNSServiceRestored> a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: The DNS resolution service is fully operational and responding."@en .

<https://w3id.org/noria/actionprecondition/NetworkInterfaceStatusDown> a noria:ActionPreCondition ;
    rdfs:label "Network Interface Status Down"@en ;
    rdfs:comment "Condition: A critical network interface is reporting an 'administratively down' or 'operationally down' status."@en .

<https://w3id.org/noria/actionpostcondition/NetworkInterfaceStatusUp> a noria:ActionPostCondition ;
    rdfs:label "Network Interface Status Up"@en ;
    rdfs:comment "Outcome: The critical network interface is reporting an 'up' operational status."@en .

<https://w3id.org/noria/actionprecondition/NewServiceRequiresPort8443> a noria:ActionPreCondition ;
    rdfs:label "New Service Requires Port 8443"@en ;
    rdfs:comment "Condition: A new application service requires inbound access on TCP port 8443."@en .

<https://w3id.org/noria/actionpostcondition/Port8443AccessibleFromDMZ> a noria:ActionPostCondition ;
    rdfs:label "Port 8443 Accessible from DMZ"@en ;
    rdfs:comment "Outcome: TCP port 8443 is successfully accessible from the DMZ segment to the new service."@en .

