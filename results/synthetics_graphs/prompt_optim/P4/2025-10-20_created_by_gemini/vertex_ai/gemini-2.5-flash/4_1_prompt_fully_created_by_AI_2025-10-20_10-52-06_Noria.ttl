# --- Agents (foaf:Agent and org:OrganizationalUnit) ---
<https://w3id.org/noria/agent/DNSAdminTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for corporate DNS server management and resolution."@en ;
    skos:example "Manages critical DNS infrastructure."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for non-urgent issues, phone for critical outages."@en .

<https://w3id.org/noria/agent/NetworkOpsCenter> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to incidents."@en ;
