# --- Event Records (noria:EventRecord) ---
# Logs, alarms, and notifications from IT systems.

noria:Event_DNSFailureLog a noria:EventRecord ;
    rdfs:label "DNS Resolution Failure Log"@en ;
    rdfs:comment "Log entry indicating a failure in DNS resolution on DNS01."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "DNS resolution failed for external domain example.com. Server unreachable."^^xsd:string ;
    dcterms:type <kos/Notification/EventType/operational-alarm> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_HighCPULog a noria:EventRecord ;
    rdfs:label "High CPU Usage Alert"@en ;
    rdfs:comment "Alert indicating sustained high CPU usage on WebSrv01."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "CPU usage on web01.corp.example.com exceeded 90% for 5 minutes."^^xsd:string ;
    dcterms:type <kos/Notification/EventType/operational-alarm> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_InterfaceDownLog a noria:EventRecord ;
    rdfs:label "Network Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface went down on EdgeSwitch01."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_EdgeSwitch01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "Interface GigabitEthernet0/2 on es01.corp.example.com changed state to down."^^xsd:string ;
    dcterms:type <kos/Notification/EventType/state-change> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_FirewallBlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en ;
    rdfs:comment "Alert from firewall indicating blocked suspicious traffic."@en ;
    noria:loggingTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "Blocked inbound traffic from 1.2.3.4 to 192.168.10.20 on port 80."^^xsd:string ;
    dcterms:type <kos/Notification/EventType/security-alarm> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_UserLoginFailure a noria:EventRecord ;
    rdfs:label "User Login Failure Log"@en ;
    rdfs:comment "Log entry for a failed login attempt on a system."@en ;
    noria:loggingTime "2024-04-23T10:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DB01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logOriginatingAgent noria:Agent_JohnDoe ; # Example of an agent being the origin of an event (even if failed)
    noria:logText "Failed login attempt for user 'johndoe' on db01.corp.example.com from 192.168.1.100."^^xsd:string ;
    dcterms:type <kos/Notification/EventType/security-audit> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

