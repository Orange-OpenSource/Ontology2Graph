# --- Network Interfaces (noria:NetworkInterface) ---
# Connection points on resources.

noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Management and data interface for DNS services."^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for WebSrv01 server."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Data interface for web services."^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_CoreRouter01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router 01 to Edge Switch 01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to datacenter access layer."^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100^^xsd:int .

noria:NI_EdgeSwitch01_Gi0_1 a noria:NetworkInterface ;
    rdfs:label "EdgeSwitch01 GigabitEthernet0/1"@en ;
    rdfs:comment "Interface connecting Edge Switch 01 to Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeSwitch01 ;
    noria:networkInterfaceDescription "Downlink from core router."^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_EdgeSwitch01_Gi0_2 a noria:NetworkInterface ;
    rdfs:label "EdgeSwitch01 GigabitEthernet0/2"@en ;
    rdfs:comment "Interface connecting Edge Switch 01 to DNS01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeSwitch01 ;
    noria:networkInterfaceDescription "Server access port for DNS01."^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_EdgeSwitch01_Gi0_3 a noria:NetworkInterface ;
    rdfs:label "EdgeSwitch01 GigabitEthernet0/3"@en ;
    rdfs:comment "Interface connecting Edge Switch 01 to WebSrv01."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeSwitch01 ;
    noria:networkInterfaceDescription "Server access port for WebSrv01."^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_Firewall01_Ext a noria:NetworkInterface ;
    rdfs:label "Firewall01 External Interface"@en ;
    rdfs:comment "External interface of the perimeter firewall."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceDescription "Connects to ISP."^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_Firewall01_Int a noria:NetworkInterface ;
    rdfs:label "Firewall01 Internal Interface"@en ;
    rdfs:comment "Internal interface of the perimeter firewall."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall01 ;
    noria:networkInterfaceDescription "Connects to Core Router 01."^^xsd:string ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links (noria:NetworkLink) ---
# Connections between network interfaces.

noria:NL_CoreRouter01_EdgeSwitch01 a noria:NetworkLink ;
    rdfs:label "Link CoreRouter01-EdgeSwitch01"@en ;
    rdfs:comment "High-speed link between core router and edge switch."@en ;
    noria:networkLinkId "NL-CR01-ES01"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeSwitch01 ;
    noria:networkInterfaceConnects noria:NI_CoreRouter01_Gi0_0_0 ;
    noria:networkInterfaceConnects noria:NI_EdgeSwitch01_Gi0_1 ;
    noria:networkLinkInstallationDate "2021-11-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:resourceManagedBy noria:Agent_NetworkAdminTeam .

noria:NL_EdgeSwitch01_DNS01 a noria:NetworkLink ;
    rdfs:label "Link EdgeSwitch01-DNS01"@en ;
    rdfs:comment "Link between edge switch and DNS server."@en ;
    noria:networkLinkId "NL-ES01-DNS01"^^xsd:string ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_EdgeSwitch01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DNS01 ;
    noria:networkInterfaceConnects noria:NI_EdgeSwitch01_Gi0_2 ;
    noria:networkInterfaceConnects noria:NI_DNS01_Eth0 ;
