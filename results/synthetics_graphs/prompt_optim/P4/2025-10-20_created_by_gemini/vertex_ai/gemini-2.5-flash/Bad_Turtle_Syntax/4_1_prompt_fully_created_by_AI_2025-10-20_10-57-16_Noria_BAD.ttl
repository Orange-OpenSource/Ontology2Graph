# --- Operation Plans, Pre/Post Conditions (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition) ---
# Documented procedures and their expected states.

noria:OP_DNS_Troubleshooting a noria:OperationPlan ;
    rdfs:label "DNS Troubleshooting Guide"@en ;
    rdfs:label "Guide de Dépannage DNS"@fr ;
    rdfs:comment "Step-by-step guide for diagnosing and resolving DNS resolution issues."@en ;
    skos:example "Includes checks for network connectivity, DNS service status, and configuration."@en ;
    noria:operationPlanPreCondition noria:APC_DNS_FailureReported ;
    noria:operationPlanPostCondition noria:APOC_DNS_Restored .

noria:APC_DNS_FailureReported a noria:ActionPreCondition ;
    rdfs:label "DNS Failure Reported"@en ;
    rdfs:comment "Condition: A trouble ticket for DNS resolution failure has been created."@en .

noria:APOC_DNS_Restored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS resolution is functional, and all dependent services are operational."@en .

noria:OP_ServerReboot a noria:OperationPlan ;
    rdfs:label "Standard Server Reboot Procedure"@en ;
    rdfs:label "Procédure Standard de Redémarrage Serveur"@fr ;
    rdfs:comment "Standardized procedure for safely rebooting a production server."@en ;
    skos:example "Steps include notifying stakeholders, checking dependencies, executing reboot, and verifying service restoration."@en ;
    noria:operationPlanPreCondition noria:APC_Server_RebootRequired ;
    noria:operationPlanPostCondition noria:APOC_Server_OnlineAndFunctional .

noria:APC_Server_RebootRequired a noria:ActionPreCondition ;
    rdfs:label "Server Reboot Required"@en ;
    rdfs:comment "Condition: Server is unresponsive or requires a reboot for maintenance/troubleshooting."@en .

noria:APOC_Server_OnlineAndFunctional a noria:ActionPostCondition ;
    rdfs:label "Server Online and Functional"@en ;
    rdfs:comment "Outcome: Server has successfully rebooted, all critical services are running, and accessible."@en .

noria:OP_WebSrvUpgradeProcedure a noria:OperationPlan ;
    rdfs:label "Web Server OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading the operating system of a web server."@en ;
    noria:operationPlanPreCondition noria:APC_WebSrv_BackupComplete ;
    noria:operationPlanPostCondition noria:APOC_WebSrv_UpgradeVerified .

noria:APC_WebSrv_BackupComplete a noria:ActionPreCondition ;
    rdfs:label "Web Server Backup Complete"@en ;
    rdfs:comment "Condition: A full backup of the web server and its data has been successfully completed."@en .

noria:APOC_WebSrv_UpgradeVerified a noria:ActionPostCondition ;
    rdfs:label "Web Server Upgrade Verified"@en ;
    rdfs:comment "Outcome: OS upgrade is complete, web services are functional, and performance is stable."@en .

