# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
# Teams and individuals responsible for managing resources, applications, and handling incidents.

noria:Agent_NetworkAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:label "Équipe d'Administration Réseau"@fr ;
    rdfs:comment "Team responsible for the overall network infrastructure management, including routers, switches, and firewalls."@en ;
    skos:example "Handles configuration, monitoring, and troubleshooting of network devices."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for non-urgent issues, direct call for critical network outages."@en .

noria:Agent_SysAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "System Administration Team"@en ;
    rdfs:label "Équipe d'Administration Système"@fr ;
    rdfs:comment "Team responsible for server and operating system management, including virtual machines and databases."@en ;
    skos:example "Manages OS patching, server provisioning, and performance tuning."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "Submit a ticket for all requests. Critical issues require phone escalation after ticket creation."@en .

noria:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe de Support Applicatif"@fr ;
    rdfs:comment "Team providing support for business applications and their modules."@en ;
    skos:example "Responsible for application-level troubleshooting and user support."@en ;
    noria:agentWorkingHours "24/7 On-Call"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Always call the hotline for application-related incidents."@en .

noria:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:label "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team responsible for monitoring, detecting, analyzing, and responding to cybersecurity incidents."@en ;
    skos:example "Manages SIEM, intrusion detection systems, and incident response."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alert-system> ;
    noria:agentInstructions "Automated alerts are sent for critical security events. Manual contact for investigations."@en .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:label "Jean Dupont"@fr ;
    rdfs:comment "Senior Network Engineer, member of the Network Administration Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:label "Jeanne Martin"@fr ;
    rdfs:comment "Lead Application Developer, responsible for the Corporate Website application."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

# --- Product Models (noria:ProductModel) ---
# Specifications for hardware and software.

noria:ProductModel_DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoCatalyst9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade stackable access switch."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "Modular router for enterprise and service provider applications."@en ;
    noria:productManufacturedBy noria:Org_Juniper .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi"@en ;
    rdfs:comment "Type-1 hypervisor for virtualizing servers."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware and software."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware and software."@en .

noria:Org_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking products."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

# --- Sites, Rooms, Loci (bot:Site, noria:Room, noria:Locus) ---
# Physical locations for resources.

noria:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:label "Centre de Données Principal"@fr ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "A dedicated room within the Main Data Center housing critical servers."@en ;
    bot:hasSpace noria:Site_MainDC .

noria:Locus_Rack1A a noria:Locus ;
    rdfs:label "Rack 1A"@en ;
    rdfs:comment "Specific rack location within Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Locus_Rack2B a noria:Locus ;
    rdfs:label "Rack 2B"@en ;
    rdfs:comment "Specific rack location within Server Room A."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:label "Site de Reprise d'Activité"@fr ;
    rdfs:comment "Secondary data center for disaster recovery purposes."@en ;
    noria:siteId "DR01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "456 Backup Boulevard"@en ;
    noria:sitePrincipalAddressCityName "Safetown"@en ;
    noria:sitePrincipalAddressPostalCode "20002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string .

noria:Room_DRServerRoom a noria:Room ;
    rdfs:label "DR Server Room"@en ;
    rdfs:comment "Server room at the Disaster Recovery Site."@en ;
    bot:hasSpace noria:Site_DRSite .

noria:Locus_DRRack1 a noria:Locus ;
    rdfs:label "DR Rack 1"@en ;
    rdfs:comment "Rack location in the DR Server Room."@en ;
    noria:locusLine "C"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:containsZone noria:Room_DRServerRoom .

# --- Resources (noria:Resource) ---
# Physical or virtual IT assets.

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for internal network resolution."@en ;
    noria:resourceManagedBy noria:Agent_NetworkAdminTeam ;
    noria:resourceLogisticId "RES-DNS-001"^^xsd:string ;
    noria:resourceHostName "dns01.corp.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_InternalDNS ;
    noria:locatedAtLocus noria:Locus_Rack1A ;
    noria:resourceManagementIPAddress <http://192.168.10.10> .

