    dcterms:creator foaf:Person1 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:description "Checked DNS server logs, no obvious errors. CPU usage remains high. Investigating network path."@en ;
    dcterms:isPartOf noria:TroubleTicket1 .

noria:TroubleTicketNote2 a noria:TroubleTicketNote ;
    rdfs:label "WAN Link Troubleshooting Steps"@en ;
    rdfs:comment "Steps taken to diagnose and restore WAN link to Lyon."@en ;
    dcterms:created "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent2 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:description "Confirmed interface TenGigabitEthernet0/1/0 on cr01 is administratively up but operationally down. Initiated remote diagnostics on both ends of the link. Contacting ISP."@en ;
    dcterms:isPartOf noria:TroubleTicket2 .

