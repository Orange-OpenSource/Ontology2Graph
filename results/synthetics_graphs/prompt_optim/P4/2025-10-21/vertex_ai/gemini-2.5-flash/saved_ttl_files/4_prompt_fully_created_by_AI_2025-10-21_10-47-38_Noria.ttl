# Document Attachments
# =============================================================================

noria:DocumentAttachment1 a noria:DocumentAttachment ;
    rdfs:label "Network Diagram - DC Paris"@en ;
    rdfs:comment "PDF document containing the network topology diagram for the Paris Data Center."@en ;
