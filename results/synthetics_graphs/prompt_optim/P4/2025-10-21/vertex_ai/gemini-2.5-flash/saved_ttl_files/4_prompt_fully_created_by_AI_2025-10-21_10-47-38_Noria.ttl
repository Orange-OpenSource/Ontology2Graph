# Link EventRecord to ChangeRequest for status history
noria:ChangeRequest1 noria:documentStatusHistory noria:EventRecord4 . # EventRecord4 is a config change log, which is part of the CR execution.

# =============================================================================
# Procedural Elements (Operation Plans, Pre/Post Conditions)
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "Core Router Software Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading software on Juniper MX series routers."@en ;
    skos:example "1. Backup configuration. 2. Download new image. 3. Install image. 4. Reboot. 5. Verify services."@en .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "Router Reachable and Backup Complete"@en ;
    rdfs:comment "Pre-condition: The router must be reachable via management interface and a full configuration backup must be completed."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "Router Operational and Services Restored"@en ;
    rdfs:comment "Post-condition: Router is operational, all interfaces are up, and critical services are restored."@en .

noria:OperationPlan1 noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "WAN Link Troubleshooting Guide"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving WAN link outages."@en ;
    skos:example "1. Verify physical layer. 2. Check interface status. 3. Test connectivity. 4. Contact ISP."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Link Down Alert Received"@en ;
    rdfs:comment "Pre-condition: An alert indicating a WAN link is down has been received."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Link Operational or ISP Engaged"@en ;
    rdfs:comment "Post-condition: WAN link is restored, or ISP has been engaged with a ticket number."@en .

noria:OperationPlan2 noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

# Link TroubleTicketNote to Correlated Execution (Operation Plan)
noria:TroubleTicketNote2 noria:troubleTicketNoteCorrelatedExecution noria:OperationPlan2 . # The note describes actions guided by this plan.

# Link ChangeRequest to Correlated Operation Plan
noria:ChangeRequest1 noria:actionCorrelatedOperationPlan noria:OperationPlan1 .

# =============================================================================
# Anomaly Patterns
# =============================================================================

noria:AnomalyPattern1 a noria:AnomalyPattern ;
    rdfs:label "High CPU leading to DNS Unresponsiveness"@en ;
    rdfs:comment "Anomaly pattern where sustained high CPU on DNS server leads to service degradation and unresponsiveness."@en ;
    skos:example "EventRecord(CPU_High) AND EventRecord(DNS_Query_Timeout) -> DNS_Unresponsive_Fault"@en .

noria:AnomalyPattern2 a noria:AnomalyPattern ;
    rdfs:label "WAN Link Flap Detection"@en ;
    rdfs:comment "Anomaly pattern where a network interface repeatedly goes up and down in a short period, indicating an unstable link."@en ;
    skos:example "EventRecord(IF_Down) followed by EventRecord(IF_Up) multiple times within 5 minutes."@en .

