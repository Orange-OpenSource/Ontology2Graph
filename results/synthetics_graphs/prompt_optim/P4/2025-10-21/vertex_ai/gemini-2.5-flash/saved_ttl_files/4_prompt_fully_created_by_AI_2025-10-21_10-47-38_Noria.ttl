    rdfs:comment "Internal service for resolving domain names within the corporate network."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Resource1 . # This service is directly provided by the DNS server.

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Server CPU High Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on the primary DNS server."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application3 ; # IMS detected this
    noria:logOriginatingAgent foaf:Agent2 ; # NOC is the agent receiving/processing this
    noria:logText "CPU utilization on dns01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that a network interface on Core Router R01 went down."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logOriginatingAgent foaf:Agent2 ;
    noria:logText "Interface TenGigabitEthernet0/1/0 on cr01.corp.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "Application Log Error: Database Connection Failed"@en ;
    rdfs:comment "Error log from CRM application indicating a failure to connect to the database."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ApplicationModule2 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logOriginatingAgent foaf:Agent3 ;
    noria:logText "CRM_PROD: Database connection failed for user 'crm_user' on db01."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Configuration Change on Core Router R01"@en ;
    rdfs:comment "Log entry for a configuration change applied to Core Router R01."@en ;
    noria:loggingTime "2024-04-19T14:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application3 ;
    noria:logOriginatingAgent foaf:Person1 ; # Alice Smith made the change
    noria:logText "SYS-5-CONFIG_I: Configured from console by asmith_corp (10.0.0.5)."@en .

