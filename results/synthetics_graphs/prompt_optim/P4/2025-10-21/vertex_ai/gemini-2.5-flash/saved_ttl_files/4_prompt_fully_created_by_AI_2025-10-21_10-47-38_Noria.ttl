# =============================================================================
# Organization Related Entities (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "8:00 am - 12:00 am / 1:00 pm - 5:30 pm (Mon --> Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use the Ticketing system + hotline phone number for national L2 and L3 issues."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, call the dedicated hotline immediately."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Team responsible for supporting Business Application A."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon --> Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Database Admin Team"@en ;
    rdfs:comment "Team responsible for database management."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon --> Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Person1 a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Engineer for Network Infrastructure."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" .

foaf:Person2 a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Developer for Business App A."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> .

org:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "Infrastructure Operations Department"@en ;
    rdfs:comment "Department overseeing all IT infrastructure."@en ;
    org:hasMember foaf:Person1 ;
    org:unitOf org:CompanyA .

org:OrgUnit2 a org:OrganizationalUnit ;
    rdfs:label "Business Applications Department"@en ;
    rdfs:comment "Department managing all business-critical applications."@en ;
    org:hasMember foaf:Person2 ;
    org:unitOf org:CompanyA .

org:CompanyA a org:Organization ;
    rdfs:label "Example Corp"@en ;
    rdfs:comment "A fictional company."@en .

noria:CUid1 a noria:CorporateUserIdentifier ;
    rdfs:label "asmith_corp"@en ;
    rdfs:comment "Corporate User ID for Alice Smith."@en ;
    foaf:accountName "asmith_corp" ;
    foaf:holdsAccount foaf:Person1 .

noria:CUid2 a noria:CorporateUserIdentifier ;
    rdfs:label "bjohnson_corp"@en ;
    rdfs:comment "Corporate User ID for Bob Johnson."@en ;
    foaf:accountName "bjohnson_corp" ;
    foaf:holdsAccount foaf:Person2 .

