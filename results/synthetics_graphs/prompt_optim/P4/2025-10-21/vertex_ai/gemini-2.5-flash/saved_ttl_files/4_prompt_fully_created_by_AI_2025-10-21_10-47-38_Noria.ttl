    dcterms:format "application/pdf" ;
    dcterms:source <http://docs.example.com/network_diagram_dc_paris.pdf> .

noria:DocumentAttachment2 a noria:DocumentAttachment ;
    rdfs:label "Software Upgrade Release Notes - MX204"@en ;
    rdfs:comment "Release notes for the software version installed on Juniper MX204 routers."@en ;
    dcterms:identifier "DOC-SW-MX204-RN" ;
    dcterms:created "2024-03-01T09:00:00Z"^^xsd:dateTime ;
