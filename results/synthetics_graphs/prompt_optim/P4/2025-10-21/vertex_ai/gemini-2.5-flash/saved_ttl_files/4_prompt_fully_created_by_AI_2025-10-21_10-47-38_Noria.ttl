    noria:changeRequestImpact noria:Resource2, noria:NetworkLink2 ;
    noria:changeRequestPlannedStartTime "2024-04-19T13:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-19T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-19T13:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-19T14:55:00Z"^^xsd:dateTime ;
    noria:changeRequestOutageDuration "PT10M"^^xsd:duration ; # 10 minutes outage
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RoutineMaintenance> ;
