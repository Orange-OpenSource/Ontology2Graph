    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService_extra_node_11> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1_extra_node_11> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision_extra_node_11> ;
    noria:troubleTicketTrigger noria:EventRecordDNSOutageLog ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention_extra_node_11> ;
    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown_extra_node_11> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown_extra_node_11> ;
