noria:ChangeRequestRouterUpgrade a noria:ChangeRequest ;
    rdfs:label "Core Router_extra_node_11 Software Upgrade"@en, "Mise à Jour Logicielle Routeur Cœur"@fr ;
    dcterms:description "Upgrade IOS-XE software on router_extra_node_11-core-01 to address security_extra_node_11 vulnerabilities."@en ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention_extra_node_11> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard_extra_node_11> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade_extra_node_11> ;
    noria:changeRequestImpact noria:ResourceRouterCore01, noria:ApplicationModuleInternetAccessProd ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ; # 1 hour 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved_extra_node_11> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RoutineMaintenance> ;
    noria:changeRequestInitiatorParty noria:AgentNOC ;
    noria:changeRequestPilotParty noria:AgentInfraOps ;
    noria:changeRequestActorParty noria:AgentInfraOps ;
    noria:changeRequestIsRegulated true ;
    noria:documentExternalId "CR-2024-05-01-001" ;
    noria:documentHRef "https://itsm.example.com/change/CR-2024-05-01-001" .

noria:ChangeRequestDBMigration a noria:ChangeRequest ;
    rdfs:label "CRM Database_extra_node_11 Migration"@en, "Migration Base de Données CRM"@fr ;
    dcterms:description "Migrate CRM database from on-premise to cloud infrastructure_extra_node_11."@en ;
    noria:changeRequestPlannedStartTime "2024-06-15T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-06-16T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention_extra_node_11> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard_extra_node_11> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade_extra_node_11> ; # Can be considered an upgrade of platform
    noria:changeRequestImpact noria:ResourceDBServer01, noria:ApplicationModuleCRMProd ;
    noria:changeRequestOutageDuration "PT4H"^^xsd:duration ; # 4 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved_extra_node_11> ;
    noria:changeRequestInitiatorParty noria:AgentDBA ;
    noria:changeRequestPilotParty noria:AgentAppDev ;
    noria:changeRequestActorParty noria:AgentDBA ;
    noria:changeRequestIsRegulated false ;
    noria:documentExternalId "CR-2024-06-15-001" ;
    noria:documentHRef "https://itsm.example.com/change/CR-2024-06-15-001" .

# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlanRouterReload a noria:OperationPlan ;
    rdfs:label "Core Router_extra_node_11 Reload Procedure"@en, "Procédure de Redémarrage Routeur Cœur"@fr ;
    rdfs:comment "Standard_extra_node_11 operating procedure for reloading a core router_extra_node_11."@en ;
    noria:operationPlanPreCondition noria:PreConditionRouterReachability ;
    noria:operationPlanPostCondition noria:PostConditionRouterUp .

noria:OperationPlanDNSCheck a noria:OperationPlan ;
    rdfs:label "DNS Service Health Check"@en, "Vérification Santé Service DNS"@fr ;
    rdfs:comment "Procedure to verify the operational status of DNS services."@en ;
    noria:operationPlanPreCondition noria:PreConditionNetworkConnectivity ;
    noria:operationPlanPostCondition noria:PostConditionDNSResolution .

noria:PreConditionRouterReachability a noria:ActionPreCondition ;
    rdfs:label "Router_extra_node_11 Reachability Check"@en ;
    rdfs:comment "Verify that the router_extra_node_11 is reachable via management IP and console."@en .

noria:PreConditionNetworkConnectivity a noria:ActionPreCondition ;
    rdfs:label "Network Connectivity Check"@en ;
    rdfs:comment "Ensure basic network connectivity to the DNS server_extra_node_11's subnet."@en .

noria:PostConditionRouterUp a noria:ActionPostCondition ;
    rdfs:label "Router_extra_node_11 Operational Status Up_extra_node_11"@en ;
    rdfs:comment "Confirm that the router_extra_node_11 has fully booted and all interfaces are up_extra_node_11."@en .

noria:PostConditionDNSResolution a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution_extra_node_11 Functional"@en ;
    rdfs:comment "Verify that DNS queries are successfully resolved by the DNS server_extra_node_11."@en .

# Linking Operation Plans to Change Requests (example)
noria:ChangeRequestRouterUpgrade
    noria:actionCorrelatedOperationPlan noria:OperationPlanRouterReload .

# Linking Event Records to Operation Plans (example of proposed repair action)
noria:EventRecordRouterInterfaceDown
    noria:alarmProposedRepairAction noria:OperationPlanRouterReload .

# Example of a Corporate User_extra_node_11 Identifier being the originator of an event
noria:EventRecordConfigChange
    noria:logOriginatingAgent noria:CUidJaneSmith .

# Example of a Trouble Ticket Note being correlated to an execution (implicitly via pep:ProcedureExecutionContainer)
# The vocabulary states that TroubleTicketNote is a subclass of pep:ProcedureExecutionContainer,
# so we can directly link EventRecords to it via pep:member.
noria:TroubleTicketNoteDNSDiag1
    pep:member noria:EventRecordRouterInterfaceDown . # This implies the diagnosis note is part of the execution container that includes this event.

# Example of a Trouble Ticket's status history being recorded by EventRecords
noria:TroubleTicketDNSOutage
    noria:documentStatusHistory noria:EventRecordDNSOutageLog . # This event marks the start of the incident.
# More events could be added here to show status changes.

# Example of a resource being a cluster controller for another resource (e.g., a hypervisor_extra_node_11 managing VMs)
noria:ResourceHypervisor01 a noria:Resource ;
    rdfs:label "Hypervisor_extra_node_11 Host 01"@en ;
    rdfs:comment "VMware_extra_node_11 ESXi host managing virtual_extra_node_11 machines."@en ;
    noria:resourceManagedBy noria:AgentInfraOps ;
    noria:resourceProductModel noria:ProductModelDellR740_extra_node_11 ;
    noria:resourceHostName "hypervisor01.example.com" ;
    noria:resourceType <kos/Resource/type/Server_extra_node_11> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceManagementIPAddress "10.0.0.20_extra_node_11" ;
    noria:locatedAtLocus noria:LocusR1C5 .

noria:ResourceVMApp01 a noria:Resource ;
    rdfs:label "Virtual Machine for App 01"@en ;
    rdfs:comment "Virtual machine hosting a component of Application CRM."@en ;
    noria:resourceManagedBy noria:AgentAppDev ;
    noria:resourceProductModel noria:ProductModelVMwareESXi_extra_node_11 ; # The VM is 'of' this product model (hypervisor_extra_node_11 type)
    noria:resourceHostName "vmapp01.example.com" ;
    noria:resourceType <kos/Resource/type/Server_extra_node_11> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceForApplication noria:ApplicationCRM ;
    noria:clusterController noria:ResourceHypervisor01 . # VM is controlled by the hypervisor_extra_node_11.

noria:ResourceHypervisor01
    seas:subSystemOf noria:ApplicationModuleMonitoringProd . # Hypervisor_extra_node_11 is part of the monitoring application's infrastructure_extra_node_11.

# Example of network interface optical power metrics
noria:NetworkInterfaceRouterCore01Gi0_0_0
    noria:networkInterfaceLaserTxOpticalPower -2 ; # -2 dBm
    noria:networkInterfaceLaserRxOpticalPower -5 ; # -5 dBm
    noria:networkInterfaceLaserRxOpticalPowerAverage -4 ; # -4 dBm
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ; # -1 dBm
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 . # -10 dBm

# Example of virtual_extra_node_11 server_extra_node_11 status
noria:ResourceVMApp01
    noria:virtualServerStatus <kos/Resource/OperationalState/Up_extra_node_11> .

