    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks_extra_node_11> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress_extra_node_11> ;
    noria:troubleTicketImpacts noria:ApplicationModuleInternetAccessProd, noria:ResourceDNS01 ;
    noria:documentExternalId "INC-2024-04-23-001" ;
    noria:documentHRef "https://itsm.example.com/ticket/INC-2024-04-23-001" ;
    noria:documentStatusHistory noria:EventRecordDNSOutageLog .

