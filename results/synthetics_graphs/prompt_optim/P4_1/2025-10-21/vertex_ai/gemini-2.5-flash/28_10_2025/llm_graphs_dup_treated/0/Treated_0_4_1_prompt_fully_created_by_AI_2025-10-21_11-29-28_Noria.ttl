# =============================================================================
# Event Records
# =============================================================================

noria:EventRecordDNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_11 Outage Log"@en ;
    rdfs:comment "Log entry indicating DNS server_extra_node_11 became unreachable."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - Network Unreachable"@en ;
    noria:logOriginatingManagedObject noria:ResourceDNS01 ;
    noria:logOriginatingManagementSystem noria:ApplicationMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_11> .

noria:EventRecordRouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router_extra_node_11 Interface Down Event"@en ;
    rdfs:comment "Log entry for a network interface going down on Core Router_extra_node_11 01."@en ;
    noria:loggingTime "2024-04-23T10:04:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:ResourceRouterCore01 ;
    noria:logOriginatingManagementSystem noria:ApplicationMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_11> .

noria:EventRecordAppServerCPUWarning a noria:EventRecord ;
    rdfs:label "App Server_extra_node_11 CPU Warning_extra_node_11"@en ;
    rdfs:comment "Warning_extra_node_11 log for high CPU utilization on Application Server_extra_node_11 01."@en ;
    noria:loggingTime "2024-04-23T09:50:15Z"^^xsd:dateTime ;
    noria:logText "WARNING: CPU utilization on appserver01.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:ResourceAppServer01 ;
    noria:logOriginatingManagementSystem noria:ApplicationMonitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_11> .

noria:EventRecordConfigChange a noria:EventRecord ;
    rdfs:label "Configuration_extra_node_11 Change Event"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router_extra_node_11 01."@en ;
    noria:loggingTime "2024-04-23T09:30:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jsmith (10.0.0.50)"@en ;
    noria:logOriginatingManagedObject noria:ResourceRouterCore01 ;
    noria:logOriginatingAgent noria:CUidJaneSmith ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_11> . # Configuration_extra_node_11 changes can be warnings if not expected.

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TroubleTicketDNSOutage a noria:TroubleTicket ;
