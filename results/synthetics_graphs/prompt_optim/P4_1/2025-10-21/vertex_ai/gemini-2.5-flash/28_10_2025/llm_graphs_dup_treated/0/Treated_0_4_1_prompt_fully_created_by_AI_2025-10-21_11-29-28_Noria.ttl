# =============================================================================
# Agents and Organizational Units
# =============================================================================

noria:AgentNOC a foaf:Agent ;
    rdfs:label "Network Operations Center Team"@en, "Équipe du Centre d'Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for 24/7 network monitoring_extra_node_11 and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_11> ;
    noria:agentInstructions "Contact via dedicated hotline for critical_extra_node_11 issues."@en ;
    foaf:mbox "noc@example.com" .

noria:AgentAppDev a foaf:Agent ;
    rdfs:label "Application Development_extra_node_11 Team"@en, "Équipe de Développement Applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business_extra_node_11 applications."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_11> ;
    noria:agentInstructions "Submit tickets via JIRA for non-critical_extra_node_11 issues."@en ;
    foaf:mbox "appdev@example.com" .

noria:AgentInfraOps a foaf:Agent ;
    rdfs:label "Infrastructure_extra_node_11 Operations Team"@en, "Équipe Opérations Infrastructure_extra_node_11"@fr ;
    rdfs:comment "Team managing physical_extra_node_11 and virtual infrastructure_extra_node_11."@en ;
    noria:agentWorkingHours "8:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_11> ;
    noria:agentInstructions "Use internal ticketing system for all requests."@en ;
    foaf:mbox "infraops@example.com" .

noria:AgentSecurity a foaf:Agent ;
    rdfs:label "Security Operations Center"@en, "Centre d'Opérations de Sécurité"@fr ;
    rdfs:comment "Team responsible for cybersecurity monitoring_extra_node_11 and incident handling."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_11> ;
    noria:agentInstructions "Escalate security_extra_node_11 incidents immediately."@en ;
    foaf:mbox "soc@example.com" .

noria:AgentDBA a foaf:Agent ;
    rdfs:label "Database_extra_node_11 Administration Team"@en, "Équipe d'Administration de Bases de Données"@fr ;
    rdfs:comment "Team responsible for database management and support."@en ;
