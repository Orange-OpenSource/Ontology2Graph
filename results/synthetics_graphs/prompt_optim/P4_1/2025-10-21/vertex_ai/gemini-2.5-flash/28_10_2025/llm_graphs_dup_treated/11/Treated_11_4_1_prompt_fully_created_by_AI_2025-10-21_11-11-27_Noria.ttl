# --- Agents (foaf:Agent and org:OrganizationalUnit) ---
<https://w3id.org/noria/agent/DNSAdminTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for corporate DNS server_extra_node_1 management and operations."@en ;
    noria:agentWorkingHours "08:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent issues, use hotline for critical_extra_node_1 outages."@en .

<https://w3id.org/noria/agent/WebOpsTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Web Operations Team"@en ;
    rdfs:comment "Team managing the corporate web portal infrastructure_extra_node_1."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Pager> ;
    noria:agentInstructions "Automated alerts trigger on-call engineer. For manual contact, use internal chat."@en .

