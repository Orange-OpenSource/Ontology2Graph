# --- Operation Plans, Pre/Post Conditions ---
<https://w3id.org/noria/operationplan/DNSFailoverProcedure> a noria:OperationPlan ;
    rdfs:label "DNS Server_extra_node_1 Failover Procedure"@en ;
    rdfs:comment "Standard_extra_node_1 operating procedure for failing over primary DNS server_extra_node_1 to secondary."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/DNSPrimaryUnreachable> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/DNSResolutionRestored> .

<https://w3id.org/noria/actionprecondition/DNSPrimaryUnreachable> a noria:ActionPreCondition ;
    rdfs:label "DNS Primary Unreachable"@en ;
    rdfs:comment "Condition: Primary DNS server_extra_node_1 (dns01.corp.example.com) is unreachable via ping or DNS query."@en .

<https://w3id.org/noria/actionpostcondition/DNSResolutionRestored> a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored"@en ;
    rdfs:comment "Outcome: DNS queries are successfully resolved by the secondary DNS server_extra_node_1."@en .

<https://w3id.org/noria/operationplan/WebSrvRestartProcedure> a noria:OperationPlan ;
    rdfs:label "Web Server_extra_node_1 Restart Procedure"@en ;
    rdfs:comment "Procedure for gracefully restarting the corporate web server_extra_node_1."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/WebSrvHighCPU> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/WebSrvCPUStable> .

<https://w3id.org/noria/actionprecondition/WebSrvHighCPU> a noria:ActionPreCondition ;
    rdfs:label "Web Server_extra_node_1 High_extra_node_1 CPU Usage"@en ;
    rdfs:comment "Condition: Web server_extra_node_1 CPU utilization exceeds 90% for more than 5 minutes."@en .

<https://w3id.org/noria/actionpostcondition/WebSrvCPUStable> a noria:ActionPostCondition ;
    rdfs:label "Web Server_extra_node_1 CPU Stable"@en ;
    rdfs:comment "Outcome: Web server_extra_node_1 CPU utilization is below 50% for at least 15 minutes after restart."@en .

# --- Event Records ---
<https://w3id.org/noria/eventrecord/DNS01-OutageLog> a noria:EventRecord ;
    rdfs:label "DNS01 Server_extra_node_1 Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS01 server_extra_node_1 became unreachable."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/DNS01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringSystem> ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%"@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_1> ;
    noria:alarmProposedRepairAction <https://w3id.org/noria/operationplan/DNSFailoverProcedure> .

<https://w3id.org/noria/eventrecord/WebSrv01-HighCPUAlarm> a noria:EventRecord ;
    rdfs:label "WebSrv01 High_extra_node_1 CPU Alarm"@en ;
    rdfs:comment "Alarm triggered due to sustained high_extra_node_1 CPU usage on WebSrv01."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/WebSrv01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringSystem> ;
    noria:logText "WARNING: CPU utilization on websrv01.corp.example.com is 95% (threshold 90%) for 10 minutes."@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_1> ;
    noria:alarmProposedRepairAction <https://w3id.org/noria/operationplan/WebSrvRestartProcedure> .

<https://w3id.org/noria/eventrecord/RouterCore1-InterfaceDown> a noria:EventRecord ;
    rdfs:label "RouterCore1 Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router_extra_node_1 1 went down."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/networkinterface/RouterCore1-Gi0_0_2> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringSystem> ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/2, changed state to down"@en ;
    noria:loggingTime "2024-04-10T11:30:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_1> .

<https://w3id.org/noria/eventrecord/FirewallDMZ-BlockedTraffic> a noria:EventRecord ;
    rdfs:label "Firewall DMZ Blocked Traffic Alert"@en ;
    rdfs:comment "Security alert from DMZ firewall indicating blocked suspicious traffic."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/FirewallDMZ> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/InternetAccessControl> ;
    noria:logText "ALERT: Suspicious traffic from 1.2.3.4 blocked on port 80 to websrv01.corp.example.com"@en ;
    noria:loggingTime "2024-04-10T12:05:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

<https://w3id.org/noria/eventrecord/DNS01-RestoredLog> a noria:EventRecord ;
    rdfs:label "DNS01 Server_extra_node_1 Restored Log"@en ;
    rdfs:comment "Log entry indicating DNS01 server_extra_node_1 became reachable again."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/DNS01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringSystem> ;
    noria:logText "OK: Host dns01.corp.example.com is UP - PING OK - Packet loss = 0%"@en ;
    noria:loggingTime "2024-04-10T09:30:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmMitigatedBy <https://w3id.org/noria/troubleticket/TT-DNS-Outage-20240410> .

<https://w3id.org/noria/eventrecord/WebSrv01-CPUStableLog> a noria:EventRecord ;
    rdfs:label "WebSrv01 CPU Stable Log"@en ;
    rdfs:comment "Log entry indicating WebSrv01 CPU usage returned to normal after restart."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/WebSrv01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringSystem> ;
    noria:logText "OK: CPU utilization on websrv01.corp.example.com is 30% (threshold 50%) for 15 minutes."@en ;
    noria:loggingTime "2024-04-10T10:45:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmMitigatedBy <https://w3id.org/noria/troubleticket/TT-WebSrv-Perf-20240410> .

