    noria:networkLinkInstallationDate "2022-05-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01 .

noria:NetLink_CoreRouter01_to_ISP a noria:NetworkLink ;
    rdfs:label "Core Router_extra_node_9 01 to ISP Link"@en ;
    rdfs:comment "External link from core router_extra_node_9 to Internet Service Provider."@en ;
    noria:networkLinkId "NL-CR01-ISP" ;
    noria:networkLinkType "MPLS" ;
    noria:networkLinkInstallationDate "2022-05-01T09:45:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_Firewall01 . # Simplified, ISP is external to Firewall01

noria:NetLink_Firewall01_to_ISP a noria:NetworkLink ;
    rdfs:label "Firewall_extra_node_9 01 to ISP Link"@en ;
    rdfs:comment "External link from firewall_extra_node_9 to Internet Service Provider."@en ;
    noria:networkLinkId "NL-FW01-ISP" ;
    noria:networkLinkType "Fiber Optic" ;
