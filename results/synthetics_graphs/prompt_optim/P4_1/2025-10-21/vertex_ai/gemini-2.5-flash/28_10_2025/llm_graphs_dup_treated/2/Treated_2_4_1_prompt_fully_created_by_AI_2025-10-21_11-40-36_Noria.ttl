# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology_extra_node_9/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology_extra_node_9#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure_extra_node_9 Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology_extra_node_9
@prefix saref: <http://ontology_extra_node_9.tno.nl/saref#>.  #SAREF smart building appliances ontology_extra_node_9

@prefix observable: <https://unifiedcyberontology_extra_node_9.org/ontology_extra_node_9/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business_extra_node_9 offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology_extra_node_9/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (Teams and Individuals) ---
noria:Agent_NetOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for managing and monitoring_extra_node_9 network infrastructure_extra_node_9."@en ;
    rdfs:comment "Équipe responsable de la gestion et de la surveillance de l'infrastructure_extra_node_9 réseau."@fr ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_9> ;
    noria:agentInstructions "For critical_extra_node_9 issues, call the hotline. For non-critical_extra_node_9, use ticketing system."@en .

noria:Agent_AppSupportL2 a foaf:Agent ;
    rdfs:label "Application Support L2 Team"@en ;
    rdfs:label "Équipe Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support team for business_extra_node_9 applications."@en ;
    rdfs:comment "Équipe de support de second niveau pour les applications métier."@fr ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_9> ;
    noria:agentInstructions "Open a ticket via the portal, then follow up_extra_node_9 by email_extra_node_9."@en .

noria:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Cyber Security Team"@en ;
    rdfs:label "Équipe Cybersécurité"@fr ;
    rdfs:comment "Team responsible for security_extra_node_9 monitoring_extra_node_9 and incident response."@en ;
    rdfs:comment "Équipe responsable de la surveillance de la sécurité et de la réponse aux incidents."@fr ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> ;
    noria:agentInstructions "Use encrypted communication channels for sensitive information."@en .

noria:Agent_DBA_Team a foaf:Agent ;
    rdfs:label "Database_extra_node_9 Administration Team"@en ;
    rdfs:label "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> .

noria:Agent_AliceSmith a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en .

noria:Agent_BobJohnson a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en .

noria:Agent_CharlieBrown a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Security Analyst."@en .

noria:CUid_AliceSmith a noria:CorporateUserIdentifier ;
    foaf:accountName "asmith" ;
    rdfs:label "Alice Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en .
noria:Agent_AliceSmith foaf:holdsAccount noria:CUid_AliceSmith .

noria:CUid_BobJohnson a noria:CorporateUserIdentifier ;
    foaf:accountName "bjohnson" ;
    rdfs:label "Bob Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Bob Johnson."@en .
noria:Agent_BobJohnson foaf:holdsAccount noria:CUid_BobJohnson .

