    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Site_DC_Lyon a bot:Site ;
    rdfs:label "Lyon Data Center"@en ;
    rdfs:comment "Secondary data center located in Lyon."@en ;
    noria:siteId "DC-LYN-02" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server_extra_node_9 Room A"@en ;
    rdfs:comment "Main server_extra_node_9 room in Paris Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 .
noria:Site_DC_Paris bot:containsZone noria:Room_ServerRoomA .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room in Paris Data Center."@en ;
    bot:hasSpace noria:Locus_RackB1 .
noria:Site_DC_Paris bot:containsZone noria:Room_NetworkRoomB .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location for critical_extra_node_9 application servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location for database servers."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

noria:Locus_RackB1 a noria:Locus ;
    rdfs:label "Rack B1"@en ;
    rdfs:comment "Location for core network routers and firewalls."@en ;
    noria:locusLine "B" ;
    noria:locusRow "1" .

