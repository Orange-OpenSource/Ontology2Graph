# --- Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person) ---
noria:Agent_IT_Ops_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:label "Équipe Opérations IT"@fr ;
    rdfs:comment "The primary team responsible for day-to-day IT infrastructure_extra_node_2 operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/PagerDuty> ;
    noria:agentInstructions "For critical_extra_node_2 incidents, follow the PagerDuty escalation matrix. For non-critical_extra_node_2, use ticketing system."@en .

noria:Agent_Network_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:label "Équipe Ingénierie Réseau"@fr ;
    rdfs:comment "Specialized team managing network infrastructure_extra_node_2, including routers, switches, and firewalls."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri, on-call for critical_extra_node_2 issues"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_2> ;
    noria:agentInstructions "Contact via email_extra_node_2 for routine requests. For network outages, use the dedicated hotline."@en .

noria:Agent_App_Support_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe Support Applicatif"@fr ;
