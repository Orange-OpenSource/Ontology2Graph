    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_2> ;
    noria:agentInstructions "All application-related issues must be logged in the JIRA ticketing system."@en .

noria:Agent_Security_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:label "Centre d'Opérations de Cybersécurité (CSOC)"@fr ;
    rdfs:comment "Team dedicated to monitoring_extra_node_2, detecting, analyzing, and responding to cybersecurity incidents."@en ;
