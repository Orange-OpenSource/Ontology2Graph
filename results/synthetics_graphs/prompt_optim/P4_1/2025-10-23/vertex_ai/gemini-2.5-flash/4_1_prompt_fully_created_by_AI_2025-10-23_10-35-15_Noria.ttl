# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_CheckCable a noria:OperationPlan ;
    rdfs:label "Network Cable Check Procedure"@en ;
    rdfs:comment "Standard operating procedure for checking and replacing network cables."@en ;
    skos:example "1. Verify link lights. 2. Check cable integrity. 3. Replace cable if faulty."@en ;
    noria:operationPlanPreCondition noria:PreCond_LinkDown ;
    noria:operationPlanPostCondition noria:PostCond_LinkUp .

noria:OperationPlan_RestartService a noria:OperationPlan ;
    rdfs:label "Application Service Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting a critical application service."@en ;
    skos:example "1. Notify stakeholders. 2. Stop service. 3. Verify service stopped. 4. Start service. 5. Verify service started."@en ;
    noria:operationPlanPreCondition noria:PreCond_ServiceUnresponsive ;
    noria:operationPlanPostCondition noria:PostCond_ServiceRunning .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:PreCond_LinkDown a noria:ActionPreCondition ;
    rdfs:label "Network Link Down"@en ;
    rdfs:comment "Condition: A network interface or link is reported as down."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Down>" .

noria:PostCond_LinkUp a noria:ActionPostCondition ;
    rdfs:label "Network Link Up"@en ;
    rdfs:comment "Expected outcome: The network interface or link is restored to an operational state."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Up>" .

noria:PreCond_ServiceUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Application Service Unresponsive"@en ;
    rdfs:comment "Condition: An application service is not responding to requests."@en ;
    skos:example "Application health check fails." .

noria:PostCond_ServiceRunning a noria:ActionPostCondition ;
    rdfs:label "Application Service Running"@en ;
    rdfs:comment "Expected outcome: The application service is running and responsive."@en ;
    skos:example "Application health check passes." .

# =============================================================================
# Anomaly Patterns (noria:AnomalyPattern)
# =============================================================================

noria:AnomalyPattern_DNSCachePoisoning a noria:AnomalyPattern ;
    rdfs:label "DNS Cache Poisoning Pattern"@en ;
    rdfs:comment "Pattern indicating a potential DNS cache poisoning attack, characterized by unusual DNS query responses and high traffic to unknown domains."@en ;
    skos:example "Multiple DNS queries for non-existent domains followed by unexpected IP resolutions."@en .

noria:AnomalyPattern_ResourceExhaustion a noria:AnomalyPattern ;
    rdfs:label "Resource Exhaustion Pattern"@en ;
    rdfs:comment "Pattern indicating a resource exhaustion issue, characterized by sustained high CPU/memory usage and degraded application performance."@en ;
    skos:example "Sustained CPU > 90% and memory > 95% on a critical server, correlated with application latency."@en .

