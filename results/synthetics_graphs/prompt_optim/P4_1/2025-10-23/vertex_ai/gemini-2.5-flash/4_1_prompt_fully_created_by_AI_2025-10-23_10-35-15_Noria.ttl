# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- SKOS Concepts for KOS (Knowledge Organization System) ---
# These are not explicitly defined in the provided NORIA vocabulary snippet as instances,
# but are used as ranges for various properties. We define them here for completeness.

# Application KOS
<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/service-platform> a skos:Concept ; rdfs:label "Service Platform"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/business-application> a skos:Concept ; rdfs:label "Business Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; rdfs:label "Maintenance"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; rdfs:label "Silver SLA"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# Service KOS
<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en ; skos:inScheme <kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en ; skos:inScheme <kos/service/type> .

# TroubleTicket KOS
<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure"@en ; skos:inScheme <kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance"@en ; skos:inScheme <kos/TroubleTicket/type> .
<kos/TroubleTicket/category/TotalBreakdown> a skos:Concept ; rdfs:label "Total Breakdown"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/category/DegradedPerformance> a skos:Concept ; rdfs:label "Degraded Performance"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en ; skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en ; skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision System"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .
<kos/TroubleTicket/problemResponsibility/ManagedBackbone> a skos:Concept ; rdfs:label "Managed Backbone Networks"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/Customer> a skos:Concept ; rdfs:label "Customer Responsibility"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis"@en ; skos:inScheme <kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/Restoration> a skos:Concept ; rdfs:label "Restoration"@en ; skos:inScheme <kos/TroubleTicket/operationType> .

# ChangeRequest KOS
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention"@en ; skos:inScheme <kos/ChangeRequest/category> .
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en ; skos:inScheme <kos/ChangeRequest/type> .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; rdfs:label "Configuration Change"@en ; skos:inScheme <kos/ChangeRequest/cause> .
<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved"@en ; skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented"@en ; skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/specification/NetworkUpgrade> a skos:Concept ; rdfs:label "Network Upgrade Procedure"@en ; skos:inScheme <kos/ChangeRequest/specification> .

# Resource KOS
<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Firewall> a skos:Concept ; rdfs:label "Firewall"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/LifecycleState/InUse> a skos:Concept ; rdfs:label "In Use"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Up"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Down"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; rdfs:label "Up"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Down"@en ; skos:inScheme <kos/Resource/AdministrativeState> .

# Notification KOS
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<kos/Notification/EventType/stateChange> a skos:Concept ; rdfs:label "State Change"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/EventType> .
<kos/Notification/EventType/thresholdCrossing> a skos:Concept ; rdfs:label "Threshold Crossing Alert"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/EventType> .
<kos/Notification/EventType/securityAlert> a skos:Concept ; rdfs:label "Security Alert"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/EventType> .

# Agent Contact Method KOS
<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone"@en ; skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Agents (foaf:Agent & org:OrganizationalUnit)
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email dns-support@example.com for non-urgent issues. Call hotline for critical outages."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use ticketing system for all requests. Critical issues via direct phone line."@en .

foaf:Agent_AppSupportTeam a foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2 support for critical business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit tickets through the ITSM portal. Escalations via team lead."@en .

foaf:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate notification for any security breach or suspicious activity."@en .

foaf:Agent_DBA_Team a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Open a ticket for all database-related requests or issues."@en .

foaf:Agent_CloudOpsTeam a foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Team managing cloud infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use cloud platform's incident management system for issues."@en .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the Network Operations Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Application Support Team."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit_CoreNetwork a org:OrganizationalUnit ;
    rdfs:label "Core Network Unit"@en ;
    rdfs:comment "Organizational unit responsible for the core network infrastructure."@en .

org:OrgUnit_DataCenterOps a org:OrganizationalUnit ;
    rdfs:label "Data Center Operations"@en ;
    rdfs:comment "Organizational unit managing physical data center resources."@en .

