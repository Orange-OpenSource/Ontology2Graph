# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN. Ping failed."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T08:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "INTERFACE_STATUS_CHANGE: Interface router-core-01-Gi0/0/0 changed state to DOWN."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckCable .

noria:EventRecord_DBHighCPU a noria:EventRecord ;
    rdfs:label "Database Server High CPU Warning"@en ;
    rdfs:comment "Warning log for high CPU utilization on the production database server."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "WARNING: CPU utilization on db-prod-01 exceeded 80% for 5 minutes."@en ;
    dcterms:type <kos/Notification/EventType/thresholdCrossing> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_FirewallBlockedAttack a noria:EventRecord ;
    rdfs:label "Firewall Blocked Attack Alert"@en ;
    rdfs:comment "Security alert from DMZ firewall indicating a blocked brute-force attack."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "SECURITY: Brute-force attack detected and blocked from IP 203.0.113.42 on port 22."@en ;
    dcterms:type <kos/Notification/EventType/securityAlert> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_UserLoginFailure a noria:EventRecord ;
    rdfs:label "User Login Failure Log"@en ;
    rdfs:comment "Log entry for a failed login attempt by an internal user."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_VM_Web01 ;
    noria:logOriginatingAgent foaf:Agent_JohnDoe ; # Assuming John Doe tried to log in
    noria:logText "Failed login attempt for user 'jdoe' from IP 10.0.1.50 on web-vm-01."@en ;
    dcterms:type <kos/Notification/EventType/securityAlert> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

