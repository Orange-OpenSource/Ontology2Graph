# Add more event records and link them
noria:EventRecord_RouterInterfaceUp a noria:EventRecord ;
    rdfs:label "Router Interface Up Log"@en ;
    rdfs:comment "Log entry indicating a critical interface on Core Router 01 came back up."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logText "INTERFACE_STATUS_CHANGE: Interface router-core-01-Gi0/0/0 changed state to UP."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    noria:alarmMitigatedBy noria:TroubleTicket_RouterConnectivityIssue . # The TT itself is the container for the procedure execution

