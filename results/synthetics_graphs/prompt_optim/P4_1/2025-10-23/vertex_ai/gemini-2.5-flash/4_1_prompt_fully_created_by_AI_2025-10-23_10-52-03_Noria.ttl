    noria:productManufacturedBy <https://www.juniper.net/organization> .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary corporate data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "48.8700"^^xsd:float ;
    wgs84_pos:long "2.3300"^^xsd:float .

bot:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary data center for disaster recovery, located in Lyon."@en ;
    noria:siteId "DC-LYN-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "45.7400"^^xsd:float ;
    wgs84_pos:long "4.8400"^^xsd:float .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2, noria:Locus_RackA3, noria:Locus_RackA4 ;
    bot:hasBuilding bot:Site_MainDC .

noria:Room_NetworkRoom1 a noria:Room ;
    rdfs:label "Network Room 1"@en ;
    rdfs:comment "Room dedicated to network equipment in Main Data Center."@en ;
    bot:hasSpace noria:Locus_NetRack1, noria:Locus_NetRack2 ;
    bot:hasBuilding bot:Site_MainDC .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_RackA3 a noria:Locus ;
    rdfs:label "Rack A3"@en ;
    rdfs:comment "Third rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "3" ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_RackA4 a noria:Locus ;
    rdfs:label "Rack A4"@en ;
    rdfs:comment "Fourth rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "4" ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_NetRack1 a noria:Locus ;
    rdfs:label "Network Rack 1"@en ;
    rdfs:comment "First rack in Network Room 1."@en ;
    noria:locusLine "N" ;
    noria:locusRow "1" ;
    bot:hasZone noria:Room_NetworkRoom1 .

noria:Locus_NetRack2 a noria:Locus ;
    rdfs:label "Network Rack 2"@en ;
    rdfs:comment "Second rack in Network Room 1."@en ;
    noria:locusLine "N" ;
    noria:locusRow "2" ;
    bot:hasZone noria:Room_NetworkRoom1 .

