# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person) ---
org:Team_NetworkOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing and monitoring network infrastructure."@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline and ticketing system."@en .

org:Team_AppSupport a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2/L3 support for business applications."@en ;
    rdfs:label "Équipe Support Applicatif"@fr ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket via the ITSM portal for all application-related issues."@en .

org:Team_SecurityOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    rdfs:label "Centre des Opérations de Sécurité (SOC)"@fr ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "Automated alerts are sent to the SIEM. Manual intervention for critical incidents."@en .

org:Team_DBA a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    rdfs:label "Équipe Administration Bases de Données"@fr ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> .

org:Team_CloudOps a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Team managing cloud infrastructure and services."@en ;
    rdfs:label "Équipe Opérations Cloud"@fr ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/MonitoringPlatform> .

foaf:Person_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Person_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Person_CharlieBrown a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "SOC Analyst L2."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    foaf:phone "+1-555-111-2222" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

# --- Corporate User Identifiers (noria:CorporateUserIdentifier) ---
noria:CUid_AliceSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique corporate identifier for Alice Smith."@en ;
    foaf:accountName "asmith" ;
    foaf:holdsAccount foaf:Person_AliceSmith .

noria:CUid_BobJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique corporate identifier for Bob Johnson."@en ;
    foaf:accountName "bjohnson" ;
    foaf:holdsAccount foaf:Person_BobJohnson .

# --- Product Models (noria:ProductModel) ---
noria:ProductModel_Cisco3850 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 3850 Series Switch"@en ;
    rdfs:comment "Enterprise-class stackable access layer switch."@en ;
