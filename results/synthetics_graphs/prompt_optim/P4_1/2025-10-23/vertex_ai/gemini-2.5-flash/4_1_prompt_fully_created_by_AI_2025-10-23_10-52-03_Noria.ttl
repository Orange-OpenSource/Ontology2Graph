# --- Operation Plans (noria:OperationPlan) ---
noria:OP_RouterFailover a noria:OperationPlan ;
    rdfs:label "Router Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over network traffic between core routers."@en ;
    skos:example "Steps include verifying link status, initiating routing protocol changes, and validating traffic flow."@en ;
    noria:operationPlanPreCondition noria:PreCond_LinkDown ;
    noria:operationPlanPostCondition noria:PostCond_TrafficRestored .

noria:OP_DBDiskCleanup a noria:OperationPlan ;
    rdfs:label "Database Disk Cleanup Procedure"@en ;
    rdfs:comment "Procedure for clearing old logs and temporary files from database servers."@en ;
    skos:example "Steps include identifying large files, backing up, and deleting/archiving."@en ;
    noria:operationPlanPreCondition noria:PreCond_DiskFull ;
    noria:operationPlanPostCondition noria:PostCond_DiskSpaceFreed .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:PreCond_LinkDown a noria:ActionPreCondition ;
    rdfs:label "Network Link Down Detected"@en ;
    rdfs:comment "Condition: A critical network link is detected as being down."@en ;
    skos:example "EventRecord indicating 'LINEPROTO-5-UPDOWN: changed state to down'."@en .

noria:PostCond_TrafficRestored a noria:ActionPostCondition ;
    rdfs:label "Network Traffic Restored"@en ;
    rdfs:comment "Outcome: Network traffic is successfully rerouted and services are accessible."@en ;
    skos:example "Monitoring shows green status for affected services and ping tests are successful."@en .

noria:PreCond_DiskFull a noria:ActionPreCondition ;
    rdfs:label "Critical Disk Space Alert"@en ;
    rdfs:comment "Condition: Disk usage on a critical server exceeds 95%."@en ;
    skos:example "EventRecord indicating 'Disk usage on /var/lib/mysql is 98%'."@en .

noria:PostCond_DiskSpaceFreed a noria:ActionPostCondition ;
    rdfs:label "Sufficient Disk Space Available"@en ;
    rdfs:comment "Outcome: Disk usage on the server is below 80%."@en ;
    skos:example "Monitoring shows disk usage at 70% after cleanup."@en .

# --- Anomaly Patterns (noria:AnomalyPattern) ---
noria:AnomalyPattern_HighCPULatency a noria:AnomalyPattern ;
    rdfs:label "High CPU and High Latency Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a potential performance bottleneck or resource contention, characterized by simultaneous high CPU utilization on a server and high I/O latency on its associated storage."@en ;
    skos:example "Observed when noria:Event_WebSrvCPUHigh_20240726_002 and noria:Event_StorageLatency_20240726_006 occur concurrently on related resources."@en .

