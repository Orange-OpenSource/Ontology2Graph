# --- Event Records (noria:EventRecord) ---
noria:Event_RouterDown_20240726_001 a noria:EventRecord ;
    rdfs:label "Router Core 01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating that GigabitEthernet0/0/0 on Core Router 01 went down."@en ;
    noria:loggingTime "2024-07-26T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmMitigatedBy noria:TT_20240726_001 .

noria:Event_WebSrvCPUHigh_20240726_002 a noria:EventRecord ;
    rdfs:label "Web Server 01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Web Server 01."@en ;
    noria:loggingTime "2024-07-26T10:15:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    dcterms:type <kos/Notification/EventType/thresholdExceeded> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_FirewallLoginFail_20240726_003 a noria:EventRecord ;
    rdfs:label "Firewall Login Failure Alert"@en ;
    rdfs:comment "Multiple failed login attempts detected on Firewall 01."@en ;
    noria:loggingTime "2024-07-26T10:20:10Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem org:Team_SecurityOps ; # Assuming SOC system generates this alert
    noria:logText "Failed login attempts from 192.168.5.10 to fw01.corp.example.com (user: admin)."@en ;
    dcterms:type <kos/Notification/EventType/securityAlert> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent foaf:Person_CharlieBrown .

noria:Event_DBDiskFull_20240726_004 a noria:EventRecord ;
    rdfs:label "Database Server Disk Full Alert"@en ;
    rdfs:comment "Alert indicating that the disk space on Database Server 01 is critically low."@en ;
    noria:loggingTime "2024-07-26T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DBServer01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "Disk usage on /var/lib/mysql on db01.corp.example.com is 98%."@en ;
    dcterms:type <kos/Notification/EventType/resourceExhaustion> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_LoadBalancerIssue_20240726_005 a noria:EventRecord ;
