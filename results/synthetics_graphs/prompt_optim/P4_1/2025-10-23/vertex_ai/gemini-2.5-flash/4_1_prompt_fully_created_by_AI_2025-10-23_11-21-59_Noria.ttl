# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (invented for demonstration, based on property ranges)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure Application"@en .
<kos/application/type/service-platform> a skos:Concept ; skos:prefLabel "Service Platform Application"@en .
<kos/application/type/business-critical> a skos:Concept ; skos:prefLabel "Business Critical Application"@en .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring Application"@en .
<kos/application/type/log-management> a skos:Concept ; skos:prefLabel "Log Management Application"@en .

<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; skos:prefLabel "Low Business Importance"@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:prefLabel "Maintenance"@en .

<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; skos:prefLabel "Gold SLA Level"@en .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; skos:prefLabel "Silver SLA Level"@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical Severity"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major Severity"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor Severity"@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:prefLabel "Failure Ticket Type"@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:prefLabel "Assistance Ticket Type"@en .

<kos/TroubleTicket/category/NetworkOutage> a skos:Concept ; skos:prefLabel "Network Outage Category"@en .
<kos/TroubleTicket/category/ApplicationPerformance> a skos:Concept ; skos:prefLabel "Application Performance Category"@en .
<kos/TroubleTicket/category/HardwareFailure> a skos:Concept ; skos:prefLabel "Hardware Failure Category"@en .

<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision Origin"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer Origin"@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; skos:prefLabel "Immediate Intervention Urgency"@en .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; skos:prefLabel "Deferred Intervention Urgency"@en .

<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ; skos:prefLabel "Network Team Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ; skos:prefLabel "Application Team Responsibility"@en .

<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress Status"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved Status"@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; skos:prefLabel "Closed Status"@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment Type"@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:prefLabel "Customer Comment Type"@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis Operation Type"@en .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; skos:prefLabel "Resolution Operation Type"@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; skos:prefLabel "Internal Intervention Category"@en .
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; skos:prefLabel "Software Upgrade Category"@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change Type"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:prefLabel "Emergency Change Type"@en .

<kos/ChangeRequest/cause/Configuration> a skos:Concept ; skos:prefLabel "Configuration Change Cause"@en .
<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ; skos:prefLabel "Preventative Maintenance Cause"@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:prefLabel "Approved Status"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; skos:prefLabel "Implemented Status"@en .

<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server Resource Type"@en .
<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router Resource Type"@en .
<kos/Resource/type/Firewall> a skos:Concept ; skos:prefLabel "Firewall Resource Type"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine Resource Type"@en .
<kos/Resource/type/LoadBalancer> a skos:Concept ; skos:prefLabel "Load Balancer Resource Type"@en .

<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:prefLabel "In Production Lifecycle State"@en .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; skos:prefLabel "Staging Lifecycle State"@en .

<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Up Operational State"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down Operational State"@en .

<kos/Resource/AdministrativeState/Up> a skos:Concept ; skos:prefLabel "Up Administrative State"@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; skos:prefLabel "Down Administrative State"@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:prefLabel "Minor Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Informational> a skos:Concept ; skos:prefLabel "Informational Perceived Severity"@en .

<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email Contact Method"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone Contact Method"@en .

<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en .

# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

foaf:ITOperationsTeam
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Central team responsible for overall IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical incidents, call the hotline immediately. For non-critical, use ticketing system."@en .

foaf:NetworkAdminTeam
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en ;
    rdfs:comment "Team managing network devices, links, and connectivity."@en ;
    noria:agentWorkingHours "8:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit network-related requests via the dedicated portal."@en .

foaf:AppSupportTeamA
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Support team for critical business applications like Corporate Website and CRM."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Open a ticket for all application issues. Escalation via phone for P1 incidents."@en .

foaf:SecurityTeam
    a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Report all suspected security breaches to the SOC hotline."@en .

foaf:JohnDoe
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual network engineer, member of the Network Administration Team."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:JaneSmith
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead developer for the Corporate Website application."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:NOC
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "First line of defense for network monitoring and initial troubleshooting."@en ;
    noria:agentWorkingHours "24/7"@en .

org:L2Support
    a org:OrganizationalUnit ;
    rdfs:label "Level 2 Application Support"@en ;
    rdfs:comment "Second level support for complex application issues."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en .

org:L3AppDev
    a org:OrganizationalUnit ;
    rdfs:label "Level 3 Application Development"@en ;
    rdfs:comment "Development team responsible for application code and architecture."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel:DellPowerEdgeR740
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> .

noria:ProductModel:CiscoCatalyst9300
    a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300 Series Switch"@en ;
    rdfs:comment "Enterprise-grade access layer switch."@en ;
    noria:productManufacturedBy <https://www.cisco.com> .

noria:ProductModel:PaloAltoFirewallPA500
    a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-500 Firewall"@en ;
    rdfs:comment "Next-generation firewall for network security."@en ;
    noria:productManufacturedBy <https://www.paloaltonetworks.com> .

noria:ProductModel:VMwareESXi
    a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com> .

noria:ProductModel:F5BIG-IP
    a noria:ProductModel ;
    rdfs:label "F5 BIG-IP Load Balancer"@en ;
    rdfs:comment "Application delivery controller for traffic management."@en ;
    noria:productManufacturedBy <https://www.f5.com> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site:MainDataCenter
    a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC-M1" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en ;
    wgs84_pos:lat "34.0522"^^xsd:float ;
    wgs84_pos:long "-118.2437"^^xsd:float .

noria:Room:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace noria:Locus:RackA_Unit10, noria:Locus:RackB_Unit5 ;
    bot:hasSubSpace noria:Locus:RackA_Unit10, noria:Locus:RackB_Unit5 ;
    bot:hasBuilding bot:Site:MainDataCenter .

noria:Locus:RackA_Unit10
    a noria:Locus ;
    rdfs:label "Rack A, Unit 10"@en ;
    rdfs:comment "Specific location for a server within Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "10"^^xsd:int ;
    bot:hasZone noria:Room:ServerRoomA .

noria:Locus:RackB_Unit5
    a noria:Locus ;
    rdfs:label "Rack B, Unit 5"@en ;
    rdfs:comment "Specific location for a network device within Server Room A."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "5"^^xsd:int ;
    bot:hasZone noria:Room:ServerRoomA .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource:DNS01
    a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, critical for name resolution."@en ;
    noria:resourceManagedBy foaf:NetworkAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel:DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ789" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus:RackA_Unit10 ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
    noria:resourceForApplication noria:Application:CorporateWebsite .

noria:Resource:WebSrv01
    a noria:Resource ;
    rdfs:label "Corporate Web Server 01"@en ;
    rdfs:comment "Server hosting the main corporate website."@en ;
