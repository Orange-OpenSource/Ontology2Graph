# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface:DNS01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "eth0 on DNS01"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource:DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int .

noria:NetworkInterface:WebSrv01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "eth0 on WebSrv01"@en ;
    rdfs:comment "Primary network interface for WebSrv01."@en ;
    noria:networkInterfaceOf noria:Resource:WebSrv01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface:RouterCore01_Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on RouterCore01"@en ;
    rdfs:comment "Interface connecting RouterCore01 to the internal network segment."@en ;
