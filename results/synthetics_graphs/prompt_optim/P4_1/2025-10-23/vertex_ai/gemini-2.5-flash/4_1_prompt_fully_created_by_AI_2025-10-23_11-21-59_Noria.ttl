noria:OperationPlan:FirewallRuleRollback
    a noria:OperationPlan ;
    rdfs:label "Firewall Rule Rollback Procedure"@en ;
    rdfs:comment "Standard operating procedure for reverting a recently deployed firewall rule in case of issues."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition:FirewallRuleBlockingTraffic ;
    noria:operationPlanPostCondition noria:ActionPostCondition:TrafficRestored .

noria:ActionPreCondition:FirewallRuleBlockingTraffic
    a noria:ActionPreCondition ;
    rdfs:label "Firewall Rule Blocking Traffic Pre-Condition"@en ;
    rdfs:comment "Condition: A recently deployed firewall rule is identified as blocking legitimate traffic."@en .

noria:ActionPostCondition:TrafficRestored
    a noria:ActionPostCondition ;
    rdfs:label "Traffic Restored Post-Condition"@en ;
    rdfs:comment "Outcome: Network traffic flows as expected after the rule rollback, and affected services are operational."@en .

noria:EventRecord:FirewallRuleReverted noria:alarmProposedRepairAction noria:OperationPlan:FirewallRuleRollback .

