    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel:DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB01-ABC123" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus:RackA_Unit10 ;
    noria:resourceManagementIPAddress "10.0.0.20" ;
    noria:resourceForApplication noria:Application:CorporateWebsite .

noria:Resource:RouterCore01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for internal network traffic and internet egress."@en ;
