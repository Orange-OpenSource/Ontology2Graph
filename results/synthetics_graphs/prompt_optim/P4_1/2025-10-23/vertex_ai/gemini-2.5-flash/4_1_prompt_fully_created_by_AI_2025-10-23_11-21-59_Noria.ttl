noria:Resource:FirewallDMZ01
    a noria:Resource ;
    rdfs:label "DMZ Firewall 01"@en ;
    rdfs:comment "Firewall protecting the DMZ segment where public-facing services reside."@en ;
    noria:resourceManagedBy foaf:SecurityTeam ;
    noria:resourceHostName "fw-dmz01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel:PaloAltoFirewallPA500 ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW01-GHI987" ;
