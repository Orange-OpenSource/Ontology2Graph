noria:TroubleTicketNote:TTN_001_Diag
    a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT-20240315-001"@en ;
    rdfs:comment "Initial checks show no issues on DNS or WebSrv01. Traffic is not reaching the Load Balancer. Suspect issue between RouterCore01 and FirewallDMZ01."@en ;
