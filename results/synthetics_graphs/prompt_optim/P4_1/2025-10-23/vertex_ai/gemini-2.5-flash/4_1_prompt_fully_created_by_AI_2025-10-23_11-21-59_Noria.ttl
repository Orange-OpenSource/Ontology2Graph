    dcterms:creator foaf:JohnDoe ;
    dcterms:isPartOf noria:TroubleTicket:TT20240315_001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TroubleTicketNote:TTN_001_Fix
    a noria:TroubleTicketNote ;
    rdfs:label "Firewall Rule Update for TT-20240315-001"@en ;
    rdfs:comment "Identified a recently deployed firewall rule blocking external access to port 80/443. Rule has been temporarily disabled. Website is now reachable."@en ;
    dcterms:created "2024-03-15T11:00:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:JohnDoe ;
    dcterms:isPartOf noria:TroubleTicket:TT20240315_001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> .

noria:TroubleTicketNote:TTN_002_CustomerUpdate
    a noria:TroubleTicketNote ;
    rdfs:label "Customer Update for TT-20240315-002"@en ;
    rdfs:comment "Customer confirmed continued performance issues, especially during peak hours. Provided additional logs."@en ;
    dcterms:created "2024-03-15T11:45:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:JaneSmith ;
    dcterms:isPartOf noria:TroubleTicket:TT20240315_002 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

