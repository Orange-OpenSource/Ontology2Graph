# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OP_DNS_Troubleshooting a noria:OperationPlan ;
    rdfs:label "DNS Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving DNS service outages."@en ;
    skos:example "Steps include checking server status, network connectivity, DNS service health, and log analysis."@en ;
    noria:operationPlanPreCondition noria:ActionPre_DNS_Unreachable ;
    noria:operationPlanPostCondition noria:ActionPost_DNS_Restored .

noria:OP_WebSrv_PerformanceTuning a noria:OperationPlan ;
    rdfs:label "Web Server Performance Tuning Guide"@en ;
    rdfs:comment "Procedure for optimizing web server performance, including CPU and memory usage."@en ;
    skos:example "Steps involve analyzing process usage, optimizing database queries, and adjusting web server configurations."@en ;
    noria:operationPlanPreCondition noria:ActionPre_HighCPU_WebSrv ;
    noria:operationPlanPostCondition noria:ActionPost_WebSrv_PerformanceImproved .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPre_DNS_Unreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unreachable"@en ;
    rdfs:comment "Condition where the primary DNS server is not responding to network requests."@en ;
    skos:example "Ping failures, DNS queries timing out."@en .

noria:ActionPost_DNS_Restored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Condition where the primary DNS server is fully operational and resolving queries."@en ;
    skos:example "Successful pings, DNS queries resolving correctly, no error logs."@en .

noria:ActionPre_HighCPU_WebSrv a noria:ActionPreCondition ;
    rdfs:label "High CPU on Web Server"@en ;
    rdfs:comment "Condition where the web server's CPU utilization consistently exceeds a high threshold."@en ;
    skos:example "Monitoring alerts for CPU > 90% for more than 5 minutes."@en .

noria:ActionPost_WebSrv_PerformanceImproved a noria:ActionPostCondition ;
    rdfs:label "Web Server Performance Improved"@en ;
    rdfs:comment "Condition where web server response times are within acceptable limits and CPU usage is normalized."@en ;
    skos:example "Average CPU usage below 70%, page load times under 2 seconds."@en .

