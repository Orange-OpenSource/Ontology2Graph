# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (invented based on vocabulary examples)
# =============================================================================

<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application Type"@en .
<kos/application/type/business-critical> a skos:Concept ; rdfs:label "Business Critical Application Type"@en .
<kos/application/type/monitoring> a skos:Concept ; rdfs:label "Monitoring Application Type"@en .
<kos/application/type/database> a skos:Concept ; rdfs:label "Database Application Type"@en .
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en .
<kos/application/business-importance/low> a skos:Concept ; rdfs:label "Low Business Importance"@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; rdfs:label "En Production"@fr .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en ; rdfs:label "En Développement"@fr .
<https://w3id.org/noria/kos/application/status/Staging> a skos:Concept ; rdfs:label "Staging"@en ; rdfs:label "En Pré-production"@fr .

<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en .
<kos/TroubleTicket/type/Incident> a skos:Concept ; rdfs:label "Incident Ticket Type"@en .
<kos/TroubleTicket/type/RequestForInformation> a skos:Concept ; rdfs:label "Request for Information Ticket Type"@en .
<kos/TroubleTicket/category/NetworkOutage> a skos:Concept ; rdfs:label "Network Outage Category"@en .
<kos/TroubleTicket/category/SoftwareBug> a skos:Concept ; rdfs:label "Software Bug Category"@en .
<kos/TroubleTicket/category/HardwareFailure> a skos:Concept ; rdfs:label "Hardware Failure Category"@en .
<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ; rdfs:label "Network Team Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ; rdfs:label "Application Team Responsibility"@en .
<kos/TroubleTicket/problemResponsibility/HardwareVendor> a skos:Concept ; rdfs:label "Hardware Vendor Responsibility"@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress Status"@en .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved Status"@en .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed Status"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision Origin"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Origin"@en .
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention Urgency"@en .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention Urgency"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment Type"@en .
<kos/TroubleTicket/commentType/CustomerFacing> a skos:Concept ; rdfs:label "Customer Facing Comment Type"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis Operation Type"@en .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; rdfs:label "Resolution Operation Type"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; rdfs:label "Priority 1"@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; rdfs:label "Priority 2"@en .

<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade Category"@en .
<kos/ChangeRequest/category/HardwareReplacement> a skos:Concept ; rdfs:label "Hardware Replacement Category"@en .
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change Type"@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency Change Type"@en .
<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ; rdfs:label "Preventative Maintenance Cause"@en .
<kos/ChangeRequest/cause/SecurityPatch> a skos:Concept ; rdfs:label "Security Patch Cause"@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved Status"@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented Status"@en .
<kos/ChangeRequest/status/Scheduled> a skos:Concept ; rdfs:label "Scheduled Status"@en .

<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server Resource Type"@en .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router Resource Type"@en .
<kos/Resource/type/Firewall> a skos:Concept ; rdfs:label "Firewall Resource Type"@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine Resource Type"@en .
<kos/Resource/LifecycleState/InUse> a skos:Concept ; rdfs:label "In Use Lifecycle State"@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned Lifecycle State"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Up Operational State"@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Down Operational State"@en .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; rdfs:label "Up Administrative State"@en .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; rdfs:label "Down Administrative State"@en .

<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service Type"@en .
<kos/service/type/InternalService> a skos:Concept ; rdfs:label "Internal Service Type"@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning Perceived Severity"@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor Perceived Severity"@en .

<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email Contact Method"@en .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone Contact Method"@en .

# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

noria:Agent_NetworkTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for managing network infrastructure and resolving network-related incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via dedicated hotline for critical issues. Use ticketing system for standard requests."@en .

noria:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit tickets via the IT Service Portal."@en .

noria:Agent_DBATeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:label "Équipe Administration Bases de Données"@fr ;
    rdfs:comment "Team responsible for database management and maintenance."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:label "Centre Opérations Sécurité"@fr ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the Network Operations Team."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    foaf:member noria:Agent_NetworkTeam .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Application Support Team."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    foaf:member noria:Agent_AppSupportTeam .

noria:Agent_ITManager a foaf:Agent ;
    rdfs:label "IT Manager"@en ;
    rdfs:comment "Manager overseeing IT operations."@en ;
    foaf:mbox "mailto:it.manager@example.com" .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> .

noria:ProductModel_Cisco3850 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 3850"@en ;
    rdfs:comment "Enterprise-class stackable access layer switch."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> .

noria:ProductModel_PaloAlto500 a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-500"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy <http://www.paloaltonetworks.com/organization> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Type-1 hypervisor for virtualized environments."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria:Site_HQ a bot:Site ;
    rdfs:label "Headquarters Data Center"@en ;
    rdfs:comment "Main data center facility for corporate operations."@en ;
    noria:siteId "DC-HQ-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Main Street" ;
    noria:sitePrincipalAddressCityName "Anytown" ;
    noria:sitePrincipalAddressPostalCode "12345" ;
    noria:sitePrincipalAddressCountry "US" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room within the Headquarters Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    bot:hasBuilding noria:Site_HQ .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First server rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second server rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted on physical hardware."@en ;
    noria:resourceManagedBy noria:Agent_NetworkTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-03-10T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Application Server 01"@en ;
    rdfs:comment "Server hosting the main corporate web application."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> .

noria:Resource_DB01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Server hosting the corporate database."@en ;
    noria:resourceManagedBy noria:Agent_DBATeam ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DB01-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.30> .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy noria:Agent_NetworkTeam ;
    noria:resourceHostName "core-rtr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco3850 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR01-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-11-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_FirewallDMZ a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:comment "Firewall protecting the Demilitarized Zone (DMZ)."@en ;
    noria:resourceManagedBy noria:Agent_SecurityTeam ;
    noria:resourceHostName "fw-dmz01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_PaloAlto500 ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW01-JKL" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-05-15T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.254> .

noria:Resource_VirtualHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server hosting multiple virtual machines."@en ;
    noria:resourceManagedBy noria:Agent_NetworkTeam ;
    noria:resourceHostName "vhost01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-VHOST01-MNO" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-06-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.50> .

noria:Resource_VM_Monitoring a noria:Resource ;
    rdfs:label "Monitoring VM"@en ;
    rdfs:comment "Virtual machine running the network monitoring system."@en ;
    noria:resourceManagedBy noria:Agent_NetworkTeam ;
    noria:resourceHostName "vm-mon01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # Product model of the hypervisor, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-06-10T10:00:00Z"^^xsd:dateTime ;
    noria:clusterController noria:Resource_VirtualHost01 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.51> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Management interface" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for WebSrv01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Application traffic interface" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Uplink interface from Core Router 01 to external network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "WAN Uplink" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NI_RouterCore01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigabitEthernet0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 01 to internal LAN."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Internal LAN" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NI_FirewallDMZ_Eth0 a noria:NetworkInterface ;
    rdfs:label "DMZ Firewall Ethernet 0"@en ;
    rdfs:comment "External interface of the DMZ Firewall."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceDescription "External WAN" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NI_FirewallDMZ_Eth1 a noria:NetworkInterface ;
    rdfs:label "DMZ Firewall Ethernet 1"@en ;
    rdfs:comment "Internal interface of the DMZ Firewall to DMZ segment."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceDescription "Internal DMZ" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NL_CoreRtr_WAN a noria:NetworkLink ;
    rdfs:label "Core Router to WAN Link"@en ;
    rdfs:comment "High-speed link connecting the corporate network to the internet."@en ;
    noria:networkLinkId "NL-CR01-WAN-001" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResource noria:Resource_FirewallDMZ ; # Assuming firewall is between router and external WAN
