# =============================================================================
# Additional Connectivity and Density
# =============================================================================

# Link more resources to applications
noria:Resource_DNS01 noria:resourceForApplication noria:App_MonitoringSystem . # Monitoring system relies on DNS
noria:Resource_WebSrv01 noria:resourceForApplication noria:App_MonitoringSystem .
noria:Resource_DB01 noria:resourceForApplication noria:App_MonitoringSystem .
noria:Resource_RouterCore01 noria:resourceForApplication noria:App_MonitoringSystem .
noria:Resource_FirewallDMZ noria:resourceForApplication noria:App_MonitoringSystem .

# Link more applications to services
noria:Service_InternetAccess seas:subSystemOf noria:App_MonitoringSystem . # Monitoring is part of ensuring internet access

# Link event records to trouble tickets
noria:TT_20240115_001 noria:documentStatusHistory noria:Event_DNS_Restarted . # Status change implied by restart

# Link change request to event records (e.g., for implementation logs)
noria:CR_20240120_001 noria:documentStatusHistory noria:Event_DNS_Restarted . # If restart was part of CR implementation

# Example of a resource being managed by an individual agent
noria:Resource_DNS01 noria:resourceManagedBy noria:Agent_JohnDoe .

# Example of an agent managing a resource (inverse property)
noria:Agent_JohnDoe noria:agentManagesResource noria:Resource_DNS01 .

# Example of a resource being part of a cluster (even if it's a single node, it can be managed by a cluster controller)
noria:Resource_DNS01 noria:clusterController noria:Resource_VirtualHost01 . # If DNS01 was a VM on this host

# More network interface observables
noria:NI_RouterCore01_Gi0_0_1 noria:networkInterfaceLaserTxOpticalPower 0 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

