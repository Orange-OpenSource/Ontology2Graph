    noria:loggingTime "2024-01-15T08:59:45Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to up"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:Event_DNS_Restarted a noria:EventRecord ;
