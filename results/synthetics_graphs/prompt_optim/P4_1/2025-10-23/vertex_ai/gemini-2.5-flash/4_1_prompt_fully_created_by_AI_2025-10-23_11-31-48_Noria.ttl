    noria:networkInterfaceOf <resource/AppServer01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/DBServer01-eth0> a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DBServer01."@en ;
    noria:networkInterfaceOf <resource/DBServer01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/EdgeRouterLyon-ge0-0-0> a noria:NetworkInterface ;
    rdfs:label "EdgeRouterLyon GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Interface connecting Lyon Edge Router to the local LAN."@en ;
    noria:networkInterfaceOf <resource/EdgeRouterLyon> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/EdgeRouterLyon-ge0-0-1> a noria:NetworkInterface ;
    rdfs:label "EdgeRouterLyon GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Lyon Edge Router to the WAN."@en ;
    noria:networkInterfaceOf <resource/EdgeRouterLyon> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

<networkinterface/VirtualMachineWeb01-eth0> a noria:NetworkInterface ;
    rdfs:label "WebVM01 Virtual Ethernet 0"@en ;
    rdfs:comment "Virtual network interface for Web Application VM 01."@en ;
    noria:networkInterfaceOf <resource/VirtualMachineWeb01> ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/LoadBalancer01-eth0> a noria:NetworkInterface ;
