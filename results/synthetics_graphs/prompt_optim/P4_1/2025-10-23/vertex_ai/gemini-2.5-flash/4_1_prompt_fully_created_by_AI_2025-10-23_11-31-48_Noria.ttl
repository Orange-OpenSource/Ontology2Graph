<eventrecord/Log-DNS01-CPUHigh> a noria:EventRecord ;
    rdfs:label "DNS01 CPU High Alert"@en ;
    rdfs:comment "Log entry indicating high CPU utilization on DNS01 server. This event matches the 'High CPU Load Anomaly Pattern'."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/DNS01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "CPU utilization on dns01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<eventrecord/Log-RouterCore01-InterfaceDown> a noria:EventRecord ;
    rdfs:label "RouterCore01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating that an interface on RouterCore01 went down. This event is a component of a 'Network Interface Flap Anomaly Pattern'."@en ;
