    noria:logOriginatingManagedObject <resource/RouterCore01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "Interface GigabitEthernet 0/0/1 on router-core01.corp.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<eventrecord/Log-AppServer01-DiskFull> a noria:EventRecord ;
