# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

<operationplan/RouterFirmwareUpgradeProcedure> a noria:OperationPlan ;
    rdfs:label "Standard Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading firmware on Cisco ASR 9000 series routers."@en ;
    skos:example "1. Backup configuration. 2. Upload new firmware image. 3. Reload router. 4. Verify operation."@en ;
    noria:operationPlanPreCondition <actionprecondition/RouterReadyForUpgrade> ;
    noria:operationPlanPostCondition <actionpostcondition/RouterUpgradeSuccessful> .

<operationplan/DBIndexOptimizationProcedure> a noria:OperationPlan ;
    rdfs:label "Database Index Optimization Procedure"@en ;
    rdfs:comment "Procedure for analyzing and optimizing database indexes to improve query performance."@en ;
    skos:example "1. Analyze current index usage. 2. Create new indexes/rebuild existing. 3. Monitor performance."@en ;
    noria:operationPlanPreCondition <actionprecondition/DBPerformanceIssueIdentified> ;
    noria:operationPlanPostCondition <actionpostcondition/DBPerformanceImproved> .

<operationplan/WebAppSecurityPatchProcedure> a noria:OperationPlan ;
    rdfs:label "Web Application Security Patch Deployment Procedure"@en ;
    rdfs:comment "Procedure for deploying security patches to web application virtual machines."@en ;
    skos:example "1. Isolate VM. 2. Apply patches. 3. Scan for vulnerabilities. 4. Reintegrate VM."@en ;
    noria:operationPlanPreCondition <actionprecondition/VMIsolatedForPatching> ;
    noria:operationPlanPostCondition <actionpostcondition/VMPatchedAndSecure> .

<operationplan/AutomatedLogRotationProcedure> a noria:OperationPlan ;
    rdfs:label "Automated Log Rotation Implementation Procedure"@en ;
    rdfs:comment "Procedure for configuring and verifying automated log rotation on Linux servers."@en ;
    skos:example "1. Install logrotate. 2. Configure logrotate for application logs. 3. Test configuration. 4. Verify cron job."@en ;
    noria:operationPlanPreCondition <actionprecondition/LogRotationRequired> ;
    noria:operationPlanPostCondition <actionpostcondition/LogRotationImplemented> .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

<actionprecondition/RouterReadyForUpgrade> a noria:ActionPreCondition ;
    rdfs:label "Router Ready for Upgrade"@en ;
    rdfs:comment "Condition: Router is in a maintenance window, configuration backup is complete, and new firmware image is accessible."@en .

<actionpostcondition/RouterUpgradeSuccessful> a noria:ActionPostCondition ;
    rdfs:label "Router Upgrade Successful"@en ;
    rdfs:comment "Outcome: Router is operational, all interfaces are up, and new firmware version is confirmed."@en .

<actionprecondition/DBPerformanceIssueIdentified> a noria:ActionPreCondition ;
    rdfs:label "Database Performance Issue Identified"@en ;
    rdfs:comment "Condition: Database queries are slow, CPU/IO utilization is high, and index analysis suggests optimization is needed."@en .

<actionpostcondition/DBPerformanceImproved> a noria:ActionPostCondition ;
    rdfs:label "Database Performance Improved"@en ;
    rdfs:comment "Outcome: Database query response times are reduced, CPU/IO utilization is normalized, and application performance is restored."@en .

<actionprecondition/VMIsolatedForPatching> a noria:ActionPreCondition ;
    rdfs:label "VM Isolated for Patching"@en ;
    rdfs:comment "Condition: Virtual machine is isolated from the network, and a snapshot has been taken."@en .

<actionpostcondition/VMPatchedAndSecure> a noria:ActionPostCondition ;
    rdfs:label "VM Patched and Secure"@en ;
    rdfs:comment "Outcome: Virtual machine has all security patches applied, no new vulnerabilities detected, and is ready for production."@en .

<actionprecondition/LogRotationRequired> a noria:ActionPreCondition ;
    rdfs:label "Log Rotation Required"@en ;
    rdfs:comment "Condition: Server logs are growing unchecked, leading to disk space issues."@en .

<actionpostcondition/LogRotationImplemented> a noria:ActionPostCondition ;
    rdfs:label "Log Rotation Implemented"@en ;
    rdfs:comment "Outcome: Automated log rotation is configured and active, preventing disk space exhaustion from logs."@en .

# =============================================================================
# Anomaly Patterns (noria:AnomalyPattern)
# =============================================================================

<anomalypattern/HighCPULoad> a noria:AnomalyPattern ;
    rdfs:label "High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization on a server, potentially leading to performance degradation or outage."@en ;
    skos:example "CPU > 90% for 15 minutes, followed by increased latency."@en .

<anomalypattern/NetworkInterfaceFlap> a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flap Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating frequent up/down transitions of a network interface, suggesting instability."@en ;
    skos:example "Interface status changes from up to down and back to up within 5 minutes, occurring multiple times."@en .

# =============================================================================
# Document Attachments (noria:DocumentAttachment)
# =============================================================================

<documentattachment/FiberCutReport> a noria:DocumentAttachment ;
    rdfs:label "Fiber Cut Incident Report"@en ;
    rdfs:comment "Detailed report from the external provider regarding the fiber cut incident."@en ;
    dcterms:created "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    dcterms:isPartOf <troubleticket/TT-20240420-001> ;
    dcterms:format "application/pdf" ;
    dcterms:source <https://example.com/reports/fiber_cut_report_20240420.pdf> .

