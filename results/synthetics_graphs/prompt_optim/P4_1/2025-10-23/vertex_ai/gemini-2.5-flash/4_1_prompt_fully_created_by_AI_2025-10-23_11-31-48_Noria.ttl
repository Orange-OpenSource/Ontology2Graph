    rdfs:comment "Internal facing interface for Load Balancer 01, connecting to web VMs."@en ;
    noria:networkInterfaceOf <resource/LoadBalancer01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/AccessSwitchLyon01-ge0-0-1> a noria:NetworkInterface ;
