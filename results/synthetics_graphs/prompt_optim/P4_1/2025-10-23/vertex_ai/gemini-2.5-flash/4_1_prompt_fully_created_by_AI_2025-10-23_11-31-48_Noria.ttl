# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

<site/ParisDataCenter> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "PDC01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@fr ;
    noria:sitePrincipalAddressCityName "Paris"@fr ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

<site/LyonOffice> a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office with local IT infrastructure."@en ;
    noria:siteId "LRO01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès"@fr ;
    noria:sitePrincipalAddressCityName "Lyon"@fr ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

<room/PDC01-ServerRoomA> a noria:Room ;
    rdfs:label "PDC01 Server Room A"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace <site/ParisDataCenter> .

<room/LRO01-CommsRoom> a noria:Room ;
    rdfs:label "LRO01 Communications Room"@en ;
    rdfs:comment "Network equipment room in Lyon Office."@en ;
    bot:hasSpace <site/LyonOffice> .

<locus/PDC01-RackA1-U42> a noria:Locus ;
    rdfs:label "Rack A1, Unit 42 in PDC01 Server Room A"@en ;
    rdfs:comment "Specific location for a server in the data center."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "42" ;
    bot:containsZone <room/PDC01-ServerRoomA> .

<locus/PDC01-RackB5-U10> a noria:Locus ;
    rdfs:label "Rack B5, Unit 10 in PDC01 Server Room A"@en ;
    rdfs:comment "Location for a network device."@en ;
    noria:locusLine "B5" ;
    noria:locusRow "10" ;
    bot:containsZone <room/PDC01-ServerRoomA> .

<locus/LRO01-Rack1-U1> a noria:Locus ;
    rdfs:label "Rack 1, Unit 1 in LRO01 Comms Room"@en ;
    rdfs:comment "Location for the main router in Lyon office."@en ;
    noria:locusLine "1" ;
    noria:locusRow "1" ;
    bot:containsZone <room/LRO01-CommsRoom> .

