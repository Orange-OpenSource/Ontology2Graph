# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

<networklink/PDC-Internal-LAN> a noria:NetworkLink ;
    rdfs:label "PDC Internal LAN Segment"@en ;
    rdfs:comment "Internal LAN segment connecting servers and core router in Paris DC."@en ;
    noria:networkLinkId "LAN-PDC-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2021-03-15T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource <resource/RouterCore01> ;
    noria:networkLinkTerminationResource <resource/DNS01> ;
    noria:networkLinkTerminationResource <resource/AppServer01> ;
    noria:networkLinkTerminationResource <resource/DBServer01> ;
    noria:networkInterfaceConnects <networkinterface/RouterCore01-ge0-0-0> ;
    noria:networkInterfaceConnects <networkinterface/DNS01-eth0> ;
    noria:networkInterfaceConnects <networkinterface/AppServer01-eth0> ;
    noria:networkInterfaceConnects <networkinterface/DBServer01-eth0> .

<networklink/WAN-Paris-Lyon> a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-Lyon"@en ;
    rdfs:comment "Dedicated WAN link connecting Paris Data Center to Lyon Office."@en ;
    noria:networkLinkId "WAN-PDC-LRO" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2022-10-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/RouterCore01> ;
    noria:networkLinkTerminationResourceDestination <resource/EdgeRouterLyon> ;
    noria:networkInterfaceConnects <networkinterface/RouterCore01-ge0-0-1> ;
    noria:networkInterfaceConnects <networkinterface/EdgeRouterLyon-ge0-0-1> ;
    noria:resourceManagedBy <agent/NetworkOperationsTeam> .

<networklink/Lyon-Internal-LAN> a noria:NetworkLink ;
    rdfs:label "Lyon Office Internal LAN"@en ;
    rdfs:comment "Internal LAN segment for Lyon office users and local devices."@en ;
    noria:networkLinkId "LAN-LRO-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource <resource/EdgeRouterLyon> ;
    noria:networkLinkTerminationResource <resource/AccessSwitchLyon01> ;
    noria:networkInterfaceConnects <networkinterface/EdgeRouterLyon-ge0-0-0> ;
    noria:networkInterfaceConnects <networkinterface/AccessSwitchLyon01-ge0-0-1> .

<networklink/WebTier-Internal> a noria:NetworkLink ;
    rdfs:label "Web Tier Internal Network"@en ;
    rdfs:comment "Internal network segment connecting Load Balancer to Web VMs."@en ;
    noria:networkLinkId "LAN-WEB-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-02-01T09:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource <resource/LoadBalancer01> ;
    noria:networkLinkTerminationResource <resource/VirtualMachineWeb01> ;
    noria:networkInterfaceConnects <networkinterface/LoadBalancer01-eth1> ;
    noria:networkInterfaceConnects <networkinterface/VirtualMachineWeb01-eth0> .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

<application/CorporateInternetAccess> a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "Provides internet access for all corporate users and systems."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "CIA-APP" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CIA" ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "Internet Gateway Management" ;
    noria:elementManagedBy <agent/NetworkOperationsTeam> .

<application/CustomerPortal> a noria:Application ;
    rdfs:label "Customer Self-Service Portal"@en ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "CSP-APP" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "CSP" ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Self-Service Management" ;
    noria:elementManagedBy <agent/ApplicationSupportTeam> ;
    noria:resourceForApplication <resource/AppServer01> ;
    noria:resourceForApplication <resource/DBServer01> ;
    noria:resourceForApplication <resource/VirtualMachineWeb01> .

<application/MonitoringSystem> a noria:Application ;
    rdfs:label "Central Monitoring System"@en ;
    rdfs:comment "System for collecting and analyzing metrics and logs from IT infrastructure."@en ;
    noria:applicationType <kos/application/type/service-platform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationModelIdentifier "CMS-APP" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "CMS" ;
    noria:applicationFunctionalDomain "IT Operations Management" ;
    noria:applicationFunctionalSubDomain "Performance & Fault Management" ;
    noria:elementManagedBy <agent/NetworkOperationsTeam> .

