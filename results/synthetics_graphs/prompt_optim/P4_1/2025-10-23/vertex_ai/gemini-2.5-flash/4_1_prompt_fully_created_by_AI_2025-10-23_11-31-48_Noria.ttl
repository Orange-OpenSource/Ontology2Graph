# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# KOS Concepts (Knowledge Organization System)
# =============================================================================

# Application Types
<kos/application/type> a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of applications."@en .

<kos/application/type/infrastructure> a skos:Concept ;
    skos:prefLabel "Infrastructure"@en, "Infrastructure"@fr ;
    skos:inScheme <kos/application/type> .

<kos/application/type/service-platform> a skos:Concept ;
    skos:prefLabel "Service Platform"@en, "Plateforme de Service"@fr ;
    skos:inScheme <kos/application/type> .

<kos/application/type/business-application> a skos:Concept ;
    skos:prefLabel "Business Application"@en, "Application Métier"@fr ;
    skos:inScheme <kos/application/type> .

# Application Business Importance
<kos/application/business-importance> a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A scheme for classifying the business importance of applications."@en .

<kos/application/business-importance/high> a skos:Concept ;
    skos:prefLabel "High"@en, "Élevée"@fr ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/business-importance/medium> a skos:Concept ;
    skos:prefLabel "Medium"@en, "Moyenne"@fr ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/business-importance/low> a skos:Concept ;
    skos:prefLabel "Low"@en, "Faible"@fr ;
    skos:inScheme <kos/application/business-importance> .

# Application Module Status
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational status of application modules."@en .

<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ;
    skos:prefLabel "In Production"@en, "En Production"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ;
    skos:prefLabel "In Maintenance"@en, "En Maintenance"@fr ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> .

# Resource Type
<kos/Resource/type> a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of IT resources."@en .

<kos/Resource/type/server> a skos:Concept ;
    skos:prefLabel "Server"@en, "Serveur"@fr ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/router> a skos:Concept ;
    skos:prefLabel "Router"@en, "Routeur"@fr ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/switch> a skos:Concept ;
    skos:prefLabel "Switch"@en, "Commutateur"@fr ;
    skos:inScheme <kos/Resource/type> .

<kos/Resource/type/virtual-machine> a skos:Concept ;
    skos:prefLabel "Virtual Machine"@en, "Machine Virtuelle"@fr ;
    skos:inScheme <kos/Resource/type> .

# Resource Lifecycle State
<kos/Resource/LifecycleState> a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A scheme for classifying the lifecycle state of IT resources."@en .

<kos/Resource/LifecycleState/InUse> a skos:Concept ;
    skos:prefLabel "In Use"@en, "En Service"@fr ;
    skos:inScheme <kos/Resource/LifecycleState> .

<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ;
    skos:prefLabel "Decommissioned"@en, "Hors Service"@fr ;
    skos:inScheme <kos/Resource/LifecycleState> .

# Network Interface Administrative State
<kos/Resource/AdministrativeState> a skos:ConceptScheme ;
    rdfs:label "Network Interface Administrative State Scheme"@en ;
    rdfs:comment "A scheme for classifying the administrative state of network interfaces."@en .

<kos/Resource/AdministrativeState/up> a skos:Concept ;
    skos:prefLabel "Up"@en, "Actif"@fr ;
    skos:inScheme <kos/Resource/AdministrativeState> .

<kos/Resource/AdministrativeState/down> a skos:Concept ;
    skos:prefLabel "Down"@en, "Inactif"@fr ;
    skos:inScheme <kos/Resource/AdministrativeState> .

# Network Interface Operational State
<kos/Resource/OperationalState> a skos:ConceptScheme ;
    rdfs:label "Network Interface Operational State Scheme"@en ;
    rdfs:comment "A scheme for classifying the operational state of network interfaces."@en .

<kos/Resource/OperationalState/up> a skos:Concept ;
    skos:prefLabel "Up"@en, "Opérationnel"@fr ;
    skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/OperationalState/down> a skos:Concept ;
    skos:prefLabel "Down"@en, "Non Opérationnel"@fr ;
    skos:inScheme <kos/Resource/OperationalState> .

# Trouble Ticket Severity
<kos/TroubleTicket/severity> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/severity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en, "Critique"@fr ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Major> a skos:Concept ;
    skos:prefLabel "Major"@en, "Majeure"@fr ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Minor> a skos:Concept ;
    skos:prefLabel "Minor"@en, "Mineure"@fr ;
    skos:inScheme <kos/TroubleTicket/severity> .

# Trouble Ticket Status
<kos/TroubleTicket/status> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the status of trouble tickets."@en .

<kos/TroubleTicket/status/Open> a skos:Concept ;
    skos:prefLabel "Open"@en, "Ouvert"@fr ;
    skos:inScheme <kos/TroubleTicket/status> .

<kos/TroubleTicket/status/InProgress> a skos:Concept ;
    skos:prefLabel "In Progress"@en, "En Cours"@fr ;
    skos:inScheme <kos/TroubleTicket/status> .

<kos/TroubleTicket/status/Resolved> a skos:Concept ;
    skos:prefLabel "Resolved"@en, "Résolu"@fr ;
    skos:inScheme <kos/TroubleTicket/status> .

<kos/TroubleTicket/status/Closed> a skos:Concept ;
    skos:prefLabel "Closed"@en, "Fermé"@fr ;
    skos:inScheme <kos/TroubleTicket/status> .

# Trouble Ticket Origin
<kos/TroubleTicket/origin> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/origin/Customer> a skos:Concept ;
    skos:prefLabel "Customer"@en, "Client"@fr ;
    skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/origin/Supervision> a skos:Concept ;
    skos:prefLabel "Supervision System"@en, "Système de Supervision"@fr ;
    skos:inScheme <kos/TroubleTicket/origin> .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the category of trouble tickets."@en .

<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ;
    skos:prefLabel "Network Outage"@en, "Panne Réseau"@fr ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/trouble-category/ApplicationFailure> a skos:Concept ;
    skos:prefLabel "Application Failure"@en, "Défaillance Applicative"@fr ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

# Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Problem Responsibility Scheme"@en ;
    rdfs:comment "A scheme for classifying the responsibility for a problem."@en .

<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ;
    skos:prefLabel "Network Team"@en, "Équipe Réseau"@fr ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ;
    skos:prefLabel "Application Team"@en, "Équipe Applicative"@fr ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A scheme for classifying the urgency of trouble tickets."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:prefLabel "Immediate Intervention"@en, "Intervention Immédiate"@fr ;
    skos:inScheme <kos/TroubleTicket/urgency> .

<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ;
    skos:prefLabel "Deferred Intervention"@en, "Intervention Différée"@fr ;
    skos:inScheme <kos/TroubleTicket/urgency> .

# Trouble Ticket Type
<kos/TroubleTicket/type> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of trouble tickets."@en .

<kos/TroubleTicket/type/Failure> a skos:Concept ;
    skos:prefLabel "Failure"@en, "Panne"@fr ;
    skos:inScheme <kos/TroubleTicket/type> .

<kos/TroubleTicket/type/Assistance> a skos:Concept ;
    skos:prefLabel "Assistance"@en, "Assistance"@fr ;
    skos:inScheme <kos/TroubleTicket/type> .

# Trouble Ticket Comment Type
<kos/TroubleTicket/commentType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Comment Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of comments in trouble tickets."@en .

<kos/TroubleTicket/commentType/Internal> a skos:Concept ;
    skos:prefLabel "Internal"@en, "Interne"@fr ;
    skos:inScheme <kos/TroubleTicket/commentType> .

<kos/TroubleTicket/commentType/Customer> a skos:Concept ;
    skos:prefLabel "Customer"@en, "Client"@fr ;
    skos:inScheme <kos/TroubleTicket/commentType> .

# Trouble Ticket Operation Type
<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Operation Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of operations recorded in trouble ticket notes."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:prefLabel "Diagnosis"@en, "Diagnostic"@fr ;
    skos:inScheme <kos/TroubleTicket/operationType> .

<kos/TroubleTicket/operationType/Restoration> a skos:Concept ;
    skos:prefLabel "Restoration"@en, "Restauration"@fr ;
    skos:inScheme <kos/TroubleTicket/operationType> .

# Change Request Category
<kos/ChangeRequest/category> a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A scheme for classifying the category of change requests."@en .

<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ;
    skos:prefLabel "Internal Intervention"@en, "Intervention Interne"@fr ;
    skos:inScheme <kos/ChangeRequest/category> .

<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ;
    skos:prefLabel "Software Upgrade"@en, "Mise à Jour Logicielle"@fr ;
    skos:inScheme <kos/ChangeRequest/category> .

# Change Request Type
<kos/ChangeRequest/type> a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A scheme for classifying the type of change requests."@en .

<kos/ChangeRequest/type/Standard> a skos:Concept ;
    skos:prefLabel "Standard Change"@en, "Changement Standard"@fr ;
    skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/type/Emergency> a skos:Concept ;
    skos:prefLabel "Emergency Change"@en, "Changement d'Urgence"@fr ;
    skos:inScheme <kos/ChangeRequest/type> .

# Change Request Cause
<kos/ChangeRequest/cause> a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A scheme for classifying the cause of change requests."@en .

<kos/ChangeRequest/cause/Configuration> a skos:Concept ;
    skos:prefLabel "Configuration Change"@en, "Changement de Configuration"@fr ;
    skos:inScheme <kos/ChangeRequest/cause> .

<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ;
    skos:prefLabel "Preventative Maintenance"@en, "Maintenance Préventive"@fr ;
    skos:inScheme <kos/ChangeRequest/cause> .

# Change Request Status
<kos/ChangeRequest/status> a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A scheme for classifying the status of change requests."@en .

<kos/ChangeRequest/status/Approved> a skos:Concept ;
    skos:prefLabel "Approved"@en, "Approuvé"@fr ;
    skos:inScheme <kos/ChangeRequest/status> .

<kos/ChangeRequest/status/Scheduled> a skos:Concept ;
    skos:prefLabel "Scheduled"@en, "Planifié"@fr ;
    skos:inScheme <kos/ChangeRequest/status> .

<kos/ChangeRequest/status/Implemented> a skos:Concept ;
    skos:prefLabel "Implemented"@en, "Implémenté"@fr ;
    skos:inScheme <kos/ChangeRequest/status> .

# Change Request Specification
<kos/ChangeRequest/specification> a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    rdfs:comment "A scheme for classifying the specification of change requests."@en .

<kos/ChangeRequest/specification/RouterFirmwareUpdate> a skos:Concept ;
    skos:prefLabel "Router Firmware Update"@en, "Mise à Jour Firmware Routeur"@fr ;
    skos:inScheme <kos/ChangeRequest/specification> .

# Notification Severity
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ;
    rdfs:label "Perceived Severity Scheme"@en ;
    rdfs:comment "A scheme for classifying the perceived severity of notifications."@en .

<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ;
    skos:prefLabel "Critical"@en, "Critique"@fr ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ;
    skos:prefLabel "Major"@en, "Majeure"@fr ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ;
    skos:prefLabel "Warning"@en, "Avertissement"@fr ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Agent Contact Method
<kos/org/agent-contact-method> a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en .

<kos/org/agent-contact-method/Email> a skos:Concept ;
    skos:prefLabel "Email"@en, "Courriel"@fr ;
    skos:inScheme <kos/org/agent-contact-method> .

<kos/org/agent-contact-method/Phone> a skos:Concept ;
    skos:prefLabel "Phone"@en, "Téléphone"@fr ;
    skos:inScheme <kos/org/agent-contact-method> .

# Service Type
<kos/service/type> a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A scheme for classifying types of services."@en .

<kos/service/type/CustomerFacingService> a skos:Concept ;
    skos:prefLabel "Customer Facing Service"@en, "Service Client"@fr ;
    skos:inScheme <kos/service/type> .

<kos/service/type/ResourceFacingService> a skos:Concept ;
    skos:prefLabel "Resource Facing Service"@en, "Service Ressource"@fr ;
    skos:inScheme <kos/service/type> .

# Application SLA Level
<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "A scheme for classifying SLA levels for applications."@en .

<https://w3id.org/noria/kos/application/sla-level/Platinum> a skos:Concept ;
    skos:prefLabel "Platinum"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ;
    skos:prefLabel "Gold"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person)
# =============================================================================

# Organizational Units (Teams)
<agent/NetworkOperationsTeam> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the core network infrastructure."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use emergency hotline after hours."@en .

<agent/ApplicationSupportTeam> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2/L3 support for business applications."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Open a ticket via the ITSM portal first."@en .

<agent/SecurityOperationsCenter> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 Operations"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Report all security events immediately."@en .

<agent/DatabaseAdminTeam> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "8:30 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<agent/CloudInfrastructureTeam> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cloud Infrastructure Team"@en ;
    rdfs:comment "Team responsible for cloud platform management and operations."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

# Individuals (Persons)
<agent/JohnDoe> a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+33123456789" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<agent/JaneSmith> a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+33987654321" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<agent/AliceJohnson> a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "IT Service Manager."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    foaf:phone "+33611223344" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<agent/ExternalProviderTech> a foaf:Person, foaf:Agent ;
    rdfs:label "External Provider Technician"@en ;
    rdfs:comment "Technician from the external fiber optic provider."@en ;
    foaf:mbox <mailto:tech@external.com> .

# Corporate User Identifiers
<cuid/JohnDoeCUID> a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe" ;
    observable:accountIdentifier "jdoe@example.com" ;
    foaf:holdsAccount <agent/JohnDoe> .

<agent/JohnDoe> foaf:holdsAccount <cuid/JohnDoeCUID> .

<cuid/JaneSmithCUID> a noria:CorporateUserIdentifier ;
