    noria:networkLinkType "ethernet" ;
    noria:resourceManagedBy noria:OrgUnit_AppDevTeam ;
    noria:NI_AppSrv01_Eth0 noria:networkInterfaceConnects noria:NL_AppSrv01_Network .

noria:NL_DBSrv01_Network a noria:NetworkLink ;
    rdfs:label "Database Server 01 Network Link"@en ;
