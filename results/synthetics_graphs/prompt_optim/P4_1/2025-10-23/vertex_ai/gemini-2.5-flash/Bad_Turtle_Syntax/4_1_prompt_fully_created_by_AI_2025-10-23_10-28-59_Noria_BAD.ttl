# --- Event Records (noria:EventRecord) ---
noria:ER_CR01_Down a noria:EventRecord ;
    rdfs:label "CR01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    dcterms:identifier "ER-CR01-20240423-001" ;
    noria:loggingTime "2024-04-23T08:54:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "Interface ge-0/0/0 on cr01.corp.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:troubleTicketTrigger noria:TT_CR01_Outage .

noria:ER_CR01_Up a noria:EventRecord ;
    rdfs:label "CR01 Interface Up Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 came back up after repair."@en ;
    dcterms:identifier "ER-CR01-20240423-002" ;
    noria:loggingTime "2024-04-23T10:40:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logText "Interface ge-0/0/0 on cr01.corp.example.com changed state to up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmMitigatedBy noria:TT_CR01_Outage . # Linking the resolution to the TT

noria:ER_DB_HighCPU a noria:EventRecord ;
