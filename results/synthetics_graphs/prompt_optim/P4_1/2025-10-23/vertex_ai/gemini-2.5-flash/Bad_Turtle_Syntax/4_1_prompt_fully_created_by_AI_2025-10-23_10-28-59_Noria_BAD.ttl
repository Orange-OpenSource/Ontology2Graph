# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person) ---
# Organizational Units (Teams)
noria:OrgUnit_NetOpsTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Contact via dedicated incident management hotline for critical issues."@en .

noria:OrgUnit_AppDevTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

noria:OrgUnit_SecurityTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-chat> .

noria:OrgUnit_DBATeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "8:30-17:30 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> .

noria:OrgUnit_HelpDeskL1 a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Help Desk Level 1"@en ;
    rdfs:comment "First line support for all IT-related issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

# Persons
noria:Person_AliceSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

noria:Person_BobJohnson a foaf:Person, foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en .

noria:Person_CharlieBrown a foaf:Person, foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    noria:agentWorkingHours "24/7 On-Call"@en .

noria:Person_DianaPrince a foaf:Person, foaf:Agent ;
    rdfs:label "Diana Prince"@en ;
    rdfs:comment "Database Administrator."@en ;
    foaf:mbox <mailto:diana.prince@example.com> ;
    noria:agentWorkingHours "8:30-17:30 (Mon-Fri)"@en .

# --- Product Models (noria:ProductModel) ---
noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch series."@en ;
    noria:productManufacturedBy noria:Org_CiscoSystems .

noria:ProductModel_DellPowerEdgeR750 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "Versatile 2-socket/2U rack server."@en ;
    noria:productManufacturedBy noria:Org_DellTechnologies .

noria:ProductModel_PaloAltoFirewallPA500 a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-500 Series"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy noria:Org_PaloAltoNetworks .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor for virtualized environments."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:Org_CiscoSystems a org:Organization, foaf:Agent ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Multinational technology conglomerate that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

noria:Org_DellTechnologies a org:Organization, foaf:Agent ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "American multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:Org_PaloAltoNetworks a org:Organization, foaf:Agent ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "American multinational cybersecurity company."@en .

noria:Org_VMware a org:Organization, foaf:Agent ;
    rdfs:label "VMware"@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
noria:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC-M01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Site_DRSite a bot:Site ;
    rdfs:label "Disaster Recovery Site"@en ;
    rdfs:comment "Secondary data center for business continuity and disaster recovery."@en ;
    noria:siteId "DC-DR01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "456 Backup Road"@en ;
    noria:sitePrincipalAddressCityName "Gotham City"@en ;
    noria:sitePrincipalAddressPostalCode "20002"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Main Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    bot:hasBuilding noria:Site_MainDC .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Room dedicated to network equipment in Main Data Center."@en ;
    bot:hasSpace noria:Locus_RackB1 ;
    bot:hasBuilding noria:Site_MainDC .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en .

noria:Locus_RackB1 a noria:Locus ;
    rdfs:label "Rack B1"@en ;
    rdfs:comment "First rack in Network Room B."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "1"@en .

