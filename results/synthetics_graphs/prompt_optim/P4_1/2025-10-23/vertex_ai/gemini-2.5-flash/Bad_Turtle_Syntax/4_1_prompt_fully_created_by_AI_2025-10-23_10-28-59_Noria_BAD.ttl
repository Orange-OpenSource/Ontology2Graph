    rdfs:comment "Monitoring alert: Database Server 01 CPU utilization exceeded 90%."@en ;
    dcterms:identifier "ER-DB01-20240423-001" ;
    noria:loggingTime "2024-04-23T11:25:00Z"^^xsd:dateTime ;
