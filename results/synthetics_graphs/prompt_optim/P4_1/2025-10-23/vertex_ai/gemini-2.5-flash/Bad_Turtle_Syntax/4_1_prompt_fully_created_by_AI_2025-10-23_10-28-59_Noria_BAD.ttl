# --- Operation Plans (noria:OperationPlan) ---
noria:OP_Router_PSU_Replacement a noria:OperationPlan ;
    rdfs:label "Router Power Supply Unit Replacement Procedure"@en ;
    rdfs:comment "Standard operating procedure for replacing a faulty power supply unit in a Cisco Nexus 9000 series router."@en ;
    skos:example "Steps include: verify redundancy, power down faulty PSU, replace unit, power up, verify operation."@en ;
    noria:operationPlanPreCondition noria:APC_VerifyRedundancy ;
    noria:operationPlanPostCondition noria:APOC_PSUOperational .

noria:OP_DB_Performance_Troubleshoot a noria:OperationPlan ;
    rdfs:label "Database Performance Troubleshooting Guide"@en ;
    rdfs:comment "Procedure for diagnosing and resolving database performance issues."@en ;
    skos:example "Steps include: check CPU/memory, analyze query logs, review index usage, check disk I/O."@en ;
    noria:operationPlanPreCondition noria:APC_HighCPUorSlowQueries ;
    noria:operationPlanPostCondition noria:APOC_PerfRestored .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:APC_VerifyRedundancy a noria:ActionPreCondition ;
    rdfs:label "Verify Router Redundancy"@en ;
    rdfs:comment "Pre-condition: Ensure the redundant router is fully operational and carrying traffic before proceeding with maintenance on the primary unit."@en .

noria:APOC_PSUOperational a noria:ActionPostCondition ;
    rdfs:label "Power Supply Unit Operational"@en ;
    rdfs:comment "Post-condition: New PSU is installed, powered on, and reporting healthy status. Router is fully operational."@en .

noria:APC_HighCPUorSlowQueries a noria:ActionPreCondition ;
    rdfs:label "High CPU or Slow Queries Detected"@en ;
    rdfs:comment "Pre-condition: Database server CPU utilization is consistently high, or specific queries are executing slowly."@en .

noria:APOC_PerfRestored a noria:ActionPostCondition ;
    rdfs:label "Database Performance Restored"@en ;
    rdfs:comment "Post-condition: Database server CPU utilization is within normal limits, and query response times are acceptable."@en .

