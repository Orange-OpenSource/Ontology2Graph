# --- Network Links (noria:NetworkLink) ---
noria:NL_CR01_CR02_Link a noria:NetworkLink ;
    rdfs:label "Core Router Interconnect Link"@en ;
    rdfs:comment "High-speed link between Core Router 01 and Core Router 02."@en ;
    noria:networkLinkId "NL-CR01-CR02-01" ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter01, noria:Resource_CoreRouter02 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter02 ;
    noria:networkLinkInstallationDate "2021-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "fiber-optic" ;
    noria:resourceManagedBy noria:OrgUnit_NetOpsTeam ;
    noria:NI_CR01_Eth0_1 noria:networkInterfaceConnects noria:NL_CR01_CR02_Link ;
    noria:NI_CR02_Eth0_1 noria:networkInterfaceConnects noria:NL_CR01_CR02_Link .

noria:NL_FW01_Internal a noria:NetworkLink ;
    rdfs:label "Firewall Internal Link"@en ;
    rdfs:comment "Link from Firewall 01 to internal network switch."@en ;
    noria:networkLinkId "NL-FW01-INT-01" ;
    noria:networkLinkTerminationResource noria:Resource_Firewall01 ;
    noria:networkLinkInstallationDate "2021-05-10T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "ethernet" ;
    noria:resourceManagedBy noria:OrgUnit_SecurityTeam ;
    noria:NI_FW01_Int noria:networkInterfaceConnects noria:NL_FW01_Internal .

noria:NL_AppSrv01_Network a noria:NetworkLink ;
