noria:ER_FW_ScanAttempt a noria:EventRecord ;
    rdfs:label "Firewall Scan Attempt Alert"@en ;
    rdfs:comment "SIEM alert: Multiple port scan attempts detected on Firewall 01 external interface."@en ;
    dcterms:identifier "ER-FW01-20240423-001" ;
