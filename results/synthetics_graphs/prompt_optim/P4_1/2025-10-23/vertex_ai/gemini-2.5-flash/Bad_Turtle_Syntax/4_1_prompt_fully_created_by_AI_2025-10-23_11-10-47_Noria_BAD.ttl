# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

<http://example.com/site/datacenter-paris> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary corporate data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" .

<http://example.com/site/office-london> a bot:Site ;
    rdfs:label "London Office Building"@en ;
    rdfs:comment "Main office building in London."@en ;
    noria:siteId "OFF-LDN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Park Lane" ;
    noria:sitePrincipalAddressPostalCode "W1K 1PN" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressCountry "UK" .

noria:Room_DC_PAR_ServerRoom_A a noria:Room ;
    rdfs:label "Server Room A - Paris DC"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack_A1, noria:Locus_Rack_A2 ;
    seas:subSystemOf <http://example.com/site/datacenter-paris> .

noria:Room_LDN_CommsRoom_1 a noria:Room ;
    rdfs:label "Comms Room 1 - London Office"@en ;
    rdfs:comment "Communication equipment room in the London office."@en ;
    bot:hasSpace noria:Locus_Rack_C1 ;
    seas:subSystemOf <http://example.com/site/office-london> .

noria:Locus_Rack_A1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasZone noria:Room_DC_PAR_ServerRoom_A .

noria:Locus_Rack_A2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasZone noria:Room_DC_PAR_ServerRoom_A .

noria:Locus_Rack_C1 a noria:Locus ;
    rdfs:label "Rack C1"@en ;
    rdfs:comment "First rack in Comms Room 1."@en ;
    noria:locusLine "C" ;
    noria:locusRow "1" ;
    bot:hasZone noria:Room_LDN_CommsRoom_1 .

