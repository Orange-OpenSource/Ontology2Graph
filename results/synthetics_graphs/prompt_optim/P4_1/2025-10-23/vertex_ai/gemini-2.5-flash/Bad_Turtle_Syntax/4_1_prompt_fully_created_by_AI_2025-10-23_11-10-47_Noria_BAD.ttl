# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition_BackupConfig a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup Completed"@en ;
    rdfs:comment "Ensure a full configuration backup of the device is completed and verified."@en .

noria:ActionPostCondition_VerifyConnectivity a noria:ActionPostCondition ;
    rdfs:label "Verify Network Connectivity"@en ;
    rdfs:comment "Confirm all critical network interfaces are up and routing protocols are converged."@en .

noria:ActionPreCondition_DBBackup a noria:ActionPreCondition ;
    rdfs:label "Database Backup Completed"@en ;
    rdfs:comment "Ensure a full backup of the database is completed and verified before patching."@en .

noria:ActionPostCondition_VerifyDBService a noria:ActionPostCondition ;
    rdfs:label "Verify Database Service Availability"@en ;
    rdfs:comment "Confirm database service is running, accessible, and performing optimally after patching."@en .

# =============================================================================
# Document Attachments (noria:DocumentAttachment)
# =============================================================================

noria:DocumentAttachment_TT001_Diagram a noria:DocumentAttachment ;
    rdfs:label "WAN Link Diagram for TT001"@en ;
    rdfs:comment "Network diagram showing the affected WAN link for Trouble Ticket TT001."@en ;
    dcterms:identifier "WAN-DIAG-TT001" ;
    dcterms:format "image/png" ;
    dcterms:isPartOf noria:TroubleTicket_TT001 .

noria:DocumentAttachment_CR001_Plan a noria:DocumentAttachment ;
    rdfs:label "Firmware Upgrade Plan for CR001"@en ;
    rdfs:comment "Detailed plan for the router firmware upgrade associated with Change Request CR001."@en ;
    dcterms:identifier "FW-UPGRADE-PLAN-CR001" ;
    dcterms:format "application/pdf" ;
    dcterms:isPartOf noria:ChangeRequest_CR001 .
