# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_CR_PAR01_GE0_0_0 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/0 on cr-par01"@en ;
    rdfs:comment "Interface connecting cr-par01 to the internal network."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter_PAR01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceDescription "Internal LAN connection" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_Internal_DC_PAR .

noria:NetworkInterface_CR_PAR01_GE0_0_1 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/1 on cr-par01"@en ;
    rdfs:comment "Interface connecting cr-par01 to the WAN."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter_PAR01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceDescription "WAN Link to London" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceConnects noria:NetworkLink_WAN_PAR_LDN .

noria:NetworkInterface_WEBAPP_VM01_ETH0 a noria:NetworkInterface ;
    rdfs:label "eth0 on webapp-vm01"@en ;
    rdfs:comment "Primary network interface for webapp-vm01."@en ;
    noria:networkInterfaceOf noria:Resource_VirtualMachine_WEBAPP_VM01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceDescription "VM Network Adapter" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NetworkLink_Internal_DC_PAR .

noria:NetworkInterface_ER_LDN01_GE0_0_0 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/0 on er-ldn01"@en ;
    rdfs:comment "Interface connecting er-ldn01 to the WAN."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouter_LDN01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceDescription "WAN Link to Paris" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceConnects noria:NetworkLink_WAN_PAR_LDN .

noria:NetworkInterface_FW_DMZ01_ETH1 a noria:NetworkInterface ;
    rdfs:label "eth1 on fw-dmz01"@en ;
    rdfs:comment "Interface connecting fw-dmz01 to the internal network."@en ;
    noria:networkInterfaceOf noria:Resource_Firewall_DMZ01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceDescription "Internal Network Interface" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_WAN_PAR_LDN a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-London"@en ;
    rdfs:comment "Dedicated WAN link between Paris Data Center and London Office."@en ;
    noria:resourceManagedBy foaf:Agent_Network_Team ;
    noria:networkLinkId "WAN-LINK-001" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2020-01-10T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter_PAR01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeRouter_LDN01 .

noria:NetworkLink_Internal_DC_PAR a noria:NetworkLink ;
    rdfs:label "Internal DC Paris Link"@en ;
    rdfs:comment "Internal network link within Paris Data Center."@en ;
    noria:resourceManagedBy foaf:Agent_Network_Team ;
