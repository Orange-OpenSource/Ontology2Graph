# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

foaf:Agent_IT_Ops_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Central team responsible for day-to-day IT infrastructure operations."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline and ticketing system."@en .

foaf:Agent_Network_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team managing network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via internal ticketing system for non-urgent requests."@en .

foaf:Agent_App_Support_L2 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support for business applications."@en ;
    noria:agentWorkingHours "8:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Escalate from L1 support or create a new ticket for direct issues."@en .

foaf:Agent_Security_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlerts> ;
    noria:agentInstructions "Automated alerts are preferred, direct contact for confirmed breaches."@en .

foaf:Agent_DB_Admin_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use the 'DB Request' portal for new requests or issues."@en .

foaf:Agent_Cloud_Ops_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Team managing cloud infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ChatOps> ;
    noria:agentInstructions "Prefer communication via ChatOps channels for immediate issues."@en .

foaf:Agent_John_Doe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_Jane_Smith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_Alice_Johnson a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "IT Security Analyst."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_Bob_Williams a foaf:Agent ;
    rdfs:label "Bob Williams"@en ;
    rdfs:comment "Database Administrator."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_Customer_Support a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Support Center"@en ;
    rdfs:comment "First line of contact for external customers."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Direct customer calls and emails."@en .

foaf:Agent_External_Vendor a foaf:Agent, org:Organization ;
    rdfs:label "External Cloud Provider Inc."@en ;
    rdfs:comment "Third-party vendor providing cloud infrastructure services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/API> ;
    noria:agentInstructions "Automated incident reporting via API, manual escalation for critical outages."@en .

