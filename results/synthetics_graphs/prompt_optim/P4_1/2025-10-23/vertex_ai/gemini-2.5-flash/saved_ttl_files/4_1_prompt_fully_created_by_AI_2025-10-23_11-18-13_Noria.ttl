# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizations
noria:Org_ITDepartment a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main Information Technology department responsible for all IT operations."@en ;
    org:hasUnit noria:OrgUnit_NetOps , noria:OrgUnit_AppSupport , noria:OrgUnit_SecurityOps .

noria:OrgUnit_NetOps a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Unit responsible for managing and maintaining the network infrastructure."@en ;
    org:unitOf noria:Org_ITDepartment .

noria:OrgUnit_AppSupport a org:OrganizationalUnit ;
    rdfs:label "Application Support Unit"@en ;
    rdfs:comment "Unit providing support for business applications."@en ;
    org:unitOf noria:Org_ITDepartment .

noria:OrgUnit_SecurityOps a org:OrganizationalUnit ;
    rdfs:label "Security Operations Unit"@en ;
    rdfs:comment "Unit responsible for cybersecurity monitoring and incident response."@en ;
    org:unitOf noria:Org_ITDepartment .

noria:OrgUnit_DBA a org:OrganizationalUnit ;
    rdfs:label "Database Administration Unit"@en ;
    rdfs:comment "Unit responsible for managing and maintaining database systems."@en ;
    org:unitOf noria:Org_ITDepartment .

noria:OrgUnit_CloudOps a org:OrganizationalUnit ;
    rdfs:label "Cloud Operations Unit"@en ;
    rdfs:comment "Unit responsible for managing cloud infrastructure and services."@en ;
    org:unitOf noria:Org_ITDepartment .

# Agents (Teams and Individuals)
noria:Agent_NetOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for non-urgent issues, hotline for critical network outages."@en ;
    org:memberOf noria:OrgUnit_NetOps .

noria:Agent_AppSupportL2 a foaf:Agent ;
    rdfs:label "Application Support L2 Team"@en ;
    rdfs:comment "Second-level support team for critical business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Escalate via internal ticketing system, call hotline for P1 incidents."@en ;
    org:memberOf noria:OrgUnit_AppSupport .

noria:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Team handling security incidents and monitoring."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/pager> ;
    noria:agentInstructions "All security alerts are automatically routed to this team. For manual reports, use dedicated security portal."@en ;
    org:memberOf noria:OrgUnit_SecurityOps .

noria:Agent_DBATeam a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all database systems."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Submit requests via the database service portal."@en ;
    org:memberOf noria:OrgUnit_DBA .

noria:Agent_CloudOpsTeam a foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Team managing cloud infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Use internal chat for urgent cloud infrastructure issues."@en ;
    org:memberOf noria:OrgUnit_CloudOps .

noria:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual network engineer."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    org:memberOf noria:OrgUnit_NetOps .

noria:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual application support specialist."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    org:memberOf noria:OrgUnit_AppSupport .

noria:Agent_AutomatedSystem a foaf:Agent ;
    rdfs:label "Automated Monitoring System"@en ;
    rdfs:comment "Automated system for monitoring and alerting."@en ;
    noria:agentInstructions "System generates alerts automatically. No direct contact."@en .

noria:Agent_CustomerService a foaf:Agent ;
    rdfs:label "Customer Service Department"@en ;
    rdfs:comment "First point of contact for customer inquiries and issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for John Doe."@en ;
    foaf:accountName "jdoe" ;
    observable:accountIdentifier "jdoe_corp_id_123" ;
    foaf:holdsAccount noria:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate User ID for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    observable:accountIdentifier "jsmith_corp_id_456" ;
    foaf:holdsAccount noria:Agent_JaneSmith .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModel_Cisco9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch model."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_DellR750 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R750"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_PaloAlto5220 a noria:ProductModel ;
    rdfs:label "Palo Alto PA-5220"@en ;
    rdfs:comment "Next-generation firewall appliance model."@en ;
    noria:productManufacturedBy noria:Org_PaloAlto .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:ProductModel_JuniperMX480 a noria:ProductModel ;
    rdfs:label "Juniper MX480"@en ;
    rdfs:comment "High-performance edge router model."@en ;
    noria:productManufacturedBy noria:Org_Juniper .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

noria:Org_PaloAlto a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "Manufacturer of cybersecurity solutions."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

noria:Org_Juniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking products."@en .

# =============================================================================
# Locations
# =============================================================================

# Sites
noria:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:comment "Primary data center facility."@en ;
    noria:siteId "DC01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "USA"@en ;
    wgs84_pos:lat "34.0522"^^xsd:float ;
    wgs84_pos:long "-118.2437"^^xsd:float .

noria:Site_RegionalOfficeA a bot:Site ;
    rdfs:label "Regional Office A"@en ;
    rdfs:comment "Regional office building."@en ;
    noria:siteId "ROA01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddress "456 Business Park Road"@en ;
    noria:sitePrincipalAddressCityName "Gotham City"@en ;
    noria:sitePrincipalAddressPostalCode "20002"@en ;
    noria:sitePrincipalAddressCountry "USA"@en ;
    wgs84_pos:lat "40.7128"^^xsd:float ;
    wgs84_pos:long "-74.0060"^^xsd:float .

# Rooms
noria:Room_ServerRoom1 a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "Main server room within the data center."@en ;
    bot:hasSpace noria:Locus_RackA1 , noria:Locus_RackB2 ;
    bot:hasBuilding noria:Site_MainDC .

noria:Room_NetworkCloset3 a noria:Room ;
    rdfs:label "Network Closet 3"@en ;
    rdfs:comment "Network equipment closet in Regional Office A."@en ;
    bot:hasSpace noria:Locus_WallMount1 ;
    bot:hasBuilding noria:Site_RegionalOfficeA .

# Loci
noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of equipment in Rack A1, Server Room 1."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasZone noria:Room_ServerRoom1 .

noria:Locus_RackB2 a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:comment "Location of equipment in Rack B2, Server Room 1."@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" ;
    bot:hasZone noria:Room_ServerRoom1 .

noria:Locus_WallMount1 a noria:Locus ;
    rdfs:label "Wall Mount 1"@en ;
    rdfs:comment "Wall-mounted equipment location in Network Closet 3."@en ;
    noria:locusLine "WM" ;
    noria:locusRow "1" ;
    bot:hasZone noria:Room_NetworkCloset3 .

# =============================================================================
# Resources
# =============================================================================

noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router in the data center."@en ;
    noria:resourceManagedBy noria:Agent_NetOpsTeam ;
    noria:resourceHostName "cr01.dc01.example.com" ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "JPRMX480-SN12345" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Server hosting the customer portal application."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportL2 ;
    noria:resourceHostName "web01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR750 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "DELLR750-SN67890" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:locatedAtLocus noria:Locus_RackB2 ;
    noria:resourceManagementIPAddress "10.0.1.10" .

noria:Resource_FirewallA a noria:Resource ;
    rdfs:label "Perimeter Firewall A"@en ;
    rdfs:comment "Main firewall protecting the data center perimeter."@en ;
    noria:resourceManagedBy noria:Agent_SecurityTeam ;
    noria:resourceHostName "fw01.dc01.example.com" ;
    noria:resourceProductModel noria:ProductModel_PaloAlto5220 ;
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceSerialNumber "PA5220-SN11223" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-06-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.254" .

noria:Resource_DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Server hosting the main application database."@en ;
    noria:resourceManagedBy noria:Agent_DBATeam ;
    noria:resourceHostName "db01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR750 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "DELLR750-SN12121" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:locatedAtLocus noria:Locus_RackB2 ;
    noria:resourceManagementIPAddress "10.0.1.11" .

noria:Resource_EdgeSwitch01 a noria:Resource ;
    rdfs:label "Edge Switch 01"@en ;
    rdfs:comment "Access switch in Regional Office A."@en ;
    noria:resourceManagedBy noria:Agent_NetOpsTeam ;
    noria:resourceHostName "esw01.roa01.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco9300 ;
    noria:resourceType <kos/Resource/type/switch> ;
    noria:resourceSerialNumber "CSCO9300-SN33445" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-09-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_WallMount1 ;
    noria:resourceManagementIPAddress "192.168.1.1" .

noria:Resource_VirtualLoadBalancer a noria:Resource ;
    rdfs:label "Virtual Load Balancer"@en ;
    rdfs:comment "Virtual appliance for load balancing web traffic."@en ;
    noria:resourceManagedBy noria:Agent_CloudOpsTeam ;
    noria:resourceHostName "vlb01.cloud.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # Assuming it runs on ESXi
    noria:resourceType <kos/Resource/type/virtual-appliance> ;
    noria:resourceSerialNumber "VLB-VM-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CustomerPortal ;
    noria:resourceManagementIPAddress "10.0.1.5" .

noria:Resource_MonitoringServer a noria:Resource ;
    rdfs:label "Monitoring Server"@en ;
    rdfs:comment "Server hosting the central monitoring platform."@en ;
    noria:resourceManagedBy noria:Agent_AutomatedSystem ; # Managed by the system itself
    noria:resourceHostName "mon01.infra.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR750 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "DELLR750-SN98765" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_MonitoringPlatform ;
    noria:locatedAtLocus noria:Locus_RackB2 ;
    noria:resourceManagementIPAddress "10.0.0.50" .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NI_CR01_GE0_0_0 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/0 on Core Router 01, connected to Firewall A."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NI_FW01_GE0_0_0 a noria:NetworkInterface ;
    rdfs:label "ge-0/0/0"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/0 on Firewall A, connected to Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallA ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -4 .

noria:NI_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Ethernet interface 0 on Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_DBServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Ethernet interface 0 on Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_ESW01_GE0_0_1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface 0/0/1 on Edge Switch 01, uplink to WAN."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeSwitch01 ;
    noria:networkInterfaceType <kos/NetworkInterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NI_VLB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "eth0"@en ;
    rdfs:comment "Virtual Ethernet interface 0 on Virtual Load Balancer."@en ;
    noria:networkInterfaceOf noria:Resource_VirtualLoadBalancer ;
    noria:networkInterfaceType <kos/NetworkInterface/type/virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links
# =============================================================================

noria:NL_CR01_FW01_Uplink a noria:NetworkLink ;
    rdfs:label "DC Core-Firewall Uplink"@en ;
    rdfs:comment "High-speed link between Core Router 01 and Firewall A."@en ;
    noria:networkLinkId "NL-DC-CR01-FW01-001" ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter01 , noria:Resource_FirewallA ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_FirewallA ;
    noria:networkInterfaceConnects noria:NI_CR01_GE0_0_0 , noria:NI_FW01_GE0_0_0 ;
    noria:networkLinkInstallationDate "2021-06-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "fiber optic"@en ;
    noria:resourceManagedBy noria:Agent_NetOpsTeam .

noria:NL_WebSrv01_DBServer01_Link a noria:NetworkLink ;
    rdfs:label "Web-DB Server Link"@en ;
    rdfs:comment "Internal network link between Web Server 01 and Database Server 01."@en ;
    noria:networkLinkId "NL-APP-WEBDB-001" ;
    noria:networkLinkTerminationResource noria:Resource_WebSrv01 , noria:Resource_DBServer01 ;
    noria:networkInterfaceConnects noria:NI_WebSrv01_Eth0 , noria:NI_DBServer01_Eth0 ;
    noria:networkLinkInstallationDate "2022-02-10T11:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "ethernet"@en ;
    noria:resourceManagedBy noria:Agent_AppSupportL2 .

noria:NL_ROA_WAN_Uplink a noria:NetworkLink ;
    rdfs:label "Regional Office A WAN Uplink"@en ;
    rdfs:comment "WAN connection from Regional Office A to the corporate network."@en ;
    noria:networkLinkId "NL-ROA-WAN-001" ;
    noria:networkLinkTerminationResource noria:Resource_EdgeSwitch01 , noria:Resource_CoreRouter01 ; # Simplified, assuming direct link to core
    noria:networkInterfaceConnects noria:NI_ESW01_GE0_0_1 ;
