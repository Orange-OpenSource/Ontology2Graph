# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OpPlan_RestartWebServer a noria:OperationPlan ;
    rdfs:label "Standard Web Server Restart Procedure"@en ;
    rdfs:comment "Procedure for safely restarting a web server instance."@en ;
    skos:example "Steps include: drain connections, stop service, check logs, start service, verify access."@en ;
    noria:operationPlanPreCondition noria:PreCond_WebServerAccessible ;
    noria:operationPlanPostCondition noria:PostCond_WebServerRunning .

noria:OpPlan_IncreaseDBPool a noria:OperationPlan ;
    rdfs:label "Increase Database Connection Pool Size"@en ;
    rdfs:comment "Procedure to dynamically or statically increase the database connection pool for an application."@en ;
    skos:example "Steps include: identify application, modify configuration, restart application (if static), monitor database metrics."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBAccessAvailable ;
    noria:operationPlanPostCondition noria:PostCond_DBPoolIncreased .

noria:OpPlan_PortFlap a noria:OperationPlan ;
    rdfs:label "Network Interface Port Flap Procedure"@en ;
    rdfs:comment "Procedure to administratively shut down and then bring up a network interface to clear errors or reset state."@en ;
    skos:example "Steps include: verify impact, shut interface, wait 10s, no shut interface, verify link status."@en ;
    noria:operationPlanPreCondition noria:PreCond_InterfaceErrors ;
    noria:operationPlanPostCondition noria:PostCond_InterfaceClear .

noria:PreCond_WebServerAccessible a noria:ActionPreCondition ;
    rdfs:label "Web Server Accessible"@en ;
    rdfs:comment "Condition: Web server is reachable via SSH/management interface."@en ;
    skos:example "Ping to web server IP is successful."@en .

noria:PostCond_WebServerRunning a noria:ActionPostCondition ;
    rdfs:label "Web Server Running and Responsive"@en ;
    rdfs:comment "Outcome: Web server process is running, and application responds to requests."@en ;
    skos:example "HTTP 200 OK from application endpoint."@en .

noria:PreCond_DBAccessAvailable a noria:ActionPreCondition ;
    rdfs:label "Database Access Available"@en ;
    rdfs:comment "Condition: Database server is accessible and credentials are valid."@en ;
    skos:example "Can connect to database with administrative user."@en .

noria:PostCond_DBPoolIncreased a noria:ActionPostCondition ;
    rdfs:label "Database Connection Pool Increased"@en ;
    rdfs:comment "Outcome: Database connection pool size metric shows increased value, and application errors related to connections cease."@en ;
    skos:example "Monitoring shows connection pool at desired level, no more 'connection exhausted' errors."@en .

noria:PreCond_InterfaceErrors a noria:ActionPreCondition ;
    rdfs:label "Network Interface Errors Present"@en ;
    rdfs:comment "Condition: Network interface shows increasing error counters or flapping status."@en ;
    skos:example "Interface statistics show input/output errors."@en .

noria:PostCond_InterfaceClear a noria:ActionPostCondition ;
    rdfs:label "Network Interface Error Counters Cleared"@en ;
    rdfs:comment "Outcome: Network interface error counters are reset to zero or stable, and operational status is up."@en ;
    skos:example "Interface statistics show zero errors after flap."@en .

# =============================================================================
# Procedure Executions (related to Trouble Ticket Notes)
# =============================================================================

noria:PE_DBPoolIncrease a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of DB Pool Increase"@en ;
    rdfs:comment "Container for events related to increasing the database connection pool."@en ;
    dcterms:created "2024-04-20T10:35:00Z"^^xsd:dateTime ;
    pep:usedProcedure noria:OpPlan_IncreaseDBPool ;
    pep:hasInput noria:PreCond_DBAccessAvailable ;
    pep:hasOutput noria:PostCond_DBPoolIncreased .

noria:PE_PortFlapCR01 a pep:ProcedureExecutionContainer ;
