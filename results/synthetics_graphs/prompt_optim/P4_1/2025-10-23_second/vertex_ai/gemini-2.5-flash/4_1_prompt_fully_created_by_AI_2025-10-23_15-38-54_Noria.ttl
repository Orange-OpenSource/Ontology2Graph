noria:OperationPlan_SFPReplacement a noria:OperationPlan ;
    rdfs:label "SFP Module Replacement Procedure"@en ;
    rdfs:comment "Standard operating procedure for replacing a faulty SFP module in a network device."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_SFPFaultConfirmed ;
    noria:operationPlanPostCondition noria:ActionPostCondition_LinkUpAndStable .

noria:ActionPreCondition_SFPFaultConfirmed a noria:ActionPreCondition ;
    rdfs:label "SFP Fault Confirmed"@en ;
    rdfs:comment "Pre-condition: Diagnostic tests confirm SFP module failure (e.g., no light, CRC errors)."@en .

noria:ActionPostCondition_LinkUpAndStable a noria:ActionPostCondition ;
    rdfs:label "Link Up and Stable"@en ;
    rdfs:comment "Post-condition: Network link is operational, no errors, and traffic flows normally."@en .

noria:OperationPlan_FirewallSoftwareUpgrade a noria:OperationPlan ;
    rdfs:label "Firewall Software Upgrade Procedure"@en ;
    rdfs:comment "Procedure for upgrading firewall software, including backup and rollback steps."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_FirewallBackupComplete ;
    noria:operationPlanPostCondition noria:ActionPostCondition_FirewallOperationalNewVersion .

noria:ActionPreCondition_FirewallBackupComplete a noria:ActionPreCondition ;
    rdfs:label "Firewall Configuration Backup Complete"@en ;
    rdfs:comment "Pre-condition: Full configuration backup of the firewall is successfully completed."@en .

noria:ActionPostCondition_FirewallOperationalNewVersion a noria:ActionPostCondition ;
    rdfs:label "Firewall Operational with New Version"@en ;
    rdfs:comment "Post-condition: Firewall is operational, running the new software version, and traffic is flowing as expected."@en .

# =============================================================================
# Connecting Operations to Events/Tickets (pep:ProcedureExecutionContainer)
# =============================================================================

# Example of a procedure execution container for the SFP replacement
noria:ProcedureExecutionContainer_SFPReplacement_TT_DNSOutage a pep:ProcedureExecutionContainer ;
    rdfs:label "SFP Replacement Execution for DNS Outage"@en ;
    rdfs:comment "Container for actions taken during SFP replacement for DNS outage."@en ;
    dcterms:isPartOf noria:TroubleTicket_DNSOutage ;
    pep:hasProcedure noria:OperationPlan_SFPReplacement ;
    # This container would typically contain EventRecords related to the execution
    # For example, the EventRecord_RouterInterfaceUp (if created) would be a member.
    # Since ldp:member is forbidden, we can imply this relationship through other properties or comments.
    # For instance, noria:troubleTicketNoteCorrelatedExecution could link to this.
    .

noria:TroubleTicketNote_DNSOutage_Note2 noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer_SFPReplacement_TT_DNSOutage .

# Example of a procedure execution container for the Firewall Upgrade
noria:ProcedureExecutionContainer_FirewallUpgrade_CR_FirewallUpgrade a pep:ProcedureExecutionContainer ;
    rdfs:label "Firewall Upgrade Execution for CR-20240418-003"@en ;
    rdfs:comment "Container for actions taken during the firewall software upgrade."@en ;
    dcterms:isPartOf noria:ChangeRequest_FirewallUpgrade ;
    pep:hasProcedure noria:OperationPlan_FirewallSoftwareUpgrade .

