# =============================================================================
# SKOS Concept Schemes and Concepts (implicitly defined by usage)
# =============================================================================

<kos/application/type> a skos:ConceptScheme ; rdfs:label "Application Type Scheme"@en .
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/business> a skos:Concept ; skos:prefLabel "Business Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/database> a skos:Concept ; skos:prefLabel "Database Application"@en ; skos:inScheme <kos/application/type> .

<kos/application/business-importance> a skos:ConceptScheme ; rdfs:label "Application Business Importance Scheme"@en .
<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High Business Importance"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium Business Importance"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/low> a skos:Concept ; skos:prefLabel "Low Business Importance"@en ; skos:inScheme <kos/application/business-importance> .

<kos/application/status> a skos:ConceptScheme ; rdfs:label "Application Module Status Scheme"@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:inScheme <kos/application/status> .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:prefLabel "In Maintenance"@en ; skos:inScheme <kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "In Development"@en ; skos:inScheme <kos/application/status> .

<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ; rdfs:label "Application Module SLA Level Scheme"@en .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; skos:prefLabel "Gold SLA"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; skos:prefLabel "Silver SLA"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .

<kos/service/type> a skos:ConceptScheme ; rdfs:label "Service Type Scheme"@en .
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:prefLabel "Customer Facing Service"@en ; skos:inScheme <kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:prefLabel "Resource Facing Service"@en ; skos:inScheme <kos/service/type> .

<kos/TroubleTicket/severity> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Severity Scheme"@en .
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en ; skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/type> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Type Scheme"@en .
<kos/TroubleTicket/type/Incident> a skos:Concept ; skos:prefLabel "Incident"@en ; skos:inScheme <kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Problem> a skos:Concept ; skos:prefLabel "Problem"@en ; skos:inScheme <kos/TroubleTicket/type> .

<kos/TroubleTicket/priority> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Priority Scheme"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en ; skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en ; skos:inScheme <kos/TroubleTicket/priority> .

<kos/TroubleTicket/origin> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Origin Scheme"@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision System"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer Report"@en ; skos:inScheme <kos/TroubleTicket/origin> .

<kos/TroubleTicket/urgency> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Urgency Scheme"@en .
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; skos:prefLabel "Immediate Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; skos:prefLabel "Deferred Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .

<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Category Scheme"@en .
<kos/TroubleTicket/trouble-category/TotalBreakdown> a skos:Concept ; skos:prefLabel "Total Breakdown"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/trouble-category/ServiceDegradation> a skos:Concept ; skos:prefLabel "Service Degradation"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ; rdfs:label "Problem Responsibility Scheme"@en .
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ; skos:prefLabel "Managed Backbone Networks"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ; skos:prefLabel "Application Team"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .

<kos/TroubleTicket/commentType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Comment Type Scheme"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:prefLabel "Customer Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .

<kos/TroubleTicket/operationType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Operation Type Scheme"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:prefLabel "Diagnosis"@en ; skos:inScheme <kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/Resolution> a skos:Concept ; skos:prefLabel "Resolution"@en ; skos:inScheme <kos/TroubleTicket/operationType> .

<kos/TroubleTicket/status> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Status Scheme"@en .
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ; skos:prefLabel "Closed"@en ; skos:inScheme <kos/TroubleTicket/status> .

<kos/ChangeRequest/category> a skos:ConceptScheme ; rdfs:label "Change Request Category Scheme"@en .
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; skos:prefLabel "Internal Intervention"@en ; skos:inScheme <kos/ChangeRequest/category> .
<kos/ChangeRequest/category/CustomerRequest> a skos:Concept ; skos:prefLabel "Customer Request"@en ; skos:inScheme <kos/ChangeRequest/category> .

<kos/ChangeRequest/type> a skos:ConceptScheme ; rdfs:label "Change Request Type Scheme"@en .
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:prefLabel "Standard Change"@en ; skos:inScheme <kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:prefLabel "Emergency Change"@en ; skos:inScheme <kos/ChangeRequest/type> .

<kos/ChangeRequest/cause> a skos:ConceptScheme ; rdfs:label "Change Request Cause Scheme"@en .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; skos:prefLabel "Software Upgrade"@en ; skos:inScheme <kos/ChangeRequest/cause> .
<kos/ChangeRequest/cause/ConfigurationChange> a skos:Concept ; skos:prefLabel "Configuration Change"@en ; skos:inScheme <kos/ChangeRequest/cause> .

<kos/ChangeRequest/status> a skos:ConceptScheme ; rdfs:label "Change Request Status Scheme"@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:prefLabel "Approved"@en ; skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; skos:prefLabel "Implemented"@en ; skos:inScheme <kos/ChangeRequest/status> .

<kos/ChangeRequest/specification> a skos:ConceptScheme ; rdfs:label "Change Request Specification Scheme"@en .
<kos/ChangeRequest/specification/StandardProcedure> a skos:Concept ; skos:prefLabel "Standard Procedure"@en ; skos:inScheme <kos/ChangeRequest/specification> .

<kos/Resource/type> a skos:ConceptScheme ; rdfs:label "Resource Type Scheme"@en .
<kos/Resource/type/Server> a skos:Concept ; skos:prefLabel "Server"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ; skos:prefLabel "Router"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:prefLabel "Virtual Machine"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Switch> a skos:Concept ; skos:prefLabel "Network Switch"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Firewall> a skos:Concept ; skos:prefLabel "Firewall"@en ; skos:inScheme <kos/Resource/type> .

<kos/Resource/LifecycleState> a skos:ConceptScheme ; rdfs:label "Resource Lifecycle State Scheme"@en .
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:prefLabel "Decommissioned"@en ; skos:inScheme <kos/Resource/LifecycleState> .

<kos/Resource/OperationalState> a skos:ConceptScheme ; rdfs:label "Resource Operational State Scheme"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:prefLabel "Up"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:prefLabel "Down"@en ; skos:inScheme <kos/Resource/OperationalState> .

<kos/Resource/AdministrativeState> a skos:ConceptScheme ; rdfs:label "Resource Administrative State Scheme"@en .
<kos/Resource/AdministrativeState/Up> a skos:Concept ; skos:prefLabel "Up"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Down> a skos:Concept ; skos:prefLabel "Down"@en ; skos:inScheme <kos/Resource/AdministrativeState> .

<kos/org/agent-contact-method> a skos:ConceptScheme ; rdfs:label "Agent Contact Method Scheme"@en .
<kos/org/agent-contact-method/Email> a skos:Concept ; skos:prefLabel "Email"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; skos:prefLabel "Phone"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/TicketingSystem> a skos:Concept ; skos:prefLabel "Ticketing System"@en ; skos:inScheme <kos/org/agent-contact-method> .

<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ; rdfs:label "Perceived Severity Scheme"@en .
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:prefLabel "Critical"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:prefLabel "Major"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:prefLabel "Minor"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:prefLabel "Warning"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ; skos:prefLabel "Indeterminate"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, open a P1 ticket and call the hotline."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always open a ticket before calling. Provide full details."@en .

foaf:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for the development and maintenance of the Corporate Portal."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit all requests via the internal ticketing system."@en .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for non-critical, dedicated hotline for critical security events."@en .

foaf:Agent_JohnDoe a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer for Corporate Portal."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JaneSmith a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Network Architect."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for high-performance computing and virtualization."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> .

noria:ProductModel_CiscoASR1K a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "High-end router for enterprise and service provider edge deployments."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> .

noria:ProductModel_JuniperEX4600 a noria:ProductModel ;
    rdfs:label "Juniper EX4600 Switch"@en ;
    rdfs:comment "High-performance 10/40GbE data center switch."@en ;
    noria:productManufacturedBy <http://www.juniper.net/organization> .

# =============================================================================
# Locations (noria:Room, noria:Locus)
# =============================================================================

bot:Site_MainDC a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    noria:siteId "DC01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room in Main Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en .

noria:Room_NetworkRoomB a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room in Main Data Center."@en ;
    bot:hasSpace noria:Locus_NetRackB1 .

noria:Locus_NetRackB1 a noria:Locus ;
    rdfs:label "Network Rack B1"@en ;
    rdfs:comment "Main network equipment rack in Network Room B."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "1"@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted on physical hardware."@en ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-DNS-001"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.10"^^observable:IPAddress .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main core router for internal network traffic."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-core01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1K ;
    noria:resourceLogisticId "ASSET-RTR-001"@en ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_NetRackB1 ;
    noria:resourceManagementIPAddress "10.0.0.254"^^observable:IPAddress .

noria:Resource_VMWeb01 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate web portal."@en ;
    noria:resourceManagedBy foaf:Agent_AppDevTeam ;
    noria:resourceHostName "webvm01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceLogisticId "ASSET-VM-WEB-001"@en ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-ID-WEB-001"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "172.16.0.10"^^observable:IPAddress ;
    noria:clusterController noria:Resource_HypervisorHost01 .

noria:Resource_HypervisorHost01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server hosting multiple virtual machines, including webvm01."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOpsTeam ;
    noria:resourceHostName "hypervisor01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-HV-001"@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-HV-001-QWE"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.20"^^observable:IPAddress .

noria:Resource_FirewallDMZ01 a noria:Resource ;
    rdfs:label "DMZ Firewall 01"@en ;
    rdfs:comment "Firewall protecting the DMZ segment."@en ;
    noria:resourceManagedBy foaf:Agent_SecurityTeam ;
    noria:resourceHostName "fw-dmz01.corp.example.com"@en ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1K ; # Using a router model as a placeholder for a firewall product model
    noria:resourceLogisticId "ASSET-FW-001"@en ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceSerialNumber "SN-FW-001-DEF"@en ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-06-01T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_NetRackB1 ;
    noria:resourceManagementIPAddress "10.0.0.5"^^observable:IPAddress .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01-eth0"@en ;
    rdfs:comment "Ethernet interface 0 on DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_RouterCore01_Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "router-core01-Gi0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/0 on Core Router 01, connected to internal network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical"@en ;
