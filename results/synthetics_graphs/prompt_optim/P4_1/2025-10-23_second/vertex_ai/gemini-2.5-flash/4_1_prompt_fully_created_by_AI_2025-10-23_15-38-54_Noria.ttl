    noria:logText "Configuration updated by admin user 'jsmith' from 192.168.1.100."@en ;
    noria:logOriginatingManagedObject noria:Resource_FirewallDMZ01 ;
    noria:logOriginatingAgent foaf:Agent_JaneSmith ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Indeterminate> .

