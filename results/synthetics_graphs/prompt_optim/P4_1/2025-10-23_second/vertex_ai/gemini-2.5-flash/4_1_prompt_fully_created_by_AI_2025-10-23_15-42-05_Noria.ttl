noria:TroubleTicketNote_DNSOutage_Note2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Note for DNS Outage"@en ;
    rdfs:comment "Identified misconfigured firewall rule. Applied temporary fix to allow DNS traffic. Service restored."@en ;
