noria:Resource_VirtualMachineCRMDB a noria:Resource ;
    rdfs:label "CRM Database VM"@en ;
    rdfs:comment "Virtual machine hosting the CRM application database."@en ;
    noria:resourceManagedBy noria:Agent_AppDevTeam ;
