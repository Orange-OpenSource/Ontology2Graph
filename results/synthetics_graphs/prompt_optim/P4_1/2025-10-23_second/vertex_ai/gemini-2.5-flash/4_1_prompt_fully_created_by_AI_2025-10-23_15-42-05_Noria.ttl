noria:Resource_VirtualHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server running VMware ESXi, hosting multiple virtual machines."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:resourceHostName "vhost01.corp.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
