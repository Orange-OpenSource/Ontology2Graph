# -----------------------------------------------------------------------------
# Services
# -----------------------------------------------------------------------------

noria:Service_CorporateInternetAccess a noria:Service ;
    rdfs:label "Corporate Internet Access"@en ;
    rdfs:comment "End-to-end service providing internet access to all corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    noria:elementManagedBy noria:Agent_NetworkOpsTeam ;
    seas:subSystemOf noria:Application_CorporateDNS ;
    seas:subSystemOf noria:Application_MonitoringPlatform .

noria:Service_CRMDataFlow a noria:Service ;
    rdfs:label "CRM Data Flow Service"@en ;
    rdfs:comment "Service encompassing the entire data flow for the CRM application, from web frontend to database."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    noria:elementManagedBy noria:Agent_AppDevTeam ;
    seas:subSystemOf noria:ApplicationModule_CRM_Prod .

# -----------------------------------------------------------------------------
# Event Records
# -----------------------------------------------------------------------------

noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNSServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "CRITICAL: DNS service on dns01.corp.example.com is unreachable via port 53."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_InterfaceDown a noria:EventRecord ;
    rdfs:label "Network Interface Down Alert"@en ;
    rdfs:comment "Alert generated when a critical network interface went down."@en ;
    noria:loggingTime "2024-04-10T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouterParis ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "Interface GigabitEthernet0/0/2 on cr-par-01.example.com changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction <pep/Procedure/CheckFiberConnection> .

noria:EventRecord_CRMLoginFailure a noria:EventRecord ;
    rdfs:label "CRM Login Failure Alert"@en ;
    rdfs:comment "Alert indicating a high rate of failed login attempts on CRM."@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:ApplicationModule_CRM_Prod ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logText "High volume of failed login attempts detected on CRM Production module."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent noria:Agent_BobWhite .

noria:EventRecord_ConfigChange_CRPAR01 a noria:EventRecord ;
    rdfs:label "Core Router Configuration Change"@en ;
    rdfs:comment "Log entry for a configuration change applied to Core Router Paris."@en ;
    noria:loggingTime "2024-04-09T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouterParis ;
    noria:logOriginatingAgent noria:CUid_JaneSmith ;
    noria:logText "Configuration updated: interface ge-0/0/2 description changed to 'WAN link to Lyon Office - NEW'."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_CR_FirewallRuleUpdate_Start a noria:EventRecord ;
    rdfs:label "Firewall Rule Update Started"@en ;
    rdfs:comment "Log entry indicating the start of the firewall rule update procedure."@en ;
    noria:loggingTime "2024-04-11T02:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouterParis ;
    noria:logOriginatingAgent noria:CUid_JohnDoe ;
    noria:logText "CR-20240410-001: Firewall rule update procedure started."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    dcterms:references noria:ChangeRequest_FirewallRuleUpdate .

noria:EventRecord_CR_FirewallRuleUpdate_End a noria:EventRecord ;
    rdfs:label "Firewall Rule Update Completed"@en ;
    rdfs:comment "Log entry indicating the completion of the firewall rule update procedure."@en ;
    noria:loggingTime "2024-04-11T02:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouterParis ;
    noria:logOriginatingAgent noria:CUid_JohnDoe ;
    noria:logText "CR-20240410-001: Firewall rule update procedure completed successfully. Service verified."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    dcterms:references noria:ChangeRequest_FirewallRuleUpdate .

