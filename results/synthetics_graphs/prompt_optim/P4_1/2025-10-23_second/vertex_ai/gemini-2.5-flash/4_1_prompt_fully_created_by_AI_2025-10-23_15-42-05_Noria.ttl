    noria:resourceHostName "web01.crm.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-WEB-01-ABC"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <observable/ipAddress/10.0.0.20> .

noria:Resource_CoreRouterParis a noria:Resource ;
    rdfs:label "Core Router Paris"@en ;
    rdfs:comment "Main router for the Paris Data Center network."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:resourceHostName "cr-par-01.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel_JuniperMX480 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-CR-PAR-01-DEF"^^xsd:string ;
