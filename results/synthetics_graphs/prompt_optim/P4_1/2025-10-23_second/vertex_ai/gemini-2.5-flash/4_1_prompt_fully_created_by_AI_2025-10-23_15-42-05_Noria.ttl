# -----------------------------------------------------------------------------
# Operation Plans and Conditions
# -----------------------------------------------------------------------------

noria:OperationPlan_FirewallUpdateProcedure a noria:OperationPlan ;
    rdfs:label "Firewall Rule Update Procedure"@en ;
    rdfs:comment "Standard operating procedure for updating firewall rules."@en ;
    pep:hasStep "1. Review change request."@en, "2. Prepare configuration."@en, "3. Apply configuration."@en, "4. Verify service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_NetworkAccessOK ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ServiceRestored .

noria:ActionPreCondition_NetworkAccessOK a noria:ActionPreCondition ;
    rdfs:label "Network Access OK Pre-condition"@en ;
    rdfs:comment "Verify network connectivity to the firewall device before making changes."@en .

noria:ActionPostCondition_ServiceRestored a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-condition"@en ;
    rdfs:comment "Confirm that the affected service is fully operational after the change."@en .

noria:OperationPlan_RouterOSUpgradeProcedure a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Detailed procedure for upgrading router operating system, including backup and rollback steps."@en ;
    pep:hasStep "1. Backup current configuration."@en, "2. Download new OS image."@en, "3. Install new OS."@en, "4. Reboot and verify."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterOperational .

noria:ActionPreCondition_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Pre-condition"@en ;
    rdfs:comment "Ensure the upgrade is performed within an approved maintenance window."@en .

noria:ActionPostCondition_RouterOperational a noria:ActionPostCondition ;
    rdfs:label "Router Operational Post-condition"@en ;
    rdfs:comment "Verify router functionality, routing tables, and interface statuses after upgrade."@en .

