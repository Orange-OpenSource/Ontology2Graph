noria:TroubleTicketNote_DNSOutage_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note for DNS Outage"@en ;
    rdfs:comment "Initial check shows DNS server is pingable but not responding to DNS queries. Suspect firewall or service issue."@en ;
