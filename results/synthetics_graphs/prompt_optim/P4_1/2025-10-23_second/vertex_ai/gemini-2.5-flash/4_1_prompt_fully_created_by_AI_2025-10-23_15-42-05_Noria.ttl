# -----------------------------------------------------------------------------
# Network Interfaces
# -----------------------------------------------------------------------------

noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on DNS01"@en ;
    rdfs:comment "Primary network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNSServer01 ;
    noria:networkInterfaceDescription "Management and DNS traffic interface."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_CRPAR01_Ge001 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on CR-PAR-01"@en ;
    rdfs:comment "Interface connecting Core Router Paris to the internal network segment."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouterParis ;
    noria:networkInterfaceDescription "Internal DC network uplink."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 .

noria:NetworkInterface_CRPAR01_Ge002 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/2 on CR-PAR-01"@en ;
    rdfs:comment "Interface connecting Core Router Paris to the WAN link to Lyon."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouterParis ;
    noria:networkInterfaceDescription "WAN link to Lyon Office."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -4 .

noria:NetworkInterface_ERLYN01_Ge001 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on ER-LYN-01"@en ;
    rdfs:comment "Interface connecting Edge Router Lyon to the WAN link to Paris."@en ;
    noria:networkInterfaceOf noria:Resource_EdgeRouterLyon ;
    noria:networkInterfaceDescription "WAN link to Paris DC."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceLaserTxOpticalPower -2.5 ;
    noria:networkInterfaceLaserRxOpticalPower -4.5 .

noria:NetworkInterface_CRMDB_Eth0 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on CRMDB VM"@en ;
    rdfs:comment "Primary network interface for CRM Database VM."@en ;
    noria:networkInterfaceOf noria:Resource_VirtualMachineCRMDB ;
    noria:networkInterfaceDescription "Database network access."@en ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# -----------------------------------------------------------------------------
# Network Links
# -----------------------------------------------------------------------------

noria:NetworkLink_WAN_Paris_Lyon a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-Lyon"@en ;
    rdfs:comment "Dedicated fiber optic link between Paris Data Center and Lyon Office."@en ;
    noria:networkLinkId "WAN-PAR-LYN-001"^^xsd:string ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:networkLinkInstallationDate "2021-06-15T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_CoreRouterParis ;
    noria:networkLinkTerminationResourceDestination noria:Resource_EdgeRouterLyon ;
    noria:networkInterfaceConnects noria:NetworkInterface_CRPAR01_Ge002 ;
    noria:networkInterfaceConnects noria:NetworkInterface_ERLYN01_Ge001 .

# -----------------------------------------------------------------------------
# Applications
# -----------------------------------------------------------------------------

noria:Application_CorporateDNS a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:comment "Provides DNS resolution for all internal corporate services."@en ;
    noria:applicationModelIdentifier "CORP-DNS"^^xsd:string ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "CORPDNS"^^xsd:string ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "DNS Resolution"@en ;
    noria:elementManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceForApplication noria:Resource_DNSServer01 .

noria:Application_CRMSystem a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:comment "Core application for managing customer interactions and data."@en ;
    noria:applicationModelIdentifier "CRM-APP"^^xsd:string ;
    noria:applicationNumericalIdentifier 202 ;
    noria:applicationShortIdentifier "CRM"^^xsd:string ;
    noria:applicationType <kos/application/type/business-critical> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Management"@en ;
    noria:applicationFunctionalSubDomain "Sales & Support"@en ;
    noria:elementManagedBy noria:Agent_AppDevTeam ;
    noria:resourceForApplication noria:Resource_WebFrontend01 ;
    noria:resourceForApplication noria:Resource_VirtualMachineCRMDB .

noria:Application_MonitoringPlatform a noria:Application ;
    rdfs:label "IT Monitoring Platform"@en ;
    rdfs:comment "Platform for collecting, analyzing, and alerting on IT infrastructure metrics and logs."@en ;
    noria:applicationModelIdentifier "MON-PLAT"^^xsd:string ;
    noria:applicationNumericalIdentifier 303 ;
    noria:applicationShortIdentifier "MONITOR"^^xsd:string ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations"@en ;
    noria:applicationFunctionalSubDomain "Performance & Availability Monitoring"@en ;
    noria:elementManagedBy noria:Agent_NetworkOpsTeam .

