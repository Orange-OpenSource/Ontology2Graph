# -----------------------------------------------------------------------------
# Locations (Site, Room, Locus)
# -----------------------------------------------------------------------------

noria:Site_DataCenterParis a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center facility in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"@en .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within Paris Data Center."@en ;
    bot:hasZone noria:Site_DataCenterParis .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Rack A1, Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Locus_RackB5 a noria:Locus ;
    rdfs:label "Rack B5"@en ;
    rdfs:comment "Location of network equipment in Rack B5, Server Room A."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "5"^^xsd:string ;
    bot:containsZone noria:Room_ServerRoomA .

noria:Site_OfficeLyon a bot:Site ;
    rdfs:label "Lyon Office"@en ;
    rdfs:comment "Regional office in Lyon."@en ;
    noria:siteId "OFF-LYN-01"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès"@en ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69007"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string .

noria:Room_CommsRoom a noria:Room ;
    rdfs:label "Communications Room"@en ;
    rdfs:comment "Small communications room in Lyon Office."@en ;
    bot:hasZone noria:Site_OfficeLyon .

noria:Locus_CommsCabinet1 a noria:Locus ;
    rdfs:label "Comms Cabinet 1"@en ;
    rdfs:comment "Network cabinet in Communications Room."@en ;
    noria:locusLine "C"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:containsZone noria:Room_CommsRoom .

# -----------------------------------------------------------------------------
# Resources
# -----------------------------------------------------------------------------

noria:Resource_DNSServer01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-01-XYZ"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress <observable/ipAddress/10.0.0.10> .

noria:Resource_WebFrontend01 a noria:Resource ;
