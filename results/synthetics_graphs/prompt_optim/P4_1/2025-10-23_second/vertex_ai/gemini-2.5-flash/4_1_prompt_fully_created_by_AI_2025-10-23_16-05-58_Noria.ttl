# Services (noria:Service)
# =============================================================================

noria:Service1 a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "Provides end-to-end network connectivity for all corporate operations."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:ApplicationModule1 ; # Application Module is a sub-system of the service
    noria:elementManagedBy foaf:Agent2 .

noria:Service2 a noria:Service ;
    rdfs:label "Customer Facing Web Service"@en ;
    rdfs:comment "Aggregates all customer-facing web applications and services."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:ApplicationModule2 ;
    noria:elementManagedBy foaf:Agent3 .

noria:Service3 a noria:Service ;
    rdfs:label "Internal Business Process Service"@en ;
    rdfs:comment "Supports critical internal business processes, including CRM and ERP."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:ApplicationModule3 ;
    noria:elementManagedBy foaf:Agent3 .

noria:Service4 a noria:Service ;
    rdfs:label "IT Monitoring and Alerting Service"@en ;
    rdfs:comment "Provides comprehensive monitoring and alerting capabilities for IT assets."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystem noria:ApplicationModule4 ;
    noria:elementManagedBy foaf:Agent5 .

noria:Service5 a noria:Service ;
    rdfs:label "Secure Email Delivery Service"@en ;
    rdfs:comment "Ensures secure and reliable email delivery for the organization."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystem noria:ApplicationModule5 ;
    noria:elementManagedBy foaf:Agent5 .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "Standard DNS Service Restart Procedure"@en ;
    rdfs:comment "A documented procedure for restarting the corporate DNS service."@en ;
    skos:example "Steps include checking logs, attempting graceful restart, force restart if necessary, and verifying service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Core Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Procedure for upgrading firmware on core network routers, including pre-checks and post-checks."@en ;
    skos:example "Includes backup configuration, load new image, reboot, verify connectivity."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:OperationPlan3 a noria:OperationPlan ;
    rdfs:label "Database Backup and Restore Procedure"@en ;
    rdfs:comment "Standard operating procedure for backing up and restoring critical databases."@en ;
    skos:example "Daily full backup, hourly incremental backups, disaster recovery plan."@en .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS service is not responding to queries from internal clients."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Reachable and Resolving"@en ;
    rdfs:comment "Outcome: DNS service is responding to queries and correctly resolving hostnames."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Router Firmware Version Outdated"@en ;
    rdfs:comment "Condition: The current firmware version on the router is older than the approved version."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Router Firmware Version Updated and Stable"@en ;
    rdfs:comment "Outcome: Router firmware has been successfully updated to the target version, and device is stable."@en .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Service Down Alert"@en ;
    rdfs:comment "Automated alert indicating that the corporate DNS service is unreachable."@en ;
    noria:loggingTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:logText "Service 'dns-resolver' on dns01.corp.example.com is DOWN."@en ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan1 .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router R1 went down."@en ;
    noria:loggingTime "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    noria:logText "Interface Gi0/0/1 on router-core-r1 changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "DB Connection Timeout Alert"@en ;
    rdfs:comment "Alert from Customer Portal indicating database connection timeouts."@en ;
    noria:loggingTime "2024-04-23T09:10:00Z"^^xsd:dateTime ;
    noria:logText "Database connection pool exhausted for Customer Portal. Multiple timeouts observed."@en ;
    noria:logOriginatingManagedObject noria:Resource3 ; # VM hosting the portal
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Monitoring alert for high CPU utilization on WebApp01."@en ;
    noria:loggingTime "2024-04-23T08:45:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on webapp01.customer.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "Firewall Block Alert - Suspicious Activity"@en ;
    rdfs:comment "Firewall detected and blocked suspicious outbound connection attempt."@en ;
    noria:loggingTime "2024-04-23T09:15:00Z"^^xsd:dateTime ;
    noria:logText "Blocked outbound connection from 172.16.1.10 to malicious_ip:443. Policy violation."@en ;
    noria:logOriginatingManagedObject noria:Resource5 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent foaf:Agent10 . # Assuming John Smith's VM was compromised or initiated the connection

noria:EventRecord6 a noria:EventRecord ;
    rdfs:label "DNS Service Restart Success"@en ;
    rdfs:comment "Log entry confirming successful restart of DNS service."@en ;
    noria:loggingTime "2024-04-23T09:35:00Z"^^xsd:dateTime ;
    noria:logText "DNS service 'dns-resolver' on dns01.corp.example.com successfully restarted."@en ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    noria:logOriginatingAgent foaf:Agent10 . # Assuming John Smith performed the restart

noria:EventRecord7 a noria:EventRecord ;
    rdfs:label "Router Interface Up Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router R1 came back up."@en ;
    noria:loggingTime "2024-04-23T09:40:00Z"^^xsd:dateTime ;
    noria:logText "Interface Gi0/0/1 on router-core-r1 changed state to up."@en ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

