    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedService noria:Application2 ;
    noria:troubleTicketRelatedResource noria:Resource3, noria:Resource4, noria:Resource6 ;
    noria:troubleTicketRelatedParty foaf:Agent3, foaf:Agent6 ;
    noria:troubleTicketTrigger noria:EventRecord3, noria:EventRecord4 ;
    dcterms:identifier "TT-20240423-002" ;
    dcterms:created "2024-04-23T08:55:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T09:15:00Z"^^xsd:dateTime ;
    noria:documentHRef "https://ticketing.example.com/TT-20240423-002" .

noria:TroubleTicket3 a noria:TroubleTicket ;
    rdfs:label "Branch Office Internet Outage"@en ;
    rdfs:comment "Branch office in Paris has lost internet connectivity."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServiceInterruption> ;
