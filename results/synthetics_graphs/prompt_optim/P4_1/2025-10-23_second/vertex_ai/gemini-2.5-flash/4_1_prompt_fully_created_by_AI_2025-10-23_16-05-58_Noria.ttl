noria:TroubleTicket1 a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "DNS server unreachable causing internet access issues for corporate users."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/ServiceInterruption> ;
    noria:troubleTicketCause "DNS service process crashed due to memory leak."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ApplicationTeam> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T09:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketRelatedService noria:Application1 ;
    noria:troubleTicketRelatedResource noria:Resource1 ;
    noria:troubleTicketRelatedParty foaf:Agent1, foaf:Agent2 ;
    noria:troubleTicketTrigger noria:EventRecord1 ;
    noria:documentStatusHistory noria:EventRecord6 ; # DNS service restart success
    dcterms:identifier "TT-20240423-001" ;
    dcterms:created "2024-04-23T09:01:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-23T09:45:00Z"^^xsd:dateTime ;
    noria:documentHRef "https://ticketing.example.com/TT-20240423-001" .

noria:TroubleTicket2 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Slow Performance"@en ;
    rdfs:comment "Customers reporting slow loading times and occasional timeouts on the portal."@en ;
