# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use emergency hotline after hours."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate all network-related critical alarms immediately."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Customer Portal Support"@en ;
    rdfs:comment "Team handling issues related to the customer-facing web portal."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Sat)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Security Operations Team (SOC)"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Report all security incidents via dedicated ticketing system."@en .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "IT Infrastructure Team"@en ;
    rdfs:comment "General IT infrastructure management and maintenance."@en ;
    noria:agentWorkingHours "8:30 am - 5:30 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent6 a foaf:Agent ;
    rdfs:label "Customer Support Tier 1"@en ;
    rdfs:comment "First line of contact for customer inquiries and issues."@en ;
    noria:agentWorkingHours "7:00 am - 10:00 pm (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent7 a foaf:Agent ;
    rdfs:label "Change Management Board"@en ;
    rdfs:comment "Approves and schedules all IT changes."@en ;
    noria:agentWorkingHours "Weekly meetings, emergency approvals as needed"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent8 a foaf:Agent ;
    rdfs:label "Database Admin Team"@en ;
    rdfs:comment "Manages and maintains all corporate databases."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent9 a foaf:Agent ;
    rdfs:label "Cloud Platform Team"@en ;
    rdfs:comment "Manages the cloud infrastructure and services."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent10 a foaf:Agent ;
    rdfs:label "John Smith"@en ;
    rdfs:comment "Individual IT engineer, member of DNS Admin Team."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

