noria:DocumentAttachment1 a noria:DocumentAttachment ;
    rdfs:label "DNS Server Log Snippet"@en ;
    rdfs:comment "Relevant log entries from the DNS server during the outage."@en ;
    dcterms:isPartOf noria:TroubleTicket1 ;
    dcterms:format "text/plain"@en ;
    dcterms:source "file:///logs/dns01_error.log.txt"^^xsd:anyURI .

noria:DocumentAttachment2 a noria:DocumentAttachment ;
    rdfs:label "Router Firmware Release Notes"@en ;
    rdfs:comment "Release notes for the new firmware version of Core Router R1."@en ;
    dcterms:isPartOf noria:ChangeRequest1 ;
    dcterms:format "application/pdf"@en ;
    dcterms:source "file:///docs/Cisco_Catalyst_9300_ReleaseNotes_v17.pdf"^^xsd:anyURI .

noria:DocumentAttachment3 a noria:DocumentAttachment ;
    rdfs:label "Customer Portal Performance Report"@en ;
    rdfs:comment "Performance metrics report showing degradation of customer portal."@en ;
    dcterms:isPartOf noria:TroubleTicket2 ;
    dcterms:format "application/pdf"@en ;
    dcterms:source "file:///reports/customer_portal_perf_20240423.pdf"^^xsd:anyURI .

