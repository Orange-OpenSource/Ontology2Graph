<kos/TroubleTicket/operationType> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Concept Scheme"@en ;
    rdfs:comment "Defines the operation type of trouble ticket notes."@en .

<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ;
    skos:prefLabel "Diagnosis"@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

<kos/TroubleTicket/operationType/Resolution> a skos:Concept ;
    skos:prefLabel "Resolution"@en ;
    skos:inScheme <kos/TroubleTicket/operationType> .

