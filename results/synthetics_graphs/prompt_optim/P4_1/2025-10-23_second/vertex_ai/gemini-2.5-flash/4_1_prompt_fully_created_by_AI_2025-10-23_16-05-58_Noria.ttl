# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TroubleTicketNote1 a noria:TroubleTicketNote ;
    rdfs:label "Initial DNS Restart Attempt"@en ;
    rdfs:comment "Attempted to restart DNS service on dns01.corp.example.com. Service came back up briefly then went down again."@en ;
    dcterms:created "2024-04-23T09:15:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent10 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord6 ; # This note is about the action that led to EventRecord6
    dcterms:isPartOf noria:TroubleTicket1 .

noria:TroubleTicketNote2 a noria:TroubleTicketNote ;
    rdfs:label "Customer Portal DB Check"@en ;
    rdfs:comment "Checked database server DB01 for high load or errors. Found high number of open connections. Restarted database service."@en ;
    dcterms:created "2024-04-23T09:20:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent8 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ;
    dcterms:isPartOf noria:TroubleTicket2 .

noria:TroubleTicketNote3 a noria:TroubleTicketNote ;
    rdfs:label "WAN Link Troubleshooting"@en ;
    rdfs:comment "Confirmed physical link status on ER01. Interface Gi0/0/1 was administratively down. Brought it up. Connectivity restored."@en ;
    dcterms:created "2024-04-23T09:38:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent10 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecord7 ; # This note is about the action that led to EventRecord7
    dcterms:isPartOf noria:TroubleTicket3 .

