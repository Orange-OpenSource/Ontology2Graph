    rdfs:comment "Defines urgency levels for trouble tickets."@en .

<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ;
    skos:prefLabel "Immediate Intervention"@en ;
    skos:inScheme <kos/TroubleTicket/urgency> .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Concept Scheme"@en ;
    rdfs:comment "Defines categories for the nature or technical impact of incidents."@en .

<kos/TroubleTicket/trouble-category/ServiceInterruption> a skos:Concept ;
    skos:prefLabel "Service Interruption"@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

<kos/TroubleTicket/trouble-category/PerformanceDegradation> a skos:Concept ;
    skos:prefLabel "Performance Degradation"@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> .

# Trouble Ticket Problem Responsibility
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
