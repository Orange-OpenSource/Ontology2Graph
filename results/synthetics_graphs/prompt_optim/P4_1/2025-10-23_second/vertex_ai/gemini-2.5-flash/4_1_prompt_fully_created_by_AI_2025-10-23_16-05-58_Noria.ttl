# =============================================================================
# Location (noria:Room, noria:Locus)
# =============================================================================

noria:Room1 a noria:Room ;
    rdfs:label "Main Data Center Server Room A"@en ;
    rdfs:comment "Primary server room in the main data center facility."@en ;
    bot:hasSpace noria:Locus1, noria:Locus2, noria:Locus3, noria:Locus4 .

noria:Room2 a noria:Room ;
    rdfs:label "Branch Office Network Closet"@en ;
    rdfs:comment "Network equipment closet in a regional branch office."@en ;
    bot:hasSpace noria:Locus5 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Location for DNS server in Rack A1, unit 10."@en ;
    noria:locusLine "A1"@en ;
    noria:locusRow "10"@en .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack A2, Unit 5"@en ;
    rdfs:comment "Location for Core Router R1 in Rack A2, unit 5."@en ;
    noria:locusLine "A2"@en ;
    noria:locusRow "5"@en .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack B1, Unit 1"@en ;
    rdfs:comment "Location for Database Server DB01 in Rack B1, unit 1."@en ;
    noria:locusLine "B1"@en ;
    noria:locusRow "1"@en .

noria:Locus4 a noria:Locus ;
    rdfs:label "Rack C3, Unit 15"@en ;
    rdfs:comment "Location for Firewall FW01 in Rack C3, unit 15."@en ;
    noria:locusLine "C3"@en ;
    noria:locusRow "15"@en .

noria:Locus5 a noria:Locus ;
    rdfs:label "Wall Mount Rack, Unit 1"@en ;
    rdfs:comment "Location for Edge Router ER01 in the branch office."@en ;
    noria:locusLine "WM1"@en ;
    noria:locusRow "1"@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource1 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in main data center."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "ASSET-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
    noria:locatedAtLocus noria:Locus1 .

noria:Resource2 a noria:Resource ;
    rdfs:label "Core Router R1"@en ;
    rdfs:comment "Main core router connecting internal network to external services."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
