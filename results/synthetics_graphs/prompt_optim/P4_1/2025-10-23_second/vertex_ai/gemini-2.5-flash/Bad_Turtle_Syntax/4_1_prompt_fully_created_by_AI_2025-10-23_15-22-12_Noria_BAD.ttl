# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix devopsprod: <http://w3id.org/devops-infra/product#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# SKOS Concept Schemes and Concepts (for internal use, as implied by kos/ URIs)
# =============================================================================

<kos/application/type> a skos:ConceptScheme ; rdfs:label "Application Type Scheme"@en .
<kos/application/type/infrastructure> a skos:Concept ; skos:inScheme <kos/application/type> ; rdfs:label "Infrastructure Application"@en ; rdfs:comment "Represents applications that provide foundational IT services."@en .
<kos/application/type/business> a skos:Concept ; skos:inScheme <kos/application/type> ; rdfs:label "Business Application"@en ; rdfs:comment "Represents applications directly supporting business operations."@en .
<kos/application/type/monitoring> a skos:Concept ; skos:inScheme <kos/application/type> ; rdfs:label "Monitoring Application"@en ; rdfs:comment "Represents applications used for system surveillance and alerting."@en .

<kos/application/business-importance> a skos:ConceptScheme ; rdfs:label "Application Business Importance Scheme"@en .
<kos/application/business-importance/high> a skos:Concept ; skos:inScheme <kos/application/business-importance> ; rdfs:label "High Business Importance"@en ; rdfs:comment "Application is critical for core business functions."@en .
<kos/application/business-importance/medium> a skos:Concept ; skos:inScheme <kos/application/business-importance> ; rdfs:label "Medium Business Importance"@en ; rdfs:comment "Application supports important but not immediately critical business functions."@en .
<kos/application/business-importance/low> a skos:Concept ; skos:inScheme <kos/application/business-importance> ; rdfs:label "Low Business Importance"@en ; rdfs:comment "Application supports non-critical or auxiliary business functions."@en .

<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ; rdfs:label "Application Module Status Scheme"@en .
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/status> ; rdfs:label "In Production"@en ; rdfs:comment "The application module is currently live and serving users."@en .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/status> ; rdfs:label "Development"@en ; rdfs:comment "The application module is under active development."@en .
<https://w3id.org/noria/kos/application/status/Maintenance> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/status> ; rdfs:label "Maintenance"@en ; rdfs:comment "The application module is in a maintenance phase, possibly offline."@en .

<kos/TroubleTicket/severity> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Severity Scheme"@en .
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; rdfs:label "Critical Severity"@en ; rdfs:comment "Indicates a complete loss of service or major business impact."@en .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; rdfs:label "Major Severity"@en ; rdfs:comment "Indicates a significant degradation of service or partial business impact."@en .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:inScheme <kos/TroubleTicket/severity> ; rdfs:label "Minor Severity"@en ; rdfs:comment "Indicates a minor issue with limited impact on service or business."@en .

<kos/TroubleTicket/type> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Type Scheme"@en .
<kos/TroubleTicket/type/Failure> a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; rdfs:label "Failure Ticket"@en ; rdfs:comment "Ticket related to a system or service failure."@en .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; skos:inScheme <kos/TroubleTicket/type> ; rdfs:label "Assistance Ticket"@en ; rdfs:comment "Ticket for user assistance or general queries."@en .

<kos/TroubleTicket/priority> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Priority Scheme"@en .
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:inScheme <kos/TroubleTicket/priority> ; rdfs:label "Priority 1"@en ; rdfs:comment "Highest priority, immediate action required."@en .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:inScheme <kos/TroubleTicket/priority> ; rdfs:label "Priority 2"@en ; rdfs:comment "High priority, urgent action required."@en .

<kos/TroubleTicket/origin> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Origin Scheme"@en .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:inScheme <kos/TroubleTicket/origin> ; rdfs:label "Customer Origin"@en ; rdfs:comment "Ticket initiated by a customer."@en .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:inScheme <kos/TroubleTicket/origin> ; rdfs:label "Supervision Origin"@en ; rdfs:comment "Ticket initiated by a monitoring or supervision system."@en .

<kos/TroubleTicket/commentType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Note Comment Type Scheme"@en .
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:inScheme <kos/TroubleTicket/commentType> ; rdfs:label "Internal Comment"@en ; rdfs:comment "Comment visible only to internal teams."@en .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:inScheme <kos/TroubleTicket/commentType> ; rdfs:label "Customer Comment"@en ; rdfs:comment "Comment visible to the customer."@en .

<kos/TroubleTicket/operationType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Note Operation Type Scheme"@en .
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; skos:inScheme <kos/TroubleTicket/operationType> ; rdfs:label "Diagnosis Operation"@en ; rdfs:comment "Note detailing diagnostic steps."@en .
<kos/TroubleTicket/operationType/Tests> a skos:Concept ; skos:inScheme <kos/TroubleTicket/operationType> ; rdfs:label "Tests and Measurements Operation"@en ; rdfs:comment "Note detailing test results and measurements."@en .

<kos/ChangeRequest/type> a skos:ConceptScheme ; rdfs:label "Change Request Type Scheme"@en .
<kos/ChangeRequest/type/Standard> a skos:Concept ; skos:inScheme <kos/ChangeRequest/type> ; rdfs:label "Standard Change"@en ; rdfs:comment "Pre-approved, low-risk change."@en .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; skos:inScheme <kos/ChangeRequest/type> ; rdfs:label "Emergency Change"@en ; rdfs:comment "Urgent change required to resolve an incident."@en .

<kos/ChangeRequest/cause> a skos:ConceptScheme ; rdfs:label "Change Request Cause Scheme"@en .
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; skos:inScheme <kos/ChangeRequest/cause> ; rdfs:label "Software Upgrade Cause"@en ; rdfs:comment "Change due to software version upgrade."@en .
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; skos:inScheme <kos/ChangeRequest/cause> ; rdfs:label "Configuration Change Cause"@en ; rdfs:comment "Change due to modification of system configuration."@en .

<kos/ChangeRequest/status> a skos:ConceptScheme ; rdfs:label "Change Request Status Scheme"@en .
<kos/ChangeRequest/status/Approved> a skos:Concept ; skos:inScheme <kos/ChangeRequest/status> ; rdfs:label "Approved Status"@en ; rdfs:comment "Change request has been approved."@en .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; skos:inScheme <kos/ChangeRequest/status> ; rdfs:label "Implemented Status"@en ; rdfs:comment "Change request has been successfully implemented."@en .

<kos/Resource/type> a skos:ConceptScheme ; rdfs:label "Resource Type Scheme"@en .
<kos/Resource/type/Server> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Server Resource"@en ; rdfs:comment "A computing server."@en .
<kos/Resource/type/Router> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Router Resource"@en ; rdfs:comment "A network router."@en .
<kos/Resource/type/Switch> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Switch Resource"@en ; rdfs:comment "A network switch."@en .
<kos/Resource/type/VirtualMachine> a skos:Concept ; skos:inScheme <kos/Resource/type> ; rdfs:label "Virtual Machine Resource"@en ; rdfs:comment "A virtualized computing instance."@en .

<kos/Resource/LifecycleState> a skos:ConceptScheme ; rdfs:label "Resource Lifecycle State Scheme"@en .
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; rdfs:label "In Production State"@en ; rdfs:comment "Resource is actively used in production."@en .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; skos:inScheme <kos/Resource/LifecycleState> ; rdfs:label "Decommissioned State"@en ; rdfs:comment "Resource has been removed from service."@en .

<kos/Resource/OperationalState> a skos:ConceptScheme ; rdfs:label "Resource Operational State Scheme"@en .
<kos/Resource/OperationalState/Up> a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; rdfs:label "Up Operational State"@en ; rdfs:comment "Resource is operational."@en .
<kos/Resource/OperationalState/Down> a skos:Concept ; skos:inScheme <kos/Resource/OperationalState> ; rdfs:label "Down Operational State"@en ; rdfs:comment "Resource is not operational."@en .

<kos/Resource/AdministrativeState> a skos:ConceptScheme ; rdfs:label "Resource Administrative State Scheme"@en .
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ; skos:inScheme <kos/Resource/AdministrativeState> ; rdfs:label "Enabled Administrative State"@en ; rdfs:comment "Network interface is administratively enabled."@en .
<kos/Resource/AdministrativeState/Disabled> a skos:Concept ; skos:inScheme <kos/Resource/AdministrativeState> ; rdfs:label "Disabled Administrative State"@en ; rdfs:comment "Network interface is administratively disabled."@en .

<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ; rdfs:label "Perceived Severity Scheme"@en .
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Critical Perceived Severity"@en ; rdfs:comment "Highest perceived severity for an event."@en .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Major Perceived Severity"@en ; rdfs:comment "High perceived severity for an event."@en .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Minor Perceived Severity"@en ; rdfs:comment "Low perceived severity for an event."@en .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; skos:inScheme <Notification/Severity/PerceivedSeverity> ; rdfs:label "Warning Perceived Severity"@en ; rdfs:comment "Warning perceived severity for an event."@en .

<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Category Scheme"@en .
<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ; skos:inScheme <kos/TroubleTicket/trouble-category> ; rdfs:label "Network Outage Category"@en ; rdfs:comment "Category for network-related service interruptions."@en .
<kos/TroubleTicket/trouble-category/ServerFailure> a skos:Concept ; skos:inScheme <kos/TroubleTicket/trouble-category> ; rdfs:label "Server Failure Category"@en ; rdfs:comment "Category for server hardware or software failures."@en .

<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ; rdfs:label "Problem Responsibility Scheme"@en .
<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ; skos:inScheme <kos/TroubleTicket/problemResponsibility> ; rdfs:label "Internal IT Responsibility"@en ; rdfs:comment "Responsibility lies with the internal IT department."@en .
<kos/TroubleTicket/problemResponsibility/Vendor> a skos:Concept ; skos:inScheme <kos/TroubleTicket/problemResponsibility> ; rdfs:label "Vendor Responsibility"@en ; rdfs:comment "Responsibility lies with an external vendor."@en .

<kos/TroubleTicket/urgency> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Urgency Scheme"@en .
<kos/TroubleTicket/urgency/Immediate> a skos:Concept ; skos:inScheme <kos/TroubleTicket/urgency> ; rdfs:label "Immediate Intervention Urgency"@en ; rdfs:comment "Requires immediate attention and action."@en .
<kos/TroubleTicket/urgency/Deferred> a skos:Concept ; skos:inScheme <kos/TroubleTicket/urgency> ; rdfs:label "Deferred Intervention Urgency"@en ; rdfs:comment "Can be addressed at a later scheduled time."@en .

<kos/service/type> a skos:ConceptScheme ; rdfs:label "Service Type Scheme"@en .
<kos/service/type/CustomerFacingService> a skos:Concept ; skos:inScheme <kos/service/type> ; rdfs:label "Customer Facing Service"@en ; rdfs:comment "Service directly consumed by customers."@en .
<kos/service/type/ResourceFacingService> a skos:Concept ; skos:inScheme <kos/service/type> ; rdfs:label "Resource Facing Service"@en ; rdfs:comment "Service that supports other services or internal operations."@en .

<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ; rdfs:label "Application Module SLA Level Scheme"@en .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ; rdfs:label "Gold SLA Level"@en ; rdfs:comment "Highest Service Level Agreement tier."@en .
<https://w3id.org/noria/kos/application/sla-level/Silver> a skos:Concept ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ; rdfs:label "Silver SLA Level"@en ; rdfs:comment "Mid-tier Service Level Agreement."@en .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person)
# =============================================================================

org:TechCorp a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "A leading technology company providing innovative solutions."@en .

noria:CRM_OperationsTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "CRM Operations Team"@en ;
    rdfs:comment "Team responsible for the daily operation and maintenance of the CRM application."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ; # Assuming this concept exists or can be created
    noria:agentInstructions "For critical issues, use the dedicated hotline. For non-critical, open a ticket."@en ;
    org:member noria:JohnDoe, noria:JaneSmith ;
    org:unitOf org:TechCorp .

noria:L2_SupportTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "L2 Support Team"@en ;
    rdfs:comment "Second-level support team for IT infrastructure and applications."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate P1/P2 incidents immediately via phone, P3/P4 via ticketing system."@en ;
    org:unitOf org:TechCorp .

noria:Network_EngineeringTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Team responsible for designing, implementing, and maintaining the corporate network infrastructure."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact for network design changes or complex routing issues."@en ;
    org:unitOf org:TechCorp .

noria:JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "CRM Application Administrator."@en ;
    foaf:mbox <mailto:john.doe@techcorp.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox <mailto:jane.smith@techcorp.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:ServerVendor a org:Organization, foaf:Agent ;
    rdfs:label "Server Solutions Inc."@en ;
    rdfs:comment "External vendor providing server hardware and support."@en .

noria:MonitoringSystemAdmin a foaf:Person, foaf:Agent ;
    rdfs:label "Monitoring System Admin"@en ;
    rdfs:comment "Administrator for the central monitoring system."@en ;
    foaf:mbox <mailto:monitor.admin@techcorp.com> .

noria:JohnDoeCUid a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Unique corporate identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "jdoe-12345" ;
    foaf:holdsAccount noria:JohnDoe .

# =============================================================================
# Product Models
# =============================================================================

noria:DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model from Dell."@en ;
    noria:productManufacturedBy noria:DellTechnologies .

noria:CiscoCatalyst9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch series from Cisco."@en ;
    noria:productManufacturedBy noria:CiscoSystems .

noria:HPProLiantDL380 a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380"@en ;
    rdfs:comment "Versatile rack server model from HP."@en ;
    noria:productManufacturedBy noria:HPE .

noria:DellTechnologies a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria:CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "American multinational technology conglomerate corporation that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

noria:HPE a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "American multinational enterprise information technology company."@en .

# =============================================================================
# Location (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria:MainDataCenter a bot:Site ;
    rdfs:label "TechCorp Main Data Center"@en ;
    rdfs:comment "Primary data center facility for TechCorp operations."@en ;
    noria:siteId "DC-MAIN-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 TechCorp Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001" ;
    noria:sitePrincipalAddressCountry "US"@en .

noria:ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Main Data Center."@en ;
    bot:hasSpace noria:Rack1, noria:Rack2 ;
    bot:hasElement noria:MainDataCenter . # Assuming bot:hasElement can link a room to a site

noria:Rack1 a noria:Locus ;
    rdfs:label "Rack 1 in Server Room A"@en ;
    rdfs:comment "Physical rack for hosting servers and network equipment."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasElement noria:ServerRoomA .

noria:Rack2 a noria:Locus ;
    rdfs:label "Rack 2 in Server Room A"@en ;
    rdfs:comment "Physical rack for hosting servers and network equipment."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasElement noria:ServerRoomA .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:PhyServer01 a noria:Resource ;
    rdfs:label "Physical Server 01"@en ;
    rdfs:comment "Physical host for virtual machines, running CRM database."@en ;
    noria:resourceHostName "phy-server-01.techcorp.com"@en ;
    noria:resourceLogisticId "ASSET-PS01-2023" ;
    noria:resourceProductModel noria:DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-PS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:L2_SupportTeam ;
    noria:locatedAtLocus noria:Rack1 ;
    noria:resourceManagementIPAddress "10.0.0.101" .

noria:PhyServer02 a noria:Resource ;
    rdfs:label "Physical Server 02"@en ;
    rdfs:comment "Physical host for virtual machines, running CRM application servers."@en ;
    noria:resourceHostName "phy-server-02.techcorp.com"@en ;
    noria:resourceLogisticId "ASSET-PS02-2023" ;
    noria:resourceProductModel noria:HPProLiantDL380 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-PS02-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:L2_SupportTeam ;
    noria:locatedAtLocus noria:Rack1 ;
    noria:resourceManagementIPAddress "10.0.0.102" .

noria:VMCrmDb01 a noria:Resource ;
    rdfs:label "CRM Database VM 01"@en ;
    rdfs:comment "Virtual machine hosting the primary CRM database instance."@en ;
    noria:resourceHostName "vm-crm-db-01.techcorp.com"@en ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy noria:CRM_OperationsTeam ;
    noria:resourceForApplication noria:CRMApplication ;
    seas:subSystemOf noria:PhyServer01 ; # VM runs on physical server
    noria:resourceManagementIPAddress "10.0.1.10" .

noria:VMCrmApp01 a noria:Resource ;
    rdfs:label "CRM Application VM 01"@en ;
    rdfs:comment "Virtual machine hosting a CRM application server instance."@en ;
    noria:resourceHostName "vm-crm-app-01.techcorp.com"@en ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
