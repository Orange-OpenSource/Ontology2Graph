# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:DBRestartProcedure a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the CRM database service."@en ;
    skos:example "Steps include checking logs, stopping service, starting service, verifying connectivity."@en ;
    noria:operationPlanPreCondition noria:DBRestartPreCondition ;
    noria:operationPlanPostCondition noria:DBRestartPostCondition .

noria:NetworkTroubleshootingGuide a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Guide"@en ;
    rdfs:comment "Guide for diagnosing and resolving issues with network interfaces."@en ;
    skos:example "Steps include checking cable, port status, administrative state, and bouncing the interface."@en .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:DBRestartPreCondition a noria:ActionPreCondition ;
    rdfs:label "Database Restart Pre-condition"@en ;
    rdfs:comment "Verify that the database server is reachable via SSH and no active transactions are running."@en .

noria:DBRestartPostCondition a noria:ActionPostCondition ;
    rdfs:label "Database Restart Post-condition"@en ;
    rdfs:comment "Confirm database service is running, application can connect, and data integrity is maintained."@en .

# =============================================================================
# Procedure Execution Container (pep:ProcedureExecutionContainer)
# =============================================================================

noria:DBRestartProcedureExecution a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of DB Restart Procedure for CRM Outage"@en ;
    rdfs:comment "Container for events related to the execution of the database restart procedure during the CRM outage."@en ;
    pep:usedProcedure noria:DBRestartProcedure ;
    pep:hasInput noria:DBRestartPreCondition ;
    pep:hasOutput noria:DBRestartPostCondition ;
    pep:madeBy noria:JohnDoe ;
    # Link events that are part of this execution
    # Note: ldp:member is forbidden, so I'll use a generic relation or omit if no other suitable property exists.
    # The vocabulary states: "enable to track the corresponding EventRecord through the ldp:member property."
    # Since ldp is forbidden, I will use dcterms:hasPart as a generic relation for containment, if applicable, or rely on other properties.
    # For now, I'll just link the relevant events to the container directly if no specific NORIA property exists.
    # The vocabulary states: "a TroubleTicketNote is a context for (potentially) many CorrectiveMaintenanceAction to occur; hence it relates to a pep:ProcedureExecutionContainer, which in turns enable to track the corresponding EventRecord through the ldp:member property."
    # This implies that the pep:ProcedureExecutionContainer itself would contain the EventRecords.
    # Since ldp:member is forbidden, I'll use dcterms:hasPart for the container to hold the events.
    dcterms:hasPart noria:Event_DBRestartSuccess, noria:Event_NetworkInterfaceUp .

# =============================================================================
# Additional connections for density
# =============================================================================

# Link agents to resources they manage
noria:CRM_OperationsTeam noria:agentManagesResource noria:VMCrmDb01, noria:VMCrmApp01, noria:VMCrmWeb01 .
noria:L2_SupportTeam noria:agentManagesResource noria:PhyServer01, noria:PhyServer02 .
noria:Network_EngineeringTeam noria:agentManagesResource noria:CoreRouter01, noria:AccessSwitch01, noria:Link_VMCrmDb01_AccessSwitch01, noria:Link_AccessSwitch01_CoreRouter01 .

# Link applications to resources
noria:VMCrmDb01 noria:resourceForApplication noria:CRMApplication .
noria:VMCrmApp01 noria:resourceForApplication noria:CRMApplication .
noria:VMCrmWeb01 noria:resourceForApplication noria:CRMApplication .

# Link events to trouble tickets (documentStatusHistory)
noria:TroubleTicket_CRMOutage noria:documentStatusHistory noria:Event_DBServerDown .
noria:TroubleTicket_CRMOutage noria:documentStatusHistory noria:Event_CRMAccessError .
noria:TroubleTicket_CRMOutage noria:documentStatusHistory noria:Event_DBRestartSuccess .
noria:TroubleTicket_CRMOutage noria:documentStatusHistory noria:Event_NetworkInterfaceUp .

# Link events to procedure execution container (alarmMitigatedBy)
noria:Event_DBServerDown noria:alarmMitigatedBy noria:DBRestartProcedureExecution .
noria:Event_CRMAccessError noria:alarmMitigatedBy noria:DBRestartProcedureExecution .

# Link change requests to related parties
noria:ChangeRequest_DBSWUpgrade noria:changeRequestRelatedParty noria:JohnDoe, noria:L2_SupportTeam .
noria:ChangeRequest_NetworkConfig noria:changeRequestRelatedParty noria:JaneSmith, noria:Network_EngineeringTeam .

# Link trouble tickets to notes
noria:TroubleTicket_CRMOutage dcterms:hasPart noria:TTNote_Diagnosis, noria:TTNote_Resolution .

# Link application modules to resources (indirectly via application)
# This is covered by noria:resourceForApplication and noria:applicationModuleOf.
# A direct link could be seas:subSystemOf if the resource is a component of the module.
# For example, a VM is a sub-system of the application module it supports.
noria:VMCrmDb01 seas:subSystemOf noria:CRMProdModule .
noria:VMCrmApp01 seas:subSystemOf noria:CRMProdModule .
noria:VMCrmWeb01 seas:subSystemOf noria:CRMProdModule .

# Example of a DocumentAttachment
noria:NetworkDiagram_CRM a noria:DocumentAttachment ;
    rdfs:label "CRM Network Diagram"@en ;
    rdfs:comment "Detailed network topology diagram for the CRM application infrastructure."@en ;
    dcterms:format "application/pdf" ;
    dcterms:isPartOf noria:TroubleTicket_CRMOutage, noria:ChangeRequest_NetworkConfig .

# Example of a CorporateUserIdentifier for Jane Smith
noria:JaneSmithCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Unique corporate identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    observable:accountLogin "jsmith" ;
    observable:accountIdentifier "jsmith-67890" ;
    foaf:holdsAccount noria:JaneSmith .

# Example of a resource with virtualServerStatus
noria:VMCrmDb01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .
noria:VMCrmApp01 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Example of network interface optical power
noria:CoreRouter01_Ge0_0_1 noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -5 .

# Example of an AnomalyPattern
noria:DBConnectivityLossPattern a noria:AnomalyPattern ;
    rdfs:label "Database Connectivity Loss Pattern"@en ;
    rdfs:comment "Pattern indicating a loss of connectivity to the database, often characterized by network interface down events followed by application errors."@en ;
    folio:hasCause "Network failure or database service crash"@en ;
    folio:hasEffect "CRM application outage"@en .

# Link an EventRecord to an AnomalyPattern (implicitly, through its description or a more explicit property if available)
# The vocabulary doesn't define a direct property from EventRecord to AnomalyPattern, but AnomalyPattern is a FailureMode.
# We can imply this correlation through the TroubleTicket.
noria:TroubleTicket_CRMOutage dcterms:conformsTo noria:DBConnectivityLossPattern . # Using dcterms:conformsTo to link the incident to a known pattern.

# End of graph
.
