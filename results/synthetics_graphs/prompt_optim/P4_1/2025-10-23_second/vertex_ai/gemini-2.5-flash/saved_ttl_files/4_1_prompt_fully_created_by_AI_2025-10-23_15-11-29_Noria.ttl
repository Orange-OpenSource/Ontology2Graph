<kos/Resource/LifecycleState/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Staging> a skos:Concept ; skos:prefLabel "Staging Environment"@en ; skos:inScheme <kos/Resource/LifecycleState> .
