<kos/org/agent-contact-method/Chat> a skos:Concept ; skos:prefLabel "Chat Contact Method"@en ; skos:inScheme <kos/org/agent-contact-method> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, call the hotline after hours."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:comment "24/7 team monitoring network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Open a P1 ticket for any network outage."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Team responsible for critical business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for quick queries, ticketing system for incidents."@en .

foaf:Agent4 a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Lead Engineer for DNS Infrastructure."@en ;
    foaf:mbox "mailto:alice.johnson@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent5 a foaf:Person ;
    rdfs:label "Bob Williams"@en ;
    rdfs:comment "NOC Shift Supervisor."@en ;
    foaf:mbox "mailto:bob.williams@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

org:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "Infrastructure Department"@en ;
    rdfs:comment "Department managing all IT infrastructure."@en ;
    org:hasMember foaf:Agent4 .

org:OrgUnit2 a org:OrganizationalUnit ;
    rdfs:label "Core Network Team"@en ;
    rdfs:comment "Team responsible for the core network backbone."@en ;
    org:hasMember foaf:Agent5 .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel1 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for DNS."@en ;
    noria:productManufacturedBy org:ManufacturerDell .

noria:ProductModel2 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Cisco network switch model."@en ;
    noria:productManufacturedBy org:ManufacturerCisco .

noria:ProductModel3 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Juniper router model for edge routing."@en ;
    noria:productManufacturedBy org:ManufacturerJuniper .

org:ManufacturerDell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of servers and IT equipment."@en .

org:ManufacturerCisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

org:ManufacturerJuniper a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of networking products."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site1 a bot:Site ;
    rdfs:label "Main Data Center Paris"@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@fr ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

bot:Site2 a bot:Site ;
    rdfs:label "Regional Office Lyon"@en ;
    noria:siteId "RO-LYO-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès"@fr ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room1 a noria:Room ;
    rdfs:label "Server Room A01"@en ;
    rdfs:comment "Primary server room in Main Data Center Paris."@en ;
    bot:hasSpace bot:Site1 .

noria:Room2 a noria:Room ;
    rdfs:label "Network Equipment Room B02"@en ;
    rdfs:comment "Network core equipment room in Main Data Center Paris."@en ;
    bot:hasSpace bot:Site1 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack R12, Unit 23"@en ;
    rdfs:comment "Specific location for DNS server in Server Room A01."@en ;
    noria:locusLine "R12" ;
    noria:locusRow "23" ;
    bot:hasSpace noria:Room1 .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack N05, Unit 10"@en ;
    rdfs:comment "Specific location for Core Router in Network Equipment Room B02."@en ;
    noria:locusLine "N05" ;
    noria:locusRow "10" ;
    bot:hasSpace noria:Room2 .

noria:Locus3 a noria:Locus ;
    rdfs:label "Virtual Host Cluster A"@en ;
    rdfs:comment "Logical location for virtual machines."@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource1 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-R740-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource2 a noria:Resource ;
    rdfs:label "Core Router R01"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy foaf:Agent2 ;
    noria:resourceHostName "cr01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel3 ;
    noria:resourceLogisticId "LOG-CR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-MX204-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application2 ;
    noria:locatedAtLocus noria:Locus2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource3 a noria:Resource ;
    rdfs:label "Virtual Web Server 01"@en ;
    rdfs:comment "Virtual machine hosting the main corporate website."@en ;
    noria:resourceManagedBy foaf:Agent3 ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application3 ;
    noria:locatedAtLocus noria:Locus3 ;
    noria:clusterController noria:Resource4 .

noria:Resource4 a noria:Resource ;
    rdfs:label "VMware vCenter Server"@en ;
    rdfs:comment "Cluster controller for virtual machines."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "vcenter.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application4 .

noria:Resource5 a noria:Resource ;
    rdfs:label "Corporate DNS Server 02"@en ;
    rdfs:comment "Secondary DNS server for corporate network."@en ;
    noria:resourceManagedBy foaf:Agent1 ;
    noria:resourceHostName "dns02.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel1 ;
    noria:resourceLogisticId "LOG-DNS-002" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-R740-002" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application1 ;
    noria:locatedAtLocus noria:Locus1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.11> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface1 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on dns01"@en ;
    rdfs:comment "Physical interface for DNS server 01."@en ;
    noria:networkInterfaceOf noria:Resource1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface2 a noria:NetworkInterface ;
