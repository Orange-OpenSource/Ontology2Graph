<kos/TroubleTicket/operationType/Verification> a skos:Concept ; skos:prefLabel "Verification Operation"@en ; skos:inScheme <kos/TroubleTicket/operationType> .

# ChangeRequest Category
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; skos:prefLabel "Software Upgrade"@en ; skos:inScheme <kos/ChangeRequest/category> .
<kos/ChangeRequest/category/Configuration> a skos:Concept ; skos:prefLabel "Configuration Change"@en ; skos:inScheme <kos/ChangeRequest/category> .
<kos/ChangeRequest/category/HardwareReplacement> a skos:Concept ; skos:prefLabel "Hardware Replacement"@en ; skos:inScheme <kos/ChangeRequest/category> .

# ChangeRequest Type
