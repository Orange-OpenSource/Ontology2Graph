# Base URI for NORIA instances
@base <https://w3id.org/noria/data/> .

# =============================================================================
# SKOS Concepts for controlled vocabularies
# =============================================================================

# Application Types
<kos/application/type/infrastructure> a skos:Concept ; skos:prefLabel "Infrastructure Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/business-critical> a skos:Concept ; skos:prefLabel "Business Critical Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; skos:prefLabel "Monitoring Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/database> a skos:Concept ; skos:prefLabel "Database Application"@en ; skos:inScheme <kos/application/type> .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ; skos:prefLabel "High Business Importance"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; skos:prefLabel "Medium Business Importance"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/low> a skos:Concept ; skos:prefLabel "Low Business Importance"@en ; skos:inScheme <kos/application/business-importance> .

# Application Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; skos:prefLabel "In Production"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; skos:prefLabel "Development"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Staging> a skos:Concept ; skos:prefLabel "Staging"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

# TroubleTicket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ; skos:prefLabel "Critical Severity"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; skos:prefLabel "Major Severity"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; skos:prefLabel "Minor Severity"@en ; skos:inScheme <kos/TroubleTicket/severity> .

# TroubleTicket Type
<kos/TroubleTicket/type/Incident> a skos:Concept ; skos:prefLabel "Incident Ticket"@en ; skos:inScheme <kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Problem> a skos:Concept ; skos:prefLabel "Problem Ticket"@en ; skos:inScheme <kos/TroubleTicket/type> .

# TroubleTicket Priority
<kos/TroubleTicket/priority/P1> a skos:Concept ; skos:prefLabel "Priority 1"@en ; skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P2> a skos:Concept ; skos:prefLabel "Priority 2"@en ; skos:inScheme <kos/TroubleTicket/priority> .
<kos/TroubleTicket/priority/P3> a skos:Concept ; skos:prefLabel "Priority 3"@en ; skos:inScheme <kos/TroubleTicket/priority> .

# TroubleTicket Origin
<kos/TroubleTicket/origin/Customer> a skos:Concept ; skos:prefLabel "Customer Origin"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; skos:prefLabel "Supervision System Origin"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Internal> a skos:Concept ; skos:prefLabel "Internal Origin"@en ; skos:inScheme <kos/TroubleTicket/origin> .

# TroubleTicket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; skos:prefLabel "Immediate Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; skos:prefLabel "Deferred Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .

# TroubleTicket Trouble Category
<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ; skos:prefLabel "Network Outage"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/trouble-category/ServerFailure> a skos:Concept ; skos:prefLabel "Server Failure"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/trouble-category/ApplicationError> a skos:Concept ; skos:prefLabel "Application Error"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .

# TroubleTicket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/NetworkTeam> a skos:Concept ; skos:prefLabel "Network Team Responsibility"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/ApplicationTeam> a skos:Concept ; skos:prefLabel "Application Team Responsibility"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/Vendor> a skos:Concept ; skos:prefLabel "Vendor Responsibility"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .

# TroubleTicket Status
<kos/TroubleTicket/status/InProgress> a skos:Concept ; skos:prefLabel "In Progress"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; skos:prefLabel "Resolved"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ; skos:prefLabel "Closed"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/New> a skos:Concept ; skos:prefLabel "New"@en ; skos:inScheme <kos/TroubleTicket/status> .

# TroubleTicket Note Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; skos:prefLabel "Internal Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; skos:prefLabel "Customer Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .

