    dcterms:identifier "CR01-Upgrade-Plan.docx" .

# =============================================================================
# Additional Interconnections for Density
# =============================================================================

# Agents managing multiple resources/applications
foaf:Agent1 noria:agentManagesResource noria:Resource5 .
foaf:Agent2 noria:agentManagesResource noria:Resource6 .
foaf:Agent3 noria:agentManagesResource noria:Resource3 .

# Resources supporting multiple applications/modules
noria:Resource1 noria:resourceForApplication noria:ApplicationModule1 .
noria:Resource5 noria:resourceForApplication noria:ApplicationModule1 .
noria:Resource3 noria:resourceForApplication noria:ApplicationModule2 .
noria:Resource3 noria:resourceForApplication noria:ApplicationModule3 .

# Applications having multiple modules
noria:Application1 seas:subSystem noria:ApplicationModule1 .
noria:Application2 seas:subSystem noria:ApplicationModule2 .
noria:Application3 seas:subSystem noria:ApplicationModule3 .

# Services composed of multiple applications/resources
noria:Service1 seas:subSystem noria:Resource1 .
noria:Service1 seas:subSystem noria:Resource5 .
noria:Service2 seas:subSystem noria:Resource4 .

# Trouble tickets impacting multiple entities
noria:TroubleTicket1 noria:troubleTicketImpacts noria:NetworkLink1 .
noria:TroubleTicket1 noria:troubleTicketImpacts noria:NetworkLink3 .
noria:TroubleTicket2 noria:troubleTicketImpacts noria:ApplicationModule2 .

# Change requests impacting multiple entities
noria:ChangeRequest1 noria:changeRequestImpact noria:NetworkInterface2 .
noria:ChangeRequest2 noria:changeRequestImpact noria:NetworkInterface3 .

# Event records related to multiple entities
noria:EventRecord1 noria:alarmMonitoredAttribute noria:NetworkInterface1 .
noria:EventRecord2 noria:alarmMonitoredAttribute noria:Resource2 .

# Example of a Corporate User Identifier
noria:CUid1 a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Johnson's Corporate ID"@en ;
    foaf:accountName "ajohnson" ;
    observable:accountLogin "ajohnson" ;
    observable:accountIdentifier "ajohnson@example.com" ;
    foaf:holdsAccount foaf:Agent4 .

noria:CUid2 a noria:CorporateUserIdentifier ;
    rdfs:label "Bob Williams's Corporate ID"@en ;
    foaf:accountName "bwilliams" ;
    observable:accountLogin "bwilliams" ;
    observable:accountIdentifier "bwilliams@example.com" ;
    foaf:holdsAccount foaf:Agent5 .

# Example of a more complex EventRecord chain for a status history
noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "TT1 Status Change: InProgress"@en ;
    noria:loggingTime "2024-04-20T09:08:00Z"^^xsd:dateTime ;
