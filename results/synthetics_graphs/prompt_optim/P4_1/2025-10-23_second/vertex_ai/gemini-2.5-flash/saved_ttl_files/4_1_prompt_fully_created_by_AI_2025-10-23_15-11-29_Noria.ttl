noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Server 01 Interface Down Alert"@en ;
    rdfs:comment "Alert indicating that a network interface on DNS Server 01 went down."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application5 ; # Assuming Application5 is a Monitoring System
    noria:logText "Interface GigabitEthernet0/0/1 on dns01.corp.example.com changed state to down."@en ;
    dcterms:type <kos/Notification/EventType/alarm> ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan1 .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "Core Router R01 CPU Usage High"@en ;
    rdfs:comment "Warning about high CPU utilization on Core Router R01."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application5 ;
    noria:logText "CPU usage on cr01.corp.example.com exceeded 80% for 5 minutes."@en ;
    dcterms:type <kos/Notification/EventType/alarm> ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "User Login Failure"@en ;
    rdfs:comment "Failed login attempt on a critical system."@en ;
    noria:loggingTime "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application6 ; # Assuming Application6 is a Security Monitoring System
    noria:logOriginatingAgent foaf:Agent6 ; # Assuming Agent6 is a malicious actor or a user with wrong credentials
    noria:logText "Failed login for user 'jdoe' from IP 1.2.3.4 on web01.corp.example.com."@en ;
    dcterms:type <kos/Notification/EventType/securityAlert> ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "DNS Server 01 Interface Up Confirmation"@en ;
    rdfs:comment "Confirmation that network interface on DNS Server 01 is back up."@en ;
    noria:loggingTime "2024-04-20T09:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application5 ;
    noria:logText "Interface GigabitEthernet0/0/1 on dns01.corp.example.com changed state to up."@en ;
    dcterms:type <kos/Notification/EventType/stateChange> ;
    noria:alarmSeverity <kos/Notification/Severity/PerceivedSeverity/Minor> .

noria:Application5 a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "System for monitoring network devices and services."@en ;
    noria:applicationType <kos/application/type/monitoring> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> .

noria:Application6 a noria:Application ;
