# =============================================================================
# Operation Plans, Pre/Post Conditions (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "Network Interface Reactivation Procedure"@en ;
    rdfs:comment "Standard operating procedure to reactivate a down network interface."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Core Router Software Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading software on Juniper MX series routers."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "Interface Down Pre-Condition"@en ;
    rdfs:comment "Network interface is in an 'administratively up' but 'operationally down' state."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "Interface Up Post-Condition"@en ;
    rdfs:comment "Network interface is in both 'administratively up' and 'operationally up' states, and traffic is flowing."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Router Upgrade Pre-Condition"@en ;
    rdfs:comment "Router is in a maintenance window, backup configuration saved, and redundant path is active."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Router Upgrade Post-Condition"@en ;
    rdfs:comment "Router software version is updated, all interfaces are up, and routing protocols are converged."@en .

# Link ChangeRequest to OperationPlan
noria:ChangeRequest1 noria:actionCorrelatedOperationPlan noria:OperationPlan2 .

