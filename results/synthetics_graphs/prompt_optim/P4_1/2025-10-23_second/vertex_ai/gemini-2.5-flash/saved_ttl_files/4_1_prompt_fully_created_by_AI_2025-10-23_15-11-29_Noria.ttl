    dcterms:creator foaf:Agent5 ;
    dcterms:isPartOf noria:TroubleTicket1 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Resolution> ;
    noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecution1 . # Assuming ProcedureExecution1 is a pep:ProcedureExecutionContainer

noria:TroubleTicketNote3 a noria:TroubleTicketNote ;
