    rdfs:comment "Agent handling customer communications."@en .

noria:ProcedureExecution1 a pep:ProcedureExecutionContainer ;
    rdfs:label "Interface Reactivation Procedure Execution"@en ;
    rdfs:comment "Execution of commands to bring up a network interface."@en ;
    dcterms:created "2024-04-20T09:35:00Z"^^xsd:dateTime ;
    pep:hasProcedure noria:OperationPlan1 ;
    pep:madeBy foaf:Agent5 .

