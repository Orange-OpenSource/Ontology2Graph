    noria:logText "Status of TT-20240423-001 changed from InProgress to Resolved."@en ;
    noria:logOriginatingManagementSystem <http://ticketing.example.com/system> ; # Assuming a ticketing system as an application
    noria:logOriginatingAgent foaf:Person1 .

<http://ticketing.example.com/system> a noria:Application ;
    rdfs:label "Ticketing System"@en ;
    rdfs:comment "The application used for managing trouble tickets and change requests."@en ;
    noria:applicationType <kos/application/type/business> .

# Link ChangeRequest to EventRecord for status history
noria:ChangeRequest2 noria:documentStatusHistory noria:EventRecord8 .

noria:EventRecord8 a noria:EventRecord ;
    rdfs:label "Change Request Status Change to Implemented"@en ;
    rdfs:comment "Log entry indicating the status of ChangeRequest2 changed to Implemented."@en ;
    noria:loggingTime "2024-04-20T18:25:00Z"^^xsd:dateTime ;
