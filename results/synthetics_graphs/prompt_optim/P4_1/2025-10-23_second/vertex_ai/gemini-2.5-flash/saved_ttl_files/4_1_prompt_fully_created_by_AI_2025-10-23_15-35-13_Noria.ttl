# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "DNS Service Down Alert"@en ;
    rdfs:comment "Automated alert indicating that the corporate DNS service is unreachable."@en ;
    noria:loggingTime "2024-04-23T09:00:00Z"^^xsd:dateTime ;
    noria:logText "DNS service on dns01.corp.example.com is not responding to queries."@en ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "High CPU Usage on Web Server"@en ;
    rdfs:comment "Monitoring alert for sustained high CPU utilization on the web application server."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU usage on webapp01.example.com exceeded 90% for 15 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "Interface Down Log - Gi0/0/1"@en ;
    rdfs:comment "Log entry from Core Router 01 indicating an interface went down."@en ;
    noria:loggingTime "2024-04-23T08:58:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "Security Alert - Failed Login Attempts"@en ;
    rdfs:comment "Alert from firewall indicating multiple failed login attempts to a critical system."@en ;
    noria:loggingTime "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:logText "50 failed SSH login attempts from IP 203.0.113.42 to dns01.corp.example.com."@en ;
    noria:logOriginatingManagedObject noria:Resource5 ; # Firewall detected it
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logOriginatingAgent <http://example.com/ip/203.0.113.42> ; # Attacker IP as an agent
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

<http://example.com/ip/203.0.113.42> a foaf:Agent ;
    rdfs:label "Malicious IP Address"@en ;
    rdfs:comment "An external IP address identified as a source of security incidents."@en .

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "Configuration Change Log - Core Router 01"@en ;
    rdfs:comment "Log entry indicating a configuration change was applied to Core Router 01."@en ;
    noria:loggingTime "2024-04-22T15:00:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by vty0 (10.0.0.5)."@en ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logOriginatingAgent foaf:Person1 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

