    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/1, changed state to up."@en ;
    noria:logOriginatingManagedObject noria:Resource2 ;
    noria:logOriginatingManagementSystem noria:Application4 ;
    noria:logOriginatingAgent foaf:Person1 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

# Connect applications to resources they use
