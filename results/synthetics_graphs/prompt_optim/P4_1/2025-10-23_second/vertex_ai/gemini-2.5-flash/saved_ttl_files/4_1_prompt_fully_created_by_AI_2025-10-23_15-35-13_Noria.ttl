    noria:troubleTicketRelatedParty foaf:Agent2 ;
    noria:troubleTicketTrigger noria:EventRecord3 ;
    noria:troubleTicketDetectionDateTime "2024-04-23T08:59:00Z"^^xsd:dateTime ;
    dcterms:created "2024-04-23T09:05:00Z"^^xsd:dateTime ;
    dcterms:identifier "TT-20240423-003" ;
    noria:documentHRef "http://ticketing.example.com/TT-20240423-003" .

