# =============================================================================

noria:TroubleTicketNote1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT-20240423-001"@en ;
    rdfs:comment "Initial investigation shows no local issues on DNS server. Suspecting network path."@en ;
    dcterms:created "2024-04-23T09:10:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person1 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ; # Assuming a KOS for operation types
    dcterms:isPartOf noria:TroubleTicket1 .

noria:TroubleTicketNote2 a noria:TroubleTicketNote ;
    rdfs:label "Resolution Steps for TT-20240423-001"@en ;
    rdfs:comment "Restarted DNS service. Verified connectivity. Service restored."@en ;
    dcterms:created "2024-04-23T09:55:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Person1 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/CorrectiveAction> ; # Assuming a KOS for operation types
    dcterms:isPartOf noria:TroubleTicket1 ;
    noria:troubleTicketNoteCorrelatedExecution <http://example.com/procedureExecution/dnsRestart> .

<http://example.com/procedureExecution/dnsRestart> a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS Service Restart Execution"@en ;
    rdfs:comment "Container for events related to the DNS service restart."@en ;
    pep:hasProcedure noria:OperationPlan1 ;
    pep:member noria:EventRecord6 . # Assuming EventRecord6 is the log of the restart command

noria:EventRecord6 a noria:EventRecord ;
    rdfs:label "DNS Service Restart Command Log"@en ;
    rdfs:comment "Log entry for the command executed to restart the DNS service."@en ;
    noria:loggingTime "2024-04-23T09:50:00Z"^^xsd:dateTime ;
    noria:logText "systemctl restart named.service executed by John Doe."@en ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingAgent foaf:Person1 .

noria:TroubleTicketNote3 a noria:TroubleTicketNote ;
    rdfs:label "Customer Update for TT-20240423-002"@en ;
    rdfs:comment "Informed customer that we are investigating the slowdown and will provide an update within 2 hours."@en ;
    dcterms:created "2024-04-23T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent5 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Customer> ;
    dcterms:isPartOf noria:TroubleTicket2 .

