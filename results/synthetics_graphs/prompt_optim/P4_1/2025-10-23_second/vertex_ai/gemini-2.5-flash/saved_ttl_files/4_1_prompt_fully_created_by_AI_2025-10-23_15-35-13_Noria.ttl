    noria:troubleTicketRelatedResource noria:Resource8 ;
    noria:troubleTicketRelatedParty foaf:Agent1 ;
    noria:troubleTicketDetectionDateTime "2024-04-24T11:00:00Z"^^xsd:dateTime ;
    dcterms:created "2024-04-24T11:05:00Z"^^xsd:dateTime ;
    dcterms:identifier "TT-20240424-004" ;
    noria:documentHRef "http://ticketing.example.com/TT-20240424-004" .

