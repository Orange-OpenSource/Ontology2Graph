# Link EventRecord to TroubleTicket for status history
noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord7 .

noria:EventRecord7 a noria:EventRecord ;
    rdfs:label "Trouble Ticket Status Change to Resolved"@en ;
    rdfs:comment "Log entry indicating the status of TroubleTicket1 changed to Resolved."@en ;
