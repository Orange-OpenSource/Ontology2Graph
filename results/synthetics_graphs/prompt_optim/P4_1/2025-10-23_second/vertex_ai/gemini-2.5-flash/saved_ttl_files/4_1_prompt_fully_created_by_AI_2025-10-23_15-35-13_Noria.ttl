    noria:troubleTicketRelatedParty foaf:Agent3, foaf:Agent4 ;
    noria:troubleTicketTrigger noria:EventRecord11 ;
    noria:troubleTicketDetectionDateTime "2024-04-24T14:30:30Z"^^xsd:dateTime ;
    dcterms:created "2024-04-24T14:35:00Z"^^xsd:dateTime ;
    dcterms:identifier "TT-20240424-005" ;
    noria:documentHRef "http://ticketing.example.com/TT-20240424-005" .

