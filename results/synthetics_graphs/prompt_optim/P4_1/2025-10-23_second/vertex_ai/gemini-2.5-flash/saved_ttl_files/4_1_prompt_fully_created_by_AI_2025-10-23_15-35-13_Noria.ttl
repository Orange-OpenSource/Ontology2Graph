    noria:troubleTicketRelatedResource noria:Resource3 ;
    noria:troubleTicketRelatedParty foaf:Agent3, foaf:Agent5 ;
    noria:troubleTicketTrigger noria:EventRecord2 ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    dcterms:created "2024-04-23T10:25:00Z"^^xsd:dateTime ;
    dcterms:identifier "TT-20240423-002" ;
    noria:documentHRef "http://ticketing.example.com/TT-20240423-002" .

noria:TroubleTicket3 a noria:TroubleTicket ;
    rdfs:label "Network Link Flapping - CR01 to DNS01"@en ;
    rdfs:comment "Intermittent connectivity issues detected on the link between Core Router 01 and DNS Server 01."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
