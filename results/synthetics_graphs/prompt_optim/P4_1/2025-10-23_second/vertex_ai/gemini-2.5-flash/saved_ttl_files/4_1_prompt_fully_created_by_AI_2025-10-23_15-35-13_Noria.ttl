noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS server service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Firewall Configuration Rollback Procedure"@en ;
    rdfs:comment "Procedure to revert firewall configuration to a previous known good state."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS service on dns01.corp.example.com is not responding to queries."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "DNS Service Reachable"@en ;
    rdfs:comment "Outcome: DNS service on dns01.corp.example.com is responding to queries, and internet access is restored."@en .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Network Connectivity Loss after Firewall Change"@en ;
    rdfs:comment "Condition: Loss of network connectivity to protected segments immediately following a firewall configuration change."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Network Connectivity Restored after Firewall Rollback"@en ;
    rdfs:comment "Outcome: Network connectivity to protected segments is restored after reverting firewall configuration."@en .

