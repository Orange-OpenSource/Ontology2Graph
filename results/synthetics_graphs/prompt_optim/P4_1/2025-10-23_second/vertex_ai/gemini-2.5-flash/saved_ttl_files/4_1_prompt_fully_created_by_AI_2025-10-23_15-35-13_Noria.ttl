    noria:logOriginatingManagementSystem <http://changemanagement.example.com/system> ;
    noria:logOriginatingAgent foaf:Agent4 .

<http://changemanagement.example.com/system> a noria:Application ;
    rdfs:label "Change Management System"@en ;
    rdfs:comment "The application used for managing change requests."@en ;
    noria:applicationType <kos/application/type/business> .

# Link an alarm to a proposed repair action
noria:EventRecord1 noria:alarmProposedRepairAction noria:OperationPlan1 .

# Link an alarm to its mitigation
noria:EventRecord3 noria:alarmMitigatedBy <http://example.com/procedureExecution/interfaceTroubleshooting> .

<http://example.com/procedureExecution/interfaceTroubleshooting> a pep:ProcedureExecutionContainer ;
    rdfs:label "Interface Troubleshooting Execution"@en ;
    rdfs:comment "Container for actions taken to troubleshoot and restore a network interface."@en ;
    pep:member noria:EventRecord9 .

noria:EventRecord9 a noria:EventRecord ;
    rdfs:label "Interface Up Log - Gi0/0/1"@en ;
    rdfs:comment "Log entry from Core Router 01 indicating an interface came up after troubleshooting."@en ;
