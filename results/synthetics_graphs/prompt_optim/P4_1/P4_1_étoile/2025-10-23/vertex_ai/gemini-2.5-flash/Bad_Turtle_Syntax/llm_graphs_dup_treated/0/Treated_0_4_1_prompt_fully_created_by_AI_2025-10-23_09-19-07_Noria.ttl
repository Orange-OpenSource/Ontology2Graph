    rdfs:comment "Specific location within Data Center A for network equipment."@en ;
    noria:locusLine "B2"@en ;
    noria:locusRow "10"@en .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01_extra_node_5 a noria:Resource ;
    rdfs:label "Corporate DNS Server_extra_node_5 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, physical host."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam_extra_node_5 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_5 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_5> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CoreDNS_extra_node_5 ;
    noria:locatedAtLocus noria:Locus_RackA1_U23_extra_node_5 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10_extra_node_5> .

noria:Resource_RouterCore1_extra_node_5 a noria:Resource ;
    rdfs:label "Core Router_extra_node_5 1"@en ;
    rdfs:comment "Main router for the corporate backbone network."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam_extra_node_5 ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000_extra_node_5 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTR01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_5> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CorporateInternetAccess_extra_node_5 ;
    noria:locatedAtLocus noria:Locus_RackB2_U10_extra_node_5 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1_extra_node_5> .

noria:Resource_VM_CustomerPortal_extra_node_5 a noria:Resource ;
    rdfs:label "Customer_extra_node_5 Portal VM"@en ;
    rdfs:comment "Virtual machine hosting the Customer_extra_node_5 Portal application."@en ;
    noria:resourceManagedBy noria:Agent_AppDevTeam_extra_node_5 ;
    noria:resourceHostName "vm-portal-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi_extra_node_5 ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/virtual-machine_extra_node_5> ;
    noria:resourceSerialNumber "VM-CP-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_5> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_CustomerPortal_extra_node_5 ;
    noria:locatedAtLocus noria:Locus_RackA1_U24_extra_node_5 ; # Assuming the VM runs on a host in this locus
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.50_extra_node_5> .

noria:Resource_SIEMServer_extra_node_5 a noria:Resource ;
    rdfs:label "SIEM Log Server_extra_node_5"@en ;
    rdfs:comment "Server_extra_node_5 dedicated to collecting and analyzing security logs."@en ;
    noria:resourceManagedBy noria:Agent_SecurityTeam_extra_node_5 ;
    noria:resourceHostName "siem-log-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_5 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-SIEM-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_5> ;
    noria:resourceInstallationDate "2023-01-20T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:Application_SIEM_extra_node_5 ;
    noria:locatedAtLocus noria:Locus_RackA1_U23_extra_node_5 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20_extra_node_5> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetworkInterface_DNS01_Eth0_extra_node_5 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on DNS01"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01_extra_node_5 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_5> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_5> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Management and DNS traffic interface."@en ;
    noria:networkInterfaceType "physical"@en .

noria:NetworkInterface_RouterCore1_Gi0_0_0_extra_node_5 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/0 on RouterCore1"@en ;
    rdfs:comment "Uplink interface from Core Router_extra_node_5 1 to ISP."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1_extra_node_5 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_5> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_5> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceDescription "ISP Uplink 1"@en ;
    noria:networkInterfaceType "physical"@en ;
    noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -5 .

noria:NetworkInterface_RouterCore1_Gi0_0_1_extra_node_5 a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on RouterCore1"@en ;
    rdfs:comment "Internal_extra_node_5 network interface from Core Router_extra_node_5 1 to corporate LAN."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1_extra_node_5 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_5> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_5> ;
    noria:networkInterfaceRoutingPriorityMetric 60 ;
    noria:networkInterfaceDescription "Corporate LAN connection"@en ;
    noria:networkInterfaceType "physical"@en .

noria:NetworkInterface_VM_Portal_Eth0_extra_node_5 a noria:NetworkInterface ;
    rdfs:label "Ethernet0 on Customer_extra_node_5 Portal VM"@en ;
    rdfs:comment "Virtual network interface for the Customer_extra_node_5 Portal VM."@en ;
    noria:networkInterfaceOf noria:Resource_VM_CustomerPortal_extra_node_5 ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_5> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_5> ;
    noria:networkInterfaceDescription "Application traffic interface."@en ;
    noria:networkInterfaceType "virtual"@en .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetworkLink_ISP_Uplink1_extra_node_5 a noria:NetworkLink ;
    rdfs:label "ISP Uplink 1 Link"@en ;
    rdfs:comment "Physical link connecting Core Router_extra_node_5 1 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-ISP-UPLINK1" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore1_extra_node_5 ; # One end of the link
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam_extra_node_5 .

noria:NetworkLink_LAN_Core1_DNS01_extra_node_5 a noria:NetworkLink ;
    rdfs:label "LAN Link Core1 to DNS01"@en ;
    rdfs:comment "Internal_extra_node_5 LAN link connecting Core Router_extra_node_5 1 to DNS01 server."@en ;
    noria:networkLinkId "NL-LAN-CORE1-DNS01" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore1_extra_node_5 ;
    noria:networkLinkTerminationResource noria:Resource_DNS01_extra_node_5 ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet"@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam_extra_node_5 .

noria:NetworkInterface_RouterCore1_Gi0_0_1_extra_node_5 noria:networkInterfaceConnects noria:NetworkLink_LAN_Core1_DNS01_extra_node_5 .
noria:NetworkInterface_DNS01_Eth0_extra_node_5 noria:networkInterfaceConnects noria:NetworkLink_LAN_Core1_DNS01_extra_node_5 .
noria:NetworkInterface_RouterCore1_Gi0_0_0_extra_node_5 noria:networkInterfaceConnects noria:NetworkLink_ISP_Uplink1_extra_node_5 .

