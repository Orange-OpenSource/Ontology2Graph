# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service_EnterpriseConnectivity_extra_node_5 a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing network connectivity to all enterprise locations and users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService_extra_node_5> .

noria:Service_CustomerFacingWeb_extra_node_5 a noria:Service ;
    rdfs:label "Customer_extra_node_5 Facing Web Service"@en ;
    rdfs:comment "Service encompassing all web applications directly accessible by customers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService_extra_node_5> .

# Linking Application Modules to Services (using seas:subSystemOf as suggested)
