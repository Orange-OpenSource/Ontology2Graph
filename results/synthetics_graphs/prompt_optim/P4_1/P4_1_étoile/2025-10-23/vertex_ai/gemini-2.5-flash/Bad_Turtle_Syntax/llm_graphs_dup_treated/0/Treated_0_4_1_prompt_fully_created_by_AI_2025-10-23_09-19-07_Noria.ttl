noria:ApplicationModule_CustomerPortal_Prod_extra_node_5 seas:subSystemOf noria:Service_CustomerFacingWeb_extra_node_5 .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_DNSOutageLog_extra_node_5 a noria:EventRecord ;
    rdfs:label "DNS Server_extra_node_5 Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN. Ping failed."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_5> ;
    noria:logOriginatingManagedObject noria:Resource_DNS01_extra_node_5 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem_extra_node_5 .

noria:EventRecord_RouterInterfaceDown_extra_node_5 a noria:EventRecord ;
    rdfs:label "Router_extra_node_5 Interface Down Alert"@en ;
    rdfs:comment "Alert indicating GigabitEthernet0/0/0 on Core Router_extra_node_5 1 went down."@en ;
    noria:loggingTime "2024-04-20T08:55:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_5> ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore1_extra_node_5 ;
    noria:logOriginatingManagementSystem noria:Application_NMS_extra_node_5 .

noria:EventRecord_LoginFailure_extra_node_5 a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on the Customer_extra_node_5 Portal VM."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:logText "Authentication failed for user 'baduser' from IP 203.0.113.42 on vm-portal-01."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_5> ;
    noria:logOriginatingManagedObject noria:Resource_VM_CustomerPortal_extra_node_5 ;
    noria:logOriginatingManagementSystem noria:Application_SIEM_extra_node_5 ;
    noria:logOriginatingAgent noria:Agent_ExternalAttacker_extra_node_5 .

noria:Application_MonitoringSystem_extra_node_5 a noria:Application ;
    rdfs:label "Infrastructure Monitoring System"@en ;
    rdfs:comment "Application responsible for monitoring IT infrastructure_extra_node_5 health."@en ;
    noria:applicationType <kos/application/type/monitoring-tool_extra_node_5> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high_extra_node_5> .

noria:Application_NMS_extra_node_5 a noria:Application ;
    rdfs:label "Network Management System"@en ;
    rdfs:comment "Application for managing and monitoring network devices."@en ;
    noria:applicationType <kos/application/type/network-management_extra_node_5> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high_extra_node_5> .

noria:Agent_ExternalAttacker_extra_node_5 a foaf:Agent ;
    rdfs:label "External Attacker"@en ;
    rdfs:comment "Hypothetical external entity attempting unauthorized access."@en .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TroubleTicket_DNSOutage_extra_node_5 a noria:TroubleTicket ;
    rdfs:label "Critical_extra_node_5 DNS Server_extra_node_5 Outage"@en ;
    rdfs:comment "Incident reported due to primary DNS server being unreachable, impacting internet access."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical_extra_node_5> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure_extra_node_5> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1_extra_node_5> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision_extra_node_5> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress_extra_node_5> ;
    noria:troubleTicketCause "Network connectivity loss to DNS server."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
