# Link DNS Admin Team to Core DNS Application
noria:Agent_DNSAdminTeam_extra_node_5 noria:agentManagesResource noria:Application_CoreDNS_extra_node_5 .

# Link Network Ops Team to Corporate Internet Access Application
noria:Agent_NetworkOpsTeam_extra_node_5 noria:agentManagesResource noria:Application_CorporateInternetAccess_extra_node_5 .

# Link App Dev Team to Customer Portal Application
noria:Agent_AppDevTeam_extra_node_5 noria:agentManagesResource noria:Application_CustomerPortal_extra_node_5 .

# Link John Doe to DNS Admin Team (as an organizational unit member, though foaf:Agent is used for both)
# For simplicity, I'll link John Doe directly to a resource he manages.
noria:Agent_JohnDoe_extra_node_5 noria:agentManagesResource noria:Resource_DNS01_extra_node_5 .

# Link Jane Smith to Customer Portal VM
noria:Agent_JaneSmith_extra_node_5 noria:agentManagesResource noria:Resource_VM_CustomerPortal_extra_node_5 .

