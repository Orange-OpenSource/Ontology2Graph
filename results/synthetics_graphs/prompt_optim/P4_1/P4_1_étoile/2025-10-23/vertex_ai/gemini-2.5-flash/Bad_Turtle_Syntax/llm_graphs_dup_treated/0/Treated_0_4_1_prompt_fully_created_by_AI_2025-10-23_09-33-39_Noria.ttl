# Network Interfaces
# =============================================================================

noria:NetIF_DNS01_Eth0_extra_node_7
    a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01_extra_node_7 ;
    noria:networkInterfaceConnects noria:NetLink_DC_Core_extra_node_7 ;
    noria:networkInterfaceDescription "Primary network interface for DNS service."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_7> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_7> .

noria:NetIF_RouterCore01_Gi0_0_1_extra_node_7
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal data center network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01_extra_node_7 ;
    noria:networkInterfaceConnects noria:NetLink_DC_Core_extra_node_7 ;
    noria:networkInterfaceDescription "Uplink to internal DC network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_7> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_7> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetIF_RouterCore01_Gi0_0_2_extra_node_7
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the DMZ network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01_extra_node_7 ;
    noria:networkInterfaceConnects noria:NetLink_DC_DMZ_extra_node_7 ;
    noria:networkInterfaceDescription "Link to DMZ firewall."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_7> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_7> .

noria:NetIF_FirewallDMZ_Eth1_extra_node_7
    a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ Ethernet 1"@en ;
    rdfs:comment "Interface for DMZ Firewall connected to the core router."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ_extra_node_7 ;
    noria:networkInterfaceConnects noria:NetLink_DC_DMZ_extra_node_7 ;
    noria:networkInterfaceDescription "Internal_extra_node_7 interface to core network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_7> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_7> .

noria:NetIF_WebSrv01_Eth0_extra_node_7
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Ethernet interface for WebSrv01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01_extra_node_7 ;
    noria:networkInterfaceConnects noria:NetLink_DC_Core_extra_node_7 ;
    noria:networkInterfaceDescription "Primary network interface for web application."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up_extra_node_7> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up_extra_node_7> .

# =============================================================================
# Network Links
# =============================================================================

noria:NetLink_DC_Core_extra_node_7
    a noria:NetworkLink ;
    rdfs:label "Data Center Core Link"@en ;
    rdfs:comment "High-speed link connecting core router to internal servers."@en ;
    noria:networkLinkId "LINK-DC-CORE-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01_extra_node_7 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DNS01_extra_node_7 ; # Example, could be multiple
    noria:networkLinkInstallationDate "2020-07-01T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" .

noria:NetLink_DC_DMZ_extra_node_7
    a noria:NetworkLink ;
    rdfs:label "Data Center DMZ Link"@en ;
    rdfs:comment "Link between core router and DMZ firewall."@en ;
    noria:networkLinkId "LINK-DC-DMZ-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01_extra_node_7 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_FirewallDMZ_extra_node_7 ;
    noria:networkLinkInstallationDate "2021-05-10T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps" .

