    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_7> ;
    noria:resourceInstallationDate "2021-05-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23_extra_node_7 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.1.1_extra_node_7> .

noria:Resource_DBServer01_extra_node_7
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:label "Serveur de Base de Données 01"@fr ;
    rdfs:comment "Server hosting the main corporate database."@en ;
