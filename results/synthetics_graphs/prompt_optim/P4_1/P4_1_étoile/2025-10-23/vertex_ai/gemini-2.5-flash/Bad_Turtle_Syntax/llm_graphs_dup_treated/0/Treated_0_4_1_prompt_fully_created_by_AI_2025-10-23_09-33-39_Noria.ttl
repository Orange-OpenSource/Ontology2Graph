noria:OpPlan_DNS_Troubleshoot_extra_node_7
    a noria:OperationPlan ;
    rdfs:label "DNS Troubleshooting Procedure"@en ;
    rdfs:label "Procédure de Dépannage DNS"@fr ;
    rdfs:comment "Standard_extra_node_7 operating procedure for diagnosing and resolving DNS server issues."@en ;
    skos:example "Steps include checking network connectivity, service status, and configuration files."@en ;
    noria:operationPlanPreCondition noria:PreCond_DNS_Unreachable_extra_node_7 ;
    noria:operationPlanPostCondition noria:PostCond_DNS_Restored_extra_node_7 .

noria:OpPlan_Router_OS_Update_extra_node_7
    a noria:OperationPlan ;
    rdfs:label "Router OS Update Procedure"@en ;
    rdfs:label "Procédure de Mise à Jour OS Routeur"@fr ;
    rdfs:comment "Detailed steps for safely updating the operating system of a core router."@en ;
    skos:example "Includes backup, pre-checks, upgrade steps, and post-checks."@en ;
    noria:operationPlanPreCondition noria:PreCond_Router_OldOS_extra_node_7 ;
    noria:operationPlanPostCondition noria:PostCond_Router_NewOS_extra_node_7 .

noria:PreCond_DNS_Unreachable_extra_node_7
    a noria:ActionPreCondition ;
    rdfs:label "DNS Unreachable"@en ;
    rdfs:comment "Condition where the DNS service is not responding to queries."@en .

noria:PostCond_DNS_Restored_extra_node_7
    a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Condition where the DNS service is fully operational and responding to queries."@en .

noria:PreCond_Router_OldOS_extra_node_7
    a noria:ActionPreCondition ;
    rdfs:label "Router Old OS Version"@en ;
    rdfs:comment "Condition where the router is running an outdated operating system version."@en .

noria:PostCond_Router_NewOS_extra_node_7
    a noria:ActionPostCondition ;
    rdfs:label "Router New OS Version"@en ;
    rdfs:comment "Condition where the router has been successfully updated to the target operating system version."@en .

