@base <https://w3id.org/noria/> .

# =============================================================================
# Agents and Organizational Units
# =============================================================================

foaf:Agent_AdminTeam_extra_node_7
    a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and operations."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for routine issues, emergency hotline for critical outages."@en .

foaf:Agent_NetworkOps_extra_node_7
    a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_7> ;
    noria:agentInstructions "Always use the dedicated NOC hotline for network incidents."@en .

foaf:Agent_AppDev_extra_node_7
    a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:label "Équipe de Développement Applicatif"@fr ;
    rdfs:comment "Team responsible for developing and maintaining corporate applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem_extra_node_7> ;
    noria:agentInstructions "Submit all requests via the internal JIRA system."@en .

foaf:Agent_SecurityAnalyst
    a foaf:Agent ;
    rdfs:label "Security Analyst John Doe"@en ;
    rdfs:label "Analyste Sécurité Jean Dupont"@fr ;
    rdfs:comment "Individual security analyst responsible for DMZ infrastructure."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_CustomerA_extra_node_7
    a foaf:Agent ;
    rdfs:label "Customer_extra_node_7 A Representative"@en ;
    rdfs:label "Représentant Client A"@fr ;
    rdfs:comment "Key contact person for Customer_extra_node_7 A's services."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_7> .

foaf:Agent_ChangeManager_extra_node_7
    a foaf:Agent ;
    rdfs:label "Change Manager Jane Smith"@en ;
    rdfs:label "Responsable des Changements Jeanne Dupont"@fr ;
    rdfs:comment "Manager overseeing all IT change management processes."@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit_L1Support_extra_node_7
    a org:OrganizationalUnit ;
    rdfs:label "Level 1 Support"@en ;
    rdfs:label "Support Niveau 1"@fr ;
    rdfs:comment "First line of support for all IT issues."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string .

org:OrgUnit_L2Support_extra_node_7
    a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support"@en ;
    rdfs:label "Support Niveau 2"@fr ;
    rdfs:comment "Second line of support, handling more complex issues."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"^^xsd:string .

org:OrgUnit_Hotline_extra_node_7
    a org:OrganizationalUnit ;
    rdfs:label "Hotline Team"@en ;
    rdfs:label "Équipe d'Astreinte"@fr ;
    rdfs:comment "Emergency hotline for critical incidents outside business hours."@en ;
    noria:agentWorkingHours "24/7 On-call"^^xsd:string .

