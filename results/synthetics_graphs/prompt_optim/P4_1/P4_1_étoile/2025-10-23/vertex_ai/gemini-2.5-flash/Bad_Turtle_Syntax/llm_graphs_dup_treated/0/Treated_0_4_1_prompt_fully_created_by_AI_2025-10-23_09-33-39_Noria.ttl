# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01_extra_node_7
    a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical for internet access."@en ;
    noria:resourceManagedBy foaf:Agent_AdminTeam_extra_node_7 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740_extra_node_7 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS01-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_7> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23_extra_node_7 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10_extra_node_7> .

noria:Resource_RouterCore01_extra_node_7
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for the data center, handling internal and external traffic."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps_extra_node_7 ;
    noria:resourceHostName "router-core01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K_extra_node_7 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTRC01-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_7> ;
    noria:resourceInstallationDate "2020-07-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23_extra_node_7 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_WebSrv01_extra_node_7
    a noria:Resource ;
    rdfs:label "Web Application Server 01"@en ;
    rdfs:label "Serveur d'Application Web 01"@fr ;
    rdfs:comment "Server hosting the corporate web portal application."@en ;
    noria:resourceManagedBy foaf:Agent_AppDev_extra_node_7 ;
    noria:resourceHostName "websrv01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi_extra_node_7 ;
    noria:resourceType <kos/Resource/type/VirtualMachine_extra_node_7> ;
    noria:resourceSerialNumber "SN-WEB01-VM" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction_extra_node_7> ;
    noria:resourceInstallationDate "2022-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23_extra_node_7 ;
    noria:resourceForApplication noria:App_WebAppPortal_extra_node_7 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20_extra_node_7> .

noria:Resource_FirewallDMZ_extra_node_7
    a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:label "Pare-feu DMZ"@fr ;
    rdfs:comment "Firewall protecting the Demilitarized Zone (DMZ) network segment."@en ;
    noria:resourceManagedBy foaf:Agent_SecurityAnalyst ;
    noria:resourceHostName "fw-dmz.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K_extra_node_7 ; # Assuming a firewall appliance from Cisco Nexus series
    noria:resourceType <kos/Resource/type/Firewall> ;
