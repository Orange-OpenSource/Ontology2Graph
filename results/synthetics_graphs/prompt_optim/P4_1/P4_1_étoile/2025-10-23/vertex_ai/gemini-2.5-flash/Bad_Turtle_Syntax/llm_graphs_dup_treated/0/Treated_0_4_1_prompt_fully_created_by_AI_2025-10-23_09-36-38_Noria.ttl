bot:Site_ParisDC_extra_node_2 a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddressStreet "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA_extra_node_2 a noria:Room ;
    rdfs:label "Server_extra_node_2 Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace bot:Site_ParisDC_extra_node_2 .

noria:Locus_Rack12_U23_extra_node_2 a noria:Locus ;
    rdfs:label "Rack 12, Unit 23"@en ;
    rdfs:comment "Specific location within Server_extra_node_2 Room A for equipment installation."@en ;
    noria:locusLine "Rack 12" ;
    noria:locusRow "U23" ;
    bot:hasSpace noria:Room_ServerRoomA_extra_node_2 .

bot:Site_LondonOffice_extra_node_2 a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:comment "Branch office in London."@en ;
    noria:siteId "OFF-LDN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddressStreet "456 Baker Street" ;
    noria:sitePrincipalAddressCityName "London" ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE" ;
    noria:sitePrincipalAddressCountry "UK" .

noria:Room_NetworkCloset_extra_node_2 a noria:Room ;
    rdfs:label "Network Closet"@en ;
    rdfs:comment "Network equipment closet in the London Office."@en ;
    bot:hasSpace bot:Site_LondonOffice_extra_node_2 .

noria:Locus_PatchPanel_P1_extra_node_2 a noria:Locus ;
    rdfs:label "Patch Panel P1_extra_node_2"@en ;
    rdfs:comment "Location of Patch Panel P1_extra_node_2 in the Network Closet."@en ;
    noria:locusLine "Panel 1" ;
    noria:locusRow "P1_extra_node_2" ;
    bot:hasSpace noria:Room_NetworkCloset_extra_node_2 .

