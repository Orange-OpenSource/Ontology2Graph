# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OpPlan_DNS_Failover_extra_node_2 a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard_extra_node_2 operating procedure for failing over DNS services to a secondary server."@en ;
    skos:example "Steps include verifying secondary server health, updating load balancer, and monitoring resolution."@en ;
    noria:operationPlanPreCondition noria:PreCond_DNS_Unreachable_extra_node_2 ;
    noria:operationPlanPostCondition noria:PostCond_DNS_Resolving_extra_node_2 .

noria:OpPlan_Router_Rollback_extra_node_2 a noria:OperationPlan ;
    rdfs:label "Router_extra_node_2 Configuration_extra_node_2 Rollback Procedure"@en ;
    rdfs:comment "Procedure to revert router configuration to a previous stable state."@en ;
    skos:example "Steps include loading previous configuration, verifying connectivity, and notifying stakeholders."@en ;
    noria:operationPlanPreCondition noria:PreCond_Router_ConfigError_extra_node_2 ;
    noria:operationPlanPostCondition noria:PostCond_Router_ConfigRestored_extra_node_2 .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:PreCond_DNS_Unreachable_extra_node_2 a noria:ActionPreCondition ;
    rdfs:label "DNS Unreachable Pre-condition"@en ;
    rdfs:comment "Condition: Primary DNS server is not responding to queries."@en ;
    skos:example "Ping to DNS server fails, dig/nslookup queries fail."@en .

noria:PostCond_DNS_Resolving_extra_node_2 a noria:ActionPostCondition ;
    rdfs:label "DNS Resolving Post-condition"@en ;
    rdfs:comment "Condition: DNS queries are successfully resolved by the secondary server."@en ;
    skos:example "Dig/nslookup queries return correct IP addresses, client machines can access internet."@en .

noria:PreCond_Router_ConfigError_extra_node_2 a noria:ActionPreCondition ;
    rdfs:label "Router_extra_node_2 Configuration_extra_node_2 Error Pre-condition"@en ;
    rdfs:comment "Condition: Routing table shows incorrect entries or routes are missing."@en ;
    skos:example "Show ip route command output indicates issues, traceroute fails."@en .

noria:PostCond_Router_ConfigRestored_extra_node_2 a noria:ActionPostCondition ;
    rdfs:label "Router_extra_node_2 Configuration_extra_node_2 Restored Post-condition"@en ;
    rdfs:comment "Condition: Router_extra_node_2 configuration is reverted, and network connectivity is restored."@en ;
    skos:example "Show ip route command output is correct, network services are reachable."@en .

# =============================================================================
# Additional connections for density
# =============================================================================

# Link Trouble Tickets to Operation Plans (conceptual, via related actions)
noria:TT_DNSOutage_extra_node_2 noria:troubleTicketCharacteristic noria:OpPlan_DNS_Failover_extra_node_2 .
noria:TT_RouterConfigIssue_extra_node_2 noria:troubleTicketCharacteristic noria:OpPlan_Router_Rollback_extra_node_2 .

# Link Event Records to Trouble Ticket Notes (as correlated executions)
noria:TTNote_DNSOutage_1_extra_node_2 noria:troubleTicketNoteCorrelatedExecution noria:Event_DNS_Down_extra_node_2 .
noria:TTNote_CustomerPortalSlow_1_extra_node_2 noria:troubleTicketNoteCorrelatedExecution noria:Event_WebSrv_HighCPU_extra_node_2 .

# Link Agents to resources they manage (inverse of resourceManagedBy)
foaf:Agent_AdminTeam_extra_node_2 noria:agentManagesResource noria:Resource_DNS01_extra_node_2 .
foaf:Agent_NetworkOps_extra_node_2 noria:agentManagesResource noria:Resource_RouterCore01_extra_node_2, noria:Resource_Firewall01_extra_node_2 .
foaf:Agent_AppDev_extra_node_2 noria:agentManagesResource noria:Resource_WebSrv01_extra_node_2, noria:Resource_DB01_extra_node_2 .

# Link Applications to resources they use (inverse of resourceForApplication)
noria:App_CustomerPortal_extra_node_2 seas:subSystem noria:Resource_WebSrv01_extra_node_2, noria:Resource_DB01_extra_node_2 .
noria:App_CorpInternetAccess_extra_node_2 seas:subSystem noria:Resource_Firewall01_extra_node_2 .

# Link Application Modules to Services (inverse of seas:subSystemOf)
noria:Service_ExternalConnectivity_extra_node_2 seas:subSystem noria:AppMod_CorpInternetAccess_Prod_extra_node_2 .
noria:Service_CustomerFacing_extra_node_2 seas:subSystem noria:AppMod_CustomerPortal_Prod_extra_node_2 .

# Link resources to their network interfaces (inverse of networkInterfaceOf)
noria:Resource_DNS01_extra_node_2 seas:hasConnectionPoint noria:NetIF_DNS01_Eth0_extra_node_2 .
noria:Resource_RouterCore01_extra_node_2 seas:hasConnectionPoint noria:NetIF_RouterCore01_Gi0_0_1_extra_node_2 .
noria:Resource_WebSrv01_extra_node_2 seas:hasConnectionPoint noria:NetIF_WebSrv01_Eth0_extra_node_2 .
noria:Resource_Firewall01_extra_node_2 seas:hasConnectionPoint noria:NetIF_Firewall01_Ext_extra_node_2 .

# Link network interfaces to network links (inverse of networkInterfaceConnects)
noria:NetLink_DC_Core_extra_node_2 seas:connectsSystemAt noria:NetIF_RouterCore01_Gi0_0_1_extra_node_2, noria:NetIF_Firewall01_Ext_extra_node_2 .
noria:NetLink_DNS_Web_extra_node_2 seas:connectsSystemAt noria:NetIF_DNS01_Eth0_extra_node_2, noria:NetIF_WebSrv01_Eth0_extra_node_2 .

# Example of a virtual server status
noria:Resource_WebSrv01_extra_node_2 noria:virtualServerStatus <kos/Resource/OperationalState/Up_extra_node_2> .
noria:Resource_DB01_extra_node_2 noria:virtualServerStatus <kos/Resource/OperationalState/Up_extra_node_2> .

# Example of laser optical power for a network interface (if applicable)
noria:NetIF_RouterCore01_Gi0_0_1_extra_node_2 noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold 0 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

