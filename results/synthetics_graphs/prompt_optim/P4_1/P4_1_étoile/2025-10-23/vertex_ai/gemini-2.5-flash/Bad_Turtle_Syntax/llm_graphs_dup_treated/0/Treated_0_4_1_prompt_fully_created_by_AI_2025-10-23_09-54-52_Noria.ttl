# --- Operation Plans ---
noria:OperationPlan_RouterFirmwareUpdate_extra_node_6 a noria:OperationPlan ;
    rdfs:label "Router_extra_node_6 Firmware Update Procedure"@en, "Procédure de Mise à Jour Firmware Routeur"@fr ;
    rdfs:comment "Standard_extra_node_6 operating procedure for updating router firmware."@en ;
    skos:example "Steps include backup configuration, download firmware, apply update, verify connectivity."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_RouterConnectivityOK_extra_node_6 ;
    noria:operationPlanPostCondition noria:ActionPostCondition_RouterFirmwareUpdated_extra_node_6 .

noria:OperationPlan_WebAppRollback_extra_node_6 a noria:OperationPlan ;
    rdfs:label "WebApp Rollback Procedure"@en, "Procédure de Retour Arrière Application Web"@fr ;
    rdfs:comment "Procedure to revert WebApp Portal to a previous stable version in case of deployment issues."@en ;
    skos:example "Steps include stopping services, restoring previous code, restarting services, functional testing."@en ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebAppFunctional_extra_node_6 .

# --- Action Pre/Post Conditions ---
noria:ActionPreCondition_RouterConnectivityOK_extra_node_6 a noria:ActionPreCondition ;
    rdfs:label "Router_extra_node_6 Connectivity OK Pre-condition"@en ;
    rdfs:comment "Verify full network connectivity to the router before starting any maintenance."@en ;
    skos:example "Ping tests to management IP and adjacent devices must pass."@en .

noria:ActionPostCondition_RouterFirmwareUpdated_extra_node_6 a noria:ActionPostCondition ;
    rdfs:label "Router_extra_node_6 Firmware Updated Post-condition"@en ;
    rdfs:comment "Confirm that the router firmware version has been successfully up_extra_node_6dated and all interfaces are up_extra_node_6."@en ;
    skos:example "Check 'show version' output and interface status."@en .

noria:ActionPostCondition_WebAppFunctional_extra_node_6 a noria:ActionPostCondition ;
    rdfs:label "WebApp Functional Post-condition"@en ;
    rdfs:comment "Verify that the web application is fully functional and accessible after deployment or rollback."@en ;
    skos:example "Access main page, login, perform a key transaction."@en .

# --- KOS Concepts (defined inline as per example) ---
