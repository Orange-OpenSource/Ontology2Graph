# Organizational Units (Teams)
org:ITOperationsTeam_extra_node_1 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for day-to-day IT infrastructure_extra_node_1 operations."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email_extra_node_1> ;
    noria:agentInstructions "Contact via ticketing system for all non-critical_extra_node_1 issues. For critical_extra_node_1 issues, use emergency hotline."@en .

org:NetworkSupportTeam_extra_node_1 a org:OrganizationalUnit ;
    rdfs:label "Network Support Team"@en ;
    rdfs:comment "Specialized team for network infrastructure_extra_node_1 support."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone_extra_node_1> ;
    noria:agentInstructions "Always call emergency line for network outages."@en .

org:ApplicationDevTeam_extra_node_1 a org:OrganizationalUnit ;
    rdfs:label "Application Development_extra_node_1 Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat_extra_node_1> ;
    noria:agentInstructions "Use internal chat_extra_node_1 for quick queries, ticketing system for bugs."@en .

org:SecurityOperationsCenter_extra_node_1 a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Monitors and analyzes security events."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SIEMAlert_extra_node_1> ;
    noria:agentInstructions "Automated alerts are preferred for security incidents."@en .

