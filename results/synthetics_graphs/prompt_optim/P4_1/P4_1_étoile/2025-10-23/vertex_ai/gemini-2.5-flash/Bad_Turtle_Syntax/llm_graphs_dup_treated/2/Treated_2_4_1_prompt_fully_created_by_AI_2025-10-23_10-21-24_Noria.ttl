noria:Resource_VirtualMachineApp01 a noria:Resource ;
    rdfs:label "Virtual Machine for App01"@en ;
    rdfs:comment "Virtual machine hosting a module of the main corporate application."@en ;
    noria:resourceHostName "vm-app01.prod.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The hypervisor model, not the VM itself
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceManagedBy org:ITOperationsTeam ;
    noria:resourceForApplication noria:Application_CorporateApp ;
    noria:clusterController noria:Resource_HypervisorHost01 .

noria:Resource_HypervisorHost01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server hosting virtual machines."@en ;
    noria:resourceHostName "hv01.prod.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
    noria:resourceManagedBy org:ITOperationsTeam ;
    noria:locatedAtLocus noria:RackLocusA1R12 .

# =============================================================================
# Network Interfaces
