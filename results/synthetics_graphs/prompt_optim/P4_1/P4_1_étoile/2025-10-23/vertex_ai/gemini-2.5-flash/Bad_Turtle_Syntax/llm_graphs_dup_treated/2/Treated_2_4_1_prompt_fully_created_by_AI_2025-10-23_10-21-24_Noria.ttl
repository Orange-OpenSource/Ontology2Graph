noria:NetworkInterface_Web01Eth0 a noria:NetworkInterface ;
    rdfs:label "web01.prod.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebServer01 ;
    noria:networkInterfaceDescription "Primary network interface for web traffic."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_DB01Eth0 a noria:NetworkInterface ;
    rdfs:label "db01.prod.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface for DB Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DBServer01 ;
    noria:networkInterfaceDescription "Primary network interface for database traffic."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetworkInterface_CR01Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "cr01.dc.example.com:Gi0/0/1"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 01, connected to Web Server segment."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to Web Server VLAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetworkInterface_CR01Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "cr01.dc.example.com:Gi0/0/2"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 01, connected to DB Server segment."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to Database Server VLAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

# =============================================================================
# Network Links
# =============================================================================

noria:NetworkLink_Web01_CR01 a noria:NetworkLink ;
    rdfs:label "Link Web01-CR01"@en ;
    rdfs:comment "Network link between Web Server 01 and Core Router 01."@en ;
    noria:networkLinkId "NL-WEB01-CR01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ;
    noria:networkLinkInstallationDate "2023-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy org:NetworkSupportTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_Web01Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01Gi0_0_1 .

noria:NetworkLink_DB01_CR01 a noria:NetworkLink ;
    rdfs:label "Link DB01-CR01"@en ;
    rdfs:comment "Network link between DB Server 01 and Core Router 01."@en ;
    noria:networkLinkId "NL-DB01-CR01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DBServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_CoreRouter01 ;
    noria:networkLinkInstallationDate "2023-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:resourceManagedBy org:NetworkSupportTeam ;
    noria:networkInterfaceConnects noria:NetworkInterface_DB01Eth0 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01Gi0_0_2 .

# =============================================================================
# Applications
# =============================================================================

noria:Application_CorporateApp a noria:Application ;
    rdfs:label "Corporate Business Application"@en ;
    rdfs:comment "Main application supporting core business processes."@en ;
    noria:applicationModelIdentifier "CBA-V2.0" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CBA" ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Order Management"@en ;
    noria:elementManagedBy org:ApplicationDevTeam .

noria:Application_MonitoringSystem a noria:Application ;
    rdfs:label "IT Monitoring System"@en ;
    rdfs:comment "System responsible for monitoring IT infrastructure and applications."@en ;
    noria:applicationModelIdentifier "MON-V3.1" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Performance Monitoring"@en ;
    noria:elementManagedBy org:ITOperationsTeam .

noria:Application_TicketingSystem a noria:Application ;
    rdfs:label "ITSM Ticketing System"@en ;
    rdfs:comment "System used for managing incidents, problems, and changes."@en ;
    noria:applicationModelIdentifier "ITSM-V1.5" ;
    noria:applicationNumericalIdentifier 3001 ;
    noria:applicationShortIdentifier "ITSM" ;
    noria:applicationType <kos/application/type/it-service-management> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Service Management"@en ;
    noria:applicationFunctionalSubDomain "Incident Management"@en ;
    noria:elementManagedBy org:ITOperationsTeam .

