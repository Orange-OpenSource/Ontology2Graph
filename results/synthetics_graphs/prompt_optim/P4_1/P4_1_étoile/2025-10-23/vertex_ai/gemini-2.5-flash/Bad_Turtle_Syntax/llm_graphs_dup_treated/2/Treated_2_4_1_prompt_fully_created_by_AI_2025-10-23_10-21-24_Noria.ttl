noria:EventRecord_WebOutageResolved a noria:EventRecord ;
    rdfs:label "Web Server Connectivity Restored"@en ;
    rdfs:comment "Network interface eth0 on web01.prod.example.com is now up."@en ;
    noria:loggingTime "2024-04-20T10:10:00Z"^^xsd:dateTime ;
    noria:logText "Interface eth0 on web01.prod.example.com changed state to up."@en ;
