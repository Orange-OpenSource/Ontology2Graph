# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OperationPlan_CheckNetworkCable a noria:OperationPlan ;
    rdfs:label "Check Network Cable Procedure"@en ;
    rdfs:comment "Standard operating procedure for troubleshooting network cable issues."@en ;
    skos:example "1. Verify physical connection. 2. Check link lights. 3. Replace cable if necessary."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_NetworkInterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_NetworkInterfaceUp .

noria:OperationPlan_RestartWebServer a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Procedure to restart the web server service."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_WebServerUnresponsive ;
    noria:operationPlanPostCondition noria:ActionPostCondition_WebServerResponsive .

noria:ActionPreCondition_NetworkInterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down"@en ;
    rdfs:comment "Condition where a network interface is reporting an 'down' operational status."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Down>"@en .

noria:ActionPostCondition_NetworkInterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up"@en ;
    rdfs:comment "Expected outcome: network interface is reporting an 'up' operational status."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Up>"@en .

noria:ActionPreCondition_WebServerUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Web Server Unresponsive"@en ;
    rdfs:comment "Condition where the web server is not responding to HTTP requests."@en .

noria:ActionPostCondition_WebServerResponsive a noria:ActionPostCondition ;
    rdfs:label "Web Server Responsive"@en ;
    rdfs:comment "Expected outcome: web server is responding to HTTP requests."@en .

