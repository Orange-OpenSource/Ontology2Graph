    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSupportTeam org:ITOperationsTeam .

# =============================================================================
# Services
# =============================================================================

noria:Service_CustomerFacingWebPortal a noria:Service ;
    rdfs:label "Customer Facing Web Portal Service"@en ;
    rdfs:comment "End-to-end service providing access to the corporate web portal for customers."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:Application_CorporateApp ; # A service can be seen as a subsystem of a larger application
