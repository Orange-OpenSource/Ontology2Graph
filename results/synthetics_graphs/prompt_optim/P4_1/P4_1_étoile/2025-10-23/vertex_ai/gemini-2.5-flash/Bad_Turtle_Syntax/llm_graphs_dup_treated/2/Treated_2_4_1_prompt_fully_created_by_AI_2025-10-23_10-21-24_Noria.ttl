noria:EventRecord_WebConnectivityDown a noria:EventRecord ;
    rdfs:label "Web Server Connectivity Down Alert"@en ;
    rdfs:comment "Alert: Network interface eth0 on web01.prod.example.com is down."@en ;
    noria:loggingTime "2024-04-20T08:59:30Z"^^xsd:dateTime ;
    noria:logText "Interface eth0 on web01.prod.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_CheckNetworkCable ;
    dcterms:type <kos/Notification/EventType/stateChange> .

noria:EventRecord_DBHighCPU a noria:EventRecord ;
