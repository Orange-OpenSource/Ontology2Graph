noria:Resource_CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the data center network."@en ;
    noria:resourceLogisticId "RES-RTR-001" ;
    noria:resourceHostName "cr01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkSupportTeam ;
