# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# SKOS Concepts for controlled vocabularies (Kos)
# =============================================================================

# Application Types
<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/business-app> a skos:Concept ; rdfs:label "Business Application"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; rdfs:label "Monitoring System"@en ; skos:inScheme <https://w3id.org/noria/kos/application/type> .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium"@en ; skos:inScheme <https://w3id.org/noria/kos/application/business-importance> .

# Application Module Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en ; skos:inScheme <https://w3id.org/noria/kos/application/status> .

# Service Types
<kos/service/type/customer-facing> a skos:Concept ; rdfs:label "Customer Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .
<kos/service/type/resource-facing> a skos:Concept ; rdfs:label "Resource Facing Service"@en ; skos:inScheme <https://w3id.org/noria/kos/service/type> .

# Trouble Ticket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> .

# Trouble Ticket Type
<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> .

# Trouble Ticket Status
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> .

# Trouble Ticket Origin
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ; rdfs:label "Network Outage"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/trouble-category/ApplicationError> a skos:Concept ; rdfs:label "Application Error"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> .

# Problem Responsibility
<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ; rdfs:label "Internal IT"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/Vendor> a skos:Concept ; rdfs:label "Vendor"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> .

# Event Record Alarm Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning"@en ; skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> .

# Resource Type
<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .
<kos/Resource/type/Firewall> a skos:Concept ; rdfs:label "Firewall"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/type> .

# Resource Usage State (LifecycleState)
<kos/Resource/LifecycleState/InUse> a skos:Concept ; rdfs:label "In Use"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Maintenance> a skos:Concept ; rdfs:label "In Maintenance"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> .

# Network Interface Administrative Status
<kos/Resource/AdministrativeState/up> a skos:Concept ; rdfs:label "Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/down> a skos:Concept ; rdfs:label "Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> .

# Network Interface Operational Status
<kos/Resource/OperationalState/up> a skos:Concept ; rdfs:label "Up"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .
<kos/Resource/OperationalState/down> a skos:Concept ; rdfs:label "Down"@en ; skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> .

# Change Request Category
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .
<kos/ChangeRequest/category/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> .

# Change Request Type
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Normal> a skos:Concept ; rdfs:label "Normal Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> .

# Change Request Cause
<kos/ChangeRequest/cause/Configuration> a skos:Concept ; rdfs:label "Configuration Change"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .
<kos/ChangeRequest/cause/PreventativeMaintenance> a skos:Concept ; rdfs:label "Preventative Maintenance"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> .

# Change Request Status
<kos/ChangeRequest/status/Planned> a skos:Concept ; rdfs:label "Planned"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented"@en ; skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; rdfs:label "Tests and Measurements"@en ; skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone"@en ; skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> .

# =============================================================================
# Agents and Organizational Units
# =============================================================================

noria:Agent_AdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and configuration."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for routine issues, direct email for critical alerts."@en .

noria:Agent_NetworkOps a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use emergency hotline for network outages."@en .

noria:Agent_AppDev a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining corporate applications."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit bug reports via Jira, feature requests via Confluence."@en .

noria:Agent_SecurityTeam a foaf:Agent ;
    rdfs:label "Security Operations Center"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate phone call for critical security alerts."@en .

noria:Agent_User1 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An end-user reporting an issue."@en .

noria:OrgUnit_L2Support a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support"@en ;
    rdfs:comment "Second-line support for complex technical issues."@en ;
    noria:agentWorkingHours "8:00-20:00 (Mon-Sat)"@en .

noria:OrgUnit_Hotline a org:OrganizationalUnit ;
    rdfs:label "Hotline Support"@en ;
    rdfs:comment "First-line support for urgent issues, available 24/7."@en ;
    noria:agentWorkingHours "24/7"@en .

noria:Agent_CRInitiator a foaf:Agent ;
    rdfs:label "Project Manager Alice"@en ;
    rdfs:comment "Initiator of a change request."@en .

noria:Agent_CRPilot a foaf:Agent ;
    rdfs:label "Lead Engineer Bob"@en ;
    rdfs:comment "Pilot responsible for overseeing a change request."@en .

noria:Agent_CRActor a foaf:Agent ;
    rdfs:label "Technician Charlie"@en ;
    rdfs:comment "Technician executing the change request."@en .

# =============================================================================
# Locations
# =============================================================================

noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center facility in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Data"@fr ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75001" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Site_ParisDC .

noria:Locus_Rack12_U24 a noria:Locus ;
    rdfs:label "Rack 12, Unit 24"@en ;
    rdfs:comment "Specific location within Server Room A for equipment installation."@en ;
    noria:locusLine "Rack 12" ;
    noria:locusRow "U24" ;
    bot:hasSpace noria:Room_ServerRoomA .

noria:Site_RemoteOffice a bot:Site ;
    rdfs:label "Remote Office Lyon"@en ;
    rdfs:comment "Branch office in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue des Lumières"@fr ;
    noria:sitePrincipalAddressCityName "Lyon"@en ;
    noria:sitePrincipalAddressPostalCode "69002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_CommsCloset a noria:Room ;
    rdfs:label "Communications Closet"@en ;
    rdfs:comment "Network equipment closet in the Remote Office."@en ;
    bot:hasSpace noria:Site_RemoteOffice .

noria:Locus_WallMount_P01 a noria:Locus ;
    rdfs:label "Wall Mount Panel 01"@en ;
    rdfs:comment "Wall-mounted panel for network devices in the Communications Closet."@en ;
    noria:locusLine "Wall A" ;
    noria:locusRow "Panel 01" ;
    bot:hasSpace noria:Room_CommsCloset .

