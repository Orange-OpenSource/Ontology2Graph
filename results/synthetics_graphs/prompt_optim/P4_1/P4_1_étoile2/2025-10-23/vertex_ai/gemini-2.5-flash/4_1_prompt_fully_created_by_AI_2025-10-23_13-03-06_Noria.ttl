# =============================================================================
# Resources
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

noria:Resource_RouterCore1 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Main router for internal network traffic in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco3850 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Corporate Web Server 01"@en ;
    rdfs:comment "Server hosting the main corporate web application."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress "192.168.1.20" .

noria:Resource_FirewallDMZ a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:comment "Firewall protecting the DMZ segment at the remote office."@en ;
    noria:resourceManagedBy noria:Agent_SecurityTeam ;
    noria:resourceHostName "fw-dmz-01.remote.example.com" ;
    noria:resourceProductModel noria:ProductModel_Cisco3850 ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_WallMount_P01 ;
    noria:resourceManagementIPAddress "172.16.0.1" .

noria:Resource_DB01 a noria:Resource ;
    rdfs:label "Corporate Database Server 01"@en ;
    rdfs:comment "Database server for the corporate web application."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2023-05-01T09:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 ;
    noria:resourceManagementIPAddress "192.168.1.30" .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NetIF_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DNS01."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetIF_RouterCore1_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore1 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 1 to DNS01 segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetIF_RouterCore1_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "RouterCore1 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 1 to Web Server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore1 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetIF_WebSrv01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for WebSrv01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetIF_FirewallDMZ_Ext a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ External Interface"@en ;
    rdfs:comment "External interface of the DMZ Firewall."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetIF_FirewallDMZ_Int a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ Internal Interface"@en ;
    rdfs:comment "Internal interface of the DMZ Firewall, connecting to Core Router."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetIF_DB01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DB01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DB01."@en ;
    noria:networkInterfaceOf noria:Resource_DB01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links
# =============================================================================

noria:NetLink_DNS_Core a noria:NetworkLink ;
    rdfs:label "Link DNS01 to Core Router"@en ;
    rdfs:comment "Physical link between DNS01 and Core Router 1."@en ;
    noria:networkLinkId "NL-DNS-CORE-01" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkInterfaceConnects noria:NetIF_DNS01_Eth0 ;
    noria:networkInterfaceConnects noria:NetIF_RouterCore1_Gi0_0_1 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
