# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OpPlan_RouterRestart a noria:OperationPlan ;
    rdfs:label "Router Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for safely restarting a network router."@en ;
    skos:example "Steps include: notify stakeholders, save configuration, execute reload, verify connectivity."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterUnresponsive ;
    noria:operationPlanPostCondition noria:PostCond_RouterOnline .

noria:OpPlan_DBBackup a noria:OperationPlan ;
    rdfs:label "Database Backup Procedure"@en ;
    rdfs:comment "Procedure for performing a full backup of the corporate database."@en ;
    skos:example "Steps include: verify disk space, initiate backup, verify backup integrity, store offsite."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBConsistent ;
    noria:operationPlanPostCondition noria:PostCond_BackupComplete .

noria:PreCond_RouterUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Router Unresponsive"@en ;
    rdfs:comment "Condition where the router is not responding to ping or management access."@en .

noria:PostCond_RouterOnline a noria:ActionPostCondition ;
    rdfs:label "Router Online and Stable"@en ;
    rdfs:comment "Condition where the router is fully operational, all interfaces are up, and routing protocols are converged."@en .

noria:PreCond_DBConsistent a noria:ActionPreCondition ;
    rdfs:label "Database Consistent State"@en ;
    rdfs:comment "Condition where the database is in a consistent state, suitable for backup."@en .

noria:PostCond_BackupComplete a noria:ActionPostCondition ;
    rdfs:label "Backup Operation Complete"@en ;
    rdfs:comment "Condition where the database backup has successfully completed and verified."@en .

# =============================================================================
# Additional Interconnections for Density
# =============================================================================

# Agents managing resources
noria:Agent_AdminTeam noria:agentManagesResource noria:Resource_DNS01 .
noria:Agent_NetworkOps noria:agentManagesResource noria:Resource_RouterCore1 .
noria:Agent_AppDev noria:agentManagesResource noria:Resource_WebSrv01, noria:Resource_DB01 .
noria:Agent_SecurityTeam noria:agentManagesResource noria:Resource_FirewallDMZ .

# Applications using resources
noria:App_CorpDNS seas:subSystem noria:Resource_DNS01 .
noria:App_WebApp seas:subSystem noria:Resource_WebSrv01, noria:Resource_DB01 .
noria:App_Monitoring seas:subSystem noria:Resource_RouterCore1, noria:Resource_DNS01 .

# Application Modules related parties
noria:AppMod_CorpDNS_Prod noria:applicationModuleAdministrationLeader noria:Agent_AdminTeam .
noria:AppMod_WebApp_Prod noria:applicationModuleAdministrationLeader noria:Agent_AppDev .
noria:AppMod_Monitoring_Main noria:applicationModuleAdministrationLeader noria:Agent_NetworkOps .

# Trouble Ticket status history (simplified with EventRecords)
noria:TT_DNSOutage noria:documentStatusHistory noria:Event_DNS_Log1 .
noria:TT_RouterLinkDown noria:documentStatusHistory noria:Event_NetIF_Down .

# Change Request related events (simplified with EventRecords)
noria:CR_RouterUpgrade dcterms:relation noria:Event_ConfigChange .

# Example of a resource being a cluster controller for another resource (e.g., a hypervisor managing VMs)
noria:Resource_VMHost01 a noria:Resource ;
    rdfs:label "VMware ESXi Host 01"@en ;
    rdfs:comment "Physical host running virtual machines."@en ;
    noria:resourceHostName "vmhost01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:locatedAtLocus noria:Locus_Rack12_U24 .

noria:Resource_WebSrv01 noria:clusterController noria:Resource_VMHost01 .
noria:Resource_DB01 noria:clusterController noria:Resource_VMHost01 .

# Example of alarm mitigation
noria:Event_NetIF_Down noria:alarmMitigatedBy noria:TT_RouterLinkDown . # The TT is the container for the actions that mitigated the alarm.

# Example of an Operation Plan being correlated to an action (implicitly, via a Change Request)
noria:CR_RouterUpgrade pep:usedProcedure noria:OpPlan_RouterRestart . # A CR is a ProcedureExecutionContainer, and it uses an OperationPlan.

