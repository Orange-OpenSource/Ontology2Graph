# --- Services ---
:Service_EnterpriseConnectivity a noria:Service ;
    rdfs:label "Enterprise Connectivity Service"@en ;
    rdfs:comment "Bundles all services related to internal and external network connectivity."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf :AppModule_CIA_Prod, :AppModule_IDNS_Prod .

# --- Event Records ---
:EventRecord_DNS_Down a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Event"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_DNS01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN. Ping failed."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

:EventRecord_Interface_Down a noria:EventRecord ;
    rdfs:label "Network Interface Down Event"@en ;
    rdfs:comment "Log entry indicating network interface CR01_Gi0_0_1 went down."@en ;
    noria:loggingTime "2024-04-10T08:59:50Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem :App_MonitoringSystem ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

:EventRecord_Config_Change a noria:EventRecord ;
    rdfs:label "Router Configuration Change Event"@en ;
    rdfs:comment "Log entry for a configuration change on Core Router 01."@en ;
    noria:loggingTime "2024-04-09T15:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject :Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem :App_ConfigurationManagement ;
    noria:logOriginatingAgent :Agent_JohnDoe ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by John Doe (10.0.0.5)."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

:App_MonitoringSystem a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "Application responsible for monitoring network devices and services."@en ;
    noria:applicationType <kos/application/type/infrastructure> .

:App_ConfigurationManagement a noria:Application ;
    rdfs:label "Configuration Management System"@en ;
    rdfs:comment "Application for managing and tracking configuration changes."@en ;
    noria:applicationType <kos/application/type/management> .

# --- Trouble Tickets ---
:TroubleTicket_DNSOutage_001 a noria:TroubleTicket ;
    rdfs:label "Critical DNS Server Outage"@en ;
    rdfs:comment "DNS server dns01.corp.example.com is unreachable, impacting corporate internet access."@en ;
    dcterms:created "2024-04-10T09:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-10T10:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-2024-04-10-001" ;
    noria:documentHRef "https://ticketing.example.com/INC-2024-04-10-001"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger :EventRecord_DNS_Down ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/InaccessibleDestination> ;
    noria:troubleTicketCause "Network connectivity issue to DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-10T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-10T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty :Agent_DNSAdminTeam, :Agent_NetworkOpsTeam ;
    noria:troubleTicketRelatedService :App_CorporateInternetAccess, :App_InternalDNS ;
    noria:troubleTicketRelatedResource :Resource_DNS01, :Resource_CoreRouter01 ;
    noria:troubleTicketImpacts :App_CorporateInternetAccess, :Resource_DNS01 .

:TroubleTicket_InternetAccess_002 a noria:TroubleTicket ;
    rdfs:label "Corporate Internet Access Degradation"@en ;
    rdfs:comment "Users reporting slow internet access, potentially related to DNS issues."@en ;
    dcterms:created "2024-04-10T09:15:00Z"^^xsd:dateTime ;
    noria:documentExternalId "INC-2024-04-10-002" ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/User> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Initialised> ;
    noria:troubleTicketRelatedParty :Agent_AppSupportTeam ;
    noria:troubleTicketRelatedService :App_CorporateInternetAccess .

# --- Trouble Ticket Notes ---
:TroubleTicketNote_001 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis Note"@en ;
    rdfs:comment "Confirmed DNS server is not responding to pings. Investigating network path."@en ;
    dcterms:created "2024-04-10T09:10:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_JohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf :TroubleTicket_DNSOutage_001 .

:TroubleTicketNote_002 a noria:TroubleTicketNote ;
    rdfs:label "Network Interface Status Update"@en ;
    rdfs:comment "Found Gi0/0/1 on CR01 is down. Attempting to bring it up."@en ;
    dcterms:created "2024-04-10T09:25:00Z"^^xsd:dateTime ;
    dcterms:creator :Agent_NetworkOpsTeam ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf :TroubleTicket_DNSOutage_001 ;
    noria:troubleTicketNoteCorrelatedExecution :EventRecord_Interface_Down .

# --- Change Requests ---
:ChangeRequest_DNSUpgrade_001 a noria:ChangeRequest ;
    rdfs:label "DNS Software Upgrade on DNS01"@en ;
    rdfs:comment "Planned software upgrade for DNS server dns01.corp.example.com to address known vulnerabilities and improve performance."@en ;
    dcterms:created "2024-04-01T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-05T14:00:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CR-2024-04-01-001" ;
    noria:documentHRef "https://changemanagement.example.com/CR-2024-04-01-001"^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-04-15T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-15T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact :Resource_DNS01, :App_InternalDNS ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardSoftwareUpgrade> ;
    noria:changeRequestInitiatorParty :Agent_JohnDoe ;
    noria:changeRequestPilotParty :Agent_DNSAdminTeam ;
    noria:changeRequestActorParty :Agent_DNSAdminTeam ;
    noria:changeRequestIsRegulated false .

# --- Operation Plans and Conditions ---
:OperationPlan_DNS_Troubleshooting a noria:OperationPlan ;
    rdfs:label "DNS Server Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving DNS server issues."@en ;
    skos:example "Check network connectivity, verify DNS service status, inspect logs."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_DNS_Unreachable ;
    noria:operationPlanPostCondition :ActionPostCondition_DNS_Restored .

:ActionPreCondition_DNS_Unreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unreachable"@en ;
    rdfs:comment "Condition: DNS server is not responding to queries or pings."@en .

:ActionPostCondition_DNS_Restored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS server is reachable and resolving queries correctly."@en .

:OperationPlan_NetworkInterface_Bounce a noria:OperationPlan ;
    rdfs:label "Network Interface Bounce Procedure"@en ;
    rdfs:comment "Procedure to administratively shut down and then bring up a network interface."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_Interface_Down ;
    noria:operationPlanPostCondition :ActionPostCondition_Interface_Up .

:ActionPreCondition_Interface_Down a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down"@en ;
    rdfs:comment "Condition: A network interface is in an operational 'down' state."@en .

:ActionPostCondition_Interface_Up a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up"@en ;
    rdfs:comment "Outcome: The network interface is in an operational 'up' state."@en .

# Linking EventRecord to OperationPlan for proposed repair action
:EventRecord_DNS_Down noria:alarmProposedRepairAction :OperationPlan_DNS_Troubleshooting .
:EventRecord_Interface_Down noria:alarmProposedRepairAction :OperationPlan_NetworkInterface_Bounce .

# Linking TroubleTicket to OperationPlan via a hypothetical action
# (This would typically be a pep:ProcedureExecution, but for density, we can link directly to the plan)
# noria:troubleTicketCharacteristic could be used to link to a specific action or plan.
# For this example, let's assume the troubleshooting plan is implicitly part of the ticket's resolution process.

# Example of a Corporate User Identifier
:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "johndoe"@en ;
    rdfs:comment "Corporate User ID for John Doe."@en ;
    foaf:accountName "johndoe" ;
    foaf:holdsAccount :Agent_JohnDoe .

