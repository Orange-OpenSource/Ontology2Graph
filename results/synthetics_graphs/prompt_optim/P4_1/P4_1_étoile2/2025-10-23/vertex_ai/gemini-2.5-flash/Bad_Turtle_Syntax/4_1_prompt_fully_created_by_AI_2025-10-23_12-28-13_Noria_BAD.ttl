    noria:networkLinkId "NL-DNS-CR-001" ;
    noria:networkLinkTerminationResourceOrigin :Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination :Resource_CoreRouter01 ;
    noria:networkLinkInstallationDate "2022-01-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" .

:NetworkInterface_DNS01_Eth0 noria:networkInterfaceConnects :NetworkLink_DNS_CR_Uplink .
:NetworkInterface_CR01_Gi0_0_1 noria:networkInterfaceConnects :NetworkLink_DNS_CR_Uplink .

