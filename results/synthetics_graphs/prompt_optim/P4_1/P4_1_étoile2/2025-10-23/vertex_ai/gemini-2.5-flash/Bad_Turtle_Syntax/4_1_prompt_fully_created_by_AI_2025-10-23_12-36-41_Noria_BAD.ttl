    seas:hasSubSystem <noria/Resource/RouterCore01> ;
    seas:hasSubSystem <noria/Resource/FirewallDMZ01> .

<noria/Application/InternetAccessApp>
    a noria:Application ;
    rdfs:label "Internet Access Infrastructure Application"@en ;
    rdfs:comment "Abstract application representing the overall internet access infrastructure."@en ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> .

<noria/Service/CustomerOnlineExperience>
    a noria:Service ;
    rdfs:label "Customer Online Experience Service"@en ;
    rdfs:label "Service Expérience Client en Ligne"@fr ;
    rdfs:comment "Service encompassing the customer web portal and related backend systems."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
