# =============================================================================
# Event Records
# =============================================================================

<noria/EventRecord/LogDNSDown>
    a noria:EventRecord ;
    rdfs:label "DNS Server Down Log"@en ;
    rdfs:comment "Log entry indicating the corporate DNS server became unreachable."@en ;
    noria:loggingTime "2024-03-15T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <noria/Resource/DNS01> ;
    noria:logOriginatingManagementSystem <noria/Application/MonitoringSystem> ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<noria/EventRecord/LogInterfaceUp>
    a noria:EventRecord ;
    rdfs:label "Router Interface Up Log"@en ;
    rdfs:comment "Log entry indicating a router interface changed state to up."@en ;
    noria:loggingTime "2024-03-15T09:15:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <noria/Resource/RouterCore01> ;
    noria:logOriginatingManagementSystem <noria/Application/MonitoringSystem> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to up."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

<noria/EventRecord/AlarmCPUHigh>
    a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alarm"@en ;
    rdfs:comment "Alarm triggered due to high CPU utilization on WebSrv03."@en ;
    noria:loggingTime "2024-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <noria/Resource/WebSrv03> ;
    noria:logOriginatingManagementSystem <noria/Application/MonitoringSystem> ;
    noria:logText "WARNING: CPU usage on websrv03.dmz.example.com exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmProposedRepairAction <noria/OperationPlan/RestartWebServerProcess> .

<noria/EventRecord/LogConfigChange>
    a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry detailing a configuration change on RouterCore01."@en ;
    noria:loggingTime "2024-03-14T18:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <noria/Resource/RouterCore01> ;
    noria:logOriginatingAgent <foaf/Agent/AliceSmith> ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by Alice Smith (10.0.0.5)."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

