# =============================================================================
# Operation Plans and Conditions
# =============================================================================

<noria/OperationPlan/RouterFirmwareUpgradePlan>
    a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware."@en ;
    skos:example "Steps include backup configuration, upload new firmware, reboot, verify connectivity."@en ;
    noria:operationPlanPreCondition <noria/ActionPreCondition/NetworkStable> ;
    noria:operationPlanPostCondition <noria/ActionPostCondition/RouterConnectivityOK> .

<noria/OperationPlan/DBMigrationPlan>
    a noria:OperationPlan ;
    rdfs:label "Database Migration Procedure"@en ;
    rdfs:comment "Procedure for migrating a database to a new server."@en ;
    skos:example "Steps include database backup, new server setup, data transfer, application reconfiguration, and testing."@en ;
    noria:operationPlanPreCondition <noria/ActionPreCondition/NewDBServerReady> ;
    noria:operationPlanPostCondition <noria/ActionPostCondition/DBAccessOK> .

<noria/OperationPlan/RestartWebServerProcess>
    a noria:OperationPlan ;
    rdfs:label "Restart Web Server Process"@en ;
    rdfs:comment "Procedure to restart the web server process to resolve performance issues."@en ;
    skos:example "Connect to server, identify process, issue restart command, verify service."@en ;
    noria:operationPlanPostCondition <noria/ActionPostCondition/ServiceRestored> .

<noria/ActionPreCondition/NetworkStable>
    a noria:ActionPreCondition ;
    rdfs:label "Network Stability Check"@en ;
    rdfs:comment "Verify network is stable and no other critical incidents are active."@en ;
    skos:example "No active P1/P2 trouble tickets, no major alarms on core network devices."@en .

<noria/ActionPreCondition/NewDBServerReady>
    a noria:ActionPreCondition ;
    rdfs:label "New Database Server Ready"@en ;
    rdfs:comment "Ensure the target database server is provisioned, configured, and accessible."@en .

<noria/ActionPostCondition/RouterConnectivityOK>
    a noria:ActionPostCondition ;
    rdfs:label "Router Connectivity Verified"@en ;
    rdfs:comment "Confirm full network connectivity and routing functionality after router upgrade."@en ;
    skos:example "Ping tests successful, BGP/OSPF adjacencies up, traffic flowing normally."@en .

<noria/ActionPostCondition/DBAccessOK>
    a noria:ActionPostCondition ;
    rdfs:label "Database Access Verified"@en ;
    rdfs:comment "Confirm applications can connect to and query the migrated database successfully."@en .

<noria/ActionPostCondition/ServiceRestored>
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored"@en ;
    rdfs:comment "Confirm the affected service is fully operational and accessible to users."@en ;
    skos:example "Web portal loads quickly, no error messages, customer reports resolved."@en .

