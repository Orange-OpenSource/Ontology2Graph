# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents and Organizations
# =============================================================================

# Organizational Units
<org/ITDepartment>
    a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:label "Département Informatique"@fr ;
    rdfs:comment "The main IT department responsible for all IT operations."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentInstructions "Contact via internal ticketing system for all requests."@en .

<org/NetworkOperationsCenter>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC)"@en ;
    rdfs:label "Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "Team responsible for 24/7 monitoring and initial response to network incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "For critical network issues, call the hotline immediately."@en .

<org/ApplicationSupportL2>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support L2 Team"@en ;
    rdfs:label "Équipe Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support for business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

<org/CyberSecurityTeam>
    a org:OrganizationalUnit ;
    rdfs:label "Cyber Security Team"@en ;
    rdfs:label "Équipe Cybersécurité"@fr ;
    rdfs:comment "Responsible for security monitoring, incident response, and vulnerability management."@en ;
    noria:agentWorkingHours "24/7 for critical incidents"@en .

<org/DevelopmentTeam>
    a org:OrganizationalUnit ;
    rdfs:label "Development Team"@en ;
    rdfs:label "Équipe de Développement"@fr ;
    rdfs:comment "Team responsible for developing and maintaining the customer web portal."@en .

# Individual Agents
<foaf/Agent/AliceSmith>
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Email for non-urgent matters, phone for critical issues."@en .

<foaf/Agent/BobJohnson>
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Database Administrator."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"@en .

<foaf/Agent/CharlieBrown>
    a foaf:Person ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Application Developer."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en .

# =============================================================================
# Locations
# =============================================================================

<bot/Site/ParisDataCenter>
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center for corporate infrastructure."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

<noria/Room/ServerRoomA>
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace <noria/Locus/Rack12A> ;
    bot:hasSpace <noria/Locus/Rack15B> ;
    bot:hasSpace <noria/Locus/Rack20C> ;
    bot:hasSpace <noria/Locus/Rack25D> .

<noria/Locus/Rack12A>
    a noria:Locus ;
    rdfs:label "Rack 12A"@en ;
    rdfs:comment "Location of critical network equipment."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "12"@en .

<noria/Locus/Rack15B>
    a noria:Locus ;
    rdfs:label "Rack 15B"@en ;
    rdfs:comment "Location of database servers."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "15"@en .

<noria/Locus/Rack20C>
    a noria:Locus ;
    rdfs:label "Rack 20C"@en ;
    rdfs:comment "Location of web servers."@en ;
    noria:locusLine "C"@en ;
    noria:locusRow "20"@en .

<noria/Locus/Rack25D>
    a noria:Locus ;
    rdfs:label "Rack 25D"@en ;
    rdfs:comment "Location of virtualization hosts."@en ;
    noria:locusLine "D"@en ;
    noria:locusRow "25"@en .

# =============================================================================
# Product Models
# =============================================================================

<noria/ProductModel/DellPowerEdgeR740>
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <org/DellTechnologies> .

<org/DellTechnologies>
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of Dell PowerEdge servers."@en .

<noria/ProductModel/CiscoASR1000>
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Enterprise-class aggregation services router."@en ;
    noria:productManufacturedBy <org/CiscoSystems> .

<org/CiscoSystems>
    a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of Cisco networking equipment."@en .

<noria/ProductModel/JuniperMX480>
    a noria:ProductModel ;
    rdfs:label "Juniper MX480 Router"@en ;
    rdfs:comment "Modular router for high-density network deployments."@en ;
    noria:productManufacturedBy <org/JuniperNetworks> .

<org/JuniperNetworks>
    a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of Juniper networking equipment."@en .

<noria/ProductModel/VMwareESXi>
    a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy <org/VMware> .

<org/VMware>
    a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

# =============================================================================
# Resources
# =============================================================================

<noria/Resource/DNS01>
    a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for internal and external name resolution."@en ;
    noria:resourceManagedBy <org/NetworkOperationsCenter> ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel <noria/ProductModel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <noria/Application/CorpDNS> ;
    noria:locatedAtLocus <noria/Locus/Rack12A> ;
    noria:resourceManagementIPAddress <observable/IPAddress/192.168.1.10> .

<noria/Resource/RouterCore01>
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for the corporate network, handling internal and external traffic."@en ;
    noria:resourceManagedBy <org/NetworkOperationsCenter> ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel <noria/ProductModel/CiscoASR1000> ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <noria/Application/InternetAccessApp> ;
    noria:locatedAtLocus <noria/Locus/Rack12A> ;
    noria:resourceManagementIPAddress <observable/IPAddress/10.0.0.1> .

<noria/Resource/VMHost01>
    a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:label "Hôte de Virtualisation 01"@fr ;
    rdfs:comment "ESXi host running multiple virtual machines."@en ;
    noria:resourceManagedBy <org/ITDepartment> ;
    noria:resourceHostName "vmhost01.corp.example.com" ;
    noria:resourceProductModel <noria/ProductModel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceLogisticId "LOG-VMH-001" ;
    noria:resourceSerialNumber "SN-VMH-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <noria/Locus/Rack25D> ;
    noria:resourceManagementIPAddress <observable/IPAddress/192.168.1.20> .

<noria/Resource/WebSrv03>
    a noria:Resource ;
    rdfs:label "Web Server 03"@en ;
    rdfs:label "Serveur Web 03"@fr ;
    rdfs:comment "Server hosting the customer web portal frontend."@en ;
    noria:resourceManagedBy <org/ApplicationSupportL2> ;
    noria:resourceHostName "websrv03.dmz.example.com" ;
    noria:resourceProductModel <noria/ProductModel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <noria/Application/CustomerWebPortal> ;
    noria:locatedAtLocus <noria/Locus/Rack20C> ;
    noria:resourceManagementIPAddress <observable/IPAddress/172.16.0.10> .

<noria/Resource/FirewallDMZ01>
    a noria:Resource ;
    rdfs:label "DMZ Firewall 01"@en ;
    rdfs:label "Pare-feu DMZ 01"@fr ;
    rdfs:comment "Firewall protecting the DMZ segment."@en ;
    noria:resourceManagedBy <org/CyberSecurityTeam> ;
    noria:resourceHostName "fw-dmz-01.corp.example.com" ;
    noria:resourceProductModel <noria/ProductModel/JuniperMX480> ; # Using a router model as a placeholder for a firewall, as no specific firewall product model is in the schema.
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-08-20T16:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <noria/Application/CustomerWebPortal> ;
    noria:locatedAtLocus <noria/Locus/Rack12A> ;
    noria:resourceManagementIPAddress <observable/IPAddress/10.0.1.1> .

<noria/Resource/DBServer01>
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:label "Serveur de Base de Données 01"@fr ;
    rdfs:comment "Primary database server for the internal CRM system."@en ;
    noria:resourceManagedBy <foaf/Agent/BobJohnson> ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceProductModel <noria/ProductModel/DellPowerEdgeR740> ;
    noria:resourceType <kos/Resource/type/database-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-11-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication <noria/Application/InternalCRM> ;
    noria:locatedAtLocus <noria/Locus/Rack15B> ;
    noria:resourceManagementIPAddress <observable/IPAddress/192.168.2.10> .

# =============================================================================
# Network Interfaces
# =============================================================================

<noria/NetworkInterface/DNS01-Eth0>
    a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DNS01 server."@en ;
    noria:networkInterfaceOf <noria/Resource/DNS01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <noria/NetworkLink/Link-DNS-LAN> .

<noria/NetworkInterface/RouterCore01-Gi0_0_1>
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting to the internal corporate network."@en ;
    noria:networkInterfaceOf <noria/Resource/RouterCore01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to corporate LAN."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceConnects <noria/NetworkLink/Link-Core-LAN> .

<noria/NetworkInterface/RouterCore01-Gi0_0_2>
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting to the Internet service provider."@en ;
    noria:networkInterfaceOf <noria/Resource/RouterCore01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to ISP."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 ;
    noria:networkInterfaceConnects <noria/NetworkLink/Link-Core-Internet> .

<noria/NetworkInterface/FirewallDMZ01-Ext>
    a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ01 External Interface"@en ;
    rdfs:comment "External facing interface of the DMZ firewall."@en ;
    noria:networkInterfaceOf <noria/Resource/FirewallDMZ01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Interface connected to the public internet."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <noria/NetworkLink/Link-Firewall-Internet> .

<noria/NetworkInterface/WebSrv03-Eth0>
    a noria:NetworkInterface ;
    rdfs:label "WebSrv03 Ethernet 0"@en ;
    rdfs:comment "Network interface for Web Server 03 in DMZ."@en ;
    noria:networkInterfaceOf <noria/Resource/WebSrv03> ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceDescription "Virtual interface in DMZ segment."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceConnects <noria/NetworkLink/Link-Firewall-WebSrv> .

# =============================================================================
# Network Links
# =============================================================================

<noria/NetworkLink/Link-DNS-LAN>
    a noria:NetworkLink ;
    rdfs:label "DNS to LAN Link"@en ;
    rdfs:comment "Internal network link connecting DNS01 to the corporate LAN switch."@en ;
    noria:networkLinkId "NL-DNS-LAN-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <noria/Resource/DNS01> ;
    noria:networkLinkTerminationResourceDestination <noria/Resource/RouterCore01> ; # Assuming RouterCore01 is the gateway for LAN
    noria:resourceManagedBy <org/NetworkOperationsCenter> .

<noria/NetworkLink/Link-Core-LAN>
    a noria:NetworkLink ;
    rdfs:label "Core Router to LAN Link"@en ;
    rdfs:comment "Internal network link connecting RouterCore01 to the corporate LAN."@en ;
    noria:networkLinkId "NL-CORE-LAN-001" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <noria/Resource/RouterCore01> ;
    noria:networkLinkTerminationResourceDestination <noria/Resource/DNS01> ; # Example of another resource on LAN
    noria:resourceManagedBy <org/NetworkOperationsCenter> .

<noria/NetworkLink/Link-Core-Internet>
    a noria:NetworkLink ;
    rdfs:label "Core Router to Internet Link"@en ;
    rdfs:comment "External network link connecting RouterCore01 to the Internet Service Provider."@en ;
    noria:networkLinkId "NL-CORE-ISP-001" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <noria/Resource/RouterCore01> ;
    noria:resourceManagedBy <org/NetworkOperationsCenter> .

<noria/NetworkLink/Link-Firewall-Internet>
    a noria:NetworkLink ;
    rdfs:label "DMZ Firewall to Internet Link"@en ;
    rdfs:comment "External network link connecting FirewallDMZ01 to the Internet."@en ;
    noria:networkLinkId "NL-FW-ISP-001" ;
    noria:networkLinkType "Dedicated Internet Access" ;
    noria:networkLinkInstallationDate "2022-08-20T16:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <noria/Resource/FirewallDMZ01> ;
    noria:resourceManagedBy <org/CyberSecurityTeam> .

<noria/NetworkLink/Link-Firewall-WebSrv>
    a noria:NetworkLink ;
    rdfs:label "DMZ Firewall to Web Server Link"@en ;
    rdfs:comment "Internal DMZ link between FirewallDMZ01 and WebSrv03."@en ;
    noria:networkLinkId "NL-FW-WEB-001" ;
    noria:networkLinkType "VLAN" ;
    noria:networkLinkInstallationDate "2023-05-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <noria/Resource/FirewallDMZ01> ;
    noria:networkLinkTerminationResourceDestination <noria/Resource/WebSrv03> ;
    noria:resourceManagedBy <org/CyberSecurityTeam> .

# =============================================================================
# Applications
# =============================================================================

<noria/Application/CorpDNS>
    a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:label "Service DNS d'Entreprise"@fr ;
    rdfs:comment "Provides name resolution for all corporate services and users."@en ;
    noria:applicationModelIdentifier "CORP-DNS-V2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CorpDNS" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "DNS Management"@en .

<noria/Application/CustomerWebPortal>
    a noria:Application ;
    rdfs:label "Customer Web Portal"@en ;
    rdfs:label "Portail Web Client"@fr ;
    rdfs:comment "Public-facing web application for customer interactions."@en ;
    noria:applicationModelIdentifier "CUST-PORTAL-V3" ;
    noria:applicationNumericalIdentifier 2002 ;
    noria:applicationShortIdentifier "WebPortal" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Online Self-Service"@en .

<noria/Application/InternalCRM>
    a noria:Application ;
    rdfs:label "Internal CRM System"@en ;
    rdfs:label "Système CRM Interne"@fr ;
    rdfs:comment "Customer Relationship Management system used by internal sales and support teams."@en ;
    noria:applicationModelIdentifier "INT-CRM-V1" ;
    noria:applicationNumericalIdentifier 3003 ;
    noria:applicationShortIdentifier "InternalCRM" ;
    noria:applicationType <kos/application/type/business-support> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Sales and Marketing"@en ;
    noria:applicationFunctionalSubDomain "Customer Data Management"@en .

<noria/Application/MonitoringSystem>
    a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:label "Système de Supervision Réseau"@fr ;
    rdfs:comment "Application for monitoring network devices and services."@en ;
    noria:applicationModelIdentifier "NMS-PRO-V1" ;
    noria:applicationNumericalIdentifier 4004 ;
    noria:applicationShortIdentifier "NMS" ;
    noria:applicationType <kos/application/type/management-tool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Network Performance Monitoring"@en .

# =============================================================================
# Application Modules
# =============================================================================

<noria/ApplicationModule/CorpDNS-Prod>
    a noria:ApplicationModule ;
    rdfs:label "Corporate DNS Production Module"@en ;
    rdfs:label "Module de Production DNS d'Entreprise"@fr ;
    rdfs:comment "Production instance of the Corporate DNS Service."@en ;
    noria:applicationModuleOf <noria/Application/CorpDNS> ;
    noria:applicationModuleIdentifier "PROD-01" ;
    noria:applicationModuleName "CorpDNS_PROD-01" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleAdministrationTeam <org/NetworkOperationsCenter> ;
    noria:applicationModuleSupportTeam <org/NetworkOperationsCenter> ;
    noria:applicationModuleAdministrationLeader <foaf/Agent/AliceSmith> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true .

<noria/ApplicationModule/WebPortal-Frontend>
    a noria:ApplicationModule ;
    rdfs:label "Customer Web Portal Frontend Module"@en ;
