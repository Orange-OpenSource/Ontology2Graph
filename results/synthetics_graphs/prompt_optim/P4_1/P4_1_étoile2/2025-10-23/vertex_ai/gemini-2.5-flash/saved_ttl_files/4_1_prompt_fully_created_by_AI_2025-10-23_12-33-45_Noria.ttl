# --- Operation Plans (noria:OperationPlan) ---
noria:OpPlan_RouterOSUpdate a noria:OperationPlan ;
    rdfs:label "Router OS Update Procedure"@en ;
    rdfs:comment "Standard operating procedure for updating router operating systems."@en ;
    skos:example "Steps include pre-checks, backup, upgrade execution, and post-checks."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterReachability ;
    noria:operationPlanPostCondition noria:PostCond_RouterOnline .

noria:OpPlan_DBBackup a noria:OperationPlan ;
    rdfs:label "Database Backup Procedure"@en ;
    rdfs:comment "Procedure for performing a full backup of the production database."@en ;
    skos:example "Includes consistency checks, backup execution, and verification."@en ;
    noria:operationPlanPreCondition noria:PreCond_DBConsistent ;
    noria:operationPlanPostCondition noria:PostCond_BackupComplete .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:PreCond_RouterReachability a noria:ActionPreCondition ;
    rdfs:label "Router Reachability Check"@en ;
    rdfs:comment "Verify that the router is reachable and all interfaces are up before starting the OS update."@en ;
    skos:example "Ping management IP, check interface status via SNMP."@en .

noria:PostCond_RouterOnline a noria:ActionPostCondition ;
    rdfs:label "Router Online Verification"@en ;
    rdfs:comment "Confirm that the router has successfully rebooted, all critical services are running, and network traffic is flowing."@en ;
    skos:example "Verify routing tables, test connectivity to adjacent devices, check system logs for errors."@en .

noria:PreCond_DBConsistent a noria:ActionPreCondition ;
    rdfs:label "Database Consistency Check"@en ;
    rdfs:comment "Ensure the database is in a consistent state and no active transactions are running before backup."@en ;
    skos:example "Run database consistency checks, verify transaction logs."@en .

noria:PostCond_BackupComplete a noria:ActionPostCondition ;
    rdfs:label "Backup Completion Verification"@en ;
    rdfs:comment "Confirm that the database backup process completed successfully and the backup files are valid."@en ;
    skos:example "Check backup logs, verify file sizes, attempt a small restore test."@en .

