# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
noria:Agent_AdminTeam a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and related infrastructure."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all non-critical issues. For critical issues, use emergency hotline."@en .

noria:Agent_NetworkOps a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Escalate critical network incidents directly to the on-call engineer."@en .

noria:Agent_AppDev a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> .

noria:Agent_SecurityAnalyst a foaf:Agent ;
    rdfs:label "Security Analyst John Doe"@en ;
    rdfs:comment "Individual responsible for security monitoring and incident response."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

noria:OrgUnit_L1Support a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Level 1 Support"@en, "Support Nivel 1"@fr ;
    rdfs:comment "First line of support for customer and internal issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> .

noria:OrgUnit_L2Support a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Level 2 Support"@en, "Support Nivel 2"@fr ;
    rdfs:comment "Second line of support, handling more complex technical issues."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

noria:OrgUnit_Hotline a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Hotline Team"@en, "Équipe d'astreinte"@fr ;
    rdfs:comment "Emergency contact for critical incidents outside business hours."@en ;
    noria:agentWorkingHours "On-call 24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> .

noria:Agent_CustomerA a foaf:Agent ;
    rdfs:label "Customer A"@en ;
    rdfs:comment "A key corporate customer."@en .

noria:Agent_ExternalVendor a foaf:Agent ;
    rdfs:label "External Hardware Vendor"@en ;
    rdfs:comment "Vendor providing hardware maintenance and support."@en .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en, "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center location for corporate infrastructure."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en, "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    seas:subSystemOf noria:Site_ParisDC .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "2"@en ;
    seas:subSystemOf noria:Room_ServerRoomA .

# --- Product Models (noria:ProductModel) ---
noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy <https://www.dell.com/> .

noria:ProductModel_CiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center class network switch/router."@en ;
    noria:productManufacturedBy <https://www.cisco.com/> .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization hypervisor host."@en ;
    noria:productManufacturedBy <https://www.vmware.com/> .

# --- Resources (noria:Resource) ---
noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, critical infrastructure."@en ;
    noria:resourceManagedBy noria:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for data center network connectivity."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "router-core01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-07-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_VMHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "ESXi host running multiple virtual machines."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "vmhost01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceLogisticId "LOG-VMH-001" ;
    noria:resourceType <kos/Resource/type/virtualization-host> ;
    noria:resourceSerialNumber "SN-VMH-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.100" .

noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate web services."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:clusterController noria:Resource_VMHost01 ;
    noria:resourceForApplication noria:App_CustomerPortal .

noria:Resource_DB01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate database."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "db01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:clusterController noria:Resource_VMHost01 ;
    noria:resourceForApplication noria:App_CustomerPortal .

# --- Network Interfaces (noria:NetworkInterface) ---
noria:NetIF_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Management interface for DNS server" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetIF_RouterCore01_Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Uplink interface for RouterCore01 to external network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "External WAN uplink" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetIF_RouterCore01_Gi0_0_2 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Internal network interface for RouterCore01 to DNS server."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Internal LAN segment for DNS" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

noria:NetIF_VMHost01_vSwitch0 a noria:NetworkInterface ;
    rdfs:label "VMHost01 vSwitch0"@en ;
    rdfs:comment "Virtual switch interface on VMHost01."@en ;
    noria:networkInterfaceOf noria:Resource_VMHost01 ;
    noria:networkInterfaceDescription "Virtual switch for VM network traffic" ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links (noria:NetworkLink) ---
noria:NetLink_DC_Uplink a noria:NetworkLink ;
    rdfs:label "Data Center Uplink to ISP"@en ;
    rdfs:comment "High-speed fiber link connecting the data center to the internet service provider."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkId "NL-DC-ISP-001" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkInstallationDate "2020-07-01T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic WAN" ;
    noria:networkInterfaceConnects noria:NetIF_RouterCore01_Gi0_0_1 .

noria:NetLink_Internal_DNS a noria:NetworkLink ;
    rdfs:label "Internal DNS Network Link"@en ;
    rdfs:comment "Ethernet link between core router and DNS server."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:networkLinkId "NL-INT-DNS-001" ;
    noria:networkLinkTerminationResource noria:Resource_DNS01, noria:Resource_RouterCore01 ;
    noria:networkLinkInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet LAN" ;
    noria:networkInterfaceConnects noria:NetIF_DNS01_Eth0, noria:NetIF_RouterCore01_Gi0_0_2 .

# --- Applications (noria:Application) ---
noria:App_CorpInternetAccess a noria:Application ;
    rdfs:label "Corporate Internet Access"@en ;
