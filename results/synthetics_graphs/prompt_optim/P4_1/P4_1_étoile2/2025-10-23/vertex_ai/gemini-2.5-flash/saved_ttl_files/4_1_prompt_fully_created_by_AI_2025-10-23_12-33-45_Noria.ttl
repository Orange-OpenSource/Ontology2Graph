# --- Services (noria:Service) ---
noria:Service_InternetConnectivity a noria:Service ;
    rdfs:label "Internet Connectivity Service"@en ;
    rdfs:comment "End-to-end service providing internet access to corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CorpInternetAccess_Prod .

noria:Service_CustomerFacing a noria:Service ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "Service encompassing all customer-facing applications and infrastructure."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CustomerPortal_Prod .

# --- Event Records (noria:EventRecord) ---
noria:Event_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Outage Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-10T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "CRITICAL: DNS server dns01.corp.example.com is unreachable."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a critical router interface went down."@en ;
    noria:loggingTime "2024-04-10T09:29:50Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "Interface GigabitEthernet0/0/1 on router-core01 changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_WebSrvError a noria:EventRecord ;
    rdfs:label "Web Server Application Error"@en ;
    rdfs:comment "Log entry indicating an error in the web server application."@en ;
    noria:loggingTime "2024-04-10T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringSystem ;
    noria:logText "ERROR: Customer Portal application encountered a database connection error."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_ConfigChange a noria:EventRecord ;
    rdfs:label "Router Configuration Change"@en ;
    rdfs:comment "Log entry detailing a configuration change on the core router."@en ;
    noria:loggingTime "2024-04-09T15:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent noria:Agent_NetworkOps ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by NetworkOps (10.0.0.5)."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# --- Trouble Tickets (noria:TroubleTicket) ---
noria:TT_DNSOutage a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:comment "Critical incident: Corporate DNS server is down, impacting internet access."@en ;
    dcterms:created "2024-04-10T09:35:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-10T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Network connectivity issue to DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-10T09:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-10T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Agent_AdminTeam, noria:Agent_NetworkOps ;
    noria:troubleTicketRelatedService noria:App_CorpInternetAccess ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01, noria:Resource_RouterCore01 ;
    noria:troubleTicketImpacts noria:App_CorpInternetAccess, noria:Resource_DNS01 ;
    noria:troubleTicketTrigger noria:Event_DNSOutageLog ;
    noria:documentHRef "https://ticketing.example.com/TT_DNSOutage" .

noria:TT_CustomerPortalIssue a noria:TroubleTicket ;
    rdfs:label "Customer Portal Access Issue"@en ;
    rdfs:comment "Customers reporting intermittent access issues to the portal."@en ;
    dcterms:created "2024-04-10T10:20:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-10T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
