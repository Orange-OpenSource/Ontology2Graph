    noria:resourceLogisticId "AS01-DC01-R1" ;
    noria:resourceProductModel noria:ProductModelDellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:ITOperationsTeam ;
    noria:locatedAtLocus noria:RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> .

noria:DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:comment "Server hosting the main corporate database."@en ;
    noria:resourceHostName "dbserver01.corp.example.com" ;
    noria:resourceLogisticId "DB01-DC01-R1" ;
    noria:resourceProductModel noria:ProductModelDellR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:ITOperationsTeam ;
    noria:locatedAtLocus noria:RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.11> .

noria:Router01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for internal network traffic."@en ;
    noria:resourceHostName "router01.corp.example.com" ;
    noria:resourceLogisticId "CR01-DC01-R2" ;
    noria:resourceProductModel noria:ProductModelCiscoNexus9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:NetworkSupportTeam ;
    noria:locatedAtLocus noria:RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Firewall protecting the corporate network from external threats."@en ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceLogisticId "FW01-DC01-R2" ;
    noria:resourceProductModel noria:ProductModelPaloAltoFirewall ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:SecurityTeam ;
    noria:locatedAtLocus noria:RackA2 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.2> .

noria:VirtualMachineWeb01 a noria:Resource ;
    rdfs:label "Web Server VM 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate website."@en ;
    noria:resourceHostName "web01.corp.example.com" ;
    noria:resourceLogisticId "VMWEB01-DC01" ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-10T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy org:ITOperationsTeam ;
    noria:clusterController noria:AppServer01 ; # Assuming AppServer01 is a hypervisor/cluster controller
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.20> .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:NI_AppServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "AppServer01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for AppServer01."@en ;
    noria:networkInterfaceOf noria:AppServer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Uplink to core switch."@en ;
    noria:networkInterfaceConnects noria:Link_AppServer01_Router01 .

noria:NI_Router01_Gig0_0_1 a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Router01 to AppServer01."@en ;
    noria:networkInterfaceOf noria:Router01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Connection to internal application servers."@en ;
    noria:networkInterfaceConnects noria:Link_AppServer01_Router01 .

noria:NI_Router01_Gig0_0_2 a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet0/0/2"@en ;
    rdfs:comment "Interface connecting Router01 to Firewall01."@en ;
    noria:networkInterfaceOf noria:Router01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Uplink to perimeter firewall."@en ;
    noria:networkInterfaceConnects noria:Link_Router01_Firewall01 .

noria:NI_Firewall01_Eth1_1 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet1/1"@en ;
    rdfs:comment "Interface connecting Firewall01 to Router01."@en ;
    noria:networkInterfaceOf noria:Firewall01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Internal network interface."@en ;
    noria:networkInterfaceConnects noria:Link_Router01_Firewall01 .

noria:NI_Firewall01_Eth1_2 a noria:NetworkInterface ;
    rdfs:label "Firewall01 Ethernet1/2"@en ;
    rdfs:comment "Interface connecting Firewall01 to the Internet."@en ;
    noria:networkInterfaceOf noria:Firewall01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "External network interface (Internet facing)."@en ;
    noria:networkInterfaceConnects noria:Link_Firewall01_Internet .

# =============================================================================
# Network Links
# =============================================================================

noria:Link_AppServer01_Router01 a noria:NetworkLink ;
    rdfs:label "Link AppServer01 to Router01"@en ;
    rdfs:comment "Physical Ethernet link between AppServer01 and Router01."@en ;
    noria:networkLinkId "LINK-AS01-CR01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:AppServer01 ;
    noria:networkLinkTerminationResourceDestination noria:Router01 ;
    noria:resourceManagedBy org:NetworkSupportTeam .

noria:Link_Router01_Firewall01 a noria:NetworkLink ;
    rdfs:label "Link Router01 to Firewall01"@en ;
    rdfs:comment "Physical Ethernet link between Router01 and Firewall01."@en ;
    noria:networkLinkId "LINK-CR01-FW01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2021-03-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Router01 ;
    noria:networkLinkTerminationResourceDestination noria:Firewall01 ;
    noria:resourceManagedBy org:NetworkSupportTeam .

noria:Link_Firewall01_Internet a noria:NetworkLink ;
    rdfs:label "Link Firewall01 to Internet"@en ;
    rdfs:comment "External WAN link connecting Firewall01 to the Internet."@en ;
    noria:networkLinkId "LINK-FW01-INET" ;
    noria:networkLinkType "Fiber Optic WAN" ;
    noria:networkLinkInstallationDate "2021-03-01T09:45:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin noria:Firewall01 ;
    noria:resourceManagedBy org:NetworkSupportTeam .

# =============================================================================
# Applications
# =============================================================================

noria:CorporateWebsiteApp a noria:Application ;
    rdfs:label "Corporate Website Application"@en ;
    rdfs:comment "The main public-facing website for the corporation."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CWEB" ;
    noria:applicationType <kos/application/type/CustomerFacing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Marketing and Sales"@en ;
    noria:applicationFunctionalSubDomain "Online Presence Management"@en ;
    noria:resourceForApplication noria:VirtualMachineWeb01 .

noria:InternalCRMApp a noria:Application ;
    rdfs:label "Internal CRM Application"@en ;
    rdfs:comment "Customer Relationship Management system used by sales and support teams."@en ;
    noria:applicationModelIdentifier "CRM" ;
    noria:applicationNumericalIdentifier 1002 ;
    noria:applicationShortIdentifier "ICRM" ;
    noria:applicationType <kos/application/type/InternalBusiness> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Sales and Support Operations"@en ;
    noria:resourceForApplication noria:AppServer01, noria:DBServer01 .

noria:MonitoringSystemApp a noria:Application ;
    rdfs:label "IT Monitoring System"@en ;
    rdfs:comment "Application responsible for collecting and analyzing IT infrastructure metrics and logs."@en ;
    noria:applicationModelIdentifier "MONSYS" ;
    noria:applicationNumericalIdentifier 1003 ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Monitoring and Alerting"@en .

# =============================================================================
# Application Modules
# =============================================================================

noria:CorporateWebsiteProdModule a noria:ApplicationModule ;
    rdfs:label "Corporate Website Production Module"@en ;
    rdfs:comment "Production instance of the Corporate Website Application."@en ;
    noria:applicationModuleOf noria:CorporateWebsiteApp ;
    noria:applicationModuleName "CWEB_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleAdministrationTeam org:AppDevTeam ;
    noria:applicationModuleSupportTeam org:ITOperationsTeam ;
    noria:applicationModuleHotlineEnabled true .

noria:InternalCRMProdModule a noria:ApplicationModule ;
    rdfs:label "Internal CRM Production Module"@en ;
    rdfs:comment "Production instance of the Internal CRM Application."@en ;
    noria:applicationModuleOf noria:InternalCRMApp ;
    noria:applicationModuleName "CRM_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleAdministrationTeam org:AppDevTeam ;
    noria:applicationModuleSupportTeam org:ITOperationsTeam ;
    noria:applicationModuleHotlineEnabled true .

noria:MonitoringSystemProdModule a noria:ApplicationModule ;
    rdfs:label "IT Monitoring System Production Module"@en ;
    rdfs:comment "Production instance of the IT Monitoring System Application."@en ;
    noria:applicationModuleOf noria:MonitoringSystemApp ;
    noria:applicationModuleName "MONSYS_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleAdministrationTeam org:ITOperationsTeam ;
    noria:applicationModuleSupportTeam org:ITOperationsTeam ;
    noria:applicationModuleHotlineEnabled true .

# =============================================================================
# Services
# =============================================================================

noria:InternetAccessService a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet connectivity for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:CorporateWebsiteProdModule, noria:InternalCRMProdModule ; # Services are composed of application modules
    noria:resourceManagedBy org:NetworkSupportTeam .

noria:DatabaseService a noria:Service ;
    rdfs:label "Corporate Database Service"@en ;
    rdfs:comment "Centralized database service for all internal applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:InternalCRMProdModule ;
    noria:resourceManagedBy org:ITOperationsTeam .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord_Router01_InterfaceDown a noria:EventRecord ;
    rdfs:label "Router01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Router01 went down."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Router01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemApp ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_AppServer01_HighCPU a noria:EventRecord ;
    rdfs:label "AppServer01 High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on AppServer01."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on appserver01 exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:AppServer01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemApp ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_Firewall01_BlockedAttack a noria:EventRecord ;
    rdfs:label "Firewall01 Blocked Attack Event"@en ;
    rdfs:comment "Security event: Firewall blocked an attempted intrusion."@en ;
    noria:loggingTime "2024-04-23T09:45:00Z"^^xsd:dateTime ;
    noria:logText "Blocked SYN flood attack from 203.0.113.42 on port 80."@en ;
    noria:logOriginatingManagedObject noria:Firewall01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemApp ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_UserLoginFailure a noria:EventRecord ;
    rdfs:label "User Login Failure Event"@en ;
    rdfs:comment "Log entry for a failed login attempt on a system."@en ;
    noria:loggingTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Failed login for user 'jdoe' from IP 192.168.1.5."@en ;
    noria:logOriginatingManagedObject noria:AppServer01 ;
    noria:logOriginatingAgent foaf:AgentJohnDoe ; # Assuming John Doe tried to log in
    noria:logOriginatingManagementSystem noria:MonitoringSystemApp ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

# =============================================================================
# Trouble Tickets
# =============================================================================

noria:TroubleTicket_RouterOutage a noria:TroubleTicket ;
    rdfs:label "Router01 Interface Down Incident"@en ;
    rdfs:comment "Critical incident: Core Router 01's interface to application servers is down, impacting multiple services."@en ;
    dcterms:identifier "TT-20240423-001" ;
    dcterms:created "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Suspected fiber cut or faulty SFP module."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:NetworkSupportTeam, foaf:AgentJohnDoe ;
    noria:troubleTicketRelatedService noria:InternetAccessService, noria:DatabaseService ;
    noria:troubleTicketRelatedResource noria:Router01, noria:AppServer01, noria:DBServer01 ;
    noria:troubleTicketImpacts noria:CorporateWebsiteApp, noria:InternalCRMApp ;
    noria:troubleTicketTrigger noria:EventRecord_Router01_InterfaceDown ;
    noria:documentHRef <http://ticketing.example.com/TT-20240423-001> .

noria:TroubleTicket_HighCPU a noria:TroubleTicket ;
    rdfs:label "AppServer01 High CPU Incident"@en ;
    rdfs:comment "Incident: AppServer01 experiencing high CPU, potentially impacting CRM performance."@en ;
    dcterms:identifier "TT-20240423-002" ;
    dcterms:created "2024-04-23T10:20:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Prometheus"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
    noria:troubleTicketCause "Unidentified process consuming excessive CPU resources."@en ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:ITOperationsTeam, foaf:AgentJaneSmith ;
    noria:troubleTicketRelatedService noria:InternalCRMApp ;
    noria:troubleTicketRelatedResource noria:AppServer01 ;
    noria:troubleTicketImpacts noria:InternalCRMApp ;
    noria:troubleTicketTrigger noria:EventRecord_AppServer01_HighCPU ;
    noria:documentHRef <http://ticketing.example.com/TT-20240423-002> .

# =============================================================================
# Trouble Ticket Notes
# =============================================================================

noria:TroubleTicketNote_RouterOutage_Update1 a noria:TroubleTicketNote ;
    rdfs:label "Router Outage Update 1"@en ;
    rdfs:comment "Initial diagnosis: Interface status confirmed down. Investigating physical layer."@en ;
    dcterms:created "2024-04-23T10:25:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:AgentJohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_RouterOutage .

noria:TroubleTicketNote_RouterOutage_Update2 a noria:TroubleTicketNote ;
    rdfs:label "Router Outage Update 2"@en ;
    rdfs:comment "Replaced SFP module on Router01. Interface is now up. Monitoring service restoration."@en ;
    dcterms:created "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:AgentJohnDoe ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    dcterms:isPartOf noria:TroubleTicket_RouterOutage .

# =============================================================================
# Change Requests
# =============================================================================

noria:ChangeRequest_FirewallUpgrade a noria:ChangeRequest ;
    rdfs:label "Firewall Firmware Upgrade"@en ;
    rdfs:comment "Planned firmware upgrade for Perimeter Firewall 01 to address security vulnerabilities."@en ;
    dcterms:identifier "CR-20240501-001" ;
    dcterms:created "2024-04-15T09:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Firewall01, noria:InternetAccessService ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ; # 1 hour 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty foaf:AgentAliceJohnson ;
    noria:changeRequestPilotParty org:SecurityTeam ;
    noria:changeRequestActorParty org:NetworkSupportTeam ;
    noria:changeRequestIsRegulated true ;
    noria:documentHRef <http://changemanagement.example.com/CR-20240501-001> .

noria:ChangeRequest_DBMigration a noria:ChangeRequest ;
    rdfs:label "Database Migration to New Server"@en ;
    rdfs:comment "Migration of the corporate database from DBServer01 to a new, more powerful server."@en ;
    dcterms:identifier "CR-20240601-002" ;
    dcterms:created "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-06-01T00:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-06-01T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/HardwareUpgrade> ;
    noria:changeRequestImpact noria:DBServer01, noria:InternalCRMApp, noria:DatabaseService ;
    noria:changeRequestOutageDuration "PT3H"^^xsd:duration ; # 3 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Planned> ;
    noria:changeRequestInitiatorParty foaf:AgentAliceJohnson ;
    noria:changeRequestPilotParty org:AppDevTeam ;
    noria:changeRequestActorParty org:ITOperationsTeam ;
    noria:changeRequestIsRegulated false ;
    noria:documentHRef <http://changemanagement.example.com/CR-20240601-002> .

# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlan_RouterInterfaceTroubleshooting a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Plan"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving router interface issues."@en ;
    skos:example "Steps include checking cable, SFP, port status, and replacing components."@en ;
    noria:operationPlanPreCondition noria:PreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:PostCondition_InterfaceUp .

noria:PreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Down>" .

noria:PostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up' and traffic is flowing."@en ;
    skos:example "noria:networkInterfaceOperationalStatus = <kos/Resource/OperationalState/Up>" .

noria:OperationPlan_AppServerCPUFix a noria:OperationPlan ;
    rdfs:label "Application Server High CPU Remediation"@en ;
    rdfs:comment "Procedure to identify and mitigate high CPU usage on application servers."@en ;
    skos:example "Steps include identifying rogue processes, analyzing logs, and restarting services."@en ;
    noria:operationPlanPreCondition noria:PreCondition_HighCPU ;
    noria:operationPlanPostCondition noria:PostCondition_NormalCPU .

noria:PreCondition_HighCPU a noria:ActionPreCondition ;
    rdfs:label "High CPU Utilization"@en ;
    rdfs:comment "Condition: CPU utilization on an application server exceeds a predefined threshold."@en ;
    skos:example "CPU > 90% for 5 minutes." .

noria:PostCondition_NormalCPU a noria:ActionPostCondition ;
    rdfs:label "Normal CPU Utilization"@en ;
    rdfs:comment "Expected outcome: CPU utilization returns to normal levels (below threshold)."@en ;
    skos:example "CPU < 70% for 15 minutes." .

# Connecting Operation Plans to Trouble Tickets (via Event Records)
# This is an indirect connection as per NORIA, where EventRecords can be pep:ProcedureExecution
# and pep:ProcedureExecutionContainer (like TroubleTicket) can contain pep:ProcedureExecution.
# The `noria:alarmProposedRepairAction` property links an EventRecord to a pep:Procedure (OperationPlan).
noria:EventRecord_Router01_InterfaceDown noria:alarmProposedRepairAction noria:OperationPlan_RouterInterfaceTroubleshooting .
noria:EventRecord_AppServer01_HighCPU noria:alarmProposedRepairAction noria:OperationPlan_AppServerCPUFix .

# Example of documentStatusHistory for a TroubleTicket
noria:EventRecord_TT_RouterOutage_StatusChange_InProgress a noria:EventRecord ;
    rdfs:label "TT-20240423-001 Status Change to InProgress"@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logText "Trouble Ticket TT-20240423-001 status changed to InProgress."@en ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemApp ;
    noria:logOriginatingAgent foaf:AgentAliceJohnson ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:TroubleTicket_RouterOutage noria:documentStatusHistory noria:EventRecord_TT_RouterOutage_StatusChange_InProgress .

# Example of documentStatusHistory for a ChangeRequest
noria:EventRecord_CR_FirewallUpgrade_StatusChange_Scheduled a noria:EventRecord ;
    rdfs:label "CR-20240501-001 Status Change to Scheduled"@en ;
    noria:loggingTime "2024-04-18T14:00:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-20240501-001 status changed to Scheduled."@en ;
    noria:logOriginatingManagementSystem noria:MonitoringSystemApp ;
    noria:logOriginatingAgent foaf:AgentAliceJohnson ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:ChangeRequest_FirewallUpgrade noria:documentStatusHistory noria:EventRecord_CR_FirewallUpgrade_StatusChange_Scheduled .
