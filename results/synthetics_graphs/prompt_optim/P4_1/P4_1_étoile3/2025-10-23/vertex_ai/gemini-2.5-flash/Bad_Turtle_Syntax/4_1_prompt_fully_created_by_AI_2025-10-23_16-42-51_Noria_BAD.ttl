# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

<https://w3id.org/noria/operation-plan/restart-dns-service> a noria:OperationPlan ;
    rdfs:label "Restart DNS Service Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the 'named' DNS service on Linux servers."@en ;
    skos:example "Steps include checking process status, attempting graceful restart, force killing if necessary, and verifying service functionality."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/action-precondition/dns-service-down> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/action-postcondition/dns-service-up> .

<https://w3id.org/noria/action-precondition/dns-service-down> a noria:ActionPreCondition ;
    rdfs:label "DNS Service Down"@en ;
    rdfs:comment "Condition: The 'named' DNS service is not running or not responding on the target server."@en ;
    skos:example "Verification: 'systemctl status named' shows inactive, or DNS queries fail."@en .

<https://w3id.org/noria/action-postcondition/dns-service-up> a noria:ActionPostCondition ;
    rdfs:label "DNS Service Up and Responding"@en ;
    rdfs:comment "Condition: The 'named' DNS service is running and successfully resolving DNS queries."@en ;
    skos:example "Verification: 'systemctl status named' shows active, and 'dig example.com' returns valid results."@en .

<https://w3id.org/noria/operation-plan/dns-software-upgrade> a noria:OperationPlan ;
    rdfs:label "DNS Software Upgrade Procedure"@en ;
    rdfs:comment "Detailed procedure for upgrading the BIND DNS software on production servers, including backup, upgrade, and testing steps."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/action-precondition/maintenance-window-approved> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/action-postcondition/dns-software-upgraded> .

<https://w3id.org/noria/action-precondition/maintenance-window-approved> a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Approved"@en ;
    rdfs:comment "Condition: A scheduled maintenance window has been approved and communicated for the upgrade."@en .

<https://w3id.org/noria/action-postcondition/dns-software-upgraded> a noria:ActionPostCondition ;
    rdfs:label "DNS Software Upgraded and Verified"@en ;
    rdfs:comment "Condition: The DNS software has been successfully upgraded to the target version and all functionalities verified."@en .

