    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Primary network interface for management and DNS traffic."@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects <https://w3id.org/noria/network-link/dns01-to-cr01> .

<https://w3id.org/noria/network-interface/cr01-ge0-0-0> a noria:NetworkInterface ;
    rdfs:label "cr01-ge0/0/0"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/0 on Core Router 01."@en ;
    noria:networkInterfaceOf <https://w3id.org/noria/resource/core-router-01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to DNS server segment."@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects <https://w3id.org/noria/network-link/dns01-to-cr01> .

<https://w3id.org/noria/network-interface/cr01-ge0-0-1> a noria:NetworkInterface ;
    rdfs:label "cr01-ge0/0/1"@en ;
    rdfs:comment "GigabitEthernet interface 0/0/1 on Core Router 01."@en ;
    noria:networkInterfaceOf <https://w3id.org/noria/resource/core-router-01> ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceDescription "Uplink to Internet Gateway."@en ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects <https://w3id.org/noria/network-link/cr01-to-internet-gw> .

