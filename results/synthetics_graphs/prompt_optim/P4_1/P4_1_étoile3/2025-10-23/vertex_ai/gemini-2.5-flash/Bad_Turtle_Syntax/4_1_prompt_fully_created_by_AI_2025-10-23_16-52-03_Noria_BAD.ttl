# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
noria:Agent_AdminTeam
    a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and operations."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, phone for critical outages."@en .

noria:Agent_NetworkOps
    a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe des opérations réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always use emergency hotline for network incidents."@en .

noria:Agent_AppDev
    a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:label "Équipe de développement d'applications"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Submit change requests via the dedicated portal."@en .

noria:Agent_SecurityAnalyst
    a foaf:Agent ;
    rdfs:label "Security Analyst John Doe"@en ;
    rdfs:label "Analyste de sécurité John Doe"@fr ;
    rdfs:comment "Individual security analyst responsible for incident response."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:OrgUnit_L1Support
    a org:OrganizationalUnit ;
    rdfs:label "Level 1 Support"@en ;
    rdfs:label "Support de Niveau 1"@fr ;
    rdfs:comment "First line of support for all IT issues."@en ;
    noria:agentWorkingHours "24/7"@en .

noria:OrgUnit_L2Support
    a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support"@en ;
    rdfs:label "Support de Niveau 2"@fr ;
    rdfs:comment "Second line of support, handling more complex issues."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en .

noria:OrgUnit_Hotline
    a org:OrganizationalUnit ;
    rdfs:label "Hotline Team"@en ;
    rdfs:label "Équipe d'astreinte"@fr ;
    rdfs:comment "On-call team for critical application issues outside business hours."@en ;
    noria:agentWorkingHours "After-hours and weekends"@en .

noria:Agent_CustomerA
    a foaf:Agent ;
    rdfs:label "Customer A"@en ;
    rdfs:comment "Key customer reporting service degradation."@en .

noria:Agent_ExternalVendor
    a foaf:Agent ;
    rdfs:label "External Hardware Vendor"@en ;
    rdfs:comment "Third-party vendor providing hardware maintenance."@en .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
noria:Site_ParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    rdfs:comment "Main data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "A dedicated server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    bot:hasElement noria:Resource_DNS01, noria:Resource_RouterCore01, noria:Resource_VMHost01 .

noria:Locus_RackA1
    a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Specific rack location in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" .

noria:Locus_RackA2
    a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Specific rack location in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" .

# --- Product Models (noria:ProductModel) ---
noria:ProductModel_DellR740
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Server model from Dell, commonly used for enterprise applications."@en ;
    noria:productManufacturedBy <https://www.dell.com/en-us> . # Assuming Dell is an org:Organization

noria:ProductModel_CiscoNexus9K
    a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch series from Cisco."@en ;
    noria:productManufacturedBy <https://www.cisco.com> . # Assuming Cisco is an org:Organization

noria:ProductModel_VMwareESXi
    a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <https://www.vmware.com> . # Assuming VMware is an org:Organization

# --- Resources (noria:Resource) ---
noria:Resource_DNS01
    a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, critical for internet access."@en ;
    noria:resourceManagedBy noria:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_CorpDNS ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "192.168.1.10" .

noria:Resource_RouterCore01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for data center network connectivity."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "router-core01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-08-01T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_Monitoring ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.1" .

noria:Resource_VMHost01
    a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:label "Hôte de Virtualisation 01"@fr ;
    rdfs:comment "Physical server hosting multiple virtual machines."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:resourceHostName "vmhost01.dc.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "LOG-VMH-001" ;
    noria:resourceType <kos/Resource/type/Hypervisor> ;
    noria:resourceSerialNumber "SN-VMH-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_WebPortal ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "192.168.1.20" .

noria:Resource_WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:label "Serveur Web 01"@fr ;
    rdfs:comment "Virtual machine hosting the customer web portal."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "websrv01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # Represents the VM's virtual hardware
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-WEB-001-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_WebPortal ;
    noria:clusterController noria:Resource_VMHost01 ; # VMHost01 controls this VM
    noria:resourceManagementIPAddress "172.16.0.10" .

noria:Resource_DB01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:label "Serveur de Base de Données 01"@fr ;
    rdfs:comment "Virtual machine hosting the database for the customer web portal."@en ;
    noria:resourceManagedBy noria:Agent_AppDev ;
    noria:resourceHostName "db01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceSerialNumber "VM-DB-001-JKL" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-10T11:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:App_WebPortal ;
    noria:clusterController noria:Resource_VMHost01 ;
    noria:resourceManagementIPAddress "172.16.0.20" .

# --- Network Interfaces (noria:NetworkInterface) ---
noria:NetIF_DNS01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to internal network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetIF_RouterCore01_Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Uplink interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to external network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetIF_RouterCore01_Gi0_0_2
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Internal network interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Connection to internal data center network."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 50 .

noria:NetIF_VMHost01_vmnic0
    a noria:NetworkInterface ;
    rdfs:label "VMHost01 vmnic0"@en ;
    rdfs:comment "Physical network adapter for VMHost01."@en ;
    noria:networkInterfaceOf noria:Resource_VMHost01 ;
    noria:networkInterfaceDescription "Physical NIC for VM traffic."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetIF_WebSrv01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Virtual network interface for Web Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Virtual NIC for web application traffic."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:NetIF_DB01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "DB01 Ethernet 0"@en ;
    rdfs:comment "Virtual network interface for Database Server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DB01 ;
    noria:networkInterfaceDescription "Virtual NIC for database traffic."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# --- Network Links (noria:NetworkLink) ---
noria:NetLink_DC_Uplink
    a noria:NetworkLink ;
    rdfs:label "Data Center Uplink"@en ;
    rdfs:comment "High-speed fiber link connecting the data center to the internet backbone."@en ;
    noria:networkLinkId "NL-DC-UPLINK-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination <https://w3id.org/noria/ExternalNetwork> ; # Representing an external resource
    noria:networkLinkInstallationDate "2020-07-25T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic" ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:NetIF_RouterCore01_Gi0_0_1 noria:networkInterfaceConnects noria:NetLink_DC_Uplink .

noria:NetLink_Internal_A
    a noria:NetworkLink ;
    rdfs:label "Internal Link A (Router-DNS)"@en ;
    rdfs:comment "Internal network link between Core Router 01 and DNS Server 01."@en ;
    noria:networkLinkId "NL-INT-RTR-DNS-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DNS01 ;
    noria:networkLinkInstallationDate "2021-03-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:NetIF_RouterCore01_Gi0_0_2 noria:networkInterfaceConnects noria:NetLink_Internal_A ;
    noria:NetIF_DNS01_Eth0 noria:networkInterfaceConnects noria:NetLink_Internal_A .

noria:NetLink_Internal_B
    a noria:NetworkLink ;
    rdfs:label "Internal Link B (Router-VMHost)"@en ;
    rdfs:comment "Internal network link between Core Router 01 and Virtualization Host 01."@en ;
    noria:networkLinkId "NL-INT-RTR-VMH-01" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_VMHost01 ;
    noria:networkLinkInstallationDate "2022-01-20T09:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet" ;
    noria:resourceManagedBy noria:Agent_NetworkOps ;
    noria:NetIF_RouterCore01_Gi0_0_2 noria:networkInterfaceConnects noria:NetLink_Internal_B ;
    noria:NetIF_VMHost01_vmnic0 noria:networkInterfaceConnects noria:NetLink_Internal_B .

# --- Applications (noria:Application) ---
noria:App_CorpDNS
    a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:label "Service DNS d'entreprise"@fr ;
    rdfs:comment "Provides name resolution services for internal and external corporate resources."@en ;
    noria:applicationModelIdentifier "CORP-DNS-V1" ;
    noria:applicationNumericalIdentifier 101 ;
    noria:applicationShortIdentifier "CORPDNS" ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Network Services" ;
    noria:applicationFunctionalSubDomain "DNS Management" .

noria:App_WebPortal
    a noria:Application ;
    rdfs:label "Customer Web Portal"@en ;
    rdfs:label "Portail Web Client"@fr ;
    rdfs:comment "Public-facing web application for customer interactions."@en ;
    noria:applicationModelIdentifier "CUST-PORTAL-V2" ;
    noria:applicationNumericalIdentifier 201 ;
    noria:applicationShortIdentifier "WEBPORTAL" ;
    noria:applicationType <kos/application/type/Business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management" ;
    noria:applicationFunctionalSubDomain "Online Self-Service" .

noria:App_Monitoring
    a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:label "Système de Surveillance Réseau"@fr ;
