# --- Change Requests (noria:ChangeRequest) ---
noria:CR_RouterUpgrade
    a noria:ChangeRequest ;
    rdfs:label "Core Router OS Upgrade"@en ;
    rdfs:label "Mise à niveau de l'OS du Routeur Cœur"@fr ;
    rdfs:comment "Planned operating system upgrade for Core Router 01 to enhance security and performance."@en ;
    dcterms:created "2024-04-10T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-15T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-04-25T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-25T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_RouterCore01 ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RouterOSUpgradeStandard> ;
    noria:changeRequestInitiatorParty noria:Agent_NetworkOps ;
    noria:changeRequestPilotParty noria:Agent_NetworkOps ;
    noria:changeRequestActorParty noria:Agent_ExternalVendor ;
    noria:changeRequestIsRegulated false .

noria:CR_DBMigration
    a noria:ChangeRequest ;
    rdfs:label "Database Migration"@en ;
    rdfs:label "Migration de Base de Données"@fr ;
    rdfs:comment "Migration of the Web Portal database to a new, more performant platform."@en ;
    dcterms:created "2024-04-01T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-18T16:00:00Z"^^xsd:dateTime ;
