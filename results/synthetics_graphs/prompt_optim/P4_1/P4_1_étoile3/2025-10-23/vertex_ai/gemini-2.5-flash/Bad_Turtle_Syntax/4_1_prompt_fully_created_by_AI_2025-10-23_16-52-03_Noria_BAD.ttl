    noria:changeRequestIsRegulated true .

# --- Operation Plans (noria:OperationPlan) ---
noria:OpPlan_RouterOSUpgrade
    a noria:OperationPlan ;
    rdfs:label "Router OS Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems."@en ;
    skos:example "Step-by-step guide for OS upgrade, including pre-checks, upgrade steps, and post-checks."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterReachability ;
    noria:operationPlanPostCondition noria:PostCond_RouterFunctionality .

noria:OpPlan_DNSFailover
    a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Procedure to activate a secondary DNS server in case of primary server failure."@en ;
    skos:example "Steps to verify primary DNS failure, switch traffic to secondary, and verify service restoration."@en ;
    noria:operationPlanPreCondition noria:PreCond_DNSHealthCheck ;
    noria:operationPlanPostCondition noria:PostCond_DNSServiceRestored .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:PreCond_RouterReachability
    a noria:ActionPreCondition ;
    rdfs:label "Router Reachability Check"@en ;
    rdfs:comment "Verify that the router is reachable via management interface and all critical services are running before starting upgrade."@en .

noria:PostCond_RouterFunctionality
    a noria:ActionPostCondition ;
    rdfs:label "Router Functionality Verified"@en ;
    rdfs:comment "Confirm that the router is fully operational, routing tables are correct, and all interfaces are up after upgrade."@en .

noria:PreCond_DNSHealthCheck
    a noria:ActionPreCondition ;
    rdfs:label "DNS Health Check"@en ;
    rdfs:comment "Verify current DNS service status and identify primary server failure."@en .

noria:PostCond_DNSServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Confirm that DNS resolution is working correctly from multiple client locations after failover."@en .

# --- Additional connections for density ---
noria:Agent_AdminTeam noria:agentManagesResource noria:Resource_DNS01 .
noria:Agent_NetworkOps noria:agentManagesResource noria:Resource_RouterCore01, noria:Resource_VMHost01 .
noria:Agent_AppDev noria:agentManagesResource noria:Resource_WebSrv01, noria:Resource_DB01 .

noria:TT_DNSOutage noria:alarmProposedRepairAction noria:OpPlan_DNSFailover .
noria:CR_RouterUpgrade pep:usedProcedure noria:OpPlan_RouterOSUpgrade .

noria:Event_DNSOutageLog noria:alarmMitigatedBy noria:TT_DNSOutage .
noria:Event_WebSrvHighCPU noria:alarmMitigatedBy noria:TT_WebPortalSlow .

noria:TT_DNSOutage noria:documentStatusHistory noria:Event_DNSOutageLog .
noria:TT_WebPortalSlow noria:documentStatusHistory noria:Event_WebSrvHighCPU .

noria:CR_RouterUpgrade noria:documentStatusHistory noria:Event_ConfigChange .

# Example of a CUid for an agent
noria:CUid_JohnDoe
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe, a security analyst."@en ;
    foaf:accountName "jdoe" ;
    observable:accountLogin "jdoe" ;
    observable:accountIdentifier "JD001" ;
    foaf:holdsAccount noria:Agent_SecurityAnalyst .

noria:Agent_SecurityAnalyst foaf:account noria:CUid_JohnDoe .

