# --- Services (noria:Service) ---
noria:Service_InternetAccess
    a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:label "Service d'Accès Internet d'entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet access to corporate users, relying on DNS and network infrastructure."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:AppMod_CorpDNS_Prod, noria:AppMod_WebPortal_Prod . # Example of grouping application modules

noria:Service_InternalDB
    a noria:Service ;
    rdfs:label "Internal Database Service"@en ;
    rdfs:label "Service de Base de Données Interne"@fr ;
    rdfs:comment "Internal service providing database capabilities for various applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Resource_DB01 . # Example of grouping a resource

# --- Event Records (noria:EventRecord) ---
noria:Event_DNSOutageLog
    a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating that the DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - DNS service unreachable."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_RouterPortDown
    a noria:EventRecord ;
    rdfs:label "Router Port Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface on the core router went down."@en ;
    noria:loggingTime "2024-04-20T09:03:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "Interface GigabitEthernet0/0/1 on router-core01 changed state to down."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_WebSrvHighCPU
    a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on the web server."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "WARNING: WebSrv01 CPU utilization exceeded 90% for 5 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_ConfigChange
    a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry detailing a configuration change applied to the core router."@en ;
    noria:loggingTime "2024-04-19T15:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent noria:Agent_NetworkOps ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by NetworkOps (10.0.0.5)."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# --- Trouble Tickets (noria:TroubleTicket) ---
noria:TT_DNSOutage
    a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident de Panne du Serveur DNS"@fr ;
    rdfs:comment "Critical incident regarding the corporate DNS server being unreachable, impacting internet access."@en ;
    dcterms:created "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:30:00Z"^^xsd:dateTime ;
