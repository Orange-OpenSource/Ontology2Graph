noria:AppMod_WebPortal_Dev
    a noria:ApplicationModule ;
    rdfs:label "Customer Web Portal Development Module"@en ;
    rdfs:label "Module de Développement du Portail Web Client"@fr ;
    rdfs:comment "Development instance of the Customer Web Portal for testing new features."@en ;
    noria:applicationModuleOf noria:App_WebPortal ;
    noria:applicationModuleName "CUSTPORTAL_DEV" ;
    noria:applicationModuleIdentifier "DEV-001" ;
