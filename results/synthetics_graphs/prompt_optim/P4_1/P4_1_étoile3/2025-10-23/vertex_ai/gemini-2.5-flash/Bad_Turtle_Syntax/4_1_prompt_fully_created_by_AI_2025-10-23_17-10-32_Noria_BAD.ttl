# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit)
# =============================================================================

foaf:Agent_AdminTeam
    a foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and related services."@en ;
    noria:agentWorkingHours "8:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Use ticketing system for all requests. For critical issues, call the hotline."@en .

foaf:Agent_NetworkOps
    a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe des opérations réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Escalate critical network alerts immediately via phone."@en .

foaf:Agent_AppDev
    a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:label "Équipe de développement d'applications"@fr ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Submit bug reports via Jira. For urgent issues, contact team lead."@en .

foaf:Agent_SecurityAnalyst
    a foaf:Agent ;
    rdfs:label "Security Analyst John Doe"@en ;
    rdfs:label "Analyste Sécurité Jean Dupont"@fr ;
    rdfs:comment "Individual security analyst responsible for incident response."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

org:OrgUnit_L1Support
    a org:OrganizationalUnit ;
    rdfs:label "Level 1 Support"@en ;
    rdfs:label "Support Niveau 1"@fr ;
    rdfs:comment "First line of support for user issues."@en ;
    noria:agentWorkingHours "24/7"@en .

org:OrgUnit_L2Support
    a org:OrganizationalUnit ;
    rdfs:label "Level 2 Support"@en ;
    rdfs:label "Support Niveau 2"@fr ;
    rdfs:comment "Second line of support, handling more complex issues."@en ;
    noria:agentWorkingHours "8:00 am - 8:00 pm (Mon-Sun)"@en .

org:OrgUnit_Hotline
    a org:OrganizationalUnit ;
    rdfs:label "Hotline Team"@en ;
    rdfs:label "Équipe d'astreinte"@fr ;
    rdfs:comment "Dedicated team for urgent and critical incident response."@en ;
    noria:agentWorkingHours "24/7"@en .

foaf:Agent_CustomerA
    a foaf:Agent ;
    rdfs:label "Customer A Representative"@en ;
    rdfs:label "Représentant Client A"@fr ;
    rdfs:comment "Representative from a key customer reporting service issues."@en .

foaf:Agent_ChangeManager
    a foaf:Agent ;
    rdfs:label "Change Manager Jane Smith"@en ;
    rdfs:label "Responsable des changements Jeanne Dupont"@fr ;
    rdfs:comment "Manager overseeing the change management process."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

bot:Site_ParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:label "Centre de Données de Paris"@fr ;
    rdfs:comment "Primary data center location for corporate services."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@en ;
    noria:sitePrincipalAddressCityName "Paris"@en ;
    noria:sitePrincipalAddressPostalCode "75001"@en ;
    noria:sitePrincipalAddressCountry "FR"@en .

noria:Room_ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack12_U23 ;
    bot:hasSpace noria:Locus_Rack15_U10 ;
    seas:subSystemOf bot:Site_ParisDC .

noria:Locus_Rack12_U23
    a noria:Locus ;
    rdfs:label "Rack 12, Unit 23"@en ;
    rdfs:label "Baie 12, Unité 23"@fr ;
    rdfs:comment "Specific location within Server Room A for equipment installation."@en ;
    noria:locusLine "12"@en ;
    noria:locusRow "23"@en ;
    seas:subSystemOf noria:Room_ServerRoomA .

noria:Locus_Rack15_U10
    a noria:Locus ;
    rdfs:label "Rack 15, Unit 10"@en ;
    rdfs:label "Baie 15, Unité 10"@fr ;
    rdfs:comment "Another specific location within Server Room A."@en ;
    noria:locusLine "15"@en ;
    noria:locusRow "10"@en ;
    seas:subSystemOf noria:Room_ServerRoomA .

bot:Site_LondonOffice
    a bot:Site ;
    rdfs:label "London Office"@en ;
    rdfs:label "Bureau de Londres"@fr ;
    rdfs:comment "Regional office location."@en ;
    noria:siteId "OFF-LDN-01" ;
    noria:siteType "office building"@en ;
    noria:sitePrincipalAddress "456 Baker Street"@en ;
    noria:sitePrincipalAddressCityName "London"@en ;
    noria:sitePrincipalAddressPostalCode "NW1 6XE"@en ;
    noria:sitePrincipalAddressCountry "UK"@en .

noria:Room_NetworkCloset
    a noria:Room ;
    rdfs:label "Network Closet"@en ;
    rdfs:label "Local Réseau"@fr ;
    rdfs:comment "Small room for network equipment in London Office."@en ;
    bot:hasSpace noria:Locus_PatchPanel_A1 ;
    seas:subSystemOf bot:Site_LondonOffice .

noria:Locus_PatchPanel_A1
    a noria:Locus ;
    rdfs:label "Patch Panel A1"@en ;
    rdfs:label "Panneau de brassage A1"@fr ;
    rdfs:comment "Location of a patch panel in the network closet."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    seas:subSystemOf noria:Room_NetworkCloset .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Dell server model used for various enterprise applications."@en ;
    noria:productManufacturedBy <http://www.dell.com/organization> . # Assuming Dell is an org:Organization

noria:ProductModel_CiscoNexus9K
    a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "High-performance data center switch series from Cisco."@en ;
    noria:productManufacturedBy <http://www.cisco.com/organization> . # Assuming Cisco is an org:Organization

noria:ProductModel_VMwareESXi
    a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <http://www.vmware.com/organization> . # Assuming VMware is an org:Organization

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01
    a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, located in Paris DC."@en ;
    noria:resourceManagedBy foaf:Agent_AdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:Resource_RouterCore01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack15_U10 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:Resource_WebSrv01
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:label "Serveur Web 01"@fr ;
    rdfs:comment "Virtual machine hosting the customer web portal."@en ;
    noria:resourceManagedBy foaf:Agent_AppDev ;
    noria:resourceHostName "web01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # The host is ESXi, the VM is on it.
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceLogisticId "LOG-WEB-001" ;
    noria:resourceSerialNumber "SN-WEB-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.10> ;
    noria:clusterController noria:Resource_VMwareClusterController .

noria:Resource_DB01
    a noria:Resource ;
    rdfs:label "Database Server 01"@en ;
    rdfs:label "Serveur de Base de Données 01"@fr ;
    rdfs:comment "Dedicated database server for critical applications."@en ;
    noria:resourceManagedBy foaf:Agent_AppDev ;
    noria:resourceHostName "db01.app.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceLogisticId "LOG-DB-001" ;
    noria:resourceSerialNumber "SN-DB-001-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-08-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack15_U10 ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.20> .

noria:Resource_Firewall01
    a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:label "Pare-feu Périphérique 01"@fr ;
    rdfs:comment "Firewall protecting the corporate network perimeter."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoNexus9K ; # Placeholder, assuming a Cisco firewall
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceLogisticId "LOG-FW-001" ;
    noria:resourceSerialNumber "SN-FW-001-JKL" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-01-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_PatchPanel_A1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.100.1> .

noria:Resource_VMwareClusterController
    a noria:Resource ;
    rdfs:label "VMware vCenter Controller"@en ;
    rdfs:label "Contrôleur VMware vCenter"@fr ;
    rdfs:comment "Centralized management platform for VMware virtual infrastructure."@en ;
    noria:resourceManagedBy foaf:Agent_AdminTeam ;
    noria:resourceHostName "vcenter.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ; # Assuming it runs on a physical server
    noria:resourceType <kos/Resource/type/management-server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-01T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_Rack12_U23 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.20> .

# =============================================================================
# Network Interfaces (noria:NetworkInterface)
# =============================================================================

noria:NetInt_DNS01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to corporate LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetInt_RouterCore01_Gi0_0_1
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to DNS server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to DNS server subnet."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetInt_RouterCore01_Gi0_0_2
    a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting Core Router 01 to Web server segment."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceDescription "Uplink to Web server subnet."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 .

noria:NetInt_WebSrv01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for WebSrv01 virtual machine."@en ;
    noria:networkInterfaceOf noria:Resource_WebSrv01 ;
    noria:networkInterfaceDescription "Virtual Ethernet interface for web traffic."@en ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:NetInt_DB01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "DB01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DB01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DB01 ;
    noria:networkInterfaceDescription "Ethernet interface connected to database LAN."@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# =============================================================================
# Network Links (noria:NetworkLink)
# =============================================================================

noria:NetLink_DNS_Core
    a noria:NetworkLink ;
    rdfs:label "DNS to Core Router Link"@en ;
    rdfs:comment "Physical link between DNS01 and Core Router 01."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore01 ;
    noria:networkLinkInstallationDate "2022-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:networkInterfaceConnects noria:NetInt_DNS01_Eth0 ;
    noria:networkInterfaceConnects noria:NetInt_RouterCore01_Gi0_0_1 .

noria:NetLink_Core_Web
    a noria:NetworkLink ;
    rdfs:label "Core Router to Web Server Link"@en ;
    rdfs:comment "Logical link between Core Router 01 and WebSrv01."@en ;
    noria:resourceManagedBy foaf:Agent_NetworkOps ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_RouterCore01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_WebSrv01 ;
    noria:networkLinkInstallationDate "2023-05-10T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual LAN" ;
    noria:networkInterfaceConnects noria:NetInt_RouterCore01_Gi0_0_2 ;
    noria:networkInterfaceConnects noria:NetInt_WebSrv01_Eth0 .

noria:NetLink_Web_DB
    a noria:NetworkLink ;
    rdfs:label "Web Server to Database Server Link"@en ;
    rdfs:comment "Logical link between WebSrv01 and DB01."@en ;
    noria:resourceManagedBy foaf:Agent_AppDev ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_DB01 ;
    noria:networkLinkInstallationDate "2023-05-10T09:45:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual LAN" ;
    noria:networkInterfaceConnects noria:NetInt_WebSrv01_Eth0 ; # Assuming shared interface or another virtual one
    noria:networkInterfaceConnects noria:NetInt_DB01_Eth0 .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:App_CorpDNS
    a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:label "Service DNS d'entreprise"@fr ;
    rdfs:comment "Provides name resolution services for the entire corporate network."@en ;
    noria:elementManagedBy foaf:Agent_AdminTeam ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationModelIdentifier "CORP-DNS-V1" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CORPDNS" ;
    noria:applicationFunctionalDomain "Network Services"@en ;
    noria:applicationFunctionalSubDomain "DNS Resolution"@en .

noria:App_WebPortal
    a noria:Application ;
    rdfs:label "Customer Web Portal"@en ;
    rdfs:label "Portail Web Client"@fr ;
    rdfs:comment "Public-facing web application for customer interactions."@en ;
    noria:elementManagedBy foaf:Agent_AppDev ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "CUST-PORTAL-V2" ;
    noria:applicationNumericalIdentifier 2001 ;
    noria:applicationShortIdentifier "CUSTPORTAL" ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Online Self-Service"@en .

noria:App_Monitoring
    a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:label "Système de Supervision Réseau"@fr ;
    rdfs:comment "System for monitoring network devices and services, generating alerts."@en ;
    noria:elementManagedBy foaf:Agent_NetworkOps ;
    noria:applicationType <kos/application/type/management-tool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationModelIdentifier "NMS-PROD-V3" ;
    noria:applicationNumericalIdentifier 3001 ;
    noria:applicationShortIdentifier "NMSPROD" ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Performance Monitoring"@en .

