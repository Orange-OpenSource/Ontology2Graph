noria:AppMod_WebPortal_Prod
    a noria:ApplicationModule ;
    rdfs:label "Customer Web Portal Production Module"@en ;
    rdfs:label "Module de Production du Portail Web Client"@fr ;
    rdfs:comment "Live production instance of the Customer Web Portal."@en ;
