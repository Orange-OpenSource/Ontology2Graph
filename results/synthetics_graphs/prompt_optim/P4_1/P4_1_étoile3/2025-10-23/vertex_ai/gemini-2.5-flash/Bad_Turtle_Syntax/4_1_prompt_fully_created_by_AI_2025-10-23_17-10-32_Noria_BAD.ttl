# =============================================================================
# Services (noria:Service)
# =============================================================================

noria:Service_InternetAccess
    a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:label "Service d'Accès Internet d'entreprise"@fr ;
    rdfs:comment "End-to-end service providing internet connectivity to corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:App_CorpDNS ; # A service can be composed of applications/modules
    seas:subSystemOf noria:App_WebPortal ;
    seas:subSystemOf noria:Resource_Firewall01 .

noria:Service_InternalDB
    a noria:Service ;
    rdfs:label "Internal Database Service"@en ;
    rdfs:label "Service de Base de Données Interne"@fr ;
    rdfs:comment "Service providing database access for internal applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Resource_DB01 .

# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:Event_DNS_Down
    a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Alert"@en ;
    rdfs:label "Alerte Serveur DNS Inaccessible"@fr ;
    rdfs:comment "Automated alert indicating that the primary DNS server is unreachable."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%"@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:Event_Interface_Flap
    a noria:EventRecord ;
    rdfs:label "Router Interface Flap Alert"@en ;
    rdfs:label "Alerte Instabilité d'Interface Routeur"@fr ;
    rdfs:comment "Alert indicating frequent up/down transitions on a router interface."@en ;
    noria:loggingTime "2024-04-20T10:10:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "WARNING: Interface GigabitEthernet0/0/1 on router-core01.corp.example.com is flapping."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:Event_WebSrv_HighCPU
    a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:label "Alerte CPU Élevé Serveur Web"@fr ;
    rdfs:comment "Alert indicating sustained high CPU utilization on the web server."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "MAJOR: Host web01.app.example.com CPU utilization > 90% for 15 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:Event_ConfigChange_Router
    a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:label "Journal de Changement de Configuration Routeur"@fr ;
    rdfs:comment "Log entry indicating a configuration change was applied to the core router."@en ;
    noria:loggingTime "2024-04-19T16:45:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource_RouterCore01 ;
    noria:logOriginatingAgent foaf:Agent_NetworkOps ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by NetworkOps (10.0.0.5)"@en .

# =============================================================================
# Trouble Tickets (noria:TroubleTicket)
# =============================================================================

noria:TT_DNSOutage
    a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident de Panne Serveur DNS"@fr ;
    rdfs:comment "Critical incident reported due to primary DNS server being unreachable, impacting all corporate services."@en ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T12:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:Event_DNS_Down ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/InaccessibleDestination> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/SoftwareBug> ; # After diagnosis
    noria:troubleTicketCause "DNS service process crashed due to memory leak."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedApplication> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_AdminTeam ;
    noria:troubleTicketRelatedParty org:OrgUnit_Hotline ;
    noria:troubleTicketRelatedService noria:App_CorpDNS ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:Service_InternetAccess ;
    noria:troubleTicketImpacts noria:App_WebPortal ;
    noria:documentExternalId "CUST-REF-DNS-001" ;
    noria:documentHRef <http://ticketing.example.com/TT_DNSOutage> .

noria:TT_WebPerformance
    a noria:TroubleTicket ;
    rdfs:label "Web Portal Performance Issue"@en ;
    rdfs:label "Problème de Performance Portail Web"@fr ;
    rdfs:comment "Customer reported slow response times on the web portal."@en ;
    dcterms:created "2024-04-20T11:45:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/DegradedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:Event_WebSrv_HighCPU ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Dynatrace"@en ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/SlowResponse> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/ResourceSaturation> ;
    noria:troubleTicketCause "Unexpected traffic surge causing high CPU on web server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedApplication> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty foaf:Agent_CustomerA ;
    noria:troubleTicketRelatedParty foaf:Agent_AppDev ;
    noria:troubleTicketRelatedService noria:App_WebPortal ;
    noria:troubleTicketRelatedResource noria:Resource_WebSrv01 ;
    noria:troubleTicketImpacts noria:Service_InternetAccess ;
    noria:documentExternalId "CUST-WEB-002" ;
    noria:documentHRef <http://ticketing.example.com/TT_WebPerformance> .

# =============================================================================
# Trouble Ticket Notes (noria:TroubleTicketNote)
# =============================================================================

noria:TTNote_DNS_Diag
    a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage Diagnostic Note"@en ;
    rdfs:label "Note de Diagnostic Panne DNS"@fr ;
    rdfs:comment "Initial diagnostic steps performed: checked network connectivity, verified DNS service status, restarted service."@en ;
    dcterms:created "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_AdminTeam ;
    dcterms:isPartOf noria:TT_DNSOutage ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution noria:Event_ConfigChange_Router . # Example of a correlated event, even if not directly related to this note.

noria:TTNote_Web_Fix
    a noria:TroubleTicketNote ;
    rdfs:label "Web Performance Fix Note"@en ;
    rdfs:label "Note de Correction Performance Web"@fr ;
    rdfs:comment "Increased CPU and memory allocation for WebSrv01. Monitoring performance after change."@en ;
    dcterms:created "2024-04-20T12:45:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:Agent_AppDev ;
    dcterms:isPartOf noria:TT_WebPerformance ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> .

# =============================================================================
# Change Requests (noria:ChangeRequest)
# =============================================================================

noria:CR_RouterUpgrade
    a noria:ChangeRequest ;
    rdfs:label "Core Router OS Upgrade"@en ;
    rdfs:label "Mise à niveau OS Routeur Cœur"@fr ;
    rdfs:comment "Planned operating system upgrade for Core Router 01 to enhance security and performance."@en ;
    dcterms:created "2024-04-15T09:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-18T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_RouterCore01 ;
    noria:changeRequestImpact noria:Service_InternetAccess ;
    noria:changeRequestOutageDuration "PT2H"^^xsd:duration ; # 2 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/NetworkOSUpdate> ;
    noria:changeRequestInitiatorParty foaf:Agent_NetworkOps ;
    noria:changeRequestPilotParty foaf:Agent_ChangeManager ;
    noria:changeRequestActorParty foaf:Agent_NetworkOps ;
    noria:changeRequestIsRegulated true^^xsd:boolean ;
    noria:documentExternalId "CR-NET-001" ;
    noria:documentHRef <http://changemanagement.example.com/CR_RouterUpgrade> .

noria:CR_DBMigration
    a noria:ChangeRequest ;
    rdfs:label "Database Migration"@en ;
    rdfs:label "Migration de Base de Données"@fr ;
    rdfs:comment "Migration of DB01 to a new, more powerful server instance."@en ;
    dcterms:created "2024-04-10T10:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-12T11:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-15T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-16T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Major> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/HardwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_DB01 ;
    noria:changeRequestImpact noria:Service_InternalDB ;
    noria:changeRequestImpact noria:App_WebPortal ;
    noria:changeRequestOutageDuration "PT8H"^^xsd:duration ; # 8 hours
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestInitiatorParty foaf:Agent_AppDev ;
    noria:changeRequestPilotParty foaf:Agent_ChangeManager ;
    noria:changeRequestActorParty foaf:Agent_AppDev ;
    noria:changeRequestIsRegulated false^^xsd:boolean ;
    noria:documentExternalId "CR-APP-002" ;
    noria:documentHRef <http://changemanagement.example.com/CR_DBMigration> .

# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OpPlan_RouterOSUpdate
    a noria:OperationPlan ;
    rdfs:label "Router OS Update Procedure"@en ;
    rdfs:label "Procédure de Mise à Jour OS Routeur"@fr ;
    rdfs:comment "Standard operating procedure for updating network device operating systems."@en ;
    skos:example "Steps include backup configuration, upload new image, reload device, verify connectivity."@en ;
    noria:operationPlanPreCondition noria:PreCond_RouterReach ;
    noria:operationPlanPostCondition noria:PostCond_RouterUp .

noria:OpPlan_DNS_Troubleshoot
    a noria:OperationPlan ;
    rdfs:label "DNS Troubleshooting Guide"@en ;
    rdfs:label "Guide de Dépannage DNS"@fr ;
    rdfs:comment "Procedure for diagnosing and resolving DNS service outages."@en ;
    skos:example "Steps include checking service status, reviewing logs, restarting service, escalating to L2."@en ;
    noria:operationPlanPreCondition noria:PreCond_DNS_PingFail ;
    noria:operationPlanPostCondition noria:PostCond_DNS_Resolved .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:PreCond_RouterReach
    a noria:ActionPreCondition ;
    rdfs:label "Router Reachable"@en ;
    rdfs:comment "Condition: The router must be reachable via management interface before starting the update."@en .

noria:PostCond_RouterUp
    a noria:ActionPostCondition ;
    rdfs:label "Router Operational"@en ;
    rdfs:comment "Condition: The router must be fully operational, forwarding traffic, and all interfaces up after the update."@en .

noria:PreCond_DNS_PingFail
    a noria:ActionPreCondition ;
    rdfs:label "DNS Ping Failure"@en ;
    rdfs:comment "Condition: DNS server is not responding to ping requests."@en .

noria:PostCond_DNS_Resolved
    a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored"@en ;
    rdfs:comment "Condition: DNS queries are successfully resolved by the server."@en .

# =============================================================================
# Additional Connections for Density
# =============================================================================

# Link resources to applications they support
noria:Resource_DNS01 noria:resourceForApplication noria:App_CorpDNS .
noria:Resource_WebSrv01 noria:resourceForApplication noria:App_WebPortal .
noria:Resource_DB01 noria:resourceForApplication noria:App_WebPortal .
noria:Resource_RouterCore01 noria:resourceForApplication noria:App_Monitoring .
noria:Resource_Firewall01 noria:resourceForApplication noria:App_Monitoring .

# Link application modules to resources they utilize (indirectly via application)
# This is more conceptual, as noria:resourceForApplication links Resource to Application.
# For direct link, we'd need a property like noria:applicationModuleUsesResource.
# Sticking to existing properties:
# noria:AppMod_CorpDNS_Prod uses noria:Resource_DNS01 (implicitly via noria:App_CorpDNS)
# noria:AppMod_WebPortal_Prod uses noria:Resource_WebSrv01 and noria:Resource_DB01 (implicitly via noria:App_WebPortal)

# Link Event Records to Trouble Tickets (already done via noria:troubleTicketTrigger)
# Link Trouble Tickets to Event Records for status history
noria:TT_DNSOutage noria:documentStatusHistory noria:Event_DNS_Down . # Initial trigger
noria:TT_WebPerformance noria:documentStatusHistory noria:Event_WebSrv_HighCPU . # Initial trigger

# Link Change Request to Operation Plan
noria:CR_RouterUpgrade pep:usedProcedure noria:OpPlan_RouterOSUpdate .
noria:TT_DNSOutage pep:usedProcedure noria:OpPlan_DNS_Troubleshoot . # A trouble ticket might also follow an operation plan

# Link agents to resources they manage (already done)
# Link agents to applications they manage (already done)

# Example of a CUid for an agent
<https://w3id.org/noria/cuid/johndoe>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for John Doe, a security analyst."@en ;
    foaf:accountName "jdoe"@en ;
    observable:accountLogin "jdoe"@en ;
    observable:accountIdentifier "jdoe-corp-id-123"@en ;
    foaf:holdsAccount foaf:Agent_SecurityAnalyst .

# Example of an organizational unit being managed by an agent
org:OrgUnit_L1Support noria:elementManagedBy foaf:Agent_AdminTeam . # Admin team manages L1 support processes

# Example of a resource being managed by an organizational unit
noria:Resource_DNS01 noria:resourceManagedBy org:OrgUnit_L2Support . # L2 support team manages the DNS server

# Example of a network interface with optical power metrics
noria:NetInt_RouterCore01_Gi0_0_1
    noria:networkInterfaceLaserTxOpticalPower -2^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower -5^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -3^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10^^xsd:int .

# Example of a trouble ticket freeze item (using EventRecord)
noria:Event_TT_Freeze
    a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Event"@en ;
    rdfs:comment "Event indicating a trouble ticket was put on hold."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logText "Trouble Ticket TT_DNSOutage status changed to Frozen."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:TT_DNSOutage noria:troubleTicketFreezeItem noria:Event_TT_Freeze .

# Example of a document attachment
<https://w3id.org/noria/doc/network_diagram_v1.pdf>
    a noria:DocumentAttachment ;
    rdfs:label "Network Diagram v1.0"@en ;
    rdfs:comment "PDF document showing the network topology for the Paris DC."@en ;
    dcterms:created "2024-01-01T09:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf"@en ;
    dcterms:isPartOf noria:CR_RouterUpgrade ;
    dcterms:isPartOf noria:TT_DNSOutage .

# Example of a change request having an actual start/end time
noria:CR_RouterUpgrade
    noria:changeRequestActualStartTime "2024-05-01T02:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-05-01T03:45:00Z"^^xsd:dateTime .

# Example of an anomaly pattern
noria:AnomalyPattern_DNSFailure
    a noria:AnomalyPattern ;
    rdfs:label "DNS Service Failure Pattern"@en ;
    rdfs:comment "Pattern describing a DNS service failure: DNS server unreachable, high packet loss, and related application errors."@en ;
    folio:hasCause noria:PreCond_DNS_PingFail . # Linking a pre-condition as a potential cause in a failure mode context

