noria:troubleTicket/DNSOutageTT a noria:TroubleTicket ;
    rdfs:label "DNS Server Outage Incident"@en ;
    rdfs:label "Incident de Panne Serveur DNS"@fr ;
    rdfs:comment "Critical incident: Primary DNS server is down, impacting all corporate services."@en ;
