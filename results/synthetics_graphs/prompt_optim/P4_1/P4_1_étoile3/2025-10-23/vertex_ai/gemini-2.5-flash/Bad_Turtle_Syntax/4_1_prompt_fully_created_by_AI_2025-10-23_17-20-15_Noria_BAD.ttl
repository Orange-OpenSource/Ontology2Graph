    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:event/DNSServerDownAlert ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Unidentified software crash on DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:agent/NOC_Team ;
    noria:troubleTicketRelatedParty noria:agent/DNSAdminTeam ;
    noria:troubleTicketRelatedService noria:application/CorporateDNSService ;
    noria:troubleTicketRelatedResource noria:resource/DNSServer01 ;
    noria:troubleTicketImpacts noria:application/CorporateDNSService ;
    noria:troubleTicketImpacts noria:resource/DNSServer01 ;
    noria:documentHRef <http://ticketing.example.com/TT-20240423-001> .

noria:troubleTicket/WebPortalSlowTT a noria:TroubleTicket ;
    rdfs:label "Web Portal Slow Performance"@en ;
    rdfs:label "Performance Lente du Portail Web"@fr ;
    rdfs:comment "Users reporting slow loading times for the corporate web portal."@en ;
