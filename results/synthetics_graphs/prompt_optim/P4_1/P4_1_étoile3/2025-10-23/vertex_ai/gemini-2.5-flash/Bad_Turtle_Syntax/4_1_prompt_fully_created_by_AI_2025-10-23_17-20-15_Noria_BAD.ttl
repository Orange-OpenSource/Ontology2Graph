    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "jdoe-corp-id"^^xsd:string .

noria:agent/JaneSmith foaf:holdsAccount noria:cuid/JaneSmithCUid .
noria:cuid/JaneSmithCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountLogin "jsmith"^^xsd:string ;
    observable:accountIdentifier "jsmith-corp-id"^^xsd:string .

noria:resource/DNSServer01 noria:resourceForApplication noria:application/CorporateDNSService .
noria:resource/WebServer03 noria:resourceForApplication noria:application/WebPortalApp .
noria:resource/Firewall01 noria:resourceForApplication noria:application/InternetAccessService .

noria:applicationModule/CorporateDNSService_Prod seas:subSystemOf noria:service/InternetAccessService .
noria:applicationModule/WebPortal_FrontendProd seas:subSystemOf noria:service/InternetAccessService .
noria:applicationModule/WebPortal_BackendProd seas:subSystemOf noria:service/InternetAccessService, noria:service/CorporateDataService .
noria:applicationModule/CentralizedLogging_Collector seas:subSystemOf noria:application/CentralizedLoggingSystem .

