    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of Dell PowerEdge servers."@en .

noria:productModel/CiscoCatalyst9300 a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Enterprise-grade network switch series from Cisco."@en ;
    noria:productManufacturedBy noria:org/CiscoSystems .

noria:org/CiscoSystems a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of Cisco networking equipment."@en .

noria:productModel/JuniperMX204 a noria:ProductModel ;
    rdfs:label "Juniper MX204"@en ;
    rdfs:comment "Compact, high-performance universal routing platform from Juniper Networks."@en ;
    noria:productManufacturedBy noria:org/JuniperNetworks .

noria:org/JuniperNetworks a org:Organization ;
    rdfs:label "Juniper Networks"@en ;
    rdfs:comment "Manufacturer of Juniper networking equipment."@en .

noria:productModel/VMwareESXiHost a noria:ProductModel ;
    rdfs:label "VMware ESXi Host"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy noria:org/VMware .

noria:org/VMware a org:Organization ;
