# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot:  <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/>.
@prefix pep: <https://w3id.org/pep/>.
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# NORIA Knowledge Graph Instances
# =============================================================================

# -----------------------------------------------------------------------------
# Agents (foaf:Agent, org:OrganizationalUnit)
# -----------------------------------------------------------------------------

noria:agent/DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'Administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and configuration."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, direct call for critical outages."@en .

noria:agent/NOC_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:label "Équipe du Centre d'Opérations Réseau (NOC)"@fr ;
    rdfs:comment "24/7 team monitoring network infrastructure and responding to incidents."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Follow standard incident response procedures. Escalate to L2 for complex issues."@en .

noria:agent/AppSupportL2_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support L2 Team"@en ;
    rdfs:label "Équipe Support Applicatif N2"@fr ;
    rdfs:comment "Second-level support for critical business applications."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "Analyze logs, diagnose issues, and coordinate with development teams."@en .

noria:agent/IncidentResponse_Team a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Incident Response Team"@en ;
    rdfs:label "Équipe de Réponse aux Incidents"@fr ;
    rdfs:comment "Specialized team for handling major security incidents and critical outages."@en ;
    noria:agentWorkingHours "On-call 24/7"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/secure-channel> ;
    noria:agentInstructions "Activate emergency protocols. Prioritize service restoration and forensic analysis."@en .

noria:agent/JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual member of the DNS Admin Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+1-555-123-4567" .

noria:agent/JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Individual member of the Application Support L2 Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+1-555-987-6543" .

# -----------------------------------------------------------------------------
# Locations (bot:Site, noria:Room, noria:Locus)
# -----------------------------------------------------------------------------

noria:location/MainDataCenter a bot:Site ;
    rdfs:label "Main Data Center"@en ;
    rdfs:label "Centre de Données Principal"@fr ;
    rdfs:comment "Primary data center facility for corporate IT infrastructure."@en ;
    noria:siteId "DC01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string .

noria:location/ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:label "Salle Serveurs A"@fr ;
    rdfs:comment "A dedicated server room within the Main Data Center."@en ;
    bot:hasSpace noria:location/MainDataCenter .

noria:location/Rack12 a noria:Locus ;
    rdfs:label "Rack 12"@en ;
    rdfs:label "Baie 12"@fr ;
    rdfs:comment "Specific rack location within Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "12"^^xsd:string ;
    bot:hasSpace noria:location/ServerRoomA .

noria:location/EdgePoPSite a bot:Site ;
    rdfs:label "Edge PoP Site"@en ;
    rdfs:label "Site Point de Présence Edge"@fr ;
    rdfs:comment "Point of Presence site for network edge services."@en ;
    noria:siteId "POP01"^^xsd:string ;
    noria:siteType "network facility"^^xsd:string ;
    noria:sitePrincipalAddress "456 Network Street"@en ;
    noria:sitePrincipalAddressCityName "Edgeville"@en ;
    noria:sitePrincipalAddressPostalCode "20002"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string .

noria:location/NetworkClosetB a noria:Room ;
    rdfs:label "Network Closet B"@en ;
    rdfs:label "Local Technique B"@fr ;
    rdfs:comment "Network equipment closet at the Edge PoP Site."@en ;
    bot:hasSpace noria:location/EdgePoPSite .

noria:location/Shelf3 a noria:Locus ;
    rdfs:label "Shelf 3"@en ;
    rdfs:label "Étagère 3"@fr ;
    rdfs:comment "Specific shelf location within Network Closet B."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "3"^^xsd:string ;
    bot:hasSpace noria:location/NetworkClosetB .

# -----------------------------------------------------------------------------
# Product Models (noria:ProductModel)
