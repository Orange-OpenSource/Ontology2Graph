noria:troubleTicketNote/DNSOutageTT_Note1 a noria:TroubleTicketNote ;
    rdfs:label "DNS Outage TT Note 1: Initial Diagnosis"@en ;
    rdfs:comment "Initial diagnosis: DNS service unresponsive. Attempting restart."@en ;
    dcterms:created "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    dcterms:creator noria:agent/JohnDoe ;
    dcterms:description "Checked server status, ping failed. Initiated service restart via SSH."@en ;
