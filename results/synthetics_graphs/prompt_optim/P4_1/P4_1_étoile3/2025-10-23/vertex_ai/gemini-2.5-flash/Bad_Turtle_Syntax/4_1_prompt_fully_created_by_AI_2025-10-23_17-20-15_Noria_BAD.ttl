# -----------------------------------------------------------------------------
# Operation Plans (noria:OperationPlan)
# -----------------------------------------------------------------------------

noria:operationPlan/DNSServerRestartProcedure a noria:OperationPlan ;
    rdfs:label "DNS Server Restart Procedure"@en ;
    rdfs:label "Procédure de Redémarrage du Serveur DNS"@fr ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS server."@en ;
    skos:example "Steps: 1. Verify network connectivity. 2. Log in to server. 3. Stop DNS service. 4. Start DNS service. 5. Verify DNS resolution."@en ;
    noria:operationPlanPreCondition noria:actionPreCondition/VerifyNetworkConnectivity ;
    noria:operationPlanPostCondition noria:actionPostCondition/DNSResolutionRestored .

noria:operationPlan/WebPortalCacheClearProcedure a noria:OperationPlan ;
    rdfs:label "Web Portal Cache Clear Procedure"@en ;
    rdfs:label "Procédure de Vidage du Cache du Portail Web"@fr ;
    rdfs:comment "Procedure to clear application caches for the Web Portal to resolve performance issues."@en ;
    skos:example "Steps: 1. Identify affected cache instances. 2. Connect to cache server. 3. Execute cache clear command. 4. Monitor performance metrics."@en ;
    noria:operationPlanPreCondition noria:actionPreCondition/HighCPUDetected ;
    noria:operationPlanPostCondition noria:actionPostCondition/PerformanceRestored .

# -----------------------------------------------------------------------------
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# -----------------------------------------------------------------------------

noria:actionPreCondition/VerifyNetworkConnectivity a noria:ActionPreCondition ;
    rdfs:label "Verify Network Connectivity"@en ;
    rdfs:comment "Pre-condition: Ensure basic network connectivity to the server before attempting a restart."@en ;
    skos:example "Ping to server IP address is successful."@en .

noria:actionPostCondition/DNSResolutionRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Restored"@en ;
    rdfs:comment "Post-condition: Confirm that DNS resolution is functioning correctly after the restart."@en ;
    skos:example "Successful 'nslookup' queries for internal and external domains."@en .

noria:actionPreCondition/HighCPUDetected a noria:ActionPreCondition ;
    rdfs:label "High CPU Detected"@en ;
    rdfs:comment "Pre-condition: High CPU usage on web server is observed, indicating a potential performance bottleneck."@en ;
    skos:example "Monitoring system reports CPU > 90% for 15 minutes."@en .

noria:actionPostCondition/PerformanceRestored a noria:ActionPostCondition ;
    rdfs:label "Performance Restored"@en ;
    rdfs:comment "Post-condition: Web portal performance metrics return to normal levels after cache clearing."@en ;
    skos:example "Average page load time below 2 seconds, CPU usage below 50%."@en .

# -----------------------------------------------------------------------------
# Additional Interconnections
# -----------------------------------------------------------------------------

noria:troubleTicket/DNSOutageTT
    noria:documentStatusHistory noria:event/DNSServerDownAlert ;
    noria:documentStatusHistory noria:event/DNSServerRestartLog .

noria:troubleTicket/WebPortalSlowTT
    noria:documentStatusHistory noria:event/HighCPUUsageWebServer .

noria:changeRequest/WebPortalUpgradeCR
    noria:actionCorrelatedOperationPlan noria:operationPlan/WebPortalCacheClearProcedure . # Example of a related operation plan

noria:agent/JohnDoe foaf:holdsAccount noria:cuid/JohnDoeCUid .
