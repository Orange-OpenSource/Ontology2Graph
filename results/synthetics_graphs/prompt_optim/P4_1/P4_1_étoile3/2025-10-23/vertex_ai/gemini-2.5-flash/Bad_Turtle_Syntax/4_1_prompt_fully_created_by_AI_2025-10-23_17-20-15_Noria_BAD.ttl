# -----------------------------------------------------------------------------
# Services (noria:Service)
# -----------------------------------------------------------------------------

noria:service/InternetAccessService a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:label "Service d'Accès Internet d'Entreprise"@fr ;
    rdfs:comment "Provides internet connectivity to all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:applicationModule/CorporateDNSService_Prod ;
    seas:subSystemOf noria:applicationModule/WebPortal_FrontendProd ;
    seas:subSystemOf noria:applicationModule/WebPortal_BackendProd .

noria:service/CorporateDataService a noria:Service ;
    rdfs:label "Corporate Data Service"@en ;
    rdfs:label "Service de Données d'Entreprise"@fr ;
    rdfs:comment "Provides access to internal data repositories and databases."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:applicationModule/WebPortal_BackendProd .

# -----------------------------------------------------------------------------
# Event Records (noria:EventRecord)
# -----------------------------------------------------------------------------

noria:event/DNSServerDownAlert a noria:EventRecord ;
    rdfs:label "DNS Server Down Alert"@en ;
    rdfs:comment "Automated alert indicating that the primary DNS server is unreachable."@en ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:resource/DNSServer01 ;
    noria:logOriginatingManagementSystem noria:application/CentralizedLoggingSystem ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:event/HighCPUUsageWebServer a noria:EventRecord ;
    rdfs:label "High CPU Usage on Web Server"@en ;
    rdfs:comment "Alert for sustained high CPU utilization on Web Server 03."@en ;
    noria:loggingTime "2024-04-23T11:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:resource/WebServer03 ;
    noria:logOriginatingManagementSystem noria:application/CentralizedLoggingSystem ;
    noria:logText "WARNING: CPU usage on web03.corp.example.com exceeded 90% for 15 minutes."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:event/FirewallPortBlockedLog a noria:EventRecord ;
    rdfs:label "Firewall Port Blocked Log"@en ;
    rdfs:comment "Log entry indicating a specific port was blocked by Firewall 01."@en ;
    noria:loggingTime "2024-04-23T12:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:resource/Firewall01 ;
    noria:logOriginatingManagementSystem noria:application/CentralizedLoggingSystem ;
    noria:logText "FIREWALL: Blocked TCP port 8080 from source 192.168.5.10 to destination 172.16.0.5."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:event/DNSServerRestartLog a noria:EventRecord ;
    rdfs:label "DNS Server Restart Log"@en ;
    rdfs:comment "Log entry confirming the restart of DNS Server 01 by an administrator."@en ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:resource/DNSServer01 ;
    noria:logOriginatingManagementSystem noria:application/CentralizedLoggingSystem ;
    noria:logOriginatingAgent noria:agent/JohnDoe ;
    noria:logText "INFO: DNS service restarted by John Doe."@en ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

