    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    noria:troubleTicketNoteCorrelatedExecution noria:event/DNSServerRestartLog .

noria:troubleTicketNote/WebPortalSlowTT_Note1 a noria:TroubleTicketNote ;
    rdfs:label "Web Portal Slow TT Note 1: Escalation to L2"@en ;
    rdfs:comment "Escalated to L2 support due to persistent high CPU and user complaints."@en ;
    dcterms:created "2024-04-23T11:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:agent/JaneSmith ;
    dcterms:description "Observed high CPU on web03.corp.example.com. No immediate resolution found. Escalating to L2 for deeper analysis."@en ;
    dcterms:isPartOf noria:troubleTicket/WebPortalSlowTT ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Escalation> .

