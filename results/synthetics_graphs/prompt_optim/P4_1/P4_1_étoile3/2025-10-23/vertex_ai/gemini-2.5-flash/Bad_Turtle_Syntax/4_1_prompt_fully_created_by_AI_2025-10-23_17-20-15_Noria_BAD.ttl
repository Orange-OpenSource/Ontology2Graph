    rdfs:comment "Developer of virtualization software."@en .

# -----------------------------------------------------------------------------
# Resources (noria:Resource)
# -----------------------------------------------------------------------------

noria:resource/DNSServer01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:label "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for the corporate network, critical for name resolution."@en ;
    noria:resourceManagedBy noria:agent/DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com"^^xsd:string ;
    noria:resourceProductModel noria:productModel/DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceLogisticId "LOG-DNS-001"^^xsd:string ;
    noria:resourceSerialNumber "SN-R740-001"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:location/Rack12 ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.10> .

noria:resource/CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:label "Routeur Cœur 01"@fr ;
    rdfs:comment "Main router for internal network traffic and internet egress."@en ;
    noria:resourceManagedBy noria:agent/NOC_Team ;
    noria:resourceHostName "cr01.corp.example.com"^^xsd:string ;
    noria:resourceProductModel noria:productModel/JuniperMX204 ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceLogisticId "LOG-CR-001"^^xsd:string ;
    noria:resourceSerialNumber "SN-MX204-001"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:location/Rack12 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

noria:resource/WebServer03 a noria:Resource ;
    rdfs:label "Web Server 03"@en ;
    rdfs:label "Serveur Web 03"@fr ;
    rdfs:comment "Virtual machine hosting part of the corporate web portal."@en ;
    noria:resourceManagedBy noria:agent/AppSupportL2_Team ;
    noria:resourceHostName "web03.corp.example.com"^^xsd:string ;
    noria:resourceProductModel noria:productModel/VMwareESXiHost ; # The host running the VM
    noria:resourceType <kos/Resource/type/virtual-machine> ;
    noria:resourceLogisticId "LOG-WEB-003"^^xsd:string ;
    noria:resourceSerialNumber "VM-WEB-003"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-10T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:location/Rack12 ; # The physical location of its host
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.3> .

noria:resource/Firewall01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:label "Pare-feu Périmétrique 01"@fr ;
    rdfs:comment "Firewall protecting the corporate network perimeter at the Edge PoP."@en ;
    noria:resourceManagedBy noria:agent/NOC_Team ;
    noria:resourceHostName "fw01.edge.example.com"^^xsd:string ;
    noria:resourceProductModel noria:productModel/CiscoCatalyst9300 ;
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceLogisticId "LOG-FW-001"^^xsd:string ;
    noria:resourceSerialNumber "SN-C9300-001"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-08-01T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:location/Shelf3 ;
    noria:resourceManagementIPAddress <http://example.com/ip/198.51.100.1> .

# -----------------------------------------------------------------------------
# Network Interfaces (noria:NetworkInterface)
# -----------------------------------------------------------------------------

noria:networkInterface/DNSServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS Server 01 - Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf noria:resource/DNSServer01 ;
    noria:networkInterfaceDescription "Management and DNS traffic interface."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

noria:networkInterface/CoreRouter01_Ge000 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 - GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal network."@en ;
    noria:networkInterfaceOf noria:resource/CoreRouter01 ;
    noria:networkInterfaceDescription "Internal LAN uplink."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100^^xsd:int .

noria:networkInterface/CoreRouter01_Ge001 a noria:NetworkInterface ;
    rdfs:label "Core Router 01 - GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the perimeter firewall."@en ;
    noria:networkInterfaceOf noria:resource/CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to Firewall 01."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 50^^xsd:int .

noria:networkInterface/Firewall01_Eth1 a noria:NetworkInterface ;
    rdfs:label "Firewall 01 - Ethernet 1"@en ;
    rdfs:comment "Interface connecting Firewall 01 to Core Router 01."@en ;
    noria:networkInterfaceOf noria:resource/Firewall01 ;
    noria:networkInterfaceDescription "Internal network interface."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# -----------------------------------------------------------------------------
# Network Links (noria:NetworkLink)
# -----------------------------------------------------------------------------

noria:networkLink/CR01_FW01_Uplink a noria:NetworkLink ;
    rdfs:label "Core Router 01 to Firewall 01 Uplink"@en ;
    rdfs:comment "High-speed link between the core router and the perimeter firewall."@en ;
    noria:networkLinkId "NL-CR01-FW01-001"^^xsd:string ;
    noria:networkLinkType "Ethernet 10Gbps"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-08-01T11:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:agent/NOC_Team ;
    noria:networkLinkTerminationResourceOrigin noria:resource/CoreRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:resource/Firewall01 ;
    noria:networkInterfaceConnects noria:networkInterface/CoreRouter01_Ge001 ;
    noria:networkInterfaceConnects noria:networkInterface/Firewall01_Eth1 .

noria:networkLink/DNSServer01_CR01_Link a noria:NetworkLink ;
    rdfs:label "DNS Server 01 to Core Router 01 Link"@en ;
    rdfs:comment "Internal network link for DNS traffic."@en ;
    noria:networkLinkId "NL-DNS01-CR01-001"^^xsd:string ;
    noria:networkLinkType "Ethernet 1Gbps"^^xsd:string ;
    noria:networkLinkInstallationDate "2022-01-15T10:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:agent/DNSAdminTeam ;
    noria:networkLinkTerminationResourceOrigin noria:resource/DNSServer01 ;
    noria:networkLinkTerminationResourceDestination noria:resource/CoreRouter01 ;
    noria:networkInterfaceConnects noria:networkInterface/DNSServer01_Eth0 ;
    noria:networkInterfaceConnects noria:networkInterface/CoreRouter01_Ge000 .

# -----------------------------------------------------------------------------
# Applications (noria:Application)
# -----------------------------------------------------------------------------

noria:application/CorporateDNSService a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:label "Service DNS d'Entreprise"@fr ;
    rdfs:comment "Provides name resolution services for all internal and external corporate applications."@en ;
    noria:applicationModelIdentifier "CORP-DNS"^^xsd:string ;
    noria:applicationNumericalIdentifier 101^^xsd:int ;
    noria:applicationShortIdentifier "CORPDNS"^^xsd:string ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Network Services"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Name Resolution"^^xsd:string .

noria:application/WebPortalApp a noria:Application ;
    rdfs:label "Corporate Web Portal Application"@en ;
    rdfs:label "Application Portail Web d'Entreprise"@fr ;
    rdfs:comment "Main web application for employee access to internal tools and information."@en ;
    noria:applicationModelIdentifier "CORP-WEB"^^xsd:string ;
    noria:applicationNumericalIdentifier 102^^xsd:int ;
    noria:applicationShortIdentifier "CORPWEB"^^xsd:string ;
    noria:applicationType <kos/application/type/business-application> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Employee Productivity"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Internal Communications"^^xsd:string .

noria:application/CentralizedLoggingSystem a noria:Application ;
    rdfs:label "Centralized Logging System"@en ;
    rdfs:label "Système de Journalisation Centralisé"@fr ;
    rdfs:comment "Collects, stores, and analyzes logs from all IT infrastructure components."@en ;
    noria:applicationModelIdentifier "LOG-SYS"^^xsd:string ;
    noria:applicationNumericalIdentifier 103^^xsd:int ;
    noria:applicationShortIdentifier "LOGSYS"^^xsd:string ;
    noria:applicationType <kos/application/type/monitoring-tool> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "IT Operations"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Log Management"^^xsd:string .

