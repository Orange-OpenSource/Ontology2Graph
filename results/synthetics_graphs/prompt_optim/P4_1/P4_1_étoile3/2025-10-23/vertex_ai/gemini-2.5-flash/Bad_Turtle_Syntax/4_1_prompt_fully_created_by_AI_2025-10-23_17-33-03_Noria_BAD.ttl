    noria:troubleTicketSupervisionTool "Nagios" ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:documentHRef "https://itsm.example.com/tickets/TT-DNS-001" ;
    noria:documentStatusHistory noria:DNSOutageLog_StatusChange_InProgress, noria:DNSOutageLog_StatusChange_Resolved .

noria:TT-Web-002 a noria:TroubleTicket ;
    rdfs:label "Web Portal Database Connection Issue"@en ;
