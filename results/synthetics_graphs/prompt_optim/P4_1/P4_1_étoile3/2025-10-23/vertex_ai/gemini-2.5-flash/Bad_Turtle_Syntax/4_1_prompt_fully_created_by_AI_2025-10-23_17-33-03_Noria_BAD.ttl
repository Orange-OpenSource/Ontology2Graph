    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketRelatedService noria:CorpDNS ;
    noria:troubleTicketRelatedResource noria:DNS01 ;
    noria:troubleTicketRelatedParty noria:AdminTeam, noria:JohnDoe ;
