# --- Event Records ---
noria:DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server dns01.corp.example.com became unreachable."@en ;
    noria:loggingTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:DNS01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:logText "Host dns01.corp.example.com (192.168.1.10) is DOWN." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:InterfaceDownAlarm a noria:EventRecord ;
    rdfs:label "Router Interface Down Alarm"@en ;
    rdfs:comment "Alarm indicating a network interface on RouterCore01 went down."@en ;
    noria:loggingTime "2024-04-20T07:59:30Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:RouterCore01 ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:logText "Interface GigabitEthernet0/0/1 on router-core01.corp.example.com changed state to down." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:CheckCableConnection .

noria:ConfigChangeLog a noria:EventRecord ;
    rdfs:label "Router Configuration Change Log"@en ;
    rdfs:comment "Log entry for a configuration change on RouterCore01 by John Doe."@en ;
    noria:loggingTime "2024-04-19T16:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:RouterCore01 ;
    noria:logOriginatingAgent noria:JohnDoe ;
    noria:logText "Configuration changed by John Doe from console." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:WebPortalErrorLog a noria:EventRecord ;
    rdfs:label "Web Portal Application Error Log"@en ;
    rdfs:comment "Log entry indicating an error in the Web Portal application."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:WebPortal ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:logText "Application error: Database connection failed for WebPortal-Prod." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:DNS01ServiceRestartEvent a noria:EventRecord ;
    rdfs:label "DNS Service Restart Command Log"@en ;
    rdfs:comment "Log entry for the command executed to restart DNS service."@en ;
    noria:loggingTime "2024-04-20T08:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:DNS01 ;
    noria:logOriginatingAgent noria:JohnDoe ;
    noria:logText "Command executed: systemctl restart named.service" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:DNSOutageLog_StatusChange_InProgress a noria:EventRecord ;
    rdfs:label "TT-DNS-001 Status Change to InProgress"@en ;
    noria:loggingTime "2024-04-20T08:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:logText "Trouble Ticket TT-DNS-001 status changed to InProgress." ;
    dcterms:references noria:TT-DNS-001 .

noria:DNSOutageLog_StatusChange_Resolved a noria:EventRecord ;
    rdfs:label "TT-DNS-001 Status Change to Resolved"@en ;
    noria:loggingTime "2024-04-20T10:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagementSystem noria:MonitoringSystem ;
    noria:logText "Trouble Ticket TT-DNS-001 status changed to Resolved." ;
    dcterms:references noria:TT-DNS-001 .

# --- Trouble Tickets ---
