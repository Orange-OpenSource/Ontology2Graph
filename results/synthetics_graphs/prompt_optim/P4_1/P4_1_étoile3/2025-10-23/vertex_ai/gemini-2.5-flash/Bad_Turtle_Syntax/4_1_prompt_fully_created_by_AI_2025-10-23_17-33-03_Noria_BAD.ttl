    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> .

noria:TT-DNS-001-Note2 a noria:TroubleTicketNote ;
    rdfs:label "Service Restart Attempt for TT-DNS-001"@en ;
    rdfs:comment "Attempted to restart DNS service on DNS01. Service came up briefly then crashed again. Investigating logs on DNS01."@en ;
    dcterms:created "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    dcterms:creator noria:JohnDoe ;
    dcterms:isPartOf noria:TT-DNS-001 ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/TestsAndMeasurements> ;
    noria:troubleTicketNoteCorrelatedExecution noria:DNS01ServiceRestartExecution .

noria:DNS01ServiceRestartExecution a pep:ProcedureExecutionContainer ;
    rdfs:label "DNS01 Service Restart Execution"@en ;
    rdfs:comment "Container for events related to the DNS service restart on DNS01."@en ;
    dcterms:relation noria:DNS01ServiceRestartEvent .

