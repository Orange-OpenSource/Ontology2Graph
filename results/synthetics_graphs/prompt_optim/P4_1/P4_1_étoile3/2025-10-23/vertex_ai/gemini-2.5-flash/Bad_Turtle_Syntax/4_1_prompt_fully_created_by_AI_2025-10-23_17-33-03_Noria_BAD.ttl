@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .

# --- KOS Concepts (Knowledge Organization System) ---
# These concepts define controlled vocabularies used by NORIA properties.

# Application Types
<kos/application/type/infrastructure> a skos:Concept ; rdfs:label "Infrastructure Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/business> a skos:Concept ; rdfs:label "Business Application"@en ; skos:inScheme <kos/application/type> .
<kos/application/type/monitoring> a skos:Concept ; rdfs:label "Monitoring System"@en ; skos:inScheme <kos/application/type> .
<kos/application/type> a skos:ConceptScheme ; rdfs:label "Application Types"@en .

# Application Business Importance
<kos/application/business-importance/high> a skos:Concept ; rdfs:label "High Business Importance"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance/medium> a skos:Concept ; rdfs:label "Medium Business Importance"@en ; skos:inScheme <kos/application/business-importance> .
<kos/application/business-importance> a skos:ConceptScheme ; rdfs:label "Application Business Importance Levels"@en .

# Application Module Status
<https://w3id.org/noria/kos/application/status/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; rdfs:label "En Production"@fr ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status/Development> a skos:Concept ; rdfs:label "Development"@en ; rdfs:label "En Développement"@fr ; skos:inScheme <https://w3id.org/noria/kos/application/status> .
<https://w3id.org/noria/kos/application/status> a skos:ConceptScheme ; rdfs:label "Application Module Status"@en .

# Application Module SLA Level
<https://w3id.org/noria/kos/application/sla-level/Platinum> a skos:Concept ; rdfs:label "Platinum SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level/Gold> a skos:Concept ; rdfs:label "Gold SLA Level"@en ; skos:inScheme <https://w3id.org/noria/kos/application/sla-level> .
<https://w3id.org/noria/kos/application/sla-level> a skos:ConceptScheme ; rdfs:label "Application Module SLA Levels"@en .

# Trouble Ticket Severity
<kos/TroubleTicket/severity/Critical> a skos:Concept ; rdfs:label "Critical Severity"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Major> a skos:Concept ; rdfs:label "Major Severity"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity/Minor> a skos:Concept ; rdfs:label "Minor Severity"@en ; skos:inScheme <kos/TroubleTicket/severity> .
<kos/TroubleTicket/severity> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Severity Levels"@en .

# Trouble Ticket Status
<kos/TroubleTicket/status/InProgress> a skos:Concept ; rdfs:label "In Progress"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Resolved> a skos:Concept ; rdfs:label "Resolved"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status/Closed> a skos:Concept ; rdfs:label "Closed"@en ; skos:inScheme <kos/TroubleTicket/status> .
<kos/TroubleTicket/status> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Status"@en .

# Trouble Ticket Type
<kos/TroubleTicket/type/Failure> a skos:Concept ; rdfs:label "Failure"@en ; skos:inScheme <kos/TroubleTicket/type> .
<kos/TroubleTicket/type/Assistance> a skos:Concept ; rdfs:label "Assistance"@en ; skos:inScheme <kos/TroubleTicket/type> .
<kos/TroubleTicket/type> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Types"@en .

# Trouble Ticket Origin
<kos/TroubleTicket/origin/Supervision> a skos:Concept ; rdfs:label "Supervision System"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin/Customer> a skos:Concept ; rdfs:label "Customer Report"@en ; skos:inScheme <kos/TroubleTicket/origin> .
<kos/TroubleTicket/origin> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Origin"@en .

# Trouble Ticket Category
<kos/TroubleTicket/trouble-category/NetworkOutage> a skos:Concept ; rdfs:label "Network Outage"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/trouble-category/ApplicationError> a skos:Concept ; rdfs:label "Application Error"@en ; skos:inScheme <kos/TroubleTicket/trouble-category> .
<kos/TroubleTicket/trouble-category> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Categories"@en .

# Problem Responsibility
<kos/TroubleTicket/problemResponsibility/InternalIT> a skos:Concept ; rdfs:label "Internal IT"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility/ExternalVendor> a skos:Concept ; rdfs:label "External Vendor"@en ; skos:inScheme <kos/TroubleTicket/problemResponsibility> .
<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ; rdfs:label "Problem Responsibility"@en .

# Trouble Ticket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention> a skos:Concept ; rdfs:label "Immediate Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .
<kos/TroubleTicket/urgency/DeferredIntervention> a skos:Concept ; rdfs:label "Deferred Intervention"@en ; skos:inScheme <kos/TroubleTicket/urgency> .
<kos/TroubleTicket/urgency> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Urgency Levels"@en .

# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Note Comment Types"@en .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis"@en ; skos:inScheme <kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; rdfs:label "Tests and Measurements"@en ; skos:inScheme <kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType> a skos:ConceptScheme ; rdfs:label "Trouble Ticket Note Operation Types"@en .

# Change Request Category
<kos/ChangeRequest/category/Maintenance> a skos:Concept ; rdfs:label "Maintenance"@en ; skos:inScheme <kos/ChangeRequest/category> .
<kos/ChangeRequest/category/Upgrade> a skos:Concept ; rdfs:label "Upgrade"@en ; skos:inScheme <kos/ChangeRequest/category> .
<kos/ChangeRequest/category> a skos:ConceptScheme ; rdfs:label "Change Request Categories"@en .

# Change Request Type
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en ; skos:inScheme <kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency Change"@en ; skos:inScheme <kos/ChangeRequest/type> .
<kos/ChangeRequest/type> a skos:ConceptScheme ; rdfs:label "Change Request Types"@en .

# Change Request Cause
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en ; skos:inScheme <kos/ChangeRequest/cause> .
<kos/ChangeRequest/cause/ConfigurationChange> a skos:Concept ; rdfs:label "Configuration Change"@en ; skos:inScheme <kos/ChangeRequest/cause> .
<kos/ChangeRequest/cause> a skos:ConceptScheme ; rdfs:label "Change Request Causes"@en .

# Change Request Status
<kos/ChangeRequest/status/Planned> a skos:Concept ; rdfs:label "Planned"@en ; skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented"@en ; skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/status> a skos:ConceptScheme ; rdfs:label "Change Request Status"@en .

# Resource Type
<kos/Resource/type/Server> a skos:Concept ; rdfs:label "Server"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Router> a skos:Concept ; rdfs:label "Router"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/VirtualMachine> a skos:Concept ; rdfs:label "Virtual Machine"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type/Firewall> a skos:Concept ; rdfs:label "Firewall"@en ; skos:inScheme <kos/Resource/type> .
<kos/Resource/type> a skos:ConceptScheme ; rdfs:label "Resource Types"@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InProduction> a skos:Concept ; rdfs:label "In Production"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState/Decommissioned> a skos:Concept ; rdfs:label "Decommissioned"@en ; skos:inScheme <kos/Resource/LifecycleState> .
<kos/Resource/LifecycleState> a skos:ConceptScheme ; rdfs:label "Resource Lifecycle States"@en .

# Resource Operational State
<kos/Resource/OperationalState/Up> a skos:Concept ; rdfs:label "Up"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState/Down> a skos:Concept ; rdfs:label "Down"@en ; skos:inScheme <kos/Resource/OperationalState> .
<kos/Resource/OperationalState> a skos:ConceptScheme ; rdfs:label "Resource Operational States"@en .

# Resource Administrative State
<kos/Resource/AdministrativeState/Enabled> a skos:Concept ; rdfs:label "Enabled"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState/Disabled> a skos:Concept ; rdfs:label "Disabled"@en ; skos:inScheme <kos/Resource/AdministrativeState> .
<kos/Resource/AdministrativeState> a skos:ConceptScheme ; rdfs:label "Resource Administrative States"@en .

# Notification Severity Perceived Severity
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Informational> a skos:Concept ; rdfs:label "Informational"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity> a skos:ConceptScheme ; rdfs:label "Perceived Severity Levels"@en .

# Agent Contact Method
<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method> a skos:ConceptScheme ; rdfs:label "Agent Contact Methods"@en .

# Service Type
<kos/service/type/CustomerFacingService> a skos:Concept ; rdfs:label "Customer Facing Service"@en ; skos:inScheme <kos/service/type> .
<kos/service/type/ResourceFacingService> a skos:Concept ; rdfs:label "Resource Facing Service"@en ; skos:inScheme <kos/service/type> .
<kos/service/type> a skos:ConceptScheme ; rdfs:label "Service Types"@en .

# --- Agents and Organizations ---
noria:AdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Administration Team"@en ;
    rdfs:label "Équipe d'Administration IT"@fr ;
    rdfs:comment "Team responsible for core IT infrastructure management."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all requests."@en .

noria:SupportTeamL2 a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Level 2 Support Team"@en ;
    rdfs:label "Équipe Support Niveau 2"@fr ;
    rdfs:comment "Specialized team for in-depth troubleshooting and incident resolution."@en ;
    noria:agentWorkingHours "24/7 On-call" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Escalate critical incidents via dedicated hotline."@en .

noria:NOC a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:label "Centre d'Opérations Réseau"@fr ;
    rdfs:comment "Monitors network infrastructure and responds to alerts."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Automated alerts are sent to the NOC system."@en .

noria:JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Individual IT administrator, member of the Admin Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:member noria:AdminTeam ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call mobile for urgent issues."@en .

noria:JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Lead of the Level 2 Support Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:member noria:SupportTeamL2 ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for all non-critical communications."@en .

noria:AppDev a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining applications."@en .

noria:DellInc a org:Organization, foaf:Agent ;
    rdfs:label "Dell Inc."@en ;
    rdfs:comment "Manufacturer of Dell PowerEdge servers."@en .

noria:CiscoSystems a org:Organization, foaf:Agent ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of Cisco network equipment."@en .

noria:VMwareInc a org:Organization, foaf:Agent ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Developer of virtualization software."@en .

# --- Corporate User Identifiers ---
noria:JohnDoeCUid a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount noria:JohnDoe .

noria:JaneSmithCUid a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount noria:JaneSmith .

# --- Locations ---
noria:ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" .

noria:ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room within the Paris Data Center."@en ;
    bot:hasSpace noria:ParisDC .

noria:Rack12U a noria:Locus ;
    rdfs:label "Rack 12U"@en ;
    rdfs:comment "Specific rack location 12U in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "12" ;
    bot:hasSpace noria:ServerRoomA .

# --- Product Models ---
noria:DellPowerEdgeR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Server model from Dell."@en ;
    noria:productManufacturedBy noria:DellInc .

noria:CiscoCatalyst9k a noria:ProductModel ;
    rdfs:label "Cisco Catalyst 9300"@en ;
    rdfs:comment "Network switch model from Cisco."@en ;
    noria:productManufacturedBy noria:CiscoSystems .

noria:VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform software."@en ;
    noria:productManufacturedBy noria:VMwareInc .

# --- Resources ---
noria:DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for the corporate network, physical machine."@en ;
    noria:resourceManagedBy noria:AdminTeam ;
    noria:elementManagedBy noria:AdminTeam ; # Redundant but shows property usage
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:locatedAtLocus noria:Rack12U ;
    noria:resourceManagementIPAddress "192.168.1.10" ;
    noria:resourceForApplication noria:CorpDNS ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" .

noria:RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for internal network traffic."@en ;
    noria:resourceManagedBy noria:NOC ;
    noria:elementManagedBy noria:NOC ;
    noria:resourceHostName "router-core01.corp.example.com" ;
    noria:resourceProductModel noria:CiscoCatalyst9k ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:locatedAtLocus noria:Rack12U ;
    noria:resourceManagementIPAddress "10.0.0.1" ;
    noria:resourceForApplication noria:CorpDNS, noria:WebPortal ;
    noria:resourceSerialNumber "SN-RTR-001-ABC" .

noria:VMWeb01 a noria:Resource ;
    rdfs:label "Web Portal Virtual Machine 01"@en ;
    rdfs:comment "Virtual machine hosting the corporate web portal."@en ;
    noria:resourceManagedBy noria:SupportTeamL2 ;
    noria:elementManagedBy noria:SupportTeamL2 ;
    noria:resourceHostName "vmweb01.corp.example.com" ;
    noria:resourceProductModel noria:VMwareESXi ;
    noria:resourceType <kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceLogisticId "LOG-VM-001" ;
    noria:resourceForApplication noria:WebPortal ;
    noria:clusterController noria:HypervisorHost01 ;
    noria:resourceSerialNumber "SN-VM-001-DEF" .

noria:HypervisorHost01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical host running virtual machines."@en ;
    noria:resourceManagedBy noria:AdminTeam ;
    noria:elementManagedBy noria:AdminTeam ;
    noria:resourceHostName "hypervisor01.corp.example.com" ;
    noria:resourceProductModel noria:DellPowerEdgeR740 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:locatedAtLocus noria:Rack12U .

noria:FirewallFW01 a noria:Resource ;
    rdfs:label "Perimeter Firewall 01"@en ;
    rdfs:comment "Firewall protecting the corporate network perimeter."@en ;
    noria:resourceManagedBy noria:NOC ;
    noria:elementManagedBy noria:NOC ;
    noria:resourceHostName "fw01.corp.example.com" ;
    noria:resourceProductModel noria:CiscoCatalyst9k ;
    noria:resourceType <kos/Resource/type/Firewall> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-11-01T11:00:00Z"^^xsd:dateTime ;
    noria:resourceLogisticId "LOG-FW-001" ;
    noria:locatedAtLocus noria:Rack12U ;
    noria:resourceManagementIPAddress "10.0.0.254" ;
    noria:resourceForApplication noria:CorpDNS, noria:WebPortal .

# --- Network Interfaces ---
noria:DNS01-Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Main network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Primary interface for DNS traffic."@en .

noria:RouterCore01-Gi0-0-1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting RouterCore01 to DNS01."@en ;
    noria:networkInterfaceOf noria:RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Uplink to DNS server segment."@en .

noria:RouterCore01-Gi0-0-2 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet 0/0/2"@en ;
    rdfs:comment "Interface connecting RouterCore01 to FirewallFW01."@en ;
    noria:networkInterfaceOf noria:RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 ;
    noria:networkInterfaceDescription "Uplink to Firewall segment."@en .

noria:VMWeb01-vNIC0 a noria:NetworkInterface ;
    rdfs:label "VMWeb01 Virtual NIC 0"@en ;
    rdfs:comment "Virtual network interface for VMWeb01."@en ;
    noria:networkInterfaceOf noria:VMWeb01 ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

noria:FirewallFW01-Eth0 a noria:NetworkInterface ;
    rdfs:label "FirewallFW01 Ethernet 0"@en ;
    rdfs:comment "Interface connecting FirewallFW01 to RouterCore01."@en ;
    noria:networkInterfaceOf noria:FirewallFW01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# --- Network Links ---
noria:Link-DNS01-RouterCore01 a noria:NetworkLink ;
    rdfs:label "Link between DNS01 and RouterCore01"@en ;
    rdfs:comment "Physical Ethernet link."@en ;
    noria:networkLinkId "NL-001" ;
    noria:networkLinkType "Ethernet" ;
