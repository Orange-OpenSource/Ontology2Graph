# --- Operation Plans ---
noria:RouterFirmwareUpgrade a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware."@en ;
    noria:operationPlanPreCondition noria:RouterReachable ;
    noria:operationPlanPostCondition noria:RouterFirmwareUpdated .

noria:DNSFailoverProcedure a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Procedure to activate secondary DNS server in case of primary failure."@en ;
    noria:operationPlanPreCondition noria:PrimaryDNSDown ;
    noria:operationPlanPostCondition noria:DNSResolutionOK .

noria:CheckCableConnection a pep:Procedure ;
    rdfs:label "Check Cable Connection Procedure"@en ;
    rdfs:comment "Procedure to physically check and reseat network cables."@en .

# --- Action Pre/Post Conditions ---
noria:RouterReachable a noria:ActionPreCondition ;
    rdfs:label "Router Reachable"@en ;
    rdfs:comment "Condition: The router must be reachable via management interface."@en ;
    skos:example "Ping to management IP 10.0.0.1 is successful."@en .

noria:RouterFirmwareUpdated a noria:ActionPostCondition ;
    rdfs:label "Router Firmware Updated"@en ;
    rdfs:comment "Condition: Router firmware version must match the target version."@en ;
    skos:example "Verify 'show version' output for new firmware."@en .

noria:PrimaryDNSDown a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Down"@en ;
    rdfs:comment "Condition: Primary DNS server is not responding to queries."@en ;
    skos:example "DNS queries to 192.168.1.10 fail."@en .

noria:DNSResolutionOK a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution OK"@en ;
    rdfs:comment "Condition: DNS resolution is working correctly after failover."@en ;
    skos:example "Internal hosts can resolve corporate domain names."@en .
