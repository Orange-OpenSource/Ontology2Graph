    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/InternalIT> ;
    noria:troubleTicketCause "Database server overload."@en ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:documentHRef "https://itsm.example.com/tickets/TT-WEB-002" .

# --- Trouble Ticket Notes ---
noria:TT-DNS-001-Note1 a noria:TroubleTicketNote ;
    rdfs:label "Initial Diagnosis for TT-DNS-001"@en ;
    rdfs:comment "Initial checks confirm DNS service is not responding on port 53. No network connectivity issues detected to the server."@en ;
    dcterms:created "2024-04-20T08:15:00Z"^^xsd:dateTime ;
    dcterms:creator noria:JohnDoe ;
    dcterms:isPartOf noria:TT-DNS-001 ;
