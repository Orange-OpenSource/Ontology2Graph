    rdfs:label "Application Server 05"@en ;
    rdfs:comment "Server hosting the CriticalDataService application."@en ;
    noria:resourceLogisticId "LOG-SRV-005" ;
    noria:resourceHostName "appserver05.techcorp.com"@en ;
    noria:resourceProductModel ex:Dell_PowerEdge_Model ;
    noria:resourceType ex:ResourceType_Server ;
    noria:resourceSerialNumber "ABC98765432"@en ;
    noria:resourceUsageState ex:ResourceLifecycle_InProduction ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy ex:AppSupportTeam ;
