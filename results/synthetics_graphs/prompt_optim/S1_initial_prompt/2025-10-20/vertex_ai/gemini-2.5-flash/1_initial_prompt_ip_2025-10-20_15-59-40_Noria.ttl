    rdfs:comment "Service directly consumed by customers."@en .

# --- Organizational Structure ---
ex:TechCorp
    a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "A leading technology company providing critical data services."@en ;
    dcterms:identifier "TC-001" .

ex:NetOpsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing and maintaining network infrastructure."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod ex:AgentContactMethod_Email ;
    noria:agentInstructions "For critical issues, use the dedicated hotline and ticketing system."@en .

ex:AppSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting critical business applications."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "Mon-Fri, 9am-5pm CET"@en ;
    noria:agentPreferredContactMethod ex:AgentContactMethod_Email ;
    noria:agentInstructions "Submit tickets via the internal portal for all non-critical issues."@en .

ex:AliceAnalyst
    a foaf:Agent ;
    rdfs:label "Alice Analyst"@en ;
    rdfs:comment "Network Analyst at TechCorp, specializing in routing protocols."@en ;
    org:memberOf ex:NetOpsTeam ;
    foaf:mbox <mailto:alice.analyst@techcorp.com> .

ex:BobEngineer
    a foaf:Agent ;
    rdfs:label "Bob Engineer"@en ;
    rdfs:comment "Senior Application Engineer at TechCorp, lead for CriticalDataService."@en ;
    org:memberOf ex:AppSupportTeam ;
    foaf:mbox <mailto:bob.engineer@techcorp.com> .

ex:AliceCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Alice Analyst."@en ;
    foaf:accountName "a.analyst" ;
    foaf:holdsAccount ex:AliceAnalyst .

ex:BobCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Bob's Corporate User ID"@en ;
    rdfs:comment "Corporate User Identifier for Bob Engineer."@en ;
    foaf:accountName "b.engineer" ;
    foaf:holdsAccount ex:BobEngineer .

ex:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

ex:DellTechnologies
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware and software."@en .

# --- Location ---
ex:MainDataCenter
    a bot:Site ;
    rdfs:label "TechCorp Main Data Center"@en ;
    rdfs:comment "Primary data center facility for TechCorp's operations."@en ;
    noria:siteId "DC-NYC-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Tech Way"@en ;
    noria:sitePrincipalAddressCityName "New York"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en .

ex:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated server room within the Main Data Center."@en ;
    bot:hasSubSpace ex:MainDataCenter . # Assuming bot:hasSubSpace can link a room to a site, or I can use bot:containsZone from site to room. Let's use bot:containsZone from site to room.
    # Correcting: bot:containsZone is from bot:Space to bot:Zone, and noria:Room is a bot:Space. So, MainDataCenter (bot:Site) contains ServerRoomA (noria:Room).
    # The schema states bot:containsZone for Locus, not Room. Let's use bot:hasSubSpace for Site to Room.
    # The schema says noria:Room is a subClassOf bot:Space. bot:Site is also a bot:Space.
    # So, ex:MainDataCenter bot:hasSubSpace ex:ServerRoomA.

ex:Rack12_U23
    a noria:Locus ;
    rdfs:label "Rack 12, Unit 23"@en ;
    rdfs:comment "Specific location within Server Room A for a network device."@en ;
    noria:locusLine "Rack 12"@en ;
    noria:locusRow "U23"@en ;
    bot:containsZone ex:ServerRoomA . # This is inverse. Should be ex:ServerRoomA bot:containsZone ex:Rack12_U23.
    # Correcting: bot:containsZone is from bot:Space to bot:Zone. noria:Locus is a bot:Space.
    # So, ex:ServerRoomA bot:containsZone ex:Rack12_U23.

ex:ServerRoomA
    bot:containsZone ex:Rack12_U23 .
ex:MainDataCenter
    bot:hasSubSpace ex:ServerRoomA .

