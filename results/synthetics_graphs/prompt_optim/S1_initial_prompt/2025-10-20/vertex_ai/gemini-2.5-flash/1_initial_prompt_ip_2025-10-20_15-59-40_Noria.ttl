    noria:resourceManagementIPAddress <http://10.0.0.5> .

# --- Network Interfaces ---
ex:Router01_GE0_0_1
    a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Network interface on Core Router 01, connecting to Server 05."@en ;
    noria:networkInterfaceOf ex:Router01 ;
    noria:networkInterfaceDescription "Uplink to AppServer05"@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus ex:ResourceAdmState_Up ;
    noria:networkInterfaceOperationalStatus ex:ResourceOpState_Up ;
    noria:networkInterfaceRoutingPriorityMetric 10 .

ex:Server05_Eth0
    a noria:NetworkInterface ;
    rdfs:label "Server05 Ethernet0"@en ;
    rdfs:comment "Network interface on Application Server 05, connecting to Router 01."@en ;
    noria:networkInterfaceOf ex:Server05 ;
    noria:networkInterfaceDescription "Connection to Core Router 01"@en ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus ex:ResourceAdmState_Up ;
    noria:networkInterfaceOperationalStatus ex:ResourceOpState_Up .

# --- Network Links ---
ex:Link_Router01_Server05
    a noria:NetworkLink ;
    rdfs:label "Link between Router01 and Server05"@en ;
    rdfs:comment "Direct physical link connecting Core Router 01 and Application Server 05."@en ;
    noria:networkLinkId "LINK-R01-S05-01" ;
    noria:networkLinkInstallationDate "2021-03-20T15:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkTerminationResourceOrigin ex:Router01 ;
    noria:networkLinkTerminationResourceDestination ex:Server05 ;
    noria:resourceManagedBy ex:NetOpsTeam ;
    noria:networkInterfaceConnects ex:Router01_GE0_0_1, ex:Server05_Eth0 . # This property is for NetworkInterface to NetworkLink, not NetworkLink to NetworkInterface.
    # Correcting:
ex:Router01_GE0_0_1
    noria:networkInterfaceConnects ex:Link_Router01_Server05 .
ex:Server05_Eth0
    noria:networkInterfaceConnects ex:Link_Router01_Server05 .

# --- Applications and Services ---
ex:CriticalDataService
    a noria:Application ;
    rdfs:label "Critical Data Service"@en ;
    rdfs:comment "A core business application providing real-time data processing and analytics."@en ;
    noria:applicationModelIdentifier "CDS-V1.2" ;
    noria:applicationNumericalIdentifier 1001 ;
    noria:applicationShortIdentifier "CDS" ;
    noria:applicationType ex:AppType_Critical ;
    noria:applicationBusinessImportance ex:AppBizImp_High ;
    noria:applicationFunctionalDomain "Data Processing and Analytics"@en ;
    noria:applicationFunctionalSubDomain "Real-time Data Ingestion"@en ;
    noria:elementManagedBy ex:AppSupportTeam .

ex:CriticalDataService_Prod
    a noria:ApplicationModule ;
    rdfs:label "Critical Data Service Production Module"@en ;
    rdfs:comment "The production instance of the Critical Data Service application."@en ;
    noria:applicationModuleOf ex:CriticalDataService ;
    noria:applicationModuleName "CDS_PROD" ;
    noria:applicationModuleIdentifier "PROD-001" ;
    noria:applicationModuleAdministrationTeam ex:AppSupportTeam ;
    noria:applicationModuleAdministrationLeader ex:BobEngineer ;
    noria:applicationModuleSupportTeam ex:AppSupportTeam ;
    noria:applicationModuleSupportLeader ex:BobEngineer ;
    noria:applicationModuleHotlineEnabled true ;
    noria:applicationModuleSlaLevel ex:AppSLALevel_Gold ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleStatus ex:AppStatus_InProduction ;
    noria:elementManagedBy ex:AppSupportTeam .

ex:EnterpriseDataFlow
    a noria:Service ;
    rdfs:label "Enterprise Data Flow Service"@en ;
    rdfs:comment "An end-to-end service ensuring data flow across the enterprise, relying on CriticalDataService."@en ;
    noria:serviceType ex:ServiceType_CustomerFacing ;
    noria:elementManagedBy ex:AppSupportTeam .

# Link resources to applications/services
ex:Server05
    noria:resourceForApplication ex:CriticalDataService .
ex:CriticalDataService_Prod
    seas:subSystemOf ex:EnterpriseDataFlow .

# --- Event Records ---
ex:NetworkInterfaceDownEvent
    a noria:EventRecord ;
    rdfs:label "Router01 Interface Down Event"@en ;
    rdfs:comment "An event indicating that a network interface on Router01 went down."@en ;
    dcterms:type kos-notif-event-type:StateChange ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject ex:Router01_GE0_0_1 ;
    noria:logOriginatingManagementSystem ex:NetworkMonitoringSystem ;
    noria:alarmSeverity ex:NotificationSeverity_Critical .

ex:NetworkMonitoringSystem
    a noria:Application ;
    rdfs:label "Network Monitoring System"@en ;
    rdfs:comment "An application responsible for monitoring network devices and generating events."@en ;
    noria:applicationShortIdentifier "NMS" ;
    noria:elementManagedBy ex:NetOpsTeam .

# --- Trouble Tickets ---
ex:CriticalDataService_TT001
    a noria:TroubleTicket ;
    rdfs:label "Critical Data Service Outage - TT001"@en ;
    rdfs:comment "Trouble ticket opened due to an outage of the Critical Data Service."@en ;
    dcterms:identifier "TT-2024-04-20-001" ;
    dcterms:created "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CUST-INC-9876" ;
    noria:documentHRef <http://ticketing.techcorp.com/TT-2024-04-20-001> ;
    noria:troubleTicketSeverity ex:TTSeverity_Critical ;
    noria:troubleTicketType ex:TTType_Failure ;
    noria:troubleTicketPriority ex:TTPriority_P1 ;
    noria:troubleTicketOrigin ex:TTOrigin_Supervision ;
    noria:troubleTicketUrgency ex:TTUrgency_Immediate ;
    noria:troubleTicketCategory ex:TTCategory_TotalBreakdown ;
    noria:troubleTicketCause "Network interface failure on core router impacting application server connectivity."@en ;
    noria:problemCategory ex:TTCategory_TotalBreakdown ;
    noria:problemResponsibility ex:TTProblemResp_ManagedBackbone ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent ex:AppStatus_InProduction ; # Assuming a concept for TT status exists, using AppStatus_InProduction as a placeholder for "InProgress"
    noria:troubleTicketSupervisionTool "NMS" ;
    noria:troubleTicketTrigger ex:NetworkInterfaceDownEvent ;
    noria:troubleTicketRelatedParty ex:AliceAnalyst, ex:AppSupportTeam ;
    noria:troubleTicketRelatedService ex:CriticalDataService_Prod ;
    noria:troubleTicketRelatedResource ex:Router01, ex:Server05, ex:Router01_GE0_0_1, ex:Link_Router01_Server05 ;
    noria:troubleTicketImpacts ex:CriticalDataService_Prod, ex:Router01_GE0_0_1 .

# --- Trouble Ticket Notes ---
ex:TT001_Note01
    a noria:TroubleTicketNote ;
    rdfs:label "TT001 Initial Diagnosis Note"@en ;
    rdfs:comment "First note on TT001, detailing initial diagnosis steps."@en ;
    dcterms:created "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    dcterms:creator ex:AliceAnalyst ;
    dcterms:description "Confirmed interface GE0/0/1 on Router01 is down. Attempted remote bounce, no change. Suspect hardware fault."@en ;
    noria:troubleTicketNoteCommentType ex:TTCommentType_Internal ;
    noria:troubleTicketNoteOperationType ex:TTOperationType_Diagnosis .

ex:TT001_Note02
    a noria:TroubleTicketNote ;
    rdfs:label "TT001 Troubleshooting Steps Note"@en ;
    rdfs:comment "Follow-up note on TT001, detailing troubleshooting steps and correlation with operation plan."@en ;
    dcterms:created "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    dcterms:creator ex:AliceAnalyst ;
    dcterms:description "Executed 'Network Troubleshooting Plan for Core Routers'. Verified power, cabling. No immediate resolution. Escalating for hardware replacement."@en ;
    noria:troubleTicketNoteCommentType ex:TTCommentType_Internal ;
    noria:troubleTicketNoteOperationType ex:TTOperationType_Diagnosis ;
    noria:troubleTicketNoteCorrelatedExecution ex:NetworkTroubleshootingPlanExecution .

# --- Operation Plan and Conditions ---
ex:NetworkTroubleshootingPlan
    a noria:OperationPlan ;
    rdfs:label "Core Router Network Troubleshooting Plan"@en ;
    rdfs:comment "A standardized procedure for diagnosing network issues on core routers."@en ;
    noria:operationPlanPreCondition ex:CheckInterfaceStatus, ex:VerifyConnectivity ;
    noria:operationPlanPostCondition ex:ServiceRestored, ex:TrafficFlowing .

ex:CheckInterfaceStatus
    a noria:ActionPreCondition ;
    rdfs:label "Check Interface Status Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Verify the administrative and operational status of the network interface."@en .

ex:VerifyConnectivity
    a noria:ActionPreCondition ;
    rdfs:label "Verify Connectivity Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Confirm end-to-end connectivity using ping/traceroute."@en .

ex:ServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: The affected service is fully operational."@en .

ex:TrafficFlowing
    a noria:ActionPostCondition ;
    rdfs:label "Traffic Flowing Post-Condition"@en ;
    rdfs:comment "Post-condition: Network traffic is flowing as expected through the interface."@en .

ex:NetworkTroubleshootingPlanExecution
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Network Troubleshooting Plan for TT001"@en ;
    rdfs:comment "Container for the execution records of the troubleshooting plan related to TT001."@en ;
    pep:usedProcedure ex:NetworkTroubleshootingPlan .

# --- Change Request ---
ex:CR005_ReplaceNIC
    a noria:ChangeRequest ;
    rdfs:label "CR005 - Replace NIC on Router01"@en ;
    rdfs:comment "Change request to replace a faulty network interface card on Core Router 01."@en ;
    dcterms:identifier "CR-2024-04-20-005" ;
    dcterms:created "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:documentExternalId "HW-REP-R01-001" ;
    noria:documentHRef <http://changemanagement.techcorp.com/CR-2024-04-20-005> ;
    noria:changeRequestPlannedStartTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-04-20T14:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-04-20T14:55:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory ex:CRCategory_InternalIntervention ;
    noria:changeRequestType ex:CRType_Standard ;
    noria:changeRequestChangeCause ex:CRCause_HardwareReplacement ;
    noria:changeRequestOutageDuration "PT50M"^^xsd:duration ; # 50 minutes
    noria:changeRequestStatusCurrent ex:CRStatus_Approved ;
    noria:changeRequestImpact ex:Router01, ex:CriticalDataService_Prod ;
    noria:changeRequestInitiatorParty ex:AliceAnalyst ;
    noria:changeRequestPilotParty ex:AliceAnalyst ;
    noria:changeRequestActorParty ex:NetOpsTeam ;
    noria:changeRequestIsRegulated false .

# --- Event Record for Change Request ---
ex:CR005_CompletionEvent
    a noria:EventRecord ;
    rdfs:label "CR005 Completion Event"@en ;
    rdfs:comment "Event indicating the successful completion of Change Request CR005."@en ;
    dcterms:type kos-notif-event-type:StateChange ;
    noria:loggingTime "2024-04-20T14:55:00Z"^^xsd:dateTime ;
    noria:logText "Change Request CR-2024-04-20-005 completed successfully. NIC on Router01 replaced and operational."@en ;
    noria:logOriginatingManagedObject ex:Router01 ;
    noria:logOriginatingManagementSystem ex:ChangeManagementSystem ;
    noria:logOriginatingAgent ex:AliceAnalyst ;
    noria:alarmSeverity ex:NotificationSeverity_Critical . # Can be critical if it was a critical change, or informational.

ex:ChangeManagementSystem
    a noria:Application ;
    rdfs:label "Change Management System"@en ;
    rdfs:comment "An application for managing IT changes."@en ;
    noria:applicationShortIdentifier "CMS" ;
    noria:elementManagedBy ex:NetOpsTeam .

# Link the trouble ticket status history to the change completion event
ex:CriticalDataService_TT001
    noria:documentStatusHistory ex:CR005_CompletionEvent .

# Another event for interface coming back up after CR
ex:NetworkInterfaceUpEvent
    a noria:EventRecord ;
    rdfs:label "Router01 Interface Up Event"@en ;
    rdfs:comment "An event indicating that a network interface on Router01 came back up after replacement."@en ;
    dcterms:type kos-notif-event-type:StateChange ;
    noria:loggingTime "2024-04-20T14:58:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to up"@en ;
    noria:logOriginatingManagedObject ex:Router01_GE0_0_1 ;
    noria:logOriginatingManagementSystem ex:NetworkMonitoringSystem ;
    noria:alarmSeverity ex:NotificationSeverity_Critical ; # Can be informational if it's a positive change
    noria:alarmMitigatedBy ex:NetworkTroubleshootingPlanExecution . # The execution of the plan led to the fix.

# Update TT status to resolved/closed
ex:CriticalDataService_TT001
    noria:documentStatusHistory ex:NetworkInterfaceUpEvent . # This event contributes to the resolution.

# Document Attachment
ex:RouterNICReplacementReport
    a noria:DocumentAttachment ;
    rdfs:label "Router NIC Replacement Report"@en ;
    rdfs:comment "Report detailing the steps and outcome of the NIC replacement on Router01."@en ;
    dcterms:identifier "REPORT-NIC-R01-2024-04-20" ;
    dcterms:isPartOf ex:CR005_ReplaceNIC ;
    dcterms:format "application/pdf" ;
    dcterms:source <http://docs.techcorp.com/reports/NIC_R01_Replacement.pdf> .

