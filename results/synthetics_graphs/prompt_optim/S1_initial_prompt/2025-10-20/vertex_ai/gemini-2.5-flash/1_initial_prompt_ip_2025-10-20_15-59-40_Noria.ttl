# --- SKOS Concepts for Controlled Vocabularies ---
ex:AppType_Critical
    a skos:Concept ;
    skos:inScheme kos-app-type: ;
    rdfs:label "Critical Application Type"@en ;
    rdfs:comment "Represents a business-critical application type."@en .

ex:AppBizImp_High
    a skos:Concept ;
    skos:inScheme kos-app-biz-imp: ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Indicates an application with high business impact."@en .

ex:TTSeverity_Critical
    a skos:Concept ;
    skos:inScheme kos-tt-severity: ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Highest severity level for a trouble ticket."@en .

ex:TTType_Failure
    a skos:Concept ;
    skos:inScheme kos-tt-type: ;
