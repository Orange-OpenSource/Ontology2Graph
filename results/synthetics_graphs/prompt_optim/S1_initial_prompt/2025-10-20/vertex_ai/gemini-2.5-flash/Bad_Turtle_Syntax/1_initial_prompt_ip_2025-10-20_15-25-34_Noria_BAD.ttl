@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix noria: <https://w3id.org/noria/ontology/> .
@prefix ex: <http://example.com/noria-kg/> .
@base <http://example.com/noria-kg/> .

# =============================================================================
# Knowledge Graph Instances based on NORIA Ontology
# This section defines a comprehensive set of interconnected entities
# representing an IT infrastructure, its management, and operational events,
# adhering to the NORIA ontology schema.
# =============================================================================

# --- SKOS Concept Schemes and Concepts for controlled vocabularies ---
# These concepts provide the allowed values for various properties, ensuring
# data consistency and semantic clarity within the knowledge graph.

ex:ApplicationTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of applications within the IT system, enabling standardized categorization of software functionalities."@en ;
    dcterms:title "Application Type Classification"@en ;
    dcterms:description "Defines a set of standard types for applications, such as business applications, service platforms, and monitoring tools, to facilitate consistent data modeling."@en ;
    dcterms:language "en"^^xsd:string .

ex:ServicePlatform
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "Represents an application that provides a foundational platform for other services or applications, offering core functionalities that can be leveraged by multiple dependent systems."@en ;
    dcterms:title "Service Platform Type"@en ;
    dcterms:description "A type of application that provides a fundamental set of services or capabilities upon which other applications can be built or integrated."@en ;
    dcterms:language "en"^^xsd:string .

ex:BusinessApplication
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Business Application"@en ;
    rdfs:comment "Represents an application directly supporting core business functions, such as CRM, ERP, or billing systems, which are essential for the organization's operations."@en ;
    dcterms:title "Business Application Type"@en ;
    dcterms:description "Software designed to perform specific business functions, such as accounting, customer relationship management, or enterprise resource planning."@en ;
    dcterms:language "en"^^xsd:string .

ex:MonitoringTool
    a skos:Concept ;
    skos:inScheme ex:ApplicationTypeScheme ;
    rdfs:label "Monitoring Tool"@en ;
    rdfs:comment "Represents an application used for monitoring the health and performance of IT infrastructure and services, collecting metrics and generating alerts."@en ;
    dcterms:title "Monitoring Tool Type"@en ;
    dcterms:description "Software or system used to observe and track the performance, health, and availability of IT infrastructure, applications, and services."@en ;
    dcterms:language "en"^^xsd:string .

ex:ApplicationBusinessImportanceScheme
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the business importance of applications, crucial for risk assessment and incident prioritization."@en ;
    dcterms:title "Application Business Importance Classification"@en ;
    dcterms:description "Defines levels of business criticality for applications, guiding resource allocation and response strategies during operational events."@en ;
    dcterms:language "en"^^xsd:string .

ex:HighImportance
    a skos:Concept ;
    skos:inScheme ex:ApplicationBusinessImportanceScheme ;
    rdfs:label "High Importance"@en ;
    rdfs:comment "Indicates an application critical to business operations, with significant impact if unavailable, potentially leading to severe financial or reputational damage."@en ;
    dcterms:title "High Business Importance"@en ;
    dcterms:description "Indicates that the associated entity is absolutely essential for the core operations of the business, and its failure would lead to severe financial loss, legal penalties, or significant reputational damage."@en ;
    dcterms:language "en"^^xsd:string .

ex:MediumImportance
    a skos:Concept ;
    skos:inScheme ex:ApplicationBusinessImportanceScheme ;
    rdfs:label "Medium Importance"@en ;
    rdfs:comment "Indicates an application important for business operations, with moderate impact if unavailable, causing noticeable but manageable disruption."@en ;
    dcterms:title "Medium Business Importance"@en ;
    dcterms:description "Indicates that the associated entity is important for business operations, but its temporary unavailability would cause moderate disruption, which can be managed without immediate catastrophic consequences."@en ;
    dcterms:language "en"^^xsd:string .

ex:LowImportance
    a skos:Concept ;
    skos:inScheme ex:ApplicationBusinessImportanceScheme ;
    rdfs:label "Low Importance"@en ;
    rdfs:comment "Indicates an application with minor business impact if unavailable, affecting non-critical functions or a limited number of users."@en ;
    dcterms:title "Low Business Importance"@en ;
    dcterms:description "Indicates that the associated entity is not critical for immediate business operations, and its failure would have minimal or no direct impact on revenue or critical processes, though it might affect efficiency or non-essential functions."@en ;
    dcterms:language "en"^^xsd:string .

ex:TroubleTicketSeverityScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying the severity of trouble tickets, guiding response urgency and resource allocation."@en ;
    dcterms:title "Trouble Ticket Severity Classification"@en ;
    dcterms:description "Categorizes incidents based on their impact on services and users, from minor inconveniences to critical outages."@en ;
    dcterms:language "en"^^xsd:string .

ex:CriticalSeverity
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketSeverityScheme ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Indicates a severe incident causing major service disruption or outage, affecting critical business functions or a large user base, requiring immediate and top-priority resolution."@en ;
    dcterms:title "Critical Trouble Ticket Severity"@en ;
    dcterms:description "Represents an incident that causes a complete loss of service or a major business function, affecting a large number of users or critical systems, requiring immediate attention and resolution."@en ;
    dcterms:language "en"^^xsd:string .

ex:MajorSeverity
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketSeverityScheme ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Indicates a significant incident causing partial service degradation or impact to a subset of users, affecting important business functions, requiring urgent attention."@en ;
    dcterms:title "Major Trouble Ticket Severity"@en ;
    dcterms:description "Represents an incident that causes significant degradation of service or a partial loss of a business function, affecting a noticeable number of users or important systems, requiring urgent attention."@en ;
    dcterms:language "en"^^xsd:string .

ex:MinorSeverity
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketSeverityScheme ;
    rdfs:label "Minor Severity"@en ;
    rdfs:comment "Indicates a minor incident with limited impact, often a cosmetic issue or affecting a single user, with minimal disruption to business operations."@en ;
    dcterms:title "Minor Trouble Ticket Severity"@en ;
    dcterms:description "Represents an incident that causes a minor disruption or inconvenience, affecting a small number of users or a non-critical system, with limited impact on business operations."@en ;
    dcterms:language "en"^^xsd:string .

ex:TroubleTicketStatusScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for tracking the lifecycle status of trouble tickets, from creation to closure."@en ;
    dcterms:title "Trouble Ticket Status Classification"@en ;
    dcterms:description "Defines the various stages a trouble ticket progresses through, such as 'In Progress', 'Resolved', and 'Closed', to manage incident resolution workflows."@en ;
    dcterms:language "en"^^xsd:string .

ex:InProgressStatus
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketStatusScheme ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "The trouble ticket is currently being actively worked on by assigned personnel, with diagnostic or resolution steps underway."@en ;
    dcterms:title "In Progress Status"@en ;
    dcterms:description "The current state of a ticket or request where active work is being performed by assigned personnel to resolve the issue or implement the change."@en ;
    dcterms:language "en"^^xsd:string .

ex:ResolvedStatus
    a skos:Concept ;
    skos:inScheme ex:TroubleTicketStatusScheme ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "The issue described in the trouble ticket has been fixed, and a solution has been implemented, pending verification and final closure by the user or a designated team."@en ;
    dcterms:title "Resolved Status"@en ;
    dcterms:description "The state of a ticket or request where the underlying issue has been fixed or the change has been implemented, and it is awaiting verification or closure by the