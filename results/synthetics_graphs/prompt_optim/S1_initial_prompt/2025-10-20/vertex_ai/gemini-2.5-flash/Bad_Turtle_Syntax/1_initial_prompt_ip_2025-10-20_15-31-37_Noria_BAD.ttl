# =============================================================================
# Procedural Elements (Operation Plans, Pre/Post Conditions)
# =============================================================================

ex:Network_Troubleshooting_Plan
    a noria:OperationPlan ;
    rdfs:label "Network Link Troubleshooting Plan"@en ;
    rdfs:comment "A standardized procedure for diagnosing and resolving network link failures."@en ;
    noria:operationPlanPreCondition ex:Link_Down_PreCondition ;
    noria:operationPlanPostCondition ex:Link_Up_PostCondition ;
    .

ex:Link_Down_PreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Network Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en ;
    .

ex:Link_Up_PostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Network Link Up Post-Condition"@en ;
    rdfs:comment "Expected outcome: The network interface's operational status is 'up' and connectivity is restored."@en ;
    .

ex:App_Restart_Plan
    a noria:OperationPlan ;
    rdfs:label "Application Restart Procedure"@en ;
    rdfs:comment "A procedure for restarting an unresponsive application module."@en ;
    noria:operationPlanPreCondition ex:App_Unresponsive_PreCondition ;
    noria:operationPlanPostCondition ex:App_Responsive_PostCondition ;
    .

ex:App_Unresponsive_PreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Application Unresponsive Pre-Condition"@en ;
    rdfs:comment "Condition: The application module is not responding to health checks or user requests."@en ;
    .

ex:App_Responsive_PostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Application Responsive Post-Condition"@en ;
    rdfs:comment "Expected outcome: The application module is responding to health checks and user requests."@en ;
    .

