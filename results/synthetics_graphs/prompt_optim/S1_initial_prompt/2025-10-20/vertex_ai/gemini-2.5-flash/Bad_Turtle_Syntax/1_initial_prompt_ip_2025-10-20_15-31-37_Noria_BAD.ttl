# =============================================================================
# Organizational Units and Agents (Teams/Persons)
# =============================================================================

ex:TechCorp
    a org:Organization ;
    rdfs:label "TechCorp Inc."@en ;
    rdfs:comment "The main organization for which the IT infrastructure is managed."@en ;
    org:hasUnit ex:NOC_Team, ex:AppSupport_Team, ex:Infra_Team, ex:SOC_Team ;
    .

ex:NOC_Team
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center Team"@en ;
    rdfs:comment "Team responsible for monitoring and managing network infrastructure."@en ;
    org:unitOf ex:TechCorp ;
    org:hasMember ex:John_Doe ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod ex:NOC_Team_Contact_Method_Phone ;
    noria:agentInstructions "For critical network issues, call the hotline immediately. For non-critical, use ticketing system."@en ;
    .

ex:AppSupport_Team
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting and maintaining business applications."@en ;
    org:unitOf ex:TechCorp ;
    org:hasMember ex:Jane_Smith ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod ex:AppSupport_Team_Contact_Method_Email ;
    noria:agentInstructions "Submit a ticket via the internal portal for all application-related queries."@en ;
    .

ex:Infra_Team
    a org:OrganizationalUnit ;
    rdfs:label "Infrastructure Team"@en ;
    rdfs:comment "Team responsible for physical and virtual server infrastructure."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod ex:Infra_Team_Contact_Method_Ticketing ;
    .

ex:SOC_Team
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center Team"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    org:unitOf ex:TechCorp ;
    noria:agentWorkingHours "24/7 Monitoring"@en ;
    noria:agentPreferredContactMethod ex:SOC_Team_Contact_Method_Alerting ;
    .

ex:John_Doe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A network engineer in the NOC Team."@en ;
    org:memberOf ex:NOC_Team ;
    foaf:holdsAccount ex:John_Doe_CUid ;
    .

ex:Jane_Smith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An application specialist in the Application Support Team."@en ;
    org:memberOf ex:AppSupport_Team ;
    foaf:holdsAccount ex:Jane_Smith_CUid ;
    .

ex:John_Doe_CUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "The corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe"@en ;
    observable:accountLogin "jdoe"@en ;
    observable:accountIdentifier "jdoe-techcorp-12345"@en ;
    .

ex:Jane_Smith_CUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "The corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"@en ;
    observable:accountLogin "jsmith"@en ;
    observable:accountIdentifier "jsmith-techcorp-67890"@en ;
    .

ex:NOC_Team_Contact_Method_Phone
    a skos:Concept ;
    rdfs:label "Phone Contact"@en ;
    rdfs:comment "Preferred contact method for NOC team: Phone."@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
    .

ex:AppSupport_Team_Contact_Method_Email
    a skos:Concept ;
    rdfs:label "Email Contact"@en ;
    rdfs:comment "Preferred contact method for Application Support team: Email."@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
    .

ex:Infra_Team_Contact_Method_Ticketing
    a skos:Concept ;
    rdfs:label "Ticketing System"@en ;
    rdfs:comment "Preferred contact method for Infrastructure team: Ticketing System."@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
    .

ex:SOC_Team_Contact_Method_Alerting
    a skos:Concept ;
    rdfs:label "Automated Alerting System"@en ;
    rdfs:comment "Preferred contact method for SOC team: Automated Alerting System."@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
    .

# =============================================================================
# Locations
# =============================================================================

ex:Main_Data_Center
    a bot:Site ;
    rdfs:label "TechCorp Main Data Center"@en ;
    rdfs:comment "The primary data center facility for TechCorp."@en ;
    noria:siteId "DC-MAIN-01"@en ;
    noria:siteType "data center"@en ;
    noria:sitePrincipalAddress "123 TechCorp Avenue"@en ;
    noria:sitePrincipalAddressCityName "Metropolis"@en ;
    noria:sitePrincipalAddressPostalCode "10001"@en ;
    noria:sitePrincipalAddressCountry "US"@en ;
    bot:containsZone ex:Server_Room_A ;
    .

ex:Server_Room_A
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Main Data Center."@en ;
    bot:hasSubSpace ex:Rack_1, ex:Rack_2 ;
    .

ex:Rack_1
    a noria:Locus ;
    rdfs:label "Rack 1 in Server Room A"@en ;
    rdfs:comment "A specific rack location within Server Room A."@en ;
    noria:locusLine "A"@en ;
    noria:locusRow "1"@en ;
    .

ex:Rack_2
    a noria:Locus ;
    rdfs:label "Rack 2 in Server Room A"@en ;
    rdfs:comment "Another specific rack location within Server Room A."@en ;
    noria:locusLine "B"@en ;
    noria:locusRow "2"@en ;
    .

