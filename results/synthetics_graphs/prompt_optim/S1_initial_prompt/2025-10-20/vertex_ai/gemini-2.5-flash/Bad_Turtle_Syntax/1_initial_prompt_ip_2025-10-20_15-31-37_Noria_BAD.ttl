ex:TT_Network_Outage_20231026
    a noria:TroubleTicket ;
    rdfs:label "Trouble Ticket: Network Outage - Web Portal Impact"@en ;
    rdfs:comment "Trouble ticket created due to the network link failure impacting the Web Portal service."@en ;
    dcterms:identifier "TT-20231026-001"@en ;
    dcterms:created "2023-10-26T09:05:00Z"^^xsd:dateTime ;
    noria:documentExternalId "CUST-INC-9876"@en ;
    noria:documentHRef "http://ticketing.example.com/TT-20231026-001"@en ;
    noria:troubleTicketSeverity ex:Major_TroubleTicketSeverity ;
    noria:troubleTicketType ex:Failure_TroubleTicketType ;
    noria:troubleTicketCriticity ex:InterruptedService_Criticity ;
    noria:troubleTicketPriority ex:P1_Priority ;
    noria:troubleTicketOrigin ex:Supervision_Origin ;
    noria:troubleTicketTrigger ex:Event_Link_Down_Router_Core_01 ;
    noria:troubleTicketUrgency ex:ImmediateIntervention_Urgency ;
    noria:troubleTicketSupervisionTool "NMS_System"@en ;
    noria:troubleTicketCategory ex:TotalBreakdown_TroubleCategory ;
    noria:troubleTicketCause "Physical fiber cut affecting link between core router and app server."@en ;
    noria:problemResponsibility ex:ManagedBackbone_Responsibility ;
    noria:troubleTicketDetectionDateTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
