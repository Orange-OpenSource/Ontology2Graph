    noria:loggingTime "2023-10-26T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject ex:Router_Core_01 ;
    noria:logOriginatingManagementSystem ex:NMS_System ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"@en ;
    noria:alarmSeverity ex:Critical_AlarmSeverity ;
    dcterms:type ex:StateChange_EventType ;
    .

