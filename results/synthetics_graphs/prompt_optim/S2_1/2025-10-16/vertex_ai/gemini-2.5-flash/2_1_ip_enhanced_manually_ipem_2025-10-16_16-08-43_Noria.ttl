    skos:prefLabel "Customer Facing Service"@en ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:comment "A service directly consumed by external customers."@en .

<kos/service/type/InternalService>
    a skos:Concept ;
    skos:prefLabel "Internal Service"@en ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:comment "A service used internally by the organization."@en .

<kos/TroubleTicket/severity/Critical>
