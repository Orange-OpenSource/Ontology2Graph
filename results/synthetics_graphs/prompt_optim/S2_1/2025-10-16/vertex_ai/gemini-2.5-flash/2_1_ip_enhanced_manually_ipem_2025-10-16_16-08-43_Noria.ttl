    noria:applicationModelIdentifier "CP-V2.1"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CPORTAL"^^xsd:string ;
    noria:applicationType <kos/application/type/WebApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Online Self-Service"^^xsd:string ;
    noria:elementManagedBy noria:org_CoreServicesDivision .

noria:app_NetworkMonitor
    a noria:Application ;
    rdfs:label "Network Monitoring Application"@en ;
    rdfs:comment "Application used for real-time monitoring of network devices and services."@en ;
    noria:functionalElementDistinguishedName "NetworkMonitor-APP"^^xsd:string ;
    noria:applicationModelIdentifier "NMON-V3.0"^^xsd:string ;
    noria:applicationNumericalIdentifier "2002"^^xsd:int ;
    noria:applicationShortIdentifier "NMON"^^xsd:string ;
    noria:applicationType <kos/application/type/MonitoringSystem> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "IT Operations Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Network Performance Monitoring"^^xsd:string ;
    noria:elementManagedBy noria:org_NetworkOperationsTeam .

