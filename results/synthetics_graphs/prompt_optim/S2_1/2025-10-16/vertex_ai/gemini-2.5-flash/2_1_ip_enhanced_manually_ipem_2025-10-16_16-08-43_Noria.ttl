# --- foaf:Agent and org:OrganizationalUnit Instances ---
noria:agent_AliceJohnson
    a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "An employee responsible for network operations."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via corporate chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:agent_BobWilliams
    a foaf:Person ;
    rdfs:label "Bob Williams"@en ;
    rdfs:comment "An employee leading the application support team."@en ;
    noria:agentWorkingHours "10:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:org_NetworkOperationsTeam
