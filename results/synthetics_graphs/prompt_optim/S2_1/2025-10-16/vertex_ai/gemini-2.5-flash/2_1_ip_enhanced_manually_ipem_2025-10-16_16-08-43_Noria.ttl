    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "Follow escalation matrix for critical incidents."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

noria:org_ApplicationSupportL2
    a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support team for critical applications."@en ;
    noria:agentWorkingHours "08:00-20:00 (Mon-Sun)"^^xsd:string ;
    noria:agentInstructions "All issues must be logged in Jira."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:org_CoreServicesDivision
    a org:OrganizationalUnit ;
    rdfs:label "Core Services Division"@en ;
    rdfs:comment "Division overseeing essential IT services."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Strategic planning and oversight."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:org_ManufacturerX
    a org:Organization ;
    rdfs:label "Manufacturer X Inc."@en ;
    rdfs:comment "A company that manufactures network equipment."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact sales for new orders, support for existing products."^^xsd:string ;
