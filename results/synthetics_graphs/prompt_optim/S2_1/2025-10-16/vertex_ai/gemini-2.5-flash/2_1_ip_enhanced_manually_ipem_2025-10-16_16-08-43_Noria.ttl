    noria:troubleTicketTargetRestorationDateTime "2024-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-15T10:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-03-15T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:agent_BobWilliams ;
