# --- SKOS Concepts for controlled vocabularies ---
<kos/application/type/WebApplication>
    a skos:Concept ;
    skos:prefLabel "Web Application"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:comment "A software application that runs on a web server and is accessed by users through a web browser."@en .

<kos/application/type/MonitoringSystem>
    a skos:Concept ;
    skos:prefLabel "Monitoring System"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:comment "A system designed to observe and record the state of other systems or networks."@en .

<kos/application/business-importance/High>
    a skos:Concept ;
    skos:prefLabel "High Business Importance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:comment "Indicates a critical application with significant business impact."@en .

<kos/application/business-importance/Medium>
    a skos:Concept ;
    skos:prefLabel "Medium Business Importance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:comment "Indicates an important application with moderate business impact."@en .

<kos/application/sla-level/Gold>
    a skos:Concept ;
    skos:prefLabel "Gold SLA Level"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:comment "Highest Service Level Agreement, typically 24/7 support with minimal downtime."@en .

<kos/application/status/InProduction>
    a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:comment "The application module is currently live and serving users."@en .

<kos/service/type/CustomerFacingService>
