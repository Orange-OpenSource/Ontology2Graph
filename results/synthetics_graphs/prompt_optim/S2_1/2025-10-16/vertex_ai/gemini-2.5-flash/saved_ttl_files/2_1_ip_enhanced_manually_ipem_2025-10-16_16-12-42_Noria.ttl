<agent/JohnDoe>
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee responsible for network operations."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string .

<agent/JaneSmith>
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An employee leading the application support team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always use the ticketing system first."^^xsd:string .

<org/NetworkOperationsTeam>
