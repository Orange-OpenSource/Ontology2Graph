    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for optimizing slow database queries."@en ;
    noria:operationPlanPreCondition <actionprecondition/SlowQueries> ;
    noria:operationPlanPostCondition <actionpostcondition/ImprovedPerformance> .

# --- Action Pre/Post Condition Entities ---

<actionprecondition/InterfaceDown>
    a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down"@en ;
    rdfs:comment "Pre-condition: a network interface is in a 'down' operational state."@en .

<actionpostcondition/InterfaceUp>
    a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up"@en ;
    rdfs:comment "Post-condition: the network interface is in an 'up' operational state."@en .

<actionprecondition/SlowQueries>
    a noria:ActionPreCondition ;
    rdfs:label "Slow Database Queries Detected"@en ;
    rdfs:comment "Pre-condition: database monitoring reports slow query execution times."@en .

<actionpostcondition/ImprovedPerformance>
    a noria:ActionPostCondition ;
    rdfs:label "Improved Application Performance"@en ;
    rdfs:comment "Post-condition: application response times have improved after intervention."@en .

# --- Object Property Usage (ensuring all are used) ---

# noria:elementManagedBy - used by Application, Resource, Service
# noria:structuralElementObservable - used by networkInterfaceAdministrativeStatus, networkInterfaceOperationalStatus, virtualServerStatus
# noria:structuralObservableOf - inverse of structuralElementObservable, not directly used as a property of an instance, but implied by the inverse. Let's create an explicit usage.
<observable/Router01Status>
    a noria:StructuralObservable ;
    rdfs:label "Router01 Status Observable"@en ;
    rdfs:comment "An observable property for Router01's operational status."@en ;
    noria:structuralObservableOf <resource/Router01> .

# noria:eventRelatedElement - used by troubleTicketRelatedService, troubleTicketRelatedResource, changeRequestImpact, logOriginatingManagedObject, logOriginatingManagementSystem
# noria:eventRelatedParty - used by troubleTicketRelatedParty, logOriginatingAgent
# noria:agentPreferredContactMethod - used by JohnDoe, JaneSmith, NetworkOperationsTeam, ApplicationSupportTeam
# noria:applicationType - used by CustomerPortal, CoreNetworkService
# noria:applicationBusinessImportance - used by CustomerPortal, CoreNetworkService
# noria:applicationModuleOf - used by CustomerPortal-Prod, CustomerPortal-Dev
# noria:applicationModuleAdministrationTeam - used by CustomerPortal-Prod, CustomerPortal-Dev
# noria:applicationModuleAdministrationLeader - used by CustomerPortal-Prod, CustomerPortal-Dev
# noria:applicationModuleSupportTeam - used by CustomerPortal-Prod
# noria:applicationModuleSupportLeader - used by CustomerPortal-Prod
# noria:applicationModuleSupportGroup - used by CustomerPortal-Prod
# noria:applicationModuleHotlineGroup - used by CustomerPortal-Prod
# noria:applicationModuleSlaLevel - used by CustomerPortal-Prod, CustomerPortal-Dev
# noria:applicationModuleStatus - used by CustomerPortal-Prod, CustomerPortal-Dev
# noria:serviceType - used by ECommerceService, InternalMonitoringService
# noria:documentStatusHistory - used by TT-20240420-001, CR-20240425-001
# noria:troubleTicketSeverity - used by TT-20240420-001, TT-20240420-002
# noria:troubleTicketType - used by TT-20240420-001, TT-20240420-002
# noria:troubleTicketCriticity - used by TT-20240420-001, TT-20240420-002
# noria:troubleTicketPriority - used by TT-20240420-001, TT-20240420-002
# noria:troubleTicketOrigin - used by TT-20240420-001, TT-20240420-002
# noria:troubleTicketTrigger - used by TT-20240420-001
# noria:troubleTicketUrgency - used by TT-20240420-001, TT-20240420-002
# noria:troubleTicketCategory - used by TT-20240420-001
# noria:problemCategory - used by TT-20240420-001
# noria:problemResponsibility - used by TT-20240420-001, TT-20240420-002
