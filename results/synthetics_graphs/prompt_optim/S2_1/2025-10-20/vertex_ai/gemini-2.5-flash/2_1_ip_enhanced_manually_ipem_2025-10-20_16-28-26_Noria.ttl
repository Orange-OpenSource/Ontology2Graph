# --- Event Records ---
noria:Event_ServerDown
    a noria:EventRecord, BBO:DocumentResource, pep:ProcedureExecution, observable:EventRecord, log:Event ;
    rdfs:label "Server Down Alert"@en ;
    rdfs:comment "An event indicating that Application Server 01 is down."@en ;
    noria:loggingTime "2024-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: appserver01.prod.local is unreachable."^^xsd:string ;
    noria:logOriginatingManagedObject noria:Resource_Server01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OP_ServerRestart .

