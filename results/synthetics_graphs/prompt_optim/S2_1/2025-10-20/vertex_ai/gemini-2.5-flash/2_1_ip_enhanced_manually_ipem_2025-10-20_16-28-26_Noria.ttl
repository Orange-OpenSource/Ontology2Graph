# --- Change Requests ---
noria:CR_20240315_001
    a noria:ChangeRequest, BBO:DocumentResource, pep:ProcedureExecutionContainer ;
    rdfs:label "Router Firmware Upgrade"@en ;
    rdfs:comment "Change request to upgrade firmware on Core Router 01."@en ;
    noria:documentExternalId "CR-NET-001"^^xsd:string ;
    noria:documentHRef "https://changemgmt.example.com/CR_20240315_001"^^xsd:anyURI ;
    noria:changeRequestPlannedStartTime "2024-03-20T01:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-03-20T03:00:00Z"^^xsd:dateTime ;
    noria:changeRequestActualStartTime "2024-03-20T01:05:00Z"^^xsd:dateTime ;
    noria:changeRequestActualEndTime "2024-03-20T02:30:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/Maintenance> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:Resource_Router01 ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ;
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/StandardProcedure> ;
    noria:changeRequestInitiatorParty noria:Agent_JohnDoe ;
    noria:changeRequestPilotParty noria:Agent_ITSupportTeam ;
    noria:changeRequestActorParty noria:Agent_JohnDoe ;
    noria:changeRequestIsRegulated "false"^^xsd:boolean ;
    noria:documentStatusHistory noria:Event_LoginFailed . # Reusing an event for status history example

# --- Document Attachments ---
noria:Doc_CR_Plan_001
    a noria:DocumentAttachment, BBO:DocumentResource ;
    rdfs:label "CR-NET-001 Implementation Plan"@en ;
    rdfs:comment "Detailed plan for the router firmware upgrade."@en ;
    dcterms:isPartOf noria:CR_20240315_001 ;
    dcterms:format "application/pdf"^^xsd:string ;
    dcterms:title "Firmware Upgrade Plan v1.0"^^xsd:string .

# --- Anomaly Patterns ---
noria:AP_HighCPU_LowMem
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "High CPU Low Memory Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating high CPU usage combined with low available memory, often a precursor to service degradation."@en .

# --- Operation Plans ---
noria:OP_ServerRestart
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Server Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a server."@en ;
    noria:operationPlanPreCondition noria:APC_ServiceOffline ;
    noria:operationPlanPostCondition noria:APOC_ServiceRestored .

noria:OP_NetworkFailover
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Network Failover Procedure"@en ;
    rdfs:comment "Procedure to activate network failover in case of primary link failure."@en ;
    noria:operationPlanPreCondition noria:APC_BackupComplete ;
    noria:operationPlanPostCondition noria:APOC_TrafficRerouted .

# --- Action Pre-Conditions ---
noria:APC_ServiceOffline
    a noria:ActionPreCondition ;
    rdfs:label "Service Offline Pre-Condition"@en ;
    rdfs:comment "Pre-condition: The affected service must be taken offline before proceeding."@en .

noria:APC_BackupComplete
    a noria:ActionPreCondition ;
    rdfs:label "Backup Complete Pre-Condition"@en ;
    rdfs:comment "Pre-condition: A full backup of the system must be completed."@en .

# --- Action Post-Conditions ---
noria:APOC_ServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: The service is fully restored and operational."@en .

noria:APOC_TrafficRerouted
    a noria:ActionPostCondition ;
    rdfs:label "Traffic Rerouted Post-Condition"@en ;
    rdfs:comment "Post-condition: Network traffic has been successfully rerouted to the secondary path."@en .

# --- Linking Operations to Procedures ---
noria:CorrectiveAction_ServerRestart
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Server Restart"@en ;
    rdfs:comment "A specific execution instance of the server restart procedure."@en ;
    noria:actionCorrelatedOperationPlan noria:OP_ServerRestart .

noria:ChangeAction_FirmwareUpgrade
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Execution of Firmware Upgrade"@en ;
    rdfs:comment "A specific execution instance of the firmware upgrade procedure."@en ;
    noria:actionCorrelatedOperationPlan noria:OP_NetworkFailover . # Example, linking to a different OP for variety
