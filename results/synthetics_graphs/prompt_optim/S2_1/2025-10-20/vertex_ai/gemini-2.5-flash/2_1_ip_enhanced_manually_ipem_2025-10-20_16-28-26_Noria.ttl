# --- Agents and Organizations ---
noria:Agent_JohnDoe
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee responsible for IT operations."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:Agent_ITSupportTeam
    a foaf:Group, foaf:Agent ;
    rdfs:label "IT Support Team"@en ;
    rdfs:comment "The primary IT support group for all applications."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

noria:OrgUnit_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Organizational unit responsible for network infrastructure."@en .

noria:OrgUnit_AppDev
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Unit"@en ;
    rdfs:comment "Organizational unit responsible for application development and maintenance."@en .

noria:Org_ManufacturerX
    a org:Organization ;
    rdfs:label "Manufacturer X Inc."@en ;
    rdfs:comment "A leading manufacturer of network equipment."@en .

