    noria:logText "Login failed for user 'guest' from IP 1.2.3.4"^^xsd:string ;
    noria:logOriginatingManagedObject noria:Resource_Server01 ;
    noria:logOriginatingManagementSystem noria:App_Monitoring ;
    noria:logOriginatingAgent noria:Agent_JohnDoe . # Example of an agent being the source of an action (even if failed)

# --- Trouble Tickets ---
noria:TT_20240315_001
    a noria:TroubleTicket, pep:ProcedureExecutionContainer, BBO:DocumentResource ;
    rdfs:label "CRM Production Outage"@en ;
    rdfs:comment "Trouble ticket for a major outage affecting the CRM production module."@en ;
    noria:documentExternalId "CUST-INC-001"^^xsd:string ;
    noria:documentHRef "https://ticketing.example.com/TT_20240315_001"^^xsd:anyURI ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/ServiceInterruption> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:Event_ServerDown ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/Immediate> ;
    noria:troubleTicketSupervisionTool "NMS-Alerts"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/category/ServiceInterruption> ;
    noria:problemCategory <kos/TroubleTicket/category/ServiceInterruption> ;
    noria:troubleTicketCause "Unexpected server shutdown due to power fluctuation."^^xsd:string ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/NetworkTeam> ;
    noria:troubleTicketDetectionDateTime "2024-03-15T10:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-15T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-15T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-03-15T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Agent_ITSupportTeam ;
    noria:troubleTicketPartyIntervention noria:Event_ServerDown ; # Linking to an event as an intervention record
    noria:troubleTicketRelatedService noria:Service_CustomerPortal ;
    noria:troubleTicketRelatedResource noria:Resource_Server01 ;
    noria:troubleTicketImpacts noria:AppMod_CRM_Prod ;
    noria:troubleTicketCharacteristic [
        a skos:Concept ;
        rdfs:label "High Impact"^^xsd:string ;
        rdfs:comment "Characteristic: High Impact on business operations."^^xsd:string
    ] ;
    noria:troubleTicketFreezeItem noria:Event_ServerDown ; # Example of an event marking a freeze item
    noria:documentStatusHistory noria:Event_ServerDown .

