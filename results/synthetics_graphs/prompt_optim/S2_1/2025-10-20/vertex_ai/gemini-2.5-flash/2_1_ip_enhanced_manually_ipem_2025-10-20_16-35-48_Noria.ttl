.

# Resources
<resource/router_core_01> a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router in the Paris Data Center."@en ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceHostName "core-rtr-01.example.com"^^xsd:string ;
    noria:resourceProductModel <productmodel/cisco_asr9k> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "ABC12345DEF"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/network_ops_team> ;
    noria:locatedAtLocus <locus/rack_b5_u2> ;
    noria:resourceManagementIPAddress observable:ipAddress_10_0_0_1 ;
.

<resource/server_app_01> a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting critical application components."@en ;
    noria:resourceLogisticId "LOG-SRV-001"^^xsd:string ;
    noria:resourceHostName "app-srv-01.example.com"^^xsd:string ;
    noria:resourceProductModel <productmodel/hp_proliant_dl380> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "GHI67890JKL"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2023-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/app_support_team> ;
    noria:locatedAtLocus <locus/rack_a1_u10> ;
    noria:resourceManagementIPAddress observable:ipAddress_10_0_0_2 ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> ;
.

<resource/cluster_controller_01> a noria:Resource ;
    rdfs:label "Cluster Controller 01"@en ;
    rdfs:comment "Controller for the server cluster."@en ;
    noria:resourceHostName "cluster-ctrl-01.example.com"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy <org/app_support_team> ;
.

<resource/virtual_machine_db> a noria:Resource ;
    rdfs:label "Database VM"@en ;
    rdfs:comment "Virtual machine hosting the application database."@en ;
    noria:resourceHostName "db-vm-01.example.com"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceManagedBy <org/app_support_team> ;
    noria:clusterController <resource/cluster_controller_01> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> ;
.

observable:ipAddress_10_0_0_1 a observable:IPAddress ;
    rdfs:label "IP Address 10.0.0.1"@en ;
    observable:addressValue "10.0.0.1"^^xsd:string ;
.

observable:ipAddress_10_0_0_2 a observable:IPAddress ;
    rdfs:label "IP Address 10.0.0.2"@en ;
    observable:addressValue "10.0.0.2"^^xsd:string ;
.

