# Explicit inverse property usage for noria:structuralObservableOf
<kos/Resource/OperationalState/Up> noria:structuralObservableOf <resource/server_app_01> ;
    rdfs:label "Operational State Up of Application Server 01"@en ;
    rdfs:comment "Indicates that Application Server 01 is currently operational."@en ;
.
<kos/Resource/OperationalState/Up> noria:structuralObservableOf <networkinterface/srv01_eth0> ;
    rdfs:label "Operational State Up of app-srv-01 Ethernet0"@en ;
    rdfs:comment "Indicates that app-srv-01 Ethernet0 is currently operational."@en ;
.

# Adding usage for noria:actionCorrelatedOperationPlan
<pep/corrective_action_fiber_fix> a pep:ProcedureExecution ;
    rdfs:label "Corrective Action: Fiber Fix"@en ;
    rdfs:comment "Execution of a corrective action to fix the fiber link issue."@en ;
    noria:actionCorrelatedOperationPlan <operationplan/interface_troubleshooting> ;
    pep:hasInput <actionprecondition/interface_down_detected> ;
    pep:hasOutput <actionpostcondition/interface_restored> ;
.

# Explicit inverse property usage for noria:agentManagesResource
<org/network_ops_team> noria:agentManagesResource <resource/router_core_01> ;
    noria:agentManagesResource <resource/isp_router_a> ;
    noria:agentManagesResource <application/monitoring_system> ;
    noria:agentManagesResource <service/internal_monitoring> ;
.

<org/app_support_team> noria:agentManagesResource <resource/server_app_01> ;
    noria:agentManagesResource <resource/cluster_controller_01> ;
    noria:agentManagesResource <resource/virtual_machine_db> ;
    noria:agentManagesResource <application/web_portal> ;
    noria:agentManagesResource <applicationmodule/web_portal_prod> ;
    noria:agentManagesResource <applicationmodule/web_portal_dev> ;
.

# Adding usage for noria:alarmMitigatedBy
<pep/procedure_exec_container_fiber_fix> a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution Container for Fiber Fix"@en ;
    rdfs:comment "Container for all actions and events related to fixing the fiber link."@en ;
    pep:hasProcedure <operationplan/interface_troubleshooting> ;
    pep:member <pep/corrective_action_fiber_fix> ;
.
