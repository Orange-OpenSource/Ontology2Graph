# Procedural Elements
<operationplan/interface_troubleshooting> a noria:OperationPlan ;
    rdfs:label "Network Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving network interface issues."@en ;
    noria:operationPlanPreCondition <actionprecondition/interface_down_detected> ;
    noria:operationPlanPostCondition <actionpostcondition/interface_restored> ;
.

<actionprecondition/interface_down_detected> a noria:ActionPreCondition ;
    rdfs:label "Interface Down Detected"@en ;
    rdfs:comment "Condition: A network interface's operational status is 'down'."@en ;
.

<actionpostcondition/interface_restored> a noria:ActionPostCondition ;
    rdfs:label "Interface Operational Status Up"@en ;
    rdfs:comment "Outcome: The network interface's operational status is 'up' and traffic is flowing."@en ;
.

<anomalypattern/repeated_db_failures> a noria:AnomalyPattern ;
    rdfs:label "Repeated Database Connection Failures"@en ;
    rdfs:comment "Anomaly pattern indicating a series of database connection errors, potentially leading to service degradation."@en ;
    folio:hasCause <eventrecord/app_error_log> ;
.

