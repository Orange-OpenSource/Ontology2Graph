# Event Records
<eventrecord/router_interface_down> a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Core Router 01."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."^^xsd:string ;
    noria:logOriginatingManagedObject <resource/router_core_01> ;
    noria:logOriginatingManagementSystem <application/monitoring_system> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <operationplan/interface_troubleshooting> ;
    noria:alarmMitigatedBy <pep/procedure_exec_container_fiber_fix> ;
.

<eventrecord/app_error_log> a noria:EventRecord ;
    rdfs:label "Application Error Log"@en ;
