# Agents and Organizations
<agent/john_doe> a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An employee responsible for network operations."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    foaf:mbox "john.doe@example.com"^^xsd:anyURI ;
    foaf:phone "+1-555-123-4567"^^xsd:string ;
.

<agent/jane_smith> a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A senior application support engineer."@en ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Call directly for critical application issues."^^xsd:string ;
    foaf:mbox "jane.smith@example.com"^^xsd:anyURI ;
    foaf:phone "+1-555-987-6543"^^xsd:string ;
.

<org/network_ops_team> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Use ticketing system for all requests, call hotline for emergencies."^^xsd:string ;
    org:hasMember <agent/john_doe> ;
.

<org/app_support_team> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing level 2 support for critical applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the portal for all support requests."^^xsd:string ;
    org:hasMember <agent/jane_smith> ;
.

<org/it_department> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "Overall IT department responsible for all IT services."@en ;
    noria:agentWorkingHours "General Business Hours"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via internal service desk."^^xsd:string ;
    org:hasUnit <org/network_ops_team> ;
    org:hasUnit <org/app_support_team> ;
.

# Corporate User Identifiers
<cuid/jdoe_corp> a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Unique corporate identifier for John Doe."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    foaf:holdsAccount <agent/john_doe> ;
.

<cuid/jsmith_corp> a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Unique corporate identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    foaf:holdsAccount <agent/jane_smith> ;
.

# Location Entities
<site/datacenter_paris> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Republique"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Republique"^^xsd:string ;
    wgs84_pos:lat "48.8566"^^xsd:float ;
    wgs84_pos:long "2.3522"^^xsd:float ;
.

<room/server_room_a> a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Primary server room in Paris Data Center."@en ;
    bot:hasSpace <site/datacenter_paris> ;
.

<room/network_room_b> a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "Network equipment room in Paris Data Center."@en ;
    bot:hasSpace <site/datacenter_paris> ;
.

<locus/rack_a1_u10> a noria:Locus ;
    rdfs:label "Rack A1, Unit 10"@en ;
    rdfs:comment "Specific location for a server in Server Room A."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "10"^^xsd:string ;
    bot:hasSpace <room/server_room_a> ;
.

<locus/rack_b5_u2> a noria:Locus ;
    rdfs:label "Rack B5, Unit 2"@en ;
    rdfs:comment "Specific location for a router in Network Room B."@en ;
    noria:locusLine "B5"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:hasSpace <room/network_room_b> ;
.

<locus/rack_a1_u11> a noria:Locus ;
    rdfs:label "Rack A1, Unit 11"@en ;
    rdfs:comment "Specific location for a database server in Server Room A."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "11"^^xsd:string ;
    bot:hasSpace <room/server_room_a> ;
.

<locus/rack_b5_u3> a noria:Locus ;
    rdfs:label "Rack B5, Unit 3"@en ;
    rdfs:comment "Specific location for an edge router in Network Room B."@en ;
    noria:locusLine "B5"^^xsd:string ;
    noria:locusRow "3"^^xsd:string ;
    bot:hasSpace <room/network_room_b> ;
.

# Product Models
<productmodel/cisco_asr9k> a noria:ProductModel ;
