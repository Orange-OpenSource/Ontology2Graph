    noria:logOriginatingManagementSystem <application/monitoring_system> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent <agent/jane_smith> ;
.

<eventrecord/security_alert> a noria:EventRecord ;
