# Synthetic Knowledge Graph based on Noria Ontology

# --- Agents and Organizations ---

noria:person_AliceJohnson
    a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "An employee responsible for network operations."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    noria:agentManagesResource noria:resource_CoreRouter01, noria:resource_Firewall01 ;
.

noria:person_BobWilliams
    a foaf:Person ;
    rdfs:label "Bob Williams"@en ;
    rdfs:comment "A lead developer for the customer portal application."@en ;
    foaf:mbox <mailto:bob.williams@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "10:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for quick questions, ticketing system for bugs."^^xsd:string ;
    noria:agentManagesResource noria:appMod_CustomerPortal_Prod ;
.

noria:orgUnit_NOC
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Center"@en ;
    rdfs:comment "The team responsible for 24/7 network monitoring and initial incident response."@en ;
    org:unitOf noria:org_GlobalISP ;
    noria:agentWorkingHours "24/7 Shift-based"^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Follow escalation matrix for critical incidents."^^xsd:string ;
    noria:agentManagesResource noria:resource_CoreRouter01, noria:nl_DC1_DC2_Fiber ;
.

noria:orgUnit_AppSupportL2
    a org:OrganizationalUnit ;
    rdfs:label "Application Support L2"@en ;
    rdfs:comment "Second-level support team for critical business applications."@en ;
    org:unitOf noria:org_GlobalISP ;
    noria:agentWorkingHours "08:00-20:00 (Mon-Sun)"^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All issues must be logged in the ticketing system."^^xsd:string ;
    noria:agentManagesResource noria:appMod_CustomerPortal_Prod ;
.

noria:org_GlobalISP
    a org:Organization ;
    rdfs:label "Global ISP Corp."@en ;
    rdfs:comment "A global internet service provider."@en ;
    org:hasUnit noria:orgUnit_NOC, noria:orgUnit_AppSupportL2 ;
    org:hasMember noria:person_AliceJohnson, noria:person_BobWilliams ;
.

noria:cuid_ajohnson
    a noria:CorporateUserIdentifier, observable:UserAccount ;
    rdfs:label "Alice Johnson's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Johnson within the organization's IT systems."@en ;
    foaf:accountName "ajohnson"^^xsd:string ;
    observable:accountLogin "ajohnson"^^xsd:string ;
    observable:accountIdentifier "CUID-AJ-001"^^xsd:string ;
.

