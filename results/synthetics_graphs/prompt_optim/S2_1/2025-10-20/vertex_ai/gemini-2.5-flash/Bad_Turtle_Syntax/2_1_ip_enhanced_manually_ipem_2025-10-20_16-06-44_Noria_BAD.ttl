# --- Dynamic Elements ---

noria:event_LinkDown_CR01
    a noria:EventRecord, BBO:DocumentResource, pep:ProcedureExecution, observable:EventRecord, log:Event ;
    rdfs:label "Link Down Event on Core Router 01"@en ;
    rdfs:comment "An event indicating that a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject noria:resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:app_MonitoringSystem ;
    noria:alarmSeverity <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction noria:op_RouterInterfaceRestart ;
.

