# --- Procedural Elements ---

noria:ap_HighCPULowDiskIO
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "High CPU, Low Disk I/O Anomaly Pattern"@en ;
    rdfs:comment "An anomaly pattern indicating a potential software loop or inefficient process, characterized by high CPU usage but low disk I/O."@en ;
.

noria:op_RouterInterfaceRestart
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Router Interface Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network interface on a router."@en ;
    noria:operationPlanPreCondition noria:apc_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:apoc_InterfaceUp ;
.

noria:op_DBFailover
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Database Failover Procedure"@en ;
    rdfs:comment "Procedure to initiate a failover to a standby database server."@en ;
    noria:operationPlanPreCondition noria:apc_ServiceOffline ;
    noria:operationPlanPostCondition noria:apoc_ServiceRestored ;
.

noria:apc_ServiceOffline
    a noria:ActionPreCondition ;
    rdfs:label "Service Offline Pre-Condition"@en ;
    rdfs:comment "Pre-condition: The affected service must be taken offline or be already offline."@en ;
.

noria:apc_MaintenanceWindow
    a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Pre-Condition"@en ;
    rdfs:comment "Pre-condition: The operation must be performed within a scheduled maintenance window."@en ;
.

noria:apoc_InterfaceUp
    a noria:ActionPostCondition ;
    rdfs:label "Interface Up Post-Condition"@en ;
    rdfs:comment "Post-condition: The network interface must be in an 'up' operational state."@en ;
.

noria:apoc_ServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: The affected service must be fully restored and operational."@en ;
.

