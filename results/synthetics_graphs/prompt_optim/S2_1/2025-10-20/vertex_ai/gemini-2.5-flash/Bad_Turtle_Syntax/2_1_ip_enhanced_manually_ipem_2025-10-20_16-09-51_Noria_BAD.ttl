# --- Organizational Entities ---
noria:Org_ITOperations
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The central department responsible for IT infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues."^^xsd:string ;
    .

noria:Org_NetworkTeam
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Specialized team managing network infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "For critical issues, call the on-call engineer directly."^^xsd:string ;
    noria:elementManagedBy noria:Org_ITOperations ;
    .

noria:Person_AliceSmith
    a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Network Operations Lead."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for non-urgent matters, phone for urgent."^^xsd:string ;
    .

noria:Person_BobJohnson
    a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Application Support Engineer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Available via internal chat for quick queries."^^xsd:string ;
    .

noria:Org_VendorX
    a org:Organization, foaf:Agent ;
    rdfs:label "Vendor X Inc."@en ;
    rdfs:comment "Third-party hardware vendor."@en ;
    noria:agentWorkingHours "24/7 support"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Open a ticket on their portal for all support requests."^^xsd:string ;
    .

noria:CUid_AliceSmith
    a noria:CorporateUserIdentifier, foaf:OnlineAccount, observable:UserAccount ;
    rdfs:label "Alice Smith's Corporate User ID"@en ;
    rdfs:comment "Unique identifier for Alice Smith within the organization's IT systems."@en ;
    foaf:accountName "asmith"@xsd:string ;
    observable:accountLogin "asmith"@xsd:string ;
    observable:accountIdentifier "CU-ASMITH-001"^^xsd:string ;
    foaf:holdsAccount noria:Person_AliceSmith ;
    .

# --- Product Models ---
noria:ProductModel_Cisco_ASR9K
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series Router"@en ;
    rdfs:comment "Product model for Cisco ASR 9000 series routers."@en ;
    noria:productManufacturedBy noria:Org_VendorX ;
    .

noria:ProductModel_Dell_PowerEdge
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740 Server"@en ;
    rdfs:comment "Product model for Dell PowerEdge R740 rack servers."@en ;
    noria:productManufacturedBy noria:Org_VendorX ;
    .

# --- Location Entities ---
noria:Site_DataCenter_Paris
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center facility located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string ;
    .

noria:Room_ServerRoom_A1
    a noria:Room, bot:Space ;
    rdfs:label "Server Room A1"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_Rack_A1_R05 ; # Link to a locus
    .

noria:Locus_Rack_A1_R05
    a noria:Locus, bot:Space ;
    rdfs:label "Rack A1-R05"@en ;
    rdfs:comment "Specific rack location in Server Room A1."@en ;
    noria:locusLine "A1"^^xsd:string ;
    noria:locusRow "R05"^^xsd:string ;
    .

# --- Structural Elements: Resources, Network Interfaces, Network Links ---
noria:Resource_Router_Core1
    a noria:Resource, seas:System, seas:CommunicationDevice, bot:Element, observable:Device, log:Host ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Primary core router in the network backbone."@en ;
    noria:resourceLogisticId "LOG-CR1-001"^^xsd:string ;
    noria:resourceHostName "core-router-01.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel_Cisco_ASR9K ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "ABC12345DEF"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://192.168.10.1> ;
    noria:resourceManagedBy noria:Org_NetworkTeam ;
    noria:locatedAtLocus noria:Locus_Rack_A1_R05 ;
    noria:resourceForApplication noria:App_NetworkMonitoring ;
    .

noria:Resource_Server_DB1
    a noria:Resource, seas:System, observable:Device, log:Host ;
    rdfs:label "Database Server 1"@en ;
    rdfs:comment "Main database server for critical applications."@en ;
    noria:resourceLogisticId "LOG-DB1-002"^^xsd:string ;
    noria:resourceHostName "db-server-01.example.com"^^xsd:string ;
    noria:resourceProductModel noria:ProductModel_Dell_PowerEdge ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "GHI67890JKL"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress <http://10.0.0.10> ;
    noria:resourceManagedBy noria:Org_ITOperations ;
    noria:locatedAtLocus noria:Locus_Rack_A1_R05 ;
    noria:resourceForApplication noria:App_CustomerPortal ;
    .

noria:NetworkInterface_CR1_GE0_0_1
    a noria:NetworkInterface, seas:CommunicationConnectionPoint, observable:NetworkInterface ;
    rdfs:label "ge-0/0/1 on Core Router 1"@en ;
    rdfs:comment "Gigabit Ethernet interface on Core Router 1, connected to the WAN."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-1"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int ;
    noria:networkInterfaceDescription "WAN Uplink to ISP A"^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceOf noria:Resource_Router_Core1 ;
    noria:networkInterfaceConnects noria:NetworkLink_WAN_CR1_ISP_A ;
    .

noria:NetworkInterface_DB1_ETH0
    a noria:NetworkInterface, seas:CommunicationConnectionPoint, observable:NetworkInterface ;
    rdfs:label "eth0 on DB Server 1"@en ;
    rdfs:comment "Ethernet interface on Database Server 1, connected to the internal LAN."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Internal LAN connection"^^xsd:string ;
    noria:networkInterfaceType "virtual"^^xsd:string ;
    noria:networkInterfaceOf noria:Resource_Server_DB1 ;
    .

noria:NetworkLink_WAN_CR1_ISP_A
    a noria:NetworkLink, seas:CommunicationConnection ;
    rdfs:label "WAN Link Core Router 1 to ISP A"@en ;
    rdfs:comment "High-speed WAN link connecting Core Router 1 to ISP A."@en ;
    noria:networkLinkId "WAN-CR1-ISPA-001"^^xsd:string ;
    noria:networkLinkTerminationResource noria:Resource_Router_Core1 ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_Router_Core1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_ISP_Router_A ;
    noria:networkLinkInstallationDate "2020-01-10T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
    noria:resourceManagedBy noria:Org_NetworkTeam ;
    .

noria:Resource_ISP_Router_A
    a noria:Resource, seas:System, seas:CommunicationDevice, observable:Device, log:Host ;
    rdfs:label "ISP Router A"@en ;
    rdfs:comment "Router managed by ISP A, terminating the WAN link."@en ;
    noria:resourceHostName "isp-router-a.isp.com"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceManagedBy noria:Org_VendorX ;
    .

# --- Functional Elements: Applications, Application Modules, Services ---
noria:App_CustomerPortal
    a noria:Application, seas:System, observable:Application ;
