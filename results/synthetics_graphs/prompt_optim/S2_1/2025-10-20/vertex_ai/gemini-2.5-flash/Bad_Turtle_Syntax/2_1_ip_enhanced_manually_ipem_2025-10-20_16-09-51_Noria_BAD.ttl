    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CP-WEB-V2"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CPORTAL"^^xsd:string ;
    noria:applicationType <kos/application/type/ServicePlatform> ;
    noria:applicationBusinessImportance <kos/application/business-importance/Critical> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Customer Self-Service"^^xsd:string ;
    noria:elementManagedBy noria:Org_ITOperations ;
    .

noria:App_NetworkMonitoring
    a noria:Application, seas:System, observable:Application ;
