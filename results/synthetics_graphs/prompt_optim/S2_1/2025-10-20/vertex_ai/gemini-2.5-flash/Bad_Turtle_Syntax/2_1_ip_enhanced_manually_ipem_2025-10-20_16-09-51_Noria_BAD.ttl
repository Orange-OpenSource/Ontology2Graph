# Synthetic Knowledge Graph based on Noria Ontology

# --- SKOS Concept Schemes and Concepts for property ranges ---
# These are defined to satisfy the owl:intersectionOf (skos:Concept [owl:onProperty skos:inScheme; owl:hasValue <kos/...] ]) patterns.

<kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    dcterms:description "A scheme for classifying preferred contact methods for agents."@en .

<kos/application/type>
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of applications."@en .

<kos/application/business-importance>
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    dcterms:description "A scheme for classifying the business importance of applications."@en .

<kos/application/sla-level>
    a skos:ConceptScheme ;
    rdfs:label "Application Module SLA Level Scheme"@en ;
    dcterms:description "A scheme for classifying Service Level Agreement levels for application modules."@en .

<kos/application/status>
    a skos:ConceptScheme ;
    rdfs:label "Application Module Status Scheme"@en ;
    dcterms:description "A scheme for classifying the operational status of application modules."@en .

<kos/service/type>
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of services."@en .

<kos/TroubleTicket/severity>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    dcterms:description "A scheme for classifying the severity of trouble tickets."@en .

<kos/TroubleTicket/type>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of trouble tickets."@en .

<kos/TroubleTicket/category>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Criticity Scheme"@en ;
    dcterms:description "A scheme for classifying the criticity of trouble tickets from a customer impact perspective."@en .

<kos/TroubleTicket/priority>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    dcterms:description "A scheme for classifying the management priority of trouble tickets."@en .

<kos/TroubleTicket/origin>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    dcterms:description "A scheme for classifying the origin of trouble tickets."@en .

<kos/TroubleTicket/urgency>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    dcterms:description "A scheme for classifying the urgency level of trouble tickets."@en .

<kos/TroubleTicket/trouble-category>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category Scheme"@en ;
    dcterms:description "A scheme for classifying the initial and final nature/technical impact of incident categories."@en .

<kos/TroubleTicket/problemResponsibility>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    dcterms:description "A scheme for classifying the final area of responsibility for an incident."@en .

<kos/TroubleTicket/status>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme"@en ;
    dcterms:description "A scheme for classifying the current activity status of trouble tickets."@en .

<kos/TroubleTicket/commentType>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme"@en ;
    dcterms:description "A scheme for classifying the provenance type and disclosure rules for trouble ticket notes."@en .

<kos/TroubleTicket/operationType>
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme"@en ;
    dcterms:description "A scheme for classifying the operation type of trouble ticket notes."@en .

<kos/ChangeRequest/category>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    dcterms:description "A scheme for classifying the nature of change requests."@en .

<kos/ChangeRequest/type>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    dcterms:description "A scheme for classifying the type of change requests based on impact and risk."@en .

<kos/ChangeRequest/cause>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    dcterms:description "A scheme for classifying the cause or reason for change requests."@en .

<kos/ChangeRequest/status>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    dcterms:description "A scheme for classifying the current status of change requests."@en .

<kos/ChangeRequest/specification>
    a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    dcterms:description "A scheme for classifying standard operation plan items for recurring activities."@en .

<kos/Resource/OperationalState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    dcterms:description "A scheme for classifying the operational state of resources."@en .

<kos/Resource/AdministrativeState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    dcterms:description "A scheme for classifying the administrative state of resources."@en .

<Notification/Severity/PerceivedSeverity>
    a skos:ConceptScheme ;
    rdfs:label "Perceived Severity Scheme"@en ;
    dcterms:description "A scheme for classifying the perceived severity of alarms."@en .

<kos/Resource/type>
    a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    dcterms:description "A scheme for classifying types of network element resources."@en .

<kos/Resource/LifecycleState>
    a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    dcterms:description "A scheme for classifying the production state of resources."@en .

