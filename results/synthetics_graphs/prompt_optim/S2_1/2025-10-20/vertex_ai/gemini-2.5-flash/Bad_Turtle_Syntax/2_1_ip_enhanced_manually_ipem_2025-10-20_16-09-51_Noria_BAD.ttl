# --- Dynamic Elements: Event Records, Trouble Tickets, Change Requests, Document Attachments ---
noria:EventRecord_RouterDown
    a noria:EventRecord, BBO:DocumentResource, pep:ProcedureExecution, observable:EventRecord, log:Event ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log record indicating a network interface on Core Router 1 went down."@en ;
    noria:logOriginatingManagedObject noria:Resource_Router_Core1 ;
    noria:logOriginatingManagementSystem noria:App_NetworkMonitoring ;
    noria:logOriginatingAgent noria:Org_NetworkTeam ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartInterface ;
    noria:alarmMonitoredAttribute "interfaceStatus:down"^^xsd:string ; # Example of literal for this property
    .

noria:EventRecord_DBHighCPU
    a noria:EventRecord, BBO:DocumentResource, pep:ProcedureExecution, observable:EventRecord, log:Event ;
    rdfs:label "Database High CPU Alert"@en ;
    rdfs:comment "Alert indicating high CPU utilization on Database Server 1."@en ;
    noria:logOriginatingManagedObject noria:Resource_Server_DB1 ;
    noria:logOriginatingManagementSystem noria:App_NetworkMonitoring ;
    noria:logOriginatingAgent noria:Org_ITOperations ;
    noria:logText "CPU utilization on db-server-01 exceeded 90% for 5 minutes."^^xsd:string ;
    noria:loggingTime "2024-04-20T11:15:30Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    .

noria:TroubleTicket_WANOutage
    a noria:TroubleTicket, pep:ProcedureExecutionContainer, BBO:DocumentResource ;
    rdfs:label "WAN Outage Incident"@en ;
    rdfs:comment "Trouble ticket opened for a major WAN outage affecting customer services."@en ;
    noria:documentExternalId "TT-20240420-001"^^xsd:string ;
    noria:documentHRef <https://ticketing.example.com/TT-20240420-001> ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/CorruptedService> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_RouterDown ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Fiber cut on primary WAN link."^^xsd:string ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T14:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T13:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T15:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:Person_AliceSmith ;
    noria:troubleTicketPartyIntervention "Network team dispatched for on-site repair."^^xsd:string ; # Example of literal for this property
    noria:troubleTicketRelatedService noria:Service_E2E_CustomerAccess ;
    noria:troubleTicketRelatedResource noria:Resource_Router_Core1 ;
    noria:troubleTicketImpacts noria:App_CustomerPortal ;
    noria:troubleTicketCharacteristic "High impact on customer services"^^xsd:string ; # Example of literal for this property
    noria:troubleTicketFreezeItem noria:EventRecord_MaintenanceWindow ; # Link to an EventRecord
    noria:documentStatusHistory noria:EventRecord_TTStatusChange_InProgress ;
    .

