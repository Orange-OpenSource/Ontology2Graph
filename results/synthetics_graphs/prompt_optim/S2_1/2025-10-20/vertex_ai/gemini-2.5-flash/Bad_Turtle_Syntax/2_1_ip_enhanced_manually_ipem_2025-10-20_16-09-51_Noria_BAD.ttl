# --- RCA Objects ---
noria:AnomalyPattern_FiberCut
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "Fiber Cut Anomaly Pattern"@en ;
    rdfs:comment "Pattern describing the symptoms and indicators of a fiber optic cable cut."@en ;
    folio:hasFailureModeType "Physical Damage"^^xsd:string ;
    folio:hasConsequence "Total loss of connectivity"^^xsd:string ;
    .

# --- Operations Related ---
noria:OperationPlan_RestartInterface
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network interface."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp ;
    pep:hasInput "Interface name and device IP"^^xsd:string ;
    pep:hasOutput "Interface status after restart"^^xsd:string ;
    BBO:has_activationCondition "Network interface is in 'down' state"^^xsd:string ;
    BBO:has_completionCondition "Network interface is in 'up' state"^^xsd:string ;
    .

noria:OperationPlan_DBUpgrade
    a noria:OperationPlan, folio:ControlMethod, pep:Procedure ;
    rdfs:label "Database Software Upgrade Procedure"@en ;
    rdfs:comment "Procedure for upgrading the database software."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_BackupComplete ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBServiceRestored ;
    .

noria:ActionPreCondition_InterfaceDown
    a noria:ActionPreCondition ;
    rdfs:label "Interface Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition: The network interface must be in a 'down' operational state."@en ;
    .

noria:ActionPostCondition_InterfaceUp
    a noria:ActionPostCondition ;
    rdfs:label "Interface Up Post-Condition"@en ;
    rdfs:comment "Post-condition: The network interface must return to an 'up' operational state."@en ;
    .

noria:ActionPreCondition_BackupComplete
    a noria:ActionPreCondition ;
    rdfs:label "Database Backup Complete Pre-Condition"@en ;
    rdfs:comment "Pre-condition: A full backup of the database must be completed successfully."@en ;
    .

noria:ActionPostCondition_DBServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Database Service Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: The database service must be fully restored and operational."@en ;
    .

# --- Linking actions to operation plans ---
noria:Action_RestartCR1Interface
    a pep:ProcedureExecution ; # Assuming a generic action class, or can be a specific noria:Action if defined
    rdfs:label "Action: Restart Core Router 1 Interface"@en ;
    rdfs:comment "An action taken to restart the problematic interface on Core Router 1."@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_RestartInterface ;
    .

noria:Action_ExecuteDBUpgrade
    a pep:ProcedureExecution ;
    rdfs:label "Action: Execute DB Software Upgrade"@en ;
    rdfs:comment "An action taken to perform the database software upgrade."@en ;
    noria:actionCorrelatedOperationPlan noria:OperationPlan_DBUpgrade ;
    .

# --- Alarm Mitigation ---
noria:EventRecord_RouterDown_Mitigated
    a noria:EventRecord, BBO:DocumentResource, pep:ProcedureExecution, observable:EventRecord, log:Event ;
    rdfs:label "Router Interface Up Event (Mitigated)"@en ;
    rdfs:comment "Log record indicating a network interface on Core Router 1 came up after mitigation."@en ;
    noria:logOriginatingManagedObject noria:Resource_Router_Core1 ;
    noria:logOriginatingManagementSystem noria:App_NetworkMonitoring ;
    noria:logOriginatingAgent noria:Org_NetworkTeam ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to up"^^xsd:string ;
    noria:loggingTime "2024-04-20T10:45:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ; # Still critical as it's a recovery event
    noria:alarmMitigatedBy noria:ProcedureExecutionContainer_InterfaceRestart ;
    .

noria:ProcedureExecutionContainer_InterfaceRestart
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Interface Restart Execution Container"@en ;
    rdfs:comment "Container for the execution of the interface restart procedure."@en ;
    .
