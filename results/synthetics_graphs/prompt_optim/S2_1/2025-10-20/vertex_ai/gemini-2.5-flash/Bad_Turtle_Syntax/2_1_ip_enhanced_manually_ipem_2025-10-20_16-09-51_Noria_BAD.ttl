    noria:applicationModelIdentifier "NMON-PRO-V3"^^xsd:string ;
    noria:applicationNumericalIdentifier "1002"^^xsd:int ;
    noria:applicationShortIdentifier "NMON"^^xsd:string ;
    noria:applicationType <kos/application/type/Infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Resource Development, Management and Operations"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Network Performance Management"^^xsd:string ;
    noria:elementManagedBy noria:Org_NetworkTeam ;
    .

noria:AppModule_CustomerPortal_Prod
    a noria:ApplicationModule, seas:System ;
