    noria:logText "Interface GigabitEthernet0/0/1 on cr01.paris.example.com changed state to down."^^xsd:string ;
    noria:logOriginatingManagedObject <resource/CoreRouter01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <operationplan/CheckFiberLink> ;
    noria:alarmMonitoredAttribute <http://example.com/attribute/InterfaceStatus> ;
    noria:alarmMitigatedBy <changerequest/CR-20240422-001> .

<eventrecord/WebServerHighCPU>
