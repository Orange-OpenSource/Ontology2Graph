# Synthetic Knowledge Graph for NORIA Ontology

# =============================================================================
# SKOS Concepts for controlled vocabularies
# =============================================================================

# Agent Contact Method
<kos/org/agent-contact-method/Email>
    a skos:Concept ;
    skos:prefLabel "Email"@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:comment "Preferred contact method via email for routine communications."@en .

<kos/org/agent-contact-method/Phone>
    a skos:Concept ;
    skos:prefLabel "Phone"@en ;
    skos:inScheme <kos/org/agent-contact-method> ;
    rdfs:comment "Preferred contact method via phone call for urgent matters."@en .

# Application Type
<kos/application/type/ServicePlatform>
    a skos:Concept ;
    skos:prefLabel "Service Platform"@en ;
    skos:inScheme <kos/application/type> ;
    rdfs:comment "An application acting as a service platform, providing functionalities to other applications or users."@en .

<kos/application/type/Infrastructure>
    a skos:Concept ;
    skos:prefLabel "Infrastructure Application"@en ;
    skos:inScheme <kos/application/type> ;
    rdfs:comment "An application managing core infrastructure components, essential for system operations."@en .

# Application Business Importance
<kos/application/business-importance/Critical>
    a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:comment "Application is critical for business operations, any downtime would have severe impact."@en .

<kos/application/business-importance/High>
    a skos:Concept ;
    skos:prefLabel "High"@en ;
    skos:inScheme <kos/application/business-importance> ;
    rdfs:comment "Application has high business importance, significant impact if unavailable."@en .

# Application SLA Level
<kos/application/sla-level/Gold>
    a skos:Concept ;
    skos:prefLabel "Gold SLA"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:comment "Highest Service Level Agreement tier, guaranteeing maximum uptime and performance."@en .

<kos/application/sla-level/Silver>
    a skos:Concept ;
    skos:prefLabel "Silver SLA"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:comment "Standard Service Level Agreement tier, offering good performance and availability."@en .

# Application Status
<kos/application/status/InProduction>
    a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:comment "Application module is currently live and operational, serving end-users."@en .

<kos/application/status/Maintenance>
    a skos:Concept ;
    skos:prefLabel "Under Maintenance"@en ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:comment "Application module is currently undergoing scheduled or unscheduled maintenance."@en .

# Service Type
<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    skos:prefLabel "Customer Facing Service"@en ;
    skos:inScheme <kos/service/type> ;
    rdfs:comment "Service directly consumed by customers, impacting their experience."@en .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    skos:prefLabel "Resource Facing Service"@en ;
    skos:inScheme <kos/service/type> ;
    rdfs:comment "Service managing underlying resources, not directly exposed to customers but crucial for other services."@en .

# TroubleTicket Severity
<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:comment "Critical severity trouble ticket, requiring immediate attention due to severe impact."@en .

<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    skos:prefLabel "Major"@en ;
    skos:inScheme <kos/TroubleTicket/severity> ;
    rdfs:comment "Major severity trouble ticket, impacting service significantly but not completely."@en .

# TroubleTicket Type
<kos/TroubleTicket/type/Failure>
    a skos:Concept ;
    skos:prefLabel "Failure"@en ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:comment "Trouble ticket type indicating a system failure or malfunction."@en .

<kos/TroubleTicket/type/Assistance>
    a skos:Concept ;
    skos:prefLabel "Assistance"@en ;
    skos:inScheme <kos/TroubleTicket/type> ;
    rdfs:comment "Trouble ticket type for user assistance requests or general inquiries."@en .

# TroubleTicket Criticity
<kos/TroubleTicket/category/InterruptedService>
    a skos:Concept ;
    skos:prefLabel "Interrupted Service"@en ;
    skos:inScheme <kos/TroubleTicket/category> ;
    rdfs:comment "Criticity indicating a complete service interruption, rendering it unusable."@en .

# TroubleTicket Priority
<kos/TroubleTicket/priority/P1>
    a skos:Concept ;
    skos:prefLabel "Priority 1"@en ;
    skos:inScheme <kos/TroubleTicket/priority> ;
    rdfs:comment "Highest priority for trouble ticket resolution, demanding immediate action."@en .

# TroubleTicket Origin
<kos/TroubleTicket/origin/Customer>
    a skos:Concept ;
    skos:prefLabel "Customer"@en ;
    skos:inScheme <kos/TroubleTicket/origin> ;
    rdfs:comment "Trouble ticket originated by a customer, reported through support channels."@en .

# TroubleTicket Urgency
<kos/TroubleTicket/urgency/ImmediateIntervention>
    a skos:Concept ;
    skos:prefLabel "Immediate Intervention"@en ;
    skos:inScheme <kos/TroubleTicket/urgency> ;
    rdfs:comment "Urgency level requiring immediate action to prevent further damage or service loss."@en .

# TroubleTicket Trouble Category
<kos/TroubleTicket/trouble-category/TotalBreakdown>
    a skos:Concept ;
    skos:prefLabel "Total Breakdown"@en ;
    skos:inScheme <kos/TroubleTicket/trouble-category> ;
    rdfs:comment "Category indicating a complete system breakdown, leading to total service unavailability."@en .

# TroubleTicket Problem Responsibility
<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks>
    a skos:Concept ;
    skos:prefLabel "Managed Backbone Networks"@en ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
    rdfs:comment "Responsibility for the problem lies with the team managing backbone networks."@en .

# TroubleTicket Comment Type
<kos/TroubleTicket/commentType/Internal>
    a skos:Concept ;
    skos:prefLabel "Internal Comment"@en ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:comment "Comment intended for internal team members, not visible to external parties."@en .

<kos/TroubleTicket/commentType/Customer>
    a skos:Concept ;
    skos:prefLabel "Customer Comment"@en ;
    skos:inScheme <kos/TroubleTicket/commentType> ;
    rdfs:comment "Comment provided by or intended for the customer."@en .

# TroubleTicket Operation Type
<kos/TroubleTicket/operationType/Diagnosis>
    a skos:Concept ;
    skos:prefLabel "Diagnosis"@en ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:comment "Operation type related to diagnosing an issue, identifying root cause."@en .

<kos/TroubleTicket/operationType/CustomerCommunication>
    a skos:Concept ;
    skos:prefLabel "Customer Communication"@en ;
    skos:inScheme <kos/TroubleTicket/operationType> ;
    rdfs:comment "Operation type related to communicating with the customer."@en .

# TroubleTicket Status
<kos/TroubleTicket/status/InProgress>
    a skos:Concept ;
    skos:prefLabel "In Progress"@en ;
    skos:inScheme <kos/TroubleTicket/status> ;
    rdfs:comment "Trouble ticket is currently being worked on by assigned personnel."@en .

# ChangeRequest Category
<kos/ChangeRequest/category/InternalIntervention>
    a skos:Concept ;
    skos:prefLabel "Internal Intervention"@en ;
    skos:inScheme <kos/ChangeRequest/category> ;
    rdfs:comment "Change request for internal team intervention, not directly customer-facing."@en .

# ChangeRequest Type
<kos/ChangeRequest/type/Standard>
    a skos:Concept ;
    skos:prefLabel "Standard Change"@en ;
    skos:inScheme <kos/ChangeRequest/type> ;
    rdfs:comment "A routine change with low risk, pre-approved procedures."@en .

# ChangeRequest Cause
<kos/ChangeRequest/cause/SoftwareUpgrade>
    a skos:Concept ;
    skos:prefLabel "Software Upgrade"@en ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:comment "Cause of change request is a software upgrade to a newer version."@en .

<kos/ChangeRequest/cause/DatabaseMigration>
    a skos:Concept ;
    skos:prefLabel "Database Migration"@en ;
    skos:inScheme <kos/ChangeRequest/cause> ;
    rdfs:comment "Cause of change request is a migration of a database to a new platform or version."@en .

# ChangeRequest Status
<kos/ChangeRequest/status/Approved>
    a skos:Concept ;
    skos:prefLabel "Approved"@en ;
    skos:inScheme <kos/ChangeRequest/status> ;
    rdfs:comment "Change request has been formally approved for execution."@en .

# ChangeRequest Specification
<kos/ChangeRequest/specification/NetworkConfigurationUpdate>
    a skos:Concept ;
    skos:prefLabel "Network Configuration Update"@en ;
    skos:inScheme <kos/ChangeRequest/specification> ;
    rdfs:comment "Specification for updating network configurations, e.g., routing tables or firewall rules."@en .

# Notification Severity / Perceived Severity
<Notification/Severity/PerceivedSeverity/Warning>
    a skos:Concept ;
    skos:prefLabel "Warning"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:comment "Warning level severity for an alarm, indicating a potential issue that needs monitoring."@en .

<Notification/Severity/PerceivedSeverity/Critical>
    a skos:Concept ;
    skos:prefLabel "Critical"@en ;
    skos:inScheme <Notification/Severity/PerceivedSeverity> ;
    rdfs:comment "Critical level severity for an alarm, indicating an immediate and severe problem."@en .

# Resource Operational State
<kos/Resource/OperationalState/Up>
    a skos:Concept ;
    skos:prefLabel "Up"@en ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:comment "Resource is operational and running as expected."@en .

<kos/Resource/OperationalState/Down>
    a skos:Concept ;
    skos:prefLabel "Down"@en ;
    skos:inScheme <kos/Resource/OperationalState> ;
    rdfs:comment "Resource is not operational or has failed."@en .

# Resource Administrative State
<kos/Resource/AdministrativeState/Enabled>
    a skos:Concept ;
    skos:prefLabel "Enabled"@en ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:comment "Resource is administratively enabled, allowing it to function."@en .

<kos/Resource/AdministrativeState/Disabled>
    a skos:Concept ;
    skos:prefLabel "Disabled"@en ;
    skos:inScheme <kos/Resource/AdministrativeState> ;
    rdfs:comment "Resource is administratively disabled, preventing it from functioning."@en .

# Resource Type
<kos/Resource/type/Router>
    a skos:Concept ;
    skos:prefLabel "Router"@en ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:comment "Type of resource: Network Router, responsible for directing network traffic."@en .

<kos/Resource/type/Server>
    a skos:Concept ;
    skos:prefLabel "Server"@en ;
    skos:inScheme <kos/Resource/type> ;
    rdfs:comment "Type of resource: Compute Server, providing computational services."@en .

# Resource Lifecycle State
<kos/Resource/LifecycleState/InProduction>
    a skos:Concept ;
    skos:prefLabel "In Production"@en ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:comment "Resource is currently in active production use, serving live traffic or operations."@en .

<kos/Resource/LifecycleState/Decommissioned>
    a skos:Concept ;
    skos:prefLabel "Decommissioned"@en ;
    skos:inScheme <kos/Resource/LifecycleState> ;
    rdfs:comment "Resource has been removed from service and is no longer operational."@en .

# =============================================================================
# Foundational Entities
# =============================================================================

# Agents (foaf:Person, org:OrganizationalUnit)
<agent/JohnDoe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A key individual responsible for network operations and incident response."@en ;
    foaf:name "John Doe" ;
    foaf:mbox "mailto:john.doe@example.com" ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues and escalations."^^xsd:string .

<agent/JaneSmith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Support Engineer, specializing in web application performance."@en ;
    foaf:name "Jane Smith" ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    noria:agentWorkingHours "8:30 am - 4:30 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call her direct line for application outages or severe performance degradation."^^xsd:string .

<org/NetworkOperationsTeam>
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the core network infrastructure, including routers and links."@en ;
    org:unitOf <org/ExampleCompany> ;
    org:hasMember <agent/JohnDoe> ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Follow incident management procedure for escalation to on-call engineers."^^xsd:string .

<org/ApplicationSupportTeam>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing level 2 support for critical applications and their underlying servers."@en ;
    org:unitOf <org/ExampleCompany> ;
    org:hasMember <agent/JaneSmith> ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use ticketing system for all requests, ensure proper categorization."^^xsd:string .

<org/ExampleCompany>
    a org:Organization ;
    rdfs:label "Example Company Inc."@en ;
    rdfs:comment "The main organization operating the IT infrastructure and providing various digital services."@en .

# Corporate User Identifier
<corporateuseridentifier/JohnDoeLogin>
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate Login"@en ;
    rdfs:comment "The unique corporate user identifier for John Doe, used for system access."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    foaf:accountServiceHomepage <http://sso.example.com> ;
    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "jdoe-corp-id-123"^^xsd:string .

<agent/JohnDoe>
    foaf:holdsAccount <corporateuseridentifier/JohnDoeLogin> .

# Sites, Rooms, Loci
<site/DataCenterParis>
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris, hosting critical IT infrastructure."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "Data Center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" .

<room/ServerRoomA>
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A dedicated server room within the Paris Data Center, housing racks of servers and network equipment."@en ;
    bot:hasSpace <site/DataCenterParis> .

<locus/RackA1-U1>
    a noria:Locus ;
    rdfs:label "Rack A1, Unit 1"@en ;
    rdfs:comment "Specific location within Server Room A for a rack unit, typically for a single server or network device."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string ;
    bot:hasSpace <room/ServerRoomA> .

<locus/RackB2-U5>
    a noria:Locus ;
    rdfs:label "Rack B2, Unit 5"@en ;
    rdfs:comment "Specific location within Server Room A for another rack unit, used for a different set of equipment."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "2"^^xsd:string ;
    bot:hasSpace <room/ServerRoomA> .

# Product Models
<productmodel/Cisco-ASR9K>
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series"@en ;
    rdfs:comment "Product model for Cisco ASR 9000 series routers, known for high performance and reliability."@en ;
    noria:productManufacturedBy <org/CiscoSystems> .

<productmodel/HP-ProLiantDL380>
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Product model for HP ProLiant DL380 Gen10 servers, a common choice for enterprise workloads."@en ;
    noria:productManufacturedBy <org/HewlettPackardEnterprise> .

<org/CiscoSystems>
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of network equipment, including routers, switches, and security devices."@en .

<org/HewlettPackardEnterprise>
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of enterprise servers, storage, networking, and software solutions."@en .

# Resources
<resource/CoreRouter01>
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "A critical core router in the Paris Data Center, handling primary network traffic routing."@en ;
    noria:resourceLogisticId "CR01-PAR-DC"^^xsd:string ;
    noria:resourceHostName "cr01.paris.example.com"^^xsd:string ;
    noria:resourceProductModel <productmodel/Cisco-ASR9K> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "ABC12345DEF6"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/NetworkOperationsTeam> ;
    noria:locatedAtLocus <locus/RackA1-U1> ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> .

<resource/WebServer01>
    a noria:Resource ;
    rdfs:label "Web Server 01"@en ;
    rdfs:comment "A web server hosting the main company website and other public-facing applications."@en ;
    noria:resourceLogisticId "WS01-PAR-DC"^^xsd:string ;
    noria:resourceHostName "ws01.example.com"^^xsd:string ;
    noria:resourceProductModel <productmodel/HP-ProLiantDL380> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "GHI78901JKL2"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/ApplicationSupportTeam> ;
    noria:locatedAtLocus <locus/RackB2-U5> ;
    noria:resourceManagementIPAddress <http://example.com/ip/172.16.0.10> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

<resource/VirtualMachineDB>
    a noria:Resource ;
    rdfs:label "Database VM"@en ;
    rdfs:comment "A virtual machine hosting the primary database for a critical application, ensuring data persistence."@en ;
    noria:resourceLogisticId "VMDB-PROD-01"^^xsd:string ;
    noria:resourceHostName "db01.prod.example.com"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "VIRTUAL-DB-XYZ"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T08:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <org/ApplicationSupportTeam> ;
    noria:resourceManagementIPAddress <http://example.com/ip/192.168.1.50> ;
    noria:clusterController <resource/WebServer01> ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Network Interfaces
<networkinterface/CR01-GE0-0-0>
    a noria:NetworkInterface ;
    rdfs:label "Core Router 01 - GigabitEthernet0/0/0"@en ;
    rdfs:comment "Physical interface on Core Router 01 connecting to the internal network segment."@en ;
    noria:networkInterfaceOf <resource/CoreRouter01> ;
    noria:networkInterfaceDescription "Uplink to internal LAN segment 10.0.1.0/24 for server connectivity."^^xsd:string ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

<networkinterface/CR01-GE0-0-1>
    a noria:NetworkInterface ;
    rdfs:label "Core Router 01 - GigabitEthernet0/0/1"@en ;
    rdfs:comment "Physical interface on Core Router 01 connecting to the external network provider."@en ;
    noria:networkInterfaceOf <resource/CoreRouter01> ;
    noria:networkInterfaceDescription "Uplink to external WAN provider for internet access."^^xsd:string ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "50"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-1"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-8"^^xsd:int .

<networkinterface/WS01-ETH0>
    a noria:NetworkInterface ;
    rdfs:label "Web Server 01 - eth0"@en ;
    rdfs:comment "Primary network interface for Web Server 01, handling all incoming and outgoing web traffic."@en ;
    noria:networkInterfaceOf <resource/WebServer01> ;
    noria:networkInterfaceDescription "Main network interface for web traffic and application communication."^^xsd:string ;
    noria:networkInterfaceType "virtual" ;
