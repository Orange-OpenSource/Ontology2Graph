    rdfs:label "Web Server High CPU Alert"@en ;
    rdfs:comment "An alert indicating high CPU utilization on the web server, suggesting performance issues."@en ;
    noria:loggingTime "2024-04-20T11:30:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on ws01.example.com exceeded 90% for 5 minutes."^^xsd:string ;
