# Operation Plans
<operationplan/CheckFiberLink>
    a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing fiber link issues, including visual inspection and optical power tests."@en ;
    noria:operationPlanPreCondition <actionprecondition/FiberLinkDown> ;
    noria:operationPlanPostCondition <actionpostcondition/FiberLinkRestored> ;
    noria:actionCorrelatedOperationPlan <operationplan/CheckFiberLink> .

<operationplan/RestartWebServer>
    a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Procedure to restart the web server in case of performance issues or unresponsiveness."@en ;
    noria:operationPlanPreCondition <actionprecondition/HighCPUAlert> ;
    noria:operationPlanPostCondition <actionpostcondition/CPUUtilizationNormal> .

# Action Pre-Conditions
<actionprecondition/FiberLinkDown>
    a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: a fiber optic link is reported as down, indicating loss of connectivity."@en .

<actionprecondition/HighCPUAlert>
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Alert Pre-Condition"@en ;
    rdfs:comment "Condition: a high CPU utilization alert has been triggered on a server, indicating resource contention."@en .

# Action Post-Conditions
<actionpostcondition/FiberLinkRestored>
    a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored Post-Condition"@en ;
    rdfs:comment "Expected outcome: the fiber optic link is restored and operational, with traffic flowing normally."@en .

<actionpostcondition/CPUUtilizationNormal>
    a noria:ActionPostCondition ;
    rdfs:label "CPU Utilization Normal Post-Condition"@en ;
    rdfs:comment "Expected outcome: CPU utilization returns to normal levels after intervention, ensuring stable performance."@en .

# Anomaly Patterns
<anomalypattern/RepeatedInterfaceFlaps>
    a noria:AnomalyPattern ;
    rdfs:label "Repeated Interface Flaps Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating frequent up/down transitions on a network interface, potentially signaling a hardware issue or unstable link, leading to intermittent connectivity."@en ;
    folio:hasConsequence "Service Interruption"^^xsd:string ;
    folio:hasCause "Faulty Transceiver"^^xsd:string .

<anomalypattern/DatabaseDeadlockSpike>
    a noria:AnomalyPattern ;
    rdfs:label "Database Deadlock Spike Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating a sudden increase in database deadlocks, often pointing to application code issues or resource contention, leading to application unresponsiveness."@en ;
    folio:hasConsequence "Application Unresponsiveness"^^xsd:string ;
    folio:hasCause "Inefficient Database Queries"^^xsd:string .
