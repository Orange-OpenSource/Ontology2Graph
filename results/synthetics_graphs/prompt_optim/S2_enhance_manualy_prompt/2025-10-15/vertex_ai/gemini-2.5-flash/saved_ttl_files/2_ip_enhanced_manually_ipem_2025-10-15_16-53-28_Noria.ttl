# --- noria:EventRecord ---
noria:EventRecord_ServerDownAlert
    a noria:EventRecord ;
    rdfs:label "Server Down Alert - AppServer001"@en ;
    rdfs:comment "Alert indicating Application Server 001 is down."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: appserver001.example.com is unreachable via ping."^^xsd:string ;
    noria:logOriginatingManagedObject noria:Resource_Server001 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity noria:PerceivedSeverity_Critical ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartWebServer ;
.
noria:EventRecord_InterfaceFlap
    a noria:EventRecord ;
    rdfs:label "Interface Flap - Router001 Ge001"@en ;
