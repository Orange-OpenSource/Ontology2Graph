# --- KOS (Knowledge Organization System) Concepts ---
# These concepts are used as ranges for various ObjectProperties in the NORIA schema.

# Agent Contact Method KOS
<https://w3id.org/noria/kos/org/agent-contact-method>
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents."@en ;
.
noria:ContactMethod_Email
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method via email."@en ;
.
noria:ContactMethod_Phone
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method via phone."@en ;
.
noria:ContactMethod_Chat
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ;
    rdfs:label "Chat"@en ;
    rdfs:comment "Preferred contact method via instant messaging or chat."@en ;
.

