# noria:AnomalyPattern
<anomalypattern/HighCPULowThroughput>
    a noria:AnomalyPattern ;
    rdfs:label "High CPU Low Throughput Anomaly"@en ;
    rdfs:comment "Anomaly pattern: high CPU usage combined with low network throughput, indicating a potential bottleneck or application issue."@en ;
    noria:structuralObservableOf <application/App001> ;
.

# noria:OperationPlan
<operationplan/CheckFiberLink>
    a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Procedure to diagnose and resolve fiber link issues."@en ;
    noria:operationPlanPreCondition <actionprecondition/LinkDownDetected> ;
    noria:operationPlanPostCondition <actionpostcondition/LinkRestored> ;
.

<operationplan/RestartWebServer>
    a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Procedure to restart a web server in case of performance issues."@en ;
    noria:operationPlanPreCondition <actionprecondition/HighCPULowThroughputDetected> ;
    noria:operationPlanPostCondition <actionpostcondition/PerformanceRestored> ;
.

# noria:ActionPreCondition
<actionprecondition/LinkDownDetected>
