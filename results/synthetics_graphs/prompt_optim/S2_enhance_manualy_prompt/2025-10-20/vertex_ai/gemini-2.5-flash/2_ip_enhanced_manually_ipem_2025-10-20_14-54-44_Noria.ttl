# Dummy class for IPAddress to handle noria:resourceManagementIPAddress
noria:IPAddress
    a owl:Class ;
    rdfs:label "IP Address" ;
    rdfs:comment "Represents an IP address entity." .

noria:hasIPAddressValue
    a owl:DatatypeProperty ;
    rdfs:label "has IP Address Value" ;
    rdfs:comment "The actual string value of an IP address." ;
    rdfs:domain noria:IPAddress ;
    rdfs:range xsd:string .

# Dummy classes for actionCorrelatedOperationPlan domain
noria:CorrectiveMaintenanceAction
    a owl:Class ;
    rdfs:subClassOf noria:EventRecord ;
    rdfs:label "Corrective Maintenance Action" ;
    rdfs:comment "An event record representing a corrective maintenance action." .

noria:ChangeAction
    a owl:Class ;
    rdfs:subClassOf noria:EventRecord ;
    rdfs:label "Change Action" ;
    rdfs:comment "An event record representing a change action." .

