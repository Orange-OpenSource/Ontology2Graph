# foaf:Agent (Persons and Organizational Units)
<agent/JohnDoe>
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A synthetic person, IT Administrator."@en ;
    foaf:name "John Doe"^^xsd:string ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource <resource/Server001>, <networklink/WANLink001> ;
.

<agent/JaneSmith>
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A synthetic person, Network Engineer."@en ;
    foaf:name "Jane Smith"^^xsd:string ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Call directly for critical network issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentManagesResource <resource/Router001>, <networklink/LANLink001> ;
.

<org/ITOperations>
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The department responsible for IT infrastructure operations."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentManagesResource <resource/Server002>, <application/App001> ;
.

<org/NetworkTeam>
    a org:OrganizationalUnit ;
    rdfs:label "Network Engineering Team"@en ;
    rdfs:comment "Team responsible for network design and maintenance."@en ;
    noria:agentWorkingHours "09:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Escalate via internal chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentManagesResource <resource/Router002>, <networklink/WANLink002> ;
.

<org/AcmeCorp>
    a org:Organization ;
    rdfs:label "Acme Corporation"@en ;
    rdfs:comment "A fictional corporation."@en ;
    noria:agentWorkingHours "08:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact general support line."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
.

<org/GlobexCorp>
