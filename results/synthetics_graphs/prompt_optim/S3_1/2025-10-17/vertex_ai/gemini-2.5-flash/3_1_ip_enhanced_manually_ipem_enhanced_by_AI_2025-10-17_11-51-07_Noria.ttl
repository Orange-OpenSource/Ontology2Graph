# =============================================================================
# Knowledge Organization System (KOS) Concepts
# =============================================================================

# KOS for Application Type
noria-inst:AppTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of applications."@en .

noria-inst:AppType_ServicePlatform
    a skos:Concept ;
    skos:inScheme noria-inst:AppTypeScheme ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "An application acting as a platform for other services."@en .

noria-inst:AppType_Infrastructure
    a skos:Concept ;
    skos:inScheme noria-inst:AppTypeScheme ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "An application providing core infrastructure services."@en .

noria-inst:AppType_BusinessCritical
    a skos:Concept ;
    skos:inScheme noria-inst:AppTypeScheme ;
    rdfs:label "Business Critical Application"@en ;
    rdfs:comment "An application essential for core business operations."@en .

# KOS for Application Business Importance
noria-inst:AppBizImportanceScheme
    a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme"@en ;
    rdfs:comment "A controlled vocabulary for rating the business importance of applications."@en .

noria-inst:AppBizImportance_High
    a skos:Concept ;
    skos:inScheme noria-inst:AppBizImportanceScheme ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application with high business impact."@en .

noria-inst:AppBizImportance_Medium
    a skos:Concept ;
    skos:inScheme noria-inst:AppBizImportanceScheme ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Application with medium business impact."@en .

# KOS for Application SLA Level
noria-inst:AppSLALevelScheme
    a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme"@en ;
    rdfs:comment "A controlled vocabulary for Service Level Agreement levels for applications."@en .

noria-inst:AppSLALevel_Platinum
    a skos:Concept ;
    skos:inScheme noria-inst:AppSLALevelScheme ;
    rdfs:label "Platinum SLA Level"@en ;
    rdfs:comment "Highest SLA level with maximum availability and performance guarantees."@en .

noria-inst:AppSLALevel_Gold
    a skos:Concept ;
    skos:inScheme noria-inst:AppSLALevelScheme ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "High SLA level with strong availability and performance guarantees."@en .

# KOS for Application Status
noria-inst:AppStatusScheme
    a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the operational status of applications."@en .

noria-inst:AppStatus_InProduction
    a skos:Concept ;
    skos:inScheme noria-inst:AppStatusScheme ;
    rdfs:label "In Production"@en ;
    rdfs:comment "Application is currently live and operational."@en .

noria-inst:AppStatus_Development
    a skos:Concept ;
    skos:inScheme noria-inst:AppStatusScheme ;
    rdfs:label "In Development"@en ;
    rdfs:comment "Application is under development."@en .

# KOS for Service Type
noria-inst:ServiceTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of services."@en .

noria-inst:ServiceType_CustomerFacing
    a skos:Concept ;
    skos:inScheme noria-inst:ServiceTypeScheme ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by customers."@en .

noria-inst:ServiceType_ResourceFacing
    a skos:Concept ;
    skos:inScheme noria-inst:ServiceTypeScheme ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations."@en .

# KOS for TroubleTicket Severity
noria-inst:TTSeverityScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the severity of trouble tickets."@en .

noria-inst:TTSeverity_Critical
    a skos:Concept ;
    skos:inScheme noria-inst:TTSeverityScheme ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Highest severity, immediate business impact."@en .

noria-inst:TTSeverity_Major
    a skos:Concept ;
    skos:inScheme noria-inst:TTSeverityScheme ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Significant business impact, requires urgent attention."@en .

# KOS for TroubleTicket Type
noria-inst:TTTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of trouble tickets."@en .

noria-inst:TTType_Failure
    a skos:Concept ;
    skos:inScheme noria-inst:TTTypeScheme ;
    rdfs:label "Failure Ticket"@en ;
    rdfs:comment "Ticket reporting a system or service failure."@en .

noria-inst:TTType_Assistance
    a skos:Concept ;
    skos:inScheme noria-inst:TTTypeScheme ;
    rdfs:label "Assistance Ticket"@en ;
    rdfs:comment "Ticket requesting assistance or support."@en .

# KOS for TroubleTicket Criticity (Customer Impact)
noria-inst:TTCriticityScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Criticity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the criticity (customer impact) of trouble tickets."@en .

noria-inst:TTCriticity_InterruptedService
    a skos:Concept ;
    skos:inScheme noria-inst:TTCriticityScheme ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "Service is completely unavailable to the customer."@en .

noria-inst:TTCriticity_CorruptedService
    a skos:Concept ;
    skos:inScheme noria-inst:TTCriticityScheme ;
    rdfs:label "Corrupted Service"@en ;
    rdfs:comment "Service is available but with data integrity issues."@en .

# KOS for TroubleTicket Priority
noria-inst:TTPriorityScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the priority of trouble tickets."@en .

noria-inst:TTPriority_P1
    a skos:Concept ;
    skos:inScheme noria-inst:TTPriorityScheme ;
    rdfs:label "Priority 1 (P1)"@en ;
    rdfs:comment "Highest priority, critical impact, immediate resolution required."@en .

noria-inst:TTPriority_P2
    a skos:Concept ;
    skos:inScheme noria-inst:TTPriorityScheme ;
    rdfs:label "Priority 2 (P2)"@en ;
    rdfs:comment "High priority, significant impact, urgent resolution."@en .

# KOS for TroubleTicket Origin
noria-inst:TTOriginScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the origin of trouble tickets."@en .

noria-inst:TTOrigin_Customer
    a skos:Concept ;
    skos:inScheme noria-inst:TTOriginScheme ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Ticket initiated by a customer."@en .

noria-inst:TTOrigin_Supervision
    a skos:Concept ;
    skos:inScheme noria-inst:TTOriginScheme ;
    rdfs:label "Supervision System Origin"@en ;
    rdfs:comment "Ticket initiated by an automated monitoring or supervision system."@en .

# KOS for TroubleTicket Urgency
noria-inst:TTUrgencyScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the urgency of trouble tickets."@en .

noria-inst:TTUrgency_Immediate
    a skos:Concept ;
    skos:inScheme noria-inst:TTUrgencyScheme ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Requires immediate action."@en .

noria-inst:TTUrgency_Deferred
    a skos:Concept ;
    skos:inScheme noria-inst:TTUrgencyScheme ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Can be addressed later, not critical."@en .

# KOS for TroubleTicket Trouble Category
noria-inst:TTTroubleCategoryScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Trouble Category Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the technical category of trouble tickets."@en .

noria-inst:TTTroubleCategory_NetworkOutage
    a skos:Concept ;
    skos:inScheme noria-inst:TTTroubleCategoryScheme ;
    rdfs:label "Network Outage"@en ;
    rdfs:comment "Complete network service disruption."@en .

noria-inst:TTTroubleCategory_PerformanceDegradation
    a skos:Concept ;
    skos:inScheme noria-inst:TTTroubleCategoryScheme ;
    rdfs:label "Performance Degradation"@en ;
    rdfs:comment "Service is slow or degraded."@en .

# KOS for TroubleTicket Problem Responsibility
noria-inst:TTProblemResponsibilityScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en ;
    rdfs:comment "A controlled vocabulary for assigning responsibility for problems."@en .

noria-inst:TTProblemResponsibility_Customer
    a skos:Concept ;
    skos:inScheme noria-inst:TTProblemResponsibilityScheme ;
    rdfs:label "Customer Responsibility"@en ;
    rdfs:comment "Problem caused by customer actions or equipment."@en .

noria-inst:TTProblemResponsibility_InternalNetwork
    a skos:Concept ;
    skos:inScheme noria-inst:TTProblemResponsibilityScheme ;
    rdfs:label "Internal Network Responsibility"@en ;
    rdfs:comment "Problem caused by internal network infrastructure."@en .

# KOS for TroubleTicket Comment Type
noria-inst:TTCommentTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Comment Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for types of comments in trouble tickets."@en .

noria-inst:TTCommentType_Internal
    a skos:Concept ;
    skos:inScheme noria-inst:TTCommentTypeScheme ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment visible only to internal teams."@en .

noria-inst:TTCommentType_CustomerVisible
    a skos:Concept ;
    skos:inScheme noria-inst:TTCommentTypeScheme ;
    rdfs:label "Customer Visible Comment"@en ;
    rdfs:comment "Comment visible to the customer."@en .

# KOS for TroubleTicket Operation Type
noria-inst:TTOperationTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Operation Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for types of operations recorded in trouble ticket notes."@en .

noria-inst:TTOperationType_Diagnosis
    a skos:Concept ;
    skos:inScheme noria-inst:TTOperationTypeScheme ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Operation related to diagnosing the problem."@en .

noria-inst:TTOperationType_TestsMeasurements
    a skos:Concept ;
    skos:inScheme noria-inst:TTOperationTypeScheme ;
    rdfs:label "Tests and Measurements Operation"@en ;
    rdfs:comment "Operation involving running tests and taking measurements."@en .

# KOS for ChangeRequest Category
noria-inst:CRCategoryScheme
    a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying categories of change requests."@en .

noria-inst:CRCategory_InternalIntervention
    a skos:Concept ;
    skos:inScheme noria-inst:CRCategoryScheme ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change initiated and executed by internal teams."@en .

noria-inst:CRCategory_CustomerRequested
    a skos:Concept ;
    skos:inScheme noria-inst:CRCategoryScheme ;
    rdfs:label "Customer Requested Change"@en ;
    rdfs:comment "Change requested by a customer."@en .

# KOS for ChangeRequest Type
noria-inst:CRTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of change requests based on impact/risk."@en .

noria-inst:CRType_Standard
    a skos:Concept ;
    skos:inScheme noria-inst:CRTypeScheme ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "Low risk, pre-approved change."@en .

noria-inst:CRType_Major
    a skos:Concept ;
    skos:inScheme noria-inst:CRTypeScheme ;
    rdfs:label "Major Change"@en ;
    rdfs:comment "High risk, significant impact change, requires extensive approval."@en .

# KOS for ChangeRequest Cause
noria-inst:CRCauseScheme
    a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme"@en ;
    rdfs:comment "A controlled vocabulary for reasons behind change requests."@en .

noria-inst:CRCause_SoftwareUpgrade
    a skos:Concept ;
    skos:inScheme noria-inst:CRCauseScheme ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Change due to software version upgrade."@en .

noria-inst:CRCause_NetworkExtension
    a skos:Concept ;
skos:inScheme noria-inst:CRCauseScheme ;
    rdfs:label "Network Extension"@en ;
    rdfs:comment "Change due to expanding network capacity or reach."@en .

# KOS for ChangeRequest Status
noria-inst:CRStatusScheme
    a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the status of change requests."@en .

noria-inst:CRStatus_Planned
    a skos:Concept ;
    skos:inScheme noria-inst:CRStatusScheme ;
    rdfs:label "Planned"@en ;
    rdfs:comment "Change is planned but not yet started."@en .

noria-inst:CRStatus_Implemented
    a skos:Concept ;
    skos:inScheme noria-inst:CRStatusScheme ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "Change has been successfully implemented."@en .

# KOS for ChangeRequest Specification
noria-inst:CRSpecificationScheme
    a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme"@en ;
    rdfs:comment "A controlled vocabulary for specifications or standard operation plans for change requests."@en .

noria-inst:CRSpecification_StandardProcedureA
    a skos:Concept ;
    skos:inScheme noria-inst:CRSpecificationScheme ;
    rdfs:label "Standard Procedure A"@en ;
    rdfs:comment "Refers to a predefined standard operating procedure A."@en .

noria-inst:CRSpecification_CustomScript
    a skos:Concept ;
    skos:inScheme noria-inst:CRSpecificationScheme ;
    rdfs:label "Custom Script Execution"@en ;
    rdfs:comment "Change involves execution of a custom script."@en .

# KOS for Resource Operational State
noria-inst:ResourceOperationalStateScheme
    a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the operational state of resources."@en .

noria-inst:ResourceOperationalState_Up
    a skos:Concept ;
    skos:inScheme noria-inst:ResourceOperationalStateScheme ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is fully operational."@en .

noria-inst:ResourceOperationalState_Down
    a skos:Concept ;
    skos:inScheme noria-inst:ResourceOperationalStateScheme ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational."@en .

# KOS for Resource Administrative State
noria-inst:ResourceAdministrativeStateScheme
    a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the administrative state of resources."@en .

noria-inst:ResourceAdministrativeState_Enabled
    a skos:Concept ;
    skos:inScheme noria-inst:ResourceAdministrativeStateScheme ;
    rdfs:label "Enabled"@en ;
    rdfs:comment "Resource is administratively enabled."@en .

noria-inst:ResourceAdministrativeState_Disabled
    a skos:Concept ;
    skos:inScheme noria-inst:ResourceAdministrativeStateScheme ;
    rdfs:label "Disabled"@en ;
    rdfs:comment "Resource is administratively disabled."@en .

# KOS for Resource Type
noria-inst:ResourceTypeScheme
    a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme"@en ;
    rdfs:comment "A controlled vocabulary for classifying types of IT resources."@en .

noria-inst:ResourceType_Router
    a skos:Concept ;
    skos:inScheme noria-inst:ResourceTypeScheme ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network router device."@en .

noria-inst:ResourceType_Server
    a skos:Concept ;
    skos:inScheme noria-inst:ResourceTypeScheme ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computing server device."@en .

# KOS for Resource Lifecycle State
noria-inst:ResourceLifecycleStateScheme
    a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the lifecycle state of resources."@en .

noria-inst:ResourceLifecycleState_InUse
    a skos:Concept ;
    skos:inScheme noria-inst:ResourceLifecycleStateScheme ;
    rdfs:label "In Use"@en ;
    rdfs:comment "Resource is actively being used in production."@en .

noria-inst:ResourceLifecycleState_Decommissioned
    a skos:Concept ;
    skos:inScheme noria-inst:ResourceLifecycleStateScheme ;
    rdfs:label "Decommissioned"@en ;
    rdfs:comment "Resource has been removed from service."@en .

# KOS for Agent Contact Method
noria-inst:AgentContactMethodScheme
    a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme"@en ;
    rdfs:comment "A controlled vocabulary for preferred contact methods for agents."@en .

noria-inst:AgentContactMethod_Email
    a skos:Concept ;
    skos:inScheme noria-inst:AgentContactMethodScheme ;
    rdfs:label "Email"@en ;
    rdfs:comment "Preferred contact method is email."@en .

noria-inst:AgentContactMethod_Phone
    a skos:Concept ;
    skos:inScheme noria-inst:AgentContactMethodScheme ;
    rdfs:label "Phone"@en ;
    rdfs:comment "Preferred contact method is phone."@en .

# KOS for Notification Severity (Perceived Severity)
noria-inst:NotificationSeverityScheme
    a skos:ConceptScheme ;
    rdfs:label "Notification Severity Scheme"@en ;
    rdfs:comment "A controlled vocabulary for the perceived severity of notifications/alarms."@en .

noria-inst:NotificationSeverity_Critical
    a skos:Concept ;
    skos:inScheme noria-inst:NotificationSeverityScheme ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Highest severity, immediate action required."@en .

noria-inst:NotificationSeverity_Warning
    a skos:Concept ;
    skos:inScheme noria-inst:NotificationSeverityScheme ;
    rdfs:label "Warning"@en ;
    rdfs:comment "Potential issue, requires attention but not immediate action."@en .

# =============================================================================
# Core Organizational Entities
# =============================================================================

noria-inst:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange S.A."@en ;
    rdfs:comment "The main Orange corporate entity."@en ;
    dcterms:identifier "ORG-001"^^xsd:string ;
    foaf:homepage <https://www.orange.com/> .

noria-inst:NetworkOperationsUnit
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Organizational unit responsible for network operations."@en ;
    org:unitOf noria-inst:OrangeCorp ;
    dcterms:identifier "OU-NETOPS-001"^^xsd:string .

noria-inst:ApplicationSupportUnit
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Unit"@en ;
    rdfs:comment "Organizational unit responsible for application support."@en ;
    org:unitOf noria-inst:OrangeCorp ;
    dcterms:identifier "OU-APPSUP-002"^^xsd:string .

noria-inst:SecurityOperationsUnit
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Unit"@en ;
    rdfs:comment "Organizational unit responsible for security operations."@en ;
    org:unitOf noria-inst:OrangeCorp ;
    dcterms:identifier "OU-SECOPS-003"^^xsd:string .

noria-inst:JohnDoe
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A network engineer at Orange."@en ;
    foaf:mbox <mailto:john.doe@orange.com> ;
    foaf:phone "+33123456789"^^xsd:string ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:AgentContactMethod_Email .

noria-inst:JaneSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An application support lead."@en ;
    foaf:mbox <mailto:jane.smith@orange.com> ;
    foaf:phone "+33198765432"^^xsd:string ;
    noria:agentWorkingHours "8:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Use ticketing system first, then phone for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:AgentContactMethod_Phone .

noria-inst:AutomatedSystemAgent
    a foaf:Agent ;
    rdfs:label "Automated Monitoring System"@en ;
    rdfs:comment "An automated system acting as an agent for certain operations."@en ;
    noria:agentInstructions "Refer to system logs for details."^^xsd:string .

# =============================================================================
# Location Entities
# =============================================================================

noria-inst:ParisDataCenter
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string ;
    wgs84_pos:lat "48.867"^^xsd:float ;
    wgs84_pos:long "2.333"^^xsd:float .

noria-inst:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace noria-inst:Locus_Rack12A ;
    bot:hasSpace noria-inst:Locus_Rack12B ;
    bot:hasSubSpace noria-inst:Locus_Rack12A ;
    bot:hasSubSpace noria-inst:Locus_Rack12B .

noria-inst:Locus_Rack12A
    a noria:Locus ;
    rdfs:label "Rack 12A Locus"@en ;
    rdfs:comment "Specific location for Rack 12A in Server Room A."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "12"^^xsd:string .

noria-inst:Locus_Rack12B
    a noria:Locus ;
    rdfs:label "Rack 12B Locus"@en ;
    rdfs:comment "Specific location for Rack 12B in Server Room A."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "12"^^xsd:string .

# =============================================================================
# Product Model
# =============================================================================

noria-inst:CiscoASR9K
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series"@en ;
