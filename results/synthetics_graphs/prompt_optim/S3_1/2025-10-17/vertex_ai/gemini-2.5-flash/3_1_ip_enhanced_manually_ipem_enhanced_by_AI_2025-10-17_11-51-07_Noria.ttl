# =============================================================================
# Procedural Elements: AnomalyPattern, OperationPlan, ActionPreCondition, ActionPostCondition
# =============================================================================

noria-inst:HighLatencyAnomaly
    a noria:AnomalyPattern ;
    rdfs:label "High Latency Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating abnormally high network latency, potentially leading to service degradation."@en ;
    folio:hasConsequence noria-inst:ServiceDegradationConsequence .

noria-inst:ServiceDegradationConsequence
    a folio:Consequence ;
    rdfs:label "Service Degradation Consequence"@en ;
    rdfs:comment "Consequence of high latency leading to degraded service."@en .

noria-inst:RouterInterfaceTroubleshootPlan
    a noria:OperationPlan, pep:Procedure ;
    rdfs:label "Router Interface Troubleshooting Plan"@en ;
    rdfs:comment "Standard operating procedure for troubleshooting a down router interface."@en ;
    noria:operationPlanPreCondition noria-inst:PreCond_InterfaceDown ;
    noria:operationPlanPostCondition noria-inst:PostCond_InterfaceUp .

noria-inst:PreCond_InterfaceDown
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Interface is Down"@en ;
    rdfs:comment "Condition that the network interface is in a 'down' operational state."@en .

noria-inst:PostCond_InterfaceUp
    a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Interface is Up"@en ;
    rdfs:comment "Expected outcome that the network interface is in an 'up' operational state."@en .

noria-inst:CorrectiveAction_InterfaceReset
    a pep:CorrectiveMaintenanceAction ;
    rdfs:label "Corrective Action: Interface Reset"@en ;
    rdfs:comment "An action to reset a network interface."@en ;
    noria:actionCorrelatedOperationPlan noria-inst:RouterInterfaceTroubleshootPlan .

noria-inst:ChangeAction_OSUpgrade
    a pep:ChangeAction ;
    rdfs:label "Change Action: OS Upgrade"@en ;
    rdfs:comment "An action to upgrade an operating system."@en ;
    noria:actionCorrelatedOperationPlan noria-inst:RouterOSUpgradePlan .

noria-inst:RouterOSUpgradePlan
    a noria:OperationPlan, pep:Procedure ;
    rdfs:label "Router OS Upgrade Plan"@en ;
    rdfs:comment "Standard operating procedure for upgrading router operating systems."@en ;
    noria:operationPlanPreCondition noria-inst:PreCond_BackupComplete ;
    noria:operationPlanPostCondition noria-inst:PostCond_OSUpdated .

noria-inst:PreCond_BackupComplete
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Configuration Backup Complete"@en ;
    rdfs:comment "Ensures a full configuration backup is completed before OS upgrade."@en .

noria-inst:PostCond_OSUpdated
    a noria:ActionPostCondition ;
    rdfs:label "Post-condition: OS Successfully Updated"@en ;
    rdfs:comment "Verifies that the operating system has been successfully updated and is operational."@en .

