    noria:troubleTicketRelatedParty noria-inst:JohnDoe ;
    noria:troubleTicketRelatedService noria-inst:EnterpriseInternetService ;
    noria:troubleTicketRelatedResource noria-inst:CoreRouter01 ;
    noria:troubleTicketImpacts noria-inst:EnterpriseInternetService ;
    noria:troubleTicketImpacts noria-inst:CoreRouter01 ;
    noria:troubleTicketCharacteristic noria-inst:TTChar_HighImpact ;
    noria:troubleTicketFreezeItem noria-inst:EventRecord_TTFreeze1 ;
    noria:documentStatusHistory noria-inst:EventRecord_TTStatusChange1 .

