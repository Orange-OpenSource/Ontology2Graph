# --- Procedural Elements ---

noria-inst:InterfaceRestartProcedure
    a noria:OperationPlan, pep:Procedure ;
    rdfs:label "Network Interface Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network interface."@en ;
    noria:operationPlanPreCondition noria-inst:PreCond_InterfaceDown ;
    noria:operationPlanPostCondition noria-inst:PostCond_InterfaceUp .

noria-inst:PreCond_InterfaceDown
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Interface is Down"@en ;
    rdfs:comment "Condition that the network interface must be in a 'down' state."@en .

noria-inst:PostCond_InterfaceUp
    a noria:ActionPostCondition ;
    rdfs:label "Post-condition: Interface is Up"@en ;
    rdfs:comment "Expected outcome: the network interface is in an 'up' state."@en .

noria-inst:DiagnosisProcedureExecution
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Diagnosis Procedure Execution for TT-20240420-001"@en ;
    rdfs:comment "Container for the execution steps of the diagnosis procedure for the trouble ticket."@en ;
    pep:hasProcedure noria-inst:InterfaceRestartProcedure .

noria-inst:AnomalyPattern_HighLatency
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "High Latency Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating unusually high network latency, potentially signaling a problem."@en ;
    folio:hasCause noria-inst:FiberCutCause ;
    folio:hasEffect noria-inst:ServiceDegradationEffect .

noria-inst:FiberCutCause
    a folio:Cause ;
    rdfs:label "Fiber Cut Cause"@en ;
    rdfs:comment "A physical fiber cut as a cause for network issues."@en .

noria-inst:ServiceDegradationEffect
    a folio:Effect ;
    rdfs:label "Service Degradation Effect"@en ;
    rdfs:comment "Degradation of service quality as an effect of an anomaly."@en .

noria-inst:CorrectiveMaintenanceAction_InterfaceRestart
    a pep:CorrectiveMaintenanceAction ;
    rdfs:label "Corrective Action: Interface Restart"@en ;
    rdfs:comment "An action taken to restart a network interface."@en ;
    noria:actionCorrelatedOperationPlan noria-inst:InterfaceRestartProcedure ;
    pep:hasInput noria-inst:CoreRouter01_GE0_0_0 ;
    pep:hasOutput noria-inst:EventRecord_InterfaceUpConfirmation .

noria-inst:EventRecord_InterfaceUpConfirmation
    a noria:EventRecord ;
    rdfs:label "Interface Up Confirmation Event"@en ;
    rdfs:comment "Event confirming the network interface is back up after restart."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to up."^^xsd:string ;
    noria:logOriginatingManagedObject noria-inst:CoreRouter01 ;
    noria:logOriginatingManagementSystem noria-inst:MonitoringDashboard ;
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Warning ;
    noria:alarmMitigatedBy noria-inst:DiagnosisProcedureExecution .

noria-inst:ChangeAction_SoftwareUpgrade
    a pep:ChangeAction ;
    rdfs:label "Change Action: Router Software Upgrade"@en ;
    rdfs:comment "An action taken to upgrade the software on Core Router 01."@en ;
    noria:actionCorrelatedOperationPlan noria-inst:RouterSoftwareUpgradePlan ;
    pep:hasInput noria-inst:CoreRouter01 ;
    pep:hasOutput noria-inst:EventRecord_UpgradeCompletion .

noria-inst:RouterSoftwareUpgradePlan
    a noria:OperationPlan, pep:Procedure ;
    rdfs:label "Router Software Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for upgrading router software."@en ;
    noria:operationPlanPreCondition noria-inst:PreCond_BackupComplete ;
    noria:operationPlanPostCondition noria-inst:PostCond_NewSoftwareActive .

noria-inst:PreCond_BackupComplete
    a noria:ActionPreCondition ;
    rdfs:label "Pre-condition: Configuration Backup Complete"@en ;
    rdfs:comment "Ensures a backup of the router configuration is completed before upgrade."@en .

noria-inst:PostCond_NewSoftwareActive
    a noria:ActionPostCondition ;
    rdfs:label "Post-condition: New Software Version Active"@en ;
    rdfs:comment "Verifies that the router is running the new software version."@en .

noria-inst:EventRecord_UpgradeCompletion
    a noria:EventRecord ;
    rdfs:label "Router Software Upgrade Completion Event"@en ;
    rdfs:comment "Event confirming successful software upgrade on Core Router 01."@en ;
    noria:loggingTime "2024-05-01T03:45:00Z"^^xsd:dateTime ;
    noria:logText "Router software upgrade completed successfully on cr01.paris.example.com to version 17.6.1."^^xsd:string ;
    noria:logOriginatingManagedObject noria-inst:CoreRouter01 ;
    noria:logOriginatingManagementSystem noria-inst:AutomatedSystemAgent ;
    noria:alarmSeverity noria-kos:Notification/Severity/PerceivedSeverity/Warning .

