# --- Organizational Entities ---

noria-inst:OrangeCorp
    a org:Organization ;
    rdfs:label "Orange Corporation"@en ;
    rdfs:comment "The main corporate entity."@en ;
    org:hasUnit noria-inst:NetworkOperationsUnit, noria-inst:ApplicationDevelopmentUnit .

noria-inst:NetworkOperationsUnit
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Unit"@en ;
    rdfs:comment "Unit responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentInstructions "For critical issues, call hotline. For non-critical, use ticketing system."@en ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone .

noria-inst:ApplicationDevelopmentUnit
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Unit"@en ;
    rdfs:comment "Unit responsible for developing and maintaining applications."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"@en ;
    noria:agentInstructions "Submit requests via JIRA."@en ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-inst:JohnDoe
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A network engineer in the Network Operations Unit."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    org:memberOf noria-inst:NetworkOperationsUnit ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentInstructions "Contact via internal chat for urgent matters."@en ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-inst:JaneSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "An application developer in the Application Development Unit."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    org:memberOf noria-inst:ApplicationDevelopmentUnit ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"@en ;
    noria:agentInstructions "Use project management tool for task assignments."@en ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-inst:AutomatedSystemAgent
    a foaf:Agent ;
    rdfs:label "Automated System Agent"@en ;
    rdfs:comment "An automated system responsible for certain operations."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentInstructions "Logs all actions to central system."@en ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-inst:JDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "The corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe123"^^xsd:string ;
    observable:accountLogin "jdoe123"^^xsd:string ;
    observable:accountIdentifier "UUID-JD-12345"^^xsd:string .

noria-inst:JaneSmithCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "The corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith456"^^xsd:string ;
    observable:accountLogin "jsmith456"^^xsd:string ;
    observable:accountIdentifier "UUID-JS-67890"^^xsd:string .

# --- Location Entities ---

noria-inst:DataCenterParis
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Main data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string ;
    bot:hasSpace noria-inst:ServerRoomA, noria-inst:NetworkRoomB .

noria-inst:ServerRoomA
    a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "A server room within the Paris Data Center."@en ;
    bot:hasSpace noria-inst:Rack1Locus, noria-inst:Rack2Locus .

noria-inst:NetworkRoomB
    a noria:Room ;
    rdfs:label "Network Room B"@en ;
    rdfs:comment "A network equipment room within the Paris Data Center."@en ;
    bot:hasSpace noria-inst:CoreRouterLocus .

noria-inst:Rack1Locus
    a noria:Locus ;
    rdfs:label "Rack 1, Row C"@en ;
    rdfs:comment "Specific location for Rack 1 in Server Room A."@en ;
    noria:locusLine "C"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

noria-inst:Rack2Locus
    a noria:Locus ;
    rdfs:label "Rack 2, Row C"@en ;
    rdfs:comment "Specific location for Rack 2 in Server Room A."@en ;
    noria:locusLine "C"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

noria-inst:CoreRouterLocus
    a noria:Locus ;
    rdfs:label "Core Router Rack, Row A"@en ;
    rdfs:comment "Specific location for core network equipment in Network Room B."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "5"^^xsd:string .

# --- Product Models ---

noria-inst:CiscoASR9K
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series"@en ;
    rdfs:comment "Product model for Cisco ASR 9000 series routers."@en ;
    noria:productManufacturedBy noria-inst:CiscoSystems .

noria-inst:DellPowerEdge
    a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "Product model for Dell PowerEdge R740 servers."@en ;
    noria:productManufacturedBy noria-inst:DellTechnologies .

noria-inst:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of network equipment."@en .

noria-inst:DellTechnologies
    a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server and IT equipment."@en .

# --- Structural Elements ---

noria-inst:CoreRouter01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router in Paris Data Center."@en ;
    noria:resourceLogisticId "LOG-CR-01-PAR"^^xsd:string ;
    noria:resourceHostName "cr01.paris.example.com"^^xsd:string ;
    noria:resourceProductModel noria-inst:CiscoASR9K ;
    noria:resourceType noria-kos:Resource/type/Router ;
    noria:resourceSerialNumber "ABC12345DEF"^^xsd:string ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/Production ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria-inst:NetworkOperationsUnit ;
    noria:locatedAtLocus noria-inst:CoreRouterLocus ;
    noria:resourceManagementIPAddress <http://10.0.0.1> ;
    noria:virtualServerStatus noria-kos:Resource/OperationalState/Up .

noria-inst:AppServer01
    a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting critical applications."@en ;
    noria:resourceLogisticId "LOG-AS-01-PAR"^^xsd:string ;
    noria:resourceHostName "appserver01.example.com"^^xsd:string ;
    noria:resourceProductModel noria-inst:DellPowerEdge ;
    noria:resourceType noria-kos:Resource/type/Server ;
    noria:resourceSerialNumber "GHI67890JKL"^^xsd:string ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/Production ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria-inst:ApplicationDevelopmentUnit ;
    noria:locatedAtLocus noria-inst:Rack1Locus ;
    noria:resourceManagementIPAddress <http://192.168.1.10> ;
    noria:virtualServerStatus noria-kos:Resource/OperationalState/Up .

noria-inst:AppServer02
    a noria:Resource ;
    rdfs:label "Application Server 02"@en ;
    rdfs:comment "Secondary server for application redundancy."@en ;
    noria:resourceLogisticId "LOG-AS-02-PAR"^^xsd:string ;
    noria:resourceHostName "appserver02.example.com"^^xsd:string ;
    noria:resourceProductModel noria-inst:DellPowerEdge ;
    noria:resourceType noria-kos:Resource/type/Server ;
    noria:resourceSerialNumber "MNO12345PQR"^^xsd:string ;
    noria:resourceUsageState noria-kos:Resource/LifecycleState/Staging ;
    noria:resourceInstallationDate "2021-04-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria-inst:ApplicationDevelopmentUnit ;
    noria:locatedAtLocus noria-inst:Rack2Locus ;
    noria:resourceManagementIPAddress <http://192.168.1.11> ;
    noria:clusterController noria-inst:AppServer01 ;
    noria:virtualServerStatus noria-kos:Resource/OperationalState/Down .

noria-inst:CoreRouter01_GE0_0_0
    a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Network interface GE0/0/0 on Core Router 01."@en ;
    noria:networkInterfaceOf noria-inst:CoreRouter01 ;
    noria:networkInterfaceDescription "Uplink to ISP A"^^xsd:string ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus noria-kos:Resource/AdministrativeState/Enabled ;
    noria:networkInterfaceOperationalStatus noria-kos:Resource/OperationalState/Up ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-8"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-7"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-15"^^xsd:int .

noria-inst:CoreRouter01_GE0_0_1
    a noria:NetworkInterface ;
    rdfs:label "Core Router 01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Network interface GE0/0/1 on Core Router 01."@en ;
    noria:networkInterfaceOf noria-inst:CoreRouter01 ;
    noria:networkInterfaceDescription "Link to AppServer01"^^xsd:string ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus noria-kos:Resource/AdministrativeState/Enabled ;
    noria:networkInterfaceOperationalStatus noria-kos:Resource/OperationalState/Up ;
    noria:networkInterfaceRoutingPriorityMetric "10"^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

noria-inst:AppServer01_Eth0
    a noria:NetworkInterface ;
    rdfs:label "App Server 01 Ethernet0"@en ;
    rdfs:comment "Ethernet interface 0 on Application Server 01."@en ;
    noria:networkInterfaceOf noria-inst:AppServer01 ;
    noria:networkInterfaceDescription "Primary network interface"^^xsd:string ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus noria-kos:Resource/AdministrativeState/Enabled ;
    noria:networkInterfaceOperationalStatus noria-kos:Resource/OperationalState/Up .

noria-inst:WANLinkParisLondon
    a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-London"@en ;
    rdfs:comment "High-capacity WAN link connecting Paris and London data centers."@en ;
    noria:networkLinkId "WAN-PAR-LON-001"^^xsd:string ;
    noria:networkLinkInstallationDate "2019-08-01T00:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic"^^xsd:string ;
