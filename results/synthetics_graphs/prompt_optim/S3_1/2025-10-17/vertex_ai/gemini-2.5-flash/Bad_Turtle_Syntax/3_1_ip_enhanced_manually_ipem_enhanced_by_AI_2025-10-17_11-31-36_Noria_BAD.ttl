# KOS Concepts (Knowledge Organization System)
# These are required as ranges for many noria:ObjectProperty definitions.

noria-kos:ApplicationType_ServicePlatform
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Service Platform"@en ;
    rdfs:comment "A type of application that provides a platform for other services."@en .

noria-kos:ApplicationType_Infrastructure
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Infrastructure Application"@en ;
    rdfs:comment "A type of application that manages core infrastructure components."@en .

noria-kos:ApplicationBusinessImportance_High
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Indicates a critical application with high business impact."@en .

noria-kos:ApplicationBusinessImportance_Medium
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "Medium Business Importance"@en ;
    rdfs:comment "Indicates an application with moderate business impact."@en .

noria-kos:ApplicationModuleSlaLevel_Gold
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement tier."@en .

noria-kos:ApplicationModuleSlaLevel_Silver
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Silver SLA Level"@en ;
    rdfs:comment "Standard Service Level Agreement tier."@en .

noria-kos:ApplicationModuleStatus_InProduction
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently active in a production environment."@en .

noria-kos:ApplicationModuleStatus_Maintenance
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Under Maintenance"@en ;
    rdfs:comment "The application module is currently undergoing maintenance."@en .

noria-kos:ServiceType_CustomerFacing
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by external customers."@en .

noria-kos:ServiceType_ResourceFacing
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations."@en .

