# Instances for noria:EventRecord
noria-inst:Event_RouterDown_20240101
    a noria:EventRecord ;
    rdfs:label "Router Core 01 Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on Core Router 01."@en ;
    noria:loggingTime "2024-01-01T10:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject noria-inst:Router_Core_01 ;
    noria:logOriginatingManagementSystem noria-inst:NMS_System ;
    noria:alarmSeverity noria-kos:AlarmSeverity_Critical ;
    noria:alarmProposedRepairAction noria-inst:CheckFiberConnectionProcedure ;
    noria:alarmMonitoredAttribute [
        rdfs:label "Interface Status"^^xsd:string ;
        rdf:value "down"^^xsd:string ;
        dcterms:date "2024-01-01T10:00:00Z"^^xsd:dateTime ;
        rdfs:comment "Monitored attribute: operational status of the interface."@en
    ] ;
    noria:alarmMitigatedBy noria-inst:FiberRepairProcedureExecution .

