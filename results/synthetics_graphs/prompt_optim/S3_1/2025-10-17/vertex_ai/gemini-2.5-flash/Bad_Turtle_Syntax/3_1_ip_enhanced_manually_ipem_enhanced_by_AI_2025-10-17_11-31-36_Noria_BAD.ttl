noria-inst:JaneSmith_CUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Unique corporate identifier for Jane Smith."@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountLogin "jsmith"^^xsd:string ;
    observable:accountIdentifier "EMP-JS-002"^^xsd:string ;
    foaf:holdsAccount noria-inst:JaneSmith .

# Instances for bot:Site, noria:Room, noria:Locus
noria-inst:DataCenter_Paris
