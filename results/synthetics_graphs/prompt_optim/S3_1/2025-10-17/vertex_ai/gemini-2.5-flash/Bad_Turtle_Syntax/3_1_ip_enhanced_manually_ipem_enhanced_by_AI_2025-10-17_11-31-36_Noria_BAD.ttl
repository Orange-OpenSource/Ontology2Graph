# Instances for foaf:Agent (Person and Group) and org:Organization, org:OrganizationalUnit
noria-inst:JohnDoe
    a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A fictional employee, IT administrator."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:AgentContactMethod_Email .

noria-inst:JaneSmith
    a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "A fictional employee, network engineer."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "8:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Always use ticketing system first, then call."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:AgentContactMethod_Phone .

noria-inst:AliceJohnson
    a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Senior Network Architect."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    foaf:phone "+1-555-222-3333" ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "For design queries, schedule a meeting."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:AgentContactMethod_Email .

noria-inst:ITOperationsTeam
    a foaf:Group, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en ;
    rdfs:comment "Team responsible for daily IT operations and incident management."@en ;
    org:unitOf noria-inst:GlobalTechCorp ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Follow escalation matrix for critical incidents."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:AgentContactMethod_Phone .

noria-inst:NetworkEngineeringDept
    a foaf:Group, org:OrganizationalUnit ;
    rdfs:label "Network Engineering Department"@en ;
    rdfs:comment "Department responsible for network design and maintenance."@en ;
    org:unitOf noria-inst:GlobalTechCorp ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Submit change requests via portal."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:AgentContactMethod_Email .

noria-inst:CustomerSupportTeam
    a foaf:Group, org:OrganizationalUnit ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "First-line support for customer inquiries."@en ;
    org:unitOf noria-inst:GlobalTechCorp ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Log all customer interactions in CRM."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:AgentContactMethod_Phone .

noria-inst:Monitoring_Bot
    a foaf:Agent ;
    rdfs:label "Monitoring Bot"@en ;
    rdfs:comment "Automated agent for system monitoring and alerting."@en .

noria-inst:GlobalTechCorp
    a org:Organization ;
    rdfs:label "GlobalTech Corp"@en ;
    rdfs:comment "A global technology corporation."@en .

noria-inst:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "A global technology conglomerate that designs, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

noria-inst:DellTechnologies
    a org:Organization ;
    rdfs:label "Dell Technologies Inc."@en ;
    rdfs:comment "An American multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

noria-inst:JuniperNetworks
    a org:Organization ;
    rdfs:label "Juniper Networks Inc."@en ;
    rdfs:comment "A multinational corporation that develops and markets networking products."@en .

noria-inst:HPE
    a org:Organization ;
