    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject noria-inst:Router01 ;
    noria:logOriginatingManagementSystem noria-inst:MonitoringApp ;
    noria:alarmSeverity noria-inst:AlarmSeverity_Critical ;
    noria:alarmProposedRepairAction noria-inst:RestartInterfaceProcedure ;
    noria:alarmMonitoredAttribute <http://example.com/monitoredAttribute/interfaceStatus> ;
