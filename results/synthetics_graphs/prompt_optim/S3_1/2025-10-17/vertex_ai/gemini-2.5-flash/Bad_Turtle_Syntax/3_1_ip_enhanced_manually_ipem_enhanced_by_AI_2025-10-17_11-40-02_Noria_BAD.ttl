    noria:changeRequestInitiatorParty noria-inst:PeterJones ;
    noria:changeRequestPilotParty noria-inst:PeterJones ;
    noria:changeRequestActorParty noria-inst:DevOpsTeam ;
    noria:changeRequestIsRegulated false^^xsd:boolean ;
    noria:documentStatusHistory noria-inst:CR_20240501_002_StartEvent ;
    noria:documentStatusHistory noria-inst:CR_20240501_002_EndEvent .

# --- Operation Plans, Pre/Post Conditions, Anomaly Patterns ---
noria-inst:RestartInterfaceProcedure
    a noria:OperationPlan, pep:Procedure ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a network interface."@en ;
    noria:operationPlanPreCondition noria-inst:InterfaceDownPreCondition ;
    noria:operationPlanPostCondition noria-inst:InterfaceUpPostCondition .

noria-inst:RollbackProcedure
    a noria:OperationPlan, pep:Procedure ;
    rdfs:label "Application Rollback Procedure"@en ;
    rdfs:comment "Procedure to rollback an application to a previous stable version."@en ;
    noria:operationPlanPreCondition noria-inst:HighCPUPPreCondition ;
    noria:operationPlanPostCondition noria-inst:NormalCPUPPostCondition .

noria-inst:ExpandStorageProcedure
    a noria:OperationPlan, pep:Procedure ;
    rdfs:label "Expand Storage Procedure"@en ;
    rdfs:comment "Procedure for adding and configuring new storage to a server."@en ;
    noria:operationPlanPreCondition <http://example.com/precondition/disk_full_alert> ;
    noria:operationPlanPostCondition <http://example.com/postcondition/disk_space_available> .

noria-inst:InterfaceDownPreCondition
    a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition: network interface operational status is 'down'."@en .

noria-inst:InterfaceUpPostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-Condition"@en ;
    rdfs:comment "Post-condition: network interface operational status is 'up'."@en .

noria-inst:HighCPUPPreCondition
    a noria:ActionPreCondition ;
    rdfs:label "High CPU Usage Pre-Condition"@en ;
    rdfs:comment "Pre-condition: CPU usage on server is consistently high."@en .

noria-inst:NormalCPUPPostCondition
    a noria:ActionPostCondition ;
    rdfs:label "Normal CPU Usage Post-Condition"@en ;
    rdfs:comment "Post-condition: CPU usage on server returns to normal levels."@en .

<http://example.com/precondition/disk_full_alert>
    a noria:ActionPreCondition ;
    rdfs:label "Disk Full Alert Pre-Condition"@en ;
    rdfs:comment "Pre-condition: A critical alert for disk space usage has been triggered."@en .

<http://example.com/postcondition/disk_space_available>
    a noria:ActionPostCondition ;
    rdfs:label "Sufficient Disk Space Post-Condition"@en ;
    rdfs:comment "Post-condition: Sufficient disk space is available after the operation."@en .

noria-inst:FiberCutAnomaly
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "Fiber Cut Anomaly Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating a physical fiber cut, often detected by loss of optical signal."@en .

noria-inst:SoftwareBugAnomaly
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "Software Bug Anomaly Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating a software bug causing performance issues or crashes."@en .

noria-inst:DiskFullAnomaly
    a noria:AnomalyPattern, folio:FailureMode ;
    rdfs:label "Disk Full Anomaly Pattern"@en ;
    rdfs:comment "Anomaly pattern indicating critical disk space usage."@en .

noria-inst:RollbackProcedureExecution
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Rollback Procedure Execution for TT-20240420-002"@en ;
    rdfs:comment "Container for the execution of the application rollback procedure."@en ;
    pep:usedProcedure noria-inst:RollbackProcedure ;
    pep:hasOutput noria-inst:NormalCPUPPostCondition .

noria-inst:InterfaceRestartExecution
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Interface Restart Execution for RouterDownEvent"@en ;
    rdfs:comment "Execution container for restarting the network interface."@en ;
    pep:usedProcedure noria-inst:RestartInterfaceProcedure ;
    pep:hasOutput noria-inst:InterfaceUpPostCondition .

noria-inst:CorrectiveAction_RouterRestart
    a pep:ProcedureExecution ;
    rdfs:label "Corrective Action: Router Interface Restart"@en ;
    rdfs:comment "An execution of a corrective action to restart a router interface."@en ;
    noria:actionCorrelatedOperationPlan noria-inst:RestartInterfaceProcedure .

noria-inst:ChangeAction_OSUpgrade
    a pep:ProcedureExecution ;
    rdfs:label "Change Action: Router OS Upgrade Execution"@en ;
    rdfs:comment "An execution of a change action for router OS upgrade."@en ;
    noria:actionCorrelatedOperationPlan noria-inst:RestartInterfaceProcedure . # Reusing for simplicity, could be a dedicated OS upgrade procedure.
