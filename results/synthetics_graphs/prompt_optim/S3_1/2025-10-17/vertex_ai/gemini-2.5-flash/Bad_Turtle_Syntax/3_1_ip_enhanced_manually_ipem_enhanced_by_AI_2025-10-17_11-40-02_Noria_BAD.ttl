# --- Organizations and Agents ---
noria-inst:OrangeIT
    a org:Organization ;
    rdfs:label "Orange IT Department"@en ;
    rdfs:comment "The main IT organization within Orange."@en .

noria-inst:NetworkOpsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure operations."@en ;
    org:unitOf noria-inst:OrangeIT .

noria-inst:AppDevTeam
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining applications."@en ;
    org:unitOf noria-inst:OrangeIT .

noria-inst:SecurityOpsTeam
    a org:OrganizationalUnit ;
    rdfs:label "Security Operations Team"@en ;
    rdfs:comment "Team responsible for cybersecurity operations."@en ;
    org:unitOf noria-inst:OrangeIT .

noria-inst:CustomerSupportTeam
    a org:OrganizationalUnit ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "Team responsible for first-level customer support."@en ;
    org:unitOf noria-inst:OrangeIT .

noria-inst:DevOpsTeam
    a org:OrganizationalUnit ;
    rdfs:label "DevOps Team"@en ;
    rdfs:comment "Team responsible for development and operations integration."@en ;
    org:unitOf noria-inst:OrangeIT .

noria-inst:CiscoSystems
    a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria-inst:HPE
    a org:Organization ;
    rdfs:label "Hewlett Packard Enterprise"@en ;
    rdfs:comment "Manufacturer of server hardware."@en .

noria-inst:JohnDoe
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Network Engineer, team lead for Network Operations."@en ;
    org:memberOf noria-inst:NetworkOpsTeam ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:ContactMethod_Email ;
    noria:agentInstructions "Contact via email for non-urgent issues, phone for critical alerts."^^xsd:string ;
    foaf:mbox <mailto:john.doe@orange.com> ;
    foaf:phone "+33123456789"^^xsd:string .

noria-inst:JaneSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer, team lead for App Development."@en ;
    org:memberOf noria-inst:AppDevTeam ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:ContactMethod_Phone ;
    noria:agentInstructions "Use ticketing system for all requests, escalate via phone for P1 incidents."^^xsd:string ;
    foaf:mbox <mailto:jane.smith@orange.com> ;
    foaf:phone "+33987654321"^^xsd:string .

noria-inst:AliceJohnson
    a foaf:Person, foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Security Analyst, member of Security Operations Team."@en ;
    org:memberOf noria-inst:SecurityOpsTeam ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:ContactMethod_Email ;
    noria:agentInstructions "All security incidents must be reported via the dedicated security portal."^^xsd:string .

noria-inst:MarkWhite
    a foaf:Person, foaf:Agent ;
    rdfs:label "Mark White"@en ;
    rdfs:comment "Customer Support Agent."@en ;
    org:memberOf noria-inst:CustomerSupportTeam ;
    noria:agentWorkingHours "8:00-16:00 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:ContactMethod_Phone ;
    noria:agentInstructions "Direct customer contact for initial triage."^^xsd:string .

noria-inst:PeterJones
    a foaf:Person, foaf:Agent ;
    rdfs:label "Peter Jones"@en ;
    rdfs:comment "DevOps Engineer."@en ;
    org:memberOf noria-inst:DevOpsTeam ;
    noria:agentWorkingHours "9:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentPreferredContactMethod noria-inst:ContactMethod_Email ;
    noria:agentInstructions "Automated alerts are preferred for system issues."^^xsd:string .

noria-inst:ExternalContractor
    a foaf:Agent ;
    rdfs:label "External Contractor"@en ;
    rdfs:comment "An external party involved in a trouble ticket resolution."@en .

noria-inst:JohnDoeCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate User ID"@en ;
    rdfs:comment "Corporate identifier for John Doe."@en ;
    foaf:accountName "jdoe_netops"^^xsd:string ;
    observable:accountLogin "jdoe_netops"^^xsd:string ;
    observable:accountIdentifier "CU-JD-001"^^xsd:string .

noria-inst:JaneSmithCUid
    a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate User ID"@en ;
    rdfs:comment "Corporate identifier for Jane Smith."@en ;
    foaf:accountName "jsmith_appdev"^^xsd:string ;
    observable:accountLogin "jsmith_appdev"^^xsd:string ;
    observable:accountIdentifier "CU-JS-002"^^xsd:string .

# --- Locations ---
noria-inst:ParisDC
    a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix"^^xsd:string .

noria-inst:RoomA101
    a noria:Room ;
    rdfs:label "Server Room A101"@en ;
    rdfs:comment "Main server room in Paris Data Center."@en ;
    bot:hasSpace noria-inst:ParisDC .

noria-inst:RoomB202
    a noria:Room ;
    rdfs:label "Network Equipment Room B202"@en ;
    rdfs:comment "Secondary network equipment room in Paris Data Center."@en ;
    bot:hasSpace noria-inst:ParisDC .

noria-inst:LocusR12C05
    a noria:Locus ;
    rdfs:label "Rack 12, Column 05"@en ;
    rdfs:comment "Specific location within Server Room A101."@en ;
    noria:locusLine "R12"^^xsd:string ;
    noria:locusRow "C05"^^xsd:string ;
    bot:hasSpace noria-inst:RoomA101 .

noria-inst:LocusR15C08
    a noria:Locus ;
    rdfs:label "Rack 15, Column 08"@en ;
    rdfs:comment "Specific location within Server Room A101."@en ;
    noria:locusLine "R15"^^xsd:string ;
    noria:locusRow "C08"^^xsd:string ;
    bot:hasSpace noria-inst:RoomA101 .

noria-inst:LocusN01R03
    a noria:Locus ;
    rdfs:label "Network Rack 01, Row 03"@en ;
    rdfs:comment "Specific location within Network Equipment Room B202."@en ;
    noria:locusLine "N01"^^xsd:string ;
    noria:locusRow "R03"^^xsd:string ;
    bot:hasSpace noria-inst:RoomB202 .

# --- Product Models ---
noria-inst:CiscoASR9K
    a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series"@en ;
    rdfs:comment "Product model for Cisco ASR 9000 series routers."@en ;
    noria:productManufacturedBy noria-inst:CiscoSystems .

noria-inst:HPProLiantDL380
    a noria:ProductModel ;
    rdfs:label "HP ProLiant DL380 Gen10"@en ;
    rdfs:comment "Product model for HP ProLiant DL380 Gen10 servers."@en ;
    noria:productManufacturedBy noria-inst:HPE .

# --- Resources ---
noria-inst:Router01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router in Paris Data Center."@en ;
    noria:elementDistinguishedName "router01.noria.net"^^xsd:string ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
