    noria:resourceSerialNumber "MNO12345PQR"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2020-02-01T11:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication :App_CoreNetwork ;
    noria:locatedAtLocus :Locus_RackN1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.2> ;
    noria:resourceManagedBy :OrgUnit_NetworkTeam .

:Resource_ClusterController01
    a noria:Resource ;
    rdfs:label "Virtualization Cluster Controller 01"@en ;
    rdfs:comment "Manages the virtualization cluster for application servers."@en ;
    noria:resourceHostName "vcc01.dc-a.example.com"^^xsd:string ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceManagedBy :OrgUnit_AppSupportTeam .

:Resource_VirtualServer01
    a noria:Resource ;
