# --- noria:NetworkInterface instances ---

:NI_Router01_GE0_0_1
    a noria:NetworkInterface ;
    rdfs:label "Router01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Network interface on Router01 connecting to Switch01."@en ;
    noria:networkInterfaceOf :Resource_Router01 ;
