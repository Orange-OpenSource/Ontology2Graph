# --- noria:Resource instances ---

:Resource_Router01
    a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Primary core router in Data Center A."@en ;
    noria:resourceLogisticId "LOG-RTR-001"^^xsd:string ;
    noria:resourceHostName "router01.dc-a.example.com"^^xsd:string ;
    noria:resourceProductModel :ProductModel_Cisco3850 ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "ABC12345DEF"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2020-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication :App_CoreNetwork ;
    noria:locatedAtLocus :Locus_RackN1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.1> ;
    noria:resourceManagedBy :OrgUnit_NetworkTeam ;
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

:Resource_Server01
    a noria:Resource ;
    rdfs:label "Application Server 01"@en ;
    rdfs:comment "Server hosting the CRM application."@en ;
    noria:resourceLogisticId "LOG-SRV-001"^^xsd:string ;
    noria:resourceHostName "appserver01.dc-a.example.com"^^xsd:string ;
    noria:resourceProductModel :ProductModel_HPProLiantDL380 ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "GHI67890JKL"^^xsd:string ;
    noria:resourceUsageState <kos/Resource/LifecycleState/Production> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication :App_CRM ;
    noria:locatedAtLocus :Locus_RackA1 ;
    noria:resourceManagementIPAddress <http://example.com/ip/10.0.0.10> ;
    noria:resourceManagedBy :OrgUnit_AppSupportTeam .

:Resource_Switch01
    a noria:Resource ;
    rdfs:label "Access Switch 01"@en ;
    rdfs:comment "Access layer switch in Data Center A, connected to servers."@en ;
    noria:resourceLogisticId "LOG-SWT-001"^^xsd:string ;
    noria:resourceHostName "switch01.dc-a.example.com"^^xsd:string ;
    noria:resourceProductModel :ProductModel_Cisco3850 ;
