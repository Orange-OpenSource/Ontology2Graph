# --- foaf:Agent, org:Organization, org:OrganizationalUnit instances ---

:Agent_JohnDoe
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A fictional employee, acting as an agent in the system."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters, phone for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

:Agent_JaneSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Another fictional employee, a technical lead."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Always available for P1 incidents."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

:Org_ITOperations
    a org:Organization ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The main IT operations organization responsible for infrastructure."@en ;
    org:hasUnit :OrgUnit_NetworkTeam, :OrgUnit_AppSupportTeam .

:OrgUnit_NetworkTeam
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    org:unitOf :Org_ITOperations ;
    noria:agentWorkingHours "24/7 Shift Rotation"^^xsd:string ;
    noria:agentInstructions "Follow incident management procedures for all network alerts."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentManagesResource :Resource_Router01, :Resource_Switch01 .

:OrgUnit_AppSupportTeam
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting critical business applications."@en ;
    org:unitOf :Org_ITOperations ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri, On-call"^^xsd:string ;
    noria:agentInstructions "Escalate to L3 for complex application issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentManagesResource :App_CRM, :App_MonitoringSystem .

:Org_VendorA
    a org:Organization ;
    rdfs:label "Vendor A Inc."@en ;
    rdfs:comment "A third-party vendor providing network equipment."@en .

# --- bot:Site, noria:Room, noria:Locus instances ---

:Site_DataCenterA
    a bot:Site ;
    rdfs:label "Primary Data Center A"@en ;
    rdfs:comment "Main data center facility for core services."@en ;
    noria:siteId "DC-A-001"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Tech Avenue"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Metropolis"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Tech Avenue"^^xsd:string ;
    bot:hasSpace :Room_ServerRoom1, :Room_NetworkRoom1 .

:Room_ServerRoom1
    a noria:Room ;
    rdfs:label "Server Room 1"@en ;
    rdfs:comment "A room within Data Center A dedicated to server racks."@en ;
    bot:hasSpace :Locus_RackA1, :Locus_RackA2 .

:Room_NetworkRoom1
    a noria:Room ;
    rdfs:label "Network Room 1"@en ;
    rdfs:comment "A room within Data Center A dedicated to network equipment."@en ;
    bot:hasSpace :Locus_RackN1 .

:Locus_RackA1
    a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Specific location for server rack A1 in Server Room 1."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

:Locus_RackA2
    a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Specific location for server rack A2 in Server Room 1."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

:Locus_RackN1
    a noria:Locus ;
    rdfs:label "Rack N1"@en ;
    rdfs:comment "Specific location for network rack N1 in Network Room 1."@en ;
    noria:locusLine "N"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

