# --- SKOS Concepts for various KOS schemes ---

# KOS: kos/application/type
<kos/application/type/ServicePlatform>
    a skos:Concept ;
    rdfs:label "Service Platform Application Type"@en ;
    rdfs:comment "Represents an application that provides a service platform."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/Infrastructure>
    a skos:Concept ;
    rdfs:label "Infrastructure Application Type"@en ;
    rdfs:comment "Represents an application that manages infrastructure components."@en ;
    skos:inScheme <kos/application/type> .

<kos/application/type/Business>
    a skos:Concept ;
    rdfs:label "Business Application Type"@en ;
    rdfs:comment "Represents an application directly supporting business operations."@en ;
    skos:inScheme <kos/application/type> .

# KOS: kos/application/business-importance
<kos/application/business-importance/Critical>
    a skos:Concept ;
    rdfs:label "Critical Business Importance"@en ;
    rdfs:comment "Application is critical for business operations, high impact on failure."@en ;
    skos:inScheme <kos/application/business-importance> .

<kos/application/business-importance/High>
    a skos:Concept ;
    rdfs:label "High Business Importance"@en ;
    rdfs:comment "Application has high business importance, significant impact on failure."@en ;
    skos:inScheme <kos/application/business-importance> .

# KOS: kos/application/sla-level
<kos/application/sla-level/Platinum>
    a skos:Concept ;
    rdfs:label "Platinum SLA Level"@en ;
    rdfs:comment "Highest Service Level Agreement tier, maximum availability and performance."@en ;
    skos:inScheme <kos/application/sla-level> .

<kos/application/sla-level/Gold>
    a skos:Concept ;
    rdfs:label "Gold SLA Level"@en ;
    rdfs:comment "High Service Level Agreement tier, strong availability and performance."@en ;
    skos:inScheme <kos/application/sla-level> .

# KOS: kos/application/status
<kos/application/status/Production>
    a skos:Concept ;
    rdfs:label "Production Status"@en ;
    rdfs:comment "Application is currently in production and serving live users."@en ;
    skos:inScheme <kos/application/status> .

<kos/application/status/Development>
    a skos:Concept ;
    rdfs:label "Development Status"@en ;
    rdfs:comment "Application is under active development."@en ;
    skos:inScheme <kos/application/status> .

# KOS: kos/service/type
<kos/service/type/CustomerFacingService>
    a skos:Concept ;
    rdfs:label "Customer Facing Service Type"@en ;
    rdfs:comment "Service directly exposed to and consumed by customers."@en ;
    skos:inScheme <kos/service/type> .

<kos/service/type/ResourceFacingService>
    a skos:Concept ;
    rdfs:label "Resource Facing Service Type"@en ;
    rdfs:comment "Service that manages internal resources, not directly exposed to customers."@en ;
    skos:inScheme <kos/service/type> .

# KOS: kos/TroubleTicket/severity
<kos/TroubleTicket/severity/Critical>
    a skos:Concept ;
    rdfs:label "Critical Trouble Ticket Severity"@en ;
    rdfs:comment "Indicates a critical impact on service, requiring immediate attention."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

<kos/TroubleTicket/severity/Major>
    a skos:Concept ;
    rdfs:label "Major Trouble Ticket Severity"@en ;
    rdfs:comment "Indicates a major impact on service, requiring urgent attention."@en ;
    skos:inScheme <kos/TroubleTicket/severity> .

