# --- noria:NetworkLink instances ---

:NL_Router01_Switch01
    a noria:NetworkLink ;
    rdfs:label "Link Router01-Switch01"@en ;
    rdfs:comment "Physical link between Core Router 01 and Access Switch 01."@en ;
