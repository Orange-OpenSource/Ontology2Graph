# --- Agents and Organizations ---

<https://w3id.org/noria/data/agent/john-doe>
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A senior network engineer responsible for core infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent issues, phone for critical alerts."^^xsd:string ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/email> ;
    foaf:mbox <mailto:john.doe@example.com> .

<https://w3id.org/noria/data/agent/jane-smith>
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
