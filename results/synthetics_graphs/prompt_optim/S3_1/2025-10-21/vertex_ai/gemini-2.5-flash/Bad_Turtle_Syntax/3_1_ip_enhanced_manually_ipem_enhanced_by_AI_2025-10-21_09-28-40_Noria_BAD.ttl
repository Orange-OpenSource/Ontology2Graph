    observable:ipAddressType "IPv4"^^xsd:string .

observable:ipv4-10-0-0-4
    a observable:IPAddress ;
    rdfs:label "IP Address 10.0.0.4"@en ;
    rdfs:comment "Management IP address for Database Server 02."@en ;
    observable:ipAddressValue "10.0.0.4"^^xsd:string ;
    observable:ipAddressType "IPv4"^^xsd:string .

observable:ipv4-10-0-0-5
    a observable:IPAddress ;
