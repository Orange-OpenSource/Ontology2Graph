# --- Anomaly Patterns ---

<https://w3id.org/noria/data/anomalypattern/high-cpu-low-traffic>
    a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Traffic Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating high CPU usage on a network device despite low traffic, potentially signaling a software bug or attack."@en ;
    folio:hasConsequence <https://w3id.org/noria/data/troubleticket/tt-20240420-001> .

<https://w3id.org/noria/data/anomalypattern/repeated-login-failures>
    a noria:AnomalyPattern ;
    rdfs:label "Repeated Login Failures Anomaly"@en ;
    rdfs:comment "Anomaly pattern for multiple consecutive failed login attempts from a single source, indicating a brute-force attack."@en ;
    folio:hasConsequence <https://w3id.org/noria/data/event/user-login-failure> .

<https://w3id.org/noria/data/anomalypattern/db-replication-failure>
    a noria:AnomalyPattern ;
    rdfs:label "Database Replication Failure Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating a critical failure in database replication, leading to data inconsistency."@en ;
    folio:hasConsequence <https://w3id.org/noria/data/troubleticket/tt-20240421-002> .

<https://w3id.org/noria/data/anomalypattern/connection-pool-exhaustion>
    a noria:AnomalyPattern ;
    rdfs:label "Connection Pool Exhaustion Anomaly"@en ;
    rdfs:comment "Anomaly pattern indicating that an application's database connection pool is frequently exhausted, leading to service degradation."@en ;
    folio:hasConsequence <https://w3id.org/noria/data/troubleticket/tt-20240422-003> .

