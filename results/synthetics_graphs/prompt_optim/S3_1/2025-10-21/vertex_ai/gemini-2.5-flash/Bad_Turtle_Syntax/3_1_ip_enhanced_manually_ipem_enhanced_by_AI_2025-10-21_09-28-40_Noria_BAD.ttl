# --- KOS Concepts ---

# KOS Concepts for Application Type
<https://w3id.org/noria/kos/application/type/web-service>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Web Service"@en ;
    rdfs:comment "A web-based application providing services over HTTP/HTTPS."@en .

<https://w3id.org/noria/kos/application/type/database>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Database"@en ;
    rdfs:comment "An application primarily for data storage and retrieval."@en .

<https://w3id.org/noria/kos/application/type/monitoring-tool>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/type> ;
    rdfs:label "Monitoring Tool"@en ;
    rdfs:comment "An application used for system and network monitoring."@en .

# KOS Concepts for Application Business Importance
<https://w3id.org/noria/kos/application/business-importance/critical>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "Critical"@en ;
    rdfs:comment "Application is critical for business operations, high impact on failure."@en .

<https://w3id.org/noria/kos/application/business-importance/high>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/business-importance> ;
    rdfs:label "High"@en ;
    rdfs:comment "Application is important for business operations, significant impact on failure."@en .

# KOS Concepts for Application SLA Level
<https://w3id.org/noria/kos/application/sla-level/platinum>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Platinum SLA"@en ;
    rdfs:comment "Highest Service Level Agreement, maximum availability and performance."@en .

<https://w3id.org/noria/kos/application/sla-level/gold>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/sla-level> ;
    rdfs:label "Gold SLA"@en ;
    rdfs:comment "High Service Level Agreement, good availability and performance."@en .

# KOS Concepts for Application Status
<https://w3id.org/noria/kos/application/status/in-production>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "In Production"@en ;
    rdfs:comment "The application module is currently live and serving users."@en .

<https://w3id.org/noria/kos/application/status/maintenance>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/application/status> ;
    rdfs:label "Under Maintenance"@en ;
    rdfs:comment "The application module is temporarily offline for maintenance."@en .

# KOS Concepts for Service Type
<https://w3id.org/noria/kos/service/type/customer-facing>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Customer Facing Service"@en ;
    rdfs:comment "A service directly consumed by external customers."@en .

<https://w3id.org/noria/kos/service/type/resource-facing>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/service/type> ;
    rdfs:label "Resource Facing Service"@en ;
    rdfs:comment "A service that supports other services or internal operations, not directly exposed to customers."@en .

# KOS Concepts for TroubleTicket Severity
<https://w3id.org/noria/kos/TroubleTicket/severity/critical>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Critical Severity"@en ;
    rdfs:comment "Highest severity, major service outage or data loss."@en .

<https://w3id.org/noria/kos/TroubleTicket/severity/major>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/severity> ;
    rdfs:label "Major Severity"@en ;
    rdfs:comment "Significant service degradation or impact."@en .

# KOS Concepts for TroubleTicket Type
<https://w3id.org/noria/kos/TroubleTicket/type/failure>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> ;
    rdfs:label "Failure"@en ;
    rdfs:comment "Ticket type indicating a system or service failure."@en .

<https://w3id.org/noria/kos/TroubleTicket/type/assistance>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/type> ;
    rdfs:label "Assistance"@en ;
    rdfs:comment "Ticket type for user assistance or general queries."@en .

# KOS Concepts for TroubleTicket Criticity (Category)
<https://w3id.org/noria/kos/TroubleTicket/category/interrupted-service>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/category> ;
    rdfs:label "Interrupted Service"@en ;
    rdfs:comment "Criticity indicating a complete interruption of service."@en .

<https://w3id.org/noria/kos/TroubleTicket/category/corrupted-service>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/category> ;
    rdfs:label "Corrupted Service"@en ;
    rdfs:comment "Criticity indicating data corruption or incorrect service behavior."@en .

# KOS Concepts for TroubleTicket Priority
<https://w3id.org/noria/kos/TroubleTicket/priority/p1>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> ;
    rdfs:label "Priority 1"@en ;
    rdfs:comment "Highest priority, immediate action required."@en .

<https://w3id.org/noria/kos/TroubleTicket/priority/p2>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/priority> ;
    rdfs:label "Priority 2"@en ;
    rdfs:comment "High priority, urgent action required."@en .

# KOS Concepts for TroubleTicket Origin
<https://w3id.org/noria/kos/TroubleTicket/origin/customer>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> ;
    rdfs:label "Customer Origin"@en ;
    rdfs:comment "Trouble ticket initiated by a customer."@en .

<https://w3id.org/noria/kos/TroubleTicket/origin/supervision>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/origin> ;
    rdfs:label "Supervision System Origin"@en ;
    rdfs:comment "Trouble ticket initiated by an automated monitoring or supervision system."@en .

# KOS Concepts for TroubleTicket Urgency
<https://w3id.org/noria/kos/TroubleTicket/urgency/immediate>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> ;
    rdfs:label "Immediate Intervention"@en ;
    rdfs:comment "Urgency requiring immediate action."@en .

<https://w3id.org/noria/kos/TroubleTicket/urgency/deferred>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/urgency> ;
    rdfs:label "Deferred Intervention"@en ;
    rdfs:comment "Urgency allowing for delayed action."@en .

# KOS Concepts for TroubleTicket Trouble Category
<https://w3id.org/noria/kos/TroubleTicket/trouble-category/total-breakdown>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> ;
    rdfs:label "Total Breakdown"@en ;
    rdfs:comment "Category indicating a complete system or service failure."@en .

<https://w3id.org/noria/kos/TroubleTicket/trouble-category/downgrading-equipment>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/trouble-category> ;
    rdfs:label "Downgrading Equipment"@en ;
    rdfs:comment "Category indicating equipment operating at reduced capacity."@en .

# KOS Concepts for TroubleTicket Problem Responsibility
<https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/customer>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Customer Responsibility"@en ;
    rdfs:comment "Problem responsibility lies with the customer."@en .

<https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/managed-network>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility> ;
    rdfs:label "Managed Network Responsibility"@en ;
    rdfs:comment "Problem responsibility lies with the managed network provider."@en .

# KOS Concepts for TroubleTicket Comment Type
<https://w3id.org/noria/kos/TroubleTicket/commentType/internal>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> ;
    rdfs:label "Internal Comment"@en ;
    rdfs:comment "Comment intended for internal team use."@en .

<https://w3id.org/noria/kos/TroubleTicket/commentType/customer>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/commentType> ;
    rdfs:label "Customer Comment"@en ;
    rdfs:comment "Comment from or intended for the customer."@en .

# KOS Concepts for TroubleTicket Operation Type
<https://w3id.org/noria/kos/TroubleTicket/operationType/diagnosis>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> ;
    rdfs:label "Diagnosis Operation"@en ;
    rdfs:comment "Operation type related to diagnosing the issue."@en .

<https://w3id.org/noria/kos/TroubleTicket/operationType/measurements>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/operationType> ;
    rdfs:label "Measurements Operation"@en ;
    rdfs:comment "Operation type related to taking measurements."@en .

# KOS Concepts for TroubleTicket Status
<https://w3id.org/noria/kos/TroubleTicket/status/in-progress>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> ;
    rdfs:label "In Progress"@en ;
    rdfs:comment "Trouble ticket is currently being worked on."@en .

<https://w3id.org/noria/kos/TroubleTicket/status/resolved>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/TroubleTicket/status> ;
    rdfs:label "Resolved"@en ;
    rdfs:comment "Trouble ticket issue has been resolved."@en .

# KOS Concepts for ChangeRequest Category
<https://w3id.org/noria/kos/ChangeRequest/category/internal-intervention>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> ;
    rdfs:label "Internal Intervention"@en ;
    rdfs:comment "Change request for internal team intervention."@en .

<https://w3id.org/noria/kos/ChangeRequest/category/customer-requested>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/category> ;
    rdfs:label "Customer Requested Change"@en ;
    rdfs:comment "Change request initiated by a customer."@en .

# KOS Concepts for ChangeRequest Type
<https://w3id.org/noria/kos/ChangeRequest/type/standard>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> ;
    rdfs:label "Standard Change"@en ;
    rdfs:comment "A pre-approved change with low risk."@en .

<https://w3id.org/noria/kos/ChangeRequest/type/emergency>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/type> ;
    rdfs:label "Emergency Change"@en ;
    rdfs:comment "An urgent change required to resolve an incident."@en .

# KOS Concepts for ChangeRequest Cause
<https://w3id.org/noria/kos/ChangeRequest/cause/software-upgrade>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> ;
    rdfs:label "Software Upgrade"@en ;
    rdfs:comment "Cause of change request is a software upgrade."@en .

<https://w3id.org/noria/kos/ChangeRequest/cause/network-extension>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> ;
    rdfs:label "Network Extension"@en ;
    rdfs:comment "Cause of change request is a network infrastructure extension."@en .

<https://w3id.org/noria/kos/ChangeRequest/cause/configuration>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/cause> ;
    rdfs:label "Configuration Change"@en ;
    rdfs:comment "Cause of change request is a modification of system configuration."@en .

# KOS Concepts for ChangeRequest Status
<https://w3id.org/noria/kos/ChangeRequest/status/approved>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> ;
    rdfs:label "Approved"@en ;
    rdfs:comment "Change request has been approved for implementation."@en .

<https://w3id.org/noria/kos/ChangeRequest/status/implemented>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/status> ;
    rdfs:label "Implemented"@en ;
    rdfs:comment "Change request has been successfully implemented."@en .

# KOS Concepts for ChangeRequest Specification
<https://w3id.org/noria/kos/ChangeRequest/specification/standard-procedure-a>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> ;
    rdfs:label "Standard Procedure A"@en ;
    rdfs:comment "Specification referring to a predefined standard operating procedure A."@en .

<https://w3id.org/noria/kos/ChangeRequest/specification/custom-script-x>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> ;
    rdfs:label "Custom Script X"@en ;
    rdfs:comment "Specification referring to a custom script X for implementation."@en .

<https://w3id.org/noria/kos/ChangeRequest/specification/standard-procedure-b>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/ChangeRequest/specification> ;
    rdfs:label "Standard Procedure B"@en ;
    rdfs:comment "Specification referring to a predefined standard operating procedure B."@en .

# KOS Concepts for Resource Operational State
<https://w3id.org/noria/kos/Resource/OperationalState/up>
    a skos:Concept, noria:StructuralObservable ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Up"@en ;
    rdfs:comment "Resource is operational and functioning. Represents the observable state of a resource being operational."@en .

<https://w3id.org/noria/kos/Resource/OperationalState/down>
    a skos:Concept, noria:StructuralObservable ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/OperationalState> ;
    rdfs:label "Down"@en ;
    rdfs:comment "Resource is not operational. Represents the observable state of a resource being non-operational."@en .

# KOS Concepts for Resource Administrative State
<https://w3id.org/noria/kos/Resource/AdministrativeState/enabled>
    a skos:Concept, noria:StructuralObservable ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ;
    rdfs:label "Enabled"@en ;
    rdfs:comment "Resource is administratively enabled. Represents the observable state of a resource being administratively enabled."@en .

<https://w3id.org/noria/kos/Resource/AdministrativeState/disabled>
    a skos:Concept, noria:StructuralObservable ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/AdministrativeState> ;
    rdfs:label "Disabled"@en ;
    rdfs:comment "Resource is administratively disabled. Represents the observable state of a resource being administratively disabled."@en .

# KOS Concepts for Resource Type
<https://w3id.org/noria/kos/Resource/type/router>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Router"@en ;
    rdfs:comment "A network device that forwards data packets between computer networks."@en .

<https://w3id.org/noria/kos/Resource/type/server>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Server"@en ;
    rdfs:comment "A computer program or a device that provides functionality for other programs or devices."@en .

<https://w3id.org/noria/kos/Resource/type/switch>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/type> ;
    rdfs:label "Switch"@en ;
    rdfs:comment "A network device that connects devices in a computer network by using packet switching to receive, process, and forward data."@en .

# KOS Concepts for Resource Lifecycle State
<https://w3id.org/noria/kos/Resource/LifecycleState/production>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ;
    rdfs:label "Production"@en ;
    rdfs:comment "Resource is in active production use."@en .

<https://w3id.org/noria/kos/Resource/LifecycleState/development>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Resource/LifecycleState> ;
    rdfs:label "Development"@en ;
    rdfs:comment "Resource is used for development purposes."@en .

# KOS Concepts for Notification Severity (Perceived Severity)
<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/critical>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Critical Perceived Severity"@en ;
    rdfs:comment "Highest perceived severity for a notification."@en .

<https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/warning>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity> ;
    rdfs:label "Warning Perceived Severity"@en ;
    rdfs:comment "Moderate perceived severity for a notification."@en .

# KOS Concepts for Agent Contact Method
<https://w3id.org/noria/kos/org/agent-contact-method/email>
    a skos:Concept ;
    skos:inScheme <https://w3id.org/noria/kos/org/agent-contact-method> ;
