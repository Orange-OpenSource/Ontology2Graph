# Organizational Entities
<Agent/JohnDoe>
    a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "A key technical agent responsible for network operations."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for urgent issues."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<Agent/JaneSmith>
    a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application support lead."@en ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<Agent/AliceJohnson>
    a foaf:Agent ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Infrastructure architect."@en ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Email for non-critical inquiries."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<Org/NetworkOperations>
    a org:Organization ;
    rdfs:label "Network Operations Department"@en ;
    rdfs:comment "Department responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Follow escalation matrix for critical incidents."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<Org/ApplicationSupport>
    a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "8:00-20:00 Mon-Sat"^^xsd:string ;
    noria:agentInstructions "Submit tickets via portal."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> .

<Org/SecurityTeam>
    a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Operations Center"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Immediate phone call for P1 security alerts."^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

