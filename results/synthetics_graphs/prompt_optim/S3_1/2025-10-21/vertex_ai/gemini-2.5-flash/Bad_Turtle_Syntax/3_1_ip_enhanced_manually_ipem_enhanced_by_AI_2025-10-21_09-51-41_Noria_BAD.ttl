# Procedures and Actions (for pep:Procedure and pep:ProcedureExecutionContainer)
<Procedure/RestartInterface>
    a pep:Procedure ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a faulty network interface."@en ;
    noria:operationPlanPreCondition <ActionPreCondition/InterfaceDown> ;
    noria:operationPlanPostCondition <ActionPostCondition/InterfaceUp> .

<Procedure/DatabaseTroubleshooting>
    a pep:Procedure ;
    rdfs:label "Database Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving database connectivity issues."@en ;
    noria:operationPlanPreCondition <ActionPreCondition/DBConnectionFailed> ;
    noria:operationPlanPostCondition <ActionPostCondition/DBConnectionRestored> .

<ProcedureExecutionContainer/InterfaceRestartExecution>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Interface Restart Execution"@en ;
    rdfs:comment "Container for the execution of the 'Restart Network Interface Procedure'."@en .

<ProcedureExecutionContainer/DBTroubleshootingExecution>
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Database Troubleshooting Execution"@en ;
    rdfs:comment "Container for the execution of the 'Database Troubleshooting Procedure'."@en .

<ActionPreCondition/InterfaceDown>
    a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition: the network interface is in a 'down' operational state."@en .

<ActionPostCondition/InterfaceUp>
    a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-Condition"@en ;
    rdfs:comment "Post-condition: the network interface is in an 'up' operational state."@en .

<ActionPreCondition/DBConnectionFailed>
    a noria:ActionPreCondition ;
    rdfs:label "Database Connection Failed Pre-Condition"@en ;
    rdfs:comment "Pre-condition: the application cannot connect to the database."@en .

<ActionPostCondition/DBConnectionRestored>
    a noria:ActionPostCondition ;
    rdfs:label "Database Connection Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: the application can successfully connect to the database."@en .

<Action/CorrectiveMaintenanceAction1>
    a pep:ProcedureExecution ; # Assuming noria:CorrectiveMaintenanceAction is a pep:ProcedureExecution
    rdfs:label "Corrective Action for Router Interface"@en ;
    rdfs:comment "Action taken to restore RouterDC1's interface."@en ;
    noria:actionCorrelatedOperationPlan <Procedure/RestartInterface> .

<Action/ChangeAction1>
    a pep:ProcedureExecution ; # Assuming noria:ChangeAction is a pep:ProcedureExecution
    rdfs:label "Change Action for Firewall Rule"@en ;
    rdfs:comment "Action taken to implement a new firewall rule."@en ;
    noria:actionCorrelatedOperationPlan <Procedure/UpdateFirewallRules> .

<Procedure/UpdateFirewallRules>
    a pep:Procedure ;
    rdfs:label "Update Firewall Rules Procedure"@en ;
    rdfs:comment "Procedure for safely updating firewall configurations."@en .

