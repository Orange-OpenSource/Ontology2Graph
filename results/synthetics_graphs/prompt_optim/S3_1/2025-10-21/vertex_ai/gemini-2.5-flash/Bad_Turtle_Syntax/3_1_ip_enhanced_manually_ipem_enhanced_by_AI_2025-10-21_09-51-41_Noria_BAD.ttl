    rdfs:label "Regional Office B"@en ;
    rdfs:comment "Regional office building."@en ;
    noria:siteId "ROB-02"^^xsd:string ;
    noria:siteType "office building"^^xsd:string ;
    noria:sitePrincipalAddress "45 Business Street"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "20002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Gotham"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Business Street"^^xsd:string .

<Room/ServerRoom101>
    a noria:Room ;
    rdfs:label "Server Room 101"@en ;
    rdfs:comment "Main server room in Data Center A."@en ;
    bot:hasSpace <Locus/RackA1> ;
    bot:hasSpace <Locus/RackA2> .

<Room/NetworkCloset203>
    a noria:Room ;
    rdfs:label "Network Closet 203"@en ;
    rdfs:comment "Network equipment closet in Office B."@en ;
    bot:hasSpace <Locus/CabinetB1> .

<Locus/RackA1>
    a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Server Room 101."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

<Locus/RackA2>
    a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Location of network devices in Server Room 101."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

<Locus/CabinetB1>
    a noria:Locus ;
    rdfs:label "Cabinet B1"@en ;
    rdfs:comment "Location of office network equipment."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

