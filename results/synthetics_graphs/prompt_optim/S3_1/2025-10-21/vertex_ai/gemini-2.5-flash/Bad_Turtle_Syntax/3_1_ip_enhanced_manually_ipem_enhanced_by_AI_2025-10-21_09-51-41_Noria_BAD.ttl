# Network Interfaces
<NetworkInterface/RouterDC1_Eth0>
    a noria:NetworkInterface ;
    rdfs:label "Router DC1 Ethernet 0/0/0"@en ;
    rdfs:comment "Uplink interface for Core Router DC1."@en ;
    noria:networkInterfaceDescription "Uplink to ISP A"^^xsd:string ;
    noria:networkInterfaceOf <Resource/RouterDC1> ;
    noria:networkInterfaceConnects <NetworkLink/DC1_ISP_Uplink> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100^^xsd:int ;
    noria:networkInterfaceLaserTxOpticalPower -5^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower -8^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -7^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -3^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -15^^xsd:int ;
    noria:networkInterfaceType "physical"^^xsd:string .

<NetworkInterface/ServerApp1_Eth0>
    a noria:NetworkInterface ;
    rdfs:label "App Server 1 Ethernet 0"@en ;
    rdfs:comment "Network interface for Application Server 1."@en ;
    noria:networkInterfaceDescription "Connection to internal network"^^xsd:string ;
    noria:networkInterfaceOf <Resource/ServerApp1> ;
    noria:networkInterfaceConnects <NetworkLink/InternalLAN_DC1> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical"^^xsd:string .

<NetworkInterface/FirewallEdge_Eth1>
    a noria:NetworkInterface ;
    rdfs:label "Firewall Edge Ethernet 1"@en ;
    rdfs:comment "External interface for Edge Firewall."@en ;
    noria:networkInterfaceDescription "WAN connection"^^xsd:string ;
    noria:networkInterfaceOf <Resource/FirewallEdge> ;
    noria:networkInterfaceConnects <NetworkLink/WAN_Connection> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Enabled> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceType "physical"^^xsd:string .

