# Anomaly Patterns
<AnomalyPattern/HighTrafficAnomaly>
    a noria:AnomalyPattern ;
    rdfs:label "High Traffic Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating unusually high network traffic, potentially a DDoS attack or misconfiguration."@en ;
    folio:hasConsequence "Service Degradation"^^xsd:string ;
    folio:hasCause "Unexpected traffic surge"^^xsd:string .

<AnomalyPattern/FailedLoginAttempts>
    a noria:AnomalyPattern ;
    rdfs:label "Repeated Failed Login Attempts Anomaly"@en ;
    rdfs:comment "Pattern indicating multiple failed login attempts, suggesting a brute-force attack or credential stuffing."@en ;
    folio:hasConsequence "Account Lockout"^^xsd:string ;
    folio:hasCause "Unauthorized access attempt"^^xsd:string .

# Operation Plans
<OperationPlan/DDoSMitigation>
    a noria:OperationPlan ;
    rdfs:label "DDoS Mitigation Plan"@en ;
    rdfs:comment "Standard operating procedure for mitigating Distributed Denial of Service attacks."@en ;
    noria:operationPlanPreCondition <ActionPreCondition/HighTrafficAnomalyDetected> ;
    noria:operationPlanPostCondition <ActionPostCondition/TrafficNormalized> ;
    pep:hasInput "Traffic logs from NMP"^^xsd:string ;
    pep:hasOutput "Clean traffic flow"^^xsd:string .

<OperationPlan/AccountLockoutProcedure>
    a noria:OperationPlan ;
    rdfs:label "Account Lockout Resolution Procedure"@en ;
    rdfs:comment "Procedure to investigate and resolve user account lockouts."@en ;
    noria:operationPlanPreCondition <ActionPreCondition/FailedLoginAttemptsDetected> ;
    noria:operationPlanPostCondition <ActionPostCondition/AccountUnlocked> .

<ActionPreCondition/HighTrafficAnomalyDetected>
    a noria:ActionPreCondition ;
    rdfs:label "High Traffic Anomaly Detected Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Anomaly Pattern 'High Traffic Anomaly' is detected."@en .

<ActionPostCondition/TrafficNormalized>
    a noria:ActionPostCondition ;
    rdfs:label "Traffic Normalized Post-Condition"@en ;
    rdfs:comment "Post-condition: Network traffic returns to normal levels."@en .

<ActionPreCondition/FailedLoginAttemptsDetected>
    a noria:ActionPreCondition ;
    rdfs:label "Failed Login Attempts Detected Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Anomaly Pattern 'Repeated Failed Login Attempts' is detected."@en .

<ActionPostCondition/AccountUnlocked>
    a noria:ActionPostCondition ;
    rdfs:label "Account Unlocked Post-Condition"@en ;
    rdfs:comment "Post-condition: User account is successfully unlocked and secured."@en .

# Additional interconnections to ensure all properties are used
<Agent/JohnDoe>
    noria:agentManagesResource <Resource/RouterDC1> ;
    noria:agentManagesResource <NetworkLink/DC1_ISP_Uplink> .

<Org/NetworkOperations>
    noria:agentManagesResource <Resource/RouterDC1> ;
    noria:agentManagesResource <NetworkLink/DC1_ISP_Uplink> ;
    noria:agentManagesResource <Service/CustomerInternetAccess> .

<Org/ApplicationSupport>
    noria:agentManagesResource <Application/CRMSystem> ;
    noria:agentManagesResource <ApplicationModule/CRM_Prod> .

<EventRecord/LogRouterDown>
    noria:alarmMitigatedBy <ProcedureExecutionContainer/InterfaceRestartExecution> .

<EventRecord/LogAppError>
    noria:alarmMitigatedBy <ProcedureExecutionContainer/DBTroubleshootingExecution> .

<TroubleTicket/TT20240420-001>
    noria:eventRelatedElement <Resource/RouterDC1> ;
    noria:eventRelatedParty <Agent/JohnDoe> .

<ChangeRequest/CR20240419-001>
    noria:eventRelatedElement <Resource/FirewallEdge> ;
    noria:eventRelatedParty <Agent/AliceJohnson> .

<TroubleTicketNote/TT20240420-001-Note1>
    noria:eventRelatedElement <Resource/RouterDC1> ;
    noria:eventRelatedParty <Agent/JohnDoe> .

<Application/CRMSystem>
    noria:functionalElementDistinguishedName "CRM-System-Prod"^^xsd:string .

<Resource/RouterDC1>
    noria:structuralElementDistinguishedName "router-dc1-core-001"^^xsd:string .

<NetworkInterface/RouterDC1_Eth0>
    noria:structuralElementObservable <kos/Resource/OperationalState/Up> ;
    noria:structuralElementObservableData "1000Mbps"^^xsd:string .

<kos/Resource/OperationalState/Up>
    noria:structuralObservableOf <NetworkInterface/RouterDC1_Eth0> .

