# --- noria:EventRecord ---
<event/router_interface_down>
    a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface went down on a router."@en ;
    noria:logOriginatingManagedObject <resource/router_core_01> ;
    noria:logOriginatingManagementSystem <app/network_monitoring_system> ;
    noria:logOriginatingAgent <agent/network_ops_team> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/1, changed state to down."^^xsd:string ;
    noria:loggingTime "2024-01-20T14:35:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <op_plan/interface_troubleshooting> ;
    noria:eventRelatedElement <resource/router_core_01> ;
    noria:eventRelatedParty <agent/john_doe> .

<event/application_error_log>
    a noria:EventRecord ;
    rdfs:label "Application Error Log"@en ;
    rdfs:comment "Log entry indicating a critical error in the CRM application."@en ;
    noria:logOriginatingManagedObject <app/crm_suite> ;
    noria:logOriginatingManagementSystem <appmodule/crm_prod_instance> ;
    noria:logOriginatingAgent <agent/jane_smith> ;
    noria:logText "CRITICAL: Database connection failed for user 'crm_user'."^^xsd:string ;
    noria:loggingTime "2024-01-20T14:40:15Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <op_plan/db_restart_procedure> ;
    noria:eventRelatedElement <appmodule/crm_prod_instance> ;
    noria:eventRelatedParty <agent/jane_smith> .

<event/config_change_success>
    a noria:EventRecord ;
    rdfs:label "Configuration Change Success Event"@en ;
    rdfs:comment "Log entry confirming a successful configuration change on a server."@en ;
    noria:logOriginatingManagedObject <resource/web_server_03> ;
    noria:logOriginatingManagementSystem <app/network_monitoring_system> ;
    noria:logOriginatingAgent <agent/john_doe> ;
