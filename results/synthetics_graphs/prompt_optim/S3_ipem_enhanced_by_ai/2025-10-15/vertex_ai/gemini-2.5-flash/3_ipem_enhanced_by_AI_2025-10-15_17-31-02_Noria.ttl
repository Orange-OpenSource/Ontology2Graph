# Instances for noria:ActionPreCondition
noria:ActionPreCondition_ServerOffline
    a noria:ActionPreCondition ;
    rdfs:label "Server Offline Pre-Condition"@en ;
    rdfs:comment "Pre-condition: target server must be offline before maintenance."@en ;
.

noria:ActionPreCondition_MaintenanceWindow
    a noria:ActionPreCondition ;
    rdfs:label "Maintenance Window Pre-Condition"@en ;
    rdfs:comment "Pre-condition: operation must be performed within a scheduled maintenance window."@en ;
.

# Instances for noria:ActionPostCondition
noria:ActionPostCondition_ServiceRestored
    a noria:ActionPostCondition ;
    rdfs:label "Service Restored Post-Condition"@en ;
    rdfs:comment "Post-condition: service must be fully restored and functional."@en ;
.

noria:ActionPostCondition_NetworkStable
    a noria:ActionPostCondition ;
    rdfs:label "Network Stable Post-Condition"@en ;
    rdfs:comment "Post-condition: network connectivity and performance must be stable."@en ;
.

# Linking OperationPlans to Pre/Post Conditions
noria:OperationPlan_RestartServer
    noria:operationPlanPreCondition noria:ActionPreCondition_ServerOffline ;
    noria:operationPlanPostCondition noria:ActionPostCondition_ServiceRestored ;
.

noria:OperationPlan_CheckCable
    noria:operationPlanPreCondition noria:ActionPreCondition_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_NetworkStable ;
.

# Linking EventRecords (as actions) to OperationPlans
noria:EventRecord_ServerDown # Acting as a CorrectiveMaintenanceAction or ChangeAction
    noria:actionCorrelatedOperationPlan noria:OperationPlan_RestartServer ;
.
noria:EventRecord_ConfigChange # Acting as a CorrectiveMaintenanceAction or ChangeAction
    noria:actionCorrelatedOperationPlan noria:OperationPlan_CheckCable ;
.

# Instances for pep:ProcedureExecutionContainer (used as range for noria:alarmMitigatedBy)
noria:ProcedureExecutionContainer_ServerFix
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Server Fix Execution Container"@en ;
    rdfs:comment "Container for actions taken to fix Web Server 01."@en ;
.

noria:ProcedureExecutionContainer_NetworkTroubleshoot
    a pep:ProcedureExecutionContainer ;
    rdfs:label "Network Troubleshoot Execution Container"@en ;
    rdfs:comment "Container for actions taken to troubleshoot network degradation."@en ;
.

# Linking EventRecords to ProcedureExecutionContainers
noria:EventRecord_ServerDown
    noria:alarmMitigatedBy noria:ProcedureExecutionContainer_ServerFix ;
.
noria:EventRecord_InterfaceFlap
    noria:alarmMitigatedBy noria:ProcedureExecutionContainer_NetworkTroubleshoot ;
.

