# Implicit classes derived from schema usage
noria:ProceduralObject
    a owl:Class ;
    rdfs:label "Procedural Object"@en ;
    rdfs:comment "An abstract class for objects related to procedures, derived from its usage as superclass for AnomalyPattern and OperationPlan."@en ;
    rdfs:subClassOf noria:ProceduralElement ;
.

noria:StructuralProperty
    a owl:Class ;
    rdfs:label "Structural Property"@en ;
    rdfs:comment "An abstract class for properties related to structural elements, derived from its usage as superclass for ProductModel."@en ;
    rdfs:subClassOf noria:Property ;
.

