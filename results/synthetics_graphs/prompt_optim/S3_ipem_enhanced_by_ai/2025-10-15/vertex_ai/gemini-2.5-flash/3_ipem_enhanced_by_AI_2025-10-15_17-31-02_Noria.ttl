# Instances for foaf:Agent (Person and Group)
noria:Agent_Person_Alice
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "A key employee in the IT operations team."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria:AgentContactMethod_Email ;
.

noria:Agent_Person_Bob
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Lead engineer for network infrastructure."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Call directly for critical network issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria:AgentContactMethod_Phone ;
.

noria:Agent_Group_NetOps
    a foaf:Group ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for network infrastructure management."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod noria:AgentContactMethod_Chat ;
.

noria:Agent_Group_AppDev
    a foaf:Group ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core applications."@en ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Submit issues via Jira for tracking."^^xsd:string ;
    noria:agentPreferredContactMethod noria:AgentContactMethod_Email ;
.

# Instances for org:OrganizationalUnit
noria:OrgUnit_ITOperations
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
