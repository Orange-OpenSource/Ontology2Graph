# Instances for abstract classes that are superclasses of other instantiated classes
# noria:ManagedElement, noria:Property, noria:StructuralElement, noria:StructuralObservable, noria:FunctionalElement, noria:DynamicElement, noria:ProceduralElement
# These are already covered by their subclasses having rdf:type of these abstract classes.

# Explicitly linking for noria:structuralObservableOf
noria-inst:StructuralObservable_RouterStatus
    a noria:StructuralObservable ;
    rdfs:label "Router Operational Status Observable"@en ;
    rdfs:comment "An observable property representing the operational status of a router."@en ;
    noria:structuralObservableOf noria-inst:Resource_Router001 .

noria-inst:StructuralObservable_DBDiskUsage
    a noria:StructuralObservable ;
    rdfs:label "Database Disk Usage Observable"@en ;
    rdfs:comment "An observable property representing the disk usage of a database server."@en ;
    noria:structuralObservableOf noria-inst:Resource_DBServer01 .

# Explicitly linking for noria:agentManagesResource (inverse of noria:resourceManagedBy)
noria-inst:OrgUnit_NetworkOps
    noria:agentManagesResource noria-inst:Resource_Router001, noria-inst:NetLink_Router001_Router002 .
noria-inst:OrgUnit_AppSupport
    noria:agentManagesResource noria-inst:Resource_DBServer01, noria-inst:NetLink_DBServer01_Switch001 .

# Explicitly linking for noria:operationPlanPreCondition
noria-inst:OpPlan_DiskCleanup
    noria:operationPlanPreCondition noria-inst:PreCond_DBAccess .
noria-inst:OpPlan_RouterConfig
    noria:operationPlanPreCondition noria-inst:PreCond_NetworkReachability .

# Explicitly linking for noria:operationPlanPostCondition
noria-inst:OpPlan_DiskCleanup
    noria:operationPlanPostCondition noria-inst:PostCond_DiskSpaceFreed .
noria-inst:OpPlan_RouterConfig
    noria:operationPlanPostCondition noria-inst:PostCond_ConfigApplied .
