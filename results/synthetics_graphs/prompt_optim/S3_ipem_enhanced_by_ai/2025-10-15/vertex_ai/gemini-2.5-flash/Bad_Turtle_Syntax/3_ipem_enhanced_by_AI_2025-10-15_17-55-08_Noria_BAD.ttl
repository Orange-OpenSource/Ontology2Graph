# Instances of foaf:Agent and org:OrganizationalUnit
noria-inst:Person_JohnDoe
    a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "An example person, acting as an agent in the system."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-inst:Person_JaneSmith
    a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Another example person, acting as an agent."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "8:30-16:30 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Call directly for urgent issues."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone .

noria-inst:OrgUnit_NetworkOps
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "The team responsible for network infrastructure operations."@en ;
    org:unitOf noria-inst:Org_GlobalISP ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Use ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Email .

noria-inst:OrgUnit_AppSupport
    a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "The team providing support for critical applications."@en ;
    org:unitOf noria-inst:Org_GlobalISP ;
    noria:agentWorkingHours "9:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Escalate via internal chat for immediate attention."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:org/agent-contact-method/Phone .

noria-inst:Org_GlobalISP
    a org:Organization ;
    rdfs:label "Global ISP Inc."@en ;
    rdfs:comment "A global internet service provider."@en .

