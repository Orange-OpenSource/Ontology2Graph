# 1. noria:CorporateUserIdentifier
noria-inst:CUid_JDoe
    a noria:CorporateUserIdentifier ;
    rdfs:label "Corporate User ID for John Doe"@en ;
    rdfs:comment "Unique identifier for John Doe within the corporate IT system."@en ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "jdoe_id_12345"^^xsd:string ;
    foaf:holdsAccount noria-inst:Person_JohnDoe .

noria-inst:CUid_JSmith
    a noria:CorporateUserIdentifier ;
    rdfs:label "Corporate User ID for Jane Smith"@en ;
    rdfs:comment "Unique identifier for Jane Smith within the corporate IT system."@en ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountLogin "jsmith"^^xsd:string ;
    observable:accountIdentifier "jsmith_id_67890"^^xsd:string ;
    foaf:holdsAccount noria-inst:Person_JaneSmith .

# 2. noria:Application
noria-inst:App_CRMSystem
    a noria:Application ;
    rdfs:label "Customer Relationship Management System"@en ;
    rdfs:comment "Core application for managing customer interactions."@en ;
    noria:applicationModelIdentifier "CRM-V2.1"^^xsd:string ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CRM"^^xsd:string ;
    noria:applicationType noria-kos:application/type/ServicePlatform ;
    noria:applicationBusinessImportance noria-kos:application/business-importance/High ;
    noria:applicationFunctionalDomain "Customer Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Sales & Support"^^xsd:string ;
    noria:elementManagedBy noria-inst:OrgUnit_AppSupport .

noria-inst:App_MonitoringPlatform
    a noria:Application ;
    rdfs:label "Network Monitoring Platform"@en ;
    rdfs:comment "Application for real-time network performance monitoring."@en ;
    noria:applicationModelIdentifier "NMP-V3.0"^^xsd:string ;
    noria:applicationNumericalIdentifier "2002"^^xsd:int ;
    noria:applicationShortIdentifier "NMP"^^xsd:string ;
    noria:applicationType noria-kos:application/type/Infrastructure ;
    noria:applicationBusinessImportance noria-kos:application/business-importance/Medium ;
    noria:applicationFunctionalDomain "Network Operations"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Performance & Fault Management"^^xsd:string ;
    noria:elementManagedBy noria-inst:OrgUnit_NetworkOps .

# 3. noria:ApplicationModule
noria-inst:AppMod_CRM_Prod
    a noria:ApplicationModule ;
    rdfs:label "CRM Production Module"@en ;
    rdfs:comment "Production instance of the CRM system."@en ;
    noria:applicationModuleOf noria-inst:App_CRMSystem ;
    noria:applicationModuleName "CRM_PROD_EU"^^xsd:string ;
    noria:applicationModuleIdentifier "CRM-PROD-01"^^xsd:string ;
    noria:applicationModuleRelatedParty noria-inst:OrgUnit_AppSupport ;
    noria:applicationModuleAdministrationTeam noria-inst:OrgUnit_AppSupport ;
    noria:applicationModuleAdministrationLeader noria-inst:Person_JaneSmith ;
    noria:applicationModuleSupportTeam noria-inst:OrgUnit_AppSupport ;
    noria:applicationModuleSupportLeader noria-inst:Person_JaneSmith ;
    noria:applicationModuleSupportGroup noria-inst:OrgUnit_AppSupport ;
    noria:applicationModuleHotlineGroup noria-inst:OrgUnit_AppSupport ;
    noria:applicationModuleSlaLevel noria-kos:application/sla-level/Gold ;
    noria:applicationModuleSlaLevelDate "2023-01-15T09:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleStatus noria-kos:application/status/InProduction .

noria-inst:AppMod_NMP_Dev
    a noria:ApplicationModule ;
    rdfs:label "NMP Development Module"@en ;
    rdfs:comment "Development instance of the Network Monitoring Platform."@en ;
    noria:applicationModuleOf noria-inst:App_MonitoringPlatform ;
    noria:applicationModuleName "NMP_DEV_US"^^xsd:string ;
    noria:applicationModuleIdentifier "NMP-DEV-01"^^xsd:string ;
    noria:applicationModuleRelatedParty noria-inst:OrgUnit_NetworkOps ;
    noria:applicationModuleAdministrationTeam noria-inst:OrgUnit_NetworkOps ;
    noria:applicationModuleAdministrationLeader noria-inst:Person_JohnDoe ;
    noria:applicationModuleSupportTeam noria-inst:OrgUnit_NetworkOps ;
    noria:applicationModuleSupportLeader noria-inst:Person_JohnDoe ;
    noria:applicationModuleSupportGroup noria-inst:OrgUnit_NetworkOps ;
    noria:applicationModuleHotlineGroup noria-inst:OrgUnit_NetworkOps ;
    noria:applicationModuleSlaLevel noria-kos:application/sla-level/Silver ;
    noria:applicationModuleSlaLevelDate "2023-03-01T10:30:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "false"^^xsd:boolean ;
    noria:applicationModuleStatus noria-kos:application/status/Development .

# 4. noria:Service
noria-inst:Service_EnterpriseVPN
    a noria:Service ;
    rdfs:label "Enterprise VPN Service"@en ;
    rdfs:comment "Provides secure network connectivity for enterprise customers."@en ;
    noria:serviceType noria-kos:service/type/CustomerFacingService ;
    seas:subSystemOf noria-inst:App_MonitoringPlatform ;
    noria:elementManagedBy noria-inst:OrgUnit_NetworkOps .

noria-inst:Service_InternalDNS
    a noria:Service ;
    rdfs:label "Internal DNS Resolution Service"@en ;
    rdfs:comment "Provides DNS resolution for internal corporate resources."@en ;
    noria:serviceType noria-kos:service/type/ResourceFacingService ;
    seas:subSystemOf noria-inst:App_CRMSystem ;
    noria:elementManagedBy noria-inst:OrgUnit_NetworkOps .

# 5. noria:TroubleTicket
noria-inst:TT_20240401_001
    a noria:TroubleTicket ;
    rdfs:label "CRM System Outage"@en ;
    rdfs:comment "Critical outage affecting the CRM production module."@en ;
    noria:documentExternalId "EXT-CRM-001"^^xsd:string ;
    noria:documentHRef "https://ticketing.example.com/TT_20240401_001"^^xsd:anyURI ;
    noria:troubleTicketSeverity noria-kos:TroubleTicket/severity/Major ;
    noria:troubleTicketType noria-kos:TroubleTicket/type/Failure ;
    noria:troubleTicketCriticity noria-kos:TroubleTicket/category/InterruptedService ;
    noria:troubleTicketPriority noria-kos:TroubleTicket/priority/P1 ;
    noria:troubleTicketOrigin noria-kos:TroubleTicket/origin/Customer ;
    noria:troubleTicketUrgency noria-kos:TroubleTicket/urgency/ImmediateIntervention ;
    noria:troubleTicketCategory noria-kos:TroubleTicket/trouble-category/TotalBreakdown ;
    noria:problemCategory noria-kos:TroubleTicket/trouble-category/TotalBreakdown ;
    noria:troubleTicketCause "Database server unresponsive due to disk full."^^xsd:string ;
    noria:problemResponsibility noria-kos:TroubleTicket/problemResponsibility/ManagedBackboneNetworks ;
    noria:troubleTicketDetectionDateTime "2024-04-01T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-01T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-01T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-01T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent noria-kos:TroubleTicket/status/InProgress ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketRelatedParty noria-inst:Person_JaneSmith ;
    noria:troubleTicketPartyIntervention noria-inst:OrgUnit_AppSupport ;
    noria:troubleTicketRelatedService noria-inst:AppMod_CRM_Prod ;
    noria:troubleTicketRelatedResource noria-inst:Resource_DBServer01 ;
    noria:troubleTicketImpacts noria-inst:AppMod_CRM_Prod, noria-inst:Resource_DBServer01 ;
    noria:troubleTicketCharacteristic noria-inst:TroubleTicketCharacteristicType_1 ;
    noria:troubleTicketTrigger noria-inst:Event_DBAlert ;
