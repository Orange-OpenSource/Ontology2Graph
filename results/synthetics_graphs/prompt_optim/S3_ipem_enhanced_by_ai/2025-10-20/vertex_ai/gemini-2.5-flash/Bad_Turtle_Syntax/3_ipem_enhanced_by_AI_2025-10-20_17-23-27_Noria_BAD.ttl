# Instances for foaf:Agent, org:Organization, org:OrganizationalUnit
noria-inst:GlobalTechCorp
    a org:Organization ;
    rdfs:label "GlobalTech Corp"@en ;
    rdfs:comment "A leading technology company providing global IT services."@en ;
    .

noria-inst:IT_Operations_Dept
    a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "The department responsible for managing GlobalTech's IT infrastructure and applications."@en ;
    org:unitOf noria-inst:GlobalTechCorp ;
    .

noria-inst:CyberSecurity_Team
    a org:OrganizationalUnit ;
    rdfs:label "Cyber Security Team"@en ;
    rdfs:comment "Specialized team handling cybersecurity incidents, threat intelligence, and policy enforcement."@en ;
    org:unitOf noria-inst:GlobalTechCorp ;
    .

noria-inst:AliceSmith
    a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "IT Operations Manager, overseeing critical application deployments."@en ;
    noria:agentWorkingHours "09:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "Contact via email for routine inquiries, phone for urgent matters."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Email ;
    .

noria-inst:BobJohnson
    a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Network Engineer, responsible for data center network architecture."@en ;
    noria:agentWorkingHours "08:30-16:30 (Mon-Fri)"^^xsd:string ;
    noria:agentInstructions "All requests must go through the official ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method/Phone ;
    .

noria-inst:CharlieBrown
    a foaf:Agent ;
