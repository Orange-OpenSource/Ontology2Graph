# Define missing base classes from the schema's usage
noria:ProceduralObject
    a owl:Class ;
    rdfs:label "Procedural Object"@en ;
    rdfs:comment "An abstract class for objects related to procedures and operations, serving as a base for anomaly patterns and operation plans."@en ;
    rdfs:subClassOf noria:ProceduralElement ;
    .

noria:StructuralProperty
    a owl:Class ;
    rdfs:label "Structural Property"@en ;
    rdfs:comment "An abstract class for properties related to structural elements, such as product models."@en ;
    rdfs:subClassOf noria:Property ;
    .

# SKOS Concept Schemes
noria-kos:agent-contact-method
    a skos:ConceptScheme ;
    dcterms:title "Agent Contact Method"@en ;
    dcterms:description "A controlled vocabulary for preferred contact methods for agents."@en ;
    .

noria-kos:application/type
    a skos:ConceptScheme ;
    dcterms:title "Application Type"@en ;
    dcterms:description "A controlled vocabulary for types of applications."@en ;
    .

noria-kos:application/business-importance
    a skos:ConceptScheme ;
    dcterms:title "Application Business Importance"@en ;
