inst:TroubleTicketNote_TT001_Update1 a noria:TroubleTicketNote ;
    rdfs:label "TT-20240320-001 Note 1" ;
    rdfs:comment "Initial diagnosis for network outage ticket." ;
    dcterms:created "2024-03-20T10:30:00Z"^^xsd:dateTime ;
    dcterms:creator inst:JohnDoe ;
    dcterms:description "Confirmed fiber cut on external link. Initiating emergency repair procedure."^^xsd:string ;
