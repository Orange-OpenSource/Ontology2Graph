# =============================================================================
# RCA objects
# =============================================================================

inst:HighCPULoadAnomaly a noria:AnomalyPattern ;
    rdfs:label "High CPU Load Anomaly Pattern" ;
    rdfs:comment "Anomaly pattern indicating sustained high CPU load on a server, potentially leading to performance degradation." ;
    folio:hasCause "Inefficient application code or resource contention."^^xsd:string ;
    folio:hasEffect "Application slowdown or unresponsiveness."^^xsd:string .

inst:LinkFailureAnomaly a noria:AnomalyPattern ;
    rdfs:label "Network Link Failure Anomaly Pattern" ;
    rdfs:comment "Anomaly pattern for unexpected network link disconnections or errors, indicating potential hardware failure or physical damage." ;
    folio:hasCause "Physical damage to fiber, faulty transceiver, or misconfiguration."^^xsd:string ;
    folio:hasEffect "Network outage or degraded connectivity."^^xsd:string .

# =============================================================================
# Linking EventRecords to Procedures and Containers
# =============================================================================

# Example of an EventRecord being part of a ProcedureExecutionContainer
# TroubleTicket_NetworkOutage_001 is a pep:ProcedureExecutionContainer
# EventRecord_RouterDown is a pep:ProcedureExecution
# So, we can link them using ldp:member (implied by pep:ProcedureExecutionContainer)
# For this example, I'll explicitly state the relationship for clarity, though it's often implicit.
inst:TroubleTicket_NetworkOutage_001 pep:hasExecution inst:EventRecord_RouterDown .
inst:TroubleTicket_NetworkOutage_001 pep:hasExecution inst:TroubleTicketNote_TT001_Update1 .
inst:TroubleTicket_NetworkOutage_001 pep:hasExecution inst:TroubleTicketNote_TT001_Update2 .

inst:ChangeRequest_RouterConfig_001 pep:hasExecution inst:EventRecord_ConfigChange .

# Example of actionCorrelatedOperationPlan (domain is CorrectiveMaintenanceAction or ChangeAction, which are types of EventRecord)
inst:EventRecord_RouterDown noria:actionCorrelatedOperationPlan inst:NetworkTroubleshootingPlan .
inst:EventRecord_ConfigChange noria:actionCorrelatedOperationPlan inst:NetworkTroubleshootingPlan . # Re-using for demonstration

# Example of alarmMitigatedBy
inst:EventRecord_RouterDown noria:alarmMitigatedBy inst:TroubleTicket_NetworkOutage_001 .
inst:EventRecord_ServerCPUHigh noria:alarmMitigatedBy inst:TroubleTicket_AppPerformance_002 .
