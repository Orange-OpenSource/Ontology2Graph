# =============================================================================
# Application related entities
# =============================================================================

inst:CustomerPortalApp a noria:Application ;
    rdfs:label "Customer Portal Application" ;
    rdfs:comment "Main application for customer interactions." ;
    noria:applicationModelIdentifier "CP-APP-001"^^xsd:string ;
    noria:applicationNumericalIdentifier 1001^^xsd:int ;
    noria:applicationShortIdentifier "CustPortal"^^xsd:string ;
    noria:applicationType inst:WebPortalType ;
    noria:applicationBusinessImportance inst:CriticalImportance ;
    noria:applicationFunctionalDomain "Customer Relationship Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Online Self-Service"^^xsd:string ;
    noria:resourceForApplication inst:WebServer01 .

inst:BillingServiceApp a noria:Application ;
    rdfs:label "Billing Service Application" ;
    rdfs:comment "Backend application for billing and invoicing." ;
    noria:applicationModelIdentifier "BS-APP-002"^^xsd:string ;
    noria:applicationNumericalIdentifier 1002^^xsd:int ;
    noria:applicationShortIdentifier "BillingSvc"^^xsd:string ;
    noria:applicationType inst:DatabaseServiceType ;
    noria:applicationBusinessImportance inst:HighImportance ;
    noria:applicationFunctionalDomain "Financial Management"^^xsd:string ;
    noria:applicationFunctionalSubDomain "Invoice Processing"^^xsd:string ;
    noria:resourceForApplication inst:DBServer01 .

inst:CustomerPortalProdModule a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module" ;
    rdfs:comment "Production instance of the Customer Portal application." ;
    noria:applicationModuleOf inst:CustomerPortalApp ;
    noria:applicationModuleName "CustPortal_Prod"^^xsd:string ;
    noria:applicationModuleIdentifier "CP-MOD-PROD"^^xsd:string ;
    noria:applicationModuleAdministrationTeam inst:AppSupportTeam ;
    noria:applicationModuleAdministrationLeader inst:JaneSmith ;
    noria:applicationModuleSupportTeam inst:AppSupportTeam ;
    noria:applicationModuleSupportLeader inst:JaneSmith ;
    noria:applicationModuleSupportGroup inst:AppSupportTeam ;
    noria:applicationModuleHotlineGroup inst:AppSupportTeam ;
    noria:applicationModuleSlaLevel inst:SlaLevelGold ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true^^xsd:boolean ;
    noria:applicationModuleStatus inst:InProductionStatus .

inst:BillingServiceProdModule a noria:ApplicationModule ;
    rdfs:label "Billing Service Production Module" ;
    rdfs:comment "Production instance of the Billing Service application." ;
    noria:applicationModuleOf inst:BillingServiceApp ;
    noria:applicationModuleName "BillingSvc_Prod"^^xsd:string ;
    noria:applicationModuleIdentifier "BS-MOD-PROD"^^xsd:string ;
    noria:applicationModuleAdministrationTeam inst:AppSupportTeam ;
    noria:applicationModuleAdministrationLeader inst:JaneSmith ;
    noria:applicationModuleSupportTeam inst:AppSupportTeam ;
    noria:applicationModuleSupportLeader inst:JaneSmith ;
    noria:applicationModuleSupportGroup inst:AppSupportTeam ;
    noria:applicationModuleHotlineGroup inst:AppSupportTeam ;
    noria:applicationModuleSlaLevel inst:SlaLevelGold ;
    noria:applicationModuleSlaLevelDate "2024-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled true^^xsd:boolean ;
    noria:applicationModuleStatus inst:InProductionStatus .

inst:CustomerFacingService a noria:Service ;
    rdfs:label "Customer Facing Web Service" ;
    rdfs:comment "End-to-end service for customer interactions, including portal and billing." ;
    noria:serviceType inst:CustomerFacingServiceType ;
    seas:subSystemOf inst:CustomerPortalProdModule ;
    seas:subSystemOf inst:BillingServiceProdModule .

inst:InternalDataService a noria:Service ;
    rdfs:label "Internal Data Processing Service" ;
    rdfs:comment "Internal service for data processing and analytics." ;
    noria:serviceType inst:InternalServiceType ;
    seas:subSystemOf inst:BillingServiceProdModule .

# =============================================================================
# Operations related entities
# =============================================================================

inst:NetworkTroubleshootingPlan a noria:OperationPlan ;
    rdfs:label "Network Troubleshooting Plan" ;
    rdfs:comment "Standard operating procedure for diagnosing network issues." ;
    noria:operationPlanPreCondition inst:NetworkIssueDetected ;
    noria:operationPlanPostCondition inst:NetworkIssueResolved .

inst:ServerRestartPlan a noria:OperationPlan ;
    rdfs:label "Server Restart Procedure" ;
    rdfs:comment "Procedure for safely restarting a server." ;
    noria:operationPlanPreCondition inst:ServerUnresponsive ;
    noria:operationPlanPostCondition inst:ServerOperational .

inst:NetworkIssueDetected a noria:ActionPreCondition ;
    rdfs:label "Network Issue Detected" ;
    rdfs:comment "Pre-condition: A network connectivity issue has been detected." .

inst:ServerUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Server Unresponsive" ;
    rdfs:comment "Pre-condition: A server is not responding to requests." .

inst:NetworkIssueResolved a noria:ActionPostCondition ;
    rdfs:label "Network Issue Resolved" ;
    rdfs:comment "Post-condition: The network connectivity issue has been resolved." .

inst:ServerOperational a noria:ActionPostCondition ;
    rdfs:label "Server Operational" ;
    rdfs:comment "Post-condition: The server is back to operational state." .

# =============================================================================
# Notification related entities (Event Records)
# =============================================================================

inst:EventRecord_RouterDown a noria:EventRecord ;
    rdfs:label "Event: Router Interface Down" ;
    rdfs:comment "Log entry indicating a network interface went down on Core Router 01." ;
    noria:loggingTime "2024-03-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Line protocol on Interface GigabitEthernet0/0/0, changed state to down"^^xsd:string ;
    noria:logOriginatingManagedObject inst:CoreRouter01 ;
    noria:logOriginatingManagementSystem inst:CustomerPortalApp ; # Example of an application acting as a management system
    noria:logOriginatingAgent inst:NetworkTeam ;
    noria:alarmSeverity inst:PerceivedSeverityCritical ;
    noria:alarmProposedRepairAction inst:NetworkTroubleshootingPlan ;
    noria:alarmMonitoredAttribute inst:CoreRouter01_Gig0_0_0 .

inst:EventRecord_ServerCPUHigh a noria:EventRecord ;
    rdfs:label "Event: Server CPU High" ;
    rdfs:comment "Log entry indicating high CPU utilization on Web Server 01." ;
    noria:loggingTime "2024-03-20T10:15:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization exceeded 90% for 5 minutes on webserver01"^^xsd:string ;
    noria:logOriginatingManagedObject inst:WebServer01 ;
    noria:logOriginatingManagementSystem inst:BillingServiceApp ; # Another example of an application acting as a management system
    noria:logOriginatingAgent inst:ITOperationsDept ;
    noria:alarmSeverity inst:PerceivedSeverityWarning .

inst:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Event: Configuration Change on Router" ;
    rdfs:comment "Log entry for a configuration change applied to Core Router 01." ;
    noria:loggingTime "2024-03-19T14:30:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by jdoe (10.0.0.50)"^^xsd:string ;
    noria:logOriginatingManagedObject inst:CoreRouter01 ;
    noria:logOriginatingManagementSystem inst:CustomerPortalApp ;
    noria:logOriginatingAgent inst:JohnDoe .

