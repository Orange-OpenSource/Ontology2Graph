    noria:troubleTicketType inst:FailureType ;
    noria:troubleTicketCriticity inst:NetworkOutageCategory ;
    noria:troubleTicketPriority inst:PriorityP1 ;
    noria:troubleTicketOrigin inst:SupervisionOrigin ;
    noria:troubleTicketTrigger inst:EventRecord_RouterDown ;
    noria:troubleTicketUrgency inst:ImmediateInterventionUrgency ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory inst:NetworkOutageCategory ;
    noria:problemCategory inst:NetworkOutageCategory ;
    noria:troubleTicketCause "Fiber cut detected between CoreRouter01 and external network."^^xsd:string ;
    noria:problemResponsibility inst:InternalITResponsibility ;
    noria:troubleTicketDetectionDateTime "2024-03-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-03-20T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketPlannedRestorationDateTime "2024-03-20T11:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-03-20T13:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true^^xsd:boolean ;
    noria:troubleTicketStatusCurrent inst:InProgressStatus ;
    noria:troubleTicketRelatedParty inst:NetworkTeam ;
    noria:troubleTicketPartyIntervention inst:JohnDoe ;
    noria:troubleTicketRelatedService inst:CustomerFacingService ;
    noria:troubleTicketRelatedResource inst:CoreRouter01 ;
    noria:troubleTicketImpacts inst:CustomerPortalApp ;
    noria:troubleTicketImpacts inst:BillingServiceApp ;
    noria:troubleTicketCharacteristic inst:NetworkOutageCategory ; # Using a KOS concept as a characteristic example
    noria:documentStatusHistory inst:EventRecord_RouterDown .

