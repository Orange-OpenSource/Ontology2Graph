@base <https://w3id.org/noria/instance/> .

# =============================================================================
# SKOS Concept Schemes and Concepts for ObjectProperty Ranges
# =============================================================================

inst:AgentContactMethodScheme a skos:ConceptScheme ;
    rdfs:label "Agent Contact Method Scheme" ;
    rdfs:comment "A scheme for classifying preferred contact methods for agents." .

inst:EmailContactMethod a skos:Concept ;
    skos:inScheme inst:AgentContactMethodScheme ;
    rdfs:label "Email" ;
    rdfs:comment "Preferred contact method via email." .

inst:PhoneContactMethod a skos:Concept ;
    skos:inScheme inst:AgentContactMethodScheme ;
    rdfs:label "Phone" ;
    rdfs:comment "Preferred contact method via phone." .

inst:ApplicationTypeScheme a skos:ConceptScheme ;
    rdfs:label "Application Type Scheme" ;
    rdfs:comment "A scheme for classifying types of applications." .

inst:WebPortalType a skos:Concept ;
    skos:inScheme inst:ApplicationTypeScheme ;
    rdfs:label "Web Portal" ;
    rdfs:comment "Application type for web-based portals." .

inst:DatabaseServiceType a skos:Concept ;
    skos:inScheme inst:ApplicationTypeScheme ;
    rdfs:label "Database Service" ;
    rdfs:comment "Application type for database services." .

inst:ApplicationBusinessImportanceScheme a skos:ConceptScheme ;
    rdfs:label "Application Business Importance Scheme" ;
    rdfs:comment "A scheme for classifying the business importance of applications." .

inst:CriticalImportance a skos:Concept ;
    skos:inScheme inst:ApplicationBusinessImportanceScheme ;
    rdfs:label "Critical" ;
    rdfs:comment "Application is critical for business operations." .

inst:HighImportance a skos:Concept ;
    skos:inScheme inst:ApplicationBusinessImportanceScheme ;
    rdfs:label "High" ;
    rdfs:comment "Application has high business importance." .

inst:ApplicationSlaLevelScheme a skos:ConceptScheme ;
    rdfs:label "Application SLA Level Scheme" ;
    rdfs:comment "A scheme for classifying Service Level Agreement (SLA) levels for application modules." .

inst:SlaLevelGold a skos:Concept ;
    skos:inScheme inst:ApplicationSlaLevelScheme ;
    rdfs:label "Gold" ;
    rdfs:comment "Gold level SLA, highest priority." .

inst:SlaLevelSilver a skos:Concept ;
    skos:inScheme inst:ApplicationSlaLevelScheme ;
    rdfs:label "Silver" ;
    rdfs:comment "Silver level SLA, standard priority." .

inst:ApplicationStatusScheme a skos:ConceptScheme ;
    rdfs:label "Application Status Scheme" ;
    rdfs:comment "A scheme for classifying the operational status of application modules." .

inst:InProductionStatus a skos:Concept ;
    skos:inScheme inst:ApplicationStatusScheme ;
    rdfs:label "In Production" ;
    rdfs:comment "Application module is currently in production." .

inst:MaintenanceStatus a skos:Concept ;
    skos:inScheme inst:ApplicationStatusScheme ;
    rdfs:label "Under Maintenance" ;
    rdfs:comment "Application module is currently under maintenance." .

inst:ServiceTypeScheme a skos:ConceptScheme ;
    rdfs:label "Service Type Scheme" ;
    rdfs:comment "A scheme for classifying types of services." .

inst:CustomerFacingServiceType a skos:Concept ;
    skos:inScheme inst:ServiceTypeScheme ;
    rdfs:label "Customer Facing Service" ;
    rdfs:comment "Service directly used by customers." .

inst:InternalServiceType a skos:Concept ;
    skos:inScheme inst:ServiceTypeScheme ;
    rdfs:label "Internal Service" ;
    rdfs:comment "Service used internally by the organization." .

inst:TroubleTicketSeverityScheme a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Severity Scheme" ;
    rdfs:comment "A scheme for classifying the severity of trouble tickets." .

inst:SeverityCritical a skos:Concept ;
    skos:inScheme inst:TroubleTicketSeverityScheme ;
    rdfs:label "Critical" ;
    rdfs:comment "Critical severity trouble ticket." .

inst:SeverityMajor a skos:Concept ;
    skos:inScheme inst:TroubleTicketSeverityScheme ;
    rdfs:label "Major" ;
    rdfs:comment "Major severity trouble ticket." .

inst:TroubleTicketTypeScheme a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Type Scheme" ;
    rdfs:comment "A scheme for classifying types of trouble tickets." .

inst:FailureType a skos:Concept ;
    skos:inScheme inst:TroubleTicketTypeScheme ;
    rdfs:label "Failure" ;
    rdfs:comment "Trouble ticket type indicating a system failure." .

inst:AssistanceType a skos:Concept ;
    skos:inScheme inst:TroubleTicketTypeScheme ;
    rdfs:label "Assistance" ;
    rdfs:comment "Trouble ticket type for user assistance." .

inst:TroubleTicketCategoryScheme a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Category Scheme" ;
    rdfs:comment "A scheme for classifying the category of trouble tickets." .

inst:NetworkOutageCategory a skos:Concept ;
    skos:inScheme inst:TroubleTicketCategoryScheme ;
    rdfs:label "Network Outage" ;
    rdfs:comment "Trouble ticket category for network outages." .

inst:SoftwareBugCategory a skos:Concept ;
    skos:inScheme inst:TroubleTicketCategoryScheme ;
    rdfs:label "Software Bug" ;
    rdfs:comment "Trouble ticket category for software bugs." .

inst:TroubleTicketPriorityScheme a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Priority Scheme" ;
    rdfs:comment "A scheme for classifying the priority of trouble tickets." .

inst:PriorityP1 a skos:Concept ;
    skos:inScheme inst:TroubleTicketPriorityScheme ;
    rdfs:label "P1" ;
    rdfs:comment "Priority 1: Highest urgency, immediate action required." .

inst:PriorityP2 a skos:Concept ;
    skos:inScheme inst:TroubleTicketPriorityScheme ;
    rdfs:label "P2" ;
    rdfs:comment "Priority 2: High urgency, prompt action required." .

inst:TroubleTicketOriginScheme a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Origin Scheme" ;
    rdfs:comment "A scheme for classifying the origin of trouble tickets." .

inst:CustomerOrigin a skos:Concept ;
    skos:inScheme inst:TroubleTicketOriginScheme ;
    rdfs:label "Customer" ;
    rdfs:comment "Trouble ticket originated by a customer." .

inst:SupervisionOrigin a skos:Concept ;
    skos:inScheme inst:TroubleTicketOriginScheme ;
    rdfs:label "Supervision" ;
    rdfs:comment "Trouble ticket originated by a monitoring system." .

inst:TroubleTicketUrgencyScheme a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Urgency Scheme" ;
    rdfs:comment "A scheme for classifying the urgency of trouble tickets." .

inst:ImmediateInterventionUrgency a skos:Concept ;
    skos:inScheme inst:TroubleTicketUrgencyScheme ;
    rdfs:label "Immediate Intervention" ;
    rdfs:comment "Urgency requiring immediate intervention." .

inst:DeferredInterventionUrgency a skos:Concept ;
    skos:inScheme inst:TroubleTicketUrgencyScheme ;
    rdfs:label "Deferred Intervention" ;
    rdfs:comment "Urgency allowing for deferred intervention." .

inst:TroubleTicketProblemResponsibilityScheme a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Scheme" ;
    rdfs:comment "A scheme for classifying the responsibility for a problem in a trouble ticket." .

inst:CustomerResponsibility a skos:Concept ;
    skos:inScheme inst:TroubleTicketProblemResponsibilityScheme ;
    rdfs:label "Customer" ;
    rdfs:comment "Problem responsibility lies with the customer." .

inst:InternalITResponsibility a skos:Concept ;
    skos:inScheme inst:TroubleTicketProblemResponsibilityScheme ;
    rdfs:label "Internal IT" ;
    rdfs:comment "Problem responsibility lies with internal IT." .

inst:TroubleTicketStatusScheme a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Status Scheme" ;
    rdfs:comment "A scheme for classifying the current status of trouble tickets." .

inst:InProgressStatus a skos:Concept ;
    skos:inScheme inst:TroubleTicketStatusScheme ;
    rdfs:label "In Progress" ;
    rdfs:comment "Trouble ticket is currently being worked on." .

inst:ResolvedStatus a skos:Concept ;
    skos:inScheme inst:TroubleTicketStatusScheme ;
    rdfs:label "Resolved" ;
    rdfs:comment "Trouble ticket has been resolved." .

inst:TroubleTicketCommentTypeScheme a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Comment Type Scheme" ;
    rdfs:comment "A scheme for classifying the type of comments in trouble ticket notes." .

inst:InternalCommentType a skos:Concept ;
    skos:inScheme inst:TroubleTicketCommentTypeScheme ;
    rdfs:label "Internal" ;
    rdfs:comment "Internal comment for team members." .

inst:CustomerCommentType a skos:Concept ;
    skos:inScheme inst:TroubleTicketCommentTypeScheme ;
    rdfs:label "Customer" ;
    rdfs:comment "Comment intended for the customer." .

inst:TroubleTicketOperationTypeScheme a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Note Operation Type Scheme" ;
    rdfs:comment "A scheme for classifying the operation type of trouble ticket notes." .

inst:DiagnosisOperationType a skos:Concept ;
    skos:inScheme inst:TroubleTicketOperationTypeScheme ;
    rdfs:label "Diagnosis" ;
    rdfs:comment "Operation type for diagnostic activities." .

inst:ResolutionOperationType a skos:Concept ;
    skos:inScheme inst:TroubleTicketOperationTypeScheme ;
    rdfs:label "Resolution" ;
    rdfs:comment "Operation type for resolution activities." .

inst:ChangeRequestCategoryScheme a skos:ConceptScheme ;
    rdfs:label "Change Request Category Scheme" ;
    rdfs:comment "A scheme for classifying the category of change requests." .

inst:InternalInterventionCategory a skos:Concept ;
    skos:inScheme inst:ChangeRequestCategoryScheme ;
    rdfs:label "Internal Intervention" ;
    rdfs:comment "Change request for internal intervention." .

inst:SoftwareUpgradeCategory a skos:Concept ;
    skos:inScheme inst:ChangeRequestCategoryScheme ;
    rdfs:label "Software Upgrade" ;
    rdfs:comment "Change request for software upgrade." .

inst:ChangeRequestTypeScheme a skos:ConceptScheme ;
    rdfs:label "Change Request Type Scheme" ;
    rdfs:comment "A scheme for classifying the type of change requests." .

inst:StandardChangeType a skos:Concept ;
    skos:inScheme inst:ChangeRequestTypeScheme ;
    rdfs:label "Standard Change" ;
    rdfs:comment "Standard change request type." .

inst:EmergencyChangeType a skos:Concept ;
    skos:inScheme inst:ChangeRequestTypeScheme ;
    rdfs:label "Emergency Change" ;
    rdfs:comment "Emergency change request type." .

inst:ChangeRequestCauseScheme a skos:ConceptScheme ;
    rdfs:label "Change Request Cause Scheme" ;
    rdfs:comment "A scheme for classifying the cause of change requests." .

inst:ConfigurationCause a skos:Concept ;
    skos:inScheme inst:ChangeRequestCauseScheme ;
    rdfs:label "Configuration" ;
    rdfs:comment "Change request caused by configuration needs." .

inst:PreventativeMaintenanceCause a skos:Concept ;
    skos:inScheme inst:ChangeRequestCauseScheme ;
    rdfs:label "Preventative Maintenance" ;
    rdfs:comment "Change request for preventative maintenance." .

inst:ChangeRequestStatusScheme a skos:ConceptScheme ;
    rdfs:label "Change Request Status Scheme" ;
    rdfs:comment "A scheme for classifying the current status of change requests." .

inst:ApprovedStatus a skos:Concept ;
    skos:inScheme inst:ChangeRequestStatusScheme ;
    rdfs:label "Approved" ;
    rdfs:comment "Change request has been approved." .

inst:ImplementedStatus a skos:Concept ;
    skos:inScheme inst:ChangeRequestStatusScheme ;
    rdfs:label "Implemented" ;
    rdfs:comment "Change request has been implemented." .

inst:ChangeRequestSpecificationScheme a skos:ConceptScheme ;
    rdfs:label "Change Request Specification Scheme" ;
    rdfs:comment "A scheme for classifying the specification of change requests." .

inst:RoutineMaintenanceSpec a skos:Concept ;
    skos:inScheme inst:ChangeRequestSpecificationScheme ;
    rdfs:label "Routine Maintenance" ;
    rdfs:comment "Specification for routine maintenance." .

inst:SoftwarePatchSpec a skos:Concept ;
    skos:inScheme inst:ChangeRequestSpecificationScheme ;
    rdfs:label "Software Patch" ;
    rdfs:comment "Specification for applying a software patch." .

inst:ResourceOperationalStateScheme a skos:ConceptScheme ;
    rdfs:label "Resource Operational State Scheme" ;
    rdfs:comment "A scheme for classifying the operational state of resources." .

inst:OperationalStateUp a skos:Concept ;
    skos:inScheme inst:ResourceOperationalStateScheme ;
    rdfs:label "Up" ;
    rdfs:comment "Resource is operational." .

inst:OperationalStateDown a skos:Concept ;
    skos:inScheme inst:ResourceOperationalStateScheme ;
    rdfs:label "Down" ;
    rdfs:comment "Resource is not operational." .

inst:ResourceAdministrativeStateScheme a skos:ConceptScheme ;
    rdfs:label "Resource Administrative State Scheme" ;
    rdfs:comment "A scheme for classifying the administrative state of resources." .

inst:AdministrativeStateEnabled a skos:Concept ;
    skos:inScheme inst:ResourceAdministrativeStateScheme ;
    rdfs:label "Enabled" ;
    rdfs:comment "Resource is administratively enabled." .

inst:AdministrativeStateDisabled a skos:Concept ;
    skos:inScheme inst:ResourceAdministrativeStateScheme ;
    rdfs:label "Disabled" ;
    rdfs:comment "Resource is administratively disabled." .

inst:ResourceTypeScheme a skos:ConceptScheme ;
    rdfs:label "Resource Type Scheme" ;
    rdfs:comment "A scheme for classifying types of resources." .

inst:ServerResourceType a skos:Concept ;
    skos:inScheme inst:ResourceTypeScheme ;
    rdfs:label "Server" ;
    rdfs:comment "Resource type for servers." .

inst:RouterResourceType a skos:Concept ;
    skos:inScheme inst:ResourceTypeScheme ;
    rdfs:label "Router" ;
    rdfs:comment "Resource type for network routers." .

inst:ResourceLifecycleStateScheme a skos:ConceptScheme ;
    rdfs:label "Resource Lifecycle State Scheme" ;
    rdfs:comment "A scheme for classifying the lifecycle state of resources." .

inst:InUseState a skos:Concept ;
    skos:inScheme inst:ResourceLifecycleStateScheme ;
    rdfs:label "In Use" ;
    rdfs:comment "Resource is currently in active use." .

inst:DecommissionedState a skos:Concept ;
    skos:inScheme inst:ResourceLifecycleStateScheme ;
    rdfs:label "Decommissioned" ;
    rdfs:comment "Resource has been decommissioned." .

inst:NotificationSeverityPerceivedSeverityScheme a skos:ConceptScheme ;
    rdfs:label "Notification Severity Perceived Severity Scheme" ;
    rdfs:comment "A scheme for classifying the perceived severity of notifications." .

inst:PerceivedSeverityCritical a skos:Concept ;
    skos:inScheme inst:NotificationSeverityPerceivedSeverityScheme ;
    rdfs:label "Critical" ;
    rdfs:comment "Perceived severity: Critical." .

inst:PerceivedSeverityWarning a skos:Concept ;
    skos:inScheme inst:NotificationSeverityPerceivedSeverityScheme ;
    rdfs:label "Warning" ;
    rdfs:comment "Perceived severity: Warning." .

# =============================================================================
# Organization related entities
# =============================================================================

inst:OrangeCompany a org:Organization, foaf:Agent ;
    rdfs:label "Orange S.A." ;
    rdfs:comment "The main organization, Orange S.A." ;
    noria:agentWorkingHours "24/7"^^xsd:string ;
    noria:agentInstructions "Contact via dedicated support portal for critical issues."^^xsd:string ;
    noria:agentPreferredContactMethod inst:EmailContactMethod .

inst:ITOperationsDept a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "IT Operations Department" ;
    rdfs:comment "Department responsible for IT operations." ;
    org:unitOf inst:OrangeCompany ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00 CET"^^xsd:string ;
    noria:agentInstructions "Use internal ticketing system for all requests."^^xsd:string ;
    noria:agentPreferredContactMethod inst:PhoneContactMethod .

inst:NetworkTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team" ;
    rdfs:comment "Team managing network infrastructure." ;
    org:unitOf inst:ITOperationsDept ;
    noria:agentWorkingHours "24/7 On-call"^^xsd:string ;
    noria:agentInstructions "For network emergencies, call hotline. For routine, use ticketing system."^^xsd:string ;
    noria:agentPreferredContactMethod inst:PhoneContactMethod .

inst:AppSupportTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team" ;
    rdfs:comment "Team providing support for business applications." ;
    org:unitOf inst:ITOperationsDept ;
    noria:agentWorkingHours "Mon-Fri 8:00-18:00 CET"^^xsd:string ;
    noria:agentInstructions "Submit tickets via the application's helpdesk portal."^^xsd:string ;
    noria:agentPreferredContactMethod inst:EmailContactMethod .

inst:JohnDoe a foaf:Person, foaf:Agent ;
    rdfs:label "John Doe" ;
    rdfs:comment "Employee, Network Engineer." ;
    org:memberOf inst:NetworkTeam ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00 CET"^^xsd:string ;
    noria:agentInstructions "Email for non-urgent matters, phone for urgent."^^xsd:string ;
    noria:agentPreferredContactMethod inst:EmailContactMethod .

inst:JaneSmith a foaf:Person, foaf:Agent ;
    rdfs:label "Jane Smith" ;
    rdfs:comment "Employee, Application Lead." ;
    org:memberOf inst:AppSupportTeam ;
    noria:agentWorkingHours "Mon-Fri 9:00-17:00 CET"^^xsd:string ;
    noria:agentInstructions "Contact via internal chat for quick questions."^^xsd:string ;
    noria:agentPreferredContactMethod inst:EmailContactMethod .

inst:CorporateUserIdentifier_JDoe a noria:CorporateUserIdentifier ;
    rdfs:label "CUid for John Doe" ;
    rdfs:comment "Corporate User Identifier for John Doe." ;
    foaf:accountName "jdoe"^^xsd:string ;
    observable:accountLogin "jdoe"^^xsd:string ;
    observable:accountIdentifier "CU-JD-001"^^xsd:string .

inst:CorporateUserIdentifier_JSmith a noria:CorporateUserIdentifier ;
    rdfs:label "CUid for Jane Smith" ;
    rdfs:comment "Corporate User Identifier for Jane Smith." ;
    foaf:accountName "jsmith"^^xsd:string ;
    observable:accountLogin "jsmith"^^xsd:string ;
    observable:accountIdentifier "CU-JS-002"^^xsd:string .

# =============================================================================
# Location related entities
# =============================================================================

inst:DataCenterParis a bot:Site ;
    rdfs:label "Paris Data Center" ;
    rdfs:comment "Main data center located in Paris." ;
    noria:siteId "DC-PAR-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Rue de la Paix"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "75002"^^xsd:string ;
    noria:sitePrincipalAddressCityName "Paris"^^xsd:string ;
    noria:sitePrincipalAddressCountry "FR"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" .

inst:ServerRoomA a noria:Room ;
    rdfs:label "Server Room A" ;
    rdfs:comment "Server room A within the Paris Data Center." ;
    bot:hasSpace inst:DataCenterParis .

inst:RackLocus1 a noria:Locus ;
    rdfs:label "Rack Locus 1" ;
    rdfs:comment "Specific locus for Rack 1 in Server Room A." ;
    bot:hasSpace inst:ServerRoomA ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "1"^^xsd:string .

inst:RackLocus2 a noria:Locus ;
    rdfs:label "Rack Locus 2" ;
    rdfs:comment "Specific locus for Rack 2 in Server Room A." ;
    bot:hasSpace inst:ServerRoomA ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "2"^^xsd:string .

# =============================================================================
# Structural objects (Resources, Network Interfaces, Network Links, Product Models)
# =============================================================================

inst:DellManufacturer a org:Organization ;
    rdfs:label "Dell Technologies" ;
    rdfs:comment "Manufacturer of server hardware." .

inst:CiscoManufacturer a org:Organization ;
    rdfs:label "Cisco Systems" ;
    rdfs:comment "Manufacturer of network hardware." .

inst:ServerProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740" ;
    rdfs:comment "Product model for Dell PowerEdge R740 server." ;
    noria:productManufacturedBy inst:DellManufacturer .

inst:RouterProductModel_CiscoASR9K a noria:ProductModel ;
    rdfs:label "Cisco ASR 9000 Series" ;
    rdfs:comment "Product model for Cisco ASR 9000 Series router." ;
    noria:productManufacturedBy inst:CiscoManufacturer .

inst:WebServer01 a noria:Resource ;
    rdfs:label "Web Server 01" ;
    rdfs:comment "Primary web server for customer-facing applications." ;
    noria:resourceLogisticId "ASSET-WEB-001"^^xsd:string ;
    noria:resourceHostName "webserver01.noria.local"^^xsd:string ;
    noria:resourceSerialNumber "SN-WEB-001-XYZ"^^xsd:string ;
    noria:resourceInstallationDate "2023-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceProductModel inst:ServerProductModel_DellR740 ;
    noria:resourceType inst:ServerResourceType ;
    noria:resourceUsageState inst:InUseState ;
    noria:resourceManagedBy inst:ITOperationsDept ;
    noria:locatedAtLocus inst:RackLocus1 ;
    noria:resourceManagementIPAddress "10.0.0.10"^^xsd:string ;
    noria:virtualServerStatus inst:OperationalStateUp .

inst:DBServer01 a noria:Resource ;
    rdfs:label "Database Server 01" ;
    rdfs:comment "Primary database server for critical data." ;
    noria:resourceLogisticId "ASSET-DB-001"^^xsd:string ;
    noria:resourceHostName "dbserver01.noria.local"^^xsd:string ;
    noria:resourceSerialNumber "SN-DB-001-ABC"^^xsd:string ;
    noria:resourceInstallationDate "2023-02-20T11:30:00Z"^^xsd:dateTime ;
    noria:resourceProductModel inst:ServerProductModel_DellR740 ;
    noria:resourceType inst:ServerResourceType ;
    noria:resourceUsageState inst:InUseState ;
    noria:resourceManagedBy inst:ITOperationsDept ;
    noria:locatedAtLocus inst:RackLocus1 ;
    noria:resourceManagementIPAddress "10.0.0.11"^^xsd:string ;
    noria:virtualServerStatus inst:OperationalStateUp .

inst:CoreRouter01 a noria:Resource ;
    rdfs:label "Core Router 01" ;
    rdfs:comment "Main router for the data center network." ;
    noria:resourceLogisticId "ASSET-RTR-001"^^xsd:string ;
    noria:resourceHostName "corerouter01.noria.local"^^xsd:string ;
    noria:resourceSerialNumber "SN-RTR-001-DEF"^^xsd:string ;
    noria:resourceInstallationDate "2022-11-01T09:00:00Z"^^xsd:dateTime ;
    noria:resourceProductModel inst:RouterProductModel_CiscoASR9K ;
    noria:resourceType inst:RouterResourceType ;
    noria:resourceUsageState inst:InUseState ;
    noria:resourceManagedBy inst:NetworkTeam ;
    noria:locatedAtLocus inst:RackLocus2 ;
    noria:resourceManagementIPAddress "10.0.0.1"^^xsd:string ;
    noria:virtualServerStatus inst:OperationalStateUp .

inst:CoreRouter02 a noria:Resource ;
    rdfs:label "Core Router 02" ;
    rdfs:comment "Secondary router for redundancy in the data center network." ;
    noria:resourceLogisticId "ASSET-RTR-002"^^xsd:string ;
    noria:resourceHostName "corerouter02.noria.local"^^xsd:string ;
    noria:resourceSerialNumber "SN-RTR-002-GHI"^^xsd:string ;
    noria:resourceInstallationDate "2022-11-01T09:30:00Z"^^xsd:dateTime ;
    noria:resourceProductModel inst:RouterProductModel_CiscoASR9K ;
    noria:resourceType inst:RouterResourceType ;
    noria:resourceUsageState inst:InUseState ;
    noria:resourceManagedBy inst:NetworkTeam ;
    noria:locatedAtLocus inst:RackLocus2 ;
    noria:resourceManagementIPAddress "10.0.0.2"^^xsd:string ;
    noria:virtualServerStatus inst:OperationalStateUp ;
    noria:clusterController inst:CoreRouter01 .

inst:WebServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "WebServer01 Ethernet 0" ;
    rdfs:comment "Ethernet interface 0 for Web Server 01." ;
    noria:networkInterfaceDescription "Primary network interface for web traffic."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceOf inst:WebServer01 ;
    noria:networkInterfaceAdministrativeStatus inst:AdministrativeStateEnabled ;
    noria:networkInterfaceOperationalStatus inst:OperationalStateUp ;
    noria:networkInterfaceRoutingPriorityMetric 100^^xsd:int .

inst:DBServer01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DBServer01 Ethernet 0" ;
    rdfs:comment "Ethernet interface 0 for Database Server 01." ;
    noria:networkInterfaceDescription "Primary network interface for database traffic."^^xsd:string ;
    noria:networkInterfaceType "physical"^^xsd:string ;
    noria:networkInterfaceOf inst:DBServer01 ;
    noria:networkInterfaceAdministrativeStatus inst:AdministrativeStateEnabled ;
    noria:networkInterfaceOperationalStatus inst:OperationalStateUp ;
    noria:networkInterfaceRoutingPriorityMetric 100^^xsd:int .

inst:CoreRouter01_Gig0_0_0 a noria:NetworkInterface ;
    rdfs:label "CoreRouter01 Gig0/0/0" ;
