# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# --- Custom KOS for this graph (based on NORIA schema indications) ---
@prefix kos-app-type: <https://w3id.org/noria/kos/application/type/> .
@prefix kos-app-bizimp: <https://w3id.org/noria/kos/application/business-importance/> .
@prefix kos-app-status: <https://w3id.org/noria/kos/application/status/> .
@prefix kos-app-sla: <https://w3id.org/noria/kos/application/sla-level/> .
@prefix kos-tt-sev: <https://w3id.org/noria/kos/TroubleTicket/severity/> .
@prefix kos-tt-type: <https://w3id.org/noria/kos/TroubleTicket/type/> .
@prefix kos-tt-crit: <https://w3id.org/noria/kos/TroubleTicket/category/> .
@prefix kos-tt-prio: <https://w3id.org/noria/kos/TroubleTicket/priority/> .
@prefix kos-tt-origin: <https://w3id.org/noria/kos/TroubleTicket/origin/> .
@prefix kos-tt-urg: <https://w3id.org/noria/kos/TroubleTicket/urgency/> .
@prefix kos-tt-tcat: <https://w3id.org/noria/kos/TroubleTicket/trouble-category/> .
@prefix kos-tt-probresp: <https://w3id.org/noria/kos/TroubleTicket/problemResponsibility/> .
@prefix kos-tt-comtype: <https://w3id.org/noria/kos/TroubleTicket/commentType/> .
@prefix kos-tt-optype: <https://w3id.org/noria/kos/TroubleTicket/operationType/> .
@prefix kos-cr-cat: <https://w3id.org/noria/kos/ChangeRequest/category/> .
@prefix kos-cr-type: <https://w3id.org/noria/kos/ChangeRequest/type/> .
@prefix kos-cr-cause: <https://w3id.org/noria/kos/ChangeRequest/cause/> .
@prefix kos-cr-status: <https://w3id.org/noria/kos/ChangeRequest/status/> .
@prefix kos-cr-spec: <https://w3id.org/noria/kos/ChangeRequest/specification/> .
@prefix kos-res-type: <https://w3id.org/noria/kos/Resource/type/> .
@prefix kos-res-lcs: <https://w3id.org/noria/kos/Resource/LifecycleState/> .
@prefix kos-res-opstate: <https://w3id.org/noria/kos/Resource/OperationalState/> .
@prefix kos-res-admstate: <https://w3id.org/noria/kos/Resource/AdministrativeState/> .
@prefix kos-notif-sev: <https://w3id.org/noria/kos/Notification/Severity/PerceivedSeverity/> .
@prefix kos-svc-type: <https://w3id.org/noria/kos/service/type/> .
@prefix kos-agent-contact: <https://w3id.org/noria/kos/org/agent-contact-method/> .

# =============================================================================
# KOS Concepts Declarations (as indicated by NORIA schema)
# =============================================================================

# Application Types
kos-app-type: a skos:ConceptScheme ; rdfs:label "Application Type Scheme"@en .
kos-app-type:infrastructure a skos:Concept ; skos:inScheme kos-app-type: ; rdfs:label "Infrastructure Application"@en ; rdfs:comment "An application providing core infrastructure services."@en .
kos-app-type:business a skos:Concept ; skos:inScheme kos-app-type: ; rdfs:label "Business Application"@en ; rdfs:comment "An application directly supporting business processes."@en .
kos-app-type:monitoring a skos:Concept ; skos:inScheme kos-app-type: ; rdfs:label "Monitoring Application"@en ; rdfs:comment "An application used for monitoring IT systems."@en .
kos-app-type:database a skos:Concept ; skos:inScheme kos-app-type: ; rdfs:label "Database Application"@en ; rdfs:comment "An application providing database services."@en .

# Application Business Importance
kos-app-bizimp: a skos:ConceptScheme ; rdfs:label "Application Business Importance Scheme"@en .
kos-app-bizimp:high a skos:Concept ; skos:inScheme kos-app-bizimp: ; rdfs:label "High Business Importance"@en ; rdfs:comment "Application is critical for business operations."@en .
kos-app-bizimp:medium a skos:Concept ; skos:inScheme kos-app-bizimp: ; rdfs:label "Medium Business Importance"@en ; rdfs:comment "Application supports important but not critical business functions."@en .
kos-app-bizimp:low a skos:Concept ; skos:inScheme kos-app-bizimp: ; rdfs:label "Low Business Importance"@en ; rdfs:comment "Application is non-critical for business operations."@en .

# Application Module Status
kos-app-status: a skos:ConceptScheme ; rdfs:label "Application Module Status Scheme"@en .
kos-app-status:InProduction a skos:Concept ; skos:inScheme kos-app-status: ; rdfs:label "In Production"@en ; rdfs:comment "The application module is currently active in a production environment."@en .
kos-app-status:Development a skos:Concept ; skos:inScheme kos-app-status: ; rdfs:label "Development"@en ; rdfs:comment "The application module is under development."@en .
kos-app-status:Staging a skos:Concept ; skos:inScheme kos-app-status: ; rdfs:label "Staging"@en ; rdfs:comment "The application module is in a staging environment for testing."@en .
kos-app-status:Decommissioned a skos:Concept ; skos:inScheme kos-app-status: ; rdfs:label "Decommissioned"@en ; rdfs:comment "The application module has been removed from service."@en .

# Application SLA Level
kos-app-sla: a skos:ConceptScheme ; rdfs:label "Application SLA Level Scheme"@en .
kos-app-sla:Platinum a skos:Concept ; skos:inScheme kos-app-sla: ; rdfs:label "Platinum SLA"@en ; rdfs:comment "Highest service level agreement, maximum availability and fastest response times."@en .
kos-app-sla:Gold a skos:Concept ; skos:inScheme kos-app-sla: ; rdfs:label "Gold SLA"@en ; rdfs:comment "High service level agreement, strong availability and quick response times."@en .
kos-app-sla:Silver a skos:Concept ; skos:inScheme kos-app-sla: ; rdfs:label "Silver SLA"@en ; rdfs:comment "Standard service level agreement."@en .

# Trouble Ticket Severity
kos-tt-sev: a skos:ConceptScheme ; rdfs:label "Trouble Ticket Severity Scheme"@en .
kos-tt-sev:Critical a skos:Concept ; skos:inScheme kos-tt-sev: ; rdfs:label "Critical"@en ; rdfs:comment "Service completely down or major business impact."@en .
kos-tt-sev:Major a skos:Concept ; skos:inScheme kos-tt-sev: ; rdfs:label "Major"@en ; rdfs:comment "Significant service degradation or partial business impact."@en .
kos-tt-sev:Minor a skos:Concept ; skos:inScheme kos-tt-sev: ; rdfs:label "Minor"@en ; rdfs:comment "Small impact, workaround available."@en .
kos-tt-sev:Warning a skos:Concept ; skos:inScheme kos-tt-sev: ; rdfs:label "Warning"@en ; rdfs:comment "Potential issue, no immediate impact."@en .

# Trouble Ticket Type
kos-tt-type: a skos:ConceptScheme ; rdfs:label "Trouble Ticket Type Scheme"@en .
kos-tt-type:Failure a skos:Concept ; skos:inScheme kos-tt-type: ; rdfs:label "Failure"@en ; rdfs:comment "Ticket related to a system or service failure."@en .
kos-tt-type:Assistance a skos:Concept ; skos:inScheme kos-tt-type: ; rdfs:label "Assistance"@en ; rdfs:comment "Ticket for user assistance or support."@en .
kos-tt-type:Maintenance a skos:Concept ; skos:inScheme kos-tt-type: ; rdfs:label "Maintenance"@en ; rdfs:comment "Ticket for scheduled or unscheduled maintenance."@en .

# Trouble Ticket Criticity (Category)
kos-tt-crit: a skos:ConceptScheme ; rdfs:label "Trouble Ticket Criticity Scheme"@en .
kos-tt-crit:InterruptedService a skos:Concept ; skos:inScheme kos-tt-crit: ; rdfs:label "Interrupted Service"@en ; rdfs:comment "Service is completely unavailable."@en .
kos-tt-crit:CorruptedService a skos:Concept ; skos:inScheme kos-tt-crit: ; rdfs:label "Corrupted Service"@en ; rdfs:comment "Service is available but data or functionality is compromised."@en .
kos-tt-crit:DegradedPerformance a skos:Concept ; skos:inScheme kos-tt-crit: ; rdfs:label "Degraded Performance"@en ; rdfs:comment "Service is slow or performing below expected levels."@en .

# Trouble Ticket Priority
kos-tt-prio: a skos:ConceptScheme ; rdfs:label "Trouble Ticket Priority Scheme"@en .
kos-tt-prio:P1 a skos:Concept ; skos:inScheme kos-tt-prio: ; rdfs:label "Priority 1"@en ; rdfs:comment "Highest priority, immediate action required."@en .
kos-tt-prio:P2 a skos:Concept ; skos:inScheme kos-tt-prio: ; rdfs:label "Priority 2"@en ; rdfs:comment "High priority, urgent action required."@en .
kos-tt-prio:P3 a skos:Concept ; skos:inScheme kos-tt-prio: ; rdfs:label "Priority 3"@en ; rdfs:comment "Medium priority, action required within a defined timeframe."@en .
kos-tt-prio:P4 a skos:Concept ; skos:inScheme kos-tt-prio: ; rdfs:label "Priority 4"@en ; rdfs:comment "Low priority, routine action."@en .

# Trouble Ticket Origin
kos-tt-origin: a skos:ConceptScheme ; rdfs:label "Trouble Ticket Origin Scheme"@en .
kos-tt-origin:Customer a skos:Concept ; skos:inScheme kos-tt-origin: ; rdfs:label "Customer"@en ; rdfs:comment "Ticket initiated by a customer."@en .
kos-tt-origin:Supervision a skos:Concept ; skos:inScheme kos-tt-origin: ; rdfs:label "Supervision System"@en ; rdfs:comment "Ticket initiated by an automated monitoring system."@en .
kos-tt-origin:Internal a skos:Concept ; skos:inScheme kos-tt-origin: ; rdfs:label "Internal User"@en ; rdfs:comment "Ticket initiated by an internal user or employee."@en .

# Trouble Ticket Urgency
kos-tt-urg: a skos:ConceptScheme ; rdfs:label "Trouble Ticket Urgency Scheme"@en .
kos-tt-urg:ImmediateIntervention a skos:Concept ; skos:inScheme kos-tt-urg: ; rdfs:label "Immediate Intervention"@en ; rdfs:comment "Requires immediate action to prevent further damage or restore service."@en .
kos-tt-urg:DeferredIntervention a skos:Concept ; skos:inScheme kos-tt-urg: ; rdfs:label "Deferred Intervention"@en ; rdfs:comment "Action can be scheduled for a later time without critical impact."@en .

# Trouble Ticket Trouble Category
kos-tt-tcat: a skos:ConceptScheme ; rdfs:label "Trouble Ticket Trouble Category Scheme"@en .
kos-tt-tcat:NetworkOutage a skos:Concept ; skos:inScheme kos-tt-tcat: ; rdfs:label "Network Outage"@en ; rdfs:comment "Complete loss of network connectivity."@en .
kos-tt-tcat:ServerFailure a skos:Concept ; skos:inScheme kos-tt-tcat: ; rdfs:label "Server Failure"@en ; rdfs:comment "A server is not functioning."@en .
kos-tt-tcat:SoftwareBug a skos:Concept ; skos:inScheme kos-tt-tcat: ; rdfs:label "Software Bug"@en ; rdfs:comment "An error in software causing malfunction."@en .

# Trouble Ticket Problem Responsibility
kos-tt-probresp: a skos:ConceptScheme ; rdfs:label "Trouble Ticket Problem Responsibility Scheme"@en .
kos-tt-probresp:InternalIT a skos:Concept ; skos:inScheme kos-tt-probresp: ; rdfs:label "Internal IT"@en ; rdfs:comment "Responsibility lies with internal IT department."@en .
kos-tt-probresp:Vendor a skos:Concept ; skos:inScheme kos-tt-probresp: ; rdfs:label "Vendor"@en ; rdfs:comment "Responsibility lies with a third-party vendor."@en .
kos-tt-probresp:Customer a skos:Concept ; skos:inScheme kos-tt-probresp: ; rdfs:label "Customer"@en ; rdfs:comment "Responsibility lies with the customer."@en .

# Trouble Ticket Comment Type
kos-tt-comtype: a skos:ConceptScheme ; rdfs:label "Trouble Ticket Comment Type Scheme"@en .
kos-tt-comtype:Internal a skos:Concept ; skos:inScheme kos-tt-comtype: ; rdfs:label "Internal Comment"@en ; rdfs:comment "Comment visible only to internal staff."@en .
kos-tt-comtype:CustomerVisible a skos:Concept ; skos:inScheme kos-tt-comtype: ; rdfs:label "Customer Visible Comment"@en ; rdfs:comment "Comment visible to the customer."@en .

# Trouble Ticket Operation Type
kos-tt-optype: a skos:ConceptScheme ; rdfs:label "Trouble Ticket Operation Type Scheme"@en .
kos-tt-optype:Diagnosis a skos:Concept ; skos:inScheme kos-tt-optype: ; rdfs:label "Diagnosis"@en ; rdfs:comment "Notes related to diagnostic steps taken."@en .
kos-tt-optype:Resolution a skos:Concept ; skos:inScheme kos-tt-optype: ; rdfs:label "Resolution"@en ; rdfs:comment "Notes related to the resolution steps."@en .
kos-tt-optype:CustomerUpdate a skos:Concept ; skos:inScheme kos-tt-optype: ; rdfs:label "Customer Update"@en ; rdfs:comment "Notes for customer communication."@en .

# Change Request Category
kos-cr-cat: a skos:ConceptScheme ; rdfs:label "Change Request Category Scheme"@en .
kos-cr-cat:InternalIntervention a skos:Concept ; skos:inScheme kos-cr-cat: ; rdfs:label "Internal Intervention"@en ; rdfs:comment "Change performed by internal teams."@en .
kos-cr-cat:ThirdPartyIntervention a skos:Concept ; skos:inScheme kos-cr-cat: ; rdfs:label "Third Party Intervention"@en ; rdfs:comment "Change performed by external vendors."@en .

# Change Request Type
kos-cr-type: a skos:ConceptScheme ; rdfs:label "Change Request Type Scheme"@en .
kos-cr-type:Standard a skos:Concept ; skos:inScheme kos-cr-type: ; rdfs:label "Standard Change"@en ; rdfs:comment "Pre-approved, low-risk change."@en .
kos-cr-type:Normal a skos:Concept ; skos:inScheme kos-cr-type: ; rdfs:label "Normal Change"@en ; rdfs:comment "Requires assessment and authorization."@en .
kos-cr-type:Emergency a skos:Concept ; skos:inScheme kos-cr-type: ; rdfs:label "Emergency Change"@en ; rdfs:comment "Urgent change to resolve an incident."@en .

# Change Request Cause
kos-cr-cause: a skos:ConceptScheme ; rdfs:label "Change Request Cause Scheme"@en .
kos-cr-cause:Configuration a skos:Concept ; skos:inScheme kos-cr-cause: ; rdfs:label "Configuration Change"@en ; rdfs:comment "Change due to configuration update."@en .
kos-cr-cause:SoftwareUpgrade a skos:Concept ; skos:inScheme kos-cr-cause: ; rdfs:label "Software Upgrade"@en ; rdfs:comment "Change due to software version upgrade."@en .
kos-cr-cause:NetworkExtension a skos:Concept ; skos:inScheme kos-cr-cause: ; rdfs:label "Network Extension"@en ; rdfs:comment "Change due to network infrastructure expansion."@en .

# Change Request Status
kos-cr-status: a skos:ConceptScheme ; rdfs:label "Change Request Status Scheme"@en .
kos-cr-status:Planned a skos:Concept ; skos:inScheme kos-cr-status: ; rdfs:label "Planned"@en ; rdfs:comment "Change is scheduled."@en .
kos-cr-status:InProgress a skos:Concept ; skos:inScheme kos-cr-status: ; rdfs:label "In Progress"@en ; rdfs:comment "Change is currently being implemented."@en .
kos-cr-status:Completed a skos:Concept ; skos:inScheme kos-cr-status: ; rdfs:label "Completed"@en ; rdfs:comment "Change has been successfully implemented."@en .
kos-cr-status:Failed a skos:Concept ; skos:inScheme kos-cr-status: ; rdfs:label "Failed"@en ; rdfs:comment "Change implementation failed."@en .

# Change Request Specification
kos-cr-spec: a skos:ConceptScheme ; rdfs:label "Change Request Specification Scheme"@en .
kos-cr-spec:StandardProcedure a skos:Concept ; skos:inScheme kos-cr-spec: ; rdfs:label "Standard Procedure"@en ; rdfs:comment "Change follows a documented standard operating procedure."@en .
kos-cr-spec:CustomScript a skos:Concept ; skos:inScheme kos-cr-spec: ; rdfs:label "Custom Script"@en ; rdfs:comment "Change requires a custom script or manual steps."@en .

# Resource Type
kos-res-type: a skos:ConceptScheme ; rdfs:label "Resource Type Scheme"@en .
kos-res-type:Server a skos:Concept ; skos:inScheme kos-res-type: ; rdfs:label "Server"@en ; rdfs:comment "A physical or virtual server."@en .
kos-res-type:Router a skos:Concept ; skos:inScheme kos-res-type: ; rdfs:label "Router"@en ; rdfs:comment "A network router device."@en .
kos-res-type:Switch a skos:Concept ; skos:inScheme kos-res-type: ; rdfs:label "Switch"@en ; rdfs:comment "A network switch device."@en .
kos-res-type:Firewall a skos:Concept ; skos:inScheme kos-res-type: ; rdfs:label "Firewall"@en ; rdfs:comment "A network security firewall."@en .
kos-res-type:DatabaseServer a skos:Concept ; skos:inScheme kos-res-type: ; rdfs:label "Database Server"@en ; rdfs:comment "A server dedicated to hosting databases."@en .
kos-res-type:LoadBalancer a skos:Concept ; skos:inScheme kos-res-type: ; rdfs:label "Load Balancer"@en ; rdfs:comment "A device distributing network traffic."@en .
kos-res-type:VirtualMachine a skos:Concept ; skos:inScheme kos-res-type: ; rdfs:label "Virtual Machine"@en ; rdfs:comment "A virtualized computing instance."@en .

# Resource Lifecycle State
kos-res-lcs: a skos:ConceptScheme ; rdfs:label "Resource Lifecycle State Scheme"@en .
kos-res-lcs:InProduction a skos:Concept ; skos:inScheme kos-res-lcs: ; rdfs:label "In Production"@en ; rdfs:comment "Resource is actively used in production."@en .
kos-res-lcs:Staging a skos:Concept ; skos:inScheme kos-res-lcs: ; rdfs:label "Staging"@en ; rdfs:comment "Resource is in a staging environment."@en .
kos-res-lcs:Decommissioned a skos:Concept ; skos:inScheme kos-res-lcs: ; rdfs:label "Decommissioned"@en ; rdfs:comment "Resource has been removed from service."@en .
kos-res-lcs:Maintenance a skos:Concept ; skos:inScheme kos-res-lcs: ; rdfs:label "Under Maintenance"@en ; rdfs:comment "Resource is temporarily out of service for maintenance."@en .

# Resource Operational State
kos-res-opstate: a skos:ConceptScheme ; rdfs:label "Resource Operational State Scheme"@en .
kos-res-opstate:Up a skos:Concept ; skos:inScheme kos-res-opstate: ; rdfs:label "Up"@en ; rdfs:comment "Resource is operational."@en .
kos-res-opstate:Down a skos:Concept ; skos:inScheme kos-res-opstate: ; rdfs:label "Down"@en ; rdfs:comment "Resource is not operational."@en .
kos-res-opstate:Degraded a skos:Concept ; skos:inScheme kos-res-opstate: ; rdfs:label "Degraded"@en ; rdfs:comment "Resource is operational but with reduced performance."@en .

# Resource Administrative State
kos-res-admstate: a skos:ConceptScheme ; rdfs:label "Resource Administrative State Scheme"@en .
kos-res-admstate:Enabled a skos:Concept ; skos:inScheme kos-res-admstate: ; rdfs:label "Enabled"@en ; rdfs:comment "Resource is administratively enabled."@en .
kos-res-admstate:Disabled a skos:Concept ; skos:inScheme kos-res-admstate: ; rdfs:label "Disabled"@en ; rdfs:comment "Resource is administratively disabled."@en .

# Notification Severity (PerceivedSeverity)
kos-notif-sev: a skos:ConceptScheme ; rdfs:label "Notification Perceived Severity Scheme"@en .
kos-notif-sev:Critical a skos:Concept ; skos:inScheme kos-notif-sev: ; rdfs:label "Critical"@en ; rdfs:comment "Highest severity, immediate attention required."@en .
kos-notif-sev:Major a skos:Concept ; skos:inScheme kos-notif-sev: ; rdfs:label "Major"@en ; rdfs:comment "High severity, significant impact."@en .
kos-notif-sev:Minor a skos:Concept ; skos:inScheme kos-notif-sev: ; rdfs:label "Minor"@en ; rdfs:comment "Low severity, minor impact."@en .
kos-notif-sev:Warning a skos:Concept ; skos:inScheme kos-notif-sev: ; rdfs:label "Warning"@en ; rdfs:comment "Potential issue, no immediate impact."@en .
kos-notif-sev:Informational a skos:Concept ; skos:inScheme kos-notif-sev: ; rdfs:label "Informational"@en ; rdfs:comment "For information purposes only."@en .

# Service Type
kos-svc-type: a skos:ConceptScheme ; rdfs:label "Service Type Scheme"@en .
kos-svc-type:CustomerFacingService a skos:Concept ; skos:inScheme kos-svc-type: ; rdfs:label "Customer Facing Service"@en ; rdfs:comment "A service directly consumed by customers."@en .
kos-svc-type:ResourceFacingService a skos:Concept ; skos:inScheme kos-svc-type: ; rdfs:label "Resource Facing Service"@en ; rdfs:comment "A service supporting other services or internal operations."@en .

# Agent Contact Method
kos-agent-contact: a skos:ConceptScheme ; rdfs:label "Agent Contact Method Scheme"@en .
kos-agent-contact:Email a skos:Concept ; skos:inScheme kos-agent-contact: ; rdfs:label "Email"@en ; rdfs:comment "Preferred contact method is email."@en .
kos-agent-contact:Phone a skos:Concept ; skos:inScheme kos-agent-contact: ; rdfs:label "Phone"@en ; rdfs:comment "Preferred contact method is phone."@en .
kos-agent-contact:TicketingSystem a skos:Concept ; skos:inScheme kos-agent-contact: ; rdfs:label "Ticketing System"@en ; rdfs:comment "Preferred contact method is via the ticketing system."@en .

# =============================================================================
# Agents (Teams and Individuals)
# =============================================================================

:Agent_NetOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the core network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod kos-agent-contact:Phone ;
    noria:agentInstructions "For critical issues, call the hotline. For non-critical, use the ticketing system."@en .

:Agent_AppDevTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos-agent-contact:Email ;
    noria:agentInstructions "Submit all requests via Jira. Urgent issues require prior email notification."@en .

:Agent_DBATeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "8:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos-agent-contact:TicketingSystem ;
    noria:agentInstructions "Create a ticket for all database-related requests. Escalation via phone for P1 incidents."@en .

:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC) Team"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod kos-agent-contact:Phone ;
    noria:agentInstructions "Report all security incidents immediately via dedicated hotline."@en .

:Agent_JohnDoe a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, member of the Network Operations Team."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    foaf:phone "+1-555-123-4567" ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos-agent-contact:Phone .

:Agent_JaneSmith a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Database Administrator, member of the Database Administration Team."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    foaf:phone "+1-555-987-6543" ;
    noria:agentWorkingHours "8:30-16:30 (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod kos-agent-contact:Email .

:Agent_AliceJohnson a foaf:Agent, foaf:Person ;
