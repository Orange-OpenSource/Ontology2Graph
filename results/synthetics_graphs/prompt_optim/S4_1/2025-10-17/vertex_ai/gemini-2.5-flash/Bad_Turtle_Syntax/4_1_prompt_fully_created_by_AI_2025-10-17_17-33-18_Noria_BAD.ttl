# =============================================================================
# Event Records
# =============================================================================

:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "Interface ge-0/0/1 on cr01.par.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject :Resource_CoreRouter_01 ;
    noria:logOriginatingManagementSystem :Application_NetworkMonitoring ;
    noria:alarmSeverity kos-notif-sev:Critical .

:EventRecord_WebServerHighCPU a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alert"@en ;
