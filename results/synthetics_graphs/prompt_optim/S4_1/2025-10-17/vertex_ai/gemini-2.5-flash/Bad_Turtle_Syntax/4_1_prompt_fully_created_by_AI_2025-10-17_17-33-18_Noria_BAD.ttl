# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

:OperationPlan_RouterInterfaceTroubleshooting a noria:OperationPlan ;
    rdfs:label "Router Interface Troubleshooting Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving router interface issues."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition :ActionPostCondition_InterfaceUp .

:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: A network interface reports an operational status of 'down'."@en .

:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface reports an operational status of 'up' and traffic flows normally."@en .

:OperationPlan_WebServerScaling a noria:OperationPlan ;
    rdfs:label "Web Server Scaling Procedure"@en ;
    rdfs:comment "Procedure to scale up web server resources in response to high load."@en ;
    noria:operationPlanPreCondition :ActionPreCondition_HighCPU ;
    noria:operationPlanPostCondition :ActionPostCondition_NormalCPU .

:ActionPreCondition_HighCPU a noria:ActionPreCondition ;
    rdfs:label "High CPU Utilization"@en ;
    rdfs:comment "Condition: CPU utilization on web server exceeds threshold for sustained period."@en .

:ActionPostCondition_NormalCPU a noria:ActionPostCondition ;
    rdfs:label "Normal CPU Utilization"@en ;
    rdfs:comment "Expected outcome: CPU utilization returns to normal levels after scaling."@en .

# Linking an EventRecord to a proposed repair action (OperationPlan)
:EventRecord_RouterInterfaceDown noria:alarmProposedRepairAction :OperationPlan_RouterInterfaceTroubleshooting .

# Linking a TroubleTicketNote to a correlated execution (e.g., a procedure execution container)
# For simplicity, let's assume a hypothetical procedure execution container for the diagnosis steps.
:ProcedureExecutionContainer_TT001_Diag a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution for TT-001 Diagnosis"@en ;
    rdfs:comment "Container for actions taken during initial diagnosis of TT-001."@en .

:TroubleTicketNote_001_01 noria:troubleTicketNoteCorrelatedExecution :ProcedureExecutionContainer_TT001_Diag .

# Example of an EventRecord being part of a ProcedureExecutionContainer
:EventRecord_RouterInterfaceDown pep:member :ProcedureExecutionContainer_TT001_Diag .

# Example of an alarm being mitigated by a procedure execution container
:ProcedureExecutionContainer_TT001_Resolution a pep:ProcedureExecutionContainer ;
    rdfs:label "Procedure Execution for TT-001 Resolution"@en ;
    rdfs:comment "Container for actions taken to resolve TT-001, including ISP repair."@en .

# Assuming the interface comes back up after resolution
:EventRecord_RouterInterfaceUp a noria:EventRecord ;
    rdfs:label "Router Interface Up Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 01 came back up."@en ;
    noria:loggingTime "2024-04-20T12:45:00Z"^^xsd:dateTime ;
    noria:logText "Interface ge-0/0/1 on cr01.par.example.com changed state to up."@en ;
    noria:logOriginatingManagedObject :Resource_CoreRouter_01 ;
    noria:logOriginatingManagementSystem :Application_NetworkMonitoring ;
    noria:alarmSeverity kos-notif-sev:Informational ;
    pep:member :ProcedureExecutionContainer_TT001_Resolution .

:TroubleTicket_001 noria:alarmMitigatedBy :ProcedureExecutionContainer_TT001_Resolution .

# Example of a Change Request impacting a service and resource
:ChangeRequest_001 noria:changeRequestImpact :Service_PublicWebAccess .

# Further connections to ensure density
:Agent_NetOpsTeam noria:agentManagesResource :Resource_CoreRouter_01, :Resource_CoreRouter_02 .
:Agent_AppDevTeam noria:agentManagesResource :Resource_WebServer_01, :Resource_VirtualMachine_App01, :Resource_Hypervisor_01 .
