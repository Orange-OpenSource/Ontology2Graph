noria:EventRecord_DNS_Down_Log a noria:EventRecord ;
    rdfs:label "DNS Server Down Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: Host dns01.corp.example.com is DOWN - PING CRITICAL - Packet loss = 100%"@en ;
    noria:logOriginatingManagedObject noria:Resource_DNS01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_Interface_Down_Log a noria:EventRecord ;
    rdfs:label "Network Interface Down Log"@en ;
    rdfs:comment "Log entry for Edge Router interface ge-0/0/1 going down."@en ;
    noria:loggingTime "2024-04-20T08:55:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface ge-0/0/1, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_Router_Edge01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_Config_Change_Log a noria:EventRecord ;
