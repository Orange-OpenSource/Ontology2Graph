# --- noria:Resource instances ---
noria-data:Resource_RouterCore1
    a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Primary core router in the main data center."@en ;
    noria:resourceLogisticId "LOG-RT-001"^^xsd:string ;
    noria:resourceHostName "core-router-01"^^xsd:string ;
    noria:resourceSerialNumber "SN-CR01-XYZ"^^xsd:string ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:ipAddress_10-0-0-1 ;
    noria:resourceManagedBy noria-data:OrgUnit_NetworkOps ;
    noria:resourceProductModel noria-data:ProductModel_Cisco3850 ;
    noria:resourceType noria-kos:Resource-type:Router ;
    noria:resourceUsageState noria-kos:Resource-LifecycleState:InProduction ;
    noria:locatedAtLocus noria-data:Locus_RackA01 ;
    noria:clusterController noria-data:Resource_ClusterManager1 .

noria-data:Resource_ServerAppDB
    a noria:Resource ;
    rdfs:label "Application Database Server"@en ;
    rdfs:comment "Server hosting the main application database."@en ;
    noria:resourceLogisticId "LOG-DB-002"^^xsd:string ;
    noria:resourceHostName "app-db-server-02"^^xsd:string ;
    noria:resourceSerialNumber "SN-DB02-ABC"^^xsd:string ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress observable:ipAddress_10-0-0-2 ;
    noria:resourceManagedBy noria-data:OrgUnit_AppDev ;
    noria:resourceProductModel noria-data:ProductModel_DellPowerEdgeR740 ;
    noria:resourceType noria-kos:Resource-type:Server ;
    noria:resourceUsageState noria-kos:Resource-LifecycleState:InProduction ;
    noria:locatedAtLocus noria-data:Locus_RackA01 ;
    noria:virtualServerStatus noria-kos:Resource-OperationalState:Up .

noria-data:Resource_EdgeSwitchParis
    a noria:Resource ;
    rdfs:label "Paris Edge Switch"@en ;
    rdfs:comment "Network switch at the Paris edge location."@en ;
    noria:resourceLogisticId "LOG-ES-003"^^xsd:string ;
