    rdfs:label "Network Link Flap Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating frequent up/down transitions on a network link."@en ;
    folio:hasConsequence noria-data:TroubleTicket_TT001 .

# --- noria:OperationPlan instances ---
noria-data:OperationPlan_RestartInterface
    a noria:OperationPlan ;
    rdfs:label "Restart Network Interface Procedure"@en ;
    rdfs:comment "Standard operating procedure to restart a faulty network interface."@en ;
    pep:hasInput noria-data:ActionPreCondition_InterfaceDown ;
    pep:hasOutput noria-data:ActionPostCondition_InterfaceUp .

noria-data:OperationPlan_DBOptimization
    a noria:OperationPlan ;
    rdfs:label "Database Query Optimization Procedure"@en ;
    rdfs:comment "Procedure for identifying and optimizing slow database queries."@en ;
    pep:hasInput noria-data:ActionPreCondition_SlowQueries ;
    pep:hasOutput noria-data:ActionPostCondition_ImprovedPerformance .

# --- noria:ActionPreCondition and noria:ActionPostCondition instances ---
noria-data:ActionPreCondition_InterfaceDown
    a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Pre-Condition"@en ;
    rdfs:comment "Pre-condition: The target network interface is in a 'down' operational state."@en .

noria-data:ActionPostCondition_InterfaceUp
    a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Post-Condition"@en ;
    rdfs:comment "Post-condition: The target network interface is in an 'up' operational state."@en .

noria-data:ActionPreCondition_SlowQueries
    a noria:ActionPreCondition ;
    rdfs:label "Slow Database Queries Pre-Condition"@en ;
    rdfs:comment "Pre-condition: Database queries are executing slower than expected thresholds."@en .

noria-data:ActionPostCondition_ImprovedPerformance
    a noria:ActionPostCondition ;
    rdfs:label "Improved Database Performance Post-Condition"@en ;
    rdfs:comment "Post-condition: Database query response times are within acceptable limits."@en .

# --- Linking actions to operation plans (using EventRecord as proxy for action) ---
noria-data:EventRecord_LinkDown
    noria:alarmMitigatedBy noria-data:EventRecord_InterfaceRestarted .

noria-data:EventRecord_InterfaceRestarted
    a noria:EventRecord ;
    rdfs:label "Interface Restarted Event"@en ;
    rdfs:comment "Event recording the successful restart of a network interface."@en ;
    noria:loggingTime "2024-01-20T10:20:00Z"^^xsd:dateTime ;
    noria:logText "Interface GigabitEthernet0/0/1 restarted successfully."^^xsd:string ;
    noria:logOriginatingManagedObject noria-data:Resource_RouterCore1 ;
    noria:logOriginatingManagementSystem noria-data:Application_MonitoringSystem ;
    noria:logOriginatingAgent noria-data:Agent_Alice ;
    pep:usedProcedure noria-data:OperationPlan_RestartInterface .

noria-data:EventRecord_DBOptimizationAction
    a noria:EventRecord ;
    rdfs:label "DB Optimization Action Event"@en ;
    rdfs:comment "Event recording an action taken for database optimization."@en ;
    noria:loggingTime "2024-01-20T11:15:00Z"^^xsd:dateTime ;
    noria:logText "Executed query optimization script on app-db-server-02."^^xsd:string ;
    noria:logOriginatingManagedObject noria-data:Resource_ServerAppDB ;
    noria:logOriginatingManagementSystem noria-data:Application_CoreBanking ;
    noria:logOriginatingAgent noria-data:Agent_Bob ;
    pep:usedProcedure noria-data:OperationPlan_DBOptimization .

# Additional interconnections to ensure all nodes are linked
