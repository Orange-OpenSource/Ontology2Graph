    noria:elementProperty noria-data:Property_LinkFlapCount .

noria-data:Property_LinkFlapCount
    a noria:Property ;
    rdfs:label "Link Flap Count Property"@en ;
    rdfs:comment "A property representing the number of link flaps within a time period."@en ;
    noria:structuralElementObservableData "5"^^xsd:int .

# Ensure all abstract classes have concrete instances or are covered by sub-classes
# noria:ManagedElement -> covered by all concrete classes
# noria:Property -> noria:ProductModel, noria:StructuralProperty (implicit), noria:Property_HighImpact, noria:Property_HighCPUThreshold, noria:Property_LinkFlapCount
# noria:StructuralElement -> noria:Resource, noria:NetworkInterface, noria:NetworkLink
# noria:StructuralObservable -> noria:ProductModel (ProductModel is subClassOf StructuralProperty, which is subClassOf StructuralObservable)
# noria:FunctionalElement -> noria:Application, noria:ApplicationModule, noria:Service
# noria:DynamicElement -> noria:CorporateUserIdentifier, noria:TroubleTicket, noria:TroubleTicketNote, noria:ChangeRequest, noria:DocumentAttachment, noria:EventRecord
# noria:ProceduralElement -> noria:AnomalyPattern, noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition

# Additional entities for variety and scale
