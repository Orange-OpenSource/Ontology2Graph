    noria:elementProperty noria-data:Property_HighCPUThreshold .

noria-data:Property_HighCPUThreshold
    a noria:Property ;
    rdfs:label "High CPU Threshold Property"@en ;
    rdfs:comment "A property representing a threshold for high CPU usage."@en ;
    noria:structuralElementObservableData "80"^^xsd:int .

