# --- foaf:Agent and org:OrganizationalUnit instances ---
noria-data:Agent_Alice
    a foaf:Person ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "An IT administrator responsible for network infrastructure."@en ;
    foaf:name "Alice Smith"^^xsd:string ;
    foaf:mbox "mailto:alice.smith@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Contact via email for non-urgent issues, phone for critical alerts."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method:Email .

noria-data:Agent_Bob
    a foaf:Person ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "A software developer working on the core application."@en ;
    foaf:name "Bob Johnson"^^xsd:string ;
    foaf:mbox "mailto:bob.johnson@example.com"^^xsd:anyURI ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"^^xsd:string ;
    noria:agentInstructions "Use internal chat for quick questions, ticketing system for bugs."^^xsd:string ;
    noria:agentPreferredContactMethod noria-kos:agent-contact-method:Chat .

noria-data:OrgUnit_NetworkOps
    a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing the network infrastructure."@en ;
    org:unitOf noria-data:Org_ITDepartment .

noria-data:OrgUnit_AppDev
    a org:OrganizationalUnit ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining core applications."@en ;
    org:unitOf noria-data:Org_ITDepartment .

noria-data:Org_ITDepartment
    a org:Organization ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "The main IT department of the company."@en .

noria-data:CUid_Alice
    a noria:CorporateUserIdentifier ;
    rdfs:label "Alice's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Smith."@en ;
    foaf:accountName "asmith"^^xsd:string ;
    observable:accountIdentifier "CU-ASMITH-001"^^xsd:string ;
    foaf:holdsAccount noria-data:Agent_Alice .

# --- noria:Room and noria:Locus instances ---
noria-data:Room_ServerRoom314
    a noria:Room ;
    rdfs:label "Server Room 314"@en ;
    rdfs:comment "Main data center server room."@en ;
    bot:hasSpace noria-data:Locus_RackA01 .

noria-data:Room_EdgeLocationParis
    a noria:Room ;
    rdfs:label "Edge Location Paris"@en ;
    rdfs:comment "Small server room at Paris edge location."@en ;
    bot:hasSpace noria-data:Locus_RackB05 .

noria-data:Locus_RackA01
    a noria:Locus ;
    rdfs:label "Rack A01 in Server Room 314"@en ;
    rdfs:comment "Specific rack location for servers."@en ;
    noria:locusLine "A"^^xsd:string ;
    noria:locusRow "01"^^xsd:string .

noria-data:Locus_RackB05
    a noria:Locus ;
    rdfs:label "Rack B05 in Edge Location Paris"@en ;
    rdfs:comment "Specific rack location for edge devices."@en ;
    noria:locusLine "B"^^xsd:string ;
    noria:locusRow "05"^^xsd:string .

noria-data:Site_MainDC
    a bot:Site ;
    rdfs:label "Main Data Center Site"@en ;
    rdfs:comment "The primary data center facility."@en ;
    noria:siteId "DC-MAIN-01"^^xsd:string ;
    noria:siteType "data center"^^xsd:string ;
    noria:sitePrincipalAddress "123 Datacenter Ave"^^xsd:string ;
    noria:sitePrincipalAddressPostalCode "10001"^^xsd:string ;
    noria:sitePrincipalAddressCityName "New York"^^xsd:string ;
    noria:sitePrincipalAddressCountry "US"^^xsd:string ;
    noria:sitePrincipalAddressStreet "Datacenter Avenue"^^xsd:string ;
    bot:hasSpace noria-data:Room_ServerRoom314 .

