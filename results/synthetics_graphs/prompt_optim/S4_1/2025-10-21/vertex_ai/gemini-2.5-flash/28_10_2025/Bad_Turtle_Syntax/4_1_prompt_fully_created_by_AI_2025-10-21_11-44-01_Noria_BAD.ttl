<https://w3id.org/noria/data/operationplan/OP_DNS_Restart> a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS service."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/data/actioncondition/APC_DNS_Unreachable> ;
