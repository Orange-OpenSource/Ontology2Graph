    pep:hasStep <https://w3id.org/noria/data/operationplan/OP_DNS_Restart_Step1> .

<https://w3id.org/noria/data/operationplan/OP_DNS_Restart_Step1> a pep:Step ;
    rdfs:label "Check DNS Service Status"@en ;
    rdfs:comment "Verify current status of DNS service using 'systemctl status named'."@en ;
    pep:hasInput "systemctl status named" ;
    pep:hasOutput "Service status output" .

<https://w3id.org/noria/data/operationplan/OP_Firewall_Rollback> a noria:OperationPlan ;
    rdfs:label "Firewall Rule Rollback Procedure"@en ;
    rdfs:comment "Procedure to revert recent firewall configuration changes."@en ;
