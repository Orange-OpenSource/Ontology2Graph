# =============================================================================
# Anomaly Patterns (noria:AnomalyPattern)
# =============================================================================

<https://w3id.org/noria/data/anomalypattern/AP_HighCPULowThroughput> a noria:AnomalyPattern ;
    rdfs:label "High CPU, Low Throughput Anomaly"@en ;
    rdfs:comment "Pattern indicating a potential performance bottleneck or application issue: high CPU usage on a server combined with low network throughput, suggesting internal processing issues rather than network saturation."@en ;
    folio:hasCause "Application deadlock or inefficient code"@en ;
    folio:hasEffect "Service degradation, slow response times"@en .

# =============================================================================
# Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

<https://w3id.org/noria/data/actioncondition/APC_DNS_Unreachable> a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unreachable"@en ;
    rdfs:comment "Condition: Primary DNS server is not reachable via network protocols (e.g., ping, DNS query)."@en ;
    skos:example "Ping to dns01.corp.example.com fails; dig @dns01.corp.example.com fails."@en .

<https://w3id.org/noria/data/actioncondition/APOC_DNS_Resolved> a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: Primary DNS server is reachable and responding to DNS queries correctly."@en ;
    skos:example "Ping to dns01.corp.example.com succeeds; dig @dns01.corp.example.com returns expected results."@en .

<https://w3id.org/noria/data/actioncondition/APC_Firewall_Misconfig> a noria:ActionPreCondition ;
    rdfs:label "Firewall Misconfiguration Suspected"@en ;
    rdfs:comment "Condition: Network connectivity issues observed immediately after a firewall configuration change."@en ;
    skos:example "Traffic to specific ports/IPs blocked after CR_FirewallRuleChange_002."@en .

<https://w3id.org/noria/data/actioncondition/APOC_Connectivity_Restored> a noria:ActionPostCondition ;
    rdfs:label "Network Connectivity Restored"@en ;
    rdfs:comment "Outcome: Affected network connectivity is fully restored and stable."@en ;
    skos:example "All services reachable, no packet loss, stable latency."@en .

