# Organizational Units (Teams)
<https://w3id.org/noria/data/org/DNSAdminTeam> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:label "Équipe d'Administration DNS"@fr ;
    rdfs:comment "Team responsible for DNS server management and resolution of related incidents."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for routine issues, phone for critical outages."@en .

<https://w3id.org/noria/data/org/NetworkOpsTeam> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call the hotline for network-related critical incidents."@en .

<https://w3id.org/noria/data/org/AppSupportTeamA> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:label "Équipe Support Applicatif A"@fr ;
    rdfs:comment "Supports critical business applications like the Customer Portal and Billing Service."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Submit a ticket via the internal portal for all requests."@en .

<https://w3id.org/noria/data/org/SecurityTeam> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:label "Centre des Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Monitors and responds to security incidents across the IT landscape."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate notification required for any detected security breach."@en .

<https://w3id.org/noria/data/org/CustomerService> a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Customer Service Department"@en ;
    rdfs:label "Service Client"@fr ;
    rdfs:comment "First point of contact for customer inquiries and issues."@en ;
