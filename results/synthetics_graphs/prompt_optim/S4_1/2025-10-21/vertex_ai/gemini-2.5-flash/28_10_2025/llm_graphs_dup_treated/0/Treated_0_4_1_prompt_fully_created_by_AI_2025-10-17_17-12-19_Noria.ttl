# =============================================================================
# Agents and Organizations
# =============================================================================

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for the overall IT infrastructure_extra_node_12 and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_12> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical_extra_node_12 incidents, use emergency hotline."@en .

org:NetworkTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure_extra_node_12."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_12> ;
    noria:agentInstructions "Open a ticket for non-urgent requests. Call directly for network outages."@en ;
    org:member foaf:JohnDoe_extra_node_12, foaf:JaneSmith_extra_node_12 .

org:ApplicationSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business_extra_node_12 applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system_extra_node_12> ;
    noria:agentInstructions "All application-related issues must be reported via the dedicated application support portal."@en .

org:SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring_extra_node_12 and responding to security_extra_node_12 incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alert-system> ;
    noria:agentInstructions "Automated alerts are processed by the SOC. For manual reporting, use the security_extra_node_12 incident form."@en .

org:HardwareVendor a org:Organization ;
    rdfs:label "GlobalTech Hardware Inc."@en ;
    rdfs:comment "Manufacturer of server_extra_node_12 and network equipment."@en .

org:SoftwareVendor a org:Organization ;
    rdfs:label "AppSolutions Corp."@en ;
    rdfs:comment "Provider of enterprise application software."@en .

foaf:JohnDoe_extra_node_12 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com_extra_node_12> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_12> ;
    noria:agentInstructions "Available for urgent network issues."@en ;
    noria:agentManagesResource noria:RouterCore1_extra_node_12, noria:FirewallDMZ_extra_node_12 .

foaf:JaneSmith_extra_node_12 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Support Lead."@en ;
    foaf:mbox <mailto:jane.smith@example.com_extra_node_12> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email_extra_node_12> ;
    noria:agentInstructions "Primary contact for ERP system issues."@en ;
    noria:agentManagesResource noria:ERPAppModuleProd .

foaf:CustomerA a foaf:Agent ;
    rdfs:label "Customer_extra_node_12 A Corp."@en ;
    rdfs:comment "A key corporate customer utilizing various services."@en .

foaf:SystemUser1 a foaf:Agent ;
    rdfs:label "System User_extra_node_12 1"@en ;
    rdfs:comment "An end-user of the corporate IT services."@en .

noria:CUidJohnDoe_extra_node_12 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Unique identifier for John Doe within the organization_extra_node_12's IT systems."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:JohnDoe_extra_node_12 .

