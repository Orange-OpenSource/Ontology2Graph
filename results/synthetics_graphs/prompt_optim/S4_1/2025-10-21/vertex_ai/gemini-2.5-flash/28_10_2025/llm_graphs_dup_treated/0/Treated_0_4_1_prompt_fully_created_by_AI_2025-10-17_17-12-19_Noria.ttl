# Anomaly Pattern
noria:HighCPULoadPattern a noria:AnomalyPattern ;
    rdfs:label "High_extra_node_12 CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high_extra_node_12 CPU utilization, potentially leading to performance degradation or service outage."@en ;
    skos:example "Triggered when CPU usage exceeds 90% for more than 10 minutes on a critical_extra_node_12 server_extra_node_12."@en .

# Linking EventRecord to AnomalyPattern (via folio:hasFailureMode)
noria:EventRecordWebSrvCPUAlarm folio:hasFailureMode noria:HighCPULoadPattern .

# Linking TroubleTicket to AnomalyPattern (via folio:hasFailureMode)
noria:TroubleTicket20240420_002 folio:hasFailureMode noria:HighCPULoadPattern .

# Linking a CUid to an EventRecord as logOriginatingAgent
noria:EventRecordRouterConfigChange noria:logOriginatingAgent noria:CUidJohnDoe_extra_node_12 .

# Linking a TroubleTicket to a specific characteristic (example of noria:troubleTicketCharacteristic)
noria:TroubleTicket20240420_001 noria:troubleTicketCharacteristic [
    a noria:Property ;
    rdfs:label "Impacted Customer_extra_node_12 Count"@en ;
    rdfs:comment "Number of customers affected by the DNS outage."@en ;
    rdf:value "50"^^xsd:int
] .

noria:TroubleTicket20240420_002 noria:troubleTicketCharacteristic [
    a noria:Property ;
    rdfs:label "Affected Business Unit"@en ;
    rdfs:comment "The business_extra_node_12 unit most affected by the ERP performance degradation."@en ;
    rdf:value "Finance Department"@en
] .

# Example of DocumentAttachment
noria:NetworkDiagramPDF a noria:DocumentAttachment ;
