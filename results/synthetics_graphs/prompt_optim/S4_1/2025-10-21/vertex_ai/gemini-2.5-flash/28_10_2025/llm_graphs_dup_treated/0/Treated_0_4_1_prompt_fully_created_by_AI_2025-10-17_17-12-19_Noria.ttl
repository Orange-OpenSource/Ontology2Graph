] .

# Example of noria:troubleTicketFreezeItem
noria:TroubleTicket20240420_001 noria:troubleTicketFreezeItem noria:EventRecordFreezeStart, noria:EventRecordFreezeEnd .

noria:EventRecordFreezeStart a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Start"@en ;
    rdfs:comment "Ticket put on hold due to external dependency."@en ;
    noria:logText "Ticket INC-DNS-2024-001 frozen due to awaiting vendor response."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational_extra_node_12> .

noria:EventRecordFreezeEnd a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze End"@en ;
    rdfs:comment "Ticket unfrozen, vendor response received."@en ;
    noria:logText "Ticket INC-DNS-2024-001 unfrozen. Vendor provided workaround."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational_extra_node_12> .

