# -----------------------------------------------------------------------------
# Trouble Tickets (noria:TroubleTicket)
# -----------------------------------------------------------------------------

noria:TroubleTicket_DNS_Outage_TT a noria:TroubleTicket ;
    rdfs:label "Critical DNS Server Outage"@en ;
    rdfs:label "Panne Critique Serveur DNS"@fr ;
    dcterms:identifier "TT-2024-04-20-001" ;
    dcterms:description "Primary DNS server is down, impacting all corporate services relying on name resolution."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_DNS_Outage_Log ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios Monitoring" ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCriticity <kos/TroubleTicket/category/InterruptedService> ;
    noria:troubleTicketCause "Hardware failure on primary DNS server."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-20T09:00:05Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable true ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty org:Team_NetworkOperations ;
    noria:troubleTicketRelatedParty foaf:Agent_AliceSmith ;
    noria:troubleTicketRelatedService noria:Application_DNS_Service ;
    noria:troubleTicketRelatedResource noria:Resource_DNS01 ;
    noria:troubleTicketImpacts noria:Application_CorporateWebPortal ;
    noria:troubleTicketImpacts noria:Service_InternetAccess ;
    noria:documentHRef <https://itsm.example.com/ticket/TT-2024-04-20-001> ;
    noria:documentStatusHistory noria:EventRecord_DNS_Outage_Log ;
    noria:documentStatusHistory noria:EventRecord_DNS_Restored .

noria:TroubleTicket_WebSrv_Performance_TT a noria:TroubleTicket ;
    rdfs:label "Web Portal Performance Degradation"@en ;
    rdfs:label "Dégradation Performance Portail Web"@fr ;
    dcterms:identifier "TT-2024-04-20-002" ;
    dcterms:description "Users report slow response times for the Corporate Web Portal. High CPU on websrv01 detected."@en ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Assistance> ;
