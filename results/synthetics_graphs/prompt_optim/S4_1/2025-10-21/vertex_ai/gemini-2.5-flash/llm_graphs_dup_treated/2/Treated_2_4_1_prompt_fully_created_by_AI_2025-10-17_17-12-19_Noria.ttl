    rdfs:comment "Log entry for a configuration change on Core Router 1."@en ;
    noria:logOriginatingManagedObject noria:RouterCore1 ;
    noria:logOriginatingAgent foaf:JohnDoe ;
    noria:logText "Configuration changed by jdoe from console. Interface Gi0/0/1 shutdown."@en ;
    noria:loggingTime "2024-04-19T15:45:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecordFirewallBlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en ;
    rdfs:comment "Alert from DMZ Firewall indicating blocked suspicious traffic."@en ;
