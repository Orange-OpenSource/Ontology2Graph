# Anomaly Pattern
noria:HighCPULoadPattern a noria:AnomalyPattern ;
    rdfs:label "High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization, potentially leading to performance degradation or service outage."@en ;
    skos:example "Triggered when CPU usage exceeds 90% for more than 10 minutes on a critical server."@en .

# Linking EventRecord to AnomalyPattern (via folio:hasFailureMode)
noria:EventRecordWebSrvCPUAlarm folio:hasFailureMode noria:HighCPULoadPattern .

# Linking TroubleTicket to AnomalyPattern (via folio:hasFailureMode)
noria:TroubleTicket20240420_002 folio:hasFailureMode noria:HighCPULoadPattern .

# Linking a CUid to an EventRecord as logOriginatingAgent
noria:EventRecordRouterConfigChange noria:logOriginatingAgent noria:CUidJohnDoe .

# Linking a TroubleTicket to a specific characteristic (example of noria:troubleTicketCharacteristic)
noria:TroubleTicket20240420_001 noria:troubleTicketCharacteristic [
    a noria:Property ;
    rdfs:label "Impacted Customer Count"@en ;
    rdfs:comment "Number of customers affected by the DNS outage."@en ;
    rdf:value "50"^^xsd:int
] .

noria:TroubleTicket20240420_002 noria:troubleTicketCharacteristic [
    a noria:Property ;
    rdfs:label "Affected Business Unit"@en ;
    rdfs:comment "The business unit most affected by the ERP performance degradation."@en ;
    rdf:value "Finance Department"@en
] .

# Example of DocumentAttachment
noria:NetworkDiagramPDF a noria:DocumentAttachment ;
    rdfs:label "Network Diagram DC1"@en ;
    rdfs:comment "PDF document showing the network topology of Data Center 1."@en ;
    dcterms:format "application/pdf" ;
    dcterms:identifier "NET-DIAG-DC1-V2.pdf" ;
    dcterms:isPartOf noria:TroubleTicket20240420_001 ;
    dcterms:isPartOf noria:ChangeRequest20240419_001 .

noria:ScreenshotERPError a noria:DocumentAttachment ;
    rdfs:label "ERP Error Screenshot"@en ;
    rdfs:comment "Screenshot of the error message encountered by a user in the ERP system."@en ;
    dcterms:format "image/png" ;
    dcterms:identifier "ERP-ERROR-20240420.png" ;
    dcterms:isPartOf noria:TroubleTicket20240420_002 .

# Example of noria:troubleTicketPartyIntervention
noria:TroubleTicket20240420_001 noria:troubleTicketPartyIntervention [
    a noria:Property ;
    rdfs:label "Initial Assignment"@en ;
    rdfs:comment "Ticket initially assigned to Network Team."@en ;
    dcterms:created "2024-04-20T09:02:00Z"^^xsd:dateTime ;
    dcterms:creator org:ITOperationsDept ;
    rdf:value org:NetworkTeam
] .

noria:TroubleTicket20240420_001 noria:troubleTicketPartyIntervention [
    a noria:Property ;
    rdfs:label "Escalation to L3"@en ;
    rdfs:comment "Escalated to L3 Network Engineer John Doe."@en ;
    dcterms:created "2024-04-20T09:30:00Z"^^xsd:dateTime ;
    dcterms:creator org:NetworkTeam ;
    rdf:value foaf:JohnDoe
] .

# Example of noria:troubleTicketFreezeItem
noria:TroubleTicket20240420_001 noria:troubleTicketFreezeItem noria:EventRecordFreezeStart, noria:EventRecordFreezeEnd .

noria:EventRecordFreezeStart a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze Start"@en ;
    rdfs:comment "Ticket put on hold due to external dependency."@en ;
    noria:logText "Ticket INC-DNS-2024-001 frozen due to awaiting vendor response."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecordFreezeEnd a noria:EventRecord ;
    rdfs:label "Trouble Ticket Freeze End"@en ;
    rdfs:comment "Ticket unfrozen, vendor response received."@en ;
    noria:logText "Ticket INC-DNS-2024-001 unfrozen. Vendor provided workaround."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# Example of noria:alarmMitigatedBy
noria:EventRecordWebSrvCPUAlarm noria:alarmMitigatedBy noria:TroubleTicket20240420_002 .

