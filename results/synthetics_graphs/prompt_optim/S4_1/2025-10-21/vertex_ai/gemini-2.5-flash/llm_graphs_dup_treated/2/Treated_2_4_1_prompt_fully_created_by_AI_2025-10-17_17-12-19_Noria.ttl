# =============================================================================
# Agents and Organizations
# =============================================================================

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for the overall IT infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical incidents, use emergency hotline."@en .

org:NetworkTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_12> ;
    noria:agentInstructions "Open a ticket for non-urgent requests. Call directly for network outages."@en ;
    org:member foaf:JohnDoe, foaf:JaneSmith .

org:ApplicationSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "All application-related issues must be reported via the dedicated application support portal."@en .

org:SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alert-system> ;
    noria:agentInstructions "Automated alerts are processed by the SOC. For manual reporting, use the security incident form."@en .

org:HardwareVendor a org:Organization ;
    rdfs:label "GlobalTech Hardware Inc."@en ;
    rdfs:comment "Manufacturer of server and network equipment."@en .

org:SoftwareVendor a org:Organization ;
    rdfs:label "AppSolutions Corp."@en ;
    rdfs:comment "Provider of enterprise application software."@en .

foaf:JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_12> ;
    noria:agentInstructions "Available for urgent network issues."@en ;
    noria:agentManagesResource noria:RouterCore1, noria:FirewallDMZ .

foaf:JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Support Lead."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Primary contact for ERP system issues."@en ;
    noria:agentManagesResource noria:ERPAppModuleProd .

foaf:CustomerA a foaf:Agent ;
    rdfs:label "Customer A Corp."@en ;
    rdfs:comment "A key corporate customer utilizing various services."@en .

foaf:SystemUser1 a foaf:Agent ;
    rdfs:label "System User 1"@en ;
    rdfs:comment "An end-user of the corporate IT services."@en .

noria:CUidJohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Unique identifier for John Doe within the organization's IT systems."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:JohnDoe .

# =============================================================================
# Product Models
# =============================================================================

noria:ProductModelDellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy org:HardwareVendor .

noria:ProductModelCiscoNexus9K a noria:ProductModel ;
    rdfs:label "Cisco Nexus 9000 Series"@en ;
    rdfs:comment "Data center switch series."@en ;
    noria:productManufacturedBy org:HardwareVendor .

noria:ProductModelPaloAltoFW a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5200 Series"@en ;
    rdfs:comment "Next-generation firewall appliance."@en ;
    noria:productManufacturedBy org:HardwareVendor .

noria:ProductModelVMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Industry-leading bare-metal hypervisor."@en ;
    noria:productManufacturedBy org:SoftwareVendor .

# =============================================================================
# Locations
# =============================================================================

bot:DataCenterParis a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center location in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" .

bot:OfficeLyon a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office in Lyon with local IT infrastructure."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès" .

noria:ServerRoomDC1 a noria:Room ;
    rdfs:label "Server Room DC1"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace bot:DataCenterParis .

noria:NetworkRoomDC1 a noria:Room ;
    rdfs:label "Network Room DC1"@en ;
    rdfs:comment "Dedicated network equipment room in Paris Data Center."@en ;
    bot:hasSpace bot:DataCenterParis .

noria:LocusRackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Rack A1 in Server Room DC1."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:containsZone noria:ServerRoomDC1 .

noria:LocusRackB2 a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:comment "Location of network devices in Rack B2 in Network Room DC1."@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" ;
    bot:containsZone noria:NetworkRoomDC1 .

# =============================================================================
# Resources
# =============================================================================

noria:DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network services."@en ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModelDellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:CorpDNSApp ;
    noria:locatedAtLocus noria:LocusRackA1 ;
    noria:resourceManagementIPAddress <http://ip.example.com/192.168.1.10> .

noria:WebSrv01 a noria:Resource ;
    rdfs:label "Corporate Web Server 01"@en ;
    rdfs:comment "Web server hosting internal corporate applications."@en ;
    noria:resourceManagedBy org:ApplicationSupportTeam ;
    noria:resourceLogisticId "LOG-WEB-001" ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModelDellR740 ;
    noria:resourceType <kos/Resource/type/virtual-machine_extra_node_12> ;
    noria:resourceSerialNumber "SN-WEB-001-ABC" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:ERPApp ;
    noria:locatedAtLocus noria:LocusRackA1 ;
    noria:resourceManagementIPAddress <http://ip.example.com/10.0.0.100> .

noria:RouterCore1 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
    rdfs:comment "Main router for the corporate network backbone."@en ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModelCiscoNexus9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTR-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-11-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:LocusRackB2 ;
    noria:resourceManagementIPAddress <http://ip.example.com/172.16.0.1> .

noria:FirewallDMZ a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:comment "Firewall protecting the Demilitarized Zone (DMZ)."@en ;
    noria:resourceManagedBy org:SecurityTeam ;
    noria:resourceLogisticId "LOG-FW-001" ;
    noria:resourceHostName "fw-dmz-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModelPaloAltoFW ;
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceSerialNumber "SN-FW-001-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:LocusRackB2 ;
    noria:resourceManagementIPAddress <http://ip.example.com/192.168.2.1> .

noria:Hypervisor01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server running virtual machines."@en ;
    noria:resourceManagedBy org:ITOperationsDept ;
    noria:resourceLogisticId "LOG-HV-001" ;
    noria:resourceHostName "hypervisor01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModelDellR740 ;
    noria:resourceType <kos/Resource/type/hypervisor> ;
    noria:resourceSerialNumber "SN-HV-001-JKL" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-02-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:LocusRackA1 ;
    noria:resourceManagementIPAddress <http://ip.example.com/192.168.1.20> ;
    noria:clusterController noria:vCenterServer .

noria:vCenterServer a noria:Resource ;
    rdfs:label "vCenter Server"@en ;
    rdfs:comment "Centralized management for VMware vSphere environments."@en ;
    noria:resourceManagedBy org:ITOperationsDept ;
    noria:resourceHostName "vcenter.corp.example.com" ;
    noria:resourceType <kos/Resource/type/virtual-machine_extra_node_12> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication noria:VirtualizationPlatform .

# =============================================================================
# Network Interfaces
# =============================================================================

noria:DNS01Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Management interface for DNS01" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:DNS01 ;
    noria:networkInterfaceConnects noria:LinkDNS01Core1 .

noria:WebSrv01Eth0 a noria:NetworkInterface ;
    rdfs:label "WebSrv01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for WebSrv01."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Application interface for WebSrv01" ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceOf noria:WebSrv01 ;
    noria:networkInterfaceConnects noria:LinkWebSrv01Core1 .

noria:RouterCore1Gi0_0_0 a noria:NetworkInterface ;
    rdfs:label "RouterCore1 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface from Core Router 1 to DNS01."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceDescription "Link to DNS01" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:RouterCore1 ;
    noria:networkInterfaceConnects noria:LinkDNS01Core1 .

noria:RouterCore1Gi0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore1 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Uplink interface from Core Router 1 to FirewallDMZ."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric 10 ;
    noria:networkInterfaceDescription "Link to DMZ Firewall" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:RouterCore1 ;
    noria:networkInterfaceConnects noria:LinkCore1FirewallDMZ .

noria:FirewallDMZEth0 a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ Ethernet 0"@en ;
    rdfs:comment "Interface for DMZ Firewall connected to Core Router 1."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "Internal interface to Core Router" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:FirewallDMZ ;
    noria:networkInterfaceConnects noria:LinkCore1FirewallDMZ .

noria:FirewallDMZEth1 a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ Ethernet 1"@en ;
    rdfs:comment "Interface for DMZ Firewall connected to external network."@en ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceDescription "External interface to Internet" ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceOf noria:FirewallDMZ ;
    noria:networkInterfaceConnects noria:LinkFirewallDMZInternet .

# =============================================================================
# Network Links
# =============================================================================

noria:LinkDNS01Core1 a noria:NetworkLink ;
    rdfs:label "Link DNS01 - Core Router 1"@en ;
    rdfs:comment "Network link between DNS01 server and Core Router 1."@en ;
    noria:networkLinkId "NL-DNS01-RTR01" ;
    noria:networkLinkTerminationResourceOrigin noria:DNS01 ;
    noria:networkLinkTerminationResourceDestination noria:RouterCore1 ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 1Gbps" .

noria:LinkWebSrv01Core1 a noria:NetworkLink ;
    rdfs:label "Link WebSrv01 - Core Router 1"@en ;
    rdfs:comment "Network link between WebSrv01 and Core Router 1."@en ;
    noria:networkLinkId "NL-WEB01-RTR01" ;
    noria:networkLinkTerminationResourceOrigin noria:WebSrv01 ;
    noria:networkLinkTerminationResourceDestination noria:RouterCore1 ;
    noria:networkLinkInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Virtual Ethernet 10Gbps" .

noria:LinkCore1FirewallDMZ a noria:NetworkLink ;
    rdfs:label "Link Core Router 1 - DMZ Firewall"@en ;
    rdfs:comment "Network link between Core Router 1 and DMZ Firewall."@en ;
    noria:networkLinkId "NL-RTR01-FWDMZ" ;
    noria:networkLinkTerminationResourceOrigin noria:RouterCore1 ;
    noria:networkLinkTerminationResourceDestination noria:FirewallDMZ ;
    noria:networkLinkInstallationDate "2021-11-01T08:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 10Gbps" .

noria:LinkFirewallDMZInternet a noria:NetworkLink ;
    rdfs:label "Link DMZ Firewall - Internet"@en ;
    rdfs:comment "External network link from DMZ Firewall to the Internet."@en ;
    noria:networkLinkId "NL-FWDMZ-INT" ;
    noria:networkLinkTerminationResourceOrigin noria:FirewallDMZ ;
    noria:networkLinkInstallationDate "2022-05-10T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "MPLS VPN 1Gbps" .

