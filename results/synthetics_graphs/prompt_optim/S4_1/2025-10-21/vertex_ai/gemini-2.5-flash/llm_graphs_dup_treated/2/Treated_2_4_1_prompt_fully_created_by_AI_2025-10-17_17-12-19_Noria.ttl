# =============================================================================
# Services
# =============================================================================

noria:InternetAccessService a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "End-to-end service providing internet access to corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:FirewallDMZ, noria:RouterCore1 .

noria:VPNService a noria:Service ;
    rdfs:label "Remote VPN Access Service"@en ;
    rdfs:comment "Service enabling secure remote access to the corporate network."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:FirewallDMZ .

noria:InternalDNSResolutionService a noria:Service ;
    rdfs:label "Internal DNS Resolution Service"@en ;
    rdfs:comment "Service providing DNS resolution for internal applications and resources."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:CorpDNSAppModuleProd, noria:DNS01 .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecordDNSFailure a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:logOriginatingManagedObject noria:DNS01 ;
    noria:logOriginatingManagementSystem noria:MonitoringAppModuleProd ;
    noria:logText "DNS server dns01.corp.example.com is unreachable on port 53."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:DNSFailoverProcedure .

noria:EventRecordWebSrvCPUAlarm a noria:EventRecord ;
    rdfs:label "Web Server CPU High Alarm"@en ;
    rdfs:comment "Alarm triggered due to high CPU utilization on WebSrv01."@en ;
