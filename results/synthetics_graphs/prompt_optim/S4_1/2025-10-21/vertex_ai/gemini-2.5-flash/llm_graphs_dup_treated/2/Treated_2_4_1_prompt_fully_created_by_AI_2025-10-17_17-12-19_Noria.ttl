# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:DNSFailoverProcedure a noria:OperationPlan ;
    rdfs:label "DNS Failover Procedure"@en ;
    rdfs:comment "Standard operating procedure for failing over DNS services in case of primary server failure."@en ;
    noria:operationPlanPreCondition noria:PreCondDNSPrimaryDown ;
    noria:operationPlanPostCondition noria:PostCondDNSServiceRestored .

noria:RouterConfigUpdate a noria:OperationPlan ;
    rdfs:label "Router Configuration Update Procedure"@en ;
    rdfs:comment "Procedure for safely updating router configurations."@en ;
    noria:operationPlanPreCondition noria:PreCondRouterAccessOK ;
    noria:operationPlanPostCondition noria:PostCondRouterConfigApplied .

noria:PreCondDNSPrimaryDown a noria:ActionPreCondition ;
    rdfs:label "Primary DNS Server Down"@en ;
    rdfs:comment "Condition: Primary DNS server is confirmed to be unreachable or unresponsive."@en .

noria:PostCondDNSServiceRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Outcome: DNS resolution is functional and accessible from all clients."@en .

noria:PreCondRouterAccessOK a noria:ActionPreCondition ;
    rdfs:label "Router Access Verified"@en ;
    rdfs:comment "Condition: Secure access to the router is established and verified."@en .

noria:PostCondRouterConfigApplied a noria:ActionPostCondition ;
    rdfs:label "Router Configuration Applied and Verified"@en ;
    rdfs:comment "Outcome: New configuration is applied, saved, and network connectivity is verified."@en .

# =============================================================================
# Correlated Executions (linking EventRecords to Procedures/Actions)
# =============================================================================

noria:EventRecordDNSFailoverAction a noria:EventRecord ;
    rdfs:label "DNS Failover Action Log"@en ;
    rdfs:comment "Log entry for the execution of the DNS failover procedure."@en ;
    noria:logOriginatingManagedObject noria:DNS01 ;
    noria:logOriginatingManagementSystem noria:MonitoringPlatform ;
    noria:logOriginatingAgent foaf:JohnDoe ;
    noria:logText "Executed DNS failover script. Primary DNS marked as down, traffic shifted to secondary."@en ;
    noria:loggingTime "2024-04-20T09:40:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:alarmProposedRepairAction noria:DNSFailoverProcedure ;
    pep:usedProcedure noria:DNSFailoverProcedure .

noria:TroubleTicket20240420_001 noria:documentStatusHistory noria:EventRecordDNSFailoverAction .

noria:EventRecordRouterConfigApplied a noria:EventRecord ;
    rdfs:label "Router Config Applied Log"@en ;
    rdfs:comment "Log entry confirming successful application of router configuration."@en ;
    noria:logOriginatingManagedObject noria:RouterCore1 ;
    noria:logOriginatingAgent foaf:JohnDoe ;
    noria:logText "Configuration changes applied successfully to router-core-01.corp.example.com. Interface Gi0/0/1 brought down."@en ;
    noria:loggingTime "2024-04-19T15:35:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    pep:usedProcedure noria:RouterConfigUpdate .

noria:ChangeRequest20240419_001 noria:documentStatusHistory noria:EventRecordRouterConfigApplied .

noria:EventRecordWebSrvRestart a noria:EventRecord ;
    rdfs:label "Web Server Restart Log"@en ;
    rdfs:comment "Log entry for restarting WebSrv01 to mitigate high CPU."@en ;
    noria:logOriginatingManagedObject noria:WebSrv01 ;
    noria:logOriginatingManagementSystem noria:MonitoringPlatform ;
    noria:logOriginatingAgent foaf:JaneSmith ;
    noria:logText "WebSrv01 restarted to clear high CPU load. Monitoring for stability."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:TroubleTicket20240420_002 noria:documentStatusHistory noria:EventRecordWebSrvRestart .

noria:TTNote20240420_002_2 a noria:TroubleTicketNote ;
    rdfs:label "Web Server Restart Note"@en ;
    rdfs:comment "Restarted WebSrv01. CPU utilization dropped to normal levels. Monitoring ERP performance."@en ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/CorrectiveAction> ;
    dcterms:created "2024-04-20T11:05:00Z"^^xsd:dateTime ;
    dcterms:creator foaf:JaneSmith ;
    dcterms:isPartOf noria:TroubleTicket20240420_002 ;
    noria:troubleTicketNoteCorrelatedExecution noria:EventRecordWebSrvRestart .

