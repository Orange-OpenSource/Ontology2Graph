    noria:logOriginatingManagementSystem noria:MonitoringAppModuleProd ;
    noria:logText "CPU utilization on websrv01.corp.example.com exceeded 90% for 15 minutes."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmMonitoredAttribute "CPU_Usage" .

noria:EventRecordRouterConfigChange a noria:EventRecord ;
