# --- Operation Plans (noria:OperationPlan) ---
<operationplan/CheckFiberLink> a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Procedure to diagnose and potentially repair a suspected fiber optic link issue."@en ;
    skos:example "1. Verify physical_extra_node_4 connection. 2. Check optical power levels. 3. Test continuity with OTDR."@en ;
    noria:operationPlanPreCondition <actionprecondition/FiberLinkDown> ;
    noria:operationPlanPostCondition <actionpostcondition/FiberLinkRestored> .

<operationplan/RestartWebServer> a noria:OperationPlan ;
    rdfs:label "Restart Web Server_extra_node_4 Procedure"@en ;
    rdfs:comment "Standard_extra_node_4 procedure for restarting a web server_extra_node_4 in case of performance issues."@en ;
    skos:example "1. Check logs for errors. 2. Attempt graceful restart. 3. Force restart if necessary. 4. Verify service availability."@en ;
    noria:operationPlanPreCondition <actionprecondition/WebServerUnresponsive> ;
    noria:operationPlanPostCondition <actionpostcondition/WebServerOperational> .

<operationplan/DiskCleanup> a noria:OperationPlan ;
    rdfs:label "Database_extra_node_4 Disk Cleanup Procedure"@en ;
    rdfs:comment "Procedure to free up_extra_node_4 disk space on database servers."@en ;
    skos:example "1. Identify largest files. 2. Archive old logs. 3. Delete temporary files. 4. Verify free space."@en ;
    noria:operationPlanPreCondition <actionprecondition/DiskSpaceLow> ;
    noria:operationPlanPostCondition <actionpostcondition/DiskSpaceNormal> .

<operationplan/RestartBackendServer> a noria:OperationPlan ;
    rdfs:label "Restart Backend Server_extra_node_4 Procedure"@en ;
    rdfs:comment "Procedure to restart an unhealthy backend web server_extra_node_4."@en ;
    skos:example "1. Isolate server_extra_node_4 from load balancer. 2. Log in and check application status. 3. Restart application service. 4. Re-add to load balancer pool."@en ;
    noria:operationPlanPreCondition <actionprecondition/BackendServerUnhealthy> ;
    noria:operationPlanPostCondition <actionpostcondition/BackendServerHealthy> .

# --- Procedural Elements (noria:ProceduralElement) ---
<proceduralelement/DDoSResponsePlan> a noria:ProceduralElement, noria:OperationPlan ;
    rdfs:label "DDoS Attack Response Plan"@en ;
    rdfs:comment "Standard_extra_node_4 operating procedure for responding to a Distributed Denial of Service attack."@en ;
    skos:example "1. Verify attack. 2. Activate scrubbing center. 3. Block malicious IPs. 4. Notify stakeholders."@en ;
    noria:operationPlanPreCondition <actionprecondition/DDoSAttackDetected> ;
    noria:operationPlanPostCondition <actionpostcondition/DDoSAttackMitigated> .

<proceduralelement/SecurityIncidentResponse> a noria:ProceduralElement, noria:OperationPlan ;
    rdfs:label "Security Incident Response Plan"@en ;
    rdfs:comment "General procedure for responding to security_extra_node_4 incidents."@en ;
    skos:example "1. Containment. 2. Eradication. 3. Recovery. 4. Post-incident analysis."@en ;
    noria:operationPlanPreCondition <actionprecondition/SecurityIncidentDetected> ;
    noria:operationPlanPostCondition <actionpostcondition/SecurityIncidentResolved> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
<actionprecondition/FiberLinkDown> a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-condition"@en ;
    rdfs:comment "Condition: A network interface connected to a fiber link reports an 'administratively down' or 'operational down' status."@en .

<actionpostcondition/FiberLinkRestored> a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored Post-condition"@en ;
    rdfs:comment "Condition: The network interface connected to the fiber link reports an 'up_extra_node_4' operational status and traffic flows normally."@en .

<actionprecondition/WebServerUnresponsive> a noria:ActionPreCondition ;
    rdfs:label "Web Server_extra_node_4 Unresponsive Pre-condition"@en ;
    rdfs:comment "Condition: Web server_extra_node_4 is not responding to HTTP requests or showing high_extra_node_4 resource utilization."@en .

<actionpostcondition/WebServerOperational> a noria:ActionPostCondition ;
    rdfs:label "Web Server_extra_node_4 Operational Post-condition"@en ;
    rdfs:comment "Condition: Web server_extra_node_4 is responding to HTTP requests, and resource utilization is within normal limits."@en .

<actionprecondition/DiskSpaceLow> a noria:ActionPreCondition ;
    rdfs:label "Low Disk Space Pre-condition"@en ;
    rdfs:comment "Condition: Disk utilization on a critical_extra_node_4 server_extra_node_4 exceeds 90%."@en .

<actionpostcondition/DiskSpaceNormal> a noria:ActionPostCondition ;
    rdfs:label "Normal Disk Space Post-condition"@en ;
    rdfs:comment "Condition: Disk utilization on the server_extra_node_4 is below 80% after cleanup."@en .

<actionprecondition/BackendServerUnhealthy> a noria:ActionPreCondition ;
    rdfs:label "Backend Server_extra_node_4 Unhealthy Pre-condition"@en ;
    rdfs:comment "Condition: Load balancer health check fails for a backend server_extra_node_4."@en .

<actionpostcondition/BackendServerHealthy> a noria:ActionPostCondition ;
    rdfs:label "Backend Server_extra_node_4 Healthy Post-condition"@en ;
    rdfs:comment "Condition: Load balancer health check passes for the backend server_extra_node_4, and it's serving traffic."@en .

<actionprecondition/DDoSAttackDetected> a noria:ActionPreCondition ;
    rdfs:label "DDoS Attack Detected Pre-condition"@en ;
    rdfs:comment "Condition: High_extra_node_4 volume of suspicious traffic detected towards public-facing services, exceeding normal thresholds."@en .

<actionpostcondition/DDoSAttackMitigated> a noria:ActionPostCondition ;
    rdfs:label "DDoS Attack Mitigated Post-condition"@en ;
    rdfs:comment "Condition: Malicious traffic is filtered, and legitimate traffic flow is restored to normal levels."@en .

<actionprecondition/SecurityIncidentDetected> a noria:ActionPreCondition ;
    rdfs:label "Security Incident Detected Pre-condition"@en ;
    rdfs:comment "Condition: A security_extra_node_4 alert or anomaly pattern indicates a potential security_extra_node_4 breach or attack."@en .

<actionpostcondition/SecurityIncidentResolved> a noria:ActionPostCondition ;
    rdfs:label "Security Incident Resolved_extra_node_4 Post-condition"@en ;
    rdfs:comment "Condition: The security_extra_node_4 threat has been neutralized, systems are secured, and normal operations resumed."@en .

