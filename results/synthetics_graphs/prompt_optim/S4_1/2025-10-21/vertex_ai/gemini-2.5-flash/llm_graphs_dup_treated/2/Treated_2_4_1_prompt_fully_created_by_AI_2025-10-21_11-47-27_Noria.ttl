    noria:logOriginatingManagedObject <resource/Firewall_FW01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform_extra_node_4> ;
    noria:logText "SECURITY ALERT: High_extra_node_4 volume of SYN packets from external IP 198.51.100.1 blocked by FW01." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_4> ;
    noria:logOriginatingAgent <agent/Team_SecurityOps> ;
