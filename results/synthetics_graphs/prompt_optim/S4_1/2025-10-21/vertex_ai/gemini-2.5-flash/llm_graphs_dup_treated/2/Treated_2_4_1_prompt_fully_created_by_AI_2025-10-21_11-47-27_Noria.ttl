    noria:logOriginatingManagementSystem <application/MonitoringPlatform_extra_node_4> ;
    noria:logText "CRITICAL: Interface Ge0/0/1 on core01.prod.example.com changed state to down." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_4> ;
    noria:alarmProposedRepairAction <operationplan/CheckFiberLink> ;
    dcterms:conformsTo <anomalypattern/NetworkInterfaceDown> ;
    noria:alarmMitigatedBy <troubleticket/TT_20240420_002> .

<eventrecord/Log_Firewall_BlockedTraffic> a noria:EventRecord ;
    rdfs:label "Firewall_extra_node_4 Blocked Traffic Alert"@en ;
    rdfs:comment "Unusual traffic pattern blocked by perimeter firewall_extra_node_4."@en ;
