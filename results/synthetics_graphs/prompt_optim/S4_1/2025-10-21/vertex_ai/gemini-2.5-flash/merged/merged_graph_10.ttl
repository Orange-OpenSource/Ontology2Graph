<kos/TroubleTicket/problemResponsibility> a skos:ConceptScheme ;
    rdfs:label "Trouble Ticket Problem Responsibility Concept Scheme"@en ;
    rdfs:comment "A controlled vocabulary for problem responsibility."@en .

<kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> a skos:Concept ;
    skos:inScheme <kos/TroubleTicket/problemResponsibility> ;
