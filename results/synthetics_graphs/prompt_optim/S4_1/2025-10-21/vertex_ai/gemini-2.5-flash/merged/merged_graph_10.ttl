    dcterms:isPartOf <troubleTicket/TT_20240420_001> .

<documentAttachment/CR_20240501_002_Plan> a noria:DocumentAttachment ;
    rdfs:label "Router_extra_node_3 OS Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the Edge Router_extra_node_3 01 OS upgrade."@en ;
    dcterms:identifier "DOC-CR-20240501-002-PLAN" ;
    dcterms:created "2024-04-22T11:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ;
    dcterms:source "https://docs.example.com/changes/CR-20240501-002_plan.docx" ;
    dcterms:isPartOf <changeRequest/CR_20240501_002> .

