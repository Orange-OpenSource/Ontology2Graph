    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "false"^^xsd:boolean ;
    noria:applicationModuleAdministrationTeam <agent/Team_AppSupport> .

<applicationmodule/MonitoringPlatform_Prod> a noria:ApplicationModule ;
    rdfs:label "Monitoring Platform Production Module"@en ;
    rdfs:comment "Production instance of the Monitoring Platform."@en ;
    noria:applicationModuleOf <application/MonitoringPlatform> ;
    noria:applicationModuleName "MON_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Gold> ;
