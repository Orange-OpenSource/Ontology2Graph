    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceForApplication <https://w3id.org/noria/application/CorporateWebsite> ;
    noria:locatedAtLocus <https://w3id.org/noria/locus/RackA2> ;
    noria:resourceManagementIPAddress "192.168.10.50" .

<https://w3id.org/noria/networkinterface/LoadBalancer01-Eth0> a noria:NetworkInterface ;
    rdfs:label "LoadBalancer01 Ethernet 0"@en ;
