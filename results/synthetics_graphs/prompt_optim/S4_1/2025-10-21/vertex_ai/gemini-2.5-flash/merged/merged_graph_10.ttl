    dcterms:identifier "NET-DIAG-DC1-V2.pdf" ;
    dcterms:isPartOf noria:TroubleTicket20240420_001 ;
    dcterms:isPartOf noria:ChangeRequest20240419_001 .

noria:ScreenshotERPError a noria:DocumentAttachment ;
    rdfs:label "ERP Error Screenshot"@en ;
    rdfs:comment "Screenshot of the error message encountered by a user in the ERP system."@en ;
    dcterms:format "image/png" ;
    dcterms:identifier "ERP-ERROR-20240420.png" ;
    dcterms:isPartOf noria:TroubleTicket20240420_002 .

