# =============================================================================
# Event Records (noria:EventRecord)
# =============================================================================

noria:EventRecord_RouterDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Event"@en ;
    rdfs:comment "Log entry indicating a network interface on Core Router 001 went down."@en ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down"@en ;
    noria:logOriginatingManagedObject noria:Resource_Router001 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_DBError a noria:EventRecord ;
    rdfs:label "Database Connection Error Event"@en ;
    rdfs:comment "Log entry from Web Server 001 reporting database connection issues."@en ;
    noria:loggingTime "2024-04-23T10:06:30Z"^^xsd:dateTime ;
    noria:logText "ERROR: Could not connect to database 'customer_db' on host 'db-prod-001.dc-par.example.com'"@en ;
    noria:logOriginatingManagedObject noria:Resource_Server001 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_FirewallBlocked a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Event"@en ;
    rdfs:comment "Firewall log indicating blocked traffic from an unusual source."@en ;
    noria:loggingTime "2024-04-23T09:55:15Z"^^xsd:dateTime ;
    noria:logText "DENY: TCP 1.2.3.4:12345 -> 10.0.0.10:80, policy 'external-access'"@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall001 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent noria:Agent_CarolWhite . # Carol might have configured a temporary block

noria:EventRecord_ConfigChange a noria:EventRecord ;
    rdfs:label "Router Configuration Change Event"@en ;
    rdfs:comment "Log entry indicating a configuration change on Core Router 001."@en ;
    noria:loggingTime "2024-04-22T15:30:00Z"^^xsd:dateTime ;
    noria:logText "SYS-5-CONFIG_I: Configured from console by asmith (10.0.0.1)"@en ;
    noria:logOriginatingManagedObject noria:Resource_Router001 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:logOriginatingAgent noria:Agent_AliceSmith ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

noria:EventRecord_VMCPUHigh a noria:EventRecord ;
    rdfs:label "VM CPU Usage High Alert"@en ;
    rdfs:comment "Alert indicating high CPU usage on a virtual machine."@en ;
    noria:loggingTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:logText "VM-CPU-ALERT: vm-webapp-001.dc-par.example.com CPU usage exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_VM_WebApp001 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

