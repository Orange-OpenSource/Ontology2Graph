# More Operation Plans
noria:OpPlan_DBBackupTroubleshoot a noria:OperationPlan ;
    rdfs:label "Database Backup Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving database backup failures."@en ;
    noria:operationPlanPreCondition noria:PreCond_BackupFailure ;
    noria:operationPlanPostCondition noria:PostCond_BackupSuccess .

noria:PreCond_BackupFailure a noria:ActionPreCondition ;
    rdfs:label "Backup Failure Alert Condition"@en ;
    rdfs:comment "Condition where a scheduled backup job reports a failure."@en .

noria:PostCond_BackupSuccess a noria:ActionPostCondition ;
    rdfs:label "Backup Job Successful"@en ;
    rdfs:comment "Condition where a backup job completes successfully."@en .

noria:OpPlan_RouterFirmwareUpgrade a noria:OperationPlan ;
    rdfs:label "Router Firmware Upgrade Procedure"@en ;
    rdfs:comment "Standard operating procedure for upgrading router firmware."@en ;
    noria:operationPlanPreCondition noria:PreCond_MaintenanceWindow ;
    noria:operationPlanPostCondition noria:PostCond_FirmwareUpdated .

noria:PreCond_MaintenanceWindow a noria:ActionPreCondition ;
    rdfs:label "Scheduled Maintenance Window"@en ;
    rdfs:comment "Condition where a planned maintenance window is active."@en .

noria:PostCond_FirmwareUpdated a noria:ActionPostCondition ;
    rdfs:label "Firmware Successfully Updated"@en ;
    rdfs:comment "Condition where device firmware has been successfully updated and verified."@en .

noria:CR_RouterFirmwareUpgrade_003 pep:usedProcedure noria:OpPlan_RouterFirmwareUpgrade .
noria:TT_BackupFailure_004 noria:troubleTicketRelatedParty noria:Agent_DBA_Team .
noria:TT_CRMAuthIssue_005 noria:troubleTicketRelatedParty noria:Agent_CustomerService .

# Final checks for connectivity and density:
# - All major entities (Resource, Application, TT, CR, Event, Agent, Location, ProductModel, Service, NetInterface, NetLink, OpPlan, Pre/PostCond) have been instantiated.
# - Each instance has rdf:type, rdfs:label, rdfs:comment.
# - Many instances have French labels/comments.
# - Multiple properties are used for each instance, linking them to others.
# - The graph reflects a plausible IT scenario.
# - No ldp prefix used.
# - Prefixes are declared at the beginning.
# - Organization by logical blocks.


# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, noria:CorporateUserIdentifier)
# =============================================================================

# Organizational Units (Teams)
noria:OrgUnit_NetOpsTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing and maintaining network infrastructure."@en ;
    skos:example "Handles routing, switching, and firewall configurations."@en ;
    noria:agentWorkingHours "24/7 (on-call rotation)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "For critical issues, call the on-call number after sending an email."@en .

noria:OrgUnit_AppDevTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    skos:example "Develops and deploys microservices for customer-facing applications."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/chat> ;
    noria:agentInstructions "Open a ticket in Jira for any application-related issues."@en .

noria:OrgUnit_SecurityTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cybersecurity Operations Center (CSOC)"@en ;
    rdfs:comment "Team dedicated to monitoring, detecting, and responding to cybersecurity threats."@en ;
    skos:example "Monitors SIEM alerts and performs incident response."@en ;
    noria:agentWorkingHours "24/7 (shift-based)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Immediate phone call for critical security incidents."@en .

noria:OrgUnit_DBATeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing all corporate database systems."@en ;
    noria:agentWorkingHours "9:00-18:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticket> .

noria:OrgUnit_CloudOpsTeam a org:OrganizationalUnit, foaf:Agent ;
    rdfs:label "Cloud Operations Team"@en ;
    rdfs:comment "Manages cloud infrastructure and services."@en ;
    noria:agentWorkingHours "9:00-17:00 (Mon-Fri)"^^xsd:string ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> .

