    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/WebSrvCPUStable> .

<https://w3id.org/noria/actionprecondition/WebSrvHighCPU> a noria:ActionPreCondition ;
    rdfs:label "Web Server_extra_node_1 High_extra_node_1 CPU Usage"@en ;
    rdfs:comment "Condition: Web server_extra_node_1 CPU utilization exceeds 90% for more than 5 minutes."@en .

<https://w3id.org/noria/actionpostcondition/WebSrvCPUStable> a noria:ActionPostCondition ;
    rdfs:label "Web Server_extra_node_1 CPU Stable"@en ;
    rdfs:comment "Outcome: Web server_extra_node_1 CPU utilization is below 50% for at least 15 minutes after restart."@en .

