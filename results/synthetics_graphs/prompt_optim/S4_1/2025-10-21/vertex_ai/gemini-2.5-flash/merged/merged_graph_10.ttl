# Trouble Ticket Note Comment Type
<kos/TroubleTicket/commentType/Internal> a skos:Concept ; rdfs:label "Internal Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .
<kos/TroubleTicket/commentType/Customer> a skos:Concept ; rdfs:label "Customer Comment"@en ; skos:inScheme <kos/TroubleTicket/commentType> .

# Trouble Ticket Note Operation Type
<kos/TroubleTicket/operationType/Diagnosis> a skos:Concept ; rdfs:label "Diagnosis"@en ; skos:inScheme <kos/TroubleTicket/operationType> .
<kos/TroubleTicket/operationType/TestsAndMeasurements> a skos:Concept ; rdfs:label "Tests and Measurements"@en ; skos:inScheme <kos/TroubleTicket/operationType> .

# Change Request Category
<kos/ChangeRequest/category/InternalIntervention> a skos:Concept ; rdfs:label "Internal Intervention"@en ; skos:inScheme <kos/ChangeRequest/category> .
<kos/ChangeRequest/category/CustomerIntervention> a skos:Concept ; rdfs:label "Customer Intervention"@en ; skos:inScheme <kos/ChangeRequest/category> .

# Change Request Type
<kos/ChangeRequest/type/Standard> a skos:Concept ; rdfs:label "Standard Change"@en ; skos:inScheme <kos/ChangeRequest/type> .
<kos/ChangeRequest/type/Emergency> a skos:Concept ; rdfs:label "Emergency Change"@en ; skos:inScheme <kos/ChangeRequest/type> .

# Change Request Cause
<kos/ChangeRequest/cause/SoftwareUpgrade> a skos:Concept ; rdfs:label "Software Upgrade"@en ; skos:inScheme <kos/ChangeRequest/cause> .
<kos/ChangeRequest/cause/NetworkExtension> a skos:Concept ; rdfs:label "Network Extension"@en ; skos:inScheme <kos/ChangeRequest/cause> .

# Change Request Status
<kos/ChangeRequest/status/Approved> a skos:Concept ; rdfs:label "Approved"@en ; skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/status/Implemented> a skos:Concept ; rdfs:label "Implemented"@en ; skos:inScheme <kos/ChangeRequest/status> .
<kos/ChangeRequest/status/Scheduled> a skos:Concept ; rdfs:label "Scheduled"@en ; skos:inScheme <kos/ChangeRequest/status> .

# Change Request Specification
<kos/ChangeRequest/specification/StandardProcedureA> a skos:Concept ; rdfs:label "Standard Procedure A"@en ; skos:inScheme <kos/ChangeRequest/specification> .

# Notification Event Type
<kos/Notification/EventType/StateChange> a skos:Concept ; rdfs:label "State Change"@en ; skos:inScheme <kos/Notification/EventType> .
<kos/Notification/EventType/ThresholdCrossing> a skos:Concept ; rdfs:label "Threshold Crossing Alert"@en ; skos:inScheme <kos/Notification/EventType> .
<kos/Notification/EventType/ConfigurationChange> a skos:Concept ; rdfs:label "Configuration Change"@en ; skos:inScheme <kos/Notification/EventType> .
<kos/Notification/EventType/SecurityAlert> a skos:Concept ; rdfs:label "Security Alert"@en ; skos:inScheme <kos/Notification/EventType> .

# Notification Severity (PerceivedSeverity)
<Notification/Severity/PerceivedSeverity/Critical> a skos:Concept ; rdfs:label "Critical"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Major> a skos:Concept ; rdfs:label "Major"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Minor> a skos:Concept ; rdfs:label "Minor"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Warning> a skos:Concept ; rdfs:label "Warning"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .
<Notification/Severity/PerceivedSeverity/Indeterminate> a skos:Concept ; rdfs:label "Indeterminate"@en ; skos:inScheme <Notification/Severity/PerceivedSeverity> .

# Notification Probable Cause
<kos/Notification/ProbableCause/HardwareFailure> a skos:Concept ; rdfs:label "Hardware Failure"@en ; skos:inScheme <kos/Notification/ProbableCause> .
<kos/Notification/ProbableCause/SoftwareError> a skos:Concept ; rdfs:label "Software Error"@en ; skos:inScheme <kos/Notification/ProbableCause> .
<kos/Notification/ProbableCause/NetworkCongestion> a skos:Concept ; rdfs:label "Network Congestion"@en ; skos:inScheme <kos/Notification/ProbableCause> .

# =============================================================================
# Agents and Organizations
# =============================================================================

foaf:Agent1 a foaf:Agent ;
    rdfs:label "Network Operations Center (NOC) Team"@en ;
    rdfs:comment "Team responsible for 24/7 monitoring and initial response to network incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Contact via dedicated hotline for critical issues. Use ticketing system for non-urgent matters."@en .

foaf:Agent2 a foaf:Agent ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team managing physical and virtual server infrastructure."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Email for routine requests. Pager for critical server alerts."@en .

foaf:Agent3 a foaf:Agent ;
    rdfs:label "Application Support Team A"@en ;
    rdfs:comment "Team providing support for critical business application 'CRM-Suite'."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Chat> ;
    noria:agentInstructions "Use internal chat for immediate application issues. Open a ticket for feature requests."@en .

foaf:Agent4 a foaf:Agent ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team responsible for database systems maintenance and performance."@en ;
    noria:agentWorkingHours "8:30-17:30 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "All requests must go through the ticketing system."@en .

foaf:Agent5 a foaf:Agent ;
    rdfs:label "Security Operations Center (SOC) Team"@en ;
    rdfs:comment "Team responsible for cybersecurity monitoring and incident response."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate phone call for any suspected security breach."@en .

foaf:Agent6 a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, member of NOC Team."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent7 a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior System Administrator, member of Server Administration Team."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

org:OrgUnit1 a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Main department overseeing all IT infrastructure and services."@en ;
    org:hasMember foaf:Agent1, foaf:Agent2, foaf:Agent4, foaf:Agent6, foaf:Agent7 .

org:OrgUnit2 a org:OrganizationalUnit ;
    rdfs:label "Business Applications Department"@en ;
    rdfs:comment "Department responsible for business-specific software applications."@en ;
    org:hasMember foaf:Agent3 .

org:OrgUnit3 a org:OrganizationalUnit ;
    rdfs:label "Cybersecurity Department"@en ;
    rdfs:comment "Department responsible for the organization's information security."@en ;
    org:hasMember foaf:Agent5 .

org:Manufacturer1 a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Leading manufacturer of networking hardware."@en .

org:Manufacturer2 a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

org:Manufacturer3 a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

