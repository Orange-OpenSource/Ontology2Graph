# =============================================================================
# Operation Plans, Pre/Post Conditions
# =============================================================================

noria:OperationPlanRouterReload a noria:OperationPlan ;
    rdfs:label "Core Router Reload Procedure"@en, "Procédure de Redémarrage Routeur Cœur"@fr ;
    rdfs:comment "Standard operating procedure for reloading a core router."@en ;
    noria:operationPlanPreCondition noria:PreConditionRouterReachability ;
    noria:operationPlanPostCondition noria:PostConditionRouterUp .

noria:OperationPlanDNSCheck a noria:OperationPlan ;
    rdfs:label "DNS Service Health Check"@en, "Vérification Santé Service DNS"@fr ;
    rdfs:comment "Procedure to verify the operational status of DNS services."@en ;
    noria:operationPlanPreCondition noria:PreConditionNetworkConnectivity ;
    noria:operationPlanPostCondition noria:PostConditionDNSResolution .

noria:PreConditionRouterReachability a noria:ActionPreCondition ;
    rdfs:label "Router Reachability Check"@en ;
    rdfs:comment "Verify that the router is reachable via management IP and console."@en .

noria:PreConditionNetworkConnectivity a noria:ActionPreCondition ;
    rdfs:label "Network Connectivity Check"@en ;
    rdfs:comment "Ensure basic network connectivity to the DNS server's subnet."@en .

noria:PostConditionRouterUp a noria:ActionPostCondition ;
    rdfs:label "Router Operational Status Up"@en ;
    rdfs:comment "Confirm that the router has fully booted and all interfaces are up."@en .

noria:PostConditionDNSResolution a noria:ActionPostCondition ;
    rdfs:label "DNS Resolution Functional"@en ;
    rdfs:comment "Verify that DNS queries are successfully resolved by the DNS server."@en .

# Linking Operation Plans to Change Requests (example)
noria:ChangeRequestRouterUpgrade
    noria:actionCorrelatedOperationPlan noria:OperationPlanRouterReload .

# Linking Event Records to Operation Plans (example of proposed repair action)
noria:EventRecordRouterInterfaceDown
    noria:alarmProposedRepairAction noria:OperationPlanRouterReload .

# Example of a Corporate User Identifier being the originator of an event
noria:EventRecordConfigChange
    noria:logOriginatingAgent noria:CUidJaneSmith .

# Example of a Trouble Ticket Note being correlated to an execution (implicitly via pep:ProcedureExecutionContainer)
# The vocabulary states that TroubleTicketNote is a subclass of pep:ProcedureExecutionContainer,
# so we can directly link EventRecords to it via pep:member.
noria:TroubleTicketNoteDNSDiag1
    pep:member noria:EventRecordRouterInterfaceDown . # This implies the diagnosis note is part of the execution container that includes this event.

# Example of a Trouble Ticket's status history being recorded by EventRecords
noria:TroubleTicketDNSOutage
    noria:documentStatusHistory noria:EventRecordDNSOutageLog . # This event marks the start of the incident.
# More events could be added here to show status changes.

# Example of a resource being a cluster controller for another resource (e.g., a hypervisor managing VMs)
noria:ResourceHypervisor01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "VMware ESXi host managing virtual machines."@en ;
    noria:resourceManagedBy noria:AgentInfraOps ;
    noria:resourceProductModel noria:ProductModelDellR740 ;
    noria:resourceHostName "hypervisor01.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceManagementIPAddress "10.0.0.20" ;
    noria:locatedAtLocus noria:LocusR1C5 .

noria:ResourceVMApp01 a noria:Resource ;
    rdfs:label "Virtual Machine for App 01"@en ;
    rdfs:comment "Virtual machine hosting a component of Application CRM."@en ;
    noria:resourceManagedBy noria:AgentAppDev ;
    noria:resourceProductModel noria:ProductModelVMwareESXi ; # The VM is 'of' this product model (hypervisor type)
    noria:resourceHostName "vmapp01.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceForApplication noria:ApplicationCRM ;
    noria:clusterController noria:ResourceHypervisor01 . # VM is controlled by the hypervisor.

noria:ResourceHypervisor01
    seas:subSystemOf noria:ApplicationModuleMonitoringProd . # Hypervisor is part of the monitoring application's infrastructure.

# Example of network interface optical power metrics
noria:NetworkInterfaceRouterCore01Gi0_0_0
    noria:networkInterfaceLaserTxOpticalPower -2 ; # -2 dBm
    noria:networkInterfaceLaserRxOpticalPower -5 ; # -5 dBm
    noria:networkInterfaceLaserRxOpticalPowerAverage -4 ; # -4 dBm
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ; # -1 dBm
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 . # -10 dBm

# Example of virtual server status
noria:ResourceVMApp01
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# End of Graph

