<kos/org/agent-contact-method/Email> a skos:Concept ; rdfs:label "Email"@en ; skos:inScheme <kos/org/agent-contact-method> .
<kos/org/agent-contact-method/Phone> a skos:Concept ; rdfs:label "Phone"@en ; skos:inScheme <kos/org/agent-contact-method> .

# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
foaf:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution."@en ;
    noria:agentWorkingHours "08:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via email for non-urgent issues, phone for critical outages."@en .

foaf:Agent_NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing core network infrastructure and connectivity."@en ;
    noria:agentWorkingHours "24/7 Shift Rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always call the hotline for network incidents."@en .

foaf:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2 support for business applications."@en ;
    noria:agentWorkingHours "09:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Engineer, Network Operations."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    org:memberOf foaf:Agent_NetworkOpsTeam .

foaf:Agent_JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Manager, CRM System."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    org:memberOf foaf:Agent_AppSupportTeam .

foaf:Agent_AliceBrown a foaf:Agent ;
    rdfs:label "Alice Brown"@en ;
    rdfs:comment "Junior Network Engineer."@en ;
    foaf:mbox <mailto:alice.brown@example.com> ;
    org:memberOf foaf:Agent_NetworkOpsTeam .

org:Manufacturer_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of server and network hardware."@en .

org:Manufacturer_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

# --- Corporate User Identifiers (noria:CorporateUserIdentifier) ---
