# =============================================================================
# Additional Connections and Density
# =============================================================================

# Link agents to resources they manage
foaf:Agent1 noria:agentManagesResource noria:Resource1, noria:Resource2, noria:Resource5 .
foaf:Agent2 noria:agentManagesResource noria:Resource3, noria:Resource6 .
foaf:Agent4 noria:agentManagesResource noria:Resource4, noria:Resource8 .
foaf:Agent5 noria:agentManagesResource noria:Resource7 .

# Link applications to resources they use
noria:Resource3 noria:resourceForApplication noria:Application1 .
noria:Resource4 noria:resourceForApplication noria:Application1, noria:Application3 .
noria:Resource6 noria:resourceForApplication noria:Application1 .
noria:Resource8 noria:resourceForApplication noria:Application1, noria:Application3 .

# Link application modules to related parties
noria:ApplicationModule1 noria:applicationModuleRelatedParty foaf:Agent3 .
noria:ApplicationModule3 noria:applicationModuleRelatedParty foaf:Agent1 .
noria:ApplicationModule4 noria:applicationModuleRelatedParty foaf:Agent4 .
noria:ApplicationModule5 noria:applicationModuleRelatedParty foaf:Agent5 .

# Link EventRecords to TroubleTickets and ChangeRequests
noria:TroubleTicket1 noria:documentStatusHistory noria:EventRecord1 .
noria:TroubleTicket2 noria:documentStatusHistory noria:EventRecord2 .
noria:ChangeRequest2 noria:documentStatusHistory noria:EventRecord3 .

# Link TroubleTicketNotes to correlated executions (e.g., an EventRecord representing an action)
noria:TroubleTicketNote3 noria:troubleTicketNoteCorrelatedExecution noria:EventRecord2 . # The event record itself is a ProcedureExecution.

# Link EventRecords to mitigation actions (TroubleTickets or ChangeRequests)
noria:EventRecord1 noria:alarmMitigatedBy noria:TroubleTicket1 . # The TT is the container for mitigation.
noria:EventRecord3 noria:alarmMitigatedBy noria:ChangeRequest2 .

# Example of noria:CorporateUserIdentifier
noria:CUid1 a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Unique corporate identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent6 .

noria:CUid2 a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Unique corporate identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent7 .

# Example of noria:virtualServerStatus
noria:Resource6 noria:virtualServerStatus <kos/Resource/OperationalState/Up> .

# Example of optical power metrics for a network interface
noria:NetworkInterface2 noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -5 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -4 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

noria:NetworkInterface4 noria:networkInterfaceLaserTxOpticalPower -3 ;
    noria:networkInterfaceLaserRxOpticalPower -6 ;
    noria:networkInterfaceLaserRxOpticalPowerAverage -5 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -11 .

# Example of noria:troubleTicketPartyIntervention
noria:TroubleTicket1 noria:troubleTicketPartyIntervention noria:EventRecord1, noria:TroubleTicketNote1, noria:TroubleTicketNote2 .
noria:TroubleTicket2 noria:troubleTicketPartyIntervention noria:EventRecord2, noria:TroubleTicketNote3 .

# Example of noria:troubleTicketFreezeItem
noria:TroubleTicket1 noria:troubleTicketFreezeItem noria:EventRecord6 . # Assuming EventRecord6 is a status change to 'Frozen'

noria:EventRecord6 a noria:EventRecord ;
    rdfs:label "Trouble Ticket TT-20240423-001 Frozen"@en ;
    rdfs:comment "Status change for TT-20240423-001 to Frozen due to ISP dependency."@en ;
    dcterms:identifier "EVT-20240423-006" ;
    dcterms:description "TT-20240423-001 status changed to Frozen."@en ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:loggingTime "2024-04-23T10:55:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:TroubleTicket1 ;
    noria:logOriginatingManagementSystem noria:Application2 ;
    noria:logOriginatingAgent foaf:Agent6 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Indeterminate> .

# Example of noria:troubleTicketCharacteristic (using a blank node for complex characteristic)
noria:TroubleTicket1 noria:troubleTicketCharacteristic [
    a noria:Property ;
    rdfs:label "Customer Impact Level"@en ;
    rdfs:comment "Level of impact on the customer's business operations."@en ;
    rdf:value "High"^^xsd:string
] .

noria:TroubleTicket2 noria:troubleTicketCharacteristic [
    a noria:Property ;
    rdfs:label "Data Loss Risk"@en ;
    rdfs:comment "Risk assessment for potential data loss during the incident."@en ;
    rdf:value "Medium"^^xsd:string
] .

# Ensure all entities are connected and dense.
# The current structure ensures:
# - Agents manage Resources.
# - Resources are part of Applications.
# - Applications have Modules.
# - Modules are part of Services.
# - Resources are located at Loci, which are in Rooms, which are in Sites.
# - Network Interfaces are on Resources and connect Network Links.
# - Event Records originate from Resources/Applications/Agents.
# - Trouble Tickets are triggered by Event Records, relate to Services/Applications/Resources/Agents, and have Notes.
# - Change Requests impact Resources/Applications/Services/Modules and involve Agents.
# - Operation Plans have Pre/Post Conditions.
# - Many cross-references between TroubleTickets, ChangeRequests, and EventRecords.

