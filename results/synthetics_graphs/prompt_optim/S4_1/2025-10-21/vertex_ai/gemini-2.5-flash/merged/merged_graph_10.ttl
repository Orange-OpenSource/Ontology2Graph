# Services
# =============================================================================

noria:Service1 a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet access for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf noria:ApplicationModule3 . # NMS monitors this service

noria:Service2 a noria:Service ;
    rdfs:label "CRM Data Replication Service"@en ;
    rdfs:comment "Ensures data consistency between primary and disaster recovery CRM databases."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:ApplicationModule1, noria:ApplicationModule4 . # CRM Prod and EDB Prod rely on this.

noria:Service3 a noria:Service ;
    rdfs:label "Internal Network Connectivity"@en ;
    rdfs:comment "Provides network connectivity within the main data center."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:ApplicationModule3 .

# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OperationPlan1 a noria:OperationPlan ;
    rdfs:label "Router Interface Shutdown Procedure"@en ;
    rdfs:comment "Standard operating procedure for gracefully shutting down a router interface."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition1 ;
    noria:operationPlanPostCondition noria:ActionPostCondition1 .

noria:ActionPreCondition1 a noria:ActionPreCondition ;
    rdfs:label "Interface Status Up"@en ;
    rdfs:comment "The network interface must be in an 'up' administrative and operational state before shutdown."@en .

noria:ActionPostCondition1 a noria:ActionPostCondition ;
    rdfs:label "Interface Status Down"@en ;
    rdfs:comment "The network interface must be in a 'down' administrative and operational state after shutdown."@en .

noria:OperationPlan2 a noria:OperationPlan ;
    rdfs:label "Database Failover Procedure"@en ;
    rdfs:comment "Procedure to switch from primary to replica database in case of failure."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition2 ;
    noria:operationPlanPostCondition noria:ActionPostCondition2 .

noria:ActionPreCondition2 a noria:ActionPreCondition ;
    rdfs:label "Replica Database Synchronized"@en ;
    rdfs:comment "The replica database must be fully synchronized with the primary before failover."@en .

noria:ActionPostCondition2 a noria:ActionPostCondition ;
    rdfs:label "Service Restored on Replica"@en ;
    rdfs:comment "The application service must be successfully connected to and operating on the replica database."@en .

# =============================================================================
# Event Records
# =============================================================================

noria:EventRecord1 a noria:EventRecord ;
    rdfs:label "Interface Down Alert R1-PAR-01 ge-0/0/1.200"@en ;
    rdfs:comment "Automated alert indicating that external interface on R1-PAR-01 went down."@en ;
    dcterms:identifier "EVT-20240423-001" ;
    dcterms:description "Line protocol on Interface GigabitEthernet0/0/1, changed state to down."@en ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:loggingTime "2024-04-23T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource1 ;
    noria:logOriginatingManagementSystem noria:Application2 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan1 ;
    dcterms:conformsTo <kos/Notification/ProbableCause/HardwareFailure> .

noria:EventRecord2 a noria:EventRecord ;
    rdfs:label "Database Connection Error APP-SRV-01"@en ;
    rdfs:comment "Application server reported inability to connect to the database."@en ;
    dcterms:identifier "EVT-20240423-002" ;
    dcterms:description "SQLSTATE[08006] [7] could not connect to server: Connection refused."@en ;
    dcterms:type <kos/Notification/EventType/ThresholdCrossing> ;
    noria:loggingTime "2024-04-23T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource3 ;
    noria:logOriginatingManagementSystem noria:Application1 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    dcterms:conformsTo <kos/Notification/ProbableCause/SoftwareError> .

noria:EventRecord3 a noria:EventRecord ;
    rdfs:label "Configuration Change FW-DC-01"@en ;
    rdfs:comment "Log entry for a configuration change applied to the firewall."@en ;
    dcterms:identifier "EVT-20240423-003" ;
    dcterms:description "Rule 'Allow_SSH_NOC' modified by John Doe."@en ;
    dcterms:type <kos/Notification/EventType/ConfigurationChange> ;
    noria:loggingTime "2024-04-23T09:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource7 ;
    noria:logOriginatingAgent foaf:Agent6 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Indeterminate> .

noria:EventRecord4 a noria:EventRecord ;
    rdfs:label "High CPU Usage DB-SRV-01"@en ;
    rdfs:comment "Alert for sustained high CPU usage on the primary database server."@en ;
    dcterms:identifier "EVT-20240423-004" ;
    dcterms:description "CPU usage exceeded 90% for 15 minutes on db-srv-01."@en ;
    dcterms:type <kos/Notification/EventType/ThresholdCrossing> ;
    noria:loggingTime "2024-04-23T10:10:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Resource4 ;
    noria:logOriginatingManagementSystem noria:Application2 ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:conformsTo <kos/Notification/ProbableCause/NetworkCongestion> . # Could be DB issue, but for example, let's say network.

noria:EventRecord5 a noria:EventRecord ;
    rdfs:label "Security Alert - Unauthorized Access Attempt"@en ;
    rdfs:comment "Alert from SIEM about multiple failed login attempts on IAM system."@en ;
    dcterms:identifier "EVT-20240423-005" ;
    dcterms:description "Multiple failed login attempts detected on IAM-SYS_PROD from external IP 203.0.113.42."@en ;
    dcterms:type <kos/Notification/EventType/SecurityAlert> ;
    noria:loggingTime "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject noria:Application4 ;
    noria:logOriginatingManagementSystem noria:Application2 ; # NMS could forward to SIEM, or SIEM is another app. Let's assume NMS for simplicity.
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

