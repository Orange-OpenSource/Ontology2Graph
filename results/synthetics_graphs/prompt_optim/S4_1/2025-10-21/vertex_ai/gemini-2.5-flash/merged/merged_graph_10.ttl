# --- Network Links (noria:NetworkLink) ---
noria:NetworkLink_CR01_Uplink a noria:NetworkLink ;
    rdfs:label "Core Router 01 Uplink"@en ;
    rdfs:comment "Link connecting Core Router 01 to the internet backbone."@en ;
    noria:networkLinkId "NL-CR01-UPLINK" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource noria:Resource_CoreRouter01 ;
    noria:networkInterfaceConnects noria:NetworkInterface_CR01_Gig0_0_0 ;
