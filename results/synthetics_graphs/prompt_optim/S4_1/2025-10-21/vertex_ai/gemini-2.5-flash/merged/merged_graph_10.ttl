# --- Event Records (noria:EventRecord) ---
noria:Event_WebSrv01_CPU_High a noria:EventRecord ;
    rdfs:label "WebSrv01 High_extra_node_2 CPU Alert"@en ;
    rdfs:comment "Automated alert indicating high_extra_node_2 CPU utilization on Web Server_extra_node_2 01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on websrv01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logOriginatingAgent noria:Agent_Automated_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_2> .

noria:Event_CR01_Interface_Down a noria:EventRecord ;
    rdfs:label "CR01 Interface Down Alert"@en ;
    rdfs:comment "Critical_extra_node_2 alert: Core Router_extra_node_2 01 interface Gi0/0/0 went down."@en ;
    noria:loggingTime "2024-04-20T10:15:30Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down on cr01.corp.example.com."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logOriginatingAgent noria:Agent_Automated_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_2> ;
    noria:alarmProposedRepairAction noria:OP_CheckFiberConnection .

noria:Event_DB01_Disk_Full a noria:EventRecord ;
    rdfs:label "DB01 Disk Full Alert"@en ;
    rdfs:comment "Alert: Database_extra_node_2 Server_extra_node_2 01 disk space is critically low."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "Disk usage on /var/lib/mysql on db01.corp.example.com is 98%."@en ;
    noria:logOriginatingManagedObject noria:Resource_DB01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logOriginatingAgent noria:Agent_Automated_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_2> .

noria:Event_Security_Login_Failure a noria:EventRecord ;
    rdfs:label "Repeated Login Failures Alert"@en ;
    rdfs:comment "Security alert: Multiple failed login attempts detected on a critical_extra_node_2 system."@en ;
    noria:loggingTime "2024-04-20T11:35:00Z"^^xsd:dateTime ;
    noria:logText "User_extra_node_2 'attacker' failed to log in 5 times from IP 203.0.113.42 on Resource_WebSrv01."@en ;
    noria:logOriginatingManagedObject noria:Resource_WebSrv01 ;
    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logOriginatingAgent noria:Agent_Automated_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_2> .

noria:Event_FW01_Blocked_Traffic a noria:EventRecord ;
