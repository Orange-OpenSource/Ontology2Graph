# Example of an event record correlated with a procedure execution container
<https://w3id.org/noria/troubleticketnote/TTN-20240420-001-02> noria:troubleTicketNoteCorrelatedExecution <https://w3id.org/noria/procedureexecutioncontainer/DiskCleanupExecution> .

<https://w3id.org/noria/procedureexecutioncontainer/DiskCleanupExecution> a pep:ProcedureExecutionContainer ;
    rdfs:label "Disk Cleanup Execution for TT-20240420-001"@en ;
    rdfs:comment "Container for all actions and events related to the disk cleanup procedure for TT-20240420-001."@en ;
    dcterms:created "2024-04-20T10:50:00Z"^^xsd:dateTime ;
    dcterms:modified "2024-04-20T11:05:00Z"^^xsd:dateTime ;
    # ldp:member is explicitly forbidden, so we use dcterms:hasPart or similar if available, or just link directly
    dcterms:hasPart <https://w3id.org/noria/event/Log-DBServer01-DiskCleared> .

# Another resource and its network interface
<https://w3id.org/noria/resource/LoadBalancer01> a noria:Resource ;
    rdfs:label "Application Load Balancer 01"@en ;
