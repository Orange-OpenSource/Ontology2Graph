# --- Operation Plans (noria:OperationPlan) ---
noria:OperationPlan_RestartInterface a noria:OperationPlan ;
    rdfs:label "Network Interface Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting a network interface on a router."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_InterfaceDown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_InterfaceUp .

noria:OperationPlan_DBServiceRestart a noria:OperationPlan ;
    rdfs:label "Database Service Restart Procedure"@en ;
    rdfs:comment "Procedure to restart the database service on a server."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_DBServiceUnresponsive ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DBServiceRunning .

noria:OperationPlan_RouterSoftwareUpgrade a noria:OperationPlan ;
    rdfs:label "Router Software Upgrade Procedure"@en ;
    rdfs:comment "Detailed steps for upgrading router operating system software."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_BackupComplete ;
    noria:operationPlanPostCondition noria:ActionPostCondition_SoftwareUpgraded .

noria:OperationPlan_FirewallRuleUpdate a noria:OperationPlan ;
    rdfs:label "Firewall Rule Update Procedure"@en ;
    rdfs:comment "Procedure for safely updating firewall rules."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_ChangeWindow ;
    noria:operationPlanPostCondition noria:ActionPostCondition_TrafficFlowConfirmed .

noria:OperationPlan_VMResourceModify a noria:OperationPlan ;
    rdfs:label "Virtual Machine Resource Modification Procedure"@en ;
    rdfs:comment "Procedure for modifying CPU/RAM allocation of a virtual machine."@en ;
    noria:operationPlanPreCondition noria:ActionPreCondition_VMShutdown ;
    noria:operationPlanPostCondition noria:ActionPostCondition_VMResourcesUpdated .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
noria:ActionPreCondition_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface is Down"@en ;
    rdfs:comment "Condition: The target network interface must be in an operational 'down' state."@en .

noria:ActionPostCondition_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface is Up"@en ;
    rdfs:comment "Expected outcome: The network interface should transition to an operational 'up' state."@en .

noria:ActionPreCondition_DBServiceUnresponsive a noria:ActionPreCondition ;
    rdfs:label "Database Service Unresponsive"@en ;
    rdfs:comment "Condition: The database service is not responding to queries or is in a hung state."@en .

noria:ActionPostCondition_DBServiceRunning a noria:ActionPostCondition ;
    rdfs:label "Database Service Running"@en ;
    rdfs:comment "Expected outcome: The database service is running and accepting connections."@en .

noria:ActionPreCondition_BackupComplete a noria:ActionPreCondition ;
    rdfs:label "Configuration Backup Complete"@en ;
    rdfs:comment "Condition: A full backup of the device configuration must be completed before proceeding."@en .

noria:ActionPostCondition_SoftwareUpgraded a noria:ActionPostCondition ;
    rdfs:label "Software Version Upgraded"@en ;
    rdfs:comment "Expected outcome: The device's operating system software is successfully upgraded to the target version."@en .

noria:ActionPreCondition_ChangeWindow a noria:ActionPreCondition ;
    rdfs:label "Approved Change Window"@en ;
    rdfs:comment "Condition: The change must be executed within an approved maintenance window."@en .

noria:ActionPostCondition_TrafficFlowConfirmed a noria:ActionPostCondition ;
    rdfs:label "New Traffic Flow Confirmed"@en ;
    rdfs:comment "Expected outcome: New application traffic flows are confirmed to be working as expected."@en .

noria:ActionPreCondition_VMShutdown a noria:ActionPreCondition ;
    rdfs:label "Virtual Machine Shutdown"@en ;
    rdfs:comment "Condition: The target virtual machine must be gracefully shut down before resource modification."@en .

noria:ActionPostCondition_VMResourcesUpdated a noria:ActionPostCondition ;
    rdfs:label "Virtual Machine Resources Updated"@en ;
    rdfs:comment "Expected outcome: The virtual machine's CPU and RAM resources are successfully updated and VM restarted."@en .

# --- Additional connections for density ---
# Link resources to applications they support
noria:Resource_DNSServer01 noria:resourceForApplication noria:Application_CorporateDNS .
noria:Resource_WebFrontendVM01 noria:resourceForApplication noria:Application_CRMSystem .
noria:Resource_DatabaseServer01 noria:resourceForApplication noria:Application_CRMSystem .
noria:Resource_CoreRouter01 noria:resourceForApplication noria:Application_CorporateDNS, noria:Application_MonitoringPlatform .
noria:Resource_Firewall01 noria:resourceForApplication noria:Service_CorporateInternetAccess, noria:Service_SecurityMonitoring .
noria:Resource_LoadBalancer01 noria:resourceForApplication noria:Application_CRMSystem .
noria:Resource_VMwareVCenter noria:clusterController noria:Resource_WebFrontendVM01 .

# Link agents to resources they manage
foaf:Agent_DNSAdminTeam noria:agentManagesResource noria:Resource_DNSServer01 .
foaf:Agent_NetworkOpsTeam noria:agentManagesResource noria:Resource_CoreRouter01, noria:NetworkLink_CR01_Uplink, noria:NetworkLink_Internal_CR01_DNS01 .
foaf:Agent_AppSupportTeam noria:agentManagesResource noria:Resource_WebFrontendVM01, noria:Resource_DatabaseServer01, noria:Resource_LoadBalancer01, noria:Resource_VMwareVCenter .
foaf:Agent_SecurityTeam noria:agentManagesResource noria:Resource_Firewall01, noria:Service_SecurityMonitoring .


# =============================================================================
# Agents and Organizations
# =============================================================================

org:ITOperationsDept a org:OrganizationalUnit ;
    rdfs:label "IT Operations Department"@en ;
    rdfs:comment "Department responsible for the overall IT infrastructure and services."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical incidents, use emergency hotline."@en .

org:NetworkTeam a org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Open a ticket for non-urgent requests. Call directly for network outages."@en ;
    org:member foaf:JohnDoe, foaf:JaneSmith .

org:ApplicationSupportTeam a org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "All application-related issues must be reported via the dedicated application support portal."@en .

org:SecurityTeam a org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/alert-system> ;
    noria:agentInstructions "Automated alerts are processed by the SOC. For manual reporting, use the security incident form."@en .

org:HardwareVendor a org:Organization ;
    rdfs:label "GlobalTech Hardware Inc."@en ;
    rdfs:comment "Manufacturer of server and network equipment."@en .

org:SoftwareVendor a org:Organization ;
    rdfs:label "AppSolutions Corp."@en ;
    rdfs:comment "Provider of enterprise application software."@en .

foaf:JohnDoe a foaf:Agent ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Senior Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone> ;
    noria:agentInstructions "Available for urgent network issues."@en ;
    noria:agentManagesResource noria:RouterCore1, noria:FirewallDMZ .

foaf:JaneSmith a foaf:Agent ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Application Support Lead."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "Primary contact for ERP system issues."@en ;
    noria:agentManagesResource noria:ERPAppModuleProd .

foaf:CustomerA a foaf:Agent ;
    rdfs:label "Customer A Corp."@en ;
    rdfs:comment "A key corporate customer utilizing various services."@en .

foaf:SystemUser1 a foaf:Agent ;
    rdfs:label "System User 1"@en ;
    rdfs:comment "An end-user of the corporate IT services."@en .

noria:CUidJohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Unique identifier for John Doe within the organization's IT systems."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:JohnDoe .

