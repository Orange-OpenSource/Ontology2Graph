<resource/VirtualRouter_VR01> a noria:Resource ;
    rdfs:label "Virtual Router 01"@en ;
    rdfs:comment "Virtual router instance providing routing for a specific tenant network."@en ;
    noria:resourceHostName "vr01.tenant.example.com" ;
    noria:resourceProductModel <productmodel/Juniper_MX204> ;
    noria:resourceType <kos/Resource/type/virtual-router> ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-08-01T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/Team_NetworkOps> ;
    noria:resourceForApplication <application/CustomerPortal> .

# --- Network Interfaces (noria:NetworkInterface) ---
<networkinterface/Web01_Eth0> a noria:NetworkInterface ;
    rdfs:label "Web01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Web Server 01."@en ;
    noria:networkInterfaceOf <resource/Server_Web01> ;
    noria:networkInterfaceType <kos/networkinterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/DB01_Eth0> a noria:NetworkInterface ;
    rdfs:label "DB01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Database Server 01."@en ;
    noria:networkInterfaceOf <resource/Server_DB01> ;
    noria:networkInterfaceType <kos/networkinterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/Core01_Ge0_0_0> a noria:NetworkInterface ;
    rdfs:label "Core01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Interface connecting Core Router 01 to internal network segment."@en ;
    noria:networkInterfaceOf <resource/Router_Core01> ;
