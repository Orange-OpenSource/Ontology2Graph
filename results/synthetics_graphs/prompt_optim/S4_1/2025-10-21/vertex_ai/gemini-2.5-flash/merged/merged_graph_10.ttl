# --- Event Records (noria:EventRecord) ---
noria:EventRecord_DNSOutageLog a noria:EventRecord ;
    rdfs:label "DNS Server Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS server became unreachable."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logText "CRITICAL: DNS server dns01.corp.example.com is unreachable via ICMP."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNSServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

noria:EventRecord_RouterInterfaceDown a noria:EventRecord ;
    rdfs:label "Router Interface Down Alert"@en ;
    rdfs:comment "Alert indicating a critical interface on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T09:05:00Z"^^xsd:dateTime ;
    noria:logText "INTERFACE_STATUS: GigabitEthernet0/0/1 on cr01.corp.example.com changed state to down."@en ;
    noria:logOriginatingManagedObject noria:Resource_CoreRouter01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction noria:OperationPlan_RestartInterface .

noria:EventRecord_DBErrorLog a noria:EventRecord ;
    rdfs:label "Database Connection Error Log"@en ;
    rdfs:comment "Log entry showing repeated database connection errors."@en ;
    noria:loggingTime "2024-04-20T09:10:00Z"^^xsd:dateTime ;
    noria:logText "ERROR: Failed to connect to database db01.corp.example.com: Connection timed out."@en ;
    noria:logOriginatingManagedObject noria:Resource_DatabaseServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_CRMSlowResponse a noria:EventRecord ;
    rdfs:label "CRM Slow Response Alert"@en ;
    rdfs:comment "Alert indicating slow response times for the CRM application."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logText "WARNING: CRM_PROD average response time exceeded 5 seconds."@en ;
    noria:logOriginatingManagedObject noria:ApplicationModule_CRMSystem_Prod ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_UserLoginFailure a noria:EventRecord ;
    rdfs:label "Failed Login Attempt"@en ;
    rdfs:comment "Log entry for a failed login attempt on a critical system."@en ;
    noria:loggingTime "2024-04-20T09:20:00Z"^^xsd:dateTime ;
    noria:logText "AUTH_FAILURE: User 'attacker' failed to login to dns01.corp.example.com from 1.2.3.4."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNSServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logOriginatingAgent foaf:Agent_SecurityTeam ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> .

noria:EventRecord_SecurityAlert a noria:EventRecord ;
    rdfs:label "High Severity Security Alert"@en ;
    rdfs:comment "Alert from SIEM indicating potential intrusion attempt."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "ALERT: Multiple failed login attempts from external IP on critical server."@en ;
    noria:logOriginatingManagedObject noria:Resource_DNSServer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:logOriginatingAgent foaf:Agent_SecurityTeam ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> .

noria:EventRecord_FirewallBlockedTraffic a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Log"@en ;
    rdfs:comment "Log entry indicating traffic blocked by firewall."@en ;
    noria:loggingTime "2024-04-20T10:01:00Z"^^xsd:dateTime ;
    noria:logText "FIREWALL: Blocked connection from 1.2.3.4 to 192.168.1.10 on port 53 (DNS)."@en ;
    noria:logOriginatingManagedObject noria:Resource_Firewall01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

noria:EventRecord_LBHealthCheckFailure a noria:EventRecord ;
    rdfs:label "Load Balancer Health Check Failure"@en ;
    rdfs:comment "Log entry indicating a health check failure for a backend server on the load balancer."@en ;
    noria:loggingTime "2024-04-20T09:14:00Z"^^xsd:dateTime ;
    noria:logText "HEALTH_CHECK: Backend server web01.corp.example.com failed health check on LB01."@en ;
    noria:logOriginatingManagedObject noria:Resource_LoadBalancer01 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringPlatform ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

