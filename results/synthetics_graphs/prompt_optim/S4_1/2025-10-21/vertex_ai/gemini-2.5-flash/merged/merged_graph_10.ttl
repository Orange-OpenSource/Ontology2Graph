# =============================================================================
# Operation Plans and Conditions
# =============================================================================

noria:OperationPlan_DNS_Restart a noria:OperationPlan ;
    rdfs:label "DNS Service Restart Procedure"@en ;
    rdfs:comment "Standard operating procedure for restarting the corporate DNS service."@en .

noria:ActionPreCondition_DNSUnreachable a noria:ActionPreCondition ;
    rdfs:label "DNS Service Unreachable"@en ;
    rdfs:comment "Condition: DNS service is not responding to queries."@en .

noria:ActionPostCondition_DNSRestored a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored"@en ;
    rdfs:comment "Condition: DNS service is responding to queries and stable."@en .

noria:OperationPlan_DNS_Restart noria:operationPlanPreCondition noria:ActionPreCondition_DNSUnreachable ;
    noria:operationPlanPostCondition noria:ActionPostCondition_DNSRestored .

noria:OperationPlan_RouterPortTroubleshoot a noria:OperationPlan ;
    rdfs:label "Router Port Troubleshooting Guide"@en ;
    rdfs:comment "Procedure for diagnosing and resolving issues with flapping or down router ports."@en .

noria:ActionPreCondition_PortFlapping a noria:ActionPreCondition ;
    rdfs:label "Network Port Flapping Detected"@en ;
    rdfs:comment "Condition: A network interface is repeatedly changing its operational state (up/down)."@en .

noria:ActionPostCondition_PortStable a noria:ActionPostCondition ;
    rdfs:label "Network Port Stable"@en ;
    rdfs:comment "Condition: The network interface maintains a stable operational state (up)."@en .

noria:OperationPlan_RouterPortTroubleshoot noria:operationPlanPreCondition noria:ActionPreCondition_PortFlapping ;
    noria:operationPlanPostCondition noria:ActionPostCondition_PortStable .

# Link EventRecord to OperationPlan via alarmProposedRepairAction
noria:EventRecord_DNSFailureLog noria:alarmProposedRepairAction noria:OperationPlan_DNS_Restart .
noria:EventRecord_RouterInterfaceDown noria:alarmProposedRepairAction noria:OperationPlan_RouterPortTroubleshoot .

# Link TroubleTicketNote to correlated execution (if applicable, here just an example)
noria:TTNote_DNSOutage_1 noria:troubleTicketNoteCorrelatedExecution noria:TroubleTicket_DNSOutage . # The TT itself is a ProcedureExecutionContainer

# Link ChangeRequest to OperationPlan (if applicable)
noria:ChangeRequest_DNSUpgrade noria:actionCorrelatedOperationPlan noria:OperationPlan_DNS_Restart . # Simplified, a real upgrade would be more complex

# =============================================================================
# Anomaly Patterns
# =============================================================================

noria:AnomalyPattern_DNSCachePoisoning a noria:AnomalyPattern ;
    rdfs:label "DNS Cache Poisoning Pattern"@en ;
    rdfs:comment "Pattern indicating a potential DNS cache poisoning attack, characterized by unusual DNS query responses and high error rates."@en ;
    skos:example "Detection of multiple DNS resolution failures for legitimate domains combined with unexpected IP addresses in responses."@en .

noria:AnomalyPattern_HighCPULoad a noria:AnomalyPattern ;
    rdfs:label "Sustained High CPU Load Pattern"@en ;
    rdfs:comment "Pattern indicating a sustained period of abnormally high CPU utilization on a server, potentially leading to performance degradation."@en ;
    skos:example "CPU usage above 90% for more than 15 minutes on a production web server."@en .

# Link AnomalyPattern to EventRecords or TroubleTickets (via dcterms:relation or noria:troubleTicketTrigger)
noria:TroubleTicket_EcommerceSlowdown dcterms:relation noria:AnomalyPattern_HighCPULoad .
noria:EventRecord_ServerCPUAlert dcterms:relation noria:AnomalyPattern_HighCPULoad .

