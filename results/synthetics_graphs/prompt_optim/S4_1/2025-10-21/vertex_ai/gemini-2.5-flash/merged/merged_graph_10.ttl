# --- Operation Plans ---
noria:OpPlan_WebScaleUp a noria:OperationPlan ;
    rdfs:label "Web Server Scale-Up Procedure"@en ;
    rdfs:comment "Standard operating procedure for scaling up web server resources."@en ;
    noria:operationPlanPreCondition noria:PreCond_HighCPUAlert ;
    noria:operationPlanPostCondition noria:PostCond_CPUNormalized .

noria:OpPlan_FiberTroubleshooting a noria:OperationPlan ;
    rdfs:label "Fiber Optic Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and resolving fiber optic link issues."@en ;
    noria:operationPlanPreCondition noria:PreCond_InterfaceDown ;
    noria:operationPlanPostCondition noria:PostCond_InterfaceUp .

# --- Action Pre/Post Conditions ---
noria:PreCond_HighCPUAlert a noria:ActionPreCondition ;
    rdfs:label "High CPU Alert Condition"@en ;
    rdfs:comment "Condition where a critical server's CPU utilization exceeds a predefined threshold."@en .

noria:PostCond_CPUNormalized a noria:ActionPostCondition ;
    rdfs:label "CPU Utilization Normalized"@en ;
    rdfs:comment "Condition where CPU utilization returns to normal operating levels after intervention."@en .

noria:PreCond_InterfaceDown a noria:ActionPreCondition ;
    rdfs:label "Network Interface Down Condition"@en ;
    rdfs:comment "Condition where a critical network interface reports an 'administratively down' or 'operational down' status."@en .

noria:PostCond_InterfaceUp a noria:ActionPostCondition ;
    rdfs:label "Network Interface Up Condition"@en ;
    rdfs:comment "Condition where a network interface returns to an 'up' operational status."@en .

# --- Linking Event Records to Trouble Tickets and Change Requests ---
noria:TT_EcommerceOutage_001 noria:documentStatusHistory noria:Event_WebSrv01_CPUHigh .
noria:TT_DBPerformance_002 noria:documentStatusHistory noria:Event_DBSrv01_DiskFull .
noria:TT_NetworkIssue_003 noria:documentStatusHistory noria:Event_Router01_InterfaceDown .

noria:CR_WebSrvScaleUp_001 noria:documentStatusHistory noria:Event_WebSrv01_CPUHigh . # CR triggered by this event
noria:CR_DBDiskExpansion_002 noria:documentStatusHistory noria:Event_DBSrv01_DiskFull . # CR triggered by this event

# --- Linking Operation Plans to Actions (implicitly via CR/TT) ---
# The schema defines noria:actionCorrelatedOperationPlan for CorrectiveMaintenanceAction and ChangeAction.
# TroubleTicket and ChangeRequest are pep:ProcedureExecutionContainer.
# We can link the CR to the OperationPlan that guided its execution.
noria:CR_WebSrvScaleUp_001 pep:usedProcedure noria:OpPlan_WebScaleUp .
noria:TTNote_003_FiberCheck noria:troubleTicketNoteCorrelatedExecution noria:OpPlan_FiberTroubleshooting . # This is a bit of a stretch, as TTNote is not a ProcedureExecutionContainer, but it's the closest property.
# A more direct way would be to create a pep:ProcedureExecution for the action taken during the TTNote.
# Let's create a ProcedureExecution for the fiber check.

noria:ProcExec_FiberCheck_001 a pep:ProcedureExecution ;
    rdfs:label "Fiber Check Execution for TT_NetworkIssue_003"@en ;
    rdfs:comment "Execution of fiber optic troubleshooting procedure."@en ;
    pep:usedProcedure noria:OpPlan_FiberTroubleshooting ;
    pep:madeBy noria:Agent_AliceSmith ;
    dcterms:created "2024-03-20T10:55:00Z"^^xsd:dateTime ;
    pep:hasSimpleResult "Fiber cable found to be physically damaged."@en .

noria:TTNote_003_FiberCheck noria:troubleTicketNoteCorrelatedExecution noria:ProcExec_FiberCheck_001 .

