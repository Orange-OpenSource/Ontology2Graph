# =============================================================================
# Procedural Elements (noria:OperationPlan, noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

<https://w3id.org/noria/operationplan/DiskCleanupProcedure> a noria:OperationPlan ;
    rdfs:label "Database Server Disk Cleanup Procedure"@en ;
    rdfs:comment "Standard operating procedure for clearing disk space on database servers."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/DiskUsageHigh> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/DiskSpaceRestored> .

<https://w3id.org/noria/actionprecondition/DiskUsageHigh> a noria:ActionPreCondition ;
    rdfs:label "Disk Usage Exceeds Threshold"@en ;
    rdfs:comment "Condition: Disk utilization on a critical server is above 90%."@en ;
    skos:example "Disk /dev/sda1 on db01.corp.example.com is 98% full."@en .

<https://w3id.org/noria/actionpostcondition/DiskSpaceRestored> a noria:ActionPostCondition ;
    rdfs:label "Disk Space Restored"@en ;
    rdfs:comment "Outcome: Disk utilization is below 70% and services are operational."@en ;
    skos:example "Disk /dev/sda1 on db01.corp.example.com is now 40% full. ERP application is responsive."@en .

<https://w3id.org/noria/operationplan/MPLSLinkTroubleshooting> a noria:OperationPlan ;
    rdfs:label "MPLS Link Troubleshooting Procedure"@en ;
    rdfs:comment "Procedure for diagnosing and restoring MPLS link connectivity."@en ;
    noria:operationPlanPreCondition <https://w3id.org/noria/actionprecondition/MPLSLinkDown> ;
    noria:operationPlanPostCondition <https://w3id.org/noria/actionpostcondition/MPLSLinkUp> .

<https://w3id.org/noria/actionprecondition/MPLSLinkDown> a noria:ActionPreCondition ;
    rdfs:label "MPLS Link Down"@en ;
    rdfs:comment "Condition: MPLS link between two sites is reported as down or experiencing severe packet loss."@en ;
    skos:example "Interface GigabitEthernet0/0/0 on edgerouter-nyc.example.com is down."@en .

<https://w3id.org/noria/actionpostcondition/MPLSLinkUp> a noria:ActionPostCondition ;
    rdfs:label "MPLS Link Restored"@en ;
    rdfs:comment "Outcome: MPLS link is operational, and network connectivity is restored."@en ;
    skos:example "Ping tests from NYC to DC are successful. Users report restored access."@en .

# =============================================================================
# Anomaly Patterns (noria:AnomalyPattern)
# =============================================================================

<https://w3id.org/noria/anomalypattern/HighCPUHighLatency> a noria:AnomalyPattern ;
    rdfs:label "High CPU and High Latency Pattern"@en ;
    rdfs:comment "Indicates a potential performance bottleneck or resource exhaustion when both CPU usage and network latency are high on a server."@en ;
    folio:hasCause "Resource Contention" ;
    folio:hasEffect "Application Slowdown" .

<https://w3id.org/noria/anomalypattern/InterfaceFlap> a noria:AnomalyPattern ;
    rdfs:label "Network Interface Flapping Pattern"@en ;
    rdfs:comment "Frequent up/down transitions of a network interface, often indicating a physical layer issue or faulty transceiver."@en ;
    folio:hasCause "Faulty Cable/Transceiver" ;
    folio:hasEffect "Intermittent Connectivity" .

# =============================================================================
# Additional Connectivity and Density
# =============================================================================

# Linking EventRecord to TroubleTicket for status history
<https://w3id.org/noria/troubleticket/TT-20240420-001> noria:documentStatusHistory <https://w3id.org/noria/event/Log-DBServer01-DiskCleared> .

# Linking ChangeRequest to EventRecord for actual execution
<https://w3id.org/noria/changerequest/CR-20240422-001> noria:documentStatusHistory <https://w3id.org/noria/event/Log-WebServer01-PatchStart> .

<https://w3id.org/noria/event/Log-WebServer01-PatchStart> a noria:EventRecord ;
    rdfs:label "WebServer01 Patching Started Log"@en ;
    rdfs:comment "Log entry indicating the start of OS patching on WebServer01."@en ;
    noria:loggingTime "2024-04-22T02:00:00Z"^^xsd:dateTime ;
    noria:logText "OS patching initiated on web01.corp.example.com by automated system."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/WebServer01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringPlatform> ;
    noria:logOriginatingAgent <https://w3id.org/noria/agent/ITOpsTeam> ;
    dcterms:type <kos/Notification/EventType/SystemMaintenance> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

# More complex relationships for agents and resources
<https://w3id.org/noria/agent/ITOpsTeam> noria:agentManagesResource <https://w3id.org/noria/resource/VMHost01>, <https://w3id.org/noria/resource/DBServer01> .
<https://w3id.org/noria/agent/NetworkAdminTeam> noria:agentManagesResource <https://w3id.org/noria/networklink/MPLS-NYC-DC> .
<https://w3id.org/noria/agent/SecurityTeam> noria:agentManagesResource <https://w3id.org/noria/resource/Firewall01> .

# Additional application modules and their relations
<https://w3id.org/noria/applicationmodule/CRMSystem-Dev> a noria:ApplicationModule ;
    rdfs:label "CRM System Development Module"@en ;
    rdfs:comment "Development instance of the CRM system, used for testing new features."@en ;
    noria:applicationModuleOf <https://w3id.org/noria/application/CRMSystem> ;
    noria:applicationModuleName "CRM_DEV" ;
    noria:applicationModuleIdentifier "DEV" ;
    noria:applicationModuleAdministrationTeam <https://w3id.org/noria/agent/AppSupportTeam> ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/Development> .

# Linking a resource to multiple applications
<https://w3id.org/noria/resource/DBServer01> noria:resourceForApplication <https://w3id.org/noria/application/CRMSystem> .

# More detailed network interface properties
<https://w3id.org/noria/networkinterface/Router01-Gi0-0-1>
    noria:networkInterfaceLaserRxOpticalPowerAverage "-5"^^xsd:int .

<https://w3id.org/noria/networkinterface/EdgeRouterNYC-Gi0-0-0>
    noria:networkInterfaceLaserRxOpticalPowerAverage "-4"^^xsd:int .

# Example of a trouble ticket party intervention
