# --- Services (noria:Service) ---
<service/InternetAccess> a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "Provides internet access for all corporate users and applications."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <application/MonitoringPlatform>, <application/CustomerPortal> ;
    noria:elementManagedBy <agent/Team_NetworkOps> .

<service/DatabaseService> a noria:Service ;
    rdfs:label "Central Database Service"@en ;
    rdfs:comment "Provides database backend for multiple business applications."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf <application/InternalCRM>, <application/CustomerPortal> ;
    noria:elementManagedBy <agent/Team_AppSupport> .

<service/AnalyticsService> a noria:Service ;
    rdfs:label "Business Analytics Service"@en ;
    rdfs:comment "Provides data analytics and reporting capabilities to business users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <application/AnalyticsDashboard> ;
    noria:elementManagedBy <agent/Team_AppSupport> .

<service/TenantConnectivity> a noria:Service ;
    rdfs:label "Tenant Connectivity Service"@en ;
    rdfs:comment "Provides network connectivity for specific customer tenants."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <resource/VirtualRouter_VR01> ;
    noria:elementManagedBy <agent/Team_NetworkOps> .

# --- Event Records (noria:EventRecord) ---
<eventrecord/Log_Web01_HighCPU> a noria:EventRecord ;
    rdfs:label "Web01 High CPU Alert"@en ;
    rdfs:comment "CPU utilization on Web01 exceeded 90% for 5 minutes."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Server_Web01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "ALERT: High CPU usage (92%) on web01.prod.example.com" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    dcterms:conformsTo <anomalypattern/HighCPULoad> ;
    noria:alarmMitigatedBy <troubleticket/TT_20240420_001> .

<eventrecord/Log_Core01_InterfaceDown> a noria:EventRecord ;
    rdfs:label "Core01 Interface Down Alert"@en ;
    rdfs:comment "GigabitEthernet 0/0/1 on Core Router 01 went down."@en ;
    noria:loggingTime "2024-04-20T10:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Router_Core01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "CRITICAL: Interface Ge0/0/1 on core01.prod.example.com changed state to down." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <operationplan/CheckFiberLink> ;
    dcterms:conformsTo <anomalypattern/NetworkInterfaceDown> ;
    noria:alarmMitigatedBy <troubleticket/TT_20240420_002> .

<eventrecord/Log_Firewall_BlockedTraffic> a noria:EventRecord ;
    rdfs:label "Firewall Blocked Traffic Alert"@en ;
    rdfs:comment "Unusual traffic pattern blocked by perimeter firewall."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Firewall_FW01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "SECURITY ALERT: High volume of SYN packets from external IP 198.51.100.1 blocked by FW01." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:logOriginatingAgent <agent/Team_SecurityOps> ;
    noria:alarmProposedRepairAction <proceduralelement/DDoSResponsePlan> .

<eventrecord/Log_VMApp01_Restart> a noria:EventRecord ;
    rdfs:label "VM App01 Restart Event"@en ;
    rdfs:comment "Virtual machine VM_App01 was restarted by an administrator."@en ;
    noria:loggingTime "2024-04-20T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/VM_App01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "INFO: VM vm-app01.prod.example.com restarted by asmith." ;
    noria:logOriginatingAgent <agent/Person_Alice> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> .

<eventrecord/Log_DB01_DiskFull> a noria:EventRecord ;
    rdfs:label "DB01 Disk Full Alert"@en ;
    rdfs:comment "Disk space on Database Server 01 reached critical levels."@en ;
    noria:loggingTime "2024-04-21T08:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Server_DB01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "CRITICAL: Disk usage (98%) on /data partition of db01.prod.example.com" ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:alarmProposedRepairAction <operationplan/DiskCleanup> .

<eventrecord/Log_Firewall_PortScan> a noria:EventRecord ;
    rdfs:label "Firewall Port Scan Alert"@en ;
    rdfs:comment "Detected an external port scan attempt on the perimeter firewall."@en ;
    noria:loggingTime "2024-04-21T10:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Firewall_FW01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "SECURITY ALERT: Port scan detected from 203.0.113.5 on FW01." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Minor> ;
    noria:logOriginatingAgent <agent/Team_SecurityOps> .

<eventrecord/Log_CR_Analytics_Success> a noria:EventRecord ;
    rdfs:label "Analytics Dashboard Deployment Success"@en ;
    rdfs:comment "New Analytics Dashboard application successfully deployed."@en ;
    noria:loggingTime "2024-05-10T21:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <application/AnalyticsDashboard> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "INFO: Analytics Dashboard (AD_PROD) deployment completed successfully." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:logOriginatingAgent <agent/Person_Bob> .

<eventrecord/Log_LB01_HealthCheckFail> a noria:EventRecord ;
    rdfs:label "LB01 Health Check Failure"@en ;
    rdfs:comment "Load balancer detected a backend server failure."@en ;
    noria:loggingTime "2024-04-22T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/LoadBalancer_LB01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "WARNING: Health check failed for backend server web02.prod.example.com on LB01." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:alarmProposedRepairAction <operationplan/RestartBackendServer> .

<eventrecord/Log_SAN01_DiskFailure> a noria:EventRecord ;
    rdfs:label "SAN01 Disk Failure Alert"@en ;
    rdfs:comment "One disk in SAN Storage Array 01 reported a failure."@en ;
    noria:loggingTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Storage_SAN01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "CRITICAL: Disk drive 3 in RAID group 5 failed on san01.prod.example.com." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<eventrecord/Log_SAN01_DiskReplaceSuccess> a noria:EventRecord ;
    rdfs:label "SAN01 Disk Replacement Success"@en ;
    rdfs:comment "Failed disk in SAN Storage Array 01 successfully replaced."@en ;
    noria:loggingTime "2024-04-24T11:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Storage_SAN01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "INFO: Disk drive 3 in RAID group 5 replaced successfully on san01.prod.example.com. RAID rebuild initiated." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:logOriginatingAgent <agent/Person_Bob> .

<eventrecord/Log_VR01_ConfigChange> a noria:EventRecord ;
    rdfs:label "VR01 Configuration Change"@en ;
    rdfs:comment "Configuration change applied to Virtual Router 01."@en ;
    noria:loggingTime "2024-04-25T09:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/VirtualRouter_VR01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "INFO: Configuration committed by asmith on vr01.tenant.example.com." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Informational> ;
    noria:logOriginatingAgent <agent/Person_Alice> .

<eventrecord/Log_Audit_LoginFail> a noria:EventRecord ;
    rdfs:label "Failed Login Attempt Audit"@en ;
    rdfs:comment "Multiple failed login attempts detected on a critical server."@en ;
    noria:loggingTime "2024-04-25T10:30:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Server_DB01> ;
    noria:logOriginatingManagementSystem <application/MonitoringPlatform> ;
    noria:logText "SECURITY AUDIT: 5 failed login attempts for user 'root' from 192.168.1.100 on db01.prod.example.com." ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent <agent/Team_SecurityOps> ;
    dcterms:conformsTo <anomalypattern/BruteForceLogin> ;
    noria:alarmProposedRepairAction <proceduralelement/SecurityIncidentResponse> .

# --- Trouble Tickets (noria:TroubleTicket) ---
<troubleticket/TT_20240420_001> a noria:TroubleTicket ;
    rdfs:label "Customer Portal Access Issue"@en ;
