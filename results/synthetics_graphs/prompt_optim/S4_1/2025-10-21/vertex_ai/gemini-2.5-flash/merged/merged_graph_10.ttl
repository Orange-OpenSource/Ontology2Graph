noria:NetworkLink1 a noria:NetworkLink ;
    rdfs:label "Core-Internal Link R1-SW-EDGE"@en ;
    rdfs:comment "Link between Core Router R1-PAR-01 and Edge Switch SW-EDGE-01."@en ;
    noria:networkLinkId "NL-001" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource1 ;
    noria:networkLinkTerminationResourceDestination noria:Resource5 ;
    noria:networkLinkInstallationDate "2021-05-01T09:30:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkInterfaceConnects noria:NetworkInterface1, noria:NetworkInterface7 .

