    bot:containsZone noria:Locus6 .

noria:Locus1 a noria:Locus ;
    rdfs:label "Rack A01-R01"@en ;
    rdfs:comment "First rack in Server Room A01."@en ;
    noria:locusLine "A01" ;
    noria:locusRow "R01" .

noria:Locus2 a noria:Locus ;
    rdfs:label "Rack A01-R02"@en ;
    rdfs:comment "Second rack in Server Room A01."@en ;
    noria:locusLine "A01" ;
    noria:locusRow "R02" .

noria:Locus3 a noria:Locus ;
    rdfs:label "Rack A01-R03"@en ;
    rdfs:comment "Third rack in Server Room A01."@en ;
    noria:locusLine "A01" ;
    noria:locusRow "R03" .

noria:Locus4 a noria:Locus ;
    rdfs:label "Rack B02-N01"@en ;
    rdfs:comment "First network rack in Network Room B02."@en ;
    noria:locusLine "B02" ;
    noria:locusRow "N01" .

noria:Locus5 a noria:Locus ;
    rdfs:label "Rack B02-N02"@en ;
    rdfs:comment "Second network rack in Network Room B02."@en ;
    noria:locusLine "B02" ;
    noria:locusRow "N02" .

noria:Locus6 a noria:Locus ;
