    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int .

<networkinterface/Core01_Ge0_0_1> a noria:NetworkInterface ;
    rdfs:label "Core01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to Edge Router 01."@en ;
    noria:networkInterfaceOf <resource/Router_Core01> ;
    noria:networkInterfaceType <kos/networkinterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower "-3"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-5"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-1"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

<networkinterface/Edge01_Ge0_0_0> a noria:NetworkInterface ;
    rdfs:label "Edge01 GigabitEthernet 0/0/0"@en ;
    rdfs:comment "Interface connecting Edge Router 01 to Core Router 01."@en ;
    noria:networkInterfaceOf <resource/Router_Edge01> ;
    noria:networkInterfaceType <kos/networkinterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> ;
    noria:networkInterfaceLaserTxOpticalPower "-4"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-6"^^xsd:int ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-11"^^xsd:int .

<networkinterface/Edge01_Ge0_0_1> a noria:NetworkInterface ;
    rdfs:label "Edge01 GigabitEthernet 0/0/1"@en ;
    rdfs:comment "Interface connecting Edge Router 01 to the Internet Service Provider."@en ;
    noria:networkInterfaceOf <resource/Router_Edge01> ;
    noria:networkInterfaceType <kos/networkinterface/type/physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/VMApp01_Eth0> a noria:NetworkInterface ;
    rdfs:label "VM App01 Ethernet 0"@en ;
    rdfs:comment "Virtual network interface for VM_App01."@en ;
    noria:networkInterfaceOf <resource/VM_App01> ;
    noria:networkInterfaceType <kos/networkinterface/type/virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/LRO_SW_Core_Ge1_0_1> a noria:NetworkInterface ;
    rdfs:label "LRO Core Switch GigabitEthernet 1/0/1"@en ;
    rdfs:comment "Uplink interface for LRO Core Switch."@en ;
    noria:networkInterfaceOf <resource/Switch_LRO_Core> ;
