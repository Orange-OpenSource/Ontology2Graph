noria:TroubleTicket_001 a noria:TroubleTicket ;
    rdfs:label "Customer Portal Outage"@en ;
    rdfs:comment "Critical incident: Customer Portal is completely inaccessible."@en ;
    dcterms:identifier "TT-20240423-001"^^xsd:string ;
    dcterms:created "2024-04-23T10:07:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Customer> ;
    noria:troubleTicketTrigger noria:EventRecord_DBError ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Nagios"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/TotalBreakdown> ;
    noria:troubleTicketCause "Database connection failure due to network issue."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T10:06:00Z"^^xsd:dateTime ;
    noria:troubleTicketTargetRestorationDateTime "2024-04-23T11:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketCommittedRestorationDateTime "2024-04-23T12:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketIsNotificationEnable "true"^^xsd:boolean ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:OrgUnit_AppDevTeam, noria:OrgUnit_DBATeam, noria:OrgUnit_NetOpsTeam ;
    noria:troubleTicketRelatedService noria:Service_CustomerWebApp ;
    noria:troubleTicketImpacts noria:Application_CustomerPortal, noria:Resource_Server001, noria:Resource_DBServer001 .

noria:TroubleTicket_002 a noria:TroubleTicket ;
    rdfs:label "Router Uplink Flapping"@en ;
    rdfs:comment "Network interface on core router is intermittently going up and down."@en ;
    dcterms:identifier "TT-20240423-002"^^xsd:string ;
    dcterms:created "2024-04-23T10:15:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_RouterDown ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Zabbix"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/DowngradingEquipment> ;
