# --- Agents (Teams and Individuals) ---
noria:Agent_NetOpsTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for managing and monitoring network infrastructure."@en ;
    rdfs:comment "Équipe responsable de la gestion et de la surveillance de l'infrastructure réseau."@fr ;
