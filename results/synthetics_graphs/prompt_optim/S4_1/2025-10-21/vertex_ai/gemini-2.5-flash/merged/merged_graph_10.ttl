    noria:networkLinkTerminationResource noria:Resource1 ;
    noria:networkLinkInstallationDate "2021-03-15T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkType "Fiber Optic 100Gbps" ;
    noria:networkInterfaceConnects noria:NetworkInterface2 .

