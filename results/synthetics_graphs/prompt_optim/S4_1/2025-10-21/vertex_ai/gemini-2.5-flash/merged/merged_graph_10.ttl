# --- Agents (foaf:Agent, org:OrganizationalUnit) ---
<agent/Team_NetworkOperations> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:label "Équipe Opérations Réseau"@fr ;
    rdfs:comment "Team responsible for the daily operation and maintenance of the network infrastructure_extra_node_3."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/email> ;
    noria:agentInstructions "For critical_extra_node_3 issues, call the hotline first, then open a ticket."@en .

<agent/Team_ApplicationSupport> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:label "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing technical support for business_extra_node_3 applications."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/ticketing-system> ;
    noria:agentInstructions "All requests must be submitted via the ITSM portal."@en .

<agent/Team_SecurityOperations> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:label "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Team monitoring_extra_node_3 and responding to security_extra_node_3 incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/phone_extra_node_3> ;
    noria:agentInstructions "Immediate notification for any detected threat."@en .

