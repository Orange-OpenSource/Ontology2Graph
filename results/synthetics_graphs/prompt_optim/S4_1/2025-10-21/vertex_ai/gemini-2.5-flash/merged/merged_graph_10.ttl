# --- Operation Plans (noria:OperationPlan) ---
<operationplan/CheckFiberLink> a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Procedure to diagnose and potentially repair a suspected fiber optic link issue."@en ;
    skos:example "1. Verify physical connection. 2. Check optical power levels. 3. Test continuity with OTDR."@en ;
    noria:operationPlanPreCondition <actionprecondition/FiberLinkDown> ;
    noria:operationPlanPostCondition <actionpostcondition/FiberLinkRestored> .

<operationplan/RestartWebServer> a noria:OperationPlan ;
    rdfs:label "Restart Web Server Procedure"@en ;
    rdfs:comment "Standard procedure for restarting a web server in case of performance issues."@en ;
    skos:example "1. Check logs for errors. 2. Attempt graceful restart. 3. Force restart if necessary. 4. Verify service availability."@en ;
    noria:operationPlanPreCondition <actionprecondition/WebServerUnresponsive> ;
    noria:operationPlanPostCondition <actionpostcondition/WebServerOperational> .

<operationplan/DiskCleanup> a noria:OperationPlan ;
    rdfs:label "Database Disk Cleanup Procedure"@en ;
    rdfs:comment "Procedure to free up disk space on database servers."@en ;
    skos:example "1. Identify largest files. 2. Archive old logs. 3. Delete temporary files. 4. Verify free space."@en ;
    noria:operationPlanPreCondition <actionprecondition/DiskSpaceLow> ;
    noria:operationPlanPostCondition <actionpostcondition/DiskSpaceNormal> .

<operationplan/RestartBackendServer> a noria:OperationPlan ;
    rdfs:label "Restart Backend Server Procedure"@en ;
    rdfs:comment "Procedure to restart an unhealthy backend web server."@en ;
    skos:example "1. Isolate server from load balancer. 2. Log in and check application status. 3. Restart application service. 4. Re-add to load balancer pool."@en ;
    noria:operationPlanPreCondition <actionprecondition/BackendServerUnhealthy> ;
    noria:operationPlanPostCondition <actionpostcondition/BackendServerHealthy> .

# --- Procedural Elements (noria:ProceduralElement) ---
<proceduralelement/DDoSResponsePlan> a noria:ProceduralElement, noria:OperationPlan ;
    rdfs:label "DDoS Attack Response Plan"@en ;
    rdfs:comment "Standard operating procedure for responding to a Distributed Denial of Service attack."@en ;
    skos:example "1. Verify attack. 2. Activate scrubbing center. 3. Block malicious IPs. 4. Notify stakeholders."@en ;
    noria:operationPlanPreCondition <actionprecondition/DDoSAttackDetected> ;
    noria:operationPlanPostCondition <actionpostcondition/DDoSAttackMitigated> .

<proceduralelement/SecurityIncidentResponse> a noria:ProceduralElement, noria:OperationPlan ;
    rdfs:label "Security Incident Response Plan"@en ;
    rdfs:comment "General procedure for responding to security incidents."@en ;
    skos:example "1. Containment. 2. Eradication. 3. Recovery. 4. Post-incident analysis."@en ;
    noria:operationPlanPreCondition <actionprecondition/SecurityIncidentDetected> ;
    noria:operationPlanPostCondition <actionpostcondition/SecurityIncidentResolved> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
<actionprecondition/FiberLinkDown> a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-condition"@en ;
    rdfs:comment "Condition: A network interface connected to a fiber link reports an 'administratively down' or 'operational down' status."@en .

<actionpostcondition/FiberLinkRestored> a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Restored Post-condition"@en ;
    rdfs:comment "Condition: The network interface connected to the fiber link reports an 'up' operational status and traffic flows normally."@en .

<actionprecondition/WebServerUnresponsive> a noria:ActionPreCondition ;
    rdfs:label "Web Server Unresponsive Pre-condition"@en ;
    rdfs:comment "Condition: Web server is not responding to HTTP requests or showing high resource utilization."@en .

<actionpostcondition/WebServerOperational> a noria:ActionPostCondition ;
    rdfs:label "Web Server Operational Post-condition"@en ;
    rdfs:comment "Condition: Web server is responding to HTTP requests, and resource utilization is within normal limits."@en .

<actionprecondition/DiskSpaceLow> a noria:ActionPreCondition ;
    rdfs:label "Low Disk Space Pre-condition"@en ;
    rdfs:comment "Condition: Disk utilization on a critical server exceeds 90%."@en .

<actionpostcondition/DiskSpaceNormal> a noria:ActionPostCondition ;
    rdfs:label "Normal Disk Space Post-condition"@en ;
    rdfs:comment "Condition: Disk utilization on the server is below 80% after cleanup."@en .

<actionprecondition/BackendServerUnhealthy> a noria:ActionPreCondition ;
    rdfs:label "Backend Server Unhealthy Pre-condition"@en ;
    rdfs:comment "Condition: Load balancer health check fails for a backend server."@en .

<actionpostcondition/BackendServerHealthy> a noria:ActionPostCondition ;
    rdfs:label "Backend Server Healthy Post-condition"@en ;
    rdfs:comment "Condition: Load balancer health check passes for the backend server, and it's serving traffic."@en .

<actionprecondition/DDoSAttackDetected> a noria:ActionPreCondition ;
    rdfs:label "DDoS Attack Detected Pre-condition"@en ;
    rdfs:comment "Condition: High volume of suspicious traffic detected towards public-facing services, exceeding normal thresholds."@en .

<actionpostcondition/DDoSAttackMitigated> a noria:ActionPostCondition ;
    rdfs:label "DDoS Attack Mitigated Post-condition"@en ;
    rdfs:comment "Condition: Malicious traffic is filtered, and legitimate traffic flow is restored to normal levels."@en .

<actionprecondition/SecurityIncidentDetected> a noria:ActionPreCondition ;
    rdfs:label "Security Incident Detected Pre-condition"@en ;
    rdfs:comment "Condition: A security alert or anomaly pattern indicates a potential security breach or attack."@en .

<actionpostcondition/SecurityIncidentResolved> a noria:ActionPostCondition ;
    rdfs:label "Security Incident Resolved Post-condition"@en ;
    rdfs:comment "Condition: The security threat has been neutralized, systems are secured, and normal operations resumed."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
<documentattachment/FiberCutPhoto> a noria:DocumentAttachment ;
    rdfs:label "Photo of Fiber Cut"@en ;
    rdfs:comment "Image showing the physical damage to the fiber optic cable."@en ;
    dcterms:created "2024-04-20T10:42:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/Person_Alice> ;
    dcterms:isPartOf <troubleticket/TT_20240420_002> ;
    dcterms:format "image/jpeg" ;
    dcterms:source "file:///path/to/fiber_cut_photo.jpg"^^xsd:anyURI .

<documentattachment/UpgradePlanPDF> a noria:DocumentAttachment ;
    rdfs:label "Core Router Upgrade Plan"@en ;
    rdfs:comment "Detailed plan for the Core Router software upgrade."@en ;
    dcterms:created "2024-04-16T11:00:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/Person_Alice> ;
    dcterms:isPartOf <changerequest/CR_20240425_001> ;
    dcterms:format "application/pdf" ;
    dcterms:source "file:///path/to/core_router_upgrade_plan.pdf"^^xsd:anyURI .

<documentattachment/DeploymentPlanAnalytics> a noria:DocumentAttachment ;
    rdfs:label "Analytics Dashboard Deployment Plan"@en ;
    rdfs:comment "Detailed plan for deploying the Analytics Dashboard application."@en ;
    dcterms:created "2024-04-25T10:00:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/Person_Bob> ;
    dcterms:isPartOf <changerequest/CR_20240510_001> ;
    dcterms:format "application/pdf" ;
    dcterms:source "file:///path/to/analytics_deployment_plan.pdf"^^xsd:anyURI .

<documentattachment/SecurityIncidentReport> a noria:DocumentAttachment ;
    rdfs:label "Brute Force Incident Report"@en ;
    rdfs:comment "Report detailing the brute force attack on DB01 and mitigation steps."@en ;
    dcterms:created "2024-04-25T11:30:00Z"^^xsd:dateTime ;
    dcterms:creator <agent/Person_Charlie> ;
    dcterms:isPartOf <troubleticket/TT_20240425_001> ;
    dcterms:format "application/pdf" ;
    dcterms:source "file:///path/to/brute_force_report.pdf"^^xsd:anyURI .

# --- Anomaly Patterns (noria:AnomalyPattern) ---
<anomalypattern/HighCPULoad> a noria:AnomalyPattern ;
    rdfs:label "High CPU Load Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating sustained high CPU utilization, potentially leading to performance degradation or outage."@en ;
    skos:example "Triggered when CPU > 90% for 5 minutes on a critical server."@en .

<anomalypattern/NetworkInterfaceDown> a noria:AnomalyPattern ;
    rdfs:label "Network Interface Down Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating a critical network interface has transitioned to an 'operational down' state."@en ;
    skos:example "Triggered when a core router interface goes down."@en .

<anomalypattern/BruteForceLogin> a noria:AnomalyPattern ;
    rdfs:label "Brute Force Login Anomaly Pattern"@en ;
    rdfs:comment "Pattern indicating multiple failed login attempts from a single source IP or user, suggesting a brute force attack."@en ;
    skos:example "Triggered when > 3 failed logins in 1 minute for a user."@en .

# --- Additional Agent-Resource/Link Management Links ---
<agent/Team_NetworkOps> noria:agentManagesResource <resource/Router_Core01>, <resource/Router_Edge01>, <resource/Switch_LRO_Core>, <networklink/Core01_Edge01_Link>, <networklink/Edge01_ISP_Link>, <networklink/LRO_Uplink>, <resource/LoadBalancer_LB01>, <networklink/Edge01_LB01_Link>, <resource/VirtualRouter_VR01> .
<agent/Team_AppSupport> noria:agentManagesResource <resource/Server_Web01>, <resource/Server_DB01>, <resource/VM_App01>, <resource/VM_Analytics01>, <resource/Storage_SAN01> .
<agent/Team_SecurityOps> noria:agentManagesResource <resource/Firewall_FW01> .

