    seas:subSystemOf noria:ApplicationModule_CRMSystem_Prod ;
    seas:subSystemOf noria:Resource_WebFrontendVM01, noria:Resource_DatabaseServer01, noria:Resource_LoadBalancer01 .

noria:Service_SecurityMonitoring a noria:Service ;
    rdfs:label "Security Monitoring Service"@en ;
    rdfs:comment "Service providing real-time security event monitoring and alerting."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf noria:Application_MonitoringPlatform ;
    seas:subSystemOf noria:ApplicationModule_MonitoringPlatform_Prod ;
