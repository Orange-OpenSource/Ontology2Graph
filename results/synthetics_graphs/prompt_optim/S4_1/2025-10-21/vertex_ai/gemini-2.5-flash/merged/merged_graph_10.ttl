    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/LB01_Eth0> a noria:NetworkInterface ;
    rdfs:label "LB01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for Load Balancer 01."@en ;
    noria:networkInterfaceOf <resource/LoadBalancer_LB01> ;
