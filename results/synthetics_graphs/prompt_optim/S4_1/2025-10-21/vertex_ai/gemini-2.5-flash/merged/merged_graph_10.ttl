    dcterms:creator <agent/Person_AliceSmith> ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal_extra_node_3> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis_extra_node_3> ;
    dcterms:description "Confirmed packet loss and latency from both ends of the link. Engaged MPLS provider."@en ;
    dcterms:isPartOf <troubleTicket/TT_20240420_004> .

