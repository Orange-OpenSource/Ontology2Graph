# --- Event Records (noria:EventRecord) ---
<eventRecord/Log_DB01_DiskFull> a noria:EventRecord ;
    rdfs:label "DB01 Disk Full Alert"@en ;
    rdfs:comment "Log entry indicating that the disk space on DB01 is critically low."@en ;
    noria:loggingTime "2024-04-20T10:00:00Z"^^xsd:dateTime ;
    noria:logText "Disk usage on /dev/sda1 on db01.corp.example.com is 95%."@en ;
    noria:logOriginatingManagedObject <resource/Server_DB01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_3> .

<eventRecord/Log_Edge01_InterfaceDown> a noria:EventRecord ;
    rdfs:label "Edge01 Interface Down Alert"@en ;
    rdfs:comment "Log entry indicating that the internet-facing interface on Edge Router_extra_node_3 01 went down."@en ;
    noria:loggingTime "2024-04-20T10:30:00Z"^^xsd:dateTime ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface GigabitEthernet0/0/0, changed state to down."@en ;
    noria:logOriginatingManagedObject <resource/Router_Edge01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical_extra_node_3> .

<eventRecord/Log_WEB01_HighCPU> a noria:EventRecord ;
    rdfs:label "WEB01 High_extra_node_3 CPU Alert"@en ;
    rdfs:comment "Log entry indicating sustained high_extra_node_3 CPU utilization on Web Server_extra_node_3 01."@en ;
    noria:loggingTime "2024-04-20T11:00:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject <resource/Server_WEB01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major_extra_node_3> .

<eventRecord/Log_Firewall_BlockedAttempt> a noria:EventRecord ;
    rdfs:label "Firewall Blocked Attempt"@en ;
    rdfs:comment "Log entry showing a blocked connection attempt by the DMZ firewall."@en ;
    noria:loggingTime "2024-04-20T11:15:00Z"^^xsd:dateTime ;
    noria:logText "FW-DMZ01: Blocked connection from 1.2.3.4 to 10.0.0.12 on port 80."@en ;
