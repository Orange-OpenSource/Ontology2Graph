# Adding a TroubleTicket related to DR site
noria:TroubleTicket_005 a noria:TroubleTicket ;
    rdfs:label "DR Site Connectivity Issue"@en ;
    rdfs:comment "Connectivity issues detected between primary DC and DR site."@en ;
    dcterms:identifier "TT-20240424-005"^^xsd:string ;
    dcterms:created "2024-04-24T09:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Major> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P2> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/DeferredIntervention> ;
    noria:troubleTicketSupervisionTool "Network Monitoring"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/InaccessibleDestination> ;
    noria:troubleTicketCause "Intermittent packet loss on WAN link to Frankfurt."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ManagedBackboneNetworks> ;
    noria:troubleTicketDetectionDateTime "2024-04-24T08:45:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:OrgUnit_NetOpsTeam ;
    noria:troubleTicketRelatedResource noria:Resource_DRRouter001, noria:Resource_Router001 ;
    noria:troubleTicketImpacts noria:NetLink_DR_WAN, noria:NetLink_Router001_ISP .

# Adding a ChangeRequest for a new application deployment
noria:ChangeRequest_004 a noria:ChangeRequest ;
    rdfs:label "Deploy New Internal Reporting Tool"@en ;
    rdfs:comment "Deployment of a new internal reporting application on the virtualization platform."@en ;
    dcterms:identifier "CR-20240427-004"^^xsd:string ;
    dcterms:created "2024-04-27T10:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedStartTime "2024-05-15T18:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-15T20:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Normal> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/NetworkExtension> ; # Assuming it involves network changes
    noria:changeRequestImpact noria:Application_VirtualizationPlatform, noria:Resource_VMHost001 ;
    noria:changeRequestOutageDuration "PT0H0M"^^xsd:duration ; # No outage expected
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Scheduled> ;
    noria:changeRequestInitiatorParty noria:OrgUnit_CloudOpsTeam ;
    noria:changeRequestPilotParty noria:OrgUnit_CloudOpsTeam ;
    noria:changeRequestActorParty noria:OrgUnit_CloudOpsTeam ;
    noria:changeRequestIsRegulated "false"^^xsd:boolean .

# Adding an EventRecord for a security alert
noria:EventRecord_MalwareDetected a noria:EventRecord ;
    rdfs:label "Malware Detected on Server"@en ;
    rdfs:comment "Antivirus software detected malware on a web server."@en ;
    noria:loggingTime "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:logText "ALERT: Malware 'Trojan.Generic' detected in C:\\inetpub\\wwwroot\\index.php on web-app-001.dc-par.example.com."@en ;
    noria:logOriginatingManagedObject noria:Resource_Server001 ;
    noria:logOriginatingManagementSystem noria:Application_MonitoringSystem ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> ;
    noria:logOriginatingAgent noria:OrgUnit_SecurityTeam .

noria:TroubleTicket_006 a noria:TroubleTicket ;
    rdfs:label "Malware Incident on Web Server"@en ;
    rdfs:comment "Critical security incident: Malware detected on a production web server."@en ;
    dcterms:identifier "TT-20240423-006"^^xsd:string ;
    dcterms:created "2024-04-23T11:35:00Z"^^xsd:dateTime ;
    noria:troubleTicketSeverity <kos/TroubleTicket/severity/Critical> ;
    noria:troubleTicketType <kos/TroubleTicket/type/Failure> ;
    noria:troubleTicketPriority <kos/TroubleTicket/priority/P1> ;
    noria:troubleTicketOrigin <kos/TroubleTicket/origin/Supervision> ;
    noria:troubleTicketTrigger noria:EventRecord_MalwareDetected ;
    noria:troubleTicketUrgency <kos/TroubleTicket/urgency/ImmediateIntervention> ;
    noria:troubleTicketSupervisionTool "Antivirus"^^xsd:string ;
    noria:troubleTicketCategory <kos/TroubleTicket/trouble-category/SecurityIncident> ;
    noria:troubleTicketCause "Compromised web application leading to malware infection."@en ;
    noria:problemResponsibility <kos/TroubleTicket/problemResponsibility/ContractApplicationHostingServices> ;
    noria:troubleTicketDetectionDateTime "2024-04-23T11:30:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/InProgress> ;
    noria:troubleTicketRelatedParty noria:OrgUnit_SecurityTeam, noria:OrgUnit_AppDevTeam ;
    noria:troubleTicketRelatedResource noria:Resource_Server001 ;
    noria:troubleTicketImpacts noria:Service_CustomerWebApp, noria:Application_CustomerPortal .

noria:TroubleTicketNote_006_1 a noria:TroubleTicketNote ;
    rdfs:label "Server Isolation for Malware Incident"@en ;
    rdfs:comment "Web server web-app-001.dc-par.example.com isolated from network. Forensic analysis initiated."@en ;
    dcterms:created "2024-04-23T11:45:00Z"^^xsd:dateTime ;
    dcterms:creator noria:Agent_CarolWhite ;
    noria:troubleTicketNoteCommentType <kos/TroubleTicket/commentType/Internal> ;
    noria:troubleTicketNoteOperationType <kos/TroubleTicket/operationType/Diagnosis> ;
    dcterms:isPartOf noria:TroubleTicket_006 .

# Adding a new OperationPlan for incident response
noria:OperationPlan_IncidentResponse_Malware a noria:OperationPlan ;
    rdfs:label "Malware Incident Response Procedure"@en ;
    rdfs:comment "Procedure for handling malware detection incidents, including isolation, analysis, and remediation."@en ;
    skos:example "Steps include network isolation, forensic image, malware removal, and vulnerability patching."@en ;
    noria:operationPlanPreCondition noria:PreCond_MalwareDetected ;
    noria:operationPlanPostCondition noria:PostCond_SystemCleanAndSecure .

noria:PreCond_MalwareDetected a noria:ActionPreCondition ;
    rdfs:label "Malware Detected"@en ;
    rdfs:comment "Antivirus or EDR system has reported malware presence on a system."@en .

noria:PostCond_SystemCleanAndSecure a noria:ActionPostCondition ;
    rdfs:label "System Clean and Secure"@en ;
    rdfs:comment "The infected system has been cleaned, vulnerabilities patched, and is deemed secure for re-integration."@en .

noria:ProcedureExecutionContainer_TT006_IR a pep:ProcedureExecutionContainer ;
    rdfs:label "Incident Response for TT-006"@en ;
    rdfs:comment "Container for incident response actions taken for Trouble Ticket 006."@en ;
    pep:usedProcedure noria:OperationPlan_IncidentResponse_Malware ;
    pep:hasInput noria:PreCond_MalwareDetected ;
    pep:hasOutput noria:PostCond_SystemCleanAndSecure .

noria:TroubleTicketNote_006_1 noria:troubleTicketNoteCorrelatedExecution noria:ProcedureExecutionContainer_TT006_IR .

# Final status update for TT-006
noria:TroubleTicket_006
    noria:troubleTicketPlannedRestorationDateTime "2024-04-23T18:00:00Z"^^xsd:dateTime ;
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:problemCategory <kos/TroubleTicket/trouble-category/SecurityIncident> .



# =============================================================================
# Ontology Metadata
# =============================================================================

<https://w3id.org/noria/ontology/>
    a voaf:Vocabulary, owl:Ontology ;
    dcterms:title "The NORIA Ontology"@en ;
    dcterms:description """The NORIA-O project is a data model for IT networks, events and operations information.
    The ontology is developed using web technologies (e.g. RDF, OWL, SKOS) and is intended as a structure for realizing an IT Service Management (ITSM) Knowledge Graph (KG) for Anomaly Detection (AD) and Risk Management applications.
    The model has been developed in collaboration with operational teams, and in connection with third parties linked vocabularies.
    """@en ;
    dcterms:creator "Lionel Tailhardat (https://orcid.org/0000-0001-5887-899X)" ;
    dcterms:creator "Yoan Chabot (https://orcid.org/0000-0001-5639-1504)" ;
    dcterms:creator "Raphaël Troncy (https://orcid.org/0000-0003-0457-1436)" ;
    dcterms:publisher <https://www.orange.com/> ;
    dcterms:license <https://spdx.org/licenses/BSD-4-Clause> ;
    vann:preferredNamespacePrefix "noria" ;
    vann:preferredNamespaceUri "https://w3id.org/noria/ontology/" ;
    dcterms:issued "2022-05-10"^^xsd:date ;
    dcterms:modified "2024-03-15"^^xsd:date ;
    owl:versionInfo "v0.3" ;
    owl:versionIRI <ontology/noria-0.3> ;
    owl:priorVersion <ontology/noria-0.2> ;
    rdfs:seeAlso <https://w3id.org/noria/doc/> ;
.

# =============================================================================
# Agents (foaf:Agent and org:OrganizationalUnit)
# =============================================================================

<https://w3id.org/noria/agent/ITOpsTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "IT Operations Team"@en, "Équipe Opérations IT"@fr ;
    rdfs:comment "Central team responsible for day-to-day IT infrastructure operations and incident response."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Pager> ;
    noria:agentInstructions "Contact via primary incident management system, then pager for critical issues."@en .

<https://w3id.org/noria/agent/NetworkAdminTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Administration Team"@en, "Équipe Administration Réseau"@fr ;
    rdfs:comment "Specialized team managing network devices and connectivity."@en ;
    noria:agentWorkingHours "8:00-18:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Open a ticket in the network management system for all requests."@en ;
    noria:agentManagesResource <https://w3id.org/noria/resource/Router01>, <https://w3id.org/noria/resource/Firewall01> .

<https://w3id.org/noria/agent/AppSupportTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en, "Équipe Support Applicatif"@fr ;
    rdfs:comment "Team providing support for business applications."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All application issues must be reported via the dedicated ticketing portal."@en ;
    noria:agentManagesResource <https://w3id.org/noria/application/CRMSystem>, <https://w3id.org/noria/application/ERPBackend> .

<https://w3id.org/noria/agent/SecurityTeam> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en, "Centre d'Opérations de Sécurité (SOC)"@fr ;
    rdfs:comment "Monitors and responds to security incidents."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/SecureChat> ;
    noria:agentInstructions "Use encrypted channels for sensitive communications."@en .

<https://w3id.org/noria/agent/JohnDoe> a foaf:Agent ;
    rdfs:label "John Doe"@en, "Jean Dupont"@fr ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox "mailto:john.doe@example.com" ;
    foaf:phone "+33123456789" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

<https://w3id.org/noria/agent/JaneSmith> a foaf:Agent ;
    rdfs:label "Jane Smith"@en, "Jeanne Martin"@fr ;
    rdfs:comment "CRM Application Administrator."@en ;
    foaf:mbox "mailto:jane.smith@example.com" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<https://w3id.org/noria/agent/ExternalVendor> a foaf:Agent, org:Organization ;
    rdfs:label "External Cloud Provider"@en, "Fournisseur Cloud Externe"@fr ;
    rdfs:comment "Third-party vendor providing cloud infrastructure services."@en ;
    noria:agentWorkingHours "24/7" ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/API> ;
    noria:agentInstructions "Refer to API documentation for automated incident reporting."@en .

