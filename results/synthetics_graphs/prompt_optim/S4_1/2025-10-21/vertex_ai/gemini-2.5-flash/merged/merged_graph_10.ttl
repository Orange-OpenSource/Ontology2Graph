    noria:logText "Trouble Ticket TT-20240420-001 transferred from ITOpsTeam to AppSupportTeam for database-specific investigation."@en ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringPlatform> ;
    noria:logOriginatingAgent <https://w3id.org/noria/agent/JohnDoe> ;
