# --- Network Interfaces (noria:NetworkInterface) ---
noria:NetworkInterface_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "dns01.corp.example.com:eth0"@en ;
    rdfs:comment "Ethernet interface for DNS server 01."@en ;
    noria:networkInterfaceOf noria:Resource_DNSServer01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceDescription "Primary network interface for DNS queries."@en .

noria:NetworkInterface_CR01_Gig0_0_0 a noria:NetworkInterface ;
    rdfs:label "cr01.corp.example.com:GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface for Core Router 01."@en ;
    noria:networkInterfaceOf noria:Resource_CoreRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric 100 ;
    noria:networkInterfaceLaserTxOpticalPower -2 ;
    noria:networkInterfaceLaserRxOpticalPower -3 ;
    noria:networkInterfaceLaserRxHighPowerWarningThreshold -1 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

