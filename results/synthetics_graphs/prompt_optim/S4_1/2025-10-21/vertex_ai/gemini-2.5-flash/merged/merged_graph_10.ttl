    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

<networkinterface/VR01_Eth0> a noria:NetworkInterface ;
    rdfs:label "VR01 Ethernet 0"@en ;
    rdfs:comment "Virtual network interface for Virtual Router 01."@en ;
    noria:networkInterfaceOf <resource/VirtualRouter_VR01> ;
