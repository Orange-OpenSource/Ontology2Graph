    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/up> .

# --- Network Links (noria:NetworkLink) ---
<networklink/Core01_Edge01_Link> a noria:NetworkLink ;
    rdfs:label "Core01-Edge01 Interconnect Link"@en ;
    rdfs:comment "High-speed fiber link between Core Router 01 and Edge Router 01."@en ;
    noria:networkLinkId "NL-PDC1-CORE-EDGE" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkInstallationDate "2022-05-01T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/Router_Core01> ;
    noria:networkLinkTerminationResourceDestination <resource/Router_Edge01> ;
    noria:networkInterfaceConnects <networkinterface/Core01_Ge0_0_1> ;
    noria:networkInterfaceConnects <networkinterface/Edge01_Ge0_0_0> ;
    noria:resourceManagedBy <agent/Team_NetworkOps> .

<networklink/Edge01_ISP_Link> a noria:NetworkLink ;
    rdfs:label "Edge01-ISP Uplink"@en ;
    rdfs:comment "Internet uplink from Edge Router 01 to ISP."@en ;
    noria:networkLinkId "NL-PDC1-ISP" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkInstallationDate "2022-05-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResource <resource/Router_Edge01> ;
    noria:networkInterfaceConnects <networkinterface/Edge01_Ge0_0_1> ;
    noria:resourceManagedBy <agent/Team_NetworkOps> .

<networklink/LRO_Uplink> a noria:NetworkLink ;
    rdfs:label "LRO Office Uplink"@en ;
    rdfs:comment "Uplink from Lyon Regional Office to PDC1."@en ;
    noria:networkLinkId "NL-LRO-PDC1" ;
    noria:networkLinkType "Dedicated Ethernet" ;
    noria:networkLinkInstallationDate "2023-02-10T10:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/Switch_LRO_Core> ;
    noria:networkLinkTerminationResourceDestination <resource/Router_Core01> ;
    noria:networkInterfaceConnects <networkinterface/LRO_SW_Core_Ge1_0_1> ;
    noria:networkInterfaceConnects <networkinterface/Core01_Ge0_0_0> ;
    noria:resourceManagedBy <agent/Team_NetworkOps> .

<networklink/Edge01_LB01_Link> a noria:NetworkLink ;
    rdfs:label "Edge01-LB01 Interconnect Link"@en ;
    rdfs:comment "Link between Edge Router 01 and Load Balancer 01."@en ;
    noria:networkLinkId "NL-PDC1-EDGE-LB" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkInstallationDate "2023-04-01T11:00:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/Router_Edge01> ;
    noria:networkLinkTerminationResourceDestination <resource/LoadBalancer_LB01> ;
    noria:networkInterfaceConnects <networkinterface/Edge01_Ge0_0_1> ;
    noria:networkInterfaceConnects <networkinterface/LB01_Eth0> ;
    noria:resourceManagedBy <agent/Team_NetworkOps> .

# --- Applications (noria:Application) ---
<application/CustomerPortal> a noria:Application ;
    rdfs:label "Customer Portal"@en ;
    rdfs:label "Portail Client"@fr ;
    rdfs:comment "Web application allowing customers to manage their services."@en ;
    noria:applicationModelIdentifier "CP-PROD" ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CP" ;
    noria:applicationType <kos/application/type/customer-facing> ;
    noria:applicationBusinessImportance <kos/application/business-importance/high> ;
    noria:applicationFunctionalDomain "Customer Relationship Management"@en ;
    noria:applicationFunctionalSubDomain "Online Self-Service"@en ;
    noria:elementManagedBy <agent/Team_AppSupport> .

<application/InternalCRM> a noria:Application ;
    rdfs:label "Internal CRM"@en ;
    rdfs:label "CRM Interne"@fr ;
    rdfs:comment "Application for managing customer interactions by internal staff."@en ;
    noria:applicationModelIdentifier "CRM-INT" ;
    noria:applicationNumericalIdentifier "1002"^^xsd:int ;
    noria:applicationShortIdentifier "CRM" ;
    noria:applicationType <kos/application/type/internal-business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Sales and Marketing"@en ;
    noria:applicationFunctionalSubDomain "Customer Data Management"@en ;
    noria:elementManagedBy <agent/Team_AppSupport> .

<application/MonitoringPlatform> a noria:Application ;
    rdfs:label "Monitoring Platform"@en ;
    rdfs:label "Plateforme de Supervision"@fr ;
    rdfs:comment "System for monitoring IT infrastructure and applications."@en ;
    noria:applicationModelIdentifier "MON-PLAT" ;
    noria:applicationNumericalIdentifier "2001"^^xsd:int ;
    noria:applicationShortIdentifier "MON" ;
    noria:applicationType <kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "IT Operations Management"@en ;
    noria:applicationFunctionalSubDomain "Performance and Availability Monitoring"@en ;
    noria:elementManagedBy <agent/Team_NetworkOps> .

<application/AnalyticsDashboard> a noria:Application ;
    rdfs:label "Analytics Dashboard"@en ;
    rdfs:comment "Application for visualizing business performance metrics."@en ;
    noria:applicationModelIdentifier "ANALYTICS-DASH" ;
    noria:applicationNumericalIdentifier "3001"^^xsd:int ;
    noria:applicationShortIdentifier "AD" ;
    noria:applicationType <kos/application/type/internal-business> ;
    noria:applicationBusinessImportance <kos/application/business-importance/medium> ;
    noria:applicationFunctionalDomain "Business Intelligence"@en ;
    noria:applicationFunctionalSubDomain "Data Visualization"@en ;
    noria:elementManagedBy <agent/Team_AppSupport> .

# --- Application Modules (noria:ApplicationModule) ---
<applicationmodule/CustomerPortal_Prod> a noria:ApplicationModule ;
    rdfs:label "Customer Portal Production Module"@en ;
    rdfs:comment "Production instance of the Customer Portal application."@en ;
    noria:applicationModuleOf <application/CustomerPortal> ;
    noria:applicationModuleName "CP_PROD" ;
    noria:applicationModuleIdentifier "PROD" ;
    noria:applicationModuleStatus <https://w3id.org/noria/kos/application/status/InProduction> ;
    noria:applicationModuleSlaLevel <https://w3id.org/noria/kos/application/sla-level/Platinum> ;
    noria:applicationModuleSlaLevelDate "2023-01-01T00:00:00Z"^^xsd:dateTime ;
    noria:applicationModuleHotlineEnabled "true"^^xsd:boolean ;
    noria:applicationModuleAdministrationTeam <agent/Team_AppSupport> ;
    noria:applicationModuleAdministrationLeader <agent/Person_Bob> ;
    noria:applicationModuleSupportTeam <agent/Team_AppSupport> ;
    noria:applicationModuleSupportLeader <agent/Person_Bob> ;
    noria:applicationModuleSupportGroup <agent/Team_AppSupport> ;
    noria:applicationModuleHotlineGroup <agent/Team_AppSupport> ;
    seas:subSystemOf <resource/Server_Web01>, <resource/Server_DB01>, <resource/LoadBalancer_LB01> .

