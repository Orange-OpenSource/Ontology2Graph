    noria:logOriginatingManagementSystem noria:App_MonitoringPlatform ;
    noria:logOriginatingAgent noria:Agent_Automated_System ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning_extra_node_2> .

