# =============================================================================
# Agents (Teams and Individuals)
# =============================================================================

foaf:Agent_NetworkTeam a foaf:Agent ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for managing network infrastructure."@en ;
    noria:agentWorkingHours "9:00-17:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for all issues. For critical issues, use emergency phone line."@en .

foaf:Agent_ServerTeam a foaf:Agent ;
    rdfs:label "Server Administration Team"@en ;
    rdfs:comment "Team responsible for server and virtual machine management."@en ;
    noria:agentWorkingHours "24/7 On-call rotation"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Open a ticket for non-critical issues. Call hotline for any server outage."@en .

foaf:Agent_AppDevTeam a foaf:Agent ;
    rdfs:label "Application Development Team"@en ;
    rdfs:comment "Team responsible for developing and maintaining business applications."@en ;
    noria:agentWorkingHours "10:00-18:00 Mon-Fri"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Use internal chat for urgent development-related queries."@en .

foaf:Agent_CustomerSupport a foaf:Agent ;
    rdfs:label "Customer Support Team"@en ;
    rdfs:comment "First line support for customer inquiries."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_JohnDoe a foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:john.doe@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

foaf:Agent_JaneSmith a foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Server Administrator."@en ;
    foaf:mbox <mailto:jane.smith@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> .

foaf:Agent_AliceJohnson a foaf:Person ;
    rdfs:label "Alice Johnson"@en ;
    rdfs:comment "Application Support Specialist."@en ;
    foaf:mbox <mailto:alice.johnson@example.com> ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

# Organizational Units
org:OrgUnit_ITDepartment a org:OrganizationalUnit ;
    rdfs:label "IT Department"@en ;
    rdfs:comment "Overall IT department responsible for all IT services."@en ;
    org:hasMember foaf:Agent_JohnDoe, foaf:Agent_JaneSmith, foaf:Agent_AliceJohnson .

foaf:Agent_JohnDoe org:memberOf org:OrgUnit_ITDepartment .
foaf:Agent_JaneSmith org:memberOf org:OrgUnit_ITDepartment .
foaf:Agent_AliceJohnson org:memberOf org:OrgUnit_ITDepartment .

foaf:Agent_NetworkTeam org:subOrganizationOf org:OrgUnit_ITDepartment .
foaf:Agent_ServerTeam org:subOrganizationOf org:OrgUnit_ITDepartment .
foaf:Agent_AppDevTeam org:subOrganizationOf org:OrgUnit_ITDepartment .
foaf:Agent_CustomerSupport org:subOrganizationOf org:OrgUnit_ITDepartment .

# Corporate User Identifiers
noria:CUid_JohnDoe a noria:CorporateUserIdentifier ;
    rdfs:label "John Doe's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for John Doe."@en ;
    foaf:accountName "jdoe" ;
    foaf:holdsAccount foaf:Agent_JohnDoe .

noria:CUid_JaneSmith a noria:CorporateUserIdentifier ;
    rdfs:label "Jane Smith's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Jane Smith."@en ;
    foaf:accountName "jsmith" ;
    foaf:holdsAccount foaf:Agent_JaneSmith .

noria:CUid_AliceJohnson a noria:CorporateUserIdentifier ;
    rdfs:label "Alice Johnson's Corporate ID"@en ;
    rdfs:comment "Corporate user identifier for Alice Johnson."@en ;
    foaf:accountName "ajohnson" ;
    foaf:holdsAccount foaf:Agent_AliceJohnson .

