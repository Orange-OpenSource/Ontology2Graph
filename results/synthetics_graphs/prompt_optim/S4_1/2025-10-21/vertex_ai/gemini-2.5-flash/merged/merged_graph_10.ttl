    noria:resourceUsageState <kos/Resource/LifecycleState/Staging> ;
    noria:resourceForApplication noria:AppModule_CustomerPortal_Staging ;
    noria:clusterController noria:Resource_VMHost001 ;
    noria:resourceManagementIPAddress "10.0.0.12"^^xsd:string .

noria:NetInt_VM_WebApp002_Eth0 a noria:NetworkInterface ;
    rdfs:label "VM WebApp 002 Ethernet 0"@en ;
    rdfs:comment "Network interface for Virtual Machine WebApp 002 (Staging)."@en ;
    noria:networkInterfaceOf noria:Resource_VM_WebApp002 ;
    noria:networkInterfaceType "virtual" ;
