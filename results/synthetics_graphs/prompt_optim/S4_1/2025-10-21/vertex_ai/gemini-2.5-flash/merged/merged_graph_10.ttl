noria:ChangeRequestRouterUpgrade a noria:ChangeRequest ;
    rdfs:label "Core Router Software Upgrade"@en, "Mise à Jour Logicielle Routeur Cœur"@fr ;
    dcterms:description "Upgrade IOS-XE software on router-core-01 to address security vulnerabilities."@en ;
    noria:changeRequestPlannedStartTime "2024-05-01T02:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-05-01T04:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
    noria:changeRequestChangeCause <kos/ChangeRequest/cause/SoftwareUpgrade> ;
    noria:changeRequestImpact noria:ResourceRouterCore01, noria:ApplicationModuleInternetAccessProd ;
    noria:changeRequestOutageDuration "PT1H30M"^^xsd:duration ; # 1 hour 30 minutes
    noria:changeRequestStatusCurrent <kos/ChangeRequest/status/Approved> ;
    noria:changeRequestSpecification <kos/ChangeRequest/specification/RoutineMaintenance> ;
    noria:changeRequestInitiatorParty noria:AgentNOC ;
    noria:changeRequestPilotParty noria:AgentInfraOps ;
    noria:changeRequestActorParty noria:AgentInfraOps ;
    noria:changeRequestIsRegulated true ;
    noria:documentExternalId "CR-2024-05-01-001" ;
    noria:documentHRef "https://itsm.example.com/change/CR-2024-05-01-001" .

