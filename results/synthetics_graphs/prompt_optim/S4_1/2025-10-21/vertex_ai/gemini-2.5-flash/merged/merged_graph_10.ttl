    noria:resourceLogisticId "LOG-RTR-001" ;
    noria:resourceHostName "router-core-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModelCiscoNexus9K ;
    noria:resourceType <kos/Resource/type/router> ;
    noria:resourceSerialNumber "SN-RTR-001-DEF" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-11-01T08:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:LocusRackB2 ;
    noria:resourceManagementIPAddress <http://ip.example.com/172.16.0.1> .

noria:FirewallDMZ a noria:Resource ;
    rdfs:label "DMZ Firewall"@en ;
    rdfs:comment "Firewall protecting the Demilitarized Zone (DMZ)."@en ;
    noria:resourceManagedBy org:SecurityTeam ;
    noria:resourceLogisticId "LOG-FW-001" ;
    noria:resourceHostName "fw-dmz-01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModelPaloAltoFW ;
    noria:resourceType <kos/Resource/type/firewall> ;
    noria:resourceSerialNumber "SN-FW-001-GHI" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:LocusRackB2 ;
    noria:resourceManagementIPAddress <http://ip.example.com/192.168.2.1> .

noria:Hypervisor01 a noria:Resource ;
    rdfs:label "Hypervisor Host 01"@en ;
    rdfs:comment "Physical server running virtual machines."@en ;
    noria:resourceManagedBy org:ITOperationsDept ;
    noria:resourceLogisticId "LOG-HV-001" ;
