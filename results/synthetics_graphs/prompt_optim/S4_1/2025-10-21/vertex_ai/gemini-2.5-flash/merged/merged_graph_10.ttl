# =============================================================================
# Resources
# =============================================================================

noria:ResourceDNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en, "Serveur DNS d'Entreprise 01"@fr ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy noria:AgentInfraOps ;
    noria:resourceProductModel noria:ProductModelDellR740 ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceSerialNumber "SN-DELL-R740-001" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InUse> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:ApplicationInternetAccess ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
