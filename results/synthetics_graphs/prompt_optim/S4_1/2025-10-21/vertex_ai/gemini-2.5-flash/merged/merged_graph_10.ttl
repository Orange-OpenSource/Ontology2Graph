    noria:resourceInstallationDate "2022-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:ERPApp ;
    noria:locatedAtLocus noria:LocusRackA1 ;
    noria:resourceManagementIPAddress <http://ip.example.com/10.0.0.100> .

noria:RouterCore1 a noria:Resource ;
    rdfs:label "Core Router 1"@en ;
