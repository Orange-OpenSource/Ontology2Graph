    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" .

bot:OfficeLyon a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office in Lyon with local IT infrastructure."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "456 Avenue Jean Jaurès" ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon" ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès" .

noria:ServerRoomDC1 a noria:Room ;
    rdfs:label "Server Room DC1"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace bot:DataCenterParis .

noria:NetworkRoomDC1 a noria:Room ;
    rdfs:label "Network Room DC1"@en ;
    rdfs:comment "Dedicated network equipment room in Paris Data Center."@en ;
    bot:hasSpace bot:DataCenterParis .

noria:LocusRackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "Location of servers in Rack A1 in Server Room DC1."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:containsZone noria:ServerRoomDC1 .

noria:LocusRackB2 a noria:Locus ;
    rdfs:label "Rack B2"@en ;
    rdfs:comment "Location of network devices in Rack B2 in Network Room DC1."@en ;
    noria:locusLine "B" ;
    noria:locusRow "2" ;
    bot:containsZone noria:NetworkRoomDC1 .

# =============================================================================
# Resources
# =============================================================================

noria:DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network services."@en ;
    noria:resourceManagedBy org:NetworkTeam ;
    noria:resourceLogisticId "LOG-DNS-001" ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModelDellR740 ;
    noria:resourceType <kos/Resource/type/server> ;
    noria:resourceSerialNumber "SN-DNS-001-XYZ" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceForApplication noria:CorpDNSApp ;
    noria:locatedAtLocus noria:LocusRackA1 ;
    noria:resourceManagementIPAddress <http://ip.example.com/192.168.1.10> .

