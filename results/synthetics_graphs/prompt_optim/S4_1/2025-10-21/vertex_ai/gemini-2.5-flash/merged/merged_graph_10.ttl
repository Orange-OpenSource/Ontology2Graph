    dcterms:description "Migrate CRM database from on-premise to cloud infrastructure."@en ;
    noria:changeRequestPlannedStartTime "2024-06-15T22:00:00Z"^^xsd:dateTime ;
    noria:changeRequestPlannedEndTime "2024-06-16T06:00:00Z"^^xsd:dateTime ;
    noria:changeRequestCategory <kos/ChangeRequest/category/InternalIntervention> ;
    noria:changeRequestType <kos/ChangeRequest/type/Standard> ;
