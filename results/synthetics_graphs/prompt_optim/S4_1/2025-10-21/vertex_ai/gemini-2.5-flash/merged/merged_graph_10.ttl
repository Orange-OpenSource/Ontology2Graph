# Event Records (noria:EventRecord)
# =============================================================================

<https://w3id.org/noria/event/Log-WebServer01-CPUHigh> a noria:EventRecord ;
    rdfs:label "High CPU Usage on WebServer01 Log"@en ;
    rdfs:comment "Log entry indicating sustained high CPU usage on WebServer01."@en ;
    noria:loggingTime "2024-04-20T10:05:00Z"^^xsd:dateTime ;
    noria:logText "CPU utilization on web01.corp.example.com exceeded 90% for 5 minutes."@en ;
    noria:logOriginatingManagedObject <https://w3id.org/noria/resource/WebServer01> ;
    noria:logOriginatingManagementSystem <https://w3id.org/noria/application/MonitoringPlatform> ;
    dcterms:type <kos/Notification/EventType/PerformanceIssue> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> .

<https://w3id.org/noria/event/Alarm-DBServer01-DiskFull> a noria:EventRecord ;
    rdfs:label "Critical Alarm: DBServer01 Disk Full"@en ;
