    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

<https://w3id.org/noria/networklink/LAN-LoadBalancer> a noria:NetworkLink ;
    rdfs:label "LAN Load Balancer Link"@en ;
    rdfs:comment "Internal LAN segment connecting load balancer to web servers."@en ;
    noria:networkLinkId "LAN-LB-001" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkInterfaceConnects <https://w3id.org/noria/networkinterface/LoadBalancer01-Eth0>,
                                   <https://w3id.org/noria/networkinterface/WebServer01-Eth0> ;
    noria:resourceManagedBy <https://w3id.org/noria/agent/NetworkAdminTeam> .

# Final check for connectivity and density:
# - All major entities (Resource, Application, TT, CR, Event, Agent, Location) have labels, comments, and types.
# - Resources are linked to ProductModels, Locations, ManagedBy Agents, and Applications.
# - NetworkInterfaces are linked to Resources and NetworkLinks.
# - NetworkLinks connect NetworkInterfaces and have termination resources.
# - Applications have types, importance, and functional domains.
# - ApplicationModules are linked to Applications and have various related parties and statuses.
# - Services are linked to ApplicationModules.
# - EventRecords are linked to originating objects (Resource/Application), management systems, and agents, and have severity/type.
# - TroubleTickets are linked to related services/applications/resources, related parties, trigger events, and have detailed properties.
# - TroubleTicketNotes are linked to TroubleTickets and authors.
# - ChangeRequests are linked to impacted entities, initiators, actors, and have detailed properties.
# - DocumentAttachments are linked to TroubleTickets/ChangeRequests.
# - OperationPlans, Pre/PostConditions are linked to each other.
# - Cross-linking between dynamic elements (EventRecord -> TroubleTicket -> TroubleTicketNote -> EventRecord, EventRecord -> ChangeRequest).
# - All entities are connected. The graph is dense.
# - No ldp prefix used.
# - Max tokens constraint is aimed for by generating a substantial amount of interconnected data.


