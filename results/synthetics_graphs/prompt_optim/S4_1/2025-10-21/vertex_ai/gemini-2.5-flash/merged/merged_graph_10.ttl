# Example of a cluster controller
noria:Resource_VirtualizationHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "Physical server hosting multiple virtual machines, including web01."@en ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceHostName "vhost01.corp.example.com" ;
    noria:resourceManagedBy foaf:Agent_DNSAdminTeam . # Assuming same team manages virtualization hosts

noria:Resource_WebSrv01 noria:clusterController noria:Resource_VirtualizationHost01 .

# Example of a NetworkInterface with optical power thresholds
noria:NI_ER01_Gig0_0_2 noria:networkInterfaceLaserRxHighPowerWarningThreshold -2 ;
    noria:networkInterfaceLaserRxLowPowerWarningThreshold -10 .

# Example of a Change Request impacting a Service
noria:ChangeRequest_RouterFirmwareUpdate noria:changeRequestImpact noria:Service_InternetAccess .

# Example of a Change Request impacting an Application Module
noria:ChangeRequest_DBOptimization noria:changeRequestImpact noria:AppMod_Ecommerce_Backend .

# Example of a TroubleTicketNote correlated execution
noria:TTNote_DNSOutage_2 noria:troubleTicketNoteCorrelatedExecution noria:ChangeRequest_DNSUpgrade . # Simplified, linking a note to a CR that might resolve the underlying issue.

# Final status for resolved tickets
noria:TroubleTicket_DNSOutage noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T09:50:00Z"^^xsd:dateTime .

noria:TroubleTicket_EcommerceSlowdown noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:30:00Z"^^xsd:dateTime .

noria:TroubleTicket_RouterPortFlapping noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T11:45:00Z"^^xsd:dateTime .

