    noria:resourceHostName "web-prod01.example.com" ;
    noria:resourceProductModel <productModel/Dell_PowerEdge_R750> ;
    noria:resourceType <kos/Resource/type/Server> ;
    noria:resourceSerialNumber "ABC98765432" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-03-01T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/Rack_A1_R2> ;
    noria:resourceManagementIPAddress <observable/IPAddress_10.0.0.10> ;
    noria:resourceForApplication <application/CorporateWebsite> .

<resource/Firewall_DMZ_PAR01> a noria:Resource ;
