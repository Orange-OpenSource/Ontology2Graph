    noria:logOriginatingManagedObject <resource/Firewall_DMZ_PAR01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "Blocked SYN flood attack from 192.168.1.100 on port 80."@en ;
    dcterms:type <kos/Notification/EventType/SecurityAlarm> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Warning> ;
    noria:logOriginatingAgent <agent/Team_SecurityOperations> .

<eventRecord/Log_DB_BackupSuccess> a noria:EventRecord ;
    rdfs:label "Database Backup Success Log"@en ;
    rdfs:comment "Log entry confirming successful daily database backup."@en ;
    noria:loggingTime "2024-04-20T03:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/VirtualMachine_DB_PROD01> ;
    noria:logOriginatingManagementSystem <application/CustomerDatabase> ;
    noria:logText "Daily full backup of Customer Database completed successfully."@en ;
    dcterms:type <kos/Notification/EventType/Informational> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Clear> .

<eventRecord/Log_UserLoginFailure> a noria:EventRecord ;
    rdfs:label "User Login Failure Log"@en ;
    rdfs:comment "Log entry for a failed login attempt."@en ;
    noria:loggingTime "2024-04-20T11:05:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <application/CorporateWebsite> ;
    noria:logOriginatingManagementSystem <application/CorporateWebsite> ;
    noria:logText "Failed login attempt for user 'jdoe' from IP 203.0.113.42."@en ;
