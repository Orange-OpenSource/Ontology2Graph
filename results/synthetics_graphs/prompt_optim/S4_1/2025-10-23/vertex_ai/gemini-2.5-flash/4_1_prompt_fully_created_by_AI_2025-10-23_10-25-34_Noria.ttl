# --- Network Links (noria:NetworkLink) ---
# Connections between network interfaces or resources.

<networkLink/Internal_Link_PAR01_1> a noria:NetworkLink ;
    rdfs:label "Internal Data Center Link PAR01-1"@en ;
    rdfs:comment "High-speed internal link within Paris Data Center."@en ;
    noria:networkLinkId "NL-PAR01-INT-01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> ;
    noria:networkLinkTerminationResource <resource/Router_Core_PAR01> ;
    noria:networkLinkTerminationResource <resource/Server_Web_PROD01> ;
    noria:networkLinkTerminationResource <resource/VirtualMachine_DB_PROD01> .

<networkLink/DMZ_Link_PAR01> a noria:NetworkLink ;
    rdfs:label "DMZ Link PAR01"@en ;
    rdfs:comment "Link between Core Router and DMZ Firewall."@en ;
    noria:networkLinkId "NL-PAR01-DMZ-01" ;
    noria:networkLinkType "Ethernet 1Gbps" ;
    noria:networkLinkInstallationDate "2022-06-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/Team_SecurityOperations> ;
    noria:networkLinkTerminationResource <resource/Router_Core_PAR01> ;
    noria:networkLinkTerminationResource <resource/Firewall_DMZ_PAR01> .

<networkLink/External_Link_PAR01> a noria:NetworkLink ;
    rdfs:label "External Internet Link PAR01"@en ;
    rdfs:comment "Uplink to the internet from Paris Data Center."@en ;
    noria:networkLinkId "NL-PAR01-EXT-01" ;
    noria:networkLinkType "Fiber Optic 10Gbps" ;
    noria:networkLinkInstallationDate "2022-06-20T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> ;
    noria:networkLinkTerminationResource <resource/Firewall_DMZ_PAR01> .

<networkLink/WAN_Link_PAR_LDN> a noria:NetworkLink ;
    rdfs:label "WAN Link Paris-London"@en ;
    rdfs:comment "Dedicated WAN link connecting Paris Data Center to London Office."@en ;
    noria:networkLinkId "NL-WAN-PAR-LDN-01" ;
    noria:networkLinkType "MPLS VPN 1Gbps" ;
    noria:networkLinkInstallationDate "2022-02-10T11:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> ;
    noria:networkLinkTerminationResource <resource/Router_Core_PAR01> ;
    noria:networkLinkTerminationResource <resource/Router_Edge_LDN01> .

# --- Applications (noria:Application) ---
# Software systems and services.

<application/CorporateWebsite> a noria:Application ;
    rdfs:label "Corporate Website"@en ;
    rdfs:comment "Public-facing website for the company."@en ;
    noria:applicationModelIdentifier "CORPWEB" ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "CW" ;
    noria:applicationType <kos/application/type/WebApplication> ;
    noria:applicationBusinessImportance <kos/application/business-importance/High> ;
    noria:applicationFunctionalDomain "Marketing and Sales"@en ;
    noria:applicationFunctionalSubDomain "Customer Engagement"@en .

<application/CustomerDatabase> a noria:Application ;
    rdfs:label "Customer Database System"@en ;
    rdfs:comment "Backend system for managing customer information."@en ;
    noria:applicationModelIdentifier "CUSTDB" ;
    noria:applicationNumericalIdentifier "1002"^^xsd:int ;
    noria:applicationShortIdentifier "CDB" ;
    noria:applicationType <kos/application/type/DatabaseSystem> ;
