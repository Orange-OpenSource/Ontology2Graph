# --- Resources (noria:Resource) ---
# Physical and virtual IT assets.

<resource/Router_Core_PAR01> a noria:Resource ;
    rdfs:label "Core Router PAR01"@en ;
    rdfs:comment "Main core router in Paris Data Center."@en ;
    noria:resourceManagedBy <agent/Team_NetworkOperations> ;
    noria:resourceHostName "cr-par01.example.com" ;
    noria:resourceProductModel <productModel/Cisco_Catalyst_9300> ;
    noria:resourceType <kos/Resource/type/Router> ;
    noria:resourceSerialNumber "FOC12345678" ;
    noria:resourceUsageState <kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus <locus/Rack_A1_R1> ;
    noria:resourceManagementIPAddress <observable/IPAddress_10.0.0.1> .

<resource/Server_Web_PROD01> a noria:Resource ;
    rdfs:label "Web Server PROD01"@en ;
