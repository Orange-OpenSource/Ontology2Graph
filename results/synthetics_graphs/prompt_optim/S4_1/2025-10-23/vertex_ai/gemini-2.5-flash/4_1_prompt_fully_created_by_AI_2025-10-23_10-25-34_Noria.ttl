# Network ports and logical interfaces on resources.

<networkInterface/CR_PAR01_Gi0_0_1> a noria:NetworkInterface ;
    rdfs:label "Gi0/0/1 on Core Router PAR01"@en ;
    rdfs:comment "GigabitEthernet interface connecting to internal network."@en ;
