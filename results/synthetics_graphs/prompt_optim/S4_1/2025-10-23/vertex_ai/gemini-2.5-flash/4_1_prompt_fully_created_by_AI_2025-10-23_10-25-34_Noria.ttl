<eventRecord/Log_DiskCleanup_End> a noria:EventRecord ;
    rdfs:label "Disk Cleanup Ended Log"@en ;
    noria:loggingTime "2024-04-21T08:20:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Server_Email_PROD01> ;
    noria:logOriginatingAgent <agent/Team_ApplicationSupport> ;
    noria:logText "Temporary disk cleanup completed. 50GB freed. Disk usage 70%."@en .

