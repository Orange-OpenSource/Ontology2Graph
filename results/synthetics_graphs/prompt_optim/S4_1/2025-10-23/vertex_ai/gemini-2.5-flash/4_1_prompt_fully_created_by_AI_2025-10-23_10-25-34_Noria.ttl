# --- Event Records (noria:EventRecord) ---
# Logs, alarms, and notifications from various systems.

<eventRecord/Log_Router_InterfaceDown> a noria:EventRecord ;
    rdfs:label "Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating a network interface went down."@en ;
    noria:loggingTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Router_Core_PAR01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "LINEPROTO-5-UPDOWN: Interface Gi0/0/1, changed state to down"@en ;
    dcterms:type <kos/Notification/EventType/StateChange> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<eventRecord/Alarm_WebServer_HighCPU> a noria:EventRecord ;
    rdfs:label "Web Server High CPU Alarm"@en ;
    rdfs:comment "Alarm triggered due to sustained high CPU utilization on web server."@en ;
    noria:loggingTime "2024-04-20T09:15:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/Server_Web_PROD01> ;
    noria:logOriginatingManagementSystem <application/MonitoringSystem> ;
    noria:logText "CPU utilization on web-prod01 exceeded 90% for 15 minutes."@en ;
    dcterms:type <kos/Notification/EventType/ThresholdCrossingAlert> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Major> ;
    noria:alarmProposedRepairAction <operationPlan/RestartWebServerService> .

<eventRecord/Log_Firewall_BlockedAttack> a noria:EventRecord ;
    rdfs:label "Firewall Blocked Attack Log"@en ;
