    rdfs:comment "Procedure for temporary disk space recovery on a server."@en ;
    noria:operationPlanPreCondition <actionPreCondition/DiskFull> ;
    noria:operationPlanPostCondition <actionPostCondition/DiskSpaceRecovered> .

<actionPreCondition/DiskFull> a noria:ActionPreCondition ;
    rdfs:label "Disk Full"@en ;
    rdfs:comment "Condition: A disk partition is 100% full, impacting service."@en .

<actionPostCondition/DiskSpaceRecovered> a noria:ActionPostCondition ;
    rdfs:label "Disk Space Recovered"@en ;
    rdfs:comment "Outcome: Sufficient disk space recovered to restore service, and partition usage is below critical threshold."@en .

<eventRecord/Log_DiskCleanup_Start> a noria:EventRecord ;
