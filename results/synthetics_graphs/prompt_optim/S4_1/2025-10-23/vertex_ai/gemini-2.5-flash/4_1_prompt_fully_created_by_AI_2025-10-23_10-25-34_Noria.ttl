# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# --- Ontology management ---
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# --- Domain specific ---
@prefix time: <http://www.w3.org/2006/time#> .
@prefix bot: <https://w3id.org/bot#> .
@prefix gn: <https://www.geonames.org/ontology#> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix log: <https://w3id.org/sepses/ns/log#> .
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .
@prefix seas: <https://w3id.org/seas/> .
@prefix pep: <https://w3id.org/pep/> .
@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> .
@prefix devopsprod: <http://w3id.org/devops-infra/product#> .

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Knowledge Graph Instances
# =============================================================================

# --- Agents (foaf:Agent and org:OrganizationalUnit) ---
# Individuals and Teams responsible for managing resources, applications, and handling incidents.

<agent/Team_NetworkOperations> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team responsible for the day-to-day operation and maintenance of the network infrastructure."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "For critical issues, use the dedicated hotline. For non-critical, open a ticket."@en .

<agent/Team_ApplicationSupport> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team responsible for supporting business applications."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "All application-related issues must be reported via the ticketing system."@en .

<agent/Team_SecurityOperations> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Immediate notification required for any suspected security breach."@en .

<agent/Team_DatabaseAdmin> a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Database Administration Team"@en ;
    rdfs:comment "Team managing and maintaining all corporate databases."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <kos/org/agent-contact-method/Email> .

<agent/Person_AliceSmith> a foaf:Agent ;
    rdfs:label "Alice Smith"@en ;
    rdfs:comment "Lead Network Engineer."@en ;
    foaf:mbox <mailto:alice.smith@example.com> ;
    foaf:phone "+1-555-123-4567" .

<agent/Person_BobJohnson> a foaf:Agent ;
    rdfs:label "Bob Johnson"@en ;
    rdfs:comment "Senior Application Developer."@en ;
    foaf:mbox <mailto:bob.johnson@example.com> .

<agent/Person_CharlieBrown> a foaf:Agent ;
    rdfs:label "Charlie Brown"@en ;
    rdfs:comment "Security Analyst."@en ;
    foaf:mbox <mailto:charlie.brown@example.com> .

<agent/Person_DianaPrince> a foaf:Agent ;
    rdfs:label "Diana Prince"@en ;
    rdfs:comment "Database Administrator."@en ;
    foaf:mbox <mailto:diana.prince@example.com> .

