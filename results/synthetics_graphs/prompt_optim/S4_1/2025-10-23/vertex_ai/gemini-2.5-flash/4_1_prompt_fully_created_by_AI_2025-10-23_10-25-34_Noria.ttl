# --- Operation Plans (noria:OperationPlan) ---
# Standardized procedures for IT operations.

<operationPlan/ReplaceSFPModule> a noria:OperationPlan ;
    rdfs:label "SFP Module Replacement Procedure"@en ;
    rdfs:comment "Standard operating procedure for replacing a faulty SFP module in a network device."@en ;
    skos:example "1. Identify faulty SFP. 2. Verify spare availability. 3. Remove old SFP. 4. Insert new SFP. 5. Verify link status."@en ;
    noria:operationPlanPreCondition <actionPreCondition/SFPFaultIdentified> ;
    noria:operationPlanPostCondition <actionPostCondition/LinkOperational> .

<actionPreCondition/SFPFaultIdentified> a noria:ActionPreCondition ;
    rdfs:label "SFP Fault Identified"@en ;
    rdfs:comment "Condition: Network interface is down, and diagnostics point to SFP module failure."@en .

<actionPostCondition/LinkOperational> a noria:ActionPostCondition ;
    rdfs:label "Link Operational"@en ;
    rdfs:comment "Outcome: Network interface is up, and traffic is flowing normally."@en .

<operationPlan/RestartWebServerService> a noria:OperationPlan ;
    rdfs:label "Web Server Service Restart Procedure"@en ;
    rdfs:comment "Procedure to restart the web server application service in case of performance issues."@en ;
    skos:example "1. Check logs for errors. 2. Attempt graceful restart. 3. Force restart if necessary. 4. Monitor application health."@en ;
    noria:operationPlanPreCondition <actionPreCondition/WebServerHighCPU> ;
    noria:operationPlanPostCondition <actionPostCondition/WebServerCPUNormalized> .

<actionPreCondition/WebServerHighCPU> a noria:ActionPreCondition ;
    rdfs:label "Web Server High CPU"@en ;
    rdfs:comment "Condition: Web server CPU utilization is consistently above 80%."@en .

<actionPostCondition/WebServerCPUNormalized> a noria:ActionPostCondition ;
    rdfs:label "Web Server CPU Normalized"@en ;
    rdfs:comment "Outcome: Web server CPU utilization returns to normal levels (below 50%)."@en .

<operationPlan/FirewallRuleUpdate> a noria:OperationPlan ;
    rdfs:label "Firewall Rule Update Procedure"@en ;
    rdfs:comment "Standard procedure for adding or modifying firewall rules."@en ;
    noria:operationPlanPreCondition <actionPreCondition/ChangeRequestApproved> ;
    noria:operationPlanPostCondition <actionPostCondition/RuleAppliedAndVerified> .

<actionPreCondition/ChangeRequestApproved> a noria:ActionPreCondition ;
    rdfs:label "Change Request Approved"@en ;
    rdfs:comment "Condition: A change request for firewall rule modification has been formally approved."@en .

<actionPostCondition/RuleAppliedAndVerified> a noria:ActionPostCondition ;
    rdfs:label "Rule Applied and Verified"@en ;
    rdfs:comment "Outcome: New firewall rule is applied and verified to be functioning as expected without unintended side effects."@en .

# --- Document Attachments (noria:DocumentAttachment) ---
# Files attached to tickets or requests.

<documentAttachment/NetworkDiagram_PAR01> a noria:DocumentAttachment ;
    rdfs:label "Paris DC Network Diagram"@en ;
    rdfs:comment "Diagram of the network topology in Paris Data Center."@en ;
    dcterms:created "2023-10-01T09:00:00Z"^^xsd:dateTime ;
    dcterms:format "application/pdf" ;
