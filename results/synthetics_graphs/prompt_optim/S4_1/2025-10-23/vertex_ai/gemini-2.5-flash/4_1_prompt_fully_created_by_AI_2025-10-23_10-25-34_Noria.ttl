<procedureExecutionContainer/DiskCleanup_EmailServer> a pep:ProcedureExecutionContainer ;
    rdfs:label "Disk Cleanup on Email Server"@en ;
    rdfs:comment "Container for actions related to temporary disk space cleanup on Email Server PROD01."@en ;
    pep:hasProcedure <operationPlan/TemporaryDiskCleanup> ;
    pep:member <eventRecord/Log_DiskCleanup_Start> ;
    pep:member <eventRecord/Log_DiskCleanup_End> .

