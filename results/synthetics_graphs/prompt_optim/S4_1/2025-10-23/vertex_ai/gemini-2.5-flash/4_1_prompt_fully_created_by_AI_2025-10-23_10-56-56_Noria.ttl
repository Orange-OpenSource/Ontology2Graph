# --- Network Interfaces (noria:NetworkInterface) ---
<networkinterface/DNS_Server_01_Eth0> a noria:NetworkInterface ;
    rdfs:label "eth0 on DNS Server 01"@en ;
    rdfs:comment "Primary network interface for DNS Server 01."@en ;
    noria:networkInterfaceOf <resource/DNS_Server_01> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "100"^^xsd:int ;
    noria:networkInterfaceConnects <networklink/DNS_to_Core_Switch> .

<networkinterface/Core_Router_01_Gi0_0_1> a noria:NetworkInterface ;
    rdfs:label "GigabitEthernet0/0/1 on Core Router 01"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal network."@en ;
    noria:networkInterfaceOf <resource/Core_Router_01> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "50"^^xsd:int ;
    noria:networkInterfaceConnects <networklink/Core_Router_to_Firewall> .

<networkinterface/Firewall_DMZ_01_Eth1> a noria:NetworkInterface ;
    rdfs:label "Ethernet1 on DMZ Firewall 01"@en ;
    rdfs:comment "Interface connecting DMZ Firewall 01 to the Core Router."@en ;
    noria:networkInterfaceOf <resource/Firewall_DMZ_01> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Physical> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects <networklink/Core_Router_to_Firewall> .

<networkinterface/Web_VM_Eth0> a noria:NetworkInterface ;
    rdfs:label "eth0 on Web Server VM 01"@en ;
    rdfs:comment "Virtual network interface for Web Server VM 01."@en ;
    noria:networkInterfaceOf <resource/Virtual_Machine_Web_01> ;
    noria:networkInterfaceType <kos/NetworkInterface/type/Virtual> ;
    noria:networkInterfaceAdministrativeStatus <kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <kos/Resource/OperationalState/Up> .

# --- Network Links (noria:NetworkLink) ---
<networklink/DNS_to_Core_Switch> a noria:NetworkLink ;
    rdfs:label "Link from DNS Server 01 to Core Switch"@en ;
    rdfs:comment "Physical Ethernet link between DNS Server 01 and the core network switch (represented by Core Router 01 for simplicity)."@en ;
    noria:networkLinkId "NL-DNS-CR-01" ;
    noria:networkLinkType "Ethernet 10Gbps" ;
    noria:networkLinkInstallationDate "2023-01-15T10:15:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/DNS_Server_01> ;
    noria:networkLinkTerminationResourceDestination <resource/Core_Router_01> ;
    noria:resourceManagedBy <agent/TechCorp_NOC_Team> .

<networklink/Core_Router_to_Firewall> a noria:NetworkLink ;
    rdfs:label "Link from Core Router 01 to DMZ Firewall 01"@en ;
    rdfs:comment "Physical link connecting the core router to the DMZ firewall."@en ;
    noria:networkLinkId "NL-CR-FW-01" ;
    noria:networkLinkType "Fiber Optic 40Gbps" ;
    noria:networkLinkInstallationDate "2023-05-20T09:15:00Z"^^xsd:dateTime ;
    noria:networkLinkTerminationResourceOrigin <resource/Core_Router_01> ;
    noria:networkLinkTerminationResourceDestination <resource/Firewall_DMZ_01> ;
    noria:resourceManagedBy <agent/TechCorp_NOC_Team> .

