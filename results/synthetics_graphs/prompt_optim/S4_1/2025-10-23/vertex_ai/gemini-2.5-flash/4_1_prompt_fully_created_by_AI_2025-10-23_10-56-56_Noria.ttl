    noria:networkInterfaceLaserRxLowPowerWarningThreshold "-10"^^xsd:int .

<applicationmodule/Corporate_Website_Prod>
    noria:applicationModuleAdministrationLeader <agent/Jane_Smith> ;
    noria:applicationModuleSupportLeader <agent/Jane_Smith> .

