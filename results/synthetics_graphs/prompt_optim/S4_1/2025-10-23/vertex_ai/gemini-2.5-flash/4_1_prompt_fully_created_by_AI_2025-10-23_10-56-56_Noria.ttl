# --- Operation Plans (noria:OperationPlan) ---
<operationplan/DNS_Server_Troubleshooting> a noria:OperationPlan ;
    rdfs:label "DNS Server Troubleshooting Guide"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving DNS server issues."@en ;
    skos:example "Check network connectivity, verify DNS service status, inspect logs, restart service."@en ;
    noria:operationPlanPreCondition <actionprecondition/DNS_Unreachable_Precondition> ;
    noria:operationPlanPostCondition <actionpostcondition/DNS_Service_Restored_Postcondition> .

<operationplan/Web_Server_Performance_Tuning> a noria:OperationPlan ;
    rdfs:label "Web Server Performance Tuning Procedure"@en ;
    rdfs:comment "Procedure for optimizing web server performance under high load."@en ;
    skos:example "Analyze access logs, optimize database queries, adjust web server configuration, scale resources."@en ;
    noria:operationPlanPreCondition <actionprecondition/High_CPU_Load_Precondition> ;
    noria:operationPlanPostCondition <actionpostcondition/Normal_CPU_Load_Postcondition> .

# --- Action Pre/Post Conditions (noria:ActionPreCondition, noria:ActionPostCondition) ---
<actionprecondition/DNS_Unreachable_Precondition> a noria:ActionPreCondition ;
    rdfs:label "DNS Server Unreachable Pre-condition"@en ;
    rdfs:comment "Condition: DNS server is not responding to network requests (e.g., ping, DNS queries)."@en ;
    skos:example "Ping to dns01.techcorp.com fails; nslookup for internal hosts fails."@en .

<actionpostcondition/DNS_Service_Restored_Postcondition> a noria:ActionPostCondition ;
    rdfs:label "DNS Service Restored Post-condition"@en ;
    rdfs:comment "Outcome: DNS server is reachable and successfully resolving names."@en ;
    skos:example "Ping to dns01.techcorp.com succeeds; nslookup for internal hosts succeeds."@en .

<actionprecondition/High_CPU_Load_Precondition> a noria:ActionPreCondition ;
    rdfs:label "High CPU Load Pre-condition"@en ;
    rdfs:comment "Condition: Web server VM CPU utilization consistently above 90%."@en ;
    skos:example "Monitoring system reports CPU > 90% for 15 minutes."@en .

<actionpostcondition/Normal_CPU_Load_Postcondition> a noria:ActionPostCondition ;
    rdfs:label "Normal CPU Load Post-condition"@en ;
    rdfs:comment "Outcome: Web server VM CPU utilization returns to normal levels (e.g., below 50%)."@en ;
    skos:example "Monitoring system reports CPU < 50% for 30 minutes."@en .

# --- Connecting Events to Procedures/Actions ---
# Example: The DNS outage trouble ticket might trigger a procedure execution.
# The EventRecord for Firewall config change is related to a ChangeRequest.
<changerequest/CR-20240418-002>
    dcterms:relation <eventrecord/Firewall_Config_Change_001> . # Direct relation from CR to the log of its execution

<troubleticket/TT-20240420-001>
    noria:documentStatusHistory <eventrecord/DNS_Outage_Log_001> . # The initial event that led to the ticket

# Example of a procedure execution container for a trouble ticket
# A trouble ticket itself is a pep:ProcedureExecutionContainer
<troubleticket/TT-20240420-001>
    pep:hasProcedure <operationplan/DNS_Server_Troubleshooting> .

# Anomaly Pattern (example)
<anomalypattern/DNS_Unreachable_Pattern> a noria:AnomalyPattern ;
    rdfs:label "DNS Server Unreachable Pattern"@en ;
    rdfs:comment "Pattern indicating a critical DNS service failure, characterized by host unreachability and DNS query failures."@en ;
    folio:hasCause "Power failure or network isolation of primary DNS server."@en ;
    folio:hasEffect "Corporate services become unavailable due to name resolution failure."@en ;
    skos:example "Correlates 'DNS Server 01 Unreachable Log' with 'Corporate Website Slow Performance' and 'Secure Remote Access Failure' events."@en .

# Linking the anomaly pattern to the trouble ticket
<troubleticket/TT-20240420-001>
    dcterms:conformsTo <anomalypattern/DNS_Unreachable_Pattern> .

# Further connections to increase density
<resource/DNS_Server_01>
    noria:resourceForApplication <application/DNS_Service> .

<resource/Core_Router_01>
    noria:resourceForApplication <application/Internal_Monitoring_System> . # Router is part of the monitoring system's infrastructure

<resource/Firewall_DMZ_01>
    noria:resourceForApplication <application/Corporate_Website> . # Firewall protects the website

<application/Corporate_Website>
    noria:elementManagedBy <agent/TechCorp_App_Support> .

<application/Internal_Monitoring_System>
    noria:elementManagedBy <agent/TechCorp_NOC_Team> .

<application/DNS_Service>
    noria:elementManagedBy <agent/TechCorp_Server_Ops> .

<agent/TechCorp_NOC_Team>
    noria:agentManagesResource <resource/Core_Router_01> ;
    noria:agentManagesResource <networklink/DNS_to_Core_Switch> .

<agent/TechCorp_Server_Ops>
    noria:agentManagesResource <resource/DNS_Server_01> ;
    noria:agentManagesResource <resource/Virtual_Host_01> ;
    noria:agentManagesResource <resource/Virtual_Machine_Web_01> ;
    noria:agentManagesResource <resource/Virtual_Machine_DB_01> .

<agent/TechCorp_App_Support>
    noria:agentManagesResource <resource/Virtual_Machine_Web_01> ;
    noria:agentManagesResource <resource/Virtual_Machine_DB_01> .

<agent/TechCorp_Security_Team>
    noria:agentManagesResource <resource/Firewall_DMZ_01> .

# Example of a correlated execution for a trouble ticket note
<troubleticketnote/TT-20240420-001-Note-02>
    noria:troubleTicketNoteCorrelatedExecution <eventrecord/DNS_Outage_Log_001> . # The note is about the action taken, which might be logged.

# Another event record for the resolution of the DNS outage
<eventrecord/DNS_Service_Restored_Log_001> a noria:EventRecord ;
    rdfs:label "DNS Server 01 Service Restored Log"@en ;
    rdfs:comment "Log entry indicating DNS Server 01 service has been restored after power supply replacement."@en ;
    noria:loggingTime "2024-04-20T10:25:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/DNS_Server_01> ;
    noria:logOriginatingManagementSystem <application/Internal_Monitoring_System> ;
    noria:logOriginatingAgent <agent/TechCorp_Server_Ops> ;
    noria:logText "INFO: Host dns01.techcorp.com is UP - PING OK - Packet loss = 0%" ;
    dcterms:type <kos/Notification/EventType/OperationalAlarm> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Clear> ;
    noria:alarmMitigatedBy <troubleticket/TT-20240420-001> . # The ticket itself is the container for the resolution process

<troubleticket/TT-20240420-001>
    noria:documentStatusHistory <eventrecord/DNS_Service_Restored_Log_001> .

# Final status update for the trouble ticket
<troubleticket/TT-20240420-001>
    noria:troubleTicketStatusCurrent <kos/TroubleTicket/status/Resolved> ;
    noria:troubleTicketPlannedRestorationDateTime "2024-04-20T10:30:00Z"^^xsd:dateTime .

