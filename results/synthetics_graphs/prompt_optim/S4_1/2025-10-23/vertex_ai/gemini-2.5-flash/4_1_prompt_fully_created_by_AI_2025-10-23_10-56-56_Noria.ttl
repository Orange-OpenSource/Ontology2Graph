# --- Services (noria:Service) ---
<service/Internet_Access_Service> a noria:Service ;
    rdfs:label "Corporate Internet Access Service"@en ;
    rdfs:comment "End-to-end service providing internet access to corporate users."@en ;
    noria:serviceType <kos/service/type/CustomerFacingService> ;
    seas:subSystemOf <applicationmodule/Corporate_Website_Prod> ; # Example of linking to an application module
    seas:subSystemOf <applicationmodule/DNS_Service_Prod> .

<service/Secure_Remote_Access> a noria:Service ;
    rdfs:label "Secure Remote Access Service"@en ;
    rdfs:comment "Service enabling secure remote access for employees."@en ;
    noria:serviceType <kos/service/type/ResourceFacingService> ;
    seas:subSystemOf <application/Internal_Monitoring_System> . # Example of linking to an application

# --- Event Records (noria:EventRecord) ---
<eventrecord/DNS_Outage_Log_001> a noria:EventRecord ;
    rdfs:label "DNS Server 01 Unreachable Log"@en ;
    rdfs:comment "Log entry indicating DNS Server 01 became unreachable."@en ;
    noria:loggingTime "2024-04-20T08:00:00Z"^^xsd:dateTime ;
    noria:logOriginatingManagedObject <resource/DNS_Server_01> ;
    noria:logOriginatingManagementSystem <application/Internal_Monitoring_System> ;
    noria:logText "CRITICAL: Host dns01.techcorp.com is DOWN - PING CRITICAL - Packet loss = 100%" ;
    dcterms:type <kos/Notification/EventType/OperationalAlarm> ;
    noria:alarmSeverity <Notification/Severity/PerceivedSeverity/Critical> .

<eventrecord/Router_Interface_Down_001> a noria:EventRecord ;
    rdfs:label "Core Router Interface Down Log"@en ;
    rdfs:comment "Log entry indicating an interface on Core Router 01 went down."@en ;
