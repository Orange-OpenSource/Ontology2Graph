# Add a new anomaly pattern for chat platform lag
<anomalypattern/Chat_Lag_Pattern> a noria:AnomalyPattern ;
    rdfs:label "Chat Platform Lag Pattern"@en ;
    rdfs:comment "Pattern indicating performance degradation in the chat platform, characterized by message delivery delays and high queue backlogs."@en ;
    folio:hasCause "Database performance issues or insufficient server resources."@en ;
    folio:hasEffect "Disrupted internal communication and reduced productivity."@en ;
    skos:example "Correlates 'Chat Platform High Latency Log' with user reports of delays."@en .

<troubleticket/TT-20240425-006>
    dcterms:conformsTo <anomalypattern/Chat_Lag_Pattern> .

# Add a new operation plan for chat platform troubleshooting
<operationplan/Chat_Platform_Troubleshooting> a noria:OperationPlan ;
    rdfs:label "Chat Platform Troubleshooting Guide"@en ;
    rdfs:comment "Standard operating procedure for diagnosing and resolving chat platform performance issues."@en ;
    skos:example "Check database health, optimize queries, scale VM resources, restart application services."@en ;
    noria:operationPlanPreCondition <actionprecondition/Chat_Lag_Precondition> ;
    noria:operationPlanPostCondition <actionpostcondition/Chat_Performance_Restored_Postcondition> .

<actionprecondition/Chat_Lag_Precondition> a noria:ActionPreCondition ;
    rdfs:label "Chat Platform Lag Pre-condition"@en ;
    rdfs:comment "Condition: Users report message delivery delays, and monitoring shows high message queue backlog."@en .

<actionpostcondition/Chat_Performance_Restored_Postcondition> a noria:ActionPostCondition ;
    rdfs:label "Chat Performance Restored Post-condition"@en ;
    rdfs:comment "Outcome: Message delivery is real-time, and message queue backlog is within normal limits."@en .

<troubleticket/TT-20240425-006>
    pep:hasProcedure <operationplan/Chat_Platform_Troubleshooting> .

