# Add more details to existing entities
<resource/DNS_Server_01>
    noria:virtualServerStatus <kos/Resource/OperationalState/Up> . # Even if it's a physical server, it can have a 'virtual' status in some contexts

<networkinterface/Core_Router_01_Gi0_0_1>
    noria:networkInterfaceLaserTxOpticalPower "-2"^^xsd:int ;
    noria:networkInterfaceLaserRxOpticalPower "-3"^^xsd:int ;
