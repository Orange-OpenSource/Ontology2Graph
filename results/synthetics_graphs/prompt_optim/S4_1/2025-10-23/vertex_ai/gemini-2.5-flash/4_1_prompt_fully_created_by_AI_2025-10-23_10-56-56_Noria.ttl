    rdfs:comment "High-performance rack server for data centers."@en ;
    noria:productManufacturedBy <org/Dell_Technologies> .

<productmodel/PaloAlto_PA-5220> a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220 Firewall"@en ;
    rdfs:comment "Next-generation firewall for data center security."@en ;
    noria:productManufacturedBy <org/PaloAlto_Networks> .

<productmodel/VMware_ESXi> a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy <org/VMware_Inc> .

<org/Cisco_Systems> a org:Organization ;
    rdfs:label "Cisco Systems Inc."@en ;
    rdfs:comment "Multinational technology conglomerate that develops, manufactures, and sells networking hardware, software, telecommunications equipment and other high-technology services and products."@en .

<org/Dell_Technologies> a org:Organization ;
    rdfs:label "Dell Technologies Inc."@en ;
    rdfs:comment "American multinational technology company that develops, sells, repairs, and supports computers and related products and services."@en .

<org/PaloAlto_Networks> a org:Organization ;
    rdfs:label "Palo Alto Networks Inc."@en ;
    rdfs:comment "American multinational cybersecurity company."@en .

<org/VMware_Inc> a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Cloud computing and virtualization technology company."@en .

# --- Locations (bot:Site, noria:Room, noria:Locus) ---
<site/Paris_DC> a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center for TechCorp's European operations."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix" ;
    noria:sitePrincipalAddressCityName "Paris" ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCountry "FR" ;
    wgs84_pos:lat "48.869"^^xsd:float ;
    wgs84_pos:long "2.334"^^xsd:float .

<room/Paris_DC_ServerRoom_A> a noria:Room ;
    rdfs:label "Paris DC Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace <site/Paris_DC> .

<locus/Paris_DC_Rack_A1_U24> a noria:Locus ;
    rdfs:label "Rack A1, Unit 24 in Paris DC Server Room A"@en ;
    rdfs:comment "Specific location for a server within a rack."@en ;
    noria:locusLine "A1" ;
    noria:locusRow "24" ;
    bot:hasSpace <room/Paris_DC_ServerRoom_A> .

<locus/Paris_DC_Rack_B5_U10> a noria:Locus ;
    rdfs:label "Rack B5, Unit 10 in Paris DC Server Room A"@en ;
    rdfs:comment "Specific location for a network device within a rack."@en ;
    noria:locusLine "B5" ;
    noria:locusRow "10" ;
    bot:hasSpace <room/Paris_DC_ServerRoom_A> .

<locus/Paris_DC_Rack_C2_U1> a noria:Locus ;
    rdfs:label "Rack C2, Unit 1 in Paris DC Server Room A"@en ;
    rdfs:comment "Specific location for a firewall within a rack."@en ;
    noria:locusLine "C2" ;
    noria:locusRow "1" ;
    bot:hasSpace <room/Paris_DC_ServerRoom_A> .

