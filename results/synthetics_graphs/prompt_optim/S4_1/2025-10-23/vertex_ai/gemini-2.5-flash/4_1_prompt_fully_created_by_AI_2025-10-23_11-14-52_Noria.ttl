# =============================================================================
# Operation Plans (noria:OperationPlan)
# =============================================================================

noria:OperationPlan_CheckFiberLink a noria:OperationPlan ;
    rdfs:label "Check Fiber Link Procedure"@en ;
    rdfs:comment "Standard operating procedure for diagnosing fiber optic link issues."@en ;
    skos:example "1. Verify physical connection. 2. Check optical power levels. 3. Test with loopback."@en ;
    noria:operationPlanPreCondition noria:PreCond_FiberLinkDown ;
    noria:operationPlanPostCondition noria:PostCond_FiberLinkStatusKnown .

noria:OperationPlan_CheckRouterConfig a noria:OperationPlan ;
    rdfs:label "Check Router Configuration Procedure"@en ;
    rdfs:comment "Procedure to verify router configuration for network connectivity issues."@en ;
    skos:example "1. Login to router. 2. Show running-config. 3. Check interface status. 4. Verify routing table."@en ;
    noria:operationPlanPreCondition noria:PreCond_NetworkIssueSuspected ;
    noria:operationPlanPostCondition noria:PostCond_RouterConfigVerified .

noria:OperationPlan_CRMDBRestart a noria:OperationPlan ;
    rdfs:label "CRM Database Restart Procedure"@en ;
    rdfs:comment "Standard procedure for restarting the CRM database service in case of performance issues."@en ;
    skos:example "1. Notify users. 2. Stop application services. 3. Stop database service. 4. Start database service. 5. Start application services. 6. Verify functionality."@en ;
    noria:operationPlanPreCondition noria:PreCond_CRMSlowResponse ;
    noria:operationPlanPostCondition noria:PostCond_CRMPerformanceRestored .

# =============================================================================
# Action Conditions (noria:ActionPreCondition, noria:ActionPostCondition)
# =============================================================================

noria:PreCond_FiberLinkDown a noria:ActionPreCondition ;
    rdfs:label "Fiber Link Down Pre-Condition"@en ;
    rdfs:comment "Condition: A fiber optic network link is reported as down or experiencing signal loss."@en ;
    skos:example "EventRecord with alarmSeverity Critical and logText indicating 'fiber link down'."@en .

noria:PostCond_FiberLinkStatusKnown a noria:ActionPostCondition ;
    rdfs:label "Fiber Link Status Known Post-Condition"@en ;
    rdfs:comment "Outcome: The administrative and operational status of the fiber link is determined, and cause of issue identified."@en ;
    skos:example "networkInterfaceOperationalStatus is 'up' or 'down' and problemCategory is identified."@en .

noria:PreCond_NetworkIssueSuspected a noria:ActionPreCondition ;
    rdfs:label "Network Issue Suspected Pre-Condition"@en ;
    rdfs:comment "Condition: General network connectivity issues or routing problems are suspected."@en ;
    skos:example "TroubleTicket with troubleTicketCategory 'Inaccessible destination'."@en .

noria:PostCond_RouterConfigVerified a noria:ActionPostCondition ;
    rdfs:label "Router Configuration Verified Post-Condition"@en ;
    rdfs:comment "Outcome: Router configuration has been reviewed and confirmed to be correct or issues identified."@en ;
    skos:example "No configuration errors found, or specific configuration changes identified as root cause."@en .

noria:PreCond_CRMSlowResponse a noria:ActionPreCondition ;
    rdfs:label "CRM Slow Response Pre-Condition"@en ;
    rdfs:comment "Condition: CRM application is experiencing significant performance degradation or unresponsiveness."@en ;
    skos:example "EventRecord with alarmSeverity Warning or Major for CRM application response time."@en .

noria:PostCond_CRMPerformanceRestored a noria:ActionPostCondition ;
    rdfs:label "CRM Performance Restored Post-Condition"@en ;
    rdfs:comment "Outcome: CRM application response times return to normal and user complaints cease."@en ;
    skos:example "APM tool reports normal response times, and TroubleTicket status changes to 'Resolved'."@en .

# =============================================================================
# End of Graph
# =============================================================================
