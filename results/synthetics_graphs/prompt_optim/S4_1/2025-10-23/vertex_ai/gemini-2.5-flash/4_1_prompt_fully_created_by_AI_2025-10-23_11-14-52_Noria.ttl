# === PREFIXES ================================================================

# --- Basic ---
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

# --- Ontology management ---
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <https://schema.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# --- Domain specific ---
@prefix qudt: <http://data.qudt.org/qudt/owl/1.0.0/qudt.owl#> .  # Quantities, Units, Dimensions and Types (QUDT)
@prefix qudt-unit: <http://data.qudt.org/qudt/owl/1.0.0/unit.owl#> .  #QUDT units
@prefix time: <http://www.w3.org/2006/time#> .  # OWL-Time

@prefix bot:  <https://w3id.org/bot#> .  # Building Topology Ontology
@prefix gn: <https://www.geonames.org/ontology#> .  # GeoNames Ontology
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .  # WGS84 Geo Positioning

@prefix BBO: <https://www.irit.fr/recherches/MELODI/ontologies/BBO#> .  # BPMN 2.0 Based Ontology for Business Process Representation
@prefix org: <http://www.w3.org/ns/org#> .  # The Organization Ontology

@prefix log: <https://w3id.org/sepses/ns/log#> .  # a.k.a. SLOGERT
@prefix folio: <http://IBCNServices.github.io/Folio-Ontology/Folio.owl#> .  # Failure Mode and Effect Analysis combined with Anomaly Ontology (FOLIO)

@prefix ssn: <http://www.w3.org/ns/ssn/>.  # Semantic Sensor Network (SSN) Ontology
@prefix seas: <https://w3id.org/seas/>.  # Smart Energy Aware Systems (SEAS)
@prefix pep: <https://w3id.org/pep/>.  # SEAS Procedure Execution ontology
@prefix saref: <http://ontology.tno.nl/saref#>.  #SAREF smart building appliances ontology

@prefix observable: <https://unifiedcyberontology.org/ontology/uco/observable#> . # Unified Cybersecurity Ontology (UCO)

@prefix devopsprod: <http://w3id.org/devops-infra/product#> .  # DevOps-Infra, Ontology for the representation of the business offering of a company, including the offered services and microservices

# --- NORIA ---
@prefix noria: <https://w3id.org/noria/ontology/> .
@base <https://w3id.org/noria/> .

# =============================================================================
# Agents (foaf:Agent, org:OrganizationalUnit, foaf:Person)
# =============================================================================

noria:Agent_DNSAdminTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "DNS Admin Team"@en ;
    rdfs:comment "Team responsible for DNS server management and resolution of related incidents."@en ;
    noria:agentWorkingHours "8:00 am - 6:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    noria:agentInstructions "Contact via ticketing system for non-critical issues, direct call for critical outages."@en .

noria:Agent_NetworkOpsTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Network Operations Team"@en ;
    rdfs:comment "Team managing network infrastructure, including routers and switches."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> ;
    noria:agentInstructions "Always use hotline for network incidents."@en .

noria:Agent_AppSupportTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Application Support Team"@en ;
    rdfs:comment "Team providing L2 support for critical business applications."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/TicketingSystem> ;
    noria:agentInstructions "Submit a ticket for all application-related issues."@en .

noria:Agent_SecurityTeam a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Security Operations Center (SOC)"@en ;
    rdfs:comment "Team responsible for monitoring and responding to security incidents."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/SIEMAlert> ;
    noria:agentInstructions "Automated alerts are preferred, follow up with secure communication channels."@en .

noria:Agent_JohnDoe a foaf:Agent, foaf:Person ;
    rdfs:label "John Doe"@en ;
    rdfs:comment "Lead Network Engineer, responsible for core routing infrastructure."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Email> ;
    foaf:mbox "mailto:john.doe@example.com" .

noria:Agent_JaneSmith a foaf:Agent, foaf:Person ;
    rdfs:label "Jane Smith"@en ;
    rdfs:comment "Senior Application Developer, specializing in the CRM system."@en ;
    noria:agentWorkingHours "9:00 am - 5:00 pm (Mon-Fri)"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/InternalChat> ;
    foaf:mbox "mailto:jane.smith@example.com" .

noria:Agent_CustomerSupport a foaf:Agent, org:OrganizationalUnit ;
    rdfs:label "Customer Support Center"@en ;
    rdfs:comment "First line of contact for customer-reported issues."@en ;
    noria:agentWorkingHours "24/7"@en ;
    noria:agentPreferredContactMethod <https://w3id.org/noria/kos/org/agent-contact-method/Phone> .

# =============================================================================
# Product Models (noria:ProductModel)
# =============================================================================

noria:ProductModel_DellR740 a noria:ProductModel ;
    rdfs:label "Dell PowerEdge R740"@en ;
    rdfs:comment "High-performance rack server model."@en ;
    noria:productManufacturedBy noria:Org_Dell .

noria:ProductModel_CiscoASR1000 a noria:ProductModel ;
    rdfs:label "Cisco ASR 1000 Series Router"@en ;
    rdfs:comment "Enterprise-class aggregation services router."@en ;
    noria:productManufacturedBy noria:Org_Cisco .

noria:ProductModel_PaloAltoFirewall a noria:ProductModel ;
    rdfs:label "Palo Alto Networks PA-5220"@en ;
    rdfs:comment "Next-generation firewall for data center security."@en ;
    noria:productManufacturedBy noria:Org_PaloAlto .

noria:ProductModel_VMwareESXi a noria:ProductModel ;
    rdfs:label "VMware ESXi Hypervisor"@en ;
    rdfs:comment "Virtualization platform for running virtual machines."@en ;
    noria:productManufacturedBy noria:Org_VMware .

noria:Org_Dell a org:Organization ;
    rdfs:label "Dell Technologies"@en ;
    rdfs:comment "Manufacturer of computer hardware."@en .

noria:Org_Cisco a org:Organization ;
    rdfs:label "Cisco Systems"@en ;
    rdfs:comment "Manufacturer of networking hardware."@en .

noria:Org_PaloAlto a org:Organization ;
    rdfs:label "Palo Alto Networks"@en ;
    rdfs:comment "Manufacturer of cybersecurity products."@en .

noria:Org_VMware a org:Organization ;
    rdfs:label "VMware Inc."@en ;
    rdfs:comment "Provider of cloud computing and virtualization software."@en .

# =============================================================================
# Locations (bot:Site, noria:Room, noria:Locus)
# =============================================================================

noria:Site_ParisDC a bot:Site ;
    rdfs:label "Paris Data Center"@en ;
    rdfs:comment "Primary data center located in Paris."@en ;
    noria:siteId "DC-PAR-01" ;
    noria:siteType "data center" ;
    noria:sitePrincipalAddress "123 Rue de la Paix"@fr ;
    noria:sitePrincipalAddressPostalCode "75002" ;
    noria:sitePrincipalAddressCityName "Paris"@fr ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Rue de la Paix" ;
    wgs84_pos:lat "48.867"^^xsd:float ;
    wgs84_pos:long "2.333"^^xsd:float .

noria:Site_LyonOffice a bot:Site ;
    rdfs:label "Lyon Regional Office"@en ;
    rdfs:comment "Regional office building in Lyon."@en ;
    noria:siteId "OFF-LYN-01" ;
    noria:siteType "office building" ;
    noria:sitePrincipalAddress "45 Avenue Jean Jaurès"@fr ;
    noria:sitePrincipalAddressPostalCode "69007" ;
    noria:sitePrincipalAddressCityName "Lyon"@fr ;
    noria:sitePrincipalAddressCountry "FR" ;
    noria:sitePrincipalAddressStreet "Avenue Jean Jaurès" .

noria:Room_ServerRoomA a noria:Room ;
    rdfs:label "Server Room A"@en ;
    rdfs:comment "Main server room within the Paris Data Center."@en ;
    bot:hasSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    bot:hasSubSpace noria:Locus_RackA1, noria:Locus_RackA2 ;
    bot:hasBuilding noria:Site_ParisDC .

noria:Room_NetworkCloset a noria:Room ;
    rdfs:label "Network Closet 201"@en ;
    rdfs:comment "Network equipment closet in the Lyon Office."@en ;
    bot:hasSpace noria:Locus_WallMount1 ;
    bot:hasSubSpace noria:Locus_WallMount1 ;
    bot:hasBuilding noria:Site_LyonOffice .

noria:Locus_RackA1 a noria:Locus ;
    rdfs:label "Rack A1"@en ;
    rdfs:comment "First rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "1" ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_RackA2 a noria:Locus ;
    rdfs:label "Rack A2"@en ;
    rdfs:comment "Second rack in Server Room A."@en ;
    noria:locusLine "A" ;
    noria:locusRow "2" ;
    bot:hasZone noria:Room_ServerRoomA .

noria:Locus_WallMount1 a noria:Locus ;
    rdfs:label "Wall Mount 1"@en ;
    rdfs:comment "Wall-mounted equipment area in Network Closet 201."@en ;
    noria:locusLine "WM" ;
    noria:locusRow "1" ;
    bot:hasZone noria:Room_NetworkCloset .

# =============================================================================
# Resources (noria:Resource)
# =============================================================================

noria:Resource_DNS01 a noria:Resource ;
    rdfs:label "Corporate DNS Server 01"@en ;
    rdfs:comment "Primary DNS server for corporate network, hosted in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_DNSAdminTeam ;
    noria:resourceHostName "dns01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Server> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.10" ;
    noria:resourceForApplication noria:Application_CorpDNS .

noria:Resource_RouterCore01 a noria:Resource ;
    rdfs:label "Core Router 01"@en ;
    rdfs:comment "Main router for the corporate backbone network in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-core-01.paris.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.1" ;
    noria:resourceForApplication noria:Application_CorpNetwork .

noria:Resource_FirewallDMZ01 a noria:Resource ;
    rdfs:label "DMZ Firewall 01"@en ;
    rdfs:comment "Firewall protecting the DMZ segment in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_SecurityTeam ;
    noria:resourceHostName "fw-dmz-01.paris.example.com" ;
    noria:resourceProductModel noria:ProductModel_PaloAltoFirewall ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Firewall> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA1 ;
    noria:resourceManagementIPAddress "10.0.0.5" ;
    noria:resourceForApplication noria:Application_InternetAccess .

noria:Resource_VMHost01 a noria:Resource ;
    rdfs:label "Virtualization Host 01"@en ;
    rdfs:comment "ESXi host running multiple virtual machines in Paris DC."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:resourceHostName "vmhost-01.paris.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Hypervisor> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2021-08-10T11:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_RackA2 ;
    noria:resourceManagementIPAddress "10.0.0.20" ;
    noria:resourceForApplication noria:Application_VirtualizationPlatform .

noria:Resource_CRMAppVM a noria:Resource ;
    rdfs:label "CRM Application VM"@en ;
    rdfs:comment "Virtual machine hosting the CRM application, running on VMHost01."@en ;
    noria:resourceManagedBy noria:Agent_AppSupportTeam ;
    noria:resourceHostName "crm-app-vm.example.com" ;
    noria:resourceProductModel noria:ProductModel_VMwareESXi ; # This is the hypervisor model, not the VM itself, but for simplicity here.
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/VirtualMachine> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-02-20T16:00:00Z"^^xsd:dateTime ;
    noria:resourceManagementIPAddress "10.0.1.50" ;
    noria:clusterController noria:Resource_VMHost01 ;
    noria:resourceForApplication noria:Application_CRMSystem .

noria:Resource_BranchRouter01 a noria:Resource ;
    rdfs:label "Lyon Branch Router 01"@en ;
    rdfs:comment "Router for the Lyon regional office, connecting to the corporate network."@en ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam ;
    noria:resourceHostName "router-lyon-01.example.com" ;
    noria:resourceProductModel noria:ProductModel_CiscoASR1000 ;
    noria:resourceType <https://w3id.org/noria/kos/Resource/type/Router> ;
    noria:resourceUsageState <https://w3id.org/noria/kos/Resource/LifecycleState/InProduction> ;
    noria:resourceInstallationDate "2023-01-05T09:00:00Z"^^xsd:dateTime ;
    noria:locatedAtLocus noria:Locus_WallMount1 ;
    noria:resourceManagementIPAddress "192.168.10.1" ;
    noria:resourceForApplication noria:Application_CorpNetwork .

# =============================================================================
# Network Components (noria:NetworkInterface, noria:NetworkLink)
# =============================================================================

noria:NI_DNS01_Eth0 a noria:NetworkInterface ;
    rdfs:label "DNS01 Ethernet 0"@en ;
    rdfs:comment "Primary network interface for DNS01 server."@en ;
    noria:networkInterfaceOf noria:Resource_DNS01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NL_DNS01_CoreSwitch .

noria:NI_RouterCore01_Gig0_0_0 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface for Core Router 01 to the internet."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "10"^^xsd:int ;
    noria:networkInterfaceConnects noria:NL_CoreRouter_Internet .

noria:NI_RouterCore01_Gig0_0_1 a noria:NetworkInterface ;
    rdfs:label "RouterCore01 GigabitEthernet0/0/1"@en ;
    rdfs:comment "Interface connecting Core Router 01 to the internal network."@en ;
    noria:networkInterfaceOf noria:Resource_RouterCore01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceRoutingPriorityMetric "20"^^xsd:int ;
    noria:networkInterfaceConnects noria:NL_CoreRouter_Internal .

noria:NI_FirewallDMZ01_Eth1 a noria:NetworkInterface ;
    rdfs:label "FirewallDMZ01 Ethernet 1"@en ;
    rdfs:comment "DMZ facing interface for Firewall DMZ 01."@en ;
    noria:networkInterfaceOf noria:Resource_FirewallDMZ01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NL_Firewall_DMZ .

noria:NI_CRMAppVM_Eth0 a noria:NetworkInterface ;
    rdfs:label "CRMAppVM Ethernet 0"@en ;
    rdfs:comment "Network interface for the CRM Application VM."@en ;
    noria:networkInterfaceOf noria:Resource_CRMAppVM ;
    noria:networkInterfaceType "virtual" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NL_VMHost_Internal .

noria:NI_BranchRouter01_Gig0_0_0 a noria:NetworkInterface ;
    rdfs:label "BranchRouter01 GigabitEthernet0/0/0"@en ;
    rdfs:comment "Uplink interface for Lyon Branch Router 01 to Paris DC."@en ;
    noria:networkInterfaceOf noria:Resource_BranchRouter01 ;
    noria:networkInterfaceType "physical" ;
    noria:networkInterfaceAdministrativeStatus <https://w3id.org/noria/kos/Resource/AdministrativeState/Up> ;
    noria:networkInterfaceOperationalStatus <https://w3id.org/noria/kos/Resource/OperationalState/Up> ;
    noria:networkInterfaceConnects noria:NL_Lyon_Paris_WAN .

noria:NL_DNS01_CoreSwitch a noria:NetworkLink ;
    rdfs:label "DNS01 to Core Switch Link"@en ;
    rdfs:comment "Ethernet link between DNS01 and the core switch in Paris DC."@en ;
    noria:networkLinkId "NL-DNS01-CSW" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkTerminationResource noria:Resource_DNS01, noria:Resource_RouterCore01 ; # Assuming Core Router has an integrated switch or connects to one.
    noria:networkLinkInstallationDate "2022-01-15T10:00:00Z"^^xsd:dateTime .

noria:NL_CoreRouter_Internet a noria:NetworkLink ;
    rdfs:label "Core Router to Internet Uplink"@en ;
    rdfs:comment "High-speed link connecting the corporate network to the internet."@en ;
    noria:networkLinkId "NL-CR01-INT" ;
    noria:networkLinkType "Fiber Optic" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01 ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime .

noria:NL_CoreRouter_Internal a noria:NetworkLink ;
    rdfs:label "Core Router to Internal Network Link"@en ;
    rdfs:comment "Link connecting the core router to the internal LAN segment."@en ;
    noria:networkLinkId "NL-CR01-LAN" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkTerminationResource noria:Resource_RouterCore01, noria:Resource_VMHost01 ;
    noria:networkLinkInstallationDate "2021-03-20T14:30:00Z"^^xsd:dateTime .

noria:NL_Firewall_DMZ a noria:NetworkLink ;
    rdfs:label "Firewall to DMZ Link"@en ;
    rdfs:comment "Link connecting the DMZ firewall to the DMZ network segment."@en ;
    noria:networkLinkId "NL-FW01-DMZ" ;
    noria:networkLinkType "Ethernet" ;
    noria:networkLinkTerminationResource noria:Resource_FirewallDMZ01 ;
    noria:networkLinkInstallationDate "2022-05-01T09:00:00Z"^^xsd:dateTime .

noria:NL_VMHost_Internal a noria:NetworkLink ;
    rdfs:label "VM Host to Internal Network Link"@en ;
    rdfs:comment "Internal virtual network link for VMs on VMHost01."@en ;
    noria:networkLinkId "NL-VMH01-INT" ;
    noria:networkLinkType "Virtual Ethernet" ;
    noria:networkLinkTerminationResource noria:Resource_VMHost01, noria:Resource_CRMAppVM ;
    noria:networkLinkInstallationDate "2021-08-10T11:00:00Z"^^xsd:dateTime .

noria:NL_Lyon_Paris_WAN a noria:NetworkLink ;
    rdfs:label "Lyon-Paris WAN Link"@en ;
    rdfs:comment "Dedicated WAN link connecting Lyon office to Paris Data Center."@en ;
    noria:networkLinkId "NL-LYN-PAR-WAN" ;
    noria:networkLinkType "MPLS VPN" ;
    noria:networkLinkTerminationResourceOrigin noria:Resource_BranchRouter01 ;
    noria:networkLinkTerminationResourceDestination noria:Resource_RouterCore01 ;
    noria:networkLinkInstallationDate "2023-01-05T09:00:00Z"^^xsd:dateTime ;
    noria:resourceManagedBy noria:Agent_NetworkOpsTeam .

# =============================================================================
# Applications (noria:Application)
# =============================================================================

noria:Application_CorpDNS a noria:Application ;
    rdfs:label "Corporate DNS Service"@en ;
    rdfs:comment "Provides name resolution for all internal corporate services."@en ;
    noria:applicationModelIdentifier "CORP-DNS" ;
    noria:applicationNumericalIdentifier "1001"^^xsd:int ;
    noria:applicationShortIdentifier "DNS" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Infrastructure Management" ;
    noria:applicationFunctionalSubDomain "Network Services" .

noria:Application_CorpNetwork a noria:Application ;
    rdfs:label "Corporate Network Infrastructure"@en ;
    rdfs:comment "The underlying network infrastructure connecting all corporate sites and services."@en ;
    noria:applicationModelIdentifier "CORP-NET" ;
    noria:applicationNumericalIdentifier "1002"^^xsd:int ;
    noria:applicationShortIdentifier "CNET" ;
    noria:applicationType <https://w3id.org/noria/kos/application/type/infrastructure> ;
    noria:applicationBusinessImportance <https://w3id.org/noria/kos/application/business-importance/critical> ;
    noria:applicationFunctionalDomain "Infrastructure Management" ;
