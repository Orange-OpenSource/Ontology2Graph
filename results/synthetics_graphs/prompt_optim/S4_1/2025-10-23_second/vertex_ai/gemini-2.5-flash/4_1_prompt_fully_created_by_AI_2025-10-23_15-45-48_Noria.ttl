# Link more agents to resources
foaf:Agent_DNSTeam noria:agentManagesResource noria:Resource_DNS01 .
foaf:Agent_NetworkOps noria:agentManagesResource noria:Resource_RouterCore01, noria:Resource_FirewallDMZ01, noria:Resource_Hypervisor01 .
