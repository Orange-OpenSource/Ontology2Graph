noria:Resource_WebSrv01 a noria:Resource ;
    rdfs:label "Corporate Web Server 01"@en ;
    rdfs:comment "Web server hosting the main corporate website."@en ;
    noria:resourceManagedBy foaf:Agent_AppSupport ;
    noria:resourceHostName "websrv01.corp.example.com" ;
    noria:resourceProductModel noria:ProductModel_DellR740 ;
    noria:resourceLogisticId "ASSET-WEB-001" ;
